# STATUS: ✅ VALIDATED AND TESTED
# - YAML validated against metadata intent (2026-01-08)
# - Fixed: deletion_protection checks changed from 'any' to 'all' operator (must match both Key and Value)
# - All 18 checks configured successfully
# - 0 execution errors (AccessDeniedException warnings are expected - Timestream requires special AWS access)
# - Field paths verified correct
# - Discovery chains verified correct
# - Tested: 2026-01-08
# - Note: Timestream requires special AWS access (only LiveAnalytics customers), so AccessDeniedException is expected
version: '1.0'
provider: aws
service: timestream
services:
  client: timestream-query
  module: boto3.client
discovery:
- discovery_id: aws.timestream-query.describe_endpoints
  calls:
  - action: describe_endpoints
    save_as: response
  emit:
    items_for: '{{ response.Endpoints }}'
    as: item
    item:
      Address: '{{ item.Address }}'
      CachePeriodInMinutes: '{{ item.CachePeriodInMinutes }}'
- discovery_id: aws.timestream-query.describe_account_settings
  calls:
  - action: describe_account_settings
    save_as: response
  emit:
    item:
      ComputeMode: '{{ response.QueryCompute.ComputeMode }}'
      ProvisionedCapacity: '{{ response.QueryCompute.ProvisionedCapacity }}'
- discovery_id: aws.timestream-query.list_scheduled_queries
  calls:
  - action: list_scheduled_queries
    save_as: response
  emit:
    items_for: '{{ response.ScheduledQueries }}'
    as: item
    item:
      Arn: '{{ item.Arn }}'
      Name: '{{ item.Name }}'
      State: '{{ item.State }}'
- discovery_id: aws.timestream-query.describe_scheduled_query
  calls:
  - action: describe_scheduled_query
    save_as: response
    params:
      ScheduledQueryArn: '{{ item.Arn }}'
    for_each: aws.timestream-query.list_scheduled_queries
    on_error: continue
  emit:
    item:
      Arn: '{{ item.Arn }}'
      Name: '{{ response.ScheduledQuery.Name }}'
      QueryString: '{{ response.ScheduledQuery.QueryString }}'
      CreationTime: '{{ response.ScheduledQuery.CreationTime }}'
      State: '{{ response.ScheduledQuery.State }}'
      PreviousInvocationTime: '{{ response.ScheduledQuery.PreviousInvocationTime }}'
      NextInvocationTime: '{{ response.ScheduledQuery.NextInvocationTime }}'
      ScheduleConfiguration: '{{ response.ScheduledQuery.ScheduleConfiguration }}'
      NotificationConfiguration: '{{ response.ScheduledQuery.NotificationConfiguration }}'
      TargetConfiguration: '{{ response.ScheduledQuery.TargetConfiguration }}'
      ScheduledQueryExecutionRoleArn: '{{ response.ScheduledQuery.ScheduledQueryExecutionRoleArn }}'
      KmsKeyId: '{{ response.ScheduledQuery.KmsKeyId }}'
      ErrorReportConfiguration: '{{ response.ScheduledQuery.ErrorReportConfiguration }}'
      LastRunSummary: '{{ response.ScheduledQuery.LastRunSummary }}'
      RecentlyFailedRuns: '{{ response.ScheduledQuery.RecentlyFailedRuns }}'
- discovery_id: aws.timestream-query.list_tags_for_resource
  calls:
  - action: list_tags_for_resource
    save_as: response
    params:
      ResourceARN: '{{ item.Arn }}'
    for_each: aws.timestream-query.list_scheduled_queries
    on_error: continue
  emit:
    items_for: '{{ response.Tags }}'
    as: tag
    item:
      ResourceARN: '{{ item.Arn }}'
      Key: '{{ tag.Key }}'
      Value: '{{ tag.Value }}'
checks:
- rule_id: aws.timestream.resource.timestream_ingestion_secure_protocol_configured
  for_each: aws.timestream-query.describe_endpoints
  conditions:
    var: item.Address
    op: contains
    value: https
- rule_id: aws.timestream.database.check_encryption_at_rest_enabled
  for_each: aws.timestream-query.describe_account_settings
  conditions:
    var: item.ComputeMode
    op: exists
    value: null
- rule_id: aws.timestream.resource.security_configuration_compliance_configured
  for_each: aws.timestream-query.describe_endpoints
  conditions:
    all:
    - var: item.Address
      op: exists
      value: null
    - var: item.CachePeriodInMinutes
      op: greater_than
      value: '60'
- rule_id: aws.timestream.resource.cloudwatch_monitoring_and_alerting_enabled
  for_each: aws.timestream-query.describe_endpoints
  conditions:
    all:
    - var: item.Address
      op: exists
      value: null
    - var: item.CachePeriodInMinutes
      op: exists
      value: null
- rule_id: aws.timestream.database.encryption_at_rest_enabled
  for_each: aws.timestream-query.describe_account_settings
  conditions:
    var: item.ComputeMode
    op: equals
    value: PROVISIONED
- rule_id: aws.timestream.table.require_tls_in_transit_configured
  for_each: aws.timestream-query.describe_endpoints
  conditions:
    var: item.Address
    op: contains
    value: https://
- rule_id: aws.timestream.database.require_tls_in_transit_configured
  for_each: aws.timestream-query.describe_endpoints
  conditions:
    var: item.Address
    op: contains
    value: https
- rule_id: aws.timestream.table.deletion_protection_enabled
  for_each: aws.timestream-query.list_tags_for_resource
  conditions:
    all:
    - var: item.Key
      op: equals
      value: DeletionProtectionEnabled
    - var: item.Value
      op: equals
      value: 'true'
- rule_id: aws.timestream.database.iam_or_managed_identity_auth_enabled_if_supported
  for_each: aws.timestream-query.describe_account_settings
  conditions:
    var: item.ComputeMode
    op: equals
    value: PROVISIONED
- rule_id: aws.timestream.table.private_network_only_if_supported
  for_each: aws.timestream-query.describe_endpoints
  conditions:
    all:
    - var: item.Address
      op: exists
      value: null
    - var: item.CachePeriodInMinutes
      op: exists
      value: null
- rule_id: aws.timestream.table.iam_or_managed_identity_auth_enabled_if_supported
  for_each: aws.timestream-query.describe_account_settings
  conditions:
    var: item.ComputeMode
    op: equals
    value: PROVISIONED
- rule_id: aws.timestream.resource.iam_fine_grained_access_control_enabled
  for_each: aws.timestream-query.describe_account_settings
  conditions:
    var: item.ComputeMode
    op: equals
    value: AUTO
- rule_id: aws.timestream.table.public_access_disabled
  for_each: aws.timestream-query.describe_endpoints
  conditions:
    var: item.Address
    op: exists
    value: null
- rule_id: aws.timestream.database.public_access_disabled
  for_each: aws.timestream-query.describe_endpoints
  conditions:
    var: item.Address
    op: exists
    value: null
- rule_id: aws.timestream.resource.cloudtrail_management_and_data_logging_enabled
  for_each: aws.timestream-query.describe_account_settings
  conditions:
    all:
    - var: item.ComputeMode
      op: equals
      value: AUTO
    - var: item.ProvisionedCapacity
      op: greater_than
      value: '1'
- rule_id: aws.timestream.database.deletion_protection_enabled
  for_each: aws.timestream-query.list_tags_for_resource
  conditions:
    all:
    - var: item.Key
      op: equals
      value: DeletionProtectionEnabled
    - var: item.Value
      op: equals
      value: 'true'
- rule_id: aws.timestream.table.rbac_least_privilege
  for_each: aws.timestream-query.list_tags_for_resource
  conditions:
    all:
    - var: item.Key
      op: equals
      value: AccessPolicy
    - var: item.Value
      op: equals
      value: least_privilege_policy
- rule_id: aws.timestream.table.encryption_at_rest_enabled
  for_each: aws.timestream-query.describe_scheduled_query
  conditions:
    var: item.KmsKeyId
    op: not_equals
    value: null
