version: '1.0'
provider: aws
service: s3
services:
  client: s3
  module: boto3.client
discovery:
# Primary discovery: List all S3 buckets
# Emits: resource_arn, resource_id, resource_type, resource_name for inventory
- discovery_id: aws.s3.list_buckets
  calls:
  - action: list_buckets
    save_as: response
  emit:
    items_for: '{{ response.Buckets }}'
    as: item
    item:
      resource_arn: 'arn:aws:s3:::{{ item.Name }}'
      resource_id: '{{ item.Name }}'
      resource_type: 's3:bucket'
      resource_name: '{{ item.Name }}'
      Name: '{{ item.Name }}'
      CreationDate: '{{ item.CreationDate }}'
# Bucket configuration discoveries (optional - many buckets may not have these configured)
# These use on_error: continue to handle expected NoSuch* errors gracefully

- discovery_id: aws.s3.get_bucket_abac
  calls:
  - action: get_bucket_abac
    save_as: response
    params:
      Bucket: '{{ item.Name }}'
    for_each: aws.s3.list_buckets
    on_error: continue
  emit:
    item:
      Name: '{{ item.Name }}'
      Status: '{{ response.AbacStatus.Status }}'
- discovery_id: aws.s3.get_bucket_versioning
  calls:
  - action: get_bucket_versioning
    save_as: response
    params:
      Bucket: '{{ item.Name }}'
    for_each: aws.s3.list_buckets
    on_error: continue
  emit:
    item:
      Name: '{{ item.Name }}'
      Status: '{{ response.Status }}'
      MFADelete: '{{ response.MFADelete }}'

# Optional: Bucket policy status (may not exist - expected NoSuchBucketPolicy errors)
- discovery_id: aws.s3.get_bucket_policy_status
  calls:
  - action: get_bucket_policy_status
    save_as: response
    params:
      Bucket: '{{ item.Name }}'
    for_each: aws.s3.list_buckets
    on_error: continue
  emit:
    item:
      Name: '{{ item.Name }}'
      IsPublic: '{{ response.PolicyStatus.IsPublic }}'
- discovery_id: aws.s3.get_bucket_logging
  calls:
  - action: get_bucket_logging
    save_as: response
    params:
      Bucket: '{{ item.Name }}'
    for_each: aws.s3.list_buckets
    on_error: continue
  emit:
    item:
      Name: '{{ item.Name }}'
      TargetBucket: '{{ response.LoggingEnabled.TargetBucket }}'
      TargetGrants: '{{ response.LoggingEnabled.TargetGrants }}'
      TargetPrefix: '{{ response.LoggingEnabled.TargetPrefix }}'
      TargetObjectKeyFormat: '{{ response.LoggingEnabled.TargetObjectKeyFormat }}'

# Optional: Bucket policy document (may not exist - expected NoSuchBucketPolicy errors)
- discovery_id: aws.s3.get_bucket_policy
  calls:
  - action: get_bucket_policy
    save_as: response
    params:
      Bucket: '{{ item.Name }}'
    for_each: aws.s3.list_buckets
    on_error: continue
  emit:
    item:
      Name: '{{ item.Name }}'
      Policy: '{{ response.Policy }}'
- discovery_id: aws.s3.get_bucket_encryption
  calls:
  - action: get_bucket_encryption
    save_as: response
    params:
      Bucket: '{{ item.Name }}'
    for_each: aws.s3.list_buckets
    on_error: continue
  emit:
    item:
      Name: '{{ item.Name }}'
      Rules: '{{ response.ServerSideEncryptionConfiguration.Rules }}'
- discovery_id: aws.s3.get_public_access_block
  calls:
  - action: get_public_access_block
    save_as: response
    params:
      Bucket: '{{ item.Name }}'
    for_each: aws.s3.list_buckets
    on_error: continue
  emit:
    item:
      Name: '{{ item.Name }}'
      BlockPublicAcls: '{{ response.PublicAccessBlockConfiguration.BlockPublicAcls
        }}'
      IgnorePublicAcls: '{{ response.PublicAccessBlockConfiguration.IgnorePublicAcls
        }}'
      BlockPublicPolicy: '{{ response.PublicAccessBlockConfiguration.BlockPublicPolicy
        }}'
      RestrictPublicBuckets: '{{ response.PublicAccessBlockConfiguration.RestrictPublicBuckets
        }}'

# Optional: Object Lock configuration (rare - expected ObjectLockConfigurationNotFoundError for most buckets)
- discovery_id: aws.s3.get_object_lock_configuration
  calls:
  - action: get_object_lock_configuration
    save_as: response
    params:
      Bucket: '{{ item.Name }}'
    for_each: aws.s3.list_buckets
    on_error: continue
  emit:
    item:
      Name: '{{ item.Name }}'
      ObjectLockEnabled: '{{ response.ObjectLockConfiguration.ObjectLockEnabled }}'
      Rule: '{{ response.ObjectLockConfiguration.Rule }}'

# Optional: CORS configuration (may not exist - expected NoSuchCORSConfiguration errors)
- discovery_id: aws.s3.get_bucket_cors
  calls:
  - action: get_bucket_cors
    save_as: response
    params:
      Bucket: '{{ item.Name }}'
    for_each: aws.s3.list_buckets
    on_error: continue
  emit:
    items_for: '{{ response.CORSRules }}'
    as: cors_rule
    item:
      Name: '{{ item.Name }}'
      ID: '{{ cors_rule.ID }}'
      AllowedHeaders: '{{ cors_rule.AllowedHeaders }}'
      AllowedMethods: '{{ cors_rule.AllowedMethods }}'
      AllowedOrigins: '{{ cors_rule.AllowedOrigins }}'
      ExposeHeaders: '{{ cors_rule.ExposeHeaders }}'
      MaxAgeSeconds: '{{ cors_rule.MaxAgeSeconds }}'

# Optional: Lifecycle configuration (may not exist - expected NoSuchLifecycleConfiguration errors)
- discovery_id: aws.s3.get_bucket_lifecycle_configuration
  calls:
  - action: get_bucket_lifecycle_configuration
    save_as: response
    params:
      Bucket: '{{ item.Name }}'
    for_each: aws.s3.list_buckets
    on_error: continue
  emit:
    items_for: '{{ response.Rules }}'
    as: rule
    item:
      Name: '{{ item.Name }}'
      Expiration: '{{ rule.Expiration }}'
      ID: '{{ rule.ID }}'
      Prefix: '{{ rule.Prefix }}'
      Filter: '{{ rule.Filter }}'
      Status: '{{ rule.Status }}'
      Transitions: '{{ rule.Transitions }}'
      NoncurrentVersionTransitions: '{{ rule.NoncurrentVersionTransitions }}'
      NoncurrentVersionExpiration: '{{ rule.NoncurrentVersionExpiration }}'
      AbortIncompleteMultipartUpload: '{{ rule.AbortIncompleteMultipartUpload }}'

# Optional: Lifecycle configuration (may not exist - expected NoSuchLifecycleConfiguration errors)
- discovery_id: aws.s3.get_bucket_acl
  calls:
  - action: get_bucket_acl
    save_as: response
    params:
      Bucket: '{{ item.Name }}'
    for_each: aws.s3.list_buckets
    on_error: continue
  emit:
    items_for: '{{ response.Grants }}'
    as: grant
    item:
      Name: '{{ item.Name }}'
      Grantee: '{{ grant.Grantee }}'
      Permission: '{{ grant.Permission }}'

# DISABLED: List objects in bucket - NOT NEEDED FOR CSPM
# Reason: 
# 1. Bucket-level encryption is already checked via get_bucket_encryption (bucket configuration)
# 2. list_objects_v2 is VERY slow for buckets with many objects (minutes per bucket)
# 3. CSPM focuses on configuration/security posture, not individual object checks
# 4. The check using this (aws.s3.object.encryption_at_rest_enabled) checks wrong field (ChecksumType doesn't exist)
#
# - discovery_id: aws.s3.list_objects_v2
#   calls:
#   - action: list_objects_v2
#     save_as: response
#     params:
#       Bucket: '{{ item.Name }}'
#     for_each: aws.s3.list_buckets
#     on_error: continue
#   emit:
#     items_for: '{{ response.Contents }}'
#     as: obj
#     item:
#       Name: '{{ item.Name }}'
#       Key: '{{ obj.Key }}'
#       LastModified: '{{ obj.LastModified }}'
#       ETag: '{{ obj.ETag }}'
#       Size: '{{ obj.Size }}'
#       StorageClass: '{{ obj.StorageClass }}'
checks:
- rule_id: aws.s3.macie_classification_jobs_status.macie_classification_jobs_status_configured
  for_each: aws.s3.list_buckets
  conditions:
    var: item.Name
    op: exists
    value: null
- rule_id: aws.s3.bucket.encryption_enabled
  for_each: aws.s3.list_buckets
  conditions:
    var: item.Name
    op: exists
    value: null
- rule_id: aws.s3.bucket.object_versioning_configured
  for_each: aws.s3.get_bucket_versioning
  conditions:
    var: item.Status
    op: equals
    value: Enabled
- rule_id: aws.s3.bucket.destination_private_only_configured
  for_each: aws.s3.get_bucket_policy_status
  conditions:
    var: item.IsPublic
    op: equals
    value: 'false'
- rule_id: aws.s3.bucket.key_rotation_enabled
  for_each: aws.s3.get_bucket_abac
  conditions:
    var: item.Status
    op: exists
    value: null
- rule_id: aws.s3.bucket_notification.bucket_destination_least_privilege
  for_each: aws.s3.list_buckets
  conditions:
    all:
    - var: item.Name
      op: exists
      value: null
    - var: item.CreationDate
      op: exists
      value: null
    - var: item.BucketArn
      op: exists
      value: null
- rule_id: aws.s3.bucket.object_level_write_logging_enabled
  for_each: aws.s3.get_bucket_logging
  conditions:
    var: item.TargetBucket
    op: exists
    value: null
- rule_id: aws.s3.bucket_notification.bucket_destination_encrypted
  for_each: aws.s3.list_buckets
  conditions:
    all:
    - var: item.Name
      op: exists
      value: null
    - var: item.BucketArn
      op: exists
      value: null
- rule_id: aws.s3.bucket.cmk_cmek_key_configured
  for_each: aws.s3.list_buckets
  conditions:
    all:
    - var: item.Name
      op: exists
      value: null
    - var: item.BucketArn
      op: exists
      value: null
- rule_id: aws.s3.website_https_only.website_https_only_configured
  for_each: aws.s3.list_buckets
  conditions:
    var: item.Name
    op: exists
    value: null
- rule_id: aws.s3.bucketpolicy.no_public_principals_configured
  for_each: aws.s3.get_bucket_policy
  conditions:
    var: item.Statement.Principal
    op: not_equals
    value: '*'
- rule_id: aws.s3.bucket.require_tls_in_transit_configured
  for_each: aws.s3.get_bucket_policy_status
  conditions:
    var: item.IsPublic
    op: equals
    value: 'false'
- rule_id: aws.s3.bucketpolicy.bucket_deny_insecure_transport_configured
  for_each: aws.s3.get_bucket_policy
  conditions:
    var: item.Statement.Condition.Bool'aws:SecureTransport'
    op: equals
    value: 'false'
- rule_id: aws.s3.bucket.s3_encrypted_at_rest
  for_each: aws.s3.get_bucket_encryption
  conditions:
    var: item.Rules
    op: exists
    value: null
- rule_id: aws.s3.bucketpolicy.bucket_deny_unencrypted_puts
  for_each: aws.s3.get_bucket_policy
  conditions:
    all:
    - var: item.Statement.Effect
      op: equals
      value: Deny
    - var: item.Statement.Condition.StringNotEquals.s3:x-amz-server-side-encryption
      op: equals
      value: AES256
    - var: item.Statement.Condition.StringNotEquals.s3:x-amz-server-side-encryption
      op: equals
      value: aws:kms
    - var: item.Statement.Action
      op: contains
      value: s3:PutObject
- rule_id: aws.s3.bucket.block_public_access_configured
  for_each: aws.s3.get_public_access_block
  conditions:
    all:
    - var: item.BlockPublicAcls
      op: equals
      value: 'true'
    - var: item.IgnorePublicAcls
      op: equals
      value: 'true'
    - var: item.BlockPublicPolicy
      op: equals
      value: 'true'
    - var: item.RestrictPublicBuckets
      op: equals
      value: 'true'
- rule_id: aws.s3.object.lock_or_immutability_enabled_if_supported
  for_each: aws.s3.get_object_lock_configuration
  conditions:
    all:
    - var: item.ObjectLockEnabled
      op: equals
      value: Enabled
    - var: item.Rule.DefaultRetention.Mode
      op: in
      value:
      - GOVERNANCE
      - COMPLIANCE
- rule_id: aws.s3.bucket.schedule_defined_min_frequency_configured
  for_each: aws.s3.list_buckets
  conditions:
    var: item.Name
    op: exists
    value: null
- rule_id: aws.s3.account.level_public_access_blocks_configured
  for_each: aws.s3.get_public_access_block
  conditions:
    all:
    - var: item.BlockPublicAcls
      op: equals
      value: 'true'
    - var: item.IgnorePublicAcls
      op: equals
      value: 'true'
    - var: item.BlockPublicPolicy
      op: equals
      value: 'true'
    - var: item.RestrictPublicBuckets
      op: equals
      value: 'true'
- rule_id: aws.s3.bucket.policy_public_write_access_configured
  for_each: aws.s3.get_bucket_policy_status
  conditions:
    var: item.IsPublic
    op: equals
    value: 'false'
- rule_id: aws.s3.bucket.storage_encrypted_and_private
  for_each: aws.s3.get_bucket_encryption
  conditions:
    var: item.Rules
    op: exists
    value: null
- rule_id: aws.s3.bucket.public_access_configured
  for_each: aws.s3.get_public_access_block
  conditions:
    all:
    - var: item.BlockPublicAcls
      op: equals
      value: 'true'
    - var: item.IgnorePublicAcls
      op: equals
      value: 'true'
    - var: item.BlockPublicPolicy
      op: equals
      value: 'true'
    - var: item.RestrictPublicBuckets
      op: equals
      value: 'true'
- rule_id: aws.s3.bucket.lifecycle_enabled
  for_each: aws.s3.get_bucket_lifecycle_configuration
  conditions:
    var: item.Status
    op: equals
    value: Enabled
- rule_id: aws.s3.bucket_encryption.bucket_at_rest_cmek_enabled
  for_each: aws.s3.get_bucket_encryption
  conditions:
    var: item.Rules
    op: exists
    value: null
- rule_id: aws.s3.bucket.block_public_access_enabled
  for_each: aws.s3.get_public_access_block
  conditions:
    all:
    - var: item.BlockPublicAcls
      op: equals
      value: 'true'
    - var: item.IgnorePublicAcls
      op: equals
      value: 'true'
    - var: item.BlockPublicPolicy
      op: equals
      value: 'true'
    - var: item.RestrictPublicBuckets
      op: equals
      value: 'true'
- rule_id: aws.s3.replication.encryption_in_transit_tls_required
  for_each: aws.s3.get_bucket_policy
  conditions:
    var: item.Policy
    op: exists
    value: null
- rule_id: aws.s3.bucket.rbac_least_privilege
  for_each: aws.s3.get_bucket_abac
  conditions:
    var: item.Status
    op: not_equals
    value: DISABLED
- rule_id: aws.s3.lifecycle_configuration.bucket_enforced_on_sensitive_datasets_configured
  for_each: aws.s3.list_buckets
  conditions:
    all:
    - var: item.Name
      op: equals
      value: sensitive
    - var: item.BucketRegion
      op: equals
      value: 'true'
- rule_id: aws.s3.lifecycle_configuration.versioning_enabled_if_supported
  for_each: aws.s3.get_bucket_versioning
  conditions:
    var: item.Status
    op: equals
    value: Enabled
- rule_id: aws.s3.bucket.metrics_enabled
  for_each: aws.s3.get_bucket_cors
  conditions:
    var: item.MetricsConfiguration.Id
    op: exists
    value: null
- rule_id: aws.s3.lifecycle_configuration.immutable_retention_locked_where_required
  for_each: aws.s3.list_buckets
  conditions:
    all:
    - var: item.Name
      op: exists
      value: null
    - var: item.CreationDate
      op: exists
      value: null
    - var: item.BucketRegion
      op: exists
      value: null
    - var: item.BucketArn
      op: exists
      value: null
- rule_id: aws.s3.bucket.immutable_or_worm_enabled_if_supported
  for_each: aws.s3.get_object_lock_configuration
  conditions:
    var: item.ObjectLockEnabled
    op: equals
    value: Enabled
- rule_id: aws.s3.bucket.versioning_enabled
  for_each: aws.s3.get_bucket_versioning
  conditions:
    var: item.Status
    op: equals
    value: Enabled
- rule_id: aws.s3.bucket.access_logging_enabled
  for_each: aws.s3.get_bucket_logging
  conditions:
    var: item.TargetBucket
    op: exists
    value: null
- rule_id: aws.s3.bucket.retention_days_minimum
  for_each: aws.s3.get_bucket_lifecycle_configuration
  conditions:
    var: item.Rules.Expiration.Days
    op: greater_than
    value: '30'
- rule_id: aws.s3.lifecycle_configuration.policies_configured
  for_each: aws.s3.get_bucket_abac
  conditions:
    var: item.Status
    op: equals
    value: Enabled
- rule_id: aws.s3.bucket.server_access_logging_enabled
  for_each: aws.s3.get_bucket_logging
  conditions:
    var: item.TargetBucket
    op: exists
    value: null
- rule_id: aws.s3.bucket_encryption.in_transit_tls_min_1_2_configured
  for_each: aws.s3.get_bucket_policy_status
  conditions:
    var: item.IsPublic
    op: equals
    value: 'false'
- rule_id: aws.s3.bucket.key_policy_least_privilege
  for_each: aws.s3.get_bucket_policy
  conditions:
    all:
    - var: item.Statement.Effect
      op: equals
      value: Allow
    - var: item.Statement.Principal
      op: not_equals
      value: '*'
    - var: item.Statement.Action
      op: in
      value:
      - s3:GetObject
      - s3:PutObject
    - var: item.Statement.Resource
      op: exists
      value: null
- rule_id: aws.s3.bucket.encryption_at_rest_enabled
  for_each: aws.s3.get_bucket_encryption
  conditions:
    var: item.Rules
    op: exists
    value: null
- rule_id: aws.s3.bucket.default_encryption_configured
  for_each: aws.s3.get_bucket_encryption
  conditions:
    var: item.Rules
    op: exists
    value: null
- rule_id: aws.s3.bucket.public_write_prohibited_configured
  for_each: aws.s3.get_bucket_acl
  conditions:
    all:
    - var: item.Grantee.URI
      op: not_equals
      value: http://acs.amazonaws.com/groups/global/AllUsers
    - var: item.Permission
      op: not_equals
      value: WRITE
- rule_id: aws.s3.intelligent_tiering.protected_from_public_override_configured
  for_each: aws.s3.get_bucket_abac
  conditions:
    all:
    - var: item.IntelligentTieringConfiguration.Status
      op: equals
      value: Enabled
    - var: item.IntelligentTieringConfiguration.Filter
      op: exists
      value: null
- rule_id: aws.s3.replication.auth_roles_least_privilege
  for_each: aws.s3.get_bucket_abac
  conditions:
    var: item.Status
    op: exists
    value: null
- rule_id: aws.s3.bucket.policy_denies_public_and_insecure_configured
  for_each: aws.s3.list_buckets
  conditions:
    var: item.Name
    op: exists
    value: null
- rule_id: aws.s3.replication.lag_monitoring_alerts_enabled
  for_each: aws.s3.list_buckets
  conditions:
    all:
    - var: item.Name
      op: exists
      value: null
    - var: item.BucketRegion
      op: exists
      value: null
# DISABLED: Object-level encryption check - NOT NEEDED FOR CSPM
# Reason:
# 1. Bucket-level encryption is already checked via get_bucket_encryption (more efficient)
# 2. list_objects_v2 is VERY slow for buckets with many objects
# 3. Check logic is incorrect (ChecksumType field doesn't exist in list_objects_v2 response)
# 4. CSPM focuses on bucket configuration, not individual object checks
#
# - rule_id: aws.s3.object.encryption_at_rest_enabled
#   for_each: aws.s3.list_objects_v2
#   conditions:
#     any:
#     - var: item.ChecksumType
#       op: equals
#       value: aws:kms
#     - var: item.ChecksumType
#       op: equals
#       value: AES256
- rule_id: aws.s3.intelligent_tiering.policies_configured
  for_each: aws.s3.get_bucket_abac
  conditions:
    all:
    - var: item.Status
      op: equals
      value: Enabled
    - var: item.Tierings.Days
      op: greater_than
      value: '30'
- rule_id: aws.s3.bucket.cmk_cmek_configured
  for_each: aws.s3.get_bucket_abac
  conditions:
    var: item.Status
    op: equals
    value: Enabled
- rule_id: aws.s3.bucket.kms_encryption_configured
  for_each: aws.s3.get_bucket_encryption
  conditions:
    var: item.Rules
    op: exists
    value: null
- rule_id: aws.s3.bucketpolicy.bucket_no_wildcards_on_actions_or_principals_configured
  for_each: aws.s3.get_bucket_policy
  conditions:
    all:
    - var: item.Statement.Action
      op: not_equals
      value: '*'
    - var: item.Statement.Principal
      op: not_equals
      value: '*'
- rule_id: aws.s3.bucket.immutability_or_object_lock_if_supported
  for_each: aws.s3.get_bucket_abac
  conditions:
    var: item.Status
    op: equals
    value: Enabled
- rule_id: aws.s3.intelligent_tiering.bucket_enforced_on_sensitive_datasets_configured
  for_each: aws.s3.get_bucket_abac
  conditions:
    all:
    - var: item.Status
      op: equals
      value: Enabled
    - var: item.Filter
      op: exists
      value: null
- rule_id: aws.s3.object.not_publicly_readable_configured
  for_each: aws.s3.get_bucket_acl
  conditions:
    all:
    - var: item.Grantee.URI
      op: not_equals
      value: http://acs.amazonaws.com/groups/global/AllUsers
    - var: item.Permission
      op: not_equals
      value: READ
- rule_id: aws.s3.bucket.public_read_prohibited_configured
  for_each: aws.s3.get_bucket_abac
  conditions:
    var: item.Status
    op: equals
    value: DISABLED
- rule_id: aws.s3.lifecycle_configuration.protected_from_public_override_configured
  for_each: aws.s3.list_buckets
  conditions:
    all:
    - var: item.Name
      op: exists
      value: null
    - var: item.BucketRegion
      op: equals
      value: us-east-1
- rule_id: aws.s3.lifecycle_configuration.certificate_expiration_rules_configured
  for_each: aws.s3.get_bucket_lifecycle_configuration
  conditions:
    all:
    - var: item.Rules.Expiration.Date
      op: exists
      value: null
    - var: item.Rules.Expiration.Days
      op: exists
      value: null
- rule_id: aws.s3.bucket.lifecycle_policy_configured
  for_each: aws.s3.get_bucket_lifecycle_configuration
  conditions:
    var: item.Status
    op: equals
    value: Enabled
- rule_id: aws.s3.bucket.secure_transport_policy_configured
  for_each: aws.s3.get_bucket_policy_status
  conditions:
    var: item.IsPublic
    op: equals
    value: 'false'
- rule_id: aws.s3.bucket.backup_storage_immutability_enabled
  for_each: aws.s3.get_bucket_versioning
  conditions:
    var: item.Status
    op: equals
    value: Enabled
- rule_id: aws.s3.bucket_notification.bucket_cross_account_destinations_restricted
  for_each: aws.s3.list_buckets
  conditions:
    all:
    - var: item.Buckets.BucketArn
      op: exists
      value: null
    - var: item.Buckets.BucketArn
      op: not_equals
      value: arn:aws:sns:us-east-1:123456789012:example-topic
- rule_id: aws.s3.bucket.replication_enabled
  for_each: aws.s3.list_buckets
  conditions:
    var: item.Name
    op: exists
    value: null
- rule_id: aws.s3.bucket.encryption_in_transit_tls_min_1_2_configured
  for_each: aws.s3.get_bucket_policy
  conditions:
    var: item.Policy.Statement.Condition.Bool'aws:SecureTransport'
    op: equals
    value: 'true'
- rule_id: aws.s3.bucket.encryption_at_rest_cmek_configured
  for_each: aws.s3.list_buckets
  conditions:
    var: item.Name
    op: exists
    value: null

