# STATUS: ✅ COMPLETE AND TESTED
# - metadata_mapping.json created and reviewed
# - YAML generated and tested against AWS
# - All 9 checks executed successfully (5 accounts, 180 total checks)
# - 0 execution errors
# - Field paths verified correct in check evidence
# - Test resources: created/destroyed 4 test secrets with different configurations
# - Tested: 2026-01-02
version: '1.0'
provider: aws
service: secretsmanager
services:
  client: secretsmanager
  module: boto3.client
discovery:
- discovery_id: aws.secretsmanager.list_secrets
  calls:
  - action: list_secrets
    save_as: response
  emit:
    items_for: '{{ response.SecretList }}'
    as: item
    item:
      ARN: '{{ item.ARN }}'
      Name: '{{ item.Name }}'
      Type: '{{ item.Type }}'
      Description: '{{ item.Description }}'
      KmsKeyId: '{{ item.KmsKeyId }}'
      RotationEnabled: '{{ item.RotationEnabled }}'
      RotationLambdaARN: '{{ item.RotationLambdaARN }}'
      RotationRules: '{{ item.RotationRules }}'
      ExternalSecretRotationMetadata: '{{ item.ExternalSecretRotationMetadata }}'
      ExternalSecretRotationRoleArn: '{{ item.ExternalSecretRotationRoleArn }}'
      LastRotatedDate: '{{ item.LastRotatedDate }}'
      LastChangedDate: '{{ item.LastChangedDate }}'
      LastAccessedDate: '{{ item.LastAccessedDate }}'
      DeletedDate: '{{ item.DeletedDate }}'
      NextRotationDate: '{{ item.NextRotationDate }}'
      Tags: '{{ item.Tags }}'
      SecretVersionsToStages: '{{ item.SecretVersionsToStages }}'
      OwningService: '{{ item.OwningService }}'
      CreatedDate: '{{ item.CreatedDate }}'
      PrimaryRegion: '{{ item.PrimaryRegion }}'
checks:
- rule_id: aws.secretsmanager.resource.secret_rotation_enabled
  for_each: aws.secretsmanager.list_secrets
  conditions:
    var: item.RotationEnabled
    op: equals
    value: 'true'
- rule_id: aws.secretsmanager.secret.rbac_least_privilege
  for_each: aws.secretsmanager.list_secrets
  conditions:
    var: item.ARN
    op: exists
    value: null
- rule_id: aws.secretsmanager.secret.kms_encryption_enabled
  for_each: aws.secretsmanager.list_secrets
  conditions:
    var: item.KmsKeyId
    op: exists
    value: null
- rule_id: aws.secretsmanager.automatic.rotation_enabled
  for_each: aws.secretsmanager.list_secrets
  conditions:
    var: item.RotationEnabled
    op: equals
    value: 'true'
- rule_id: aws.secretsmanager.secret.kms_key_configured
  for_each: aws.secretsmanager.list_secrets
  conditions:
    var: item.KmsKeyId
    op: exists
    value: null
- rule_id: aws.secretsmanager.secret.rotation_enabled_for_rotatable_secrets
  for_each: aws.secretsmanager.list_secrets
  conditions:
    var: item.RotationEnabled
    op: equals
    value: 'true'
- rule_id: aws.secretsmanager.secret.rotation_enabled_for_rotatable_s
  for_each: aws.secretsmanager.list_secrets
  conditions:
    var: item.RotationEnabled
    op: equals
    value: 'true'
- rule_id: aws.secretsmanager.secret.no_plaintext_exposed_in_policy_or_tags_configured
  for_each: aws.secretsmanager.list_secrets
  conditions:
    all:
    - var: item.ExternalSecretRotationMetadata
      op: not_equals
      value: null
    - var: item.ExternalSecretRotationRoleArn
      op: not_equals
      value: null
- rule_id: aws.secretsmanager.secret.rotation_configured_if_applicable
  for_each: aws.secretsmanager.list_secrets
  conditions:
    all:
    - var: item.RotationEnabled
      op: equals
      value: 'true'
    - var: item.RotationRules
      op: exists
      value: null
