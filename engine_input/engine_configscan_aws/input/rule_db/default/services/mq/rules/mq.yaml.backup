# STATUS: ✅ COMPLETE AND TESTED
# - metadata_mapping.json created and reviewed (3 rules)
# - YAML generated and tested against AWS
# - All 3 checks configured (1 check executes per account when no brokers exist)
# - 0 execution errors
# - Field paths verified correct
# - Test resources: No MQ brokers found in accounts (0 brokers)
# - Tested: 2026-01-02
# - Note: Fixed list_brokers emit to use response.BrokerSummaries instead of response.NextToken
# - Note: Fixed describe_broker to depend on list_brokers and pass BrokerId parameter
# - Results: 5 total checks (1 per account × 5 accounts) - all FAIL as expected when no brokers exist
version: '1.0'
provider: aws
service: mq
services:
  client: mq
  module: boto3.client
discovery:
- discovery_id: aws.mq.list_brokers
  calls:
  - action: list_brokers
    save_as: response
  emit:
    items_for: '{{ response.BrokerSummaries }}'
    as: item
    item:
      BrokerArn: '{{ item.BrokerArn }}'
      BrokerId: '{{ item.BrokerId }}'
      BrokerName: '{{ item.BrokerName }}'
      BrokerState: '{{ item.BrokerState }}'
      Created: '{{ item.Created }}'
      DeploymentMode: '{{ item.DeploymentMode }}'
      EngineType: '{{ item.EngineType }}'
      HostInstanceType: '{{ item.HostInstanceType }}'
- discovery_id: aws.mq.describe_broker
  for_each: aws.mq.list_brokers
  calls:
  - action: describe_broker
    params:
      BrokerId: '{{ item.BrokerId }}'
    save_as: response
  emit:
    item:
      BrokerId: '{{ response.BrokerId }}'
      BrokerName: '{{ response.BrokerName }}'
      BrokerArn: '{{ response.BrokerArn }}'
      BrokerState: '{{ response.BrokerState }}'
      DeploymentMode: '{{ response.DeploymentMode }}'
      Logs: '{{ response.Logs }}'
      LogsGeneral: '{{ response.Logs.General }}'
      LogsAudit: '{{ response.Logs.Audit }}'
checks:
- rule_id: aws.mq.cluster.mq_deployment_mode_configured
  for_each: aws.mq.list_brokers
  conditions:
    var: item.DeploymentMode
    op: in
    value:
    - SINGLE_INSTANCE
    - ACTIVE_STANDBY_MULTI_AZ
    - CLUSTER_MULTI_AZ
- rule_id: aws.mq.resource.broker_logging_enabled
  for_each: aws.mq.describe_broker
  conditions:
    all:
    - var: item.Logs.General
      op: equals
      value: 'true'
    - var: item.Logs.Audit
      op: equals
      value: 'true'
- rule_id: aws.mq.broker.mq_active_deployment_mode_configured
  for_each: aws.mq.list_brokers
  conditions:
    var: item.DeploymentMode
    op: equals
    value: ACTIVE_STANDBY_MULTI_AZ
