version: '1.0'
provider: aws
service: datasync
services:
  client: datasync
  module: boto3.client
discovery:
- discovery_id: aws.datasync.list_tasks
  calls:
  - action: list_tasks
    save_as: response
  emit:
    items_for: '{{ response.TaskList }}'
    as: item
    item:
      TaskArn: '{{ item.TaskArn }}'
      Name: '{{ item.Name }}'
      Status: '{{ item.Status }}'
- discovery_id: aws.datasync.describe_task
  for_each: '{{ aws.datasync.list_tasks }}'
  calls:
  - action: describe_task
    params:
      TaskArn: '{{ item.TaskArn }}'
    on_error: continue
    save_as: response
  emit:
    item:
      TaskArn: '{{ response.TaskArn }}'
      Name: '{{ response.Name }}'
      Status: '{{ response.Status }}'
      CloudWatchLogGroupArn: '{{ response.Options.CloudWatchLogGroupArn }}'
      Options: '{{ response.Options }}'
      SourceLocationArn: '{{ response.SourceLocationArn }}'
      DestinationLocationArn: '{{ response.DestinationLocationArn }}'
      CurrentTaskExecutionArn: '{{ response.CurrentTaskExecutionArn }}'
      SourceNetworkInterfaceArns: '{{ response.SourceNetworkInterfaceArns }}'
      DestinationNetworkInterfaceArns: '{{ response.DestinationNetworkInterfaceArns }}'
checks:
- rule_id: aws.datasync.resource.task_logging_enabled
  for_each: aws.datasync.describe_task
  conditions:
    var: item.CloudWatchLogGroupArn
    op: exists
    value: null

