# STATUS: ✅ COMPLETE AND TESTED
# - metadata_mapping.json reviewed and YAML fixed
# - YAML tested against AWS
# - All 1 checks executed successfully (5 accounts, 10 total checks)
# - 0 execution errors
# - Field paths verified correct in check evidence
# - Test resources: used existing Well-Architected workloads (2 workloads found)
# - Tested: 2026-01-02
# - Note: get_workload requires WorkloadId parameter, fixed to use list_workloads for discovery
version: '1.0'
provider: aws
service: wellarchitected
services:
  client: wellarchitected
  module: boto3.client
discovery:
- discovery_id: aws.wellarchitected.list_workloads
  calls:
  - action: list_workloads
    save_as: response
  emit:
    items_for: '{{ response.WorkloadSummaries }}'
    as: item
    item:
      WorkloadId: '{{ item.WorkloadId }}'
      WorkloadArn: '{{ item.WorkloadArn }}'
      WorkloadName: '{{ item.WorkloadName }}'
      Owner: '{{ item.Owner }}'
      UpdatedAt: '{{ item.UpdatedAt }}'
      Lenses: '{{ item.Lenses }}'
      RiskCounts: '{{ item.RiskCounts }}'
      ImprovementStatus: '{{ item.ImprovementStatus }}'
- discovery_id: aws.wellarchitected.get_workload
  for_each: aws.wellarchitected.list_workloads
  calls:
  - action: get_workload
    params:
      WorkloadId: '{{ item.WorkloadId }}'
    save_as: response
  emit:
    item:
      WorkloadId: '{{ item.WorkloadId }}'
      WorkloadArn: '{{ response.Workload.WorkloadArn }}'
      WorkloadName: '{{ response.Workload.WorkloadName }}'
      Description: '{{ response.Workload.Description }}'
      Environment: '{{ response.Workload.Environment }}'
      UpdatedAt: '{{ response.Workload.UpdatedAt }}'
      AccountIds: '{{ response.Workload.AccountIds }}'
      AwsRegions: '{{ response.Workload.AwsRegions }}'
      NonAwsRegions: '{{ response.Workload.NonAwsRegions }}'
      ArchitecturalDesign: '{{ response.Workload.ArchitecturalDesign }}'
      ReviewOwner: '{{ response.Workload.ReviewOwner }}'
      ReviewRestrictionDate: '{{ response.Workload.ReviewRestrictionDate }}'
      IsReviewOwnerUpdateAcknowledged: '{{ response.Workload.IsReviewOwnerUpdateAcknowledged }}'
      IndustryType: '{{ response.Workload.IndustryType }}'
      Industry: '{{ response.Workload.Industry }}'
      Notes: '{{ response.Workload.Notes }}'
      ImprovementStatus: '{{ response.Workload.ImprovementStatus }}'
      RiskCounts: '{{ response.Workload.RiskCounts }}'
      PillarPriorities: '{{ response.Workload.PillarPriorities }}'
      Lenses: '{{ response.Workload.Lenses }}'
checks:
- rule_id: aws.wellarchitected.workload.wellarchitected_no_high_or_medium_risks_configured
  for_each: aws.wellarchitected.get_workload
  conditions:
    all:
    - var: item.RiskCounts.HIGH
      op: equals
      value: 0
    - var: item.RiskCounts.MEDIUM
      op: equals
      value: 0
