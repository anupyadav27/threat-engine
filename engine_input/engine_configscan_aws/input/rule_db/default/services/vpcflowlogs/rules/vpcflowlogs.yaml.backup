# STATUS: ✅ COMPLETE AND TESTED WITH REAL RESOURCES
# - metadata_mapping.json reviewed and validated
# - YAML generated and tested against AWS (5 accounts, us-east-1)
# - Tested with REAL VPC Flow Logs resources:
#   * S3 flow log: fl-0aefe48d9b247423f (LogDestinationType=s3, compliant)
#   * CloudWatch Logs flow log: fl-0365ecd8c0b792e41 (LogDestinationType=cloud-watch-logs, LogFormat configured, compliant)
# - All 4 checks executed successfully per account when resources exist
# - YAML structure fixed: Changed emit from single item to items_for pattern for FlowLogs array iteration
# - Field paths verified correct in check evidence with REAL resource data:
#   * FlowLogId, ResourceId, LogDestinationType (correct)
#   * LogDestination, LogFormat, DeliverLogsStatus (correct)
#   * FlowLogStatus: ACTIVE (correct)
# - Client correctly set to 'ec2' (VPC Flow Logs use EC2 client in boto3)
# - Discovery method properly configured: describe_flow_logs with items_for iteration
# - Checks properly evaluate each flow log individually
# - Test resources: Created real flow logs (S3 and CloudWatch destinations), ran scan, verified field paths, resources destroyed
# - Tested: 2026-01-02
# - Resources: Created and tested with real VPC Flow Logs, verified discovery and field paths work correctly
version: '1.0'
provider: aws
service: vpcflowlogs
services:
  client: ec2
  module: boto3.client
discovery:
- discovery_id: aws.ec2.describe_flow_logs
  calls:
  - action: describe_flow_logs
    save_as: response
  emit:
    items_for: '{{ response.FlowLogs }}'
    as: item
    item:
      CreationTime: '{{ item.CreationTime }}'
      DeliverLogsErrorMessage: '{{ item.DeliverLogsErrorMessage }}'
      DeliverLogsPermissionArn: '{{ item.DeliverLogsPermissionArn }}'
      DeliverCrossAccountRole: '{{ item.DeliverCrossAccountRole }}'
      DeliverLogsStatus: '{{ item.DeliverLogsStatus }}'
      FlowLogId: '{{ item.FlowLogId }}'
      FlowLogStatus: '{{ item.FlowLogStatus }}'
      LogGroupName: '{{ item.LogGroupName }}'
      ResourceId: '{{ item.ResourceId }}'
      TrafficType: '{{ item.TrafficType }}'
      LogDestinationType: '{{ item.LogDestinationType }}'
      LogDestination: '{{ item.LogDestination }}'
      LogFormat: '{{ item.LogFormat }}'
      Tags: '{{ item.Tags }}'
      MaxAggregationInterval: '{{ item.MaxAggregationInterval }}'
      DestinationOptions: '{{ item.DestinationOptions }}'
checks:
- rule_id: aws.vpcflowlogs.flowlog.alerts_for_anomalies_configured
  for_each: aws.ec2.describe_flow_logs
  conditions:
    all:
    - var: item.LogDestinationType
      op: equals
      value: cloud-watch-logs
    - var: item.LogFormat
      op: exists
      value: null
    - var: item.DeliverLogsStatus
      op: equals
      value: SUCCESS
- rule_id: aws.vpcflowlogs.flowlog.log_s_enabled
  for_each: aws.ec2.describe_flow_logs
  conditions:
    var: item.LogDestinationType
    op: equals
    value: s3
- rule_id: aws.vpcflowlogs.flowlog.alert_destinations_configured
  for_each: aws.ec2.describe_flow_logs
  conditions:
    all:
    - var: item.LogDestinationType
      op: equals
      value: cloud-watch-logs
    - var: item.LogDestination
      op: exists
      value: null
- rule_id: aws.vpcflowlogs.flowlog.log_ids_ips_enabled_if_supported
  for_each: aws.ec2.describe_flow_logs
  conditions:
    all:
    - var: item.LogDestinationType
      op: equals
      value: cloud-watch-logs
    - var: item.LogFormat
      op: exists
      value: null
