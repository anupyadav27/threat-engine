{
  "cloud_csp": {
    "aws": {
      "fields": [
        { "key": "access_key_id",    "label": "Access Key ID",    "type": "text",     "required": true,  "placeholder": "AKIAIOSFODNN7EXAMPLE" },
        { "key": "secret_access_key","label": "Secret Access Key","type": "password", "required": true,  "placeholder": "wJalrXUtnFEMI/K7MDENG..." },
        { "key": "assume_role_arn",  "label": "Assume Role ARN (optional)", "type": "text", "required": false, "placeholder": "arn:aws:iam::123456789012:role/CSPMAuditRole" }
      ]
    },
    "azure": {
      "fields": [
        { "key": "client_id",       "label": "Application (Client) ID", "type": "text",     "required": true, "placeholder": "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx" },
        { "key": "client_secret",   "label": "Client Secret",           "type": "password", "required": true, "placeholder": "your-client-secret-value" },
        { "key": "tenant_id",       "label": "Directory (Tenant) ID",   "type": "text",     "required": true, "placeholder": "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx" },
        { "key": "subscription_id", "label": "Subscription ID",         "type": "text",     "required": true, "placeholder": "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx" }
      ]
    },
    "gcp": {
      "fields": [
        { "key": "service_account_key_json", "label": "Service Account Key JSON (base64 or raw)", "type": "textarea", "required": true, "placeholder": "Paste the contents of your service account JSON key file..." }
      ]
    },
    "oci": {
      "fields": [
        { "key": "tenancy_ocid",  "label": "Tenancy OCID",    "type": "text",     "required": true, "placeholder": "ocid1.tenancy.oc1..aaa..." },
        { "key": "user_ocid",     "label": "User OCID",       "type": "text",     "required": true, "placeholder": "ocid1.user.oc1..aaa..." },
        { "key": "fingerprint",   "label": "Key Fingerprint", "type": "text",     "required": true, "placeholder": "xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx" },
        { "key": "region",        "label": "Home Region",     "type": "text",     "required": true, "placeholder": "us-ashburn-1" },
        { "key": "private_key",   "label": "Private Key (PEM)", "type": "textarea", "required": true, "placeholder": "-----BEGIN RSA PRIVATE KEY-----\n..." }
      ]
    },
    "alicloud": {
      "fields": [
        { "key": "access_key_id",     "label": "Access Key ID",     "type": "text",     "required": true, "placeholder": "LTAI5t..." },
        { "key": "access_key_secret", "label": "Access Key Secret", "type": "password", "required": true, "placeholder": "your-secret" },
        { "key": "region_id",         "label": "Default Region",    "type": "text",     "required": true, "placeholder": "cn-hangzhou" }
      ]
    },
    "ibm": {
      "fields": [
        { "key": "api_key", "label": "IBM Cloud API Key", "type": "password", "required": true, "placeholder": "your-ibm-api-key" }
      ]
    },
    "k8s": {
      "fields": [
        { "key": "kubeconfig", "label": "Kubeconfig (YAML)", "type": "textarea", "required": true, "placeholder": "Paste your kubeconfig YAML content..." }
      ]
    }
  },
  "secops": {
    "github":    { "fields": [{ "key": "pat", "label": "Personal Access Token", "type": "password", "required": true,  "placeholder": "ghp_..." }] },
    "gitlab":    { "fields": [{ "key": "pat", "label": "Personal Access Token", "type": "password", "required": true,  "placeholder": "glpat-..." }] },
    "bitbucket": { "fields": [{ "key": "pat", "label": "App Password",          "type": "password", "required": true,  "placeholder": "your-app-password" }] },
    "azure_devops": { "fields": [{ "key": "pat", "label": "Personal Access Token", "type": "password", "required": true, "placeholder": "your-ado-pat" }] }
  },
  "vulnerability": {},
  "database": {
    "postgres": {
      "fields": [
        { "key": "host",     "label": "Host",     "type": "text",     "required": true,  "placeholder": "db.example.com" },
        { "key": "port",     "label": "Port",     "type": "text",     "required": false, "placeholder": "5432" },
        { "key": "database", "label": "Database", "type": "text",     "required": true,  "placeholder": "mydb" },
        { "key": "username", "label": "Username", "type": "text",     "required": true,  "placeholder": "cspm_ro_user" },
        { "key": "password", "label": "Password", "type": "password", "required": true,  "placeholder": "" }
      ]
    },
    "mysql": {
      "fields": [
        { "key": "host",     "label": "Host",     "type": "text",     "required": true,  "placeholder": "db.example.com" },
        { "key": "port",     "label": "Port",     "type": "text",     "required": false, "placeholder": "3306" },
        { "key": "database", "label": "Database", "type": "text",     "required": true,  "placeholder": "mydb" },
        { "key": "username", "label": "Username", "type": "text",     "required": true,  "placeholder": "cspm_ro_user" },
        { "key": "password", "label": "Password", "type": "password", "required": true,  "placeholder": "" }
      ]
    },
    "mssql": {
      "fields": [
        { "key": "host",     "label": "Host",     "type": "text",     "required": true,  "placeholder": "db.example.com" },
        { "key": "port",     "label": "Port",     "type": "text",     "required": false, "placeholder": "1433" },
        { "key": "database", "label": "Database", "type": "text",     "required": true,  "placeholder": "mydb" },
        { "key": "username", "label": "Username", "type": "text",     "required": true,  "placeholder": "cspm_ro_user" },
        { "key": "password", "label": "Password", "type": "password", "required": true,  "placeholder": "" }
      ]
    },
    "mongodb": {
      "fields": [
        { "key": "connection_string", "label": "Connection String", "type": "password", "required": true, "placeholder": "mongodb+srv://user:pass@cluster.mongodb.net/db" }
      ]
    },
    "oracle": {
      "fields": [
        { "key": "host",      "label": "Host",      "type": "text",     "required": true, "placeholder": "db.example.com" },
        { "key": "port",      "label": "Port",      "type": "text",     "required": false,"placeholder": "1521" },
        { "key": "service_name","label":"Service Name","type": "text",  "required": true, "placeholder": "ORCL" },
        { "key": "username",  "label": "Username",  "type": "text",     "required": true, "placeholder": "cspm_ro" },
        { "key": "password",  "label": "Password",  "type": "password", "required": true, "placeholder": "" }
      ]
    }
  }
}
