  ],
  "enriched_from_get_describe": [
    "end_time",
    "error",
    "id",
    "name",
    "start_time",
    "status"
  ],
  "final_union": [
    "Enabled",
    "Name",
    "PrincipalId",
    "Status",
    "Tier",
    "Type",
    "current_value",
    "display",
    "end_time",
    "error",
    "etag",
    "id",
    "identity",
    "jobs_summary",
    "limit",
    "monitoring_summary",
    "name",
    "next_reset_time",
    "origin",
    "properties",
    "protected_item_count",
    "quota_period",
    "recovery_plan_count",
    "recovery_services_provider_auth_type",
    "registered_servers_count",
    "sku",
    "start_time",
    "status",
    "unit"
  ],
  "source": {
    "operation_registry": "services/recoveryservices/operation_registry.json",
    "read_ops_rule": "kind is read_list (seed) or read_get (enriched)",
    "excluded_keys": [
      "next_link",
      "nextLink",
      "continuation_token",
      "value",
      "skip_token",
      "max_results",
      "top",
      "skip"
    ]
  },
  "fields": {
    "Enabled": {
      "operators": [
        "equals",
        "not_equals"
      ],
      "dependency_index_entity": "recoveryservices.item_properties",
      "type": "boolean"
    },
    "Status": {
      "operators": [
        "equals",
        "not_equals",
        "in"
      ],
      "dependency_index_entity": "recoveryservices.item_properties",
      "type": "string"
    },
    "Type": {
      "operators": [
        "equals",
        "not_equals",
        "in"
      ],
      "dependency_index_entity": "recoveryservices.item_identity",
      "type": "string"
    },
    "PrincipalId": {
      "operators": [
        "equals",
        "not_equals",
        "contains"
      ],
      "dependency_index_entity": "recoveryservices.item_identity",
      "type": "string"
    },
    "Name": {
      "operators": [
        "equals",
        "not_equals",
        "in"
      ],
      "dependency_index_entity": "recoveryservices.item_sku",
      "type": "string"
    },
    "Tier": {
      "operators": [
        "equals",
        "not_equals",
        "in"
      ],
      "dependency_index_entity": "recoveryservices.item_sku",
      "type": "string"
    }
  }
}