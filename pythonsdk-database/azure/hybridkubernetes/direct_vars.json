{
  "service": "hybridkubernetes",
  "seed_from_list": [
    "PrincipalId",
    "Type",
    "hybrid_connection_config",
    "kubeconfigs"
  ],
  "enriched_from_get_describe": [],
  "final_union": [
    "PrincipalId",
    "Type",
    "hybrid_connection_config",
    "kubeconfigs"
  ],
  "source": {
    "operation_registry": "services/hybridkubernetes/operation_registry.json",
    "read_ops_rule": "kind is read_list (seed) or read_get (enriched)",
    "excluded_keys": [
      "next_link",
      "nextLink",
      "continuation_token",
      "value",
      "skip_token",
      "max_results",
      "top",
      "skip"
    ]
  },
  "fields": {
    "Type": {
      "operators": [
        "equals",
        "not_equals",
        "in"
      ],
      "dependency_index_entity": "hybridkubernetes.item_identity",
      "type": "string"
    },
    "PrincipalId": {
      "operators": [
        "equals",
        "not_equals",
        "contains"
      ],
      "dependency_index_entity": "hybridkubernetes.item_identity",
      "type": "string"
    }
  }
}