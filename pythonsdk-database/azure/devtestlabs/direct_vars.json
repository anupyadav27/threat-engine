      "type": "string"
    },
    "Statement": {
      "operators": [
        "contains"
      ],
      "dependency_index_entity": "devtestlabs.item_policy_violations",
      "type": "array"
    },
    "Type": {
      "operators": [
        "equals",
        "not_equals",
        "in"
      ],
      "dependency_index_entity": "devtestlabs.item_identity",
