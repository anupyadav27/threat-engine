{
  "service": "streamanalytics",
  "seed_from_list": [
    "Name",
    "PrincipalId",
    "Statement",
    "Tier",
    "Type",
    "Version",
    "current_count",
    "id",
    "max_count",
    "name",
    "type"
  ],
  "enriched_from_get_describe": [],
  "final_union": [
    "Name",
    "PrincipalId",
    "Statement",
    "Tier",
    "Type",
    "Version",
    "current_count",
    "id",
    "max_count",
    "name",
    "type"
  ],
  "source": {
    "operation_registry": "services/streamanalytics/operation_registry.json",
    "read_ops_rule": "kind is read_list (seed) or read_get (enriched)",
    "excluded_keys": [
      "next_link",
      "nextLink",
      "continuation_token",
      "value",
      "skip_token",
      "max_results",
      "top",
      "skip"
    ]
  },
  "fields": {
    "Name": {
      "operators": [
        "equals",
        "not_equals",
        "in"
      ],
      "dependency_index_entity": "streamanalytics.item_sku",
      "type": "string"
    },
    "Tier": {
      "operators": [
        "equals",
        "not_equals",
        "in"
      ],
      "dependency_index_entity": "streamanalytics.item_sku",
      "type": "string"
    },
    "Type": {
      "operators": [
        "equals",
        "not_equals",
        "in"
      ],
      "dependency_index_entity": "streamanalytics.item_identity",
      "type": "string"
    },
    "PrincipalId": {
      "operators": [
        "equals",
        "not_equals",
        "contains"
      ],
      "dependency_index_entity": "streamanalytics.item_identity",
      "type": "string"
    },
    "Version": {
      "operators": [
        "equals",
        "not_equals"
      ],
      "dependency_index_entity": "streamanalytics.item_events_out_of_order_policy",
      "type": "string"
    },
    "Statement": {
      "operators": [
        "contains"
      ],
      "dependency_index_entity": "streamanalytics.item_events_out_of_order_policy",
      "type": "array"
    }
  }
}