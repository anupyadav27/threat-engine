{
  "version": "2.0",
  "description": "Comprehensive relation types for CSPM asset graph. Extensible across clouds while preserving stable IDs used by the runtime.",
  "metadata": {
    "last_updated": "2026-01-23",
    "total_relations": 35,
    "coverage": ["AWS", "Azure", "GCP", "Multi-Cloud"]
  },
  "relation_types": [
    {
      "id": "contained_by",
      "category": "network",
      "direction": "outbound",
      "inverse": "contains",
      "description": "Resource is contained within another.",
      "examples": ["subnet → vpc", "eni → subnet", "resource_group → subscription (Azure)", "project → organization (GCP)"],
      "cardinality": "many-to-one"
    },
    {
      "id": "connected_to",
      "category": "network",
      "direction": "bidirectional",
      "inverse": "connected_to",
      "description": "Network connectivity between resources.",
      "examples": ["vpc ↔ vpc (peering)", "vpc ↔ transit_gateway", "vnet ↔ vnet (Azure)", "on_premise ↔ vpc (Direct Connect/VPN)"],
      "cardinality": "many-to-many"
    },
    {
      "id": "routes_to",
      "category": "network",
      "direction": "outbound",
      "inverse": "routed_from",
      "description": "Traffic routing relationship.",
      "examples": ["route_table → internet_gateway", "route_table → nat_gateway", "route_table → vpc_endpoint", "route_table → transit_gateway"],
      "cardinality": "many-to-many"
    },
    {
      "id": "attached_to",
      "category": "security",
      "direction": "outbound",
      "inverse": "attached_on",
      "description": "Security or resource attachment.",
      "examples": ["security_group → instance", "security_group → eni", "nacl → subnet", "waf → alb", "nsg → nic (Azure)"],
      "cardinality": "many-to-many"
    },
    {
      "id": "allows_traffic_from",
      "category": "security",
      "direction": "inbound",
      "inverse": "allows_traffic_to",
      "description": "Security rule allowing traffic.",
      "examples": ["security_group_rule → cidr_block", "security_group_rule → security_group", "firewall_rule → ip_range (GCP)"],
      "cardinality": "many-to-many"
    },
    {
      "id": "uses",
      "category": "identity",
      "direction": "outbound",
      "inverse": "used_by",
      "description": "Resource uses another resource or identity.",
      "examples": ["ec2_instance → instance_profile", "lambda_function → execution_role", "ecs_task → task_role", "instance_profile → iam_role"],
      "cardinality": "many-to-one"
    },
    {
      "id": "assumes",
      "category": "identity",
      "direction": "outbound",
      "inverse": "assumed_by",
      "description": "Principal assumes a role.",
      "examples": ["service → iam_role", "federated_user → iam_role", "cross_account → iam_role"],
      "cardinality": "many-to-many"
    },
    {
      "id": "member_of",
      "category": "identity",
      "direction": "outbound",
      "inverse": "has_member",
      "description": "Identity membership in a group.",
      "examples": ["iam_user → iam_group", "service_principal → group (Azure AD)", "user → organizational_unit"],
      "cardinality": "many-to-many"
    },
    {
      "id": "has_policy",
      "category": "identity",
      "direction": "inbound",
      "inverse": "policy_attached_to",
      "description": "IAM policy attachment.",
      "examples": ["iam_role → iam_policy", "iam_user → iam_policy", "iam_group → iam_policy", "s3_bucket → bucket_policy"],
      "cardinality": "many-to-many"
    },
    {
      "id": "grants_access_to",
      "category": "identity",
      "direction": "outbound",
      "inverse": "accessible_by",
      "description": "Policy grants access to a resource.",
      "examples": ["iam_policy → s3_bucket", "iam_policy → dynamodb_table", "rbac_role → resource (Azure)"],
      "cardinality": "many-to-many"
    },
    {
      "id": "controlled_by",
      "category": "identity",
      "direction": "outbound",
      "inverse": "controls",
      "description": "Resource controlled/owned by a principal.",
      "examples": ["resource → creator_identity", "resource → owner_tag"],
      "cardinality": "many-to-one"
    },
    {
      "id": "encrypted_by",
      "category": "data",
      "direction": "outbound",
      "inverse": "encrypts",
      "description": "Resource encrypted by key.",
      "examples": ["ebs_volume → kms_key", "s3_bucket → kms_key", "rds_instance → kms_key", "storage_account → key_vault_key (Azure)"],
      "cardinality": "many-to-one"
    },
    {
      "id": "stores_data_in",
      "category": "data",
      "direction": "outbound",
      "inverse": "stores_data_from",
      "description": "Data storage relationship.",
      "examples": ["application → s3_bucket", "application → rds_database", "lambda → dynamodb_table"],
      "cardinality": "many-to-many"
    },
    {
      "id": "backs_up_to",
      "category": "data",
      "direction": "outbound",
      "inverse": "backup_of",
      "description": "Backup relationship.",
      "examples": ["ebs_volume → ebs_snapshot", "rds_instance → rds_snapshot", "ec2_instance → ami", "vm → recovery_vault (Azure)"],
      "cardinality": "one-to-many"
    },
    {
      "id": "replicates_to",
      "category": "data",
      "direction": "outbound",
      "inverse": "replica_of",
      "description": "Data replication relationship.",
      "examples": ["s3_bucket → s3_bucket (cross-region)", "rds_instance → rds_read_replica", "dynamodb_table → dynamodb_global_table"],
      "cardinality": "one-to-many"
    },
    {
      "id": "logging_enabled_to",
      "category": "monitoring",
      "direction": "outbound",
      "inverse": "receives_logs_from",
      "description": "Logging destination.",
      "examples": ["cloudtrail → s3_bucket", "vpc_flow_logs → cloudwatch_log_group", "alb → s3_bucket", "diagnostic_settings → log_analytics (Azure)"],
      "cardinality": "many-to-many"
    },
    {
      "id": "monitored_by",
      "category": "monitoring",
      "direction": "outbound",
      "inverse": "monitors",
      "description": "Monitoring relationship.",
      "examples": ["resource → cloudwatch_alarm", "application → x-ray", "resource → azure_monitor"],
      "cardinality": "many-to-many"
    },
    {
      "id": "triggers",
      "category": "compute",
      "direction": "outbound",
      "inverse": "triggered_by",
      "description": "Event triggering relationship.",
      "examples": ["s3_event → lambda_function", "eventbridge_rule → lambda_function", "sns_topic → lambda_function", "cloudwatch_alarm → sns_topic"],
      "cardinality": "many-to-many"
    },
    {
      "id": "invokes",
      "category": "compute",
      "direction": "outbound",
      "inverse": "invoked_by",
      "description": "Service invocation.",
      "examples": ["step_function → lambda_function", "api_gateway → lambda_function", "lambda_function → lambda_function"],
      "cardinality": "many-to-many"
    },
    {
      "id": "serves_traffic_for",
      "category": "compute",
      "direction": "outbound",
      "inverse": "receives_traffic_from",
      "description": "Load balancing relationship.",
      "examples": ["alb → target_group", "target_group → ec2_instance", "nlb → target_group", "load_balancer → backend_pool (Azure)"],
