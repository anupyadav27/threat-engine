    },
    {
      "id": "runs_on",
      "category": "compute",
      "direction": "outbound",
      "inverse": "hosts",
      "description": "Workload hosting relationship.",
      "examples": ["container → ecs_task", "ecs_task → ec2_instance", "pod → kubernetes_node", "app_service → app_service_plan (Azure)"],
      "cardinality": "many-to-one"
    },
    {
      "id": "scales_with",
      "category": "compute",
      "direction": "outbound",
      "inverse": "scaling_for",
      "description": "Auto-scaling relationship.",
      "examples": ["auto_scaling_group → launch_template", "ecs_service → auto_scaling_policy", "vmss → scaling_policy (Azure)"],
      "cardinality": "many-to-one"
    },
    {
      "id": "cached_by",
      "category": "compute",
      "direction": "outbound",
      "inverse": "caches",
      "description": "Caching relationship.",
      "examples": ["application → elasticache", "api_gateway → cache", "cdn → origin"],
      "cardinality": "many-to-one"
    },
    {
      "id": "exposed_through",
      "category": "exposure",
      "direction": "outbound",
      "inverse": "exposes",
      "description": "External exposure mechanism.",
      "examples": ["service → api_gateway", "service → cloudfront", "application → app_gateway (Azure)"],
      "cardinality": "many-to-many"
    },
    {
      "id": "internet_connected",
      "category": "exposure",
      "direction": "outbound",
      "inverse": null,
      "aliases": ["internet_accessible"],
      "description": "Resource has internet exposure.",
      "examples": ["ec2_instance → internet (public IP)", "s3_bucket → internet (public access)", "rds_instance → internet (publicly accessible)"],
      "cardinality": "many-to-one"
    }
    ,
    {
      "id": "manages",
      "category": "management",
      "direction": "outbound",
      "inverse": "managed_by",
      "description": "Management relationship.",
      "examples": ["systems_manager → ec2_instance", "config_rule → resource", "azure_policy → resource"],
      "cardinality": "many-to-many"
    },
    {
      "id": "deployed_by",
      "category": "management",
      "direction": "outbound",
