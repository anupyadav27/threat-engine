{
  "version": "1.0",
  "description": "Resource domain classification. Maps resource_type patterns to primary and secondary security domains.",
  "metadata": {
    "last_updated": "2026-03-14",
    "total_domains": 14
  },
  "domains": {
    "IDENTITY": {
      "description": "IAM, authentication, federation",
      "patterns": {
        "aws": ["iam.*", "cognito.*", "sso.*", "sts.*", "organizations.*"],
        "azure": ["microsoft.authorization.*", "microsoft.managedidentity.*", "microsoft.aad.*"],
        "gcp": ["iam.*", "accesscontextmanager.*"],
        "oci": ["identity.*"],
        "ibm": ["iam.*"],
        "alicloud": ["ram.*"],
        "k8s": ["rbac.*", "core.serviceaccount"]
      }
    },
    "NETWORK": {
      "description": "VPCs, subnets, routing, DNS, ENIs, VPC endpoints",
      "patterns": {
        "aws": ["ec2.vpc", "ec2.subnet", "ec2.route-table", "ec2.internet-gateway", "ec2.nat-gateway", "ec2.transit-gateway*", "ec2.network-interface", "ec2.vpc-endpoint", "ec2.vpn*", "ec2.dhcp-options", "ec2.elastic-ip", "ec2.vpc-peering*", "route53.*", "directconnect.*"],
        "azure": ["microsoft.network/virtualnetworks*", "microsoft.network/subnets", "microsoft.network/routetables", "microsoft.network/natgateways", "microsoft.network/publicipaddresses", "microsoft.network/privatednszones*", "microsoft.network/privateendpoints", "microsoft.network/virtualnetworkgateways"],
