        "oci": ["core.vcn*", "core.subnet*", "core.internetgateway", "core.natgateway", "core.routetable"],
        "ibm": ["is.vpc", "is.subnet", "is.floating-ip", "is.public-gateway", "is.network-acl", "is.routing-table"],
        "alicloud": ["vpc.*"],
        "k8s": ["networking.*"]
      }
    },
    "NETWORK_SECURITY": {
      "description": "Firewalls, security groups, ACLs, WAF",
      "patterns": {
        "aws": ["ec2.security-group", "ec2.network-acl", "waf.*", "wafv2.*", "shield.*", "firewall.*"],
