    value: 'true'
- rule_id: aws.ec2.vpnconnection.ike_phase_encryption_strong_configured
  for_each: aws.ec2.get_active_vpn_tunnel_status
  conditions:
    all:
    - var: item.Options.IkeVersion
      op: equals
      value: '2'
    - var: item.Options.EncryptionAlgorithm
      op: equals
      value: AES256
- rule_id: aws.ec2.vpnconnection.pre_shared_keys_key_rotation_policy_configured
  for_each: aws.ec2.describe_vpn_connections
  conditions:
    all:
    - var: item.VpnConnections.VpnConnectionId
      op: exists
      value: null
    - var: item.VpnConnections.VpnConnectionPreSharedKeyArn
      op: exists
      value: null
- rule_id: aws.ec2.vpnconnection.tunnel_health_monitoring_enabled
  for_each: aws.ec2.describe_vpn_connections
  conditions:
    all:
    - var: item.VpnConnections.VpnConnectionId
      op: exists
      value: null
    - var: item.VpnConnections.VpnConnectionVgwTelemetry
      op: exists
      value: null
