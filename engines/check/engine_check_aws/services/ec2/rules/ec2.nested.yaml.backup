checks:
- rule_id: aws.ec2.account.block_public_access_configured
  for_each: aws.ec2.describe_vpc_block_public_access_options
  conditions:
    all:
    - var: item.VpcBlockPublicAccessOptions.State
      op: equals
      value: enabled
    - var: item.VpcBlockPublicAccessOptions.InternetGatewayBlockMode
      op: equals
      value: block
- rule_id: aws.ec2.ami.approved_image_allowlist_enforced
  for_each: aws.ec2.list_images_in_recycle_bin
  conditions:
    all:
    - var: item.ImageId
      op: exists
      value: null
    - var: item.ImageAllowed
      op: equals
      value: 'true'
- rule_id: aws.ec2.ami.encryption_at_rest_enabled
  for_each: aws.ec2.describe_import_image_tasks
  conditions:
    var: item.Encrypted
    op: equals
    value: 'true'
- rule_id: aws.ec2.ami.image_signed_and_verified
  for_each: aws.ec2.list_images_in_recycle_bin
  conditions:
    all:
    - var: item.Images.ImageId
      op: exists
      value: null
    - var: item.Images.OwnerId
      op: exists
      value: null
- rule_id: aws.ec2.ami.not_publicly_shared_configured
  for_each: aws.ec2.describe_fpga_images
  conditions:
    var: item.Public
    op: equals
    value: 'false'
- rule_id: aws.ec2.ami.vuln_scanned_no_critical_configured
  for_each: aws.ec2.list_images_in_recycle_bin
  conditions:
    all:
    - var: item.Images.ImageId
      op: exists
      value: null
    - var: item.Images.State
      op: equals
      value: available
- rule_id: aws.ec2.amipublic.ami_public_configured
  for_each: aws.ec2.describe_fpga_images
  conditions:
    var: item.Public
    op: equals
    value: 'false'
- rule_id: aws.ec2.autoscalinggroup.instance_profile_least_privilege
  for_each: aws.ec2.describe_iam_instance_profile_associations
  conditions:
    all:
    - var: item.IamInstanceProfileAssociations.IamInstanceProfile
      op: exists
      value: null
    - var: item.IamInstanceProfileAssociations.State
      op: equals
      value: associated
- rule_id: aws.ec2.autoscalinggroup.no_public_ip_assigned_configured
  for_each: aws.ec2.describe_subnets
  conditions:
    var: item.MapPublicIpOnLaunch
    op: equals
    value: 'false'
- rule_id: aws.ec2.autoscalinggroup.uses_approved_launch_template_configured
  for_each: aws.ec2.describe_launch_template_versions
  conditions:
    all:
    - var: item.LaunchTemplateId
      op: exists
      value: null
    - var: item.LaunchTemplateName
      op: exists
      value: null
- rule_id: aws.ec2.autoscalinggroup.volumes_encrypted
  for_each: aws.ec2.describe_import_image_tasks
  conditions:
    var: item.Encrypted
    op: equals
    value: 'true'
- rule_id: aws.ec2.customergateway.api_ip_addresses_valid_and_owned_configured
  for_each: aws.ec2.describe_customer_gateways
  conditions:
    all:
    - var: item.IpAddress
      op: exists
      value: null
    - var: item.CustomerGatewayId
      op: exists
      value: null
- rule_id: aws.ec2.customergateway.no_public_management_interfaces_exposed_configured
  for_each: aws.ec2.describe_customer_gateways
  conditions:
    all:
    - var: item.IpAddress
      op: exists
      value: null
    - var: item.State
      op: equals
      value: available
- rule_id: aws.ec2.dedicatedhost.host_sharing_restricted
  for_each: aws.ec2.describe_hosts
  conditions:
    var: item.AutoPlacement
    op: equals
    value: 'off'
- rule_id: aws.ec2.dedicatedhost.instance_auto_placement_controlled_configured
  for_each: aws.ec2.describe_hosts
  conditions:
    var: item.AutoPlacement
    op: equals
    value: 'on'
- rule_id: aws.ec2.ebs.default_encryption_configured
  for_each: aws.ec2.get_ebs_encryption_by_default
  conditions:
    var: item.EbsEncryptionByDefault
    op: equals
    value: 'true'
- rule_id: aws.ec2.ebs.public_snapshot_configured
  for_each: aws.ec2.list_volumes_in_recycle_bin
  conditions:
    all:
    - var: item.Snapshots.SnapshotId
      op: exists
      value: null
    - var: item.Snapshots.Encrypted
      op: equals
      value: 'false'
- rule_id: aws.ec2.ebs.volume_encryption_configured
  for_each: aws.ec2.describe_import_image_tasks
  conditions:
    var: item.Encrypted
    op: equals
    value: 'true'
- rule_id: aws.ec2.ebs_public_snapshot.ebs_public_snapshot_configured
  for_each: aws.ec2.list_volumes_in_recycle_bin
  conditions:
    all:
    - var: item.Snapshots.SnapshotId
      op: exists
      value: null
    - var: item.Snapshots.Encrypted
      op: equals
      value: 'false'
- rule_id: aws.ec2.eip.not_in_use
  for_each: aws.ec2.describe_addresses
  conditions:
    var: item.AssociationId
    op: not_exists
    value: null
- rule_id: aws.ec2.eip.shodan_exposure_detected
  for_each: aws.ec2.describe_address_transfers
  conditions:
    var: item.PublicIp
    op: exists
    value: null
- rule_id: aws.ec2.group.cifs_access_restriction_tcp_port_445_configured
  for_each: aws.ec2.describe_security_group_rules
  conditions:
    all:
    - var: item.SecurityGroupRules.FromPort
      op: equals
      value: '445'
    - var: item.SecurityGroupRules.ToPort
      op: equals
      value: '445'
    - var: item.SecurityGroupRules.IpProtocol
      op: equals
      value: tcp
    - var: item.SecurityGroupRules.CidrIpv4
      op: not_equals
      value: 0.0.0.0/0
    - var: item.SecurityGroupRules.CidrIpv6
      op: not_equals
      value: ::/0
- rule_id: aws.ec2.group.cifs_unrestricted_access_configured
  for_each: aws.ec2.describe_security_group_rules
  conditions:
    any:
    - var: item.SecurityGroupRules.IpProtocol
      op: equals
      value: tcp
    - var: item.SecurityGroupRules.FromPort
      op: equals
      value: '445'
    - var: item.SecurityGroupRules.ToPort
      op: equals
      value: '445'
    - var: item.SecurityGroupRules.CidrIpv4
      op: equals
      value: 0.0.0.0/0
- rule_id: aws.ec2.group.ingress_ipv6_restriction_configured
  for_each: aws.ec2.describe_security_group_rules
  conditions:
    var: item.CidrIpv6
    op: exists
    value: null
- rule_id: aws.ec2.instance.data_volumes_encrypted_cmek
  for_each: aws.ec2.describe_import_image_tasks
  conditions:
    all:
    - var: item.Encrypted
      op: equals
      value: 'true'
    - var: item.KmsKeyId
      op: exists
      value: null
- rule_id: aws.ec2.instance.detailed_monitoring_enabled
  for_each: aws.ec2.describe_instances
  conditions:
    var: item.Monitoring.State
    op: equals
    value: enabled
- rule_id: aws.ec2.instance.iam_role_compliance_configured
  for_each: aws.ec2.describe_addresses
  conditions:
    all:
    - var: item.IamInstanceProfileAssociations.InstanceId
      op: exists
      value: null
    - var: item.IamInstanceProfileAssociations.IamInstanceProfile
      op: exists
      value: null
- rule_id: aws.ec2.instance.imds_hardened_configured
  for_each: aws.ec2.get_instance_metadata_defaults
  conditions:
    all:
    - var: item.MetadataOptions.HttpTokens
      op: equals
      value: required
    - var: item.MetadataOptions.HttpEndpoint
      op: equals
      value: enabled
- rule_id: aws.ec2.instance.imdsv2_enabled
  for_each: aws.ec2.get_instance_metadata_defaults
  conditions:
    var: item.MetadataOptions.HttpTokens
    op: equals
    value: required
- rule_id: aws.ec2.instance.internet_facing_with_instance_profile_configured
  for_each: aws.ec2.describe_address_transfers
  conditions:
    all:
    - var: item.NetworkInterfaces.Association.PublicIp
      op: exists
      value: null
    - var: item.IamInstanceProfile
      op: exists
      value: null
- rule_id: aws.ec2.instance.managed_by_ssm_configured
  for_each: aws.ec2.describe_iam_instance_profile_associations
  conditions:
    var: item.IamInstanceProfile
    op: exists
    value: null
