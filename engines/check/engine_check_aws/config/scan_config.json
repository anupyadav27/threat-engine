{
  "scan_modes": {
    "discovery_only": {
      "enabled": true,
      "description": "Run only discovery phase"
    },
    "check_only": {
      "enabled": true,
      "description": "Run only check phase (requires existing discovery)"
    },
    "full_scan": {
      "enabled": true,
      "description": "Run discovery + checks"
    },
    "deviation_scan": {
      "enabled": false,
      "description": "Detect configuration deviations"
    },
    "drift_scan": {
      "enabled": false,
      "description": "Detect configuration drift over time"
    }
  },
  "default_scan_mode": "full_scan",
  "service_selection": {
    "mode": "enabled",
    "description": "Service selection mode: 'all', 'enabled', 'specific'",
    "include_services": [],
    "exclude_services": []
  },
  "output": {
    "progressive": true,
    "description": "Write output progressively after each service/region",
    "update_interval": 1,
    "description_interval": "Update progress.json after each service completion"
  },
  "logging": {
    "phase_specific": true,
    "description": "Use separate log files for each phase",
    "log_level": "INFO"
  }
}

