{
  "filename": "allowing_requests_with_excessive_content_length_is_metadata.json",
  "rule_id": "allowing_requests_excessive_content",
  "title": "Allowing requests with excessive content length is security-sensitive",
  "description": "Setting excessive content length limits (over 8MB for file uploads or 2MB for other requests) can lead to DoS attacks and resource exhaustion. Applications should implement reasonable size limits to prevent malicious large file uploads that could overwhelm server resources.",
  "status": "ready",
  "defaultSeverity": "Medium",
  "category": "Security",
  "recommendation": "Limit file upload sizes to 8MB or less, and other request body sizes to 2MB or less. Use appropriate middleware configuration for your framework (Express, Multer, Formidable, etc.).",
  "impact": "Security risk",
  "tags": [
    "security",
    "dos-prevention",
    "resource-management",
    "file-upload"
  ],
  "examples": {
    "noncompliant": [
      "form.maxFileSize = 10000000; // 10MB exceeds 8MB limit",
      "multer({ limits: { fileSize: 15000000 } }); // 15MB too large",
      "app.use(express.json({ limit: '20mb' })); // 20MB excessive",
      "new Formidable(); // Default 200MB is excessive"
    ],
    "compliant": [
      "form.maxFileSize = 8000000; // 8MB at recommended limit",
      "multer({ limits: { fileSize: 5000000 } }); // 5MB within limit",
      "app.use(express.json({ limit: '2mb' })); // 2MB appropriate",
      "busboy({ limits: { fileSize: 8000000 } }); // 8MB acceptable"
    ]
  },
  "references": [
    "https://rules.sonarsource.com/javascript/RSPEC-5693"
  ],
  "logic": {
    "node_types": [
      "Statement",
      "CallExpression",
      "Property",
      "AssignmentExpression"
    ],
    "checks": [
      {
        "type": "regex_match",
        "message": "Excessive content length limit detected. Reduce file upload limits to 8MB or less, and other request limits to 2MB or less to prevent DoS attacks.",
        "property_path": [
          "source"
        ],
        "patterns": [
          "maxFileSize\\s*[=:]\\s*([9-9]\\d{6,}|[1-9]\\d{7,})",
          "fileSize\\s*[=:]\\s*([9-9]\\d{6,}|[1-9]\\d{7,})",
          "limit\\s*[=:]\\s*['\"]([9-9]\\d*mb|[1-9]\\d+mb)['\"]?",
          "limit\\s*[=:]\\s*([9-9]\\d{6,}|[1-9]\\d{7,})",
          "new\\s+Formidable\\s*\\(\\s*\\)",
          "maxFieldsSize\\s*[=:]\\s*([3-9]\\d{6,}|[1-9]\\d{7,})",
          "maxFields\\s*[=:]\\s*(1000[1-9]|[1-9]\\d{4,})",
          "bodyParser\\..*limit\\s*[=:]\\s*['\"]([3-9]mb|[1-9]\\d+mb)['\"]?",
          "express\\.(json|raw|text|urlencoded)\\(.*limit\\s*[=:]\\s*['\"]([3-9]mb|[1-9]\\d+mb)['\"]?"
        ]
      }
    ]
  }
}