{
  "filename": "jsx_list_components_should_include_a_key_property_metadata.json",
  "rule_id": "jsx_list_components_include",
  "title": "JSX list components should include a key property",
  "description": "JSX list components should have a key propertyAnalyze your codeintentionality-clearmaintainabilityCode SmellreactjsxperformanceWhy is this an issue?More InfoTo optimize the rendering of React list components, a unique identifier (UID) is required for each list item. This UID lets React identify the item throughout its lifetime. To provide it, use thekeyattribute of the list item.",
  "status": "ready",
  "defaultSeverity": "Major",
  "category": "Security",
  "recommendation": "Refactor to eliminate the flagged pattern.",
  "impact": "Security risk",
  "tags": [
    "security",
    "bug",
    "deprecated",
    "async"
  ],
  "examples": {
    "noncompliant": [
      "items.map(item => <div>{item.name}</div>)",
      "data.map(item => React.createElement('span', null, item.value))",
      "users.map(user => <UserCard user={user} />)",
      "[<div>Item 1</div>, <div>Item 2</div>]"
    ],
    "compliant": [
      "items.map(item => <div key={item.id}>{item.name}</div>)",
      "data.map(item => React.createElement('span', { key: item.id }, item.value))",
      "users.map(user => <UserCard key={user.id} user={user} />)",
      "[<div key='1'>Item 1</div>, <div key='2'>Item 2</div>]"
    ]
  },
  "references": [
    "https://rules.sonarsource.com/javascript/RSPEC-6477"
  ],
  "logic": {
    "node_types": [
      "FunctionDeclaration",
      "Statement",
      "VariableDeclaration"
    ],
    "checks": [
      {
        "type": "regex_match",
        "property_path": [
          "source"
        ],
        "pattern": "\\.map\\([^)]*=>.*<div>\\{[^}]*\\}\\s*</div>\\s*\\)\\s*\\}[^}]*\\)\\)",
        "message": "JSX div elements in map() should include a key property"
      },
      {
        "type": "regex_match",
        "property_path": [
          "source"
        ],
        "pattern": "\\.map\\([^)]*=>.*<li>\\{[^}]*\\}\\s*</li>\\s*\\)\\s*\\}[^}]*\\)\\)",
        "message": "JSX li elements in map() should include a key property"
      },
      {
        "type": "regex_match",
        "property_path": [
          "source"
        ],
        "pattern": "\\.map\\([^)]*=>.*<tr>.*</tr>\\s*\\)\\s*\\}[^}]*\\)\\)",
        "message": "JSX tr elements in map() should include a key property"
      },
      {
        "type": "regex_match",
        "property_path": [
          "source"
        ],
        "pattern": "\\.map\\([^)]*=>.*createElement\\('div',\\s*null[,)]",
        "message": "React.createElement in map() should include key property instead of null"
      },
      {
        "type": "regex_match",
        "property_path": [
          "source"
        ],
        "pattern": "<div>Element [0-9]</div>,\\s*//[^\\n]*Missing key",
        "message": "JSX elements in arrays should include key properties"
      },
      {
        "type": "regex_match",
        "property_path": [
          "source"
        ],
        "pattern": "\\.push\\(<span>",
        "message": "JSX elements created with push() should include key properties"
      },
      {
        "type": "regex_match",
        "property_path": [
          "source"
        ],
        "pattern": "\\.map\\([^)]*=>.*<span>\\{[^}]*\\}\\s*</span>",
        "message": "JSX span elements in map() should include key properties"
      },
      {
        "type": "regex_match",
        "property_path": [
          "source"
        ],
        "pattern": "\\.map\\([^)]*=>.*<section>.*</section>\\s*\\)\\s*\\}[^}]*\\)\\)",
        "message": "JSX section elements in map() should include key properties"
      },
      {
        "type": "regex_match",
        "property_path": [
          "source"
        ],
        "pattern": "\\.map\\([^)]*=>.*<[A-Z][a-zA-Z]*\\s[^>]*>.*</[A-Z][a-zA-Z]*>\\s*\\)\\s*\\}[^}]*\\)\\)",
        "message": "JSX components in map() should include key properties"
      },
      {
        "type": "regex_match",
        "property_path": [
          "source"
        ],
        "pattern": "\\.filter\\([^)]*\\)\\.map\\([^)]*=>.*<div>\\{[^}]*\\}\\s*</div>",
        "message": "JSX elements in filter().map() chains should include key properties"
      },
      {
        "type": "regex_match",
        "property_path": [
          "source"
        ],
        "pattern": "\\.flatMap\\([^)]*=>.*<div>\\{[^}]*\\}\\s*</div>",
        "message": "JSX elements in flatMap() should include key properties"
      },
      {
        "type": "regex_match",
        "property_path": [
          "source"
        ],
        "pattern": "\\.map\\([^)]*=>.*createElement\\('span',\\s*\\{\\s*className:[^}]*\\}",
        "message": "React.createElement in map() should include key property in props object"
      },
      {
        "type": "regex_match",
        "property_path": [
          "source"
        ],
        "pattern": "<React\\.Fragment>\\s*$",
        "message": "React Fragment in map() should include key properties"
      },
      {
        "type": "custom_function",
        "property_path": [
          "source"
        ],
        "function_name": "detectMissingJSXKeys",
        "message": "JSX elements in list contexts should include key properties for optimal React performance"
      }
    ]
  }
