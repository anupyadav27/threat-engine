{
  "filename": "an_open_curly_brace_should_be_placed_at_the_end_of_metadata.json",
  "rule_id": "open_curly_brace_placed",
  "title": "An open curly brace should be placed at the end of a line",
  "description": "Enforces consistent brace style by requiring opening curly braces to be placed at the end of the line rather than on a new line. This follows the standard JavaScript convention and improves code readability and consistency.",
  "status": "ready",
  "defaultSeverity": "Minor",
  "category": "Code Style",
  "recommendation": "Move the opening curly brace to the end of the same line as the function declaration, if statement, or other construct.",
  "impact": "Maintainability and code consistency",
  "examples": {
    "noncompliant": [
      "function badStyle()\n{\n    return true;\n}",
      "if (condition)\n{\n    doSomething();\n}",
      "const obj = {\n    method: function()\n    {\n        return 'bad';\n    }\n}"
    ],
    "compliant": [
      "function goodStyle() {\n    return true;\n}",
      "if (condition) {\n    doSomething();\n}",
      "const obj = {\n    method: function() {\n        return 'good';\n    }\n}"
    ]
  },
  "references": [
    "https://rules.sonarsource.com/javascript/RSPEC-1105"
  ],
  "logic": {
    "node_types": [
      "FunctionDeclaration",
      "FunctionExpression",
      "IfStatement",
      "ForStatement",
      "WhileStatement",
      "CallExpression"
    ],
    "checks": [
      {
        "type": "regex_match",
        "message": "Place the opening curly brace at the end of this line, not on a new line. Follow standard JavaScript brace style conventions.",
        "property_path": [
          "source"
        ],
        "patterns": [
          "\\)\\s*\\n\\s*\\{",
          "function\\s+\\w+\\s*\\([^)]*\\)\\s*\\n\\s*\\{",
          "function\\s*\\([^)]*\\)\\s*\\n\\s*\\{",
          "if\\s*\\([^)]*\\)\\s*\\n\\s*\\{",
          "else\\s*\\n\\s*\\{",
          "for\\s*\\([^)]*\\)\\s*\\n\\s*\\{",
          "while\\s*\\([^)]*\\)\\s*\\n\\s*\\{",
          "catch\\s*\\([^)]*\\)\\s*\\n\\s*\\{",
          "try\\s*\\n\\s*\\{",
          "finally\\s*\\n\\s*\\{"
        ]
      }
    ]
  }
}