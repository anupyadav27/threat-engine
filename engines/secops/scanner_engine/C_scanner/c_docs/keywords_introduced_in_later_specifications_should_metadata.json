{
  "filename": "keywords_introduced_in_later_specifications_should_metadata.json",
  "rule_id": "keywords_introduced_later_specifications",
  "title": "Keywords introduced in later specifications should be avoided as identifiers",
  "description": "While keywords introduced in later standards can legally be used as identifiers in code compiled to earlier standards, doing so will eventually cause problems. Such code will cause compile errors if (when) the compiler is upgraded, and fixing those errors could be difficult and painful. Additionally, such misuse of keywords has the potential to thoroughly confuse people who are unfamiliar with the code base, possibly leading them to introduce additional errors.",
  "status": "ready",
  "defaultSeverity": "Major",
  "category": "Maintainability",
  "recommendation": "Review and fix according to the rule guidelines.",
  "impact": "Maintainability issue",
  "tags": [
    "convention"
  ],
  "examples": {
    "noncompliant": [
      "int inline = 5;  // Noncompliant if compiling to C90",
      "char restrict[100];  // Noncompliant if compiling to C90",
      "void func(int _Bool);  // Noncompliant if compiling to C90"
    ],
    "compliant": [
      "int inline_value = 5;  // Compliant - not using keyword",
      "char restricted_array[100];  // Compliant",
      "void func(int boolean_flag);  // Compliant"
    ]
  },
  "references": [
    "https://rules.sonarsource.com/c/RSPEC-1760"
  ],
  "logic": {
    "node_types": [
      "VariableDeclaration",
      "FunctionDefinition",
      "ParameterDeclaration",
      "TypedefDeclaration",
      "StructDeclaration",
      "EnumDeclaration"
    ],
    "checks": [
      {
        "type": "regex_match",
        "property_path": ["source"],
        "patterns": [
          "\\b(?:int|char|short|long|float|double|void|signed|unsigned|const|volatile|static|extern|auto|register)\\s+(inline|restrict|_Bool|_Complex|_Imaginary|_Alignas|_Alignof|_Atomic|_Static_assert|_Noreturn|_Thread_local|_Generic|typeof|typeof_unqual|_Decimal128|_Decimal32|_Decimal64|_BitInt)\\s*(?:\\[|\\s*[=;,)])",
          "\\b(?:struct|union|enum)\\s+(inline|restrict|_Bool|_Complex|_Imaginary|_Alignas|_Alignof|_Atomic|_Static_assert|_Noreturn|_Thread_local|_Generic|typeof|typeof_unqual|_Decimal128|_Decimal32|_Decimal64|_BitInt)\\s*[\\{;]",
          "\\btypedef\\s+[^;]+\\s+(inline|restrict|_Bool|_Complex|_Imaginary|_Alignas|_Alignof|_Atomic|_Static_assert|_Noreturn|_Thread_local|_Generic|typeof|typeof_unqual|_Decimal128|_Decimal32|_Decimal64|_BitInt)\\s*;",
          "\\b(?:void|int|char|short|long|float|double|signed|unsigned)\\s+\\w+\\s*\\([^)]*(?:int|char|short|long|float|double|void|signed|unsigned)\\s+(inline|restrict|_Bool|_Complex|_Imaginary|_Alignas|_Alignof|_Atomic|_Static_assert|_Noreturn|_Thread_local|_Generic|typeof|typeof_unqual|_Decimal128|_Decimal32|_Decimal64|_BitInt)\\s*[,)]",
          "\\b(?:int|char|short|long|float|double|void|signed|unsigned)\\s+(inline|restrict|_Bool|_Complex|_Imaginary|_Alignas|_Alignof|_Atomic|_Static_assert|_Noreturn|_Thread_local|_Generic|typeof|typeof_unqual|_Decimal128|_Decimal32|_Decimal64|_BitInt)\\s*\\(",
          "#define\\s+(inline|restrict|_Bool|_Complex|_Imaginary|_Alignas|_Alignof|_Atomic|_Static_assert|_Noreturn|_Thread_local|_Generic|typeof|typeof_unqual|_Decimal128|_Decimal32|_Decimal64|_BitInt)\\b"
        ],
        "message": "Later C specification keyword used as identifier. This will cause compilation errors when upgrading to newer C standards.",
        "negative_patterns": [
          "^\\s*inline\\s+(?:int|char|short|long|float|double|void|signed|unsigned|const|volatile|static|extern|auto|register)",
          "^\\s*_Bool\\s+\\w+\\s*[=;]",
          "\\*\\s*restrict\\s+\\w+",
          "\\bfloat\\s+_Complex\\s+\\w+",
          "\\bdouble\\s+_Complex\\s+\\w+",
          "\\bfloat\\s+_Imaginary\\s+\\w+",
          "\\bdouble\\s+_Imaginary\\s+\\w+"
        ]
      }
    ]
  }
}