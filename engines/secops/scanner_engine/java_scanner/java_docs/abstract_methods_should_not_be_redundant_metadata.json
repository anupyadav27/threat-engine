{
  "filename": "abstract_methods_should_not_be_redundant_metadata.json",
  "rule_id": "VULNERABILITY_CONSTANT_ISSUE_RSPEC_3038",
  "title": "Avoid Redundant Abstract Methods",
  "description": "It's unnecessary to define an abstract method with the same signature as a method in an interface that the class implements. Any concrete child classes will have to implement the method either way.",
  "status": "ready",
  "defaultSeverity": "Major",
  "category": "Java",
  "recommendation": "Remove redundant abstract methods",
  "impact": "Improves code maintainability and reduces potential for errors",
  "examples": {
    "noncompliant": [],
    "compliant": []
  },
  "references": [
    "https://rules.sonarsource.com/java/RSPEC-3038"
  ],
  "logic": {
    "node_types": [
      "Class",
      "Method"
    ],
    "checks": [
      {
        "type": "required_value",
        "property_path": [
          "modifiers"
        ],
        "required_values": [
          "abstract"
        ],
        "message": "Abstract method detected in class."
      },
      {
        "type": "property_comparison",
        "property_path": [
          "type",
          "implements"
        ],
        "operator": "contains",
        "comparator_property_path": [
          "name"
        ],
        "message": "Class implements an interface."
      },
      {
        "type": "regex_match",
        "property_path": [
          "name"
        ],
        "regex": "^[a-zA-Z_][a-zA-Z0-9_]*$",
        "message": "Method name matches valid identifier."
      },
      {
        "type": "property_comparison",
        "property_path": [
          "parameters"
        ],
        "operator": "equals",
        "comparator_property_path": [
          "interface",
          "method",
          "parameters"
        ],
        "message": "Method parameters match those of an interface method."
      },
      {
        "type": "property_comparison",
        "property_path": [
          "returnType"
        ],
        "operator": "equals",
        "comparator_property_path": [
          "interface",
          "method",
          "returnType"
        ],
        "message": "Method return type matches that of an interface method."
      }
    ]
  }
}