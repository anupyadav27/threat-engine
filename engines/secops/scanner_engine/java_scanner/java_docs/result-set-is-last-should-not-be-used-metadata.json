{
  "filename": "result-set-is-last-should-not-be-used-metadata.json",
  "rule_id": "vulnerability_avoid_resultset_islast",
  "title": "Avoid using ResultSet.isLast()",
  "description": "There are several reasons to avoid using this method. ResultSet.next() is a good alternative as it does not have the mentioned issues and is always supported.",
  "status": "ready",
  "defaultSeverity": "Major",
  "category": "Vulnerability",
  "recommendation": "Use ResultSet.next() instead",
  "impact": "Improves code quality and security",
  "examples": {
    "noncompliant": [],
    "compliant": []
  },
  "references": [
    "https://rules.sonarsource.com/java/RSPEC-2232"
  ],
  "logic": {
    "node_types": ["MethodInvocation"],
    "checks": [{
      "type": "regex_match",
      "property_path": ["source"],
      "patterns": ["\\w+\\.isLast\\s*\\(", "ResultSet.*\\.isLast\\s*\\("],
      "message": "Use ResultSet.next() instead of isLast()"
    }]
  }
}