{
  "filename": "constructors-string-biginteger-bigdecimal-primitive-wrappers-metadata.json",
  "rule_id": "style_constructor_usage_java",
  "title": "Avoid using constructors for String, BigInteger, BigDecimal, and primitive-wrapper classes",
  "description": "Calling constructors for String, BigInteger, BigDecimal and the objects used to wrap primitives is less efficient and less clear than relying on autoboxing or valueOf. Consider simplifying when possible for more efficient and cleaner code.",
  "status": "ready",
  "defaultSeverity": "Major",
  "category": "Style",
  "recommendation": "Use autoboxing or valueOf instead of constructors.",
  "impact": "Improves code efficiency and readability.",
  "examples": {
    "noncompliant": [
      "String empty = new String();",
      "String nonempty = new String(\"Hello world\");",
      "Double myDouble = new Double(1.1);",
      "Integer integer = new Integer(1);",
      "Boolean bool = new Boolean(true);",
      "BigInteger bigInteger1 = new BigInteger(\"3\");",
      "BigInteger bigInteger2 = new BigInteger(\"9223372036854775807\");",
      "BigInteger bigInteger3 = new BigInteger(\"111222333444555666777888999\");"
    ],
    "compliant": [
      "String empty = \"\";",
      "String nonempty = \"Hello world\";",
      "Double myDouble = 1.1;",
      "Integer integer = 1;",
      "Boolean bool = true;",
      "BigInteger bigInteger1 = BigInteger.valueOf(3);",
      "BigInteger bigInteger2 = BigInteger.valueOf(9223372036854775807L);",
      "BigInteger bigInteger3 = new BigInteger(\"111222333444555666777888999\");",
      "BigDecimal bigDecimal = new BigDecimal(\"42.0\");"
    ]
  },
  "references": [],
  "logic": {
    "node_types": [
      "Class"
    ],
    "checks": [
      {
        "type": "regex_match",
        "property_path": [
          "source"
        ],
        "patterns": [
          "new\\s+String\\s*\\(",
          "new\\s+Integer\\s*\\(",
          "new\\s+Double\\s*\\(",
          "new\\s+Float\\s*\\(",
          "new\\s+Long\\s*\\(",
          "new\\s+Short\\s*\\(",
          "new\\s+Byte\\s*\\(",
          "new\\s+Character\\s*\\(",
          "new\\s+Boolean\\s*\\(",
          "new\\s+BigInteger\\s*\\(",
          "new\\s+BigDecimal\\s*\\("
        ],
        "message": "Avoid using constructors for String, BigInteger, BigDecimal, and primitive-wrapper classes"
      }
    ]
  }
}