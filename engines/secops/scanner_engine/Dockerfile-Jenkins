FROM python:3.11-slim

LABEL maintainer="SecOps Team"
LABEL description="Vulnerability Scanner API with Jenkins for Python and Terraform"

WORKDIR /app

# Install system dependencies including Jenkins requirements
RUN apt-get update && apt-get install -y \
    git \
    curl \
    wget \
    gnupg \
    software-properties-common \
    openjdk-17-jdk \
    && rm -rf /var/lib/apt/lists/*

# Install Jenkins
RUN wget -q -O - https://pkg.jenkins.io/debian/jenkins.io.key | apt-key add - \
    && echo "deb https://pkg.jenkins.io/debian binary/" > /etc/apt/sources.list.d/jenkins.list \
    && apt-get update \
    && apt-get install -y jenkins \
    && rm -rf /var/lib/apt/lists/*

# Copy requirements first (for better caching)
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Install FastAPI dependencies
RUN pip install --no-cache-dir \
    fastapi==0.104.1 \
    uvicorn[standard]==0.24.0 \
    python-multipart==0.0.6 \
    pydantic==2.5.0

# Copy application code
COPY . .

# Create input/output folders
RUN mkdir -p /app/scan_input /app/scan_output

# Create Jenkins home directory
RUN mkdir -p /var/jenkins_home && chown -R jenkins:jenkins /var/jenkins_home

# Set environment variables
ENV SCAN_INPUT_PATH=/app/scan_input
ENV SCAN_OUTPUT_PATH=/app/scan_output
ENV PYTHONUNBUFFERED=1
ENV PYTHONPATH=/app
ENV JENKINS_HOME=/var/jenkins_home
ENV JAVA_HOME=/usr/lib/jvm/java-17-openjdk-amd64

# Expose API and Jenkins ports
EXPOSE 8000 8080

# Create startup script
RUN echo '#!/bin/bash\n\
# Start Jenkins in background\n\
su - jenkins -c "cd /var/jenkins_home && java -jar /usr/share/jenkins/jenkins.war --httpPort=8080" &\n\
\n\
# Wait a moment for Jenkins to start\n\
sleep 10\n\
\n\
# Start Scanner API in foreground\n\
cd /app && uvicorn api_server:app --host 0.0.0.0 --port 8000 --workers 2\n\
' > /app/start.sh && chmod +x /app/start.sh

# Health check for both services
HEALTHCHECK --interval=30s --timeout=10s --start-period=30s --retries=3 \
    CMD curl -f http://localhost:8000/health && curl -f http://localhost:8080 || exit 1

# Run both services
CMD ["/app/start.sh"]