{
  "rule_id": "regex_lookahead_assertions_should_not_be_contradictory",
  "title": "Regex lookahead assertions should not be contradictory",
  "type": "CODE_SMELL",
  "status": "ready",
  "defaultSeverity": "Major",
  "description": "Lookahead assertions in regular expressions should not contradict each other.",
  "message": "Regex lookahead assertions seem contradictory.",
  "remediation": {
    "func": "Issue",
    "constantCost": "5min"
  },
  "tags": [
    "regex",
    "lookahead"
  ],
  "impact": "Maintainability",
  "recommendation": "Avoid contradictory lookahead assertions.",
  "references": [],
  "examples": {
    "noncompliant": [
      {
        "code": "import re\npattern1 = re.compile(r'(?=(x)|(y))(?!(x))z')",
        "description": "Lookahead assertions (?=(x)|(y)) and (?!(x)) are contradictory."
      }
    ],
    "compliant": [
      {
        "code": "import re\npattern1 = re.compile(r'(?=(x))(?!y)z')",
        "description": "Lookahead assertions are not contradictory."
      }
    ]
  },
  "devsecops": {
    "category": "",
    "security": "",
    "automation": "",
    "compliance": ""
  },
  "why_is_this_an_issue": "Contradictory lookahead assertions can result in unexpected matches or missed matches, leading to issues in your code.",
  "how_to_fix": "Review and refactor regular expressions with contradictory lookahead assertions to ensure they are not contradictory.",
  "security_mappings": {
    "CWE": "",
    "CERT": "",
    "OWASP": ""
  },
  "logic": {
    "check_type": "property_comparison",
    "node_types": ["Call"],
    "property_path": ["func", "attr"],
    "forbidden_values": ["compile"],
    "additional_checks": [
      {
        "property_path": ["args", 0, "node_type"],
        "forbidden_values": ["Constant"],
        
        "property_path_2": ["args", 0, "value"],
        "pattern": "(?=.*\\(\\?=([^)]+)\\).*\\(\\?!\\1\\))|(?=.*\\(\\?!([^)]+)\\).*\\(\\?=\\2\\))"
      }
    ]
  },
