{
  "rule_id": "using_unencrypted_sagemaker_notebook_instances_is_securitysensitive",
  "title": "Using unencrypted Amazon SageMaker notebook instances",
  "type": "VULNERABILITY",
  "status": "ready",
  "defaultSeverity": "Critical",
  "description": "Uses Amazon SageMaker notebook instances without enabling encryption at rest.",
  "message": "The Amazon SageMaker notebook instance is not encrypted.",
  "remediation": {
    "func": "Constant/Issue",
    "constantCost": "5min"
  },
  "tags": [
    "aws",
    "sagemaker",
    "security"
  ],
  "impact": "Potential exposure of sensitive data",
  "recommendation": "Enable encryption at rest",
  "references": [],
  "examples": {
    "noncompliant": [
      {
        "code": "boto3.client('sagemaker-runtime').create_notebook_instance(NotebookInstanceName='test-instance', IamRoleArn='arn:aws:iam::123456789012:role/my-iam-for-sagemaker')"
      }
    ],
    "compliant": [
      {
        "code": "boto3.client('sagemaker-runtime').create_notebook_instance(NotebookInstanceName='test-instance', IamRoleArn='arn:aws:iam::123456789012:role/my-iam-for-sagemaker', EncryptionOptions={'EncryptionInTransit': {'Enabled': True}, 'EncryptionAtRest': {'Enabled': True}})"
      }
    ]
  },
