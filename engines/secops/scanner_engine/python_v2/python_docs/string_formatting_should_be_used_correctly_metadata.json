  ],
  "impact": "Code readability and maintainability",
  "recommendation": "Avoid using deprecated %-formatting",
  "references": [],
  "examples": {
    "noncompliant": [
      {
        "code": "print(\"Hello {0}\".format(\"world\"))",
        "description": "Using deprecated %-formatting"
      }
    ],
    "compliant": [
      {
        "code": "print(f'Hello world')",
        "description": "Using f-string"
      },
      {
        "code": "print('Hello world'.format(name='world'))",
        "description": "Using format method correctly"
      }
    ]
  },
