  },
  "tags": [
    "private",
    "attributes",
    "readability"
  ],
  "impact": "Readability",
  "recommendation": "Remove the unused private attribute",
  "references": [],
  "examples": {
    "noncompliant": [
      {
        "code": "class MyClass:\n    _unused_attr = 1\n    def foo(self):\n        pass",
        "description": "Private attribute _unused_attr is never read"
      }
    ],
    "compliant": [
      {
        "code": "class MyClass:\n    _attr = 1\n    def foo(self):\n        self._attr += 1",
        "description": "Private attribute _attr is read"
      }
    ]
  },
