  "defaultSeverity": "Minor",
  "description": "Checks for lines ending with trailing whitespaces.",
  "message": "Line ends with trailing whitespace.",
  "remediation": {
    "func": "Constant/Issue",
    "constantCost": "5min"
  },
  "tags": [
    "whitespace",
    "formatting"
  ],
  "impact": "Does not impact correctness of the code but can make it harder to read.",
  "recommendation": "Remove trailing whitespaces at the end of lines.",
  "references": [
    "https://peps.python.org/pep-0008/#whitespace"
  ],
  "examples": {
    "noncompliant": [
      {
        "code": "foo = 1 \n",
        "description": "Line with trailing whitespace"
      }
    ],
    "compliant": [
      {
        "code": "foo = 1\n",
        "description": "Line without trailing whitespace"
      }
    ]
  },
  "devsecops": {
    "category": "",
    "security": "",
    "automation": "",
    "compliance": ""
  },
  "why_is_this_an_issue": "Trailing whitespaces can make the code harder to read and maintain.",
  "how_to_fix": "Remove trailing whitespaces at the end of lines.",
  "security_mappings": {
    "CWE": "",
    "CERT": "",
    "OWASP": ""
  },
  "logic": {
    "check_type": "pattern",
    "property_path": [
      "n.lineno",
      "n.value"
    ],
    "forbidden_values": [
      "([ \t]+)$"
    ]
  },
