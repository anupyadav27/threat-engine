{
  "rule_id": "aws_region_should_not_be_set_with_a_hardcoded_string",
  "title": "AWS Region should not be set with a hardcoded string",
  "type": "CODE_SMELL",
  "status": "ready",
  "defaultSeverity": "Minor",
  "description": "This rule checks for hardcoded AWS region in the code.",
  "message": "AWS region should not be hardcoded.",
  "remediation": {
    "func": "Constant/Issue",
    "constantCost": "5min"
  },
  "tags": [
    "aws",
    "hardcoded",
    "region"
  ],
  "impact": "Potential security and compliance issues",
  "recommendation": "Use environment variables or AWS configuration files",
  "references": [
    {
      "url": "https://aws.amazon.com/security/best-practices/hardcoded-credentials-in-code/",
      "type": "Link"
    }
  ],
  "examples": {
    "noncompliant": [
      {
        "code": "s3 = boto3.client('s3', region_name='us-west-2')",
        "description": "Hardcoded region 'us-west-2'"
      }
    ],
    "compliant": [
      {
        "code": "region = os.environ.get('AWS_REGION')",
        "description": "Using environment variable"
      }
    ]
  },
  "devsecops": {
    "category": "Infrastructure as Code",
    "security": "Medium",
    "automation": "CI/CD",
    "compliance": "ISACA COBIT, NIST SP 800-53"
  },
  "why_is_this_an_issue": "Hardcoded AWS region can lead to security and compliance issues if the code is exposed.",
  "how_to_fix": "Use environment variables or AWS configuration files to set the region dynamically.",
  "security_mappings": {
    "CWE": "",
    "CERT": "",
    "OWASP": ""
  },
  "logic": {
    "checks": [
      {
        "type": "custom_function",
        "function": "check_hardcoded_aws_region",
        "message": "AWS region should not be hardcoded."
      }
    ]
  }
}