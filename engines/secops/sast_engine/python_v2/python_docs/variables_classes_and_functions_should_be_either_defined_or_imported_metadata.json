  "remediation": {
    "func": "Constant/Issue",
    "constantCost": "5min"
  },
  "tags": [
    "naming",
    "variable",
    "function",
    "class"
  ],
  "impact": "Code readability and maintainability",
  "recommendation": "Either define or import all used variables, classes, and functions.",
  "references": [
    "https://peps.python.org/pep-0008/"
  ],
  "examples": {
    "noncompliant": [
      {
        "code": "x = 5",
        "description": "Undeclared variable"
      }
    ],
    "compliant": [
      {
        "code": "import math; result = math.sqrt(16)",
        "description": "Imported function"
      },
      {
        "code": "class MyClass: pass",
        "description": "Declared class"
      },
      {
        "code": "def my_func(): pass",
        "description": "Declared function"
      }
    ]
  },
