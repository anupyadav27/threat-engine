  "defaultSeverity": "Major",
  "description": "Instead of comparing types directly, use `isinstance()` to make code more flexible and maintainable.",
  "message": "Direct type comparison found, consider using `isinstance()` instead.",
  "remediation": {
    "func": "Refactor",
    "constantCost": "15min"
  },
  "tags": [
    "types",
    "flexibility"
  ],
  "impact": "Reduces code fragility",
  "recommendation": "Refactor code to use `isinstance()`",
  "references": [
    "https://rules.sonarsource.com/python/RSPEC-3613",
    "https://www.python.org/dev/peps/pep-0020/"
  ],
  "examples": {
    "noncompliant": [
      {
        "code": "if x == int: ...",
        "description": "Direct type comparison"
      }
    ],
    "compliant": [
      {
        "code": "if isinstance(x, int): ...",
        "description": "Using `isinstance()`"
      }
    ]
  },
