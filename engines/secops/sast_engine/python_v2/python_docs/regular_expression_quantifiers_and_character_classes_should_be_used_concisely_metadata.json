{
  "rule_id": "regular_expression_quantifiers_and_character_classes_should_be_used_concisely",
  "title": "Regular expression quantifiers and character classes should be used concisely",
  "type": "CODE_SMELL",
  "status": "ready",
  "defaultSeverity": "Major",
  "description": "Excessive usage of regular expression quantifiers and character classes can lead to inefficient regular expressions and increased processing time.",
  "message": "Consider using concise regular expressions to improve performance.",
  "remediation": {
    "func": "Issue",
    "constantCost": "5min"
  },
  "tags": [
    "performance",
    "regular_expression"
  ],
  "impact": "Performance",
  "recommendation": "Optimize regular expressions for better performance.",
  "references": [
    "https://www.regular-expressions.info/optimization.html"
  ],
  "examples": {
    "noncompliant": [
      {
        "code": "import re\npattern = re.compile(r\".*(abc){3,}.*\")",
        "description": "Excessive use of quantifier"
      },
      {
        "code": "import re\npattern = re.compile(r\"[a-z]+\")",
        "description": "Excessive use of character class"
      }
    ],
    "compliant": [
      {
        "code": "import re\npattern = re.compile(r\".*(abc){3}.*\")",
        "description": "Concise use of quantifier"
      },
      {
        "code": "import re\npattern = re.compile(r\"[a-zA-Z]\")",
        "description": "Concise use of character class"
      }
    ]
  },
  "devsecops": {
    "category": "",
    "security": "",
    "automation": "",
    "compliance": ""
  },
  "why_is_this_an_issue": "Excessive usage of regular expression quantifiers and character classes can lead to inefficient regular expressions and increased processing time.",
  "how_to_fix": "Consider using concise regular expressions to improve performance.",
  "security_mappings": {
    "CWE": "",
    "CERT": "",
    "OWASP": ""
  },
  "logic": {
    "check_type": "property_comparison",
    "node_types": ["Call"],
    "property_path": ["func", "attr"],
    "forbidden_values": ["compile", "match", "search", "findall", "finditer"],
        "additional_checks": [
          {
            "property_path": ["args", 0, "node_type"],
            "required_values": ["Constant"],
            "property_path_2": ["args", 0, "value"],
            "patterns": [
              ".*\\{\\d+,\\}.*",
              ".*\\[\\w\\W\\]\\+.*",
              ".*(?:[a-zA-Z]\\+){3,}.*",
              ".*\\[^\\w\\s\\]\\+\\[^\\w\\s\\]\\+.*",
              ".*\\[\\w\\]\\[\\w\\]\\+.*",
              ".*(\\w+?)\\+\\+.*",
              ".*[^\\w\\s]+.*",
              ".*[\\w\\s]+.*",
              ".*[A-Z]+.*",
              ".*[^A-Z\\w\\s]+.*",
              ".*[\\d]+.*",
              ".*[^\\d\\w\\s]+.*",
              ".*[\\w\\s\\d]+.*",
              ".*[^\\w\\s\\d\\p{Punct}&&[^\\p{Punct}\\p{Zs}]\\p{Z}]+.*",
              ".*[\\p{Punct}&&[^\\p{Punct}\\p{Zs}]\\p{Z}]+.*",
              ".*[\\p{Punct}&&[^\\p{Punct}\\p{Zs}]\\p{Z}\\p{Punct}]+.*",
              ".*[^\\p{Punct}\\p{Zs}]+.*",
              ".*[\\p{Zs}]+.*",
              ".*[\\p{Zs}\\p{Punct}]+.*",
              ".*[^\\p{Punct}]+.*",
              ".*[\\p{Punct}]+.*",
              ".*[\\p{Punct}\\p{Zs}]+.*"
            ]
          }
        ]
  }
}
