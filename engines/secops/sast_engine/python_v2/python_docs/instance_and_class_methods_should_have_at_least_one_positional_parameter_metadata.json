      {
        "code": "class MyClass:\n    def method():\n        pass",
        "description": "Method missing 'self' parameter."
      }
    ],
    "compliant": [
      {
        "code": "class MyClass:\n    def method(self):\n        pass",
        "description": "Method has 'self' parameter."
      },
      {
