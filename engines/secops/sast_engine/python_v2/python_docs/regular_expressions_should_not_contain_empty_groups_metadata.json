{
  "rule_id": "regular_expressions_should_not_contain_empty_groups",
  "title": "Regular expressions should not contain empty groups",
  "type": "CODE_SMELL",
  "status": "ready",
  "defaultSeverity": "Minor",
  "description": "This rule checks for regular expressions containing empty groups. Empty groups can lead to unintended matches and is generally considered bad practice.",
  "message": "Regular expression contains empty group",
  "remediation": {
    "func": "Constant/Issue",
    "constantCost": "5min"
  },
  "tags": [
    "regex",
    "pattern",
    "group"
  ],
  "impact": "Code readability and maintainability",
  "recommendation": "Refactor the regular expression to remove empty groups",
  "references": [],
  "examples": {
    "noncompliant": [
      {
        "code": "import re\npattern = re.compile(r'(?<group1>)(?<group2>)(?<group3>)|')"
      }
    ],
    "compliant": [
      {
        "code": "import re\npattern = re.compile(r'(?<group1>)(?<group2>)|')"
      }
    ]
  },
  "devsecops": {
    "category": "",
    "security": "",
    "automation": "",
    "compliance": ""
  },
  "why_is_this_an_issue": "Empty groups can lead to unintended matches",
  "how_to_fix": "Refactor the regular expression to remove empty groups",
  "security_mappings": {
    "CWE": "",
    "CERT": "",
    "OWASP": ""
  },
  "logic": {
    "check_type": "property_comparison",
    "node_types": ["Call"],
    "property_path": ["func", "attr"],
    "forbidden_values": ["compile", "match", "search", "findall", "finditer"],
    "additional_checks": [
      {
        "property_path": ["args", 0, "node_type"],
        "required_values": ["Constant"],
        "property_path_2": ["args", 0, "value"],
        "patterns": [
          "\\(\\?P?<\\w+>\\)"
        ]
      }
    ]
  },
