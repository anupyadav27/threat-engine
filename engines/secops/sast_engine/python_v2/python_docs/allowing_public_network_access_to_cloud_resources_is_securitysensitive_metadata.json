{
  "rule_id": "allowing_public_network_access_to_cloud_resources_is_securitysensitive",
  "title": "Allowing public network access to cloud resources is security sensitive",
  "type": "VULNERABILITY",
  "status": "ready",
  "defaultSeverity": "Critical",
  "description": "This rule checks for resources in cloud services that are accessible from the public internet.",
  "message": "Public access is enabled for resource: {resource}",
  "remediation": {
    "func": "Constant/Issue",
    "constantCost": "5min"
  },
  "tags": [
    "cloud",
    "security"
  ],
  "impact": "High",
  "recommendation": "Limit access to trusted networks only",
  "references": [],
  "examples": {
    "noncompliant": [
      {
        "code": "gcp_client.create_bucket(name='my-bucket', storage_class='STANDARD', access_control='Public_Read')"
      }
    ],
    "compliant": [
      {
        "code": "gcp_client.create_bucket(name='my-bucket', storage_class='STANDARD', access_control='Authenticated_Read')"
      }
    ]
  },
  "devsecops": {
    "category": "Security",
    "security": "High",
    "automation": "Medium",
    "compliance": "PCI-DSS, HIPAA, GDPR"
  },
  "why_is_this_an_issue": "Unrestricted public access to resources can lead to data breaches and unauthorized access.",
  "how_to_fix": "Limit access to trusted networks only.",
  "security_mappings": {
    "CWE": "CWE-284",
    "CERT": "VU-694855",
    "OWASP": "A3:2007"
  },
  "logic": {
    "node_types": ["Call"],
    "property_path": [],
    "checks": [
      {
        "type": "required_present",
        "property": "keywords.*.arg",
        "pattern": "access_control"
      },
      {
        "type": "regex",
        "property": "value.node_type",
        "pattern": "^Constant$"
      },
      {
        "type": "regex",
        "property": "keywords.*.value",
        "pattern": "Public_Read"
      }
    ]
  }
}