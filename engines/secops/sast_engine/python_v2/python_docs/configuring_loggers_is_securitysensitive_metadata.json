{
  "rule_id": "configuring_loggers_is_securitysensitive",
  "title": "Configuring loggers is sensitive",
  "type": "CODE_SMELL",
  "status": "ready",
  "defaultSeverity": "Major",
  "description": "Logging sensitive information can expose confidential data.",
  "message": "A logger is configured with sensitive information.",
  "remediation": {
    "func": "Constant/Issue",
    "constantCost": "5min"
  },
  "tags": [
    "logging",
    "security"
  ],
  "impact": "High",
  "recommendation": "Avoid logging sensitive information.",
  "references": [],
  "examples": {
    "noncompliant": [
      {
        "code": "logger.error(\"User password: {password}\")",
        "description": "Logging a user's password"
      }
    ],
    "compliant": [
      {
        "code": "logger.error(\"Unauthorized access attempt\")",
        "description": "Logging a generic security event"
      }
    ]
  },
  "devsecops": {
    "category": "",
    "security": "",
    "automation": "",
    "compliance": ""
  },
  "why_is_this_an_issue": "Logging sensitive information can expose confidential data and create security risks.",
  "how_to_fix": "Avoid logging sensitive information or encrypt it before logging.",
  "security_mappings": {
    "CWE": "",
    "CERT": "",
    "OWASP": ""
  },
  "logic": {
    "node_types": ["Call"],
    "checks": [
      {
        "type": "regex",
        "property_path": ["args", 0, "value"],
        "pattern": "password|API key|SSH key",
        "flags": "i"
      }
    ]
  }
}