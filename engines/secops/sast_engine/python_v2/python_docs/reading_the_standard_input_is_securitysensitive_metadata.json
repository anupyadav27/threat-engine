{
  "rule_id": "reading_the_standard_input_is_securitysensitive",
  "title": "Reading the standard input is security sensitive",
  "type": "CODE_SMELL",
  "status": "ready",
  "defaultSeverity": "Major",
  "description": "Reading the standard input can introduce security vulnerabilities, especially in production environments.",
  "message": "Avoid reading from standard input.",
  "remediation": {
    "func": "Constant/Issue",
    "constantCost": "5min"
  },
  "tags": [
    "input",
    "security"
  ],
  "impact": "Potential security vulnerability",
  "recommendation": "Use a configure file or command line arguments instead of reading from standard input.",
  "references": [],
  "examples": {
    "noncompliant": [
      {
        "code": "input()",
        "description": "Reading from standard input."
      }
    ],
    "compliant": [
      {
        "code": "import sys\nconfig = sys.argv[1]",
        "description": "Reading a configuration from command line arguments."
      }
    ]
  },
  "devsecops": {
    "category": "Input validation",
    "security": "High",
    "automation": "High",
    "compliance": "PCI DSS, OWASP"
  },
  "why_is_this_an_issue": "Standard input can be manipulated by attackers, leading to security vulnerabilities.",
  "how_to_fix": "Use a configure file or command line arguments instead of reading from standard input.",
  "security_mappings": {
    "CWE": "",
    "CERT": "",
    "OWASP": ""
  },
  "logic": {
    "check_type": "property_comparison",
    "node_types": ["Call"],
    "property_path": ["func", "id"],
    "forbidden_values": ["input", "raw_input"],
    "additional_checks": [
      {
        "property_path": ["func", "value", "id"],
