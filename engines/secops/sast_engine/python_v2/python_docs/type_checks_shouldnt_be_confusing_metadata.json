  "recommendation": "Improve readability by using more descriptive type hints.",
  "references": [],
  "examples": {
    "noncompliant": [
      {
        "code": "def add(x: Any) -> Any: return x + 1",
        "description": "Unclear return type"
      }
    ],
    "compliant": [
      {
        "code": "def add(x: int) -> int: return x + 1",
        "description": "Clearly defined return type"
      }
    ]
  },
