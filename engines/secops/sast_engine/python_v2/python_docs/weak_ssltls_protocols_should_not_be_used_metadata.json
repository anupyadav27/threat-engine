{
  "rule_id": "weak_ssltls_protocols_should_not_be_used",
  "title": "Use TLS 1.2 or higher",
  "type": "CODE_SMELL",
  "status": "ready",
  "defaultSeverity": "Major",
  "description": "Ensures that SSL/TLS protocol versions 1.0, 1.1, and SSLv3 are not used, as they are vulnerable to various attacks.",
  "message": "SSL/TLS protocol version is set to an outdated version.",
  "remediation": {
    "func": "Constant/Issue",
    "constantCost": "5min"
  },
  "tags": [
    "security",
    "network"
  ],
  "impact": "Medium",
  "recommendation": "Upgrade to TLS 1.2 or higher.",
  "references": [
    "https://www.ssllabs.com/ssltest/",
    "https://www.openssl.org/docs/man1.0.2/apps/sslciphers.html"
  ],
  "examples": {
    "noncompliant": [
      {
        "code": "import ssl\ncontext = ssl.create_default_context(ssl.PROTOCOL_TLSv1_1)\n",
        "description": "Uses TLS 1.1"
      }
    ],
    "compliant": [
      {
        "code": "import ssl\ncontext = ssl.create_default_context(ssl.PROTOCOL_TLSv1_2)\n",
        "description": "Uses TLS 1.2"
      },
      {
        "code": "import ssl\ncontext = ssl.create_default_context(ssl.PROTOCOL_TLSv1_3)\n",
        "description": "Uses TLS 1.3"
      }
    ]
  },
  "devsecops": {
    "category": "Encryption",
    "security": "High",
    "automation": "High",
    "compliance": "PCI DSS, HIPAA, GDPR"
  },
  "why_is_this_an_issue": "Older SSL/TLS protocol versions are vulnerable to attacks that can compromise sensitive data.",
  "how_to_fix": "Update the SSL/TLS protocol version used in your application.",
  "security_mappings": {
    "CWE": "CWE-499",
    "CERT": "CERT-2016-03-01",
    "OWASP": "A3:2017"
  },
  "logic": {
    "checks": [
      {
        "type": "custom_function",
        "function": "weak_ssltls_protocols_should_not_be_used_check"
      }
    ]
  }
}