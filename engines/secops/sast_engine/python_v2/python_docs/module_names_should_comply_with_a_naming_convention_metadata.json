  "defaultSeverity": "Minor",
  "description": "Checks if Python modules follow a specific naming convention.",
  "message": "Module name does not comply with convention.",
  "remediation": {
    "func": "Constant/Issue",
    "constantCost": "5min"
  },
  "tags": [
    "python",
    "naming"
  ],
  "impact": "Readability and maintainability",
  "recommendation": "Adopt a consistent naming convention for modules.",
  "references": [],
  "examples": {
    "noncompliant": [
      {
        "code": "module_with_underscores.py",
        "description": "Module with underscores"
      }
    ],
    "compliant": [
      {
        "code": "module_with_snake_case.py",
        "description": "Module with snake_case"
      }
    ]
  },
  "devsecops": {
    "category": "",
    "security": "",
    "automation": "",
    "compliance": ""
  },
  "why_is_this_an_issue": "A consistent naming convention helps maintainers understand the purpose and structure of the code.",
