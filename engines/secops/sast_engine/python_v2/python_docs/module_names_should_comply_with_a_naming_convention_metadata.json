  "logic": {
    "check_type": "pattern",
    "property_path": [
      "ast.Module",
      "body",
      "name"
    ],
    "regex": "^[a-z][a-z0-9_]*$",
    "required_present": [
      "ast.Module",
      "body"
    ]
  },
