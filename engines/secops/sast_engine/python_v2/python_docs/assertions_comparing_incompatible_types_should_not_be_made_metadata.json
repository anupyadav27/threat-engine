{
  "rule_id": "assertions_comparing_incompatible_types_should_not_be_made",
  "title": "Assertions comparing incompatible types should not be made",
  "type": "CODE_SMELL",
  "status": "ready",
  "defaultSeverity": "Major",
  "description": "Avoid assertions comparing incompatible types as they can lead to runtime errors.",
  "message": "Incompatible types comparison in assertion",
  "remediation": {
    "func": "Constant/Issue",
    "constantCost": "5min"
  },
  "tags": [
    "types",
    "assertion",
    "comparison"
  ],
  "impact": "Runtime errors",
  "recommendation": "Use appropriate type-checking and comparison functions",
  "references": [],
  "examples": {
    "noncompliant": [
      {
        "code": "assert 1 == 'a'",
        "description": "Comparison of incompatible types"
      }
    ],
    "compliant": [
      {
        "code": "assert isinstance(x, int) and x == 1",
        "description": "Proper type-checking and comparison"
      },
      {
        "code": "assert x == 1 and isinstance(x, str)",
        "description": "Proper order of type-checking and comparison"
      }
    ]
  },
  "devsecops": {
    "category": "",
    "security": "",
    "automation": "",
    "compliance": ""
  },
  "why_is_this_an_issue": "Incompatible types comparison can lead to runtime errors",
  "how_to_fix": "Use appropriate type-checking and comparison functions",
  "security_mappings": {
    "CWE": "",
    "CERT": "",
    "OWASP": ""
  },
  "logic": {
    "node_types": ["Assert"],
    "checks": [
      {
        "type": "custom_function",
        "function": "check_assertions_comparing_incompatible_types"
      }
    ]
  }
}