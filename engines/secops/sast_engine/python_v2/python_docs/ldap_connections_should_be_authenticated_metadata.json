{
  "rule_id": "ldap_connections_should_be_authenticated",
  "title": "LDAP connections should be authenticated",
  "type": "VULNERABILITY",
  "status": "ready",
  "defaultSeverity": "Blocker",
  "description": "Checks if LDAP connections are performed without authentication.",
  "message": "LDAP connections should be authenticated.",
  "remediation": {
    "func": "Constant/Issue",
    "constantCost": "5min"
  },
  "tags": [
    "ldap",
    "security",
    "authentication"
  ],
  "impact": "Exposed LDAP connections can lead to unauthorized access.",
  "recommendation": "Use authenticated LDAP connections.",
  "references": [],
  "examples": {
    "noncompliant": [
      {
        "code": "import ldap\nldap.set_option(ldap.OPT_X_TLS_REQUIRE_CERT, ldap.OPT_X_TLS_NEVER)\nl.initialize()\nl.simple_bind_s('', '')"
      }
    ],
    "compliant": [
      {
        "code": "import ldap\nldap.set_option(ldap.OPT_X_TLS_REQUIRE_CERT, ldap.OPT_X_TLS_ALWAYS)\nl.initialize()\nl.simple_bind_s('username', 'password')"
      }
    ]
  },
  "devsecops": {
    "category": "",
    "security": "",
    "automation": "",
    "compliance": ""
  },
  "why_is_this_an_issue": "Unauthenticated LDAP connections can lead to unauthorized access and data breaches.",
  "how_to_fix": "Use authenticated LDAP connections.",
  "security_mappings": {
    "CWE": "",
    "CERT": "",
    "OWASP": ""
  },
  "logic": {
    "check_type": "property_comparison",
    "property_path": [
      "ast.Assign",
      "targets",
      "0",
      "value",
      "attrs",
      "ldap_option"
