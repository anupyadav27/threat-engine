{
  "filename": "literals_should_not_be_passed_as_localized_paramet_metadata.json",
  "rule_id": "literals_passed_as_localized",
  "title": "Literals should not be passed as localized parameters",
  "description": "String literals embedded in the source code will not be localized properly. This rule raises an issue when a literal string is passed as a parameter or property and one or more of the following cases is true: The LocalizableAttribute attribute of the parameter or property is set to true, the parameter or property name contains 'Text', 'Message', or 'Caption', or the string is passed to MessageBox.Show() or Exception constructors.",
  "status": "ready",
  "defaultSeverity": "Major",
  "category": "Security",
  "recommendation": "Replace literal strings with resource strings for proper localization.",
  "impact": "Security risk",
  "tags": [
    "security",
    "localization",
    "maintainability"
  ],
  "examples": {
    "noncompliant": [
      "MessageBox.Show(\"Error occurred\");",
      "button.Text = \"Click Me\";",
      "throw new Exception(\"Invalid operation\");"
    ],
    "compliant": [
      "MessageBox.Show(Resources.ErrorMessage);",
      "button.Text = Resources.ButtonClickText;",
      "throw new Exception(Resources.InvalidOperationMessage);"
    ]
  },
  "references": [
    "https://docs.microsoft.com/en-us/dotnet/standard/globalization-localization/"
  ],
  "logic": {
    "target_ast_nodes": ["Assignment", "CallExpression"],
    "detection_conditions": "Detects string literals passed to localizable parameters like MessageBox.Show(), Text/Message/Caption properties, and Exception constructors.",
    "checks": [
      {
        "type": "regex_match",
        "property_path": ["source"],
        "pattern": "\\.(Text|Message|Caption|HeaderText)\\s*=\\s*\"[^\"]+\"",
        "exclude_patterns": [
          "^//",
          "^/\\*",
          "Resources\\.",
          "GetString\\(",
          "Console\\.",
          "\\[Test",
          "\\[Fact"
        ]
      },
      {
        "type": "regex_match",
        "property_path": ["source"],
        "pattern": "MessageBox\\.Show\\s*\\([^)]*\"[^\"]+\"",
        "exclude_patterns": [
          "^//",
          "^/\\*",
          "Resources\\.",
          "GetString\\(",
          "Console\\.",
          "\\[Test",
          "\\[Fact"
        ]
      },
      {
        "type": "regex_match",
        "property_path": ["source"],
        "pattern": "new\\s+\\w*Exception\\s*\\(\\s*\"[^\"]+\"",
        "exclude_patterns": [
          "^//",
          "^/\\*",
          "Resources\\.",
          "GetString\\(",
          "Console\\.",
          "\\[Test",
          "\\[Fact"
        ]
      }
    ],
    "exclusion_conditions": {
      "exclude_patterns": [
        "Resources\\.",
        "GetString\\(",
        "Console\\.",
        "\\[Test",
        "\\[Fact",
        "^//",
        "^/\\*",
        "///"
      ]
    },
    "node_types": ["Assignment", "CallExpression"],
    "never_trigger_on": [
      "Comments",
      "Resource strings (Resources.)",
      "Console output",
      "Test methods ([Test], [Fact])",
      "GetString() calls",
      "Logging statements"
    ],
    "reasoning": "Detects literal strings passed to localizable parameters like MessageBox.Show(), .Text, .Message, .Caption properties, and Exception constructors. These should use resource files for proper localization support.",
    "validation_examples": {
      "should_trigger": [
        "MessageBox.Show(\"Error occurred\");",
        "button.Text = \"Click Me\";",
        "label.Caption = \"Warning\";",
        "throw new ArgumentException(\"Invalid parameter\");"
      ],
      "should_not_trigger": [
        "MessageBox.Show(Resources.ErrorMessage);",
        "button.Text = Resources.ButtonClickText;",
        "Console.WriteLine(\"Debug info\");",
        "// MessageBox.Show(\"Commented out\");"
      ]
    }
  }
}