{
  "resource": [
    {
      "aws_db_instance": {
        "bad_password_db": {
          "allocated_storage": 20,
          "engine": "mysql",
          "instance_class": "t2.micro",
          "name": "mydb2",
          "username": "foo",
          "password": "notasecurepassword",
          "parameter_group_name": "default.mysql5.7",
          "_tf_file": "d:/task9/test/git1\\main.tf"
        }
      }
    },
    {
      "aws_s3_bucket": {
        "public_bucket": {
          "bucket": "${var.bucket_name}",
          "acl": "public-read",
          "versioning": [
            {
              "enabled": true,
              "mfa_delete": false
            }
          ],
          "_tf_file": "d:/task9/test/git1\\main.tf"
        }
      }
    },
    {
      "aws_db_instance": {
        "unencrypted_db": {
          "allocated_storage": 20,
          "engine": "mysql",
          "instance_class": "t2.micro",
          "name": "mydb",
          "username": "foo",
          "password": "foobarbaz",
          "parameter_group_name": "default.mysql5.7",
          "_tf_file": "d:/task9/test/git1\\main.tf"
        }
      }
    },
    {
      "aws_security_group": {
        "open_sg": {
          "name": "open-sg-git1",
          "description": "Open to the world",
          "ingress": [
            {
              "from_port": 22,
              "to_port": 22,
              "protocol": "tcp",
              "cidr_blocks": [
                "0.0.0.0/0"
              ]
            }
          ],
          "_tf_file": "d:/task9/test/git1\\main.tf"
        }
      }
    },
    {
      "random_string": {
        "lb_id": {
          "length": 3,
          "special": false,
          "_tf_file": "d:/task9/test/git1\\main.tf"
        }
      }
    },
    {
      "aws_db_subnet_group": {
        "private": {
          "subnet_ids": "${module.vpc.private_subnets}",
          "_tf_file": "d:/task9/test/git1\\main.tf"
        }
      }
    },
    {
      "aws_db_instance": {
        "database": {
          "allocated_storage": 5,
          "engine": "mysql",
          "engine_version": "5.7",
          "instance_class": "db.t3.micro",
          "username": "admin",
          "password": "notasecurepassword",
          "db_subnet_group_name": "${aws_db_subnet_group.private.name}",
          "skip_final_snapshot": true,
          "_tf_file": "d:/task9/test/git1\\main.tf"
        }
      }
    }
  ],
  "variable": [
    {
      "no_type_var": {
        "description": "This variable has no type. TODO: add type.",
        "_tf_file": "d:/task9/test/git1\\variables.tf"
      }
    },
    {
      "db_password": {
        "description": "Database password.",
        "type": "string",
        "default": "password123",
        "_tf_file": "d:/task9/test/git1\\variables.tf"
      }
    },
    {
      "bucket_name": {
        "type": "string",
        "_tf_file": "d:/task9/test/git1\\variables.tf"
      }
    },
    {
      "aws_region": {
        "description": "AWS region",
        "type": "string",
        "default": "us-east-1",
        "_tf_file": "d:/task9/test/git1\\variables.tf"
      }
    },
    {
      "vpc_cidr_block": {
        "description": "CIDR block for VPC",
        "type": "string",
        "default": "10.0.0.0/16",
        "_tf_file": "d:/task9/test/git1\\variables.tf"
      }
    },
    {
      "public_subnet_cidr_blocks": {
        "description": "Available cidr blocks for public subnets",
        "type": "${list(string)}",
        "default": [
          "10.0.1.0/24",
          "10.0.2.0/24",
          "10.0.3.0/24",
          "10.0.4.0/24",
          "10.0.5.0/24",
          "10.0.6.0/24",
          "10.0.7.0/24",
          "10.0.8.0/24"
        ],
        "_tf_file": "d:/task9/test/git1\\variables.tf"
      }
    },
    {
      "private_subnet_cidr_blocks": {
        "description": "Available cidr blocks for private subnets",
        "type": "${list(string)}",
        "default": [
          "10.0.101.0/24",
          "10.0.102.0/24",
          "10.0.103.0/24",
          "10.0.104.0/24",
          "10.0.105.0/24",
          "10.0.106.0/24",
          "10.0.107.0/24",
          "10.0.108.0/24"
        ],
        "_tf_file": "d:/task9/test/git1\\variables.tf"
      }
    },
    {
      "instances_per_subnet": {
        "description": "Number of EC2 instances per private subnet",
        "type": "number",
        "default": 2,
        "_tf_file": "d:/task9/test/git1\\variables.tf"
      }
    },
    {
      "instance_type": {
        "description": "Instance type for EC2 instances",
        "type": "string",
        "default": "t2.micro",
        "_tf_file": "d:/task9/test/git1\\variables.tf"
      }
    },
    {
      "db_username": {
        "description": "Database administrator username.",
        "type": "string",
        "default": "admin",
        "_tf_file": "d:/task9/test/git1\\variables.tf"
      }
    },
    {
      "db_password": {
        "description": "Database administrator password.",
        "type": "string",
        "default": "notasecurepassword",
        "_tf_file": "d:/task9/test/git1\\variables.tf"
      }
    }
  ]
}