{
  "filename": "hard_coded_passwords_are_security_sensitive_metadata.json",
  "rule_id": "hardcoded_passwords_are_securitysensitive",
  "title": "Hard-coded passwords are security-sensitive",
  "description": "This rule looks for hard-coded passwords in variable names that match any of the patterns from the provided list.",
  "status": "ready",
  "defaultSeverity": "Major",
  "category": "Security",
  "recommendation": "Review and fix according to the rule guidelines.",
  "impact": "Security risk",
  "tags": [
    "security",
    "cert",
    "cwe",
    "owasp",
    "bug"
  ],
  "examples": {
    "noncompliant": [
      "dbi_conn conn = dbi_conn_new(\"mysql\");\nstring password = \"secret\"; // Sensitive\ndbi_conn_set_option(conn, \"password\", password.c_str());"
    ],
    "compliant": [
      "dbi_conn conn = dbi_conn_new(\"mysql\");\nstring password = getDatabasePassword(); // Compliant\ndbi_conn_set_option(conn, \"password\", password.c_str()); // Compliant"
    ]
  },
  "references": [
    "https://rules.sonarsource.com/c/RSPEC-2068"
  ],
  "logic": {
    "node_types": [
      "VariableDeclaration",
      "AssignmentExpression",
      "Statement"
    ],
    "checks": [
      {
        "type": "regex_match",
        "property_path": [
          "source"
        ],
        "patterns": [
          "\\b(password|Password|PASSWORD)\\s*=\\s*\"[^\"]+\"",
          "\\b(passwd|Passwd|PASSWD)\\s*=\\s*\"[^\"]+\"",
          "\\b(pwd|Pwd|PWD)\\s*=\\s*\"[^\"]+\"",
          "\\b(pass|Pass|PASS)\\s*=\\s*\"[^\"]+\"",
          "\\b(secret|Secret|SECRET)\\s*=\\s*\"[^\"]+\"",
          "\\b(credential|Credential|CREDENTIAL)\\s*=\\s*\"[^\"]+\"",
          "\\b(login|Login|LOGIN)\\s*=\\s*\"[^\"]+\"",
          "\\b\\w*[pP]assword\\w*\\s*=\\s*\"[^\"]+\"",
          "\\b\\w*[pP]ass\\w*\\s*=\\s*\"[^\"]+\"",
          "\\b\\w*[sS]ecret\\w*\\s*=\\s*\"[^\"]+\"",
          "\\*\\s*(password|passwd|pwd|pass|secret)\\s*=\\s*\"[^\"]+\"",
          "char\\s+\\*\\s*(password|passwd|pwd|pass|secret)\\s*=\\s*\"[^\"]+\"",
          "const\\s+char\\s+\\*\\s*(password|passwd|pwd|pass|secret)\\s*=\\s*\"[^\"]+\"",
          "string\\s+(password|passwd|pwd|pass|secret)\\s*=\\s*\"[^\"]+\"",
          "#define\\s+(PASSWORD|PASSWD|PWD|SECRET)\\s+\"[^\"]+\"",
          "\\b(db[_-]?password|database[_-]?password|admin[_-]?password)\\s*=\\s*\"[^\"]+\"",
          "\\b(user[_-]?password|root[_-]?password|default[_-]?password)\\s*=\\s*\"[^\"]+\"",
          "\\b(login[_-]?password|auth[_-]?password|system[_-]?password)\\s*=\\s*\"[^\"]+\"",
          "\\b(mysql[_-]?password|postgres[_-]?password|oracle[_-]?password)\\s*=\\s*\"[^\"]+\""
        ],
        "message": "Hard-coded passwords are security-sensitive. Review and fix according to the rule guidelines."
      }
    ]
  }
}