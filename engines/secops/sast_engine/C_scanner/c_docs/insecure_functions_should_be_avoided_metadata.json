{
  "filename": "insecure_functions_should_be_avoided_metadata.json",
  "rule_id": "insecure_functions_avoided",
  "title": "Insecure functions should be avoided",
  "description": "An attacker typically provides input that exceeds the expected size. This could be through a text field in a user interface, a file that the program reads, or data sent over a network. The insecure function processes this input and places the result into a provided buffer.",
  "status": "ready",
  "defaultSeverity": "Info",
  "category": "Security",
  "recommendation": "Refactor to eliminate the flagged pattern.",
  "impact": "Security risk",
  "tags": [
    "security",
    "cert",
    "cwe"
  ],
  "examples": {
    "noncompliant": [
      "char buffer[100];\nstrcpy(buffer, userInput);  // Noncompliant",
      "char dest[50];\nsprintf(dest, \"%s\", userString);  // Noncompliant",
      "gets(buffer);  // Noncompliant"
    ],
    "compliant": [
      "char buffer[100];\nstrncpy(buffer, userInput, sizeof(buffer) - 1);\nbuffer[sizeof(buffer) - 1] = '\\0';",
      "char dest[50];\nsnprintf(dest, sizeof(dest), \"%s\", userString);",
      "fgets(buffer, sizeof(buffer), stdin);"
    ]
  },
  "references": [
    "https://rules.sonarsource.com/c/RSPEC-1081"
  ],
  "logic": {
    "node_types": [
      "CallExpression",
      "FunctionCall"
    ],
    "checks": [
      {
        "type": "forbidden_value",
        "property_path": [
          "name"
        ],
        "forbidden_values": [
          "strcpy",
          "strcat",
          "sprintf",
          "vsprintf",
          "gets",
          "scanf",
          "sscanf",
          "fscanf",
          "vscanf",
          "vsscanf",
          "vfscanf",
          "strncpy",
          "strncat"
        ],
        "message": "Insecure function detected. Use secure alternatives like strcpy_s, strcat_s, snprintf, fgets, scanf_s."
      },
      {
        "type": "regex_match",
        "property_path": ["source"],
        "patterns": [
          "\\b(strcpy|strcat|sprintf|vsprintf|gets|scanf|sscanf|fscanf|vscanf|vsscanf|vfscanf)\\s*\\(",
          "\\bstrncpy\\s*\\([^,]+,\\s*[^,]+,\\s*[^)]+\\)(?!.*\\[[^\\]]*\\]\\s*=\\s*'\\\\0')",
          "\\bstrncat\\s*\\([^,]+,\\s*[^,]+,\\s*[^)]+\\)(?!.*\\[[^\\]]*\\]\\s*=\\s*'\\\\0')"
        ],
        "message": "Insecure function usage detected. Consider using safer alternatives or ensure proper null termination."
      }
    ]
  }
}