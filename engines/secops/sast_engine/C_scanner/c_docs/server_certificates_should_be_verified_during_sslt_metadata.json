{
  "filename": "server_certificates_should_be_verified_during_sslt_metadata.json",
  "rule_id": "server_certificates_verified_during",
  "title": "Server certificates should be verified during SSL/TLS connections",
  "description": "Transport Layer Security (TLS) provides secure communication between systems over the internet by encrypting the data sent between them. Certificate validation adds an extra layer of trust and security to this process to ensure that a system is indeed the one it claims to be. When certificate validation is disabled, the client skips a critical security check.",
  "status": "ready",
  "defaultSeverity": "Critical",
  "category": "Security",
  "recommendation": "Review and fix according to the rule guidelines.",
  "impact": "Security risk",
  "tags": [
    "security",
    "cert",
    "cwe",
    "design"
  ],
  "examples": {
    "noncompliant": [
      "#include <openssl/ssl.h>\n\nSSL_CTX *ctx = SSL_CTX_new(TLS_client_method());\nSSL_CTX_set_verify(ctx, SSL_VERIFY_NONE, NULL); // Noncompliant: disables certificate verification\n\n// Using curl with verification disabled\ncurl_easy_setopt(curl, CURLOPT_SSL_VERIFYPEER, 0L); // Noncompliant\ncurl_easy_setopt(curl, CURLOPT_SSL_VERIFYHOST, 0L); // Noncompliant"
    ],
    "compliant": [
      "#include <openssl/ssl.h>\n\nSSL_CTX *ctx = SSL_CTX_new(TLS_client_method());\nSSL_CTX_set_verify(ctx, SSL_VERIFY_PEER, NULL); // Compliant: enables certificate verification\nSSL_CTX_set_default_verify_paths(ctx);\n\n// Using curl with proper verification\ncurl_easy_setopt(curl, CURLOPT_SSL_VERIFYPEER, 1L); // Compliant\ncurl_easy_setopt(curl, CURLOPT_SSL_VERIFYHOST, 2L); // Compliant\ncurl_easy_setopt(curl, CURLOPT_CAPATH, \"/etc/ssl/certs\"); // Compliant"
    ]
  },
  "references": [
    "https://rules.sonarsource.com/c/RSPEC-4830"
  ],
  "logic": {
    "node_types": ["TranslationUnit"],
    "checks": [
      {
        "type": "regex_match",
        "property_path": ["source"],
        "patterns": [
          "CURLOPT_SSL_VERIFYPEER\\s*,\\s*0L?\\b",
          "CURLOPT_SSL_VERIFYPEER\\s*,\\s*0\\b",
          "CURLOPT_SSL_VERIFYPEER\\s*,\\s*false\\b",
          "curl_easy_setopt\\s*\\([^)]*CURLOPT_SSL_VERIFYPEER[^)]*,\\s*0L?\\s*\\)",
          "curl_easy_setopt\\s*\\([^)]*CURLOPT_SSL_VERIFYPEER[^)]*,\\s*0\\s*\\)",
          "curl_easy_setopt\\s*\\([^)]*CURLOPT_SSL_VERIFYPEER[^)]*,\\s*false\\s*\\)"
        ],
        "message": "CURL peer certificate verification is disabled. Set CURLOPT_SSL_VERIFYPEER to 1 to enable certificate verification.",
        "severity": "critical"
      },
      {
        "type": "regex_match",
        "property_path": ["source"],
        "patterns": [
          "SSL_set_verify\\s*\\([^)]*SSL_VERIFY_NONE[^)]*\\)",
          "SSL_CTX_set_verify\\s*\\([^)]*SSL_VERIFY_NONE[^)]*\\)",
          "SSL_VERIFY_NONE\\b",
          "\\bSSL_VERIFY_NONE\\s*;",
          "=\\s*SSL_VERIFY_NONE\\b"
        ],
        "message": "OpenSSL certificate verification is disabled. Use SSL_VERIFY_PEER to enable certificate verification.",
        "severity": "critical"
      },
      {
        "type": "regex_match",
        "property_path": ["source"],
        "patterns": [
          "SSL_set_verify_result\\s*\\([^)]*X509_V_OK[^)]*\\)",
          "SSL_CTX_set_verify_result\\s*\\([^)]*X509_V_OK[^)]*\\)",
          "SSL_set_verify_result\\s*\\([^)]*1\\s*\\)",
          "SSL_CTX_set_verify_result\\s*\\([^)]*1\\s*\\)"
        ],
        "message": "Manually setting SSL verification result bypasses certificate validation. Remove manual verification result override.",
        "severity": "critical"
      },
      {
        "type": "regex_match",
        "property_path": ["source"],
        "patterns": [
          "SSL_CTX_set_verify_mode\\s*\\([^)]*,\\s*0\\s*\\)",
          "SSL_set_verify_mode\\s*\\([^)]*,\\s*0\\s*\\)",
          "SSL_CTX_set_verify_mode\\s*\\([^)]*,\\s*SSL_VERIFY_NONE\\s*\\)",
          "SSL_set_verify_mode\\s*\\([^)]*,\\s*SSL_VERIFY_NONE\\s*\\)"
        ],
        "message": "SSL verification mode set to disabled state. Enable certificate verification with SSL_VERIFY_PEER.",
        "severity": "critical"
      },
      {
        "type": "regex_match",
        "property_path": ["source"],
        "patterns": [
          "SSL_CTX_set_verify_depth\\s*\\([^)]*,\\s*0\\s*\\)",
          "SSL_set_verify_depth\\s*\\([^)]*,\\s*0\\s*\\)"
        ],
        "message": "Setting SSL verification depth to 0 disables certificate chain validation. Use depth >= 1.",
        "severity": "critical"
      },
      {
        "type": "regex_match",
        "property_path": ["source"],
        "patterns": [
          "CURLOPT_CAINFO\\s*,\\s*NULL\\b",
          "CURLOPT_CAPATH\\s*,\\s*NULL\\b",
          "CURLOPT_CAINFO\\s*,\\s*\"\"",
          "CURLOPT_CAPATH\\s*,\\s*\"\"",
          "curl_easy_setopt\\s*\\([^)]*CURLOPT_CAINFO[^)]*,\\s*NULL\\s*\\)",
          "curl_easy_setopt\\s*\\([^)]*CURLOPT_CAPATH[^)]*,\\s*NULL\\s*\\)",
          "curl_easy_setopt\\s*\\([^)]*CURLOPT_CAINFO[^)]*,\\s*\"\"\\s*\\)",
          "curl_easy_setopt\\s*\\([^)]*CURLOPT_CAPATH[^)]*,\\s*\"\"\\s*\\)"
        ],
        "message": "Certificate authority information not configured. Set CURLOPT_CAINFO or CURLOPT_CAPATH to enable certificate verification.",
        "severity": "major"
      },
      {
        "type": "regex_match",
        "property_path": ["source"],
        "patterns": [
          "SSL_CTX_load_verify_locations\\s*\\([^)]*,\\s*NULL\\s*,\\s*NULL\\s*\\)",
          "SSL_load_verify_locations\\s*\\([^)]*,\\s*NULL\\s*,\\s*NULL\\s*\\)",
          "SSL_CTX_set_default_verify_paths\\s*\\([^)]*\\)\\s*==\\s*0",
          "SSL_CTX_set_default_verify_paths\\s*\\([^)]*\\)\\s*!=\\s*1"
        ],
        "message": "Certificate authority verification paths not configured. Load CA certificates for proper verification.",
        "severity": "major"
      },
      {
        "type": "regex_match",
        "property_path": ["source"],
        "patterns": [
          "X509_VERIFY_PARAM_set_flags\\s*\\([^)]*X509_V_FLAG_NO_CHECK_TIME[^)]*\\)",
          "X509_STORE_set_flags\\s*\\([^)]*X509_V_FLAG_NO_CHECK_TIME[^)]*\\)",
          "X509_VERIFY_PARAM_set_flags\\s*\\([^)]*X509_V_FLAG_IGNORE_CRITICAL[^)]*\\)",
          "X509_STORE_set_flags\\s*\\([^)]*X509_V_FLAG_IGNORE_CRITICAL[^)]*\\)"
        ],
        "message": "X509 verification flags disable important certificate checks. Remove security-weakening flags.",
        "severity": "major"
      },
      {
        "type": "regex_match",
        "property_path": ["source"],
        "patterns": [
          "SSL_CTX_set_cert_verify_callback\\s*\\([^)]*,\\s*NULL[^)]*\\)",
          "SSL_set_cert_verify_callback\\s*\\([^)]*,\\s*NULL[^)]*\\)",
          "SSL_CTX_set_verify\\s*\\([^)]*,\\s*SSL_VERIFY_PEER\\s*,\\s*NULL\\s*\\)(?![^}]*callback)"
        ],
        "message": "Certificate verification callback not properly configured. Implement proper certificate validation.",
        "severity": "major"
      },
      {
        "type": "regex_match",
        "property_path": ["source"],
        "patterns": [
          "X509_STORE_CTX_set_verify_cb\\s*\\([^)]*,\\s*NULL[^)]*\\)",
          "X509_STORE_set_verify_cb\\s*\\([^)]*,\\s*NULL[^)]*\\)"
        ],
        "message": "X509 store verification callback set to NULL. Configure proper certificate validation callback.",
        "severity": "major"
      },
      {
        "type": "regex_match",
        "property_path": ["source"],
        "patterns": [
          "CURLOPT_SSL_CTX_FUNCTION\\s*,\\s*[^,]*disable[^,)]*",
          "CURLOPT_SSL_CTX_FUNCTION\\s*,\\s*[^,]*bypass[^,)]*",
          "curl_easy_setopt\\s*\\([^)]*CURLOPT_SSL_CTX_FUNCTION[^)]*disable[^)]*\\)",
          "curl_easy_setopt\\s*\\([^)]*CURLOPT_SSL_CTX_FUNCTION[^)]*bypass[^)]*\\)"
        ],
        "message": "CURL SSL context function configured to disable certificate verification. Ensure proper verification.",
        "severity": "critical"
      },
      {
        "type": "regex_match",
        "property_path": ["source"],
        "patterns": [
          "BIO_new_ssl_connect\\s*\\([^)]*\\)(?![^}]*verify)",
          "BIO_set_ssl\\s*\\([^)]*\\)(?![^}]*verify)"
        ],
        "message": "BIO SSL connection created without certificate verification configuration. Enable certificate verification.",
        "severity": "major"
      },
      {
        "type": "regex_match",
        "property_path": ["source"],
        "patterns": [
          "CURLOPT_PROXY_SSL_VERIFYPEER\\s*,\\s*0L?\\b",
          "CURLOPT_PROXY_SSL_VERIFYPEER\\s*,\\s*false\\b",
          "curl_easy_setopt\\s*\\([^)]*CURLOPT_PROXY_SSL_VERIFYPEER[^)]*,\\s*0L?\\s*\\)"
        ],
        "message": "CURL proxy SSL certificate verification is disabled. Enable proxy certificate verification.",
        "severity": "critical"
      },
      {
        "type": "regex_match",
        "property_path": ["source"],
        "patterns": [
          "SSL_CTX_set_options\\s*\\([^)]*SSL_OP_NO_SSL[^)]*\\)",
          "SSL_set_options\\s*\\([^)]*SSL_OP_NO_SSL[^)]*\\)",
          "SSL_CTX_set_options\\s*\\([^)]*SSL_OP_NO_TLS[^)]*\\)",
          "SSL_set_options\\s*\\([^)]*SSL_OP_NO_TLS[^)]*\\)"
        ],
        "message": "SSL/TLS protocol versions disabled entirely. Ensure secure protocol versions are enabled with certificate verification.",
        "severity": "critical"
      },
      {
        "type": "regex_match",
        "property_path": ["source"],
        "patterns": [
          "X509_free\\s*\\([^)]*\\)(?=.*verify.*return\\s+1)",
          "X509_STORE_CTX_free\\s*\\([^)]*\\)(?=.*verify.*return\\s+1)",
          "X509_free\\s*\\([^}]*\\)\\s*;[^}]*return\\s+1\\s*;",
          "X509_STORE_CTX_free\\s*\\([^}]*\\)\\s*;[^}]*return\\s+1\\s*;"
        ],
        "message": "Certificate objects freed during verification with forced success return. Ensure proper certificate validation.",
        "severity": "critical"
      },
      {
        "type": "regex_match",
        "property_path": ["source"],
        "patterns": [
          "SSL_VERIFY_NONE\\s*;",
          "\\bSSL_VERIFY_NONE;",
          "verify_mode\\s*=\\s*SSL_VERIFY_NONE",
          "mode\\s*=\\s*SSL_VERIFY_NONE"
        ],
        "message": "SSL_VERIFY_NONE constant used to disable certificate verification. Use SSL_VERIFY_PEER instead.",
        "severity": "critical"
      }
    ]
  }
}