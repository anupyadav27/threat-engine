{
  "filename": "functions_should_not_be_declared_at_block_scope_metadata.json",
  "rule_id": "functions_declared_block_scope",
  "title": "Functions should not be declared at block scope",
  "description": "It is rarely useful to declare a function at block scope. Such a function will not get special access to any name in its enclosing scope, and therefore, it is equivalent but clearer to declare it instead in the enclosing namespace. Additionally, when a function is declared at block scope, the intent is often not to declare a function but instead to declare and initialize a variable.",
  "status": "ready",
  "defaultSeverity": "Info",
  "category": "General",
  "recommendation": "Replace with the recommended alternative approach.",
  "impact": "Code readability problem",
  "tags": [
    "c"
  ],
  "examples": {
    "noncompliant": [
      "// Noncompliant: Function declared at block scope\nvoid outerFunction() {\n  int helper();  // Function declaration inside block scope\n  int result = helper();\n}"
    ],
    "compliant": [
      "// Compliant: Function declared at namespace scope\nint helper();  // Function declared at global scope\n\nvoid outerFunction() {\n  int result = helper();\n}"
    ]
  },
  "references": [
    "https://rules.sonarsource.com/c/RSPEC-824"
  ],
  "logic": {
    "node_types": [
      "FunctionDefinition"
    ],
    "checks": [
      {
        "type": "regex_match",
        "property_path": [
          "source"
        ],
        "patterns": [
          "\\{[^}]*\\b(int|void|char|double|float|long|short)\\s+\\w+\\s*\\([^)]*\\)\\s*;",
          "\\{[^}]*\\b(unsigned|signed)\\s+(int|char|long|short)\\s+\\w+\\s*\\([^)]*\\)\\s*;",
          "\\{[^}]*\\b(const\\s+)?(int|void|char|double|float|long|short)\\s*\\*\\s*\\w+\\s*\\([^)]*\\)\\s*;",
          "\\{[^}]*\\b(extern|static|inline)\\s+(int|void|char|double|float|long|short)\\s+\\w+\\s*\\([^)]*\\)\\s*;",
          "\\{[^}]*\\bstruct\\s+\\w+\\s*\\*\\s*\\w+\\s*\\([^)]*\\)\\s*;",
          "\\{[^}]*\\bFILE\\s*\\*\\s*\\w+\\s*\\([^)]*\\)\\s*;",
          "\\{[^}]*\\bsize_t\\s+\\w+\\s*\\([^)]*\\)\\s*;",
          "if\\s*\\([^)]*\\)\\s*\\{[^}]*\\b(int|void|char|double|float)\\s+\\w+\\s*\\([^)]*\\)\\s*;",
          "else\\s*\\{[^}]*\\b(int|void|char|double|float)\\s+\\w+\\s*\\([^)]*\\)\\s*;",
          "for\\s*\\([^)]*\\)\\s*\\{[^}]*\\b(int|void|char|double|float)\\s+\\w+\\s*\\([^)]*\\)\\s*;",
          "while\\s*\\([^)]*\\)\\s*\\{[^}]*\\b(int|void|char|double|float)\\s+\\w+\\s*\\([^)]*\\)\\s*;",
          "switch\\s*\\([^)]*\\)\\s*\\{[^}]*\\b(int|void|char|double|float)\\s+\\w+\\s*\\([^)]*\\)\\s*;",
          "case\\s+\\w+\\s*:[^}]*\\b(int|void|char|double|float)\\s+\\w+\\s*\\([^)]*\\)\\s*;",
          "default\\s*:[^}]*\\b(int|void|char|double|float)\\s+\\w+\\s*\\([^)]*\\)\\s*;",
          "\\s{4,}(int|void|char|double|float|long|short)\\s+\\w+\\s*\\([^)]*\\)\\s*;",
          "\\s{4,}(extern|static|inline)\\s+(int|void|char|double|float)\\s+\\w+\\s*\\([^)]*\\)\\s*;",
          "\\{[^}]*\\bviolation\\w*\\s*\\([^)]*\\)\\s*;",
          "\\{[^}]*\\bhelper\\w*\\s*\\([^)]*\\)\\s*;",
          "\\{[^}]*\\butility\\w*\\s*\\([^)]*\\)\\s*;",
          "\\{[^}]*\\binternal\\w*\\s*\\([^)]*\\)\\s*;",
          "violation\\w*.*\\{[^}]*\\b\\w+\\s+\\w+\\s*\\([^)]*\\)\\s*;",
          "\\s+int\\s+nested_\\w+\\s*\\([^)]*\\)\\s*;",
          "\\s+void\\s+nested_\\w+\\s*\\([^)]*\\)\\s*;",
          "\\s+char\\s*\\*\\s*nested_\\w+\\s*\\([^)]*\\)\\s*;"
        ],
        "message": "Functions should not be declared at block scope. Replace with the recommended alternative approach."
      }
    ]
  }
}