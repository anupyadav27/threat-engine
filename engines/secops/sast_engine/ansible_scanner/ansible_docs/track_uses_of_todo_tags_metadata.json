{
  "filename": "track_uses_of_todo_tags_metadata.json",
  "rule_id": "track_uses_todo_tags",
  "title": "Track uses of TODO tags",
  "description": "Developers often use TODO tags to mark areas in the code where additional work or improvements are needed but are not implemented immediately. However, these TODO tags sometimes get overlooked or forgotten, leading to incomplete or unfinished code. This rule aims to identify and address unattended TODO tags to ensure a clean and maintainable codebase.",
  "status": "ready",
  "defaultSeverity": "Critical",
  "category": "Security",
  "recommendation": "Review and fix according to the rule guidelines.",
  "impact": "Security risk",
  "tags": [
    "security",
    "cwe",
    "bug"
  ],
  "examples": {
    "noncompliant": [
      "TODO"
    ],
    "compliant": [
      "TODO"
    ]
  },
  "references": [
    "https://rules.sonarsource.com/ansible/RSPEC-1135"
  ],
  "logic": {
    "node_types": ["task", "play", "shell", "command", "raw"],
    "checks": [
      {
        "type": "regex_match",
        "property_path": ["source"],
        "patterns": [
          "#\\s*TODO[:\\s]",
          "#\\s*TODO$",
          "TODO[:\\s]"
        ],
        "message": "TODO tag found - track and resolve pending work"
      },
      {
        "type": "regex_match",
        "property_path": ["source"],
        "patterns": [
          "#\\s*FIXME[:\\s]",
          "#\\s*FIXME$",
          "FIXME[:\\s]"
        ],
        "message": "FIXME tag found - code needs to be fixed"
      },
      {
        "type": "regex_match",
        "property_path": ["source"],
        "patterns": [
          "#\\s*HACK[:\\s]",
          "#\\s*HACK$",
          "HACK[:\\s]"
        ],
        "message": "HACK tag found - temporary workaround needs proper solution"
      },
      {
        "type": "regex_match",
        "property_path": ["source"],
        "patterns": [
          "#\\s*XXX[:\\s]",
          "#\\s*XXX$",
          "XXX[:\\s]"
        ],
        "message": "XXX tag found - code requires attention or review"
      },
      {
        "type": "regex_match",
        "property_path": ["source"],
        "patterns": [
          "#\\s*BUG[:\\s]",
          "#\\s*BUG$",
          "BUG[:\\s]"
        ],
        "message": "BUG tag found - known issue needs to be resolved"
      },
      {
        "type": "regex_match",
        "property_path": ["source"],
        "patterns": [
          "#\\s*OPTIMIZE[:\\s]",
          "#\\s*OPTIMIZE$"
        ],
        "message": "OPTIMIZE tag found - performance improvement needed"
      },
      {
        "type": "regex_match",
        "property_path": ["source"],
        "patterns": [
          "#\\s*REFACTOR[:\\s]",
          "#\\s*REFACTOR$"
        ],
        "message": "REFACTOR tag found - code cleanup or restructuring needed"
      },
      {
        "type": "regex_match",
        "property_path": ["source"],
        "patterns": [
          "#\\s*DEPRECATED[:\\s]",
          "#\\s*DEPRECATED$"
        ],
        "message": "DEPRECATED tag found - outdated code needs replacement"
      }
    ]
  }
}