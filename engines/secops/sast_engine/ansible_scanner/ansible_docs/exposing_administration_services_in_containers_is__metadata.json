{
  "filename": "exposing_administration_services_in_containers_is__metadata.json",
  "rule_id": "exposing_administration_services_containers",
  "title": "Exposing administration services in containers is security-sensitive",
  "description": "Exposing administration services in containers is security-sensitiveAnalyze your codeintentionality-completesecuritySecurity HotspotdockerfilecweExposing administration services can lead to unauthorized access to containers or escalation of privilege inside of containers.Administration services like SSH might contain vulnerabilities, hard-coded credentials, or other security issues that increase the attack surface of a container deployment.Even if the ports of the services do not get forwarded to the host system, by default they are reachable from other containers in the same network. A malicious actor that gets access to one container could use such services to escalate access and privileges.Ask Yourself WhetherThe container starts an administration service.There is a risk if you answered",
  "status": "ready",
  "defaultSeverity": "Major",
  "category": "Security",
  "recommendation": "Review and fix according to the rule guidelines.",
  "impact": "Security risk",
  "tags": [
    "security",
    "cwe"
  ],
  "examples": {
    "noncompliant": [
      "- name: Podman tasks\n  hosts: server\n  tasks:\n    - name: Start SSH server\n      containers.podman.podman_container:\n        name: container\n        image: lscr.io/linuxserver/openssh-server:version-9.7_p1-r4\n        publish:\n          - \"22:2222\" # Sensitive"
    ],
    "compliant": []
  },
  "references": [
    "https://rules.sonarsource.com/ansible/RSPEC-6473"
  ],
  "logic": {
    "node_types": ["task", "docker_container", "kubernetes", "podman_container"],
    "checks": [
      {
        "type": "regex_match",
        "property_path": ["parent_source"],
        "pattern": "(?:port|ports|publish).*[\"']?(?:0\\.0\\.0\\.0:)?22(?:[:/\"']|\\b)",
        "message": "Exposing SSH service (port 22) is security-sensitive"
      },
      {
        "type": "regex_match",
        "property_path": ["parent_source"],
        "pattern": "(?:containerPort|targetPort|target_port):\\s*22\\b",
        "message": "Exposing SSH service (port 22) is security-sensitive"
      },
      {
        "type": "regex_match",
        "property_path": ["parent_source"],
