{
  "filename": "images_should_include_a_non_redundant_alternate_de_metadata.json",
  "rule_id": "images_include_nonredundant_alternate",
  "title": "Images should include a non-redundant alternate description",
  "description": "alt attributes, also known as \"alt tags\" or \"alt descriptions,\" are used to specify alternative text that is rendered when an image cannot be displayed. They are crucial for improving web accessibility, as they provide a text description of images for users who rely on screen readers. Screen readers announce the presence of an <img> element and read its alt attribute aloud to describe the image.",
  "status": "ready",
  "defaultSeverity": "Major",
  "category": "Security",
  "recommendation": "Replace with the recommended alternative approach.",
  "impact": "Security risk",
  "tags": [
    "security",
    "bug",
    "deprecated",
    "async"
  ],
  "examples": {
    "noncompliant": [
      "img.alt = 'image of a sunset';",
      "element.setAttribute('alt', 'picture of a dog');",
      "img.alt = '';",
      "document.createElement('img'); // missing alt",
      "img.alt = 'click here';",
      "img.setAttribute('alt', 'photo of beautiful landscape');"
    ],
    "compliant": [
      "img.alt = 'sunset over mountains';",
      "element.setAttribute('alt', 'golden retriever playing in park');",
      "img.alt = 'decorative border'; // or role='presentation'",
      "const img = document.createElement('img'); img.alt = 'company logo';",
      "img.alt = 'submit form';",
      "img.setAttribute('alt', 'beautiful mountain landscape at dusk');"
    ]
  },
  "references": [
    "https://rules.sonarsource.com/javascript/RSPEC-6851"
  ],
  "logic": {
    "node_types": [
      "AssignmentExpression",
      "CallExpression",
      "VariableDeclaration"
    ],
    "checks": [
      {
        "type": "custom_function",
        "function": "check_image_alt_text"
      }
    ]
  }
}