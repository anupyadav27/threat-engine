{
  "filename": "array_constructors_should_be_avoided_metadata.json",
  "rule_id": "array_constructors_avoided",
  "title": "Array constructors should be avoided",
  "description": "Array literals should always be preferred to Array constructors. Array constructors are error-prone due to the way their arguments are interpreted. If more than one argument is used, the array length will be equal to the number of arguments.",
  "status": "ready",
  "defaultSeverity": "Minor",
  "category": "Best Practices",
  "recommendation": "Use array literals [] instead of Array constructors new Array().",
  "impact": "Code clarity and potential unexpected behavior",
  "tags": [
    "best-practices",
    "array",
    "constructor",
    "literals"
  ],
  "examples": {
    "noncompliant": [
      "var arr = new Array();",
      "var arr = new Array(1, 2, 3);",
      "var arr = Array(10);",
      "let items = new Array(size);"
    ],
    "compliant": [
      "var arr = [];",
      "var arr = [1, 2, 3];",
      "var arr = new Array(10).fill(0);",
      "let items = Array.from({length: size});"
    ]
  },
  "references": [
    "https://rules.sonarsource.com/javascript/RSPEC-1528"
  ],
  "logic": {
    "node_types": [
      "NewExpression", 
      "CallExpression",
      "AssignmentExpression",
      "Property",
      "MethodDefinition",
      "VariableDeclarator",
      "ExpressionStatement",
      "ReturnStatement"
    ],
    "checks": [
      {
        "type": "regex_match",
        "message": "Use array literal [] instead of Array constructor",
        "property_path": [
          "source"
        ],
        "patterns": [
          "new\\s+Array\\s*\\(",
          "(?<!\\.|\\w)Array\\s*\\("
        ]
      }
    ]
  }
}