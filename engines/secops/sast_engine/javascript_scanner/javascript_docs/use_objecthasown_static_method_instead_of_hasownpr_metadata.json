{
  "filename": "use_objecthasown_static_method_instead_of_hasownpr_metadata.json",
  "rule_id": "use_objecthasown_static_method",
  "title": "Use Object.hasOwn static method instead of hasOwnProperty",
  "description": "The Object.hasOwn() method was introduced in ES2022 as a replacement for the more verbose Object.prototype.hasOwnProperty.call(). These methods return true if the specified property of an object exists as its own property. If the property is only available further down the prototype chain or does not exist at all - the methods return false.",
  "status": "ready",
  "defaultSeverity": "Major",
  "category": "Security",
  "recommendation": "Replace with the recommended alternative approach.",
  "impact": "Security risk",
  "tags": [
    "security",
    "bug",
    "deprecated",
    "async"
  ],
  "examples": {
    "noncompliant": [
      "Object.prototype.hasOwnProperty.call(obj, 'prop')",
      "obj.hasOwnProperty('prop')"
    ],
    "compliant": [
      "Object.hasOwn(obj, 'prop')"
    ]
  },
  "references": [
    "https://rules.sonarsource.com/javascript/RSPEC-6653"
  ],
  "logic": {
    "node_types": [
      "CallExpression",
      "MemberExpression"
    ],
    "checks": [
      {
        "type": "regex_match",
        "property_path": [
          "source"
        ],
        "pattern": "Object\\.prototype\\.hasOwnProperty\\.call\\s*\\(",
        "message": "Replace Object.prototype.hasOwnProperty.call() with Object.hasOwn()."
      },
      {
        "type": "regex_match",
        "property_path": [
          "source"
        ],
        "pattern": "Object\\.prototype\\.hasOwnProperty\\.apply\\s*\\(",
        "message": "Replace Object.prototype.hasOwnProperty.apply() with Object.hasOwn()."
      },
      {
        "type": "regex_match",
        "property_path": [
          "source"
        ],
        "pattern": "Object\\.prototype\\.hasOwnProperty\\.bind\\s*\\(",
        "message": "Replace Object.prototype.hasOwnProperty.bind() with Object.hasOwn()."
      },
      {
        "type": "regex_match",
        "property_path": [
          "source"
        ],
        "pattern": "\\.hasOwnProperty\\s*\\(",
        "message": "Replace .hasOwnProperty() with Object.hasOwn()."
      }
    ]
  }
}