{
  "filename": "applications_should_not_create_session_cookies_fro_metadata.json",
  "rule_id": "applications_create_session_cookies",
  "title": "Applications should not create session cookies from untrusted input",
  "description": "Session Cookie Injection occurs when a web application assigns session cookies to users using untrusted data. Session cookies are used by web applications to identify users. Thus, controlling these enable control over the identity of the users within the application.",
  "status": "ready",
  "defaultSeverity": "Major",
  "category": "Security",
  "recommendation": "Validate and sanitize all input before using it to create session cookies.",
  "impact": "Session hijacking and authentication bypass",
  "tags": [
    "security",
    "cookies",
    "session",
    "injection"
  ],
  "examples": {
    "noncompliant": [
      "document.cookie = 'sessionId=' + userInput;",
      "res.cookie('session', req.query.session);",
      "response.addCookie(new Cookie('JSESSIONID', request.getParameter('id')));",
      "ctx.cookies.set('session', ctx.query.token);"
    ],
    "compliant": [
      "document.cookie = 'sessionId=' + sanitize(userInput);",
      "res.cookie('session', validatedSession);",
      "response.addCookie(new Cookie('JSESSIONID', generateSecureId()));",
      "ctx.cookies.set('session', crypto.randomBytes(32).toString('hex'));"
    ]
  },
  "references": [
    "https://rules.sonarsource.com/javascript/RSPEC-6287"
  ],
  "logic": {
    "node_types": [
      "Statement"
    ],
    "checks": [
      {
        "type": "regex_match",
        "message": "Session cookies should not be created from untrusted input",
        "property_path": [
          "source"
        ],
        "patterns": [
          "document\\.cookie\\s*=.*\\+.*(userInput|req\\.|request\\.|ctx\\.query|params\\.)",
          "res\\.cookie\\s*\\(.*req\\.(query|params)",
          "addCookie.*request\\.getParameter",
          "cookies\\.set.*ctx\\.(query|params)"
        ]
      }
    ]
  }
}