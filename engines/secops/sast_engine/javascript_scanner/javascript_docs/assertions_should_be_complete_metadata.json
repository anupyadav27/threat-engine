{
  "filename": "assertions_should_be_complete_metadata.json",
  "rule_id": "assertions_complete",
  "title": "Assertions should be complete",
  "description": "Assertions should be complete and not use incomplete assertion methods that don't properly test values.",
  "status": "ready",
  "defaultSeverity": "Major",
  "category": "Best Practices",
  "recommendation": "Use complete assertions with expected values instead of incomplete ones.",
  "impact": "Incomplete testing and missed bugs",
  "tags": [
    "security",
    "bug",
    "deprecated",
    "async"
  ],
  "examples": {
    "noncompliant": [
      "expect(value).toBeTruthy(); // Too vague",
      "expect(result).toBeDefined(); // Incomplete check",
      "assert.ok(value); // Not specific enough"
    ],
    "compliant": [
      "expect(value).toBe(true); // Specific expectation",
      "expect(result).toBe(42); // Exact value check",
      "assert.equal(value, expectedValue); // Complete assertion"
    ]
  },
  "references": [
    "https://rules.sonarsource.com/javascript/RSPEC-2970"
  ],
  "logic": {
    "node_types": [
      "CallExpression"
    ],
    "checks": [
      {
        "type": "regex_match",
        "message": "Use complete assertions with expected values instead of incomplete ones.",
        "property_path": [
          "source"
        ],
        "patterns": [
          "\\.(toBeTruthy|toBeFalsy|toBeDefined|toBeUndefined)\\s*\\(",
          "assert\\.ok\\s*\\(",
          "expect\\([^)]+\\)\\.(toBeTruthy|toBeFalsy|toBeDefined|toBeUndefined)\\s*\\("
        ]
      }
    ]
  }
}