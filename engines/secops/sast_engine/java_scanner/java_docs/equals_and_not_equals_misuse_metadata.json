{
  "filename": "equals_and_not_equals_misuse_metadata.json",
  "rule_id": "style_object_comparison_misuse",
  "title": "Avoid using '==' and '!=' with overridden 'equals' method",
  "description": "Using '==' and '!=' operators with objects that have overridden 'equals' method can lead to incorrect comparisons. It is recommended to use 'equals' method instead.",
  "status": "ready",
  "defaultSeverity": "Major",
  "category": "Style",
  "recommendation": "Use 'equals' method instead",
  "impact": "Improves code readability and maintainability",
  "examples": {
    "noncompliant": [
      "if (firstName == lastName) { ... };"
    ],
    "compliant": [
      "if (firstName != null && firstName.equals(lastName)) { ... };"
    ]
  },
  "references": [],
  "logic": {
    "node_types": [
      "Class"
    ],
    "checks": [
      {
        "type": "regex_match",
        "property_path": [
          "source"
        ],
        "patterns": [
          "\\w+\\s*==\\s*\\w+",
          "\\w+\\s*!=\\s*\\w+"
        ],
        "message": "Avoid using '==' and '!=' with objects that have overridden 'equals' method"
      }
    ]
  }
}