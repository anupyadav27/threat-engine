{
  "filename": "database-queries-injection-attacks_metadata.json",
  "rule_id": "SECURITY_VULNERABILITY_DATABASE",
  "title": "Prevent Database Injection Attacks",
  "description": "Avoid database injection vulnerabilities by sanitizing user input before using it in database queries.",
  "status": "ready",
  "defaultSeverity": "Info",
  "category": "SECURITY",
  "recommendation": "Sanitize user input before using it in database queries.",
  "impact": "Exposes databases to malicious attacks.",
  "examples": {
    "noncompliant": [],
    "compliant": []
  },
  "references": [],
  "logic": {
    "node_types": [
      "Class"
    ],
    "checks": [
      {
        "type": "regex_match",
        "property_path": [
          "source"
        ],
        "patterns": [
          "stmt\\.execute\\(.*\\+.*\\)",
          "stmt\\.executeQuery\\(.*\\+.*\\)",
          "stmt\\.executeUpdate\\(.*\\+.*\\)",
          "createStatement\\(\\)\\.execute\\(.*\\+.*\\)",
          "query.*=.*\\\".*\\\".*\\+",
          "PreparedStatement.*=.*conn\\.prepareStatement\\(.*\\+.*\\)"
        ],
        "message": "Avoid SQL injection - use PreparedStatement with parameterized queries instead of string concatenation"
      }
    ]
  }
}