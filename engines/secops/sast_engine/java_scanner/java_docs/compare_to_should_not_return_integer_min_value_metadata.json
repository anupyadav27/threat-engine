  "title": "Avoid returning Integer.MIN_VALUE in Comparable.compareTo",
  "description": "The Comparable.compareTo method should not return Integer.MIN_VALUE as it provides no additional information to the caller and could potentially confuse code readers.",
  "status": "ready",
  "defaultSeverity": "Major",
  "category": "Code Quality",
  "recommendation": "Avoid returning Integer.MIN_VALUE in Comparable.compareTo",
  "impact": "Potential confusion for code readers",
  "examples": {
    "noncompliant": [],
    "compliant": []
  },
  "references": [
    "https://rules.sonarsource.com/java/RSPEC-2167"
  ],
  "logic": {
    "node_types": ["Class"],
    "checks": [{
      "type": "regex_match",
      "property_path": ["source"],
      "patterns": ["compareTo\\s*\\([^)]*\\)[^}]*return\\s+Integer\\.MIN_VALUE"],
      "message": "Avoid returning Integer.MIN_VALUE in Comparable.compareTo"
    }]
  }
