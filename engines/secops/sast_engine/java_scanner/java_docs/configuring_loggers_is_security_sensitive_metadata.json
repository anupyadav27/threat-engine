{
  "filename": "configuring_loggers_is_security_sensitive_metadata.json",
  "rule_id": "security_configuration_loggers",
  "title": "Secure Logger Configuration",
  "description": "This rule flags for review code that initiates logger configuration. The goal is to guide security code reviews.",
  "status": "ready",
  "defaultSeverity": "Info",
  "category": "Security",
  "recommendation": "Review and secure logger configuration",
  "impact": "Impact on the type and method of logging sensitive information",
  "examples": {
    "noncompliant": [],
    "compliant": []
  },
  "references": [],
  "logic": {
    "node_types": ["MethodInvocation", "Class"],
    "checks": [{
      "type": "regex_match",
      "property_path": ["source"],
      "patterns": ["Logger\\.getLogger|LoggerFactory\\.getLogger|LogManager\\.getLogger|setLevel\\(|addAppender\\("],
      "message": "Review and secure logger configuration"
    }]
  }
}