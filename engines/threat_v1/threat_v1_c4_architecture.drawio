                <!-- ARROWS -->
                <mxCell id="p2a1" value="triggers" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;strokeColor=#C62828;fontColor=#C62828;exitX=0.5;exitY=1;exitDx=0;exitDy=0;" edge="1" source="p2trig" target="p2api" parent="1">
