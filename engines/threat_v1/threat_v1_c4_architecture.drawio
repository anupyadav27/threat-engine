    <diagram id="p2" name="L2 — Containers (Engine)">
        <mxGraphModel dx="1422" dy="762" grid="1" gridSize="10" guides="1" pageWidth="2600" pageHeight="1800" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
