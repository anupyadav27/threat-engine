                    <mxGeometry x="560" y="80" width="580" height="160" as="geometry"/>
                </mxCell>
                <mxCell id="p4inv_note" value="Fields to add to Threat Tab (not yet in inventory):&lt;br&gt;• on_attack_path: bool — from Neo4j node property (added by GraphBuilder)&lt;br&gt;• incident_ids[]: list of threat_incidents.incident_id where this uid appears in evidence.path_resources&lt;br&gt;• hop_position: &#39;entry&#39; | &#39;intermediate&#39; | &#39;crown_jewel&#39; — computed from attack path order&lt;br&gt;• enabling_technique_ids[]: technique_ids from matched_patterns where path includes this uid&lt;br&gt;• cdr_event_count: from cdr_findings WHERE resource_uid = uid AND occurred_at &gt; now()-7d" style="text;html=1;fillColor=#DCEEFB;strokeColor=#1565C0;fontSize=10;rounded=1;align=left;spacingLeft=10;" parent="p4inv" vertex="1">
                    <mxGeometry x="1160" y="40" width="1350" height="180" as="geometry"/>
