                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="p2a7" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;" edge="1" source="p2gb" target="p2db5" parent="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="p2a8" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;" edge="1" source="p2gb" target="p2db6" parent="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="p2a9" value="MERGE/CREATE nodes+edges (Bolt)" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;strokeColor=#6A1B9A;fontColor=#6A1B9A;" edge="1" source="p2gb" target="p2neo" parent="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="p2a10" value="loads patterns" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;" edge="1" source="p2pe" target="p2cat" parent="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="p2a11" value="executes Cypher (parameterized)" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;strokeColor=#6A1B9A;fontColor=#6A1B9A;" edge="1" source="p2pe" target="p2neo" parent="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="p2a12" value="pattern matches → incidents" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;" edge="1" source="p2pe" target="p2iw" parent="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="p2a13" value="orchestrates" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;" edge="1" source="p2api" target="p2pe" parent="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="p2a14" value="orchestrates" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;" edge="1" source="p2api" target="p2iw" parent="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="p2a15" value="upserts incidents (psycopg2)" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;strokeColor=#1565C0;fontColor=#1565C0;" edge="1" source="p2iw" target="p2tdb" parent="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="p2a16" value="reads for BFF aggregation" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;dashed=1;" edge="1" source="p2bff" target="p2tdb" parent="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
            </root>
        </mxGraphModel>
    </diagram>
    <diagram id="p3" name="L3 — Engine Components">
        <mxGraphModel dx="509" dy="759" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2800" pageHeight="1900" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <mxCell id="p3t" value="Threat Engine v1 — C4 Level 3: Engine Components" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=18;fontStyle=1;fontColor=#0D47A1;" parent="1" vertex="1">
                    <mxGeometry x="40" y="16" width="2720" height="34" as="geometry"/>
                </mxCell>
                <mxCell id="p3gb_box" value="GraphBuilder" style="swimlane;startSize=36;fillColor=#BBDEFB;strokeColor=#1565C0;fontColor=#0D47A1;fontStyle=1;fontSize=14;" parent="1" vertex="1">
                    <mxGeometry x="40" y="80" width="800" height="720" as="geometry"/>
                </mxCell>
                <mxCell id="p3c1" value="&lt;b&gt;ResourceResolver&lt;/b&gt;&lt;br&gt;[Component]&lt;br&gt;&lt;br&gt;Resolves resource_uid across all 6 engine DBs.&lt;br&gt;Deduplicates by (tenant_id, account_id, resource_uid).&lt;br&gt;Returns unified ResourceNode with provider/region/type.&lt;br&gt;Skips resources not in inventory (orphaned)." style="rounded=1;whiteSpace=wrap;fillColor=#85BBF0;strokeColor=#5EA8E0;fontSize=10;" parent="p3gb_box" vertex="1">
                    <mxGeometry x="20" y="50" width="360" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="p3c2" value="&lt;b&gt;MisconfigLoader&lt;/b&gt;&lt;br&gt;[Component]&lt;br&gt;&lt;br&gt;Reads check_findings WHERE status=&#39;FAIL&#39;.&lt;br&gt;Attaches to resource nodes as HAS_FINDING edges.&lt;br&gt;Includes rule_id, mitre_technique_id, severity.&lt;br&gt;Skips rules without mitre_technique_id." style="rounded=1;whiteSpace=wrap;fillColor=#85BBF0;strokeColor=#5EA8E0;fontSize=10;" parent="p3gb_box" vertex="1">
                    <mxGeometry x="420" y="50" width="360" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="p3c3" value="&lt;b&gt;VulnLoader&lt;/b&gt;&lt;br&gt;[Component]&lt;br&gt;&lt;br&gt;Reads scan_vulnerabilities WHERE cvss_score &gt;= 7.&lt;br&gt;Joins cve_attack_mappings for technique_id.&lt;br&gt;Creates CVENode per unique CVE ID.&lt;br&gt;Edges: resource HAS_CVE cve_node." style="rounded=1;whiteSpace=wrap;fillColor=#85BBF0;strokeColor=#5EA8E0;fontSize=10;" parent="p3gb_box" vertex="1">
                    <mxGeometry x="20" y="210" width="360" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="p3c4" value="&lt;b&gt;CDRLoader&lt;/b&gt;&lt;br&gt;[Component]&lt;br&gt;&lt;br&gt;Reads cdr_findings (last 7 days, same tenant).&lt;br&gt;Creates CDREventNode per unique actor+technique.&lt;br&gt;Edges: actor PERFORMED_ON target_resource.&lt;br&gt;Sets cdr_signal_count on resource nodes." style="rounded=1;whiteSpace=wrap;fillColor=#85BBF0;strokeColor=#5EA8E0;fontSize=10;" parent="p3gb_box" vertex="1">
                    <mxGeometry x="420" y="210" width="360" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="p3c5" value="&lt;b&gt;CrownJewelClassifier&lt;/b&gt;&lt;br&gt;[Component]&lt;br&gt;&lt;br&gt;Queries resource_inventory_identifier WHERE&lt;br&gt;asset_category IN (&#39;secrets&#39;,&#39;data_store&#39;,&#39;identity&#39;).&lt;br&gt;Also checks: access_pattern=PUBLIC + datasec FAIL.&lt;br&gt;Sets is_crown_jewel=true on Neo4j node property." style="rounded=1;whiteSpace=wrap;fillColor=#85BBF0;strokeColor=#5EA8E0;fontSize=10;" parent="p3gb_box" vertex="1">
                    <mxGeometry x="20" y="370" width="360" height="140" as="geometry"/>
                </mxCell>
                <mxCell id="p3c6" value="&lt;b&gt;EdgeBuilder&lt;/b&gt;&lt;br&gt;[Component]&lt;br&gt;&lt;br&gt;Reads resource_relationship_rules (369 active rules).&lt;br&gt;Reads inventory_relationships (materialized edges).&lt;br&gt;Creates EXPOSES/CAN_ACCESS/LEADS_TO edges.&lt;br&gt;Tags on_attack_path=true after pattern execution." style="rounded=1;whiteSpace=wrap;fillColor=#85BBF0;strokeColor=#5EA8E0;fontSize=10;" parent="p3gb_box" vertex="1">
                    <mxGeometry x="420" y="370" width="360" height="140" as="geometry"/>
                </mxCell>
                <mxCell id="p3gb_note" value="Output: Complete security graph in Neo4j for this tenant.&lt;br&gt;All ops wrapped in per-tenant pg_try_advisory_lock (5 min max wait)." style="text;html=1;fillColor=#DCEEFB;strokeColor=#1565C0;fontSize=10;rounded=1;align=center;" parent="p3gb_box" vertex="1">
                    <mxGeometry x="20" y="540" width="760" height="50" as="geometry"/>
                </mxCell>
                <mxCell id="p3pe_box" value="PatternExecutor" style="swimlane;startSize=36;fillColor=#F3E5F5;strokeColor=#6A1B9A;fontColor=#4A148C;fontStyle=1;fontSize=14;" parent="1" vertex="1">
                    <mxGeometry x="900" y="80" width="800" height="720" as="geometry"/>
                </mxCell>
                <mxCell id="p3p1" value="&lt;b&gt;PatternRegistry&lt;/b&gt;&lt;br&gt;[Component]&lt;br&gt;&lt;br&gt;Loads YAML from catalog/threat_patterns/{tier}/{csp}/*.yaml.&lt;br&gt;Validates schema (pattern_id, tier, mitre_techniques, version).&lt;br&gt;Filters: active=true, deprecated_at=null.&lt;br&gt;Groups by tier for ordered execution (T1→T2→T3)." style="rounded=1;whiteSpace=wrap;fillColor=#CE93D8;strokeColor=#8E24AA;fontSize=10;" parent="p3pe_box" vertex="1">
                    <mxGeometry x="20" y="50" width="360" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="p3p2" value="&lt;b&gt;PatternCompiler&lt;/b&gt;&lt;br&gt;[Component]&lt;br&gt;&lt;br&gt;Transpiles YAML conditions → parameterized Cypher.&lt;br&gt;Uses $tenant_id, $account_id params (no string concat).&lt;br&gt;Validates Cypher syntax via neo4j driver dry-run.&lt;br&gt;Caches compiled queries per pattern_version." style="rounded=1;whiteSpace=wrap;fillColor=#CE93D8;strokeColor=#8E24AA;fontSize=10;" parent="p3pe_box" vertex="1">
                    <mxGeometry x="420" y="50" width="360" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="p3p3" value="&lt;b&gt;Tier1Matcher — Toxic Combo&lt;/b&gt;&lt;br&gt;[Component]&lt;br&gt;&lt;br&gt;Single-node flag combinations on one resource.&lt;br&gt;No graph traversal (no path).&lt;br&gt;Example: EC2 with PUBLIC_IP + no MFA + HIGH CVE.&lt;br&gt;Fastest matcher: flag AND logic only." style="rounded=1;whiteSpace=wrap;fillColor=#CE93D8;strokeColor=#8E24AA;fontSize=10;" parent="p3pe_box" vertex="1">
                    <mxGeometry x="20" y="210" width="360" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="p3p4" value="&lt;b&gt;Tier2Matcher — Partial Path&lt;/b&gt;&lt;br&gt;[Component]&lt;br&gt;&lt;br&gt;N-of-M hops forming partial attack chain.&lt;br&gt;Detects chain formation before crown jewel reach.&lt;br&gt;Example: Entry→Pivot (no target yet).&lt;br&gt;Early warning for nascent attack paths." style="rounded=1;whiteSpace=wrap;fillColor=#CE93D8;strokeColor=#8E24AA;fontSize=10;" parent="p3pe_box" vertex="1">
                    <mxGeometry x="420" y="210" width="360" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="p3p5" value="&lt;b&gt;Tier3Matcher — Full Path&lt;/b&gt;&lt;br&gt;[Component]&lt;br&gt;&lt;br&gt;Complete chain: Entry → [hops] → Crown Jewel.&lt;br&gt;CDR signal grading: 0 signals=posture, 1=suspicious, 2+=active.&lt;br&gt;min_cdr_coverage met → also escalates to active.&lt;br&gt;Highest severity + incident_class wins on roll-up." style="rounded=1;whiteSpace=wrap;fillColor=#CE93D8;strokeColor=#8E24AA;fontSize=10;" parent="p3pe_box" vertex="1">
                    <mxGeometry x="20" y="370" width="360" height="150" as="geometry"/>
                </mxCell>
                <mxCell id="p3p6" value="&lt;b&gt;PerformanceGuard&lt;/b&gt;&lt;br&gt;[Component]&lt;br&gt;&lt;br&gt;Budget: per-pattern p99 &lt; 500ms (median &lt; 100ms).&lt;br&gt;Tracks rolling p99 per pattern over last 3 runs.&lt;br&gt;Auto-quarantines pattern (active=false) on 3× breach.&lt;br&gt;Alerts via structured log for manual review." style="rounded=1;whiteSpace=wrap;fillColor=#CE93D8;strokeColor=#8E24AA;fontSize=10;" parent="p3pe_box" vertex="1">
                    <mxGeometry x="420" y="370" width="360" height="150" as="geometry"/>
                </mxCell>
                <mxCell id="p3pe_note" value="Output: List of PatternMatch objects → passed to IncidentWriter.&lt;br&gt;Roll-up key: (tenant_id, entry_resource_uid, target_resource_uid). Highest tier wins." style="text;html=1;fillColor=#EDE7F6;strokeColor=#6A1B9A;fontSize=10;rounded=1;align=center;" parent="p3pe_box" vertex="1">
                    <mxGeometry x="20" y="544" width="760" height="50" as="geometry"/>
                </mxCell>
                <mxCell id="p3iw_box" value="IncidentWriter" style="swimlane;startSize=36;fillColor=#E8F5E9;strokeColor=#2E7D32;fontColor=#1B5E20;fontStyle=1;fontSize=14;" parent="1" vertex="1">
                    <mxGeometry x="1760" y="80" width="800" height="720" as="geometry"/>
                </mxCell>
                <mxCell id="p3i1" value="&lt;b&gt;SeverityScorer&lt;/b&gt;&lt;br&gt;[Component]&lt;br&gt;&lt;br&gt;Base score: CVSS max across path vulns.&lt;br&gt;+20 if CDR active signal on path resource.&lt;br&gt;+10 if Crown Jewel is target.&lt;br&gt;+5 per additional CDR event on path." style="rounded=1;whiteSpace=wrap;fillColor=#A5D6A7;strokeColor=#388E3C;fontSize=10;" parent="p3iw_box" vertex="1">
                    <mxGeometry x="20" y="50" width="360" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="p3i2" value="&lt;b&gt;IncidentRollup&lt;/b&gt;&lt;br&gt;[Component]&lt;br&gt;&lt;br&gt;Groups all pattern matches by roll-up key.&lt;br&gt;Key: (tenant_id, entry_resource_uid, target_resource_uid).&lt;br&gt;Selects highest tier as winning pattern.&lt;br&gt;Merges evidence.matched_patterns[] from all patterns." style="rounded=1;whiteSpace=wrap;fillColor=#A5D6A7;strokeColor=#388E3C;fontSize=10;" parent="p3iw_box" vertex="1">
                    <mxGeometry x="420" y="50" width="360" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="p3i3" value="&lt;b&gt;IncidentDeduper&lt;/b&gt;&lt;br&gt;[Component]&lt;br&gt;&lt;br&gt;Computes dedup_key: sha256(pattern_id|entry_uid|target_uid).&lt;br&gt;Checks threat_incidents for existing open incident.&lt;br&gt;If exists: upsert (update severity, evidence, last_seen).&lt;br&gt;If new: INSERT with status=&#39;new&#39;, incident_class from tier." style="rounded=1;whiteSpace=wrap;fillColor=#A5D6A7;strokeColor=#388E3C;fontSize=10;" parent="p3iw_box" vertex="1">
                    <mxGeometry x="20" y="210" width="360" height="140" as="geometry"/>
                </mxCell>
                <mxCell id="p3i4" value="&lt;b&gt;LifecycleTransitioner&lt;/b&gt;&lt;br&gt;[Component]&lt;br&gt;&lt;br&gt;Applies state machine on each pipeline run:&lt;br&gt;new→open, posture→suspicious (1st CDR), suspicious→active (2nd CDR).&lt;br&gt;resolved→reopened if same dedup_key seen again.&lt;br&gt;No separate scheduler — evaluated per trigger run." style="rounded=1;whiteSpace=wrap;fillColor=#A5D6A7;strokeColor=#388E3C;fontSize=10;" parent="p3iw_box" vertex="1">
                    <mxGeometry x="420" y="210" width="360" height="140" as="geometry"/>
                </mxCell>
                <mxCell id="p3i5" value="&lt;b&gt;StoryBuilder&lt;/b&gt;&lt;br&gt;[Component]&lt;br&gt;&lt;br&gt;Generates human-readable narrative for incident card.&lt;br&gt;Template: &#39;{attacker_entry} exploiting {technique} → {target}&#39;.&lt;br&gt;Includes: mitre_tactic_chain, hop_count, crown_jewel_name.&lt;br&gt;Stored as story_text TEXT in threat_incidents." style="rounded=1;whiteSpace=wrap;fillColor=#A5D6A7;strokeColor=#388E3C;fontSize=10;" parent="p3iw_box" vertex="1">
                    <mxGeometry x="20" y="380" width="360" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="p3i6" value="&lt;b&gt;FeedbackProcessor&lt;/b&gt;&lt;br&gt;[Component]&lt;br&gt;&lt;br&gt;Reads threat_incident_feedback (require FP feedback permission).&lt;br&gt;Computes rolling 30-day FP rate per pattern_id.&lt;br&gt;If rate &gt; 30%: sets active=false on pattern (quarantine).&lt;br&gt;Emits structured log alert for security team review." style="rounded=1;whiteSpace=wrap;fillColor=#A5D6A7;strokeColor=#388E3C;fontSize=10;" parent="p3iw_box" vertex="1">
                    <mxGeometry x="420" y="380" width="360" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="p3iw_note" value="Output: Upserted rows in threat_incidents + threat_scan_runs_v1 (audit).&lt;br&gt;Evidence JSONB: {misconfig_findings, vuln_findings, cdr_events, path_resources, matched_patterns, graph_query, _schema_version:1}" style="text;html=1;fillColor=#E8F5E9;strokeColor=#2E7D32;fontSize=10;rounded=1;align=center;" parent="p3iw_box" vertex="1">
                    <mxGeometry x="20" y="536" width="760" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="p3a1" value="PatternMatch list" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=11;strokeColor=#6A1B9A;fontColor=#6A1B9A;exitX=1;exitY=0.5;exitDx=0;exitDy=0;" parent="1" source="p3pe_box" target="p3iw_box" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="p3a2" value="Neo4j graph ready" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=11;strokeColor=#1565C0;fontColor=#1565C0;exitX=1;exitY=0.5;exitDx=0;exitDy=0;" parent="1" source="p3gb_box" target="p3pe_box" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="p3api" value="&lt;b&gt;FastAPI REST Endpoints&lt;/b&gt; (require_permission(&#39;threats:read&#39;))&lt;br&gt;POST /api/v1/scan — trigger (async, returns job_id) | GET /api/v1/scan/status/{job_id}&lt;br&gt;GET /api/v1/incidents?tenant_id=&amp;status=&amp;tier=&amp;page= | GET /api/v1/incidents/{id}&lt;br&gt;GET /api/v1/incidents/{id}/graph-subgraph | POST /api/v1/incidents/{id}/feedback&lt;br&gt;GET /api/v1/graph/build | GET /api/v1/graph/build/status/{job_id}&lt;br&gt;GET /api/v1/health/live | GET /api/v1/health/ready" style="text;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;fontSize=10;rounded=1;align=left;spacingLeft=10;" parent="1" vertex="1">
                    <mxGeometry x="40" y="840" width="2520" height="120" as="geometry"/>
                </mxCell>
            </root>
        </mxGraphModel>
    </diagram>
    <diagram id="p4" name="L3 — UI Architecture">
        <mxGraphModel dx="509" dy="759" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2600" pageHeight="2000" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <mxCell id="p4t" value="Threat Engine v1 — C4 Level 3: UI Architecture &amp; Data Flow (Updated Design)" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=18;fontStyle=1;fontColor=#0D47A1;" parent="1" vertex="1">
                    <mxGeometry x="40" y="16" width="2520" height="34" as="geometry"/>
                </mxCell>
                <mxCell id="p4d1" value="✅ DESIGN DECISION: Zone C = Side Panel (NOT popup)&lt;br&gt;Panel pattern (Wiz/Orca/Prisma). Narrows Zone B, keeps card list visible. No popup chains.&lt;br&gt;Panel shows: incident_class chip, top MITRE tactics, CDR signal count, crown jewel indicator." style="text;html=1;fillColor=#E8F5E9;strokeColor=#2E7D32;fontSize=11;rounded=1;align=left;spacingLeft=10;fontColor=#1B5E20;" parent="1" vertex="1">
                    <mxGeometry x="40" y="60" width="1200" height="70" as="geometry"/>
                </mxCell>
                <mxCell id="p4d2" value="✅ DESIGN DECISION: Node click = Inline Hop Card (NOT slide-over panel)&lt;br&gt;Clicking a hop node expands a compact detail row BELOW that step in the attack chain.&lt;br&gt;Shows: technique ID + name, top 3 misconfigs, CVE count, CDR events on this node.&lt;br&gt;&#39;View Full Asset →&#39; navigates to /inventory/assets/{uid}?from=threat&amp;incident_id={id}" style="text;html=1;fillColor=#FFF8E1;strokeColor=#F57F17;fontSize=11;rounded=1;align=left;spacingLeft=10;fontColor=#E65100;" parent="1" vertex="1">
                    <mxGeometry x="1300" y="60" width="1260" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="p4browser" value="Browser (Next.js 15 SPA — fetchView via BFF + gateway REST for tables)" style="text;html=1;strokeColor=#333333;fillColor=#F5F5F5;fontSize=11;fontStyle=1;rounded=1;align=center;" parent="1" vertex="1">
                    <mxGeometry x="40" y="158" width="2520" height="34" as="geometry"/>
                </mxCell>
                <mxCell id="p4cr" value="&lt;b&gt;/threats — Command Room&lt;/b&gt;" style="swimlane;startSize=30;fillColor=#E3F2FD;strokeColor=#1565C0;fontColor=#0D47A1;fontStyle=1;fontSize=12;" parent="1" vertex="1">
                    <mxGeometry x="40" y="210" width="580" height="560" as="geometry"/>
                </mxCell>
                <mxCell id="p4kpi" value="&lt;b&gt;KPIStrip&lt;/b&gt;&lt;br&gt;active | suspicious | posture counts&lt;br&gt;Tier 3 paths | Crown Jewels at risk&lt;br&gt;← nav: crown-jewels, patterns" style="rounded=1;whiteSpace=wrap;fillColor=#BBDEFB;strokeColor=#1565C0;fontSize=10;" parent="p4cr" vertex="1">
                    <mxGeometry x="10" y="40" width="560" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="p4fb" value="&lt;b&gt;FilterBar&lt;/b&gt;&lt;br&gt;incident_class | tier | severity | csp | region&lt;br&gt;text search on title + resource_name" style="rounded=1;whiteSpace=wrap;fillColor=#BBDEFB;strokeColor=#1565C0;fontSize=10;" parent="p4cr" vertex="1">
                    <mxGeometry x="10" y="140" width="560" height="70" as="geometry"/>
                </mxCell>
                <mxCell id="p4zb" value="&lt;b&gt;Zone B — IncidentList&lt;/b&gt;&lt;br&gt;ScenarioCard × N (virtualized)&lt;br&gt;Each card: tier badge (T1/T2/T3), incident_class chip&lt;br&gt;(ACTIVE/SUSPICIOUS/POSTURE), severity dot, risk score,&lt;br&gt;title, resource, MITRE techniques, CSP/region.&lt;br&gt;Click → navigate to /threats/[id]&lt;br&gt;Hover 50ms → activate Zone C panel" style="rounded=1;whiteSpace=wrap;fillColor=#BBDEFB;strokeColor=#1565C0;fontSize=10;" parent="p4cr" vertex="1">
                    <mxGeometry x="10" y="220" width="270" height="180" as="geometry"/>
                </mxCell>
                <mxCell id="p4zc" value="&lt;b&gt;Zone C — QuickPreview Panel&lt;/b&gt;&lt;br&gt;[SIDE PANEL — not popup]&lt;br&gt;Incident class chip (color-coded)&lt;br&gt;Top MITRE tactics for this incident&lt;br&gt;CDR signals count badge&lt;br&gt;Crown jewel target name&lt;br&gt;&#39;Open Full Detail →&#39; button" style="rounded=1;whiteSpace=wrap;fillColor=#BBDEFB;strokeColor=#1565C0;fontSize=10;" parent="p4cr" vertex="1">
                    <mxGeometry x="290" y="220" width="280" height="180" as="geometry"/>
                </mxCell>
                <mxCell id="p4bff1" value="BFF: GET /views/threat_v1_incidents&lt;br&gt;{incidents[], kpi_counts, filter_options}" style="text;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;fontSize=10;rounded=1;" parent="p4cr" vertex="1">
                    <mxGeometry x="10" y="420" width="560" height="40" as="geometry"/>
                </mxCell>
                <mxCell id="p4cr_note" value="ScenarioCard.jsx (existing) — extend with tier badge + incident_class chip" style="text;html=1;fillColor=none;strokeColor=none;fontSize=9;fontColor=#666666;align=center;" parent="p4cr" vertex="1">
                    <mxGeometry x="10" y="470" width="560" height="24" as="geometry"/>
                </mxCell>
