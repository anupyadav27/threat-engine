                <!-- TITLE -->
                <mxCell id="p2t" value="Threat Engine v1 — C4 Level 2: Containers (Engine Internal Architecture)" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=18;fontStyle=1;fontColor=#0D47A1;" vertex="1" parent="1">
                    <mxGeometry x="40" y="20" width="2520" height="34" as="geometry"/>
                </mxCell>
                <!-- TRIGGER BOUNDARY (TOP) -->
                <mxCell id="p2trig" value="Argo Workflows — POST /api/v1/scan {scan_run_id, csp_engine_run_ids}" style="text;html=1;strokeColor=#C62828;fillColor=#FFEBEE;align=center;fontSize=12;fontColor=#C62828;fontStyle=1;rounded=1;" vertex="1" parent="1">
                    <mxGeometry x="900" y="70" width="680" height="40" as="geometry"/>
                </mxCell>
                <!-- FASTAPI SERVER CONTAINER -->
                <mxCell id="p2api" value="&lt;b&gt;FastAPI HTTP Server&lt;/b&gt;&lt;br&gt;[Container: Python 3.11 / FastAPI]&lt;br&gt;&lt;br&gt;Port 8020. Receives scan trigger, serves REST API.&lt;br&gt;All endpoints require require_permission(&#39;threats:read&#39;).&lt;br&gt;Returns 202 + job_id for async scan trigger.&lt;br&gt;Runs run_scan.py pipeline internally." style="rounded=1;whiteSpace=wrap;fillColor=#438DD5;fontColor=#ffffff;strokeColor=#2E6DA4;fontSize=11;arcSize=3;" vertex="1" parent="1">
                    <mxGeometry x="860" y="140" width="760" height="140" as="geometry"/>
                </mxCell>
                <!-- SOURCE DATABASES (LEFT COLUMN) -->
                <mxCell id="p2srclbl" value="Source Engine Databases (Read-Only)" style="text;html=1;strokeColor=none;fillColor=none;fontStyle=1;fontSize=11;fontColor=#333333;" vertex="1" parent="1">
                    <mxGeometry x="20" y="130" width="300" height="24" as="geometry"/>
                </mxCell>
                <mxCell id="p2db1" value="&lt;b&gt;Check DB&lt;/b&gt;&lt;br&gt;check_findings, rule_metadata" style="rounded=1;whiteSpace=wrap;fillColor=#777777;fontColor=#ffffff;strokeColor=#555555;fontSize=10;" vertex="1" parent="1">
                    <mxGeometry x="20" y="165" width="220" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="p2db2" value="&lt;b&gt;Inventory DB&lt;/b&gt;&lt;br&gt;resource_inventory_identifier,&lt;br&gt;inventory_findings, inventory_relationships" style="rounded=1;whiteSpace=wrap;fillColor=#777777;fontColor=#ffffff;strokeColor=#555555;fontSize=10;" vertex="1" parent="1">
                    <mxGeometry x="20" y="245" width="220" height="70" as="geometry"/>
                </mxCell>
                <mxCell id="p2db3" value="&lt;b&gt;CDR DB&lt;/b&gt;&lt;br&gt;cdr_findings, cdr_actor_daily_stats" style="rounded=1;whiteSpace=wrap;fillColor=#777777;fontColor=#ffffff;strokeColor=#555555;fontSize=10;" vertex="1" parent="1">
                    <mxGeometry x="20" y="335" width="220" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="p2db4" value="&lt;b&gt;Vulnerability DB&lt;/b&gt;&lt;br&gt;scan_vulnerabilities, cve_attack_mappings" style="rounded=1;whiteSpace=wrap;fillColor=#777777;fontColor=#ffffff;strokeColor=#555555;fontSize=10;" vertex="1" parent="1">
                    <mxGeometry x="20" y="415" width="220" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="p2db5" value="&lt;b&gt;IAM DB&lt;/b&gt;&lt;br&gt;iam_findings (MFA, admin, overprivileged)" style="rounded=1;whiteSpace=wrap;fillColor=#777777;fontColor=#ffffff;strokeColor=#555555;fontSize=10;" vertex="1" parent="1">
                    <mxGeometry x="20" y="495" width="220" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="p2db6" value="&lt;b&gt;DataSec DB&lt;/b&gt;&lt;br&gt;datasec_findings (S3 public + sensitive)" style="rounded=1;whiteSpace=wrap;fillColor=#777777;fontColor=#ffffff;strokeColor=#555555;fontSize=10;" vertex="1" parent="1">
                    <mxGeometry x="20" y="575" width="220" height="60" as="geometry"/>
                </mxCell>
                <!-- GRAPH BUILDER CONTAINER -->
                <mxCell id="p2gb" value="&lt;b&gt;GraphBuilder&lt;/b&gt;&lt;br&gt;[Container: Python Module]&lt;br&gt;&lt;br&gt;Reads multi-engine findings, resolves resource_uid→graph node.&lt;br&gt;Loads misconfigs, vulns, CDR events as finding nodes.&lt;br&gt;Classifies crown jewels from resource_inventory_identifier.&lt;br&gt;Builds edges: EXPOSES, HAS_FINDING, LEADS_TO.&lt;br&gt;Per-tenant advisory lock (pg_try_advisory_lock)." style="rounded=1;whiteSpace=wrap;fillColor=#438DD5;fontColor=#ffffff;strokeColor=#2E6DA4;fontSize=11;" vertex="1" parent="1">
                    <mxGeometry x="360" y="340" width="380" height="200" as="geometry"/>
                </mxCell>
                <!-- PATTERN CATALOG -->
                <mxCell id="p2cat" value="&lt;b&gt;Pattern Catalog&lt;/b&gt;&lt;br&gt;[Container: YAML Files on Disk]&lt;br&gt;&lt;br&gt;catalog/threat_patterns/{tier}/{csp}/*.yaml&lt;br&gt;30 patterns: 10×T1, 10×T2, 10×T3.&lt;br&gt;Each: conditions, hops, mitre_techniques,&lt;br&gt;positive/negative test fixtures." style="rounded=1;whiteSpace=wrap;fillColor=#438DD5;fontColor=#ffffff;strokeColor=#2E6DA4;fontSize=11;" vertex="1" parent="1">
                    <mxGeometry x="1380" y="140" width="340" height="180" as="geometry"/>
                </mxCell>
                <!-- PATTERN EXECUTOR CONTAINER -->
                <mxCell id="p2pe" value="&lt;b&gt;PatternExecutor&lt;/b&gt;&lt;br&gt;[Container: Python Module]&lt;br&gt;&lt;br&gt;Loads YAML patterns from PatternRegistry.&lt;br&gt;Compiles conditions → parameterized Cypher.&lt;br&gt;Executes T1/T2/T3 matchers against Neo4j graph.&lt;br&gt;Multi-pattern roll-up: (entry, target) key dedup.&lt;br&gt;Per-pattern p99 budget: 500ms; auto-quarantine at 3×." style="rounded=1;whiteSpace=wrap;fillColor=#438DD5;fontColor=#ffffff;strokeColor=#2E6DA4;fontSize=11;" vertex="1" parent="1">
                    <mxGeometry x="1380" y="380" width="380" height="200" as="geometry"/>
                </mxCell>
                <!-- NEO4J (CENTER-RIGHT) -->
                <mxCell id="p2neo" value="&lt;b&gt;Neo4j Aura&lt;/b&gt;&lt;br&gt;[External Graph Database]&lt;br&gt;&lt;br&gt;Receives MERGE/CREATE from GraphBuilder.&lt;br&gt;Returns path matches to PatternExecutor.&lt;br&gt;Properties on nodes: on_attack_path,&lt;br&gt;is_crown_jewel, tier, incident_class" style="rounded=1;whiteSpace=wrap;fillColor=#777777;fontColor=#ffffff;strokeColor=#555555;fontSize=11;" vertex="1" parent="1">
                    <mxGeometry x="900" y="360" width="360" height="200" as="geometry"/>
                </mxCell>
                <!-- INCIDENT WRITER CONTAINER -->
                <mxCell id="p2iw" value="&lt;b&gt;IncidentWriter&lt;/b&gt;&lt;br&gt;[Container: Python Module]&lt;br&gt;&lt;br&gt;Scores severity: CVSS base + CDR signal boost + blast radius.&lt;br&gt;Roll-up by (tenant, entry_resource_uid, target_resource_uid).&lt;br&gt;Dedup by dedup_key; upsert incident with status transition.&lt;br&gt;Builds StoryText narrative for alert card.&lt;br&gt;Processes feedback: rolling 30-day FP rate per pattern." style="rounded=1;whiteSpace=wrap;fillColor=#438DD5;fontColor=#ffffff;strokeColor=#2E6DA4;fontSize=11;" vertex="1" parent="1">
                    <mxGeometry x="1880" y="340" width="420" height="220" as="geometry"/>
                </mxCell>
                <!-- THREAT DB (BOTTOM RIGHT) -->
                <mxCell id="p2tdb" value="&lt;b&gt;Threat DB (RDS PostgreSQL)&lt;/b&gt;&lt;br&gt;[Internal Database — NEW]&lt;br&gt;&lt;br&gt;threat_incidents (lifecycle + evidence JSONB)&lt;br&gt;threat_scan_runs_v1 (audit trail)&lt;br&gt;threat_incident_feedback (FP rate loop)" style="rounded=1;whiteSpace=wrap;fillColor=#438DD5;fontColor=#ffffff;strokeColor=#2E6DA4;fontSize=11;" vertex="1" parent="1">
                    <mxGeometry x="1880" y="640" width="420" height="160" as="geometry"/>
                </mxCell>
                <!-- BFF VIEW HANDLER NOTE -->
                <mxCell id="p2bff" value="&lt;b&gt;BFF View Handlers (in API Gateway)&lt;/b&gt;&lt;br&gt;[Container: Python, shared/api_gateway/bff/]&lt;br&gt;&lt;br&gt;GET /views/threat_v1_incidents → incident list with tier/status&lt;br&gt;GET /views/threat_v1_crown_jewels → CJ catalog&lt;br&gt;GET /views/threat_v1_patterns → pattern FP rates + MITRE heatmap&lt;br&gt;Reads Threat DB directly (not via engine REST)." style="rounded=1;whiteSpace=wrap;fillColor=#f5f5f5;strokeColor=#999999;fontColor=#333333;fontSize=11;" vertex="1" parent="1">
                    <mxGeometry x="860" y="780" width="760" height="160" as="geometry"/>
                </mxCell>
                <!-- PIPELINE FLOW LABELS -->
                <mxCell id="p2step1" value="① Scan Triggered" style="text;html=1;strokeColor=none;fillColor=#E3F2FD;fontSize=10;fontStyle=1;rounded=1;" vertex="1" parent="1">
                    <mxGeometry x="920" y="300" width="140" height="28" as="geometry"/>
