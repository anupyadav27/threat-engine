                    <mxGeometry x="40" y="1420" width="2520" height="260" as="geometry"/>
                </mxCell>
                <mxCell id="p4b1" value="GET /views/threat_v1_incidents&lt;br&gt;Input: tenant_id (from AuthContext), filters&lt;br&gt;Output: incidents[], kpi_counts{active,suspicious,posture,tier3_paths,crown_jewels_at_risk}" style="rounded=1;whiteSpace=wrap;fillColor=#BBDEFB;strokeColor=#1565C0;fontSize=10;" parent="p4bff_sum" vertex="1">
