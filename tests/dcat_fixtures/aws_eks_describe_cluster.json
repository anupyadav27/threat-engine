[
  {
    "resource_uid": "arn:aws:eks:us-east-1:111:cluster/prod-eks",
    "resource_type": "eks.cluster",
    "account_id": "111",
    "provider": "aws",
    "region": "us-east-1",
    "service": "eks",
    "configuration": {
      "Name": "prod-eks",
      "Version": "1.28",
      "PlatformVersion": "eks.5",
      "Status": "ACTIVE",
      "ResourcesVpcConfig": {
        "VpcId": "vpc-1",
        "SubnetIds": ["subnet-1", "subnet-2"],
        "SecurityGroupIds": ["sg-1"],
        "EndpointPublicAccess": false,
        "EndpointPrivateAccess": true
      },
      "EncryptionConfig": [
        {"Provider": {"KeyArn": "arn:aws:kms:us-east-1:111:key/k-1"}, "Resources": ["secrets"]}
      ],
      "Logging": {
        "ClusterLogging": [
          {"Types": ["api", "audit"], "Enabled": true}
        ]
      }
    }
  },
  {
    "resource_uid": "arn:aws:ecs:us-east-1:111:cluster/web-cluster",
    "resource_type": "ecs.cluster",
    "account_id": "111",
    "provider": "aws",
    "region": "us-east-1",
    "service": "ecs",
    "configuration": {
      "clusterName": "web-cluster",
      "Status": "ACTIVE",
      "Settings": [{"Name": "containerInsights", "Value": "enabled"}],
      "CapacityProviders": ["FARGATE", "FARGATE_SPOT"]
    }
  },
  {
    "resource_uid": "arn:aws:ecr:us-east-1:111:repository/app-images",
    "resource_type": "ecr.repository",
    "account_id": "111",
    "provider": "aws",
    "region": "us-east-1",
    "service": "ecr",
    "configuration": {
      "repositoryName": "app-images",
      "EncryptionConfiguration": {"EncryptionType": "KMS", "KmsKey": "arn:aws:kms:us-east-1:111:key/k-1"},
      "ImageScanningConfiguration": {"ScanOnPush": true},
      "ImageTagMutability": "IMMUTABLE"
    }
  },
  {
    "resource_uid": "arn:aws:lambda:us-east-1:111:function:my-fn",
    "resource_type": "lambda.function",
    "account_id": "111",
    "provider": "aws",
    "region": "us-east-1",
    "service": "lambda",
    "configuration": {
      "FunctionName": "my-fn",
      "Runtime": "python3.11",
      "MemorySize": 512,
      "VpcConfig": {"VpcId": "vpc-1", "SecurityGroupIds": ["sg-2"], "SubnetIds": ["subnet-1"]},
      "KMSKeyArn": "arn:aws:kms:us-east-1:111:key/k-2",
      "TracingConfig": {"Mode": "Active"}
    }
  }
]
