{
  "model": "Sonnet",
  "extendedContextEnabled": true,

  "permissions": {
    "allow": [
      "Bash(done)",
      "Bash(git:*)",
      "Bash(cat:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(ls:*)",
      "Bash(pwd:*)",
      "Bash(docker:*)",
      "Bash(docker build:*)",
      "Bash(docker push:*)",
      "Bash(docker run:*)",
      "Bash(docker logs:*)",
      "Bash(docker images:*)",
      "Bash(docker ps:*)",
      "Bash(kubectl:*)",
      "Bash(kubectl get:*)",
      "Bash(kubectl describe:*)",
      "Bash(kubectl logs:*)",
      "Bash(kubectl apply:*)",
      "Bash(kubectl rollout:*)",
      "Bash(kubectl exec:*)",
      "Bash(kubectl port-forward:*)",
      "Bash(aws ec2 describe:*)",
      "Bash(aws s3 ls:*)",
      "Bash(aws rds describe:*)",
      "Bash(aws eks describe:*)",
      "Bash(python:*)",
      "Bash(python -m:*)",
      "Bash(pytest:*)",
      "Bash(pip:*)",
      "Bash(npm:*)",
      "Read(//)",
      "Edit(src/**:*)",
      "Edit(engine_*/**:*)",
      "Edit(consolidated_services/**:*)",
      "Edit(deployment/**:*)",
      "Edit(.claude/**:*)",
      "Edit(.gitignore:*)",
      "Edit(README.md:*)",
      "Edit(docs/**:*)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:*.aws.amazon.com)",
      "WebFetch(domain:docs.anthropic.com)",
      "WebFetch(domain:kubernetes.io)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(rm :*)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(sudo:*)",
      "Bash(chmod 777:*)",
      "Bash(:/etc/*)",
      "Bash(* > /etc/*)",
      "Read(/.env*)",
      "Read(/secrets/**:*)",
      "Read(/**/credentials/**:*)",
      "Read(/**/passwords/**:*)",
      "Read(~/.ssh/**:*)",
      "Read(~/.aws/**:*)",
      "Edit(/.env*)",
      "Edit(/secrets/**:*)",
      "Edit(/.git/**:*)",
      "Edit(/package-lock.json:*)"
    ],
    "ask": [
      "Bash(kubectl delete:*)",
      "Bash(kubectl rollout restart:*)",
      "Bash(docker push:*)",
      "Bash(docker rm:*)",
      "Edit(deployment/aws/eks/**:*)"
    ]
  },

  "sandbox": {
    "filesystemRestrictions": {
      "allow": [
        "/Users/apple/Desktop/threat-engine",
        "/tmp"
      ],
      "deny": [
        "/etc",
        "/root",
        "*.key",
        "*.pem"
      ]
    }
  },

  "syntaxHighlightingDisabled": false,
  "spinnerTipsEnabled": true,
  "companyAnnouncements": [],

  "env": {
    "LOG_LEVEL": "INFO"
  }
}
