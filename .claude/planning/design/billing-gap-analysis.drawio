    </mxCell>

    <!-- subscription_plans -->
    <mxCell id="db_plans" value="&lt;b&gt;subscription_plans table&lt;/b&gt; ⚠️&lt;br/&gt;• 4 plans: free/$0, starter/$49, pro/$99, ent/$299 ✅&lt;br/&gt;• max_accounts, scan_freq_per_day columns ✅&lt;br/&gt;• engine_allowlist JSONB ✅&lt;br/&gt;&lt;font color=&quot;#dc2626&quot;&gt;❌ stripe_price_id empty on all plans&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#dc2626&quot;&gt;❌ plan limits not populated (max_accounts=null)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef9c3;strokeColor=#ca8a04;align=left;fontSize=10;spacingLeft=8;verticalAlign=top;" vertex="1" parent="1">
      <mxGeometry x="1120" y="262" width="280" height="100" as="geometry" />
    </mxCell>

    <!-- billing_events -->
    <mxCell id="db_events" value="&lt;b&gt;billing_events table&lt;/b&gt; ✅&lt;br/&gt;• idempotency guard for trial emails ✅&lt;br/&gt;• event_type='trial.expiry_notice_sent' ✅&lt;br/&gt;• prevents duplicate emails ✅" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;align=left;fontSize=10;spacingLeft=8;verticalAlign=top;" vertex="1" parent="1">
      <mxGeometry x="1120" y="374" width="280" height="80" as="geometry" />
    </mxCell>

    <!-- billing engine endpoints -->
    <mxCell id="eng_eps" value="&lt;b&gt;Billing Engine Endpoints&lt;/b&gt; ✅&lt;br/&gt;• GET /subscription?org_id ✅&lt;br/&gt;• GET /usage?org_id ✅&lt;br/&gt;• GET /plans ✅&lt;br/&gt;• GET /invoices?org_id ✅&lt;br/&gt;• POST /checkout ✅ (code exists)&lt;br/&gt;• POST /trial/provision ✅&lt;br/&gt;• POST /usage/consume-scan-token ✅&lt;br/&gt;• GET /context/{org_id} ✅ (subscription middleware)&lt;br/&gt;• Stripe webhook handler ✅ (code exists)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;align=left;fontSize=10;spacingLeft=8;verticalAlign=top;" vertex="1" parent="1">
      <mxGeometry x="1120" y="466" width="280" height="150" as="geometry" />
    </mxCell>

    <!-- Stripe dependency -->
    <mxCell id="ext_stripe" value="&lt;b&gt;Stripe Integration&lt;/b&gt; ❌ (External)&lt;br/&gt;• STRIPE_SECRET_KEY not set in K8s secret ❌&lt;br/&gt;• stripe_price_id not populated in plans ❌&lt;br/&gt;• Checkout sessions cannot be created ❌&lt;br/&gt;• Webhook endpoint registered but no secret ❌&lt;br/&gt;• No payment methods on file ❌&lt;br/&gt;&lt;b&gt;Blocks:&lt;/b&gt; UAT-12, UAT-13 (partially)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eff6ff;strokeColor=#3b82f6;align=left;fontSize=10;spacingLeft=8;verticalAlign=top;" vertex="1" parent="1">
      <mxGeometry x="1120" y="628" width="280" height="120" as="geometry" />
    </mxCell>

    <!-- SES dependency -->
    <mxCell id="ext_ses" value="&lt;b&gt;AWS SES (Email)&lt;/b&gt; ❌ (External)&lt;br/&gt;• SES_FROM_EMAIL env var not set ❌&lt;br/&gt;• SES sandbox: sending domain not verified ❌&lt;br/&gt;• Trial warning/expiry emails cannot send ❌&lt;br/&gt;&lt;b&gt;Blocks:&lt;/b&gt; UAT-01 (invite email), UAT-07, UAT-08" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eff6ff;strokeColor=#3b82f6;align=left;fontSize=10;spacingLeft=8;verticalAlign=top;" vertex="1" parent="1">
      <mxGeometry x="1120" y="760" width="280" height="100" as="geometry" />
    </mxCell>

    <!-- ═══════════════════════════════════════════════════════════════════════ -->
    <!-- GAP SUMMARY BOX -->
    <!-- ═══════════════════════════════════════════════════════════════════════ -->
    <mxCell id="gap_bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff7ed;strokeColor=#f97316;arcSize=3;" vertex="1" parent="1">
      <mxGeometry x="40" y="900" width="1360" height="220" as="geometry" />
    </mxCell>
    <mxCell id="gap_title" value="GAP ANALYSIS SUMMARY" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=13;fontStyle=1;fontColor=#c2410c;" vertex="1" parent="1">
      <mxGeometry x="60" y="910" width="400" height="24" as="geometry" />
    </mxCell>

    <!-- Gap columns -->
    <mxCell id="gap_p1_title" value="P0 — BLOCKERS (deploy-blocking)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=11;fontStyle=1;fontColor=#dc2626;" vertex="1" parent="1">
      <mxGeometry x="60" y="938" width="310" height="20" as="geometry" />
    </mxCell>
    <mxCell id="gap_p1" value="1. Stripe secret key not configured → Upgrade button fails silently&lt;br/&gt;2. stripe_price_id empty on all plans → checkout returns 400&lt;br/&gt;3. SES_FROM_EMAIL not set → invite/trial emails fail silently&lt;br/&gt;4. UAT-01..05 (invite flow) not executed" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=10;fontColor=#dc2626;" vertex="1" parent="1">
      <mxGeometry x="60" y="962" width="310" height="80" as="geometry" />
    </mxCell>

    <mxCell id="gap_p2_title" value="P1 — UX GAPS (user-visible missing features)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=11;fontStyle=1;fontColor=#ca8a04;" vertex="1" parent="1">
      <mxGeometry x="400" y="938" width="360" height="20" as="geometry" />
    </mxCell>
    <mxCell id="gap_p2" value="1. Plan options: tier badge tiny, no feature list (accounts/scans per plan)&lt;br/&gt;2. CurrentPlanCard: renewal date always &quot;—&quot; (period_end null in DB)&lt;br/&gt;3. CurrentPlanCard: price shows &quot;Free&quot; even for paid plans (amount null)&lt;br/&gt;4. plan display_name not shown (only raw tier code badge)&lt;br/&gt;5. max_accounts not populated in plan limits → usage meter misleading&lt;br/&gt;6. No &quot;Manage payment method&quot; link" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=10;fontColor=#ca8a04;" vertex="1" parent="1">
      <mxGeometry x="400" y="962" width="360" height="100" as="geometry" />
    </mxCell>

    <mxCell id="gap_p3_title" value="P2 — UNTESTED UAT SCENARIOS" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=11;fontStyle=1;fontColor=#7c3aed;" vertex="1" parent="1">
      <mxGeometry x="790" y="938" width="310" height="20" as="geometry" />
    </mxCell>
    <mxCell id="gap_p3" value="UAT-01: Invite email delivered with correct content&lt;br/&gt;UAT-02: Group badge on invite accept page&lt;br/&gt;UAT-03: Existing user — no duplicate account&lt;br/&gt;UAT-04: Duplicate invite — stale token fails&lt;br/&gt;UAT-05: Expired invite shows error state&lt;br/&gt;UAT-07: T-3 day warning email&lt;br/&gt;UAT-08: Expiry notice sent exactly once&lt;br/&gt;UAT-09: Free plan → paywall on Pro engine&lt;br/&gt;UAT-12: Stripe checkout clears paywall&lt;br/&gt;UAT-13: scan_freq=0 → 402 on scan trigger" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=10;fontColor=#7c3aed;" vertex="1" parent="1">
      <mxGeometry x="790" y="962" width="310" height="148" as="geometry" />
    </mxCell>

    <mxCell id="gap_p4_title" value="✅ VERIFIED THIS SESSION" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=11;fontStyle=1;fontColor=#16a34a;" vertex="1" parent="1">
      <mxGeometry x="1130" y="938" width="260" height="20" as="geometry" />
    </mxCell>
    <mxCell id="gap_p4" value="✅ Login (SSL, SSO link, password mode)&lt;br/&gt;✅ Header (real user, logout, tenant switch)&lt;br/&gt;✅ Billing page loads with subscription data&lt;br/&gt;✅ Free plan shown — Active status&lt;br/&gt;✅ Plan options (4 tiers with prices)&lt;br/&gt;✅ Usage meters (accounts 0/1)&lt;br/&gt;✅ Trial chip hidden for platform_admin&lt;br/&gt;✅ Logout → login, no redirect loop&lt;br/&gt;✅ Playwright E2E: 11/11 pass" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=10;fontColor=#16a34a;" vertex="1" parent="1">
      <mxGeometry x="1130" y="962" width="260" height="140" as="geometry" />
    </mxCell>

    <!-- ═══════════════════════════════════════════════════════════════════════ -->
    <!-- ARROWS: data flow -->
