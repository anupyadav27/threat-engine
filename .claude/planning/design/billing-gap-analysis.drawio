    </mxCell>

    <!-- Invite flow -->
    <mxCell id="hdr_invite" value="&lt;b&gt;Invite Flow (/auth/invite/[token])&lt;/b&gt; ⚠️&lt;br/&gt;• invite page renders token context ✅&lt;br/&gt;• expired token shows error state ✅&lt;br/&gt;• group badge shown when group_id set ⚠️&lt;br/&gt;&lt;font color=&quot;#ca8a04&quot;&gt;⚠ NOT UAT tested yet&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#dc2626&quot;&gt;❌ invite emails: SES not verified in sandbox&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#dc2626&quot;&gt;❌ UAT-01..05 not executed&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef9c3;strokeColor=#ca8a04;align=left;fontSize=10;spacingLeft=8;verticalAlign=top;" vertex="1" parent="1">
