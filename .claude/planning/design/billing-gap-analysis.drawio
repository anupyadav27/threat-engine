    <!-- BFF billing view -->
    <mxCell id="bff_view" value="&lt;b&gt;BFF: GET /api/v1/views/billing&lt;/b&gt; ⚠️ 🔧&lt;br/&gt;• aggregates: subscription + usage + plans + invoices ✅&lt;br/&gt;• parallel fetch (fetch_many) ✅&lt;br/&gt;• trial_end normalised to trial_end_at ✅&lt;br/&gt;• trial_days_remaining computed if missing ✅&lt;br/&gt;&lt;font color=&quot;#7c3aed&quot;&gt;🔧 Fixed: org_id=&quot;&quot; for platform_admin (was sending empty string)&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#ca8a04&quot;&gt;⚠ platform_admin in &quot;All Tenants&quot; gets empty org_id → sub data blank&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#dc2626&quot;&gt;❌ subscription lacks amount/currency/period fields&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef9c3;strokeColor=#ca8a04;align=left;fontSize=10;spacingLeft=8;verticalAlign=top;" vertex="1" parent="1">
      <mxGeometry x="760" y="140" width="320" height="130" as="geometry" />
    </mxCell>

    <!-- BFF trial-status -->
    <mxCell id="bff_trial" value="&lt;b&gt;BFF: GET /api/v1/billing/trial-status&lt;/b&gt; ✅&lt;br/&gt;• returns {applicable, status, trial_end_at, days_remaining, tier} ✅&lt;br/&gt;• platform_admin → applicable=false (no chip) ✅&lt;br/&gt;• 60s TTL in-process cache ✅" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;align=left;fontSize=10;spacingLeft=8;verticalAlign=top;" vertex="1" parent="1">
      <mxGeometry x="760" y="282" width="320" height="80" as="geometry" />
    </mxCell>

    <!-- Gateway proxy checkout -->
    <mxCell id="bff_checkout" value="&lt;b&gt;Gateway: POST /api/v1/billing/checkout&lt;/b&gt; ⚠️&lt;br/&gt;• billing engine checkout router exists ✅&lt;br/&gt;• gateway routes /api/v1/billing/* to billing engine ✅&lt;br/&gt;&lt;font color=&quot;#dc2626&quot;&gt;❌ stripe_price_id empty on all plans → checkout fails&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#dc2626&quot;&gt;❌ STRIPE_SECRET_KEY env var not set on billing pod&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#dc2626&quot;&gt;❌ UAT-12 (Stripe checkout flow) not tested&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef9c3;strokeColor=#ca8a04;align=left;fontSize=10;spacingLeft=8;verticalAlign=top;" vertex="1" parent="1">
      <mxGeometry x="760" y="374" width="320" height="110" as="geometry" />
    </mxCell>

    <!-- Subscription middleware -->
    <mxCell id="bff_sub_mw" value="&lt;b&gt;SubscriptionMiddleware (scan gate)&lt;/b&gt; ⚠️&lt;br/&gt;• blocks suspended orgs with 402 ✅&lt;br/&gt;• engine allowlist enforcement ✅&lt;br/&gt;• scan_freq=0 short-circuit 402 ✅ (BILL-S03)&lt;br/&gt;• inject X-Subscription-Context header ✅&lt;br/&gt;• platform_admin → enterprise stub (unrestricted) ✅&lt;br/&gt;&lt;font color=&quot;#ca8a04&quot;&gt;⚠ 402 → paywall redirect: relies on frontend fetch interceptor&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#dc2626&quot;&gt;❌ fetch interceptor (BILL-S04) — not UAT tested end-to-end&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef9c3;strokeColor=#ca8a04;align=left;fontSize=10;spacingLeft=8;verticalAlign=top;" vertex="1" parent="1">
      <mxGeometry x="760" y="496" width="320" height="130" as="geometry" />
    </mxCell>

    <!-- Internal auth secret -->
    <mxCell id="bff_secret" value="&lt;b&gt;Internal Service Auth Secret (BILL-S11)&lt;/b&gt; ✅&lt;br/&gt;• X-Internal-Secret header on Celery→Billing calls ✅&lt;br/&gt;• BILLING_INTERNAL_SECRET in threat-engine-secrets ✅&lt;br/&gt;• billing engine validates secret on /trial/provision ✅" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;align=left;fontSize=10;spacingLeft=8;verticalAlign=top;" vertex="1" parent="1">
