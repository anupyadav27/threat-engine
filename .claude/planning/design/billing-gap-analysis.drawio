    <!-- Header real user -->
    <mxCell id="hdr_user" value="&lt;b&gt;Header — Real User Display&lt;/b&gt; ✅ 🔧&lt;br/&gt;• avatar initials from real auth (not hardcoded) ✅&lt;br/&gt;• display name from user.name or email ✅&lt;br/&gt;• logout calls logout() + clears cookie ✅&lt;br/&gt;&lt;font color=&quot;#7c3aed&quot;&gt;🔧 Fixed: was hardcoded &quot;Anup Yadav / AY&quot;&lt;/font&gt;&lt;br/&gt;&lt;font color=&quot;#7c3aed&quot;&gt;🔧 Fixed: logout loop (cookie not cleared)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f3e8ff;strokeColor=#7c3aed;align=left;fontSize=10;spacingLeft=8;verticalAlign=top;" vertex="1" parent="1">
