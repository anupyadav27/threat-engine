version: '1.0'
provider: azure
service: dataprotection
services:
  client: dataprotection
discovery:
- discovery_id: azure.dataprotection.list
  calls:
  - action: list
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.dataprotection.list
  calls:
  - action: list
    save_as: response
