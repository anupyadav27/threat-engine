version: '1.0'
provider: azure
service: cosmosdb
services:
  client: cosmosdb
  module: azure.mgmt.cosmosdb
discovery:
- discovery_id: azure.cosmosdb.databaseaccounts.list_by_resource_group
  calls:
  - action: list_by_resource_group
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.cosmosdb.restorabledatabaseaccounts.list_by_location
  calls:
  - action: list_by_location
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.cosmosdb.restorabledatabaseaccounts.list_by_location
  calls:
  - action: list_by_location
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.cosmosdb.cassandraclusters.list_by_resource_group
  calls:
  - action: list_by_resource_group
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.cosmosdb.fleet.list
  calls:
  - action: list
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.cosmosdb.locations.list
  calls:
  - action: list
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.cosmosdb.cassandradatacenters.list
  calls:
  - action: list
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
checks: []
