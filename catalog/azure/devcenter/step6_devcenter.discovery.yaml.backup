version: '1.0'
provider: azure
service: devcenter
services:
  client: devcenter
discovery:
- discovery_id: azure.devcenter.list_by_dev_center
  calls:
  - action: list_by_dev_center
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.devcenter.list_by_project
  calls:
  - action: list_by_project
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.devcenter.list_by_dev_center
  calls:
  - action: list_by_dev_center
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.devcenter.list_by_dev_center
  calls:
  - action: list_by_dev_center
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.devcenter.list_by_project
  calls:
  - action: list_by_project
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
checks: []
