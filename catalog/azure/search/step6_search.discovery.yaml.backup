version: '1.0'
provider: azure
service: search
services:
  client: search
discovery:
- discovery_id: azure.search.list_by_service
  calls:
  - action: list_by_service
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.search.list
  calls:
  - action: list
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.search.list_by_service
  calls:
  - action: list_by_service
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.search.list_supported
  calls:
  - action: list_supported
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.search.list_by_search_service
  calls:
  - action: list_by_search_service
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
checks: []
