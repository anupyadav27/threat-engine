version: '1.0'
provider: azure
service: storagemover
services:
  client: storagemover
discovery:
- discovery_id: azure.storagemover.list
  calls:
  - action: list
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.storagemover.list
  calls:
  - action: list
    save_as: response
    on_error: continue
