version: '1.0'
provider: azure
service: rdbms_mysql_flexibleservers
services:
  client: rdbms_mysql_flexibleservers
discovery:
- discovery_id: azure.rdbms_mysql_flexibleservers.list_by_server
  calls:
  - action: list_by_server
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.rdbms_mysql_flexibleservers.list_by_server
  calls:
  - action: list_by_server
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.rdbms_mysql_flexibleservers.list_by_server
  calls:
  - action: list_by_server
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.rdbms_mysql_flexibleservers.list_by_server
  calls:
  - action: list_by_server
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.rdbms_mysql_flexibleservers.list
  calls:
  - action: list
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
checks: []
