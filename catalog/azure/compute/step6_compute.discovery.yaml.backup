version: '1.0'
provider: azure
service: compute
services:
  client: compute
  module: azure.mgmt.compute
discovery:
- discovery_id: azure.compute.virtualmachines.list
  calls:
  - action: list
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
