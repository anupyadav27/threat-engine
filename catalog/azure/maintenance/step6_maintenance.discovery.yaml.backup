version: '1.0'
provider: azure
service: maintenance
services:
  client: maintenance
discovery:
- discovery_id: azure.maintenance.list
  calls:
  - action: list
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
