version: '1.0'
provider: azure
service: billing
services:
  client: billing
discovery:
- discovery_id: azure.billing.list_by_billing_account
  calls:
  - action: list_by_billing_account
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.billing.list_by_billing_account
  calls:
  - action: list_by_billing_account
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.billing.list
  calls:
  - action: list
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.billing.list_invoice_sections_by_create_subscription_permission
  calls:
  - action: list_invoice_sections_by_create_subscription_permission
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.billing.list_by_billing_account
  calls:
  - action: list_by_billing_account
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
checks: []
