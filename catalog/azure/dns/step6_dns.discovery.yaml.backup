version: '1.0'
provider: azure
service: dns
services:
  client: dns
discovery:
- discovery_id: azure.dns.list_all_by_dns_zone
  calls:
  - action: list_all_by_dns_zone
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.dns.list_by_dns_zone
  calls:
  - action: list_by_dns_zone
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.dns.list
  calls:
  - action: list
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.dns.list_by_resource_group
  calls:
  - action: list_by_resource_group
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.dns.list_all_by_dns_zone
  calls:
  - action: list_all_by_dns_zone
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
checks: []
