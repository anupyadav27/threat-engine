version: '1.0'
provider: azure
service: streamanalytics
services:
  client: streamanalytics
discovery:
- discovery_id: azure.streamanalytics.list_by_resource_group
  calls:
  - action: list_by_resource_group
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.streamanalytics.list_by_subscription
  calls:
  - action: list_by_subscription
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.streamanalytics.list_streaming_jobs
  calls:
  - action: list_streaming_jobs
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.streamanalytics.list_by_streaming_job
  calls:
  - action: list_by_streaming_job
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.streamanalytics.list_by_streaming_job
  calls:
  - action: list_by_streaming_job
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
checks: []
