version: '1.0'
provider: azure
service: costmanagement
services:
  client: costmanagement
discovery:
- discovery_id: azure.costmanagement.list
  calls:
  - action: list
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.costmanagement.list
  calls:
  - action: list
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.costmanagement.list_by_billing_account_id
  calls:
  - action: list_by_billing_account_id
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.costmanagement.list_by_savings_plan_order
  calls:
  - action: list_by_savings_plan_order
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.costmanagement.list
  calls:
  - action: list
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
checks: []
