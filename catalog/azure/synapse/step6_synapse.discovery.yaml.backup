version: '1.0'
provider: azure
service: synapse
services:
  client: synapse
discovery:
- discovery_id: azure.synapse.list_by_workspace
  calls:
  - action: list_by_workspace
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
