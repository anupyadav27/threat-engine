version: '1.0'
provider: azure
service: servicenetworking
services:
  client: servicenetworking
discovery:
- discovery_id: azure.servicenetworking.list_by_traffic_controller
  calls:
  - action: list_by_traffic_controller
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.servicenetworking.list_by_traffic_controller
  calls:
  - action: list_by_traffic_controller
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.servicenetworking.list
  calls:
  - action: list
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.servicenetworking.list_by_traffic_controller
  calls:
  - action: list_by_traffic_controller
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.servicenetworking.list_by_resource_group
  calls:
  - action: list_by_resource_group
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
checks: []
