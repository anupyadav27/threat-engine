version: '1.0'
provider: azure
service: redisenterprise
services:
  client: redisenterprise
  module: azure.mgmt.redisenterprise
discovery:
- discovery_id: azure.redisenterprise.redisenterprise.list
  calls:
  - action: list
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.redisenterprise.redisenterprise.list_by_resource_group
  calls:
  - action: list_by_resource_group
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.redisenterprise.accesspolicyassignment.list
  calls:
  - action: list
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
checks: []
