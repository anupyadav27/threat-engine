version: '1.0'
provider: azure
service: managedservices
services:
  client: managedservices
discovery:
- discovery_id: azure.managedservices.list
  calls:
  - action: list
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.managedservices.list
  calls:
  - action: list
    save_as: response
    on_error: continue
