version: '1.0'
provider: azure
service: edgeorder
services:
  client: edgeorder
discovery:
- discovery_id: azure.edgeorder.list_addresses_at_resource_group_level
  calls:
  - action: list_addresses_at_resource_group_level
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.edgeorder.list_addresses_at_subscription_level
  calls:
  - action: list_addresses_at_subscription_level
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.edgeorder.list_configurations
  calls:
  - action: list_configurations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.edgeorder.list_operations
  calls:
  - action: list_operations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.edgeorder.list_order_at_resource_group_level
  calls:
  - action: list_order_at_resource_group_level
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
checks: []
