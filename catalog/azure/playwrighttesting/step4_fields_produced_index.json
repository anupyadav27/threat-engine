{
  "service": "playwrighttesting",
  "seed_from_list": [
    "Enabled",
    "Status",
    "action_type",
    "display",
    "is_data_action",
    "name",
    "origin",
    "properties"
  ],
  "enriched_from_get_describe": [],
  "final_union": [
    "Enabled",
    "Status",
    "action_type",
    "display",
    "is_data_action",
    "name",
    "origin",
    "properties"
  ],
  "source": {
    "operation_registry": "services/playwrighttesting/operation_registry.json",
    "read_ops_rule": "kind is read_list (seed) or read_get (enriched)",
    "excluded_keys": [
      "next_link",
      "nextLink",
      "continuation_token",
      "value",
      "skip_token",
      "max_results",
      "top",
      "skip"
    ]
  },
  "fields": {
    "Enabled": {
      "operators": [
        "equals",
        "not_equals"
      ],
      "dependency_index_entity": "playwrighttesting.item_properties",
      "type": "boolean"
    },
    "Status": {
      "operators": [
        "equals",
        "not_equals",
        "in"
      ],
      "dependency_index_entity": "playwrighttesting.item_properties",
      "type": "string"
    }
  }
}