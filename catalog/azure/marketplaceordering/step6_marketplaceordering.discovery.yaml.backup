version: '1.0'
provider: azure
service: marketplaceordering
services:
  client: marketplaceordering
discovery:
- discovery_id: azure.marketplaceordering.list
  calls:
  - action: list
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
