{
  "metadata": {
    "annotations": {
      "cspm": {
        "k8s": {
          "io/configuration-change-audit-enabled": true,
          "io/roles-no-wildcard-in-rules": "example-value"
        }
      }
    }
  },
  "rules": {
    "verbs": [
      "get",
      "list"
    ],
    "apiGroups": "example-value",
    "resources": [
      "pods",
      "services"
    ]
  }
}