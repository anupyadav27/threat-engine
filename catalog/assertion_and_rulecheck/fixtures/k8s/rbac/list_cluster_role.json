{
  "automountServiceAccountToken": false,
  "metadata": {
    "annotations": {
      "cspm": {
        "k8s": {
          "io": {
            "configuration-change-audit-enabled": true
          },
          "io/change-control-role-defined": "example-value",
          "io/change-management-policy-configured": "example-value",
          "io/change-management-roles-defined": "example-value",
          "io/clusterrolebinding-admin-bindings-audited-enforced": "example-value",
          "io/configuration-change-audit-enabled": true,
          "io/configuration-change-monitoring": "example-value",
          "io/default-service-account-audit": "example-value",
          "io/incident-response-team-access-configured": "example-value",
          "io/serviceaccount-token-expiration-configured": "example-value"
        }
      }
    },
    "name": "example-name"
  },
  "rules": {
    "resources": [
      "pods",
      "services"
    ],
    "verbs": [
      "get",
      "list"
    ]
  }
}