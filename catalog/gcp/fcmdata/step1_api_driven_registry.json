  "operations": {
    "gcp.fcmdata.projects.androidApps.deliveryData.list": {
      "op": "gcp.fcmdata.projects.androidApps.deliveryData.list",
      "service": "fcmdata",
      "kind": "read_list",
      "http": {
        "verb": "GET",
        "path": "/v1beta1/{+parent}/deliveryData"
      },
      "python_call": "svc.projects().androidApps().deliveryData().list(**params).execute()",
      "description": "List aggregate delivery data for the given Android application.",
      "inputs": {
        "required": [
          {
            "param": "parent",
            "type": "string",
            "location": "path",
            "template": "{parent}",
            "slots": [
              {
                "slot": "parent",
                "source": "always_available",
                "after_segment": ""
              }
            ],
            "pattern": "^projects/[^/]+/androidApps/[^/]+$",
            "description": "Required. The application for which to list delivery data. Format: `projects/{project_id}/androidApps/{app_id}`"
          }
        ],
        "optional": [
          "pageToken",
          "pageSize"
        ]
      },
      "outputs": {
        "response_schema": "GoogleFirebaseFcmDataV1beta1ListAndroidDeliveryDataResponse",
        "list_field": "androidDeliveryData",
        "id_field": "analyticsLabel",
        "id_is_full_resource_name": false,
        "produces_fields": [
          {
            "path": "androidDeliveryData[].analyticsLabel",
            "type": "string",
            "is_id": true,
            "note": "resource identity \u2014 use as name/parent param for .get()"
          },
          {
            "path": "androidDeliveryData[].date",
