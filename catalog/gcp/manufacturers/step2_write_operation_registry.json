                "source": "always_available",
                "after_segment": "accounts"
              },
              {
                "slot": "languageId",
                "source": "from_list_op",
                "after_segment": "languages"
              },
              {
                "slot": "productCertificationId",
                "source": "from_list_op",
                "after_segment": "productCertifications"
              }
            ],
            "pattern": "^accounts/[^/]+/languages/[^/]+/productCertifications/[^/]+$",
            "description": "Required. The unique name identifier of a product certification Format: accounts/{account}/languages/{language_code}/pro"
          }
        ],
        "optional": [
          "updateMask"
        ]
      },
      "outputs": {
