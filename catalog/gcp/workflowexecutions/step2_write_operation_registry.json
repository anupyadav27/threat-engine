{
  "service": "workflowexecutions",
  "version": "v1",
  "csp": "gcp",
  "title": "Workflow Executions API",
  "base_url": "https://workflowexecutions.googleapis.com/",
  "total_operations": 1,
  "operations": {
    "gcp.workflowexecutions.projects.locations.workflows.executions.create": {
      "op": "gcp.workflowexecutions.projects.locations.workflows.executions.create",
      "service": "workflowexecutions",
      "kind": "write_create",
      "http": {
        "verb": "POST",
        "path": "/v1/{+parent}/executions"
      },
      "python_call": "svc.projects().locations().workflows().executions().create(**params).execute()",
      "description": "Creates a new execution using the latest revision of the given workflow. For more information, see Execute a workflow.",
      "inputs": {
        "required": [
          {
            "param": "parent",
            "type": "string",
            "location": "path",
            "template": "{parent}",
            "slots": [
              {
                "slot": "parent",
                "source": "always_available",
                "after_segment": ""
              }
            ],
            "pattern": "^projects/[^/]+/locations/[^/]+/workflows/[^/]+$",
            "description": "Required. Name of the workflow for which an execution should be created. Format: projects/{project}/locations/{location}"
          }
        ],
        "optional": []
      },
      "outputs": {
        "response_schema": "Execution",
        "list_field": null,
        "id_field": null,
        "id_is_full_resource_name": false,
        "produces_fields": []
      },
      "independent": true,
      "dependency_hints": [
        {
          "param": "parent",
          "can_come_from": [
            {
              "kind": "always_available",
              "param": "parent"
            }
          ]
        }
      ],
      "scopes": [
        "https://www.googleapis.com/auth/cloud-platform"
      ],
      "paginated": false
    }
  }
}