      "op": "gcp.versionhistory.platforms.list",
      "service": "versionhistory",
      "kind": "read_list",
      "http": {
        "verb": "GET",
        "path": "/v1/{+parent}/platforms"
      },
      "python_call": "svc.platforms().list(**params).execute()",
      "description": "Returns list of platforms that are available for a given product. The resource \"product\" has no resource name in its name.",
      "inputs": {
        "required": [
          {
            "param": "parent",
            "type": "string",
            "location": "path",
            "template": "{parent}",
            "slots": [
              {
                "slot": "parent",
                "source": "always_available",
                "after_segment": ""
              }
            ],
            "pattern": "^[^/]+$",
            "description": "Required. The product, which owns this collection of platforms. Format: {product}"
          }
        ],
        "optional": [
          "pageSize",
          "pageToken"
        ]
      },
      "outputs": {
        "response_schema": "ListPlatformsResponse",
        "list_field": "platforms",
        "id_field": "name",
        "id_is_full_resource_name": true,
        "produces_fields": [
          {
            "path": "platforms[].name",
            "type": "string",
            "is_id": true,
            "note": "resource identity \u2014 use as name/parent param for .get()"
          },
          {
            "path": "platforms[].platformType",
            "type": "string",
            "is_id": false
          }
