{
  "service": "paymentsresellersubscription",
  "version": "v1",
  "csp": "gcp",
  "title": "Payments Reseller Subscription API",
  "base_url": "https://paymentsresellersubscription.googleapis.com/",
  "total_operations": 2,
  "operations": {
    "gcp.paymentsresellersubscription.partners.subscriptions.create": {
      "op": "gcp.paymentsresellersubscription.partners.subscriptions.create",
      "service": "paymentsresellersubscription",
      "kind": "write_create",
      "http": {
        "verb": "POST",
        "path": "/v1/{+parent}/subscriptions"
      },
      "python_call": "svc.partners().subscriptions().create(**params).execute()",
      "description": "Used by partners to create a subscription for their customers. The created subscription is associated with the end user inferred from the end user credentials. This API must be authorized by the end u",
      "inputs": {
        "required": [
          {
            "param": "parent",
            "type": "string",
            "location": "path",
            "template": "{parent}",
            "slots": [
              {
                "slot": "parent",
                "source": "always_available",
                "after_segment": ""
              }
            ],
            "pattern": "^partners/[^/]+$",
            "description": "Required. The parent resource name, which is the identifier of the partner. It will have the format of \"partners/{partne"
          }
        ],
        "optional": [
          "subscriptionId"
        ]
      },
      "outputs": {
        "response_schema": "Subscription",
        "list_field": null,
        "id_field": null,
        "id_is_full_resource_name": false,
        "produces_fields": []
      },
      "independent": true,
      "dependency_hints": [
        {
          "param": "parent",
          "can_come_from": [
            {
              "kind": "always_available",
              "param": "parent"
            }
          ]
        }
      ],
      "scopes": [
        "https://www.googleapis.com/auth/sdm.service"
      ],
      "paginated": false
    },
    "gcp.paymentsresellersubscription.partners.subscriptions.lineItems.patch": {
      "op": "gcp.paymentsresellersubscription.partners.subscriptions.lineItems.patch",
      "service": "paymentsresellersubscription",
      "kind": "write_update",
      "http": {
        "verb": "PATCH",
        "path": "/v1/{+name}"
      },
      "python_call": "svc.partners().subscriptions().lineItems().patch(**params).execute()",
      "description": "Updates a line item of a subscription. It should be authenticated with a service account.",
      "inputs": {
        "required": [
          {
            "param": "name",
            "type": "string",
            "location": "path",
            "template": "partners/{partnerId}/subscriptions/{subscriptionId}/lineItems/{lineItemId}",
            "slots": [
              {
                "slot": "partnerId",
                "source": "from_list_op",
                "after_segment": "partners"
              },
              {
                "slot": "subscriptionId",
                "source": "from_list_op",
                "after_segment": "subscriptions"
              },
              {
                "slot": "lineItemId",
                "source": "from_list_op",
                "after_segment": "lineItems"
              }
            ],
            "pattern": "^partners/[^/]+/subscriptions/[^/]+/lineItems/[^/]+$",
            "description": "Identifier. Resource name of the line item. Format: partners/{partner}/subscriptions/{subscription}/lineItems/{lineItem}"
          }
        ],
        "optional": [
          "updateMask"
        ]
      },
      "outputs": {
        "response_schema": "SubscriptionLineItem",
        "list_field": null,
        "id_field": null,
        "id_is_full_resource_name": false,
        "produces_fields": []
      },
      "independent": false,
      "dependency_hints": [
        {
          "param": "name",
          "can_come_from": [
            {
              "kind": "known_format",
              "template": "partners/{partnerId}/subscriptions/{subscriptionId}/lineItems/{lineItemId}",
              "slots": [
                {
                  "slot": "partnerId",
                  "source": "from_list_op",
                  "after_segment": "partners"
                },
                {
                  "slot": "subscriptionId",
                  "source": "from_list_op",
                  "after_segment": "subscriptions"
                },
                {
                  "slot": "lineItemId",
                  "source": "from_list_op",
                  "after_segment": "lineItems"
                }
              ]
            },
            {
              "kind": "external_input",
              "slot": "partnerId",
              "after_segment": "partners",
              "note": "No list op found for {partnerId} \u2014 supply externally"
            },
            {
              "kind": "from_list_op",
              "op": "gcp.paymentsresellersubscription.partners.products.list",
              "match_tier": 3,
              "match_confidence": "field_match",
              "list_field": "products",
              "id_field": "name",
              "produces_slot": "subscriptionId",
              "note": "[tier 3/field_match] call gcp.paymentsresellersubscription.partners.products.list, iterate response[\"products\"][], extract item[\"name\"] \u2192 fill {subscriptionId}"
            },
            {
              "kind": "external_input",
              "slot": "lineItemId",
              "after_segment": "lineItems",
              "note": "No list op found for {lineItemId} \u2014 supply externally"
            }
          ]
        }
      ],
      "scopes": [
        "https://www.googleapis.com/auth/sdm.service"
      ],
      "paginated": false
    }
  }
}