    "gcp.chromewebstore.publishers.items.publish": {
      "op": "gcp.chromewebstore.publishers.items.publish",
      "service": "chromewebstore",
      "kind": "other",
      "http": {
        "verb": "POST",
        "path": "/v2/{+name}:publish"
      },
      "python_call": "svc.publishers().items().publish(**params).execute()",
      "description": "Submit the item to be published in the store. The item will be submitted for review unless `skip_review` is set to true, or the item is staged from a previous submission with `publish_type` set to `ST",
      "inputs": {
        "required": [
          {
            "param": "name",
            "type": "string",
            "location": "path",
            "template": "publishers/{publisherId}/items/{itemId}",
            "slots": [
              {
                "slot": "publisherId",
                "source": "from_list_op",
                "after_segment": "publishers"
              },
              {
                "slot": "itemId",
                "source": "from_list_op",
                "after_segment": "items"
              }
            ],
            "pattern": "^publishers/[^/]+/items/[^/]+$",
            "description": "Required. Name of the item in the form `publishers/{publisherId}/items/{itemId}`"
          }
        ],
        "optional": []
      },
      "outputs": {
        "response_schema": "PublishItemResponse",
