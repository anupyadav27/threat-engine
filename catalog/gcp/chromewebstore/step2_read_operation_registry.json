              "slots": [
                {
                  "slot": "publisherId",
                  "source": "from_list_op",
                  "after_segment": "publishers"
                },
                {
                  "slot": "itemId",
                  "source": "from_list_op",
                  "after_segment": "items"
                }
              ]
            },
            {
              "kind": "external_input",
              "slot": "publisherId",
              "after_segment": "publishers",
              "note": "No list op found for {publisherId} \u2014 supply externally"
