    "gcp.adsenseplatform.platforms.accounts.list": {
      "op": "gcp.adsenseplatform.platforms.accounts.list",
      "service": "adsenseplatform",
      "kind": "read_list",
      "http": {
        "verb": "GET",
        "path": "/v1/{+parent}/accounts"
      },
      "python_call": "svc.platforms().accounts().list(**params).execute()",
      "description": "Lists a partial view of sub-accounts for a specific parent account.",
      "inputs": {
        "required": [
          {
            "param": "parent",
            "type": "string",
            "location": "path",
            "template": "{parent}",
            "slots": [
              {
                "slot": "parent",
                "source": "always_available",
                "after_segment": ""
              }
            ],
            "pattern": "^platforms/[^/]+$",
            "description": "Required. Platform who parents the accounts. Format: platforms/{platform}"
          }
        ],
        "optional": [
          "pageSize",
          "pageToken"
        ]
      },
      "outputs": {
        "response_schema": "ListAccountsResponse",
        "list_field": "accounts",
        "id_field": "name",
        "id_is_full_resource_name": true,
        "produces_fields": [
          {
            "path": "accounts[].name",
            "type": "string",
            "is_id": true,
            "note": "resource identity \u2014 use as name/parent param for .get()"
          },
          {
            "path": "accounts[].regionCode",
            "type": "string",
            "is_id": false
          },
          {
            "path": "accounts[].creationRequestId",
            "type": "string",
            "is_id": false
          },
          {
            "path": "accounts[].createTime",
            "type": "string",
            "is_id": false
          },
          {
            "path": "accounts[].timeZone",
            "type": "string",
            "is_id": false
          },
          {
            "path": "accounts[].state",
            "type": "string",
            "is_id": false
          },
          {
            "path": "accounts[].displayName",
            "type": "string",
            "is_id": false
          }
        ]
      },
      "independent": true,
      "dependency_hints": [
        {
          "param": "parent",
          "can_come_from": [
            {
              "kind": "always_available",
              "param": "parent"
            }
          ]
        }
      ],
      "scopes": [
        "https://www.googleapis.com/auth/adsense",
        "https://www.googleapis.com/auth/adsense.readonly"
      ],
      "paginated": true
    },
