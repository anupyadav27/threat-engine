    "gcp.businessprofileperformance.locations.getDailyMetricsTimeSeries": {
      "op": "gcp.businessprofileperformance.locations.getDailyMetricsTimeSeries",
      "service": "businessprofileperformance",
      "kind": "read_get",
      "http": {
        "verb": "GET",
        "path": "/v1/{+name}:getDailyMetricsTimeSeries"
      },
      "python_call": "svc.locations().getDailyMetricsTimeSeries(**params).execute()",
      "description": " Returns the values for each date from a given time range that are associated with the specific daily metric. Example request: `GET https://businessprofileperformance.googleapis.com/v1/locations/12345",
      "inputs": {
        "required": [
          {
            "param": "name",
            "type": "string",
            "location": "path",
            "template": "locations/{location}",
            "slots": [
              {
                "slot": "location",
                "source": "always_available",
                "after_segment": "locations"
              }
            ],
            "pattern": "^locations/[^/]+$",
            "description": "Required. The location for which the time series should be fetched. Format: locations/{location_id} where location_id is"
          }
        ],
        "optional": [
          "dailyMetric",
          "dailyRange.startDate.year",
          "dailyRange.startDate.month",
          "dailyRange.startDate.day",
          "dailyRange.endDate.year",
          "dailyRange.endDate.month",
          "dailyRange.endDate.day",
          "dailySubEntityType.dayOfWeek",
          "dailySubEntityType.timeOfDay.hours",
          "dailySubEntityType.timeOfDay.minutes",
          "dailySubEntityType.timeOfDay.seconds",
          "dailySubEntityType.timeOfDay.nanos"
        ]
      },
      "outputs": {
        "response_schema": "GetDailyMetricsTimeSeriesResponse",
        "list_field": null,
        "id_field": null,
        "id_is_full_resource_name": false,
        "produces_fields": [
          {
            "path": "timeSeries",
            "type": "string",
            "is_id": false
          }
        ]
      },
      "independent": true,
      "dependency_hints": [
        {
          "param": "name",
          "can_come_from": [
            {
              "kind": "known_format",
              "template": "locations/{location}",
              "slots": [
                {
                  "slot": "location",
                  "source": "always_available",
                  "after_segment": "locations"
                }
              ]
            }
          ]
        }
      ],
      "scopes": [],
      "paginated": false
    },
