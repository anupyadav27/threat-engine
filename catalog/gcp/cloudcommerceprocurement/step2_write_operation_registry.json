{
  "service": "cloudcommerceprocurement",
  "version": "v1",
  "csp": "gcp",
  "title": "Cloud Commerce Partner Procurement API",
  "base_url": "https://cloudcommerceprocurement.googleapis.com/",
  "total_operations": 1,
  "operations": {
    "gcp.cloudcommerceprocurement.providers.entitlements.patch": {
      "op": "gcp.cloudcommerceprocurement.providers.entitlements.patch",
      "service": "cloudcommerceprocurement",
      "kind": "write_update",
      "http": {
        "verb": "PATCH",
        "path": "/v1/{+name}"
      },
      "python_call": "svc.providers().entitlements().patch(**params).execute()",
      "description": "Updates an existing Entitlement.",
      "inputs": {
        "required": [
          {
            "param": "name",
            "type": "string",
            "location": "path",
            "template": "providers/{providerId}/entitlements/{entitlementId}",
            "slots": [
              {
                "slot": "providerId",
                "source": "from_list_op",
                "after_segment": "providers"
              },
              {
                "slot": "entitlementId",
                "source": "from_list_op",
                "after_segment": "entitlements"
              }
            ],
            "pattern": "^providers/[^/]+/entitlements/[^/]+$",
            "description": "Required. The name of the entitlement to update."
          }
        ],
        "optional": [
          "updateMask"
        ]
      },
      "outputs": {
        "response_schema": "Entitlement",
        "list_field": null,
        "id_field": null,
        "id_is_full_resource_name": false,
        "produces_fields": []
      },
      "independent": false,
      "dependency_hints": [
        {
          "param": "name",
          "can_come_from": [
            {
              "kind": "known_format",
              "template": "providers/{providerId}/entitlements/{entitlementId}",
              "slots": [
                {
                  "slot": "providerId",
                  "source": "from_list_op",
                  "after_segment": "providers"
                },
                {
                  "slot": "entitlementId",
                  "source": "from_list_op",
                  "after_segment": "entitlements"
                }
              ]
            },
            {
              "kind": "from_list_op",
              "op": "gcp.cloudcommerceprocurement.providers.accounts.list",
              "match_tier": 3,
              "match_confidence": "field_match",
              "list_field": "accounts",
              "id_field": "name",
              "produces_slot": "providerId",
              "note": "[tier 3/field_match] call gcp.cloudcommerceprocurement.providers.accounts.list, iterate response[\"accounts\"][], extract item[\"name\"] \u2192 fill {providerId}"
            },
            {
              "kind": "from_list_op",
              "op": "gcp.cloudcommerceprocurement.providers.entitlements.list",
              "match_tier": 1,
              "match_confidence": "exact",
              "list_field": "entitlements",
              "id_field": "name",
              "produces_slot": "entitlementId",
              "note": "[tier 1/exact] call gcp.cloudcommerceprocurement.providers.entitlements.list, iterate response[\"entitlements\"][], extract item[\"name\"] \u2192 fill {entitlementId}"
            }
          ]
        }
      ],
      "scopes": [
        "https://www.googleapis.com/auth/cloud-platform"
      ],
      "paginated": false
    }
  }
}