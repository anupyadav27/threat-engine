version: '1.0'
provider: aws
service: wellarchitected
services:
  client: wellarchitected
  module: boto3.client
discovery:
- discovery_id: aws.wellarchitected.getGlobalSettings
  calls:
  - action: getGlobalSettings
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.JiraConfiguration }}'
    item:
      IntegrationStatus: '{{ item.IntegrationStatus }}'
      IssueManagementStatus: '{{ item.IssueManagementStatus }}'
      IssueManagementType: '{{ item.IssueManagementType }}'
      Subdomain: '{{ item.Subdomain }}'
      JiraProjectKey: '{{ item.JiraProjectKey }}'
      StatusMessage: '{{ item.StatusMessage }}'
- discovery_id: aws.wellarchitected.getProfileTemplate
  calls:
  - action: getProfileTemplate
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ProfileTemplate }}'
    item:
      TemplateName: '{{ item.TemplateName }}'
      TemplateQuestions: '{{ item.TemplateQuestions }}'
      CreatedAt: '{{ item.CreatedAt }}'
      UpdatedAt: '{{ item.UpdatedAt }}'
- discovery_id: aws.wellarchitected.listLenses
  calls:
  - action: listLenses
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.LensSummaries }}'
    item:
      LensArn: '{{ item.LensArn }}'
      LensAlias: '{{ item.LensAlias }}'
      LensName: '{{ item.LensName }}'
      LensType: '{{ item.LensType }}'
      Description: '{{ item.Description }}'
      CreatedAt: '{{ item.CreatedAt }}'
      UpdatedAt: '{{ item.UpdatedAt }}'
      LensVersion: '{{ item.LensVersion }}'
      Owner: '{{ item.Owner }}'
      LensStatus: '{{ item.LensStatus }}'
- discovery_id: aws.wellarchitected.listNotifications
  calls:
  - action: listNotifications
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.NotificationSummaries }}'
    item:
      Type: '{{ item.Type }}'
      LensUpgradeSummary: '{{ item.LensUpgradeSummary }}'
- discovery_id: aws.wellarchitected.listProfileNotifications
  calls:
  - action: listProfileNotifications
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.NotificationSummaries }}'
    item:
      CurrentProfileVersion: '{{ item.CurrentProfileVersion }}'
      LatestProfileVersion: '{{ item.LatestProfileVersion }}'
      Type: '{{ item.Type }}'
      ProfileArn: '{{ item.ProfileArn }}'
      ProfileName: '{{ item.ProfileName }}'
      WorkloadId: '{{ item.WorkloadId }}'
      WorkloadName: '{{ item.WorkloadName }}'
- discovery_id: aws.wellarchitected.listProfiles
  calls:
  - action: listProfiles
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.ProfileSummaries }}'
    item:
      ProfileArn: '{{ item.ProfileArn }}'
      ProfileVersion: '{{ item.ProfileVersion }}'
      ProfileName: '{{ item.ProfileName }}'
      ProfileDescription: '{{ item.ProfileDescription }}'
      Owner: '{{ item.Owner }}'
      CreatedAt: '{{ item.CreatedAt }}'
      UpdatedAt: '{{ item.UpdatedAt }}'
- discovery_id: aws.wellarchitected.listReviewTemplates
  calls:
  - action: listReviewTemplates
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.ReviewTemplates }}'
    item:
      Description: '{{ item.Description }}'
      Lenses: '{{ item.Lenses }}'
      Owner: '{{ item.Owner }}'
      UpdatedAt: '{{ item.UpdatedAt }}'
      TemplateArn: '{{ item.TemplateArn }}'
      TemplateName: '{{ item.TemplateName }}'
      UpdateStatus: '{{ item.UpdateStatus }}'
- discovery_id: aws.wellarchitected.listShareInvitations
  calls:
  - action: listShareInvitations
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.ShareInvitationSummaries }}'
    item:
      ShareInvitationId: '{{ item.ShareInvitationId }}'
      SharedBy: '{{ item.SharedBy }}'
      SharedWith: '{{ item.SharedWith }}'
      PermissionType: '{{ item.PermissionType }}'
      ShareResourceType: '{{ item.ShareResourceType }}'
      WorkloadName: '{{ item.WorkloadName }}'
      WorkloadId: '{{ item.WorkloadId }}'
      LensName: '{{ item.LensName }}'
      LensArn: '{{ item.LensArn }}'
      ProfileName: '{{ item.ProfileName }}'
      ProfileArn: '{{ item.ProfileArn }}'
      TemplateName: '{{ item.TemplateName }}'
      TemplateArn: '{{ item.TemplateArn }}'
- discovery_id: aws.wellarchitected.listWorkloads
  calls:
  - action: listWorkloads
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.WorkloadSummaries }}'
    item:
      WorkloadId: '{{ item.WorkloadId }}'
      WorkloadArn: '{{ item.WorkloadArn }}'
      WorkloadName: '{{ item.WorkloadName }}'
      Owner: '{{ item.Owner }}'
      UpdatedAt: '{{ item.UpdatedAt }}'
      Lenses: '{{ item.Lenses }}'
      RiskCounts: '{{ item.RiskCounts }}'
      ImprovementStatus: '{{ item.ImprovementStatus }}'
      Profiles: '{{ item.Profiles }}'
      PrioritizedRiskCounts: '{{ item.PrioritizedRiskCounts }}'
- discovery_id: aws.wellarchitected.getAnswer
  calls:
  - action: getAnswer
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Answer }}'
    item:
      QuestionId: '{{ item.QuestionId }}'
      PillarId: '{{ item.PillarId }}'
      QuestionTitle: '{{ item.QuestionTitle }}'
      QuestionDescription: '{{ item.QuestionDescription }}'
      ImprovementPlanUrl: '{{ item.ImprovementPlanUrl }}'
      HelpfulResourceUrl: '{{ item.HelpfulResourceUrl }}'
      HelpfulResourceDisplayText: '{{ item.HelpfulResourceDisplayText }}'
      Choices: '{{ item.Choices }}'
      SelectedChoices: '{{ item.SelectedChoices }}'
      ChoiceAnswers: '{{ item.ChoiceAnswers }}'
      IsApplicable: '{{ item.IsApplicable }}'
      Risk: '{{ item.Risk }}'
      Notes: '{{ item.Notes }}'
      Reason: '{{ item.Reason }}'
      JiraConfiguration: '{{ item.JiraConfiguration }}'
- discovery_id: aws.wellarchitected.getConsolidatedReport
  calls:
  - action: getConsolidatedReport
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Metrics }}'
    item:
      MetricType: '{{ item.MetricType }}'
      RiskCounts: '{{ item.RiskCounts }}'
      WorkloadId: '{{ item.WorkloadId }}'
      WorkloadName: '{{ item.WorkloadName }}'
      WorkloadArn: '{{ item.WorkloadArn }}'
      UpdatedAt: '{{ item.UpdatedAt }}'
      Lenses: '{{ item.Lenses }}'
      LensesAppliedCount: '{{ item.LensesAppliedCount }}'
- discovery_id: aws.wellarchitected.getLens
  calls:
  - action: getLens
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Lens }}'
    item:
      LensArn: '{{ item.LensArn }}'
      LensVersion: '{{ item.LensVersion }}'
      Name: '{{ item.Name }}'
      Description: '{{ item.Description }}'
      Owner: '{{ item.Owner }}'
      ShareInvitationId: '{{ item.ShareInvitationId }}'
      Tags: '{{ item.Tags }}'
- discovery_id: aws.wellarchitected.getLensReview
  calls:
  - action: getLensReview
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.LensReview }}'
    item:
      LensAlias: '{{ item.LensAlias }}'
      LensArn: '{{ item.LensArn }}'
      LensVersion: '{{ item.LensVersion }}'
      LensName: '{{ item.LensName }}'
      LensStatus: '{{ item.LensStatus }}'
      PillarReviewSummaries: '{{ item.PillarReviewSummaries }}'
      JiraConfiguration: '{{ item.JiraConfiguration }}'
      UpdatedAt: '{{ item.UpdatedAt }}'
      Notes: '{{ item.Notes }}'
      RiskCounts: '{{ item.RiskCounts }}'
      NextToken: '{{ item.NextToken }}'
      Profiles: '{{ item.Profiles }}'
      PrioritizedRiskCounts: '{{ item.PrioritizedRiskCounts }}'
- discovery_id: aws.wellarchitected.getLensReviewReport
  calls:
  - action: getLensReviewReport
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.LensReviewReport }}'
    item:
      LensAlias: '{{ item.LensAlias }}'
      LensArn: '{{ item.LensArn }}'
      Base64String: '{{ item.Base64String }}'
- discovery_id: aws.wellarchitected.getLensVersionDifference
  calls:
  - action: getLensVersionDifference
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.VersionDifferences }}'
    item:
      PillarDifferences: '{{ item.PillarDifferences }}'
- discovery_id: aws.wellarchitected.getMilestone
  calls:
  - action: getMilestone
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Milestone }}'
    item:
      MilestoneNumber: '{{ item.MilestoneNumber }}'
      MilestoneName: '{{ item.MilestoneName }}'
      RecordedAt: '{{ item.RecordedAt }}'
      Workload: '{{ item.Workload }}'
- discovery_id: aws.wellarchitected.getProfile
  calls:
  - action: getProfile
    save_as: response
    on_error: continue
  emit:
