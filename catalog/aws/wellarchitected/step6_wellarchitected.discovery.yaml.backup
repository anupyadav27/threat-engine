    items_for: '{{ response.Answer }}'
    item:
      QuestionId: '{{ item.QuestionId }}'
      PillarId: '{{ item.PillarId }}'
      QuestionTitle: '{{ item.QuestionTitle }}'
      QuestionDescription: '{{ item.QuestionDescription }}'
      ImprovementPlanUrl: '{{ item.ImprovementPlanUrl }}'
      HelpfulResourceUrl: '{{ item.HelpfulResourceUrl }}'
      HelpfulResourceDisplayText: '{{ item.HelpfulResourceDisplayText }}'
      Choices: '{{ item.Choices }}'
      SelectedChoices: '{{ item.SelectedChoices }}'
      ChoiceAnswers: '{{ item.ChoiceAnswers }}'
      IsApplicable: '{{ item.IsApplicable }}'
      AnswerStatus: '{{ item.AnswerStatus }}'
      Notes: '{{ item.Notes }}'
      Reason: '{{ item.Reason }}'
- discovery_id: aws.wellarchitected.getReviewTemplateLensReview
  calls:
  - action: getReviewTemplateLensReview
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.LensReview }}'
    item:
      LensAlias: '{{ item.LensAlias }}'
      LensArn: '{{ item.LensArn }}'
      LensVersion: '{{ item.LensVersion }}'
      LensName: '{{ item.LensName }}'
      LensStatus: '{{ item.LensStatus }}'
      PillarReviewSummaries: '{{ item.PillarReviewSummaries }}'
      UpdatedAt: '{{ item.UpdatedAt }}'
      Notes: '{{ item.Notes }}'
      QuestionCounts: '{{ item.QuestionCounts }}'
      NextToken: '{{ item.NextToken }}'
- discovery_id: aws.wellarchitected.getWorkload
  calls:
  - action: getWorkload
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Workload }}'
    item:
      WorkloadId: '{{ item.WorkloadId }}'
      WorkloadArn: '{{ item.WorkloadArn }}'
      WorkloadName: '{{ item.WorkloadName }}'
      Description: '{{ item.Description }}'
      Environment: '{{ item.Environment }}'
      UpdatedAt: '{{ item.UpdatedAt }}'
      AccountIds: '{{ item.AccountIds }}'
      AwsRegions: '{{ item.AwsRegions }}'
      NonAwsRegions: '{{ item.NonAwsRegions }}'
      ArchitecturalDesign: '{{ item.ArchitecturalDesign }}'
      ReviewOwner: '{{ item.ReviewOwner }}'
      ReviewRestrictionDate: '{{ item.ReviewRestrictionDate }}'
      IsReviewOwnerUpdateAcknowledged: '{{ item.IsReviewOwnerUpdateAcknowledged }}'
      IndustryType: '{{ item.IndustryType }}'
      Industry: '{{ item.Industry }}'
      Notes: '{{ item.Notes }}'
      ImprovementStatus: '{{ item.ImprovementStatus }}'
      RiskCounts: '{{ item.RiskCounts }}'
      PillarPriorities: '{{ item.PillarPriorities }}'
      Lenses: '{{ item.Lenses }}'
      Owner: '{{ item.Owner }}'
      ShareInvitationId: '{{ item.ShareInvitationId }}'
      Tags: '{{ item.Tags }}'
      DiscoveryConfig: '{{ item.DiscoveryConfig }}'
      Applications: '{{ item.Applications }}'
      Profiles: '{{ item.Profiles }}'
      PrioritizedRiskCounts: '{{ item.PrioritizedRiskCounts }}'
      JiraConfiguration: '{{ item.JiraConfiguration }}'
- discovery_id: aws.wellarchitected.listAnswers
  calls:
  - action: listAnswers
    save_as: response
