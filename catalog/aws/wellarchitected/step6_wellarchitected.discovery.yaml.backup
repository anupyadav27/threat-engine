      Status: '{{ item.Status }}'
      AccountId: '{{ item.AccountId }}'
      FlaggedResources: '{{ item.FlaggedResources }}'
      Reason: '{{ item.Reason }}'
      UpdatedAt: '{{ item.UpdatedAt }}'
