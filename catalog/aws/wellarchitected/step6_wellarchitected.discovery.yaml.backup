      QuestionCounts: '{{ item.QuestionCounts }}'
      Owner: '{{ item.Owner }}'
      UpdatedAt: '{{ item.UpdatedAt }}'
      TemplateArn: '{{ item.TemplateArn }}'
      TemplateName: '{{ item.TemplateName }}'
      Tags: '{{ item.Tags }}'
      UpdateStatus: '{{ item.UpdateStatus }}'
      ShareInvitationId: '{{ item.ShareInvitationId }}'
- discovery_id: aws.wellarchitected.getReviewTemplateAnswer
  calls:
  - action: getReviewTemplateAnswer
    save_as: response
    on_error: continue
  emit:
