version: '1.0'
provider: aws
service: forecast
services:
  client: forecast
  module: boto3.client
discovery:
- discovery_id: aws.forecast.listDatasetGroups
  calls:
  - action: listDatasetGroups
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.DatasetGroups }}'
    item:
      DatasetGroupArn: '{{ item.DatasetGroupArn }}'
      DatasetGroupName: '{{ item.DatasetGroupName }}'
      CreationTime: '{{ item.CreationTime }}'
      LastModificationTime: '{{ item.LastModificationTime }}'
- discovery_id: aws.forecast.listDatasetImportJobs
  calls:
  - action: listDatasetImportJobs
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.DatasetImportJobs }}'
    item:
      DatasetImportJobArn: '{{ item.DatasetImportJobArn }}'
      DatasetImportJobName: '{{ item.DatasetImportJobName }}'
      DataSource: '{{ item.DataSource }}'
      Status: '{{ item.Status }}'
      Message: '{{ item.Message }}'
      CreationTime: '{{ item.CreationTime }}'
      LastModificationTime: '{{ item.LastModificationTime }}'
      ImportMode: '{{ item.ImportMode }}'
- discovery_id: aws.forecast.listDatasets
  calls:
  - action: listDatasets
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Datasets }}'
    item:
      DatasetArn: '{{ item.DatasetArn }}'
      DatasetName: '{{ item.DatasetName }}'
      DatasetType: '{{ item.DatasetType }}'
      Domain: '{{ item.Domain }}'
      CreationTime: '{{ item.CreationTime }}'
      LastModificationTime: '{{ item.LastModificationTime }}'
- discovery_id: aws.forecast.listExplainabilities
  calls:
  - action: listExplainabilities
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Explainabilities }}'
    item:
      ExplainabilityArn: '{{ item.ExplainabilityArn }}'
      ExplainabilityName: '{{ item.ExplainabilityName }}'
      ResourceArn: '{{ item.ResourceArn }}'
      ExplainabilityConfig: '{{ item.ExplainabilityConfig }}'
      Status: '{{ item.Status }}'
      Message: '{{ item.Message }}'
      CreationTime: '{{ item.CreationTime }}'
      LastModificationTime: '{{ item.LastModificationTime }}'
- discovery_id: aws.forecast.listExplainabilityExports
  calls:
  - action: listExplainabilityExports
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.ExplainabilityExports }}'
    item:
      ExplainabilityExportArn: '{{ item.ExplainabilityExportArn }}'
      ExplainabilityExportName: '{{ item.ExplainabilityExportName }}'
      Destination: '{{ item.Destination }}'
      Status: '{{ item.Status }}'
      Message: '{{ item.Message }}'
      CreationTime: '{{ item.CreationTime }}'
      LastModificationTime: '{{ item.LastModificationTime }}'
- discovery_id: aws.forecast.listForecastExportJobs
  calls:
  - action: listForecastExportJobs
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.ForecastExportJobs }}'
    item:
      ForecastExportJobArn: '{{ item.ForecastExportJobArn }}'
      ForecastExportJobName: '{{ item.ForecastExportJobName }}'
      Destination: '{{ item.Destination }}'
      Status: '{{ item.Status }}'
      Message: '{{ item.Message }}'
      CreationTime: '{{ item.CreationTime }}'
      LastModificationTime: '{{ item.LastModificationTime }}'
- discovery_id: aws.forecast.listForecasts
  calls:
  - action: listForecasts
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Forecasts }}'
    item:
      ForecastArn: '{{ item.ForecastArn }}'
      ForecastName: '{{ item.ForecastName }}'
      PredictorArn: '{{ item.PredictorArn }}'
      CreatedUsingAutoPredictor: '{{ item.CreatedUsingAutoPredictor }}'
      DatasetGroupArn: '{{ item.DatasetGroupArn }}'
      Status: '{{ item.Status }}'
      Message: '{{ item.Message }}'
      CreationTime: '{{ item.CreationTime }}'
      LastModificationTime: '{{ item.LastModificationTime }}'
- discovery_id: aws.forecast.listMonitors
  calls:
  - action: listMonitors
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Monitors }}'
    item:
      MonitorArn: '{{ item.MonitorArn }}'
      MonitorName: '{{ item.MonitorName }}'
      ResourceArn: '{{ item.ResourceArn }}'
      Status: '{{ item.Status }}'
      CreationTime: '{{ item.CreationTime }}'
      LastModificationTime: '{{ item.LastModificationTime }}'
- discovery_id: aws.forecast.listPredictorBacktestExportJobs
  calls:
  - action: listPredictorBacktestExportJobs
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.PredictorBacktestExportJobs }}'
    item:
      PredictorBacktestExportJobArn: '{{ item.PredictorBacktestExportJobArn }}'
      PredictorBacktestExportJobName: '{{ item.PredictorBacktestExportJobName }}'
      Destination: '{{ item.Destination }}'
      Status: '{{ item.Status }}'
      Message: '{{ item.Message }}'
      CreationTime: '{{ item.CreationTime }}'
      LastModificationTime: '{{ item.LastModificationTime }}'
- discovery_id: aws.forecast.listPredictors
  calls:
  - action: listPredictors
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Predictors }}'
    item:
      PredictorArn: '{{ item.PredictorArn }}'
      PredictorName: '{{ item.PredictorName }}'
      DatasetGroupArn: '{{ item.DatasetGroupArn }}'
      IsAutoPredictor: '{{ item.IsAutoPredictor }}'
      ReferencePredictorSummary: '{{ item.ReferencePredictorSummary }}'
      Status: '{{ item.Status }}'
      Message: '{{ item.Message }}'
      CreationTime: '{{ item.CreationTime }}'
      LastModificationTime: '{{ item.LastModificationTime }}'
- discovery_id: aws.forecast.listWhatIfAnalyses
  calls:
  - action: listWhatIfAnalyses
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.WhatIfAnalyses }}'
    item:
      WhatIfAnalysisArn: '{{ item.WhatIfAnalysisArn }}'
      WhatIfAnalysisName: '{{ item.WhatIfAnalysisName }}'
      ForecastArn: '{{ item.ForecastArn }}'
      Status: '{{ item.Status }}'
      Message: '{{ item.Message }}'
      CreationTime: '{{ item.CreationTime }}'
      LastModificationTime: '{{ item.LastModificationTime }}'
- discovery_id: aws.forecast.listWhatIfForecastExports
  calls:
  - action: listWhatIfForecastExports
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.WhatIfForecastExports }}'
    item:
      WhatIfForecastExportArn: '{{ item.WhatIfForecastExportArn }}'
      WhatIfForecastArns: '{{ item.WhatIfForecastArns }}'
      WhatIfForecastExportName: '{{ item.WhatIfForecastExportName }}'
      Destination: '{{ item.Destination }}'
      Status: '{{ item.Status }}'
      Message: '{{ item.Message }}'
      CreationTime: '{{ item.CreationTime }}'
      LastModificationTime: '{{ item.LastModificationTime }}'
- discovery_id: aws.forecast.listWhatIfForecasts
  calls:
  - action: listWhatIfForecasts
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.WhatIfForecasts }}'
    item:
      WhatIfForecastArn: '{{ item.WhatIfForecastArn }}'
      WhatIfForecastName: '{{ item.WhatIfForecastName }}'
      WhatIfAnalysisArn: '{{ item.WhatIfAnalysisArn }}'
      Status: '{{ item.Status }}'
      Message: '{{ item.Message }}'
      CreationTime: '{{ item.CreationTime }}'
      LastModificationTime: '{{ item.LastModificationTime }}'
- discovery_id: aws.forecast.describeAutoPredictor
  calls:
  - action: describeAutoPredictor
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ForecastTypes }}'
- discovery_id: aws.forecast.describeDataset
  calls:
  - action: describeDataset
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Schema }}'
    item:
      Attributes: '{{ item.Attributes }}'
- discovery_id: aws.forecast.describeDatasetGroup
  calls:
  - action: describeDatasetGroup
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.DatasetArns }}'
- discovery_id: aws.forecast.describeDatasetImportJob
  calls:
  - action: describeDatasetImportJob
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.DataSource }}'
    item:
      S3Config: '{{ item.S3Config }}'
- discovery_id: aws.forecast.describeExplainability
  calls:
  - action: describeExplainability
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ExplainabilityConfig }}'
    item:
      TimeSeriesGranularity: '{{ item.TimeSeriesGranularity }}'
      TimePointGranularity: '{{ item.TimePointGranularity }}'
- discovery_id: aws.forecast.describeExplainabilityExport
  calls:
  - action: describeExplainabilityExport
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Destination }}'
    item:
      S3Config: '{{ item.S3Config }}'
- discovery_id: aws.forecast.describeForecast
  calls:
  - action: describeForecast
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ForecastTypes }}'
- discovery_id: aws.forecast.describeForecastExportJob
  calls:
  - action: describeForecastExportJob
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Destination }}'
    item:
      S3Config: '{{ item.S3Config }}'
- discovery_id: aws.forecast.describeMonitor
  calls:
  - action: describeMonitor
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Baseline }}'
    item:
      PredictorBaseline: '{{ item.PredictorBaseline }}'
- discovery_id: aws.forecast.describePredictor
  calls:
  - action: describePredictor
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AutoMLAlgorithmArns }}'
- discovery_id: aws.forecast.describePredictorBacktestExportJob
  calls:
  - action: describePredictorBacktestExportJob
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Destination }}'
    item:
      S3Config: '{{ item.S3Config }}'
- discovery_id: aws.forecast.describeWhatIfAnalysis
  calls:
  - action: describeWhatIfAnalysis
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.TimeSeriesSelector }}'
    item:
      TimeSeriesIdentifiers: '{{ item.TimeSeriesIdentifiers }}'
- discovery_id: aws.forecast.describeWhatIfForecast
  calls:
  - action: describeWhatIfForecast
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.TimeSeriesTransformations }}'
    item:
      Action: '{{ item.Action }}'
      TimeSeriesConditions: '{{ item.TimeSeriesConditions }}'
- discovery_id: aws.forecast.describeWhatIfForecastExport
  calls:
  - action: describeWhatIfForecastExport
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.WhatIfForecastArns }}'
- discovery_id: aws.forecast.getAccuracyMetrics
  calls:
  - action: getAccuracyMetrics
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.PredictorEvaluationResults }}'
    item:
      AlgorithmArn: '{{ item.AlgorithmArn }}'
      TestWindows: '{{ item.TestWindows }}'
- discovery_id: aws.forecast.listMonitorEvaluations
  calls:
  - action: listMonitorEvaluations
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.PredictorMonitorEvaluations }}'
    item:
      ResourceArn: '{{ item.ResourceArn }}'
      MonitorArn: '{{ item.MonitorArn }}'
      EvaluationTime: '{{ item.EvaluationTime }}'
      EvaluationState: '{{ item.EvaluationState }}'
      WindowStartDatetime: '{{ item.WindowStartDatetime }}'
      WindowEndDatetime: '{{ item.WindowEndDatetime }}'
      PredictorEvent: '{{ item.PredictorEvent }}'
      MonitorDataSource: '{{ item.MonitorDataSource }}'
      MetricResults: '{{ item.MetricResults }}'
      NumItemsEvaluated: '{{ item.NumItemsEvaluated }}'
      Message: '{{ item.Message }}'
- discovery_id: aws.forecast.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Tags }}'
    item:
      Key: '{{ item.Key }}'
      Value: '{{ item.Value }}'
checks: []
