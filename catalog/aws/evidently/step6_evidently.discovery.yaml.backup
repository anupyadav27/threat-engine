version: '1.0'
provider: aws
service: evidently
services:
  client: evidently
  module: boto3.client
discovery:
- discovery_id: aws.evidently.listProjects
  calls:
  - action: listProjects
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.projects }}'
    item:
      activeExperimentCount: '{{ item.activeExperimentCount }}'
      activeLaunchCount: '{{ item.activeLaunchCount }}'
      arn: '{{ item.arn }}'
      createdTime: '{{ item.createdTime }}'
      description: '{{ item.description }}'
      experimentCount: '{{ item.experimentCount }}'
      featureCount: '{{ item.featureCount }}'
      lastUpdatedTime: '{{ item.lastUpdatedTime }}'
      launchCount: '{{ item.launchCount }}'
      name: '{{ item.name }}'
      status: '{{ item.status }}'
      tags: '{{ item.tags }}'
- discovery_id: aws.evidently.listSegments
  calls:
  - action: listSegments
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.segments }}'
    item:
      arn: '{{ item.arn }}'
      createdTime: '{{ item.createdTime }}'
      description: '{{ item.description }}'
      experimentCount: '{{ item.experimentCount }}'
      lastUpdatedTime: '{{ item.lastUpdatedTime }}'
      launchCount: '{{ item.launchCount }}'
      name: '{{ item.name }}'
      pattern: '{{ item.pattern }}'
      tags: '{{ item.tags }}'
- discovery_id: aws.evidently.getExperiment
  calls:
  - action: getExperiment
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.experiment }}'
    item:
      arn: '{{ item.arn }}'
      createdTime: '{{ item.createdTime }}'
      description: '{{ item.description }}'
      execution: '{{ item.execution }}'
      lastUpdatedTime: '{{ item.lastUpdatedTime }}'
      metricGoals: '{{ item.metricGoals }}'
      name: '{{ item.name }}'
      onlineAbDefinition: '{{ item.onlineAbDefinition }}'
      project: '{{ item.project }}'
      randomizationSalt: '{{ item.randomizationSalt }}'
      samplingRate: '{{ item.samplingRate }}'
      schedule: '{{ item.schedule }}'
      segment: '{{ item.segment }}'
      status: '{{ item.status }}'
      statusReason: '{{ item.statusReason }}'
      tags: '{{ item.tags }}'
      treatments: '{{ item.treatments }}'
      type: '{{ item.type }}'
- discovery_id: aws.evidently.getExperimentResults
  calls:
  - action: getExperimentResults
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.resultsData }}'
    item:
      metricName: '{{ item.metricName }}'
      resultStat: '{{ item.resultStat }}'
      treatmentName: '{{ item.treatmentName }}'
      values: '{{ item.values }}'
- discovery_id: aws.evidently.getFeature
  calls:
  - action: getFeature
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.feature }}'
    item:
      arn: '{{ item.arn }}'
      createdTime: '{{ item.createdTime }}'
      defaultVariation: '{{ item.defaultVariation }}'
      description: '{{ item.description }}'
      entityOverrides: '{{ item.entityOverrides }}'
      evaluationRules: '{{ item.evaluationRules }}'
      evaluationStrategy: '{{ item.evaluationStrategy }}'
      lastUpdatedTime: '{{ item.lastUpdatedTime }}'
      name: '{{ item.name }}'
      project: '{{ item.project }}'
      status: '{{ item.status }}'
      tags: '{{ item.tags }}'
      valueType: '{{ item.valueType }}'
      variations: '{{ item.variations }}'
- discovery_id: aws.evidently.getLaunch
  calls:
  - action: getLaunch
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.launch }}'
    item:
      arn: '{{ item.arn }}'
      createdTime: '{{ item.createdTime }}'
      description: '{{ item.description }}'
      execution: '{{ item.execution }}'
      groups: '{{ item.groups }}'
      lastUpdatedTime: '{{ item.lastUpdatedTime }}'
      metricMonitors: '{{ item.metricMonitors }}'
      name: '{{ item.name }}'
      project: '{{ item.project }}'
      randomizationSalt: '{{ item.randomizationSalt }}'
      scheduledSplitsDefinition: '{{ item.scheduledSplitsDefinition }}'
      status: '{{ item.status }}'
      statusReason: '{{ item.statusReason }}'
      tags: '{{ item.tags }}'
      type: '{{ item.type }}'
- discovery_id: aws.evidently.getProject
  calls:
  - action: getProject
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.project }}'
    item:
      activeExperimentCount: '{{ item.activeExperimentCount }}'
      activeLaunchCount: '{{ item.activeLaunchCount }}'
      appConfigResource: '{{ item.appConfigResource }}'
      arn: '{{ item.arn }}'
      createdTime: '{{ item.createdTime }}'
      dataDelivery: '{{ item.dataDelivery }}'
      description: '{{ item.description }}'
      experimentCount: '{{ item.experimentCount }}'
      featureCount: '{{ item.featureCount }}'
      lastUpdatedTime: '{{ item.lastUpdatedTime }}'
      launchCount: '{{ item.launchCount }}'
      name: '{{ item.name }}'
      status: '{{ item.status }}'
      tags: '{{ item.tags }}'
- discovery_id: aws.evidently.getSegment
  calls:
  - action: getSegment
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.segment }}'
    item:
      arn: '{{ item.arn }}'
      createdTime: '{{ item.createdTime }}'
      description: '{{ item.description }}'
      experimentCount: '{{ item.experimentCount }}'
      lastUpdatedTime: '{{ item.lastUpdatedTime }}'
      launchCount: '{{ item.launchCount }}'
      name: '{{ item.name }}'
      pattern: '{{ item.pattern }}'
      tags: '{{ item.tags }}'
- discovery_id: aws.evidently.listExperiments
  calls:
  - action: listExperiments
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.experiments }}'
    item:
      arn: '{{ item.arn }}'
      createdTime: '{{ item.createdTime }}'
      description: '{{ item.description }}'
      execution: '{{ item.execution }}'
      lastUpdatedTime: '{{ item.lastUpdatedTime }}'
      metricGoals: '{{ item.metricGoals }}'
      name: '{{ item.name }}'
      onlineAbDefinition: '{{ item.onlineAbDefinition }}'
      project: '{{ item.project }}'
      randomizationSalt: '{{ item.randomizationSalt }}'
      samplingRate: '{{ item.samplingRate }}'
      schedule: '{{ item.schedule }}'
      segment: '{{ item.segment }}'
      status: '{{ item.status }}'
      statusReason: '{{ item.statusReason }}'
      tags: '{{ item.tags }}'
      treatments: '{{ item.treatments }}'
      type: '{{ item.type }}'
- discovery_id: aws.evidently.listFeatures
  calls:
  - action: listFeatures
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.features }}'
    item:
      arn: '{{ item.arn }}'
      createdTime: '{{ item.createdTime }}'
      defaultVariation: '{{ item.defaultVariation }}'
      evaluationRules: '{{ item.evaluationRules }}'
      evaluationStrategy: '{{ item.evaluationStrategy }}'
      lastUpdatedTime: '{{ item.lastUpdatedTime }}'
      name: '{{ item.name }}'
      project: '{{ item.project }}'
      status: '{{ item.status }}'
      tags: '{{ item.tags }}'
- discovery_id: aws.evidently.listLaunches
  calls:
  - action: listLaunches
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.launches }}'
    item:
      arn: '{{ item.arn }}'
      createdTime: '{{ item.createdTime }}'
      description: '{{ item.description }}'
      execution: '{{ item.execution }}'
      groups: '{{ item.groups }}'
      lastUpdatedTime: '{{ item.lastUpdatedTime }}'
      metricMonitors: '{{ item.metricMonitors }}'
      name: '{{ item.name }}'
      project: '{{ item.project }}'
      randomizationSalt: '{{ item.randomizationSalt }}'
      scheduledSplitsDefinition: '{{ item.scheduledSplitsDefinition }}'
      status: '{{ item.status }}'
      statusReason: '{{ item.statusReason }}'
      tags: '{{ item.tags }}'
      type: '{{ item.type }}'
- discovery_id: aws.evidently.listSegmentReferences
  calls:
  - action: listSegmentReferences
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.referencedBy }}'
    item:
      arn: '{{ item.arn }}'
      endTime: '{{ item.endTime }}'
      lastUpdatedOn: '{{ item.lastUpdatedOn }}'
      name: '{{ item.name }}'
      startTime: '{{ item.startTime }}'
      status: '{{ item.status }}'
      type: '{{ item.type }}'
- discovery_id: aws.evidently.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tags }}'
checks: []
