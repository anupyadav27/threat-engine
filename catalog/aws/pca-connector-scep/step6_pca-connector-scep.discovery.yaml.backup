version: '1.0'
provider: aws
service: pca-connector-scep
services:
  client: pca-connector-scep
  module: boto3.client
discovery:
- discovery_id: aws.pca-connector-scep.listConnectors
  calls:
  - action: listConnectors
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Connectors }}'
    item:
      Arn: '{{ item.Arn }}'
      CertificateAuthorityArn: '{{ item.CertificateAuthorityArn }}'
      Type: '{{ item.Type }}'
      MobileDeviceManagement: '{{ item.MobileDeviceManagement }}'
      OpenIdConfiguration: '{{ item.OpenIdConfiguration }}'
      Status: '{{ item.Status }}'
      StatusReason: '{{ item.StatusReason }}'
      Endpoint: '{{ item.Endpoint }}'
      CreatedAt: '{{ item.CreatedAt }}'
      UpdatedAt: '{{ item.UpdatedAt }}'
- discovery_id: aws.pca-connector-scep.getChallengeMetadata
  calls:
  - action: getChallengeMetadata
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ChallengeMetadata }}'
    item:
      Arn: '{{ item.Arn }}'
      ConnectorArn: '{{ item.ConnectorArn }}'
      CreatedAt: '{{ item.CreatedAt }}'
      UpdatedAt: '{{ item.UpdatedAt }}'
- discovery_id: aws.pca-connector-scep.getChallengePassword
  calls:
  - action: getChallengePassword
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Password }}'
- discovery_id: aws.pca-connector-scep.getConnector
  calls:
  - action: getConnector
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Connector }}'
    item:
      Arn: '{{ item.Arn }}'
      CertificateAuthorityArn: '{{ item.CertificateAuthorityArn }}'
      Type: '{{ item.Type }}'
      MobileDeviceManagement: '{{ item.MobileDeviceManagement }}'
      OpenIdConfiguration: '{{ item.OpenIdConfiguration }}'
      Status: '{{ item.Status }}'
      StatusReason: '{{ item.StatusReason }}'
      Endpoint: '{{ item.Endpoint }}'
      CreatedAt: '{{ item.CreatedAt }}'
      UpdatedAt: '{{ item.UpdatedAt }}'
- discovery_id: aws.pca-connector-scep.listChallengeMetadata
  calls:
  - action: listChallengeMetadata
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Challenges }}'
    item:
      Arn: '{{ item.Arn }}'
      ConnectorArn: '{{ item.ConnectorArn }}'
      CreatedAt: '{{ item.CreatedAt }}'
      UpdatedAt: '{{ item.UpdatedAt }}'
- discovery_id: aws.pca-connector-scep.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Tags }}'
checks: []
