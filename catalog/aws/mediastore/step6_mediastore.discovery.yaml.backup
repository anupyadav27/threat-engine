version: '1.0'
provider: aws
service: mediastore
services:
  client: mediastore
  module: boto3.client
discovery:
- discovery_id: aws.mediastore.describeContainer
  calls:
  - action: describeContainer
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Container }}'
    item:
      Endpoint: '{{ item.Endpoint }}'
      CreationTime: '{{ item.CreationTime }}'
      ARN: '{{ item.ARN }}'
      Name: '{{ item.Name }}'
      Status: '{{ item.Status }}'
      AccessLoggingEnabled: '{{ item.AccessLoggingEnabled }}'
- discovery_id: aws.mediastore.listContainers
  calls:
  - action: listContainers
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Containers }}'
    item:
      Endpoint: '{{ item.Endpoint }}'
      CreationTime: '{{ item.CreationTime }}'
      ARN: '{{ item.ARN }}'
      Name: '{{ item.Name }}'
      Status: '{{ item.Status }}'
      AccessLoggingEnabled: '{{ item.AccessLoggingEnabled }}'
- discovery_id: aws.mediastore.getContainerPolicy
  calls:
  - action: getContainerPolicy
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Policy }}'
- discovery_id: aws.mediastore.getCorsPolicy
  calls:
  - action: getCorsPolicy
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.CorsPolicy }}'
    item:
      AllowedOrigins: '{{ item.AllowedOrigins }}'
      AllowedMethods: '{{ item.AllowedMethods }}'
      AllowedHeaders: '{{ item.AllowedHeaders }}'
      MaxAgeSeconds: '{{ item.MaxAgeSeconds }}'
      ExposeHeaders: '{{ item.ExposeHeaders }}'
- discovery_id: aws.mediastore.getLifecyclePolicy
  calls:
  - action: getLifecyclePolicy
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.LifecyclePolicy }}'
- discovery_id: aws.mediastore.getMetricPolicy
  calls:
  - action: getMetricPolicy
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.MetricPolicy }}'
    item:
      ContainerLevelMetrics: '{{ item.ContainerLevelMetrics }}'
      MetricPolicyRules: '{{ item.MetricPolicyRules }}'
- discovery_id: aws.mediastore.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Tags }}'
    item:
      Key: '{{ item.Key }}'
      Value: '{{ item.Value }}'
checks: []
