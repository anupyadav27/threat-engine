version: '1.0'
provider: aws
service: appstream
services:
  client: appstream
  module: boto3.client
discovery:
- discovery_id: aws.appstream.describeAppBlockBuilderAppBlockAssociations
  calls:
  - action: describeAppBlockBuilderAppBlockAssociations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AppBlockBuilderAppBlockAssociations }}'
    item:
      AppBlockArn: '{{ item.AppBlockArn }}'
      AppBlockBuilderName: '{{ item.AppBlockBuilderName }}'
- discovery_id: aws.appstream.describeAppBlockBuilders
  calls:
  - action: describeAppBlockBuilders
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AppBlockBuilders }}'
    item:
      Arn: '{{ item.Arn }}'
      Name: '{{ item.Name }}'
      DisplayName: '{{ item.DisplayName }}'
      Description: '{{ item.Description }}'
      Platform: '{{ item.Platform }}'
      InstanceType: '{{ item.InstanceType }}'
      EnableDefaultInternetAccess: '{{ item.EnableDefaultInternetAccess }}'
      IamRoleArn: '{{ item.IamRoleArn }}'
      VpcConfig: '{{ item.VpcConfig }}'
      State: '{{ item.State }}'
      CreatedTime: '{{ item.CreatedTime }}'
      AppBlockBuilderErrors: '{{ item.AppBlockBuilderErrors }}'
      StateChangeReason: '{{ item.StateChangeReason }}'
      AccessEndpoints: '{{ item.AccessEndpoints }}'
- discovery_id: aws.appstream.describeAppBlocks
  calls:
  - action: describeAppBlocks
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AppBlocks }}'
    item:
      Name: '{{ item.Name }}'
      Arn: '{{ item.Arn }}'
      Description: '{{ item.Description }}'
      DisplayName: '{{ item.DisplayName }}'
      SourceS3Location: '{{ item.SourceS3Location }}'
      SetupScriptDetails: '{{ item.SetupScriptDetails }}'
      CreatedTime: '{{ item.CreatedTime }}'
      PostSetupScriptDetails: '{{ item.PostSetupScriptDetails }}'
      PackagingType: '{{ item.PackagingType }}'
      State: '{{ item.State }}'
      AppBlockErrors: '{{ item.AppBlockErrors }}'
- discovery_id: aws.appstream.describeApplicationFleetAssociations
  calls:
  - action: describeApplicationFleetAssociations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ApplicationFleetAssociations }}'
    item:
      FleetName: '{{ item.FleetName }}'
      ApplicationArn: '{{ item.ApplicationArn }}'
- discovery_id: aws.appstream.describeApplications
  calls:
  - action: describeApplications
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Applications }}'
    item:
      Name: '{{ item.Name }}'
      DisplayName: '{{ item.DisplayName }}'
      IconURL: '{{ item.IconURL }}'
      LaunchPath: '{{ item.LaunchPath }}'
      LaunchParameters: '{{ item.LaunchParameters }}'
      Enabled: '{{ item.Enabled }}'
      Metadata: '{{ item.Metadata }}'
      WorkingDirectory: '{{ item.WorkingDirectory }}'
      Description: '{{ item.Description }}'
      Arn: '{{ item.Arn }}'
      AppBlockArn: '{{ item.AppBlockArn }}'
      IconS3Location: '{{ item.IconS3Location }}'
      Platforms: '{{ item.Platforms }}'
      InstanceFamilies: '{{ item.InstanceFamilies }}'
      CreatedTime: '{{ item.CreatedTime }}'
- discovery_id: aws.appstream.describeDirectoryConfigs
  calls:
  - action: describeDirectoryConfigs
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.DirectoryConfigs }}'
    item:
      DirectoryName: '{{ item.DirectoryName }}'
      OrganizationalUnitDistinguishedNames: '{{ item.OrganizationalUnitDistinguishedNames
        }}'
      ServiceAccountCredentials: '{{ item.ServiceAccountCredentials }}'
      CreatedTime: '{{ item.CreatedTime }}'
      CertificateBasedAuthProperties: '{{ item.CertificateBasedAuthProperties }}'
- discovery_id: aws.appstream.describeFleets
  calls:
  - action: describeFleets
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Fleets }}'
    item:
      Arn: '{{ item.Arn }}'
      Name: '{{ item.Name }}'
      DisplayName: '{{ item.DisplayName }}'
      Description: '{{ item.Description }}'
      ImageName: '{{ item.ImageName }}'
      ImageArn: '{{ item.ImageArn }}'
      InstanceType: '{{ item.InstanceType }}'
      FleetType: '{{ item.FleetType }}'
      ComputeCapacityStatus: '{{ item.ComputeCapacityStatus }}'
      MaxUserDurationInSeconds: '{{ item.MaxUserDurationInSeconds }}'
      DisconnectTimeoutInSeconds: '{{ item.DisconnectTimeoutInSeconds }}'
      State: '{{ item.State }}'
      VpcConfig: '{{ item.VpcConfig }}'
      CreatedTime: '{{ item.CreatedTime }}'
      FleetErrors: '{{ item.FleetErrors }}'
      EnableDefaultInternetAccess: '{{ item.EnableDefaultInternetAccess }}'
      DomainJoinInfo: '{{ item.DomainJoinInfo }}'
      IdleDisconnectTimeoutInSeconds: '{{ item.IdleDisconnectTimeoutInSeconds }}'
      IamRoleArn: '{{ item.IamRoleArn }}'
      StreamView: '{{ item.StreamView }}'
      Platform: '{{ item.Platform }}'
      MaxConcurrentSessions: '{{ item.MaxConcurrentSessions }}'
      UsbDeviceFilterStrings: '{{ item.UsbDeviceFilterStrings }}'
      SessionScriptS3Location: '{{ item.SessionScriptS3Location }}'
      MaxSessionsPerInstance: '{{ item.MaxSessionsPerInstance }}'
      RootVolumeConfig: '{{ item.RootVolumeConfig }}'
- discovery_id: aws.appstream.describeImageBuilders
  calls:
  - action: describeImageBuilders
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ImageBuilders }}'
    item:
      Name: '{{ item.Name }}'
      Arn: '{{ item.Arn }}'
      ImageArn: '{{ item.ImageArn }}'
      Description: '{{ item.Description }}'
      DisplayName: '{{ item.DisplayName }}'
      VpcConfig: '{{ item.VpcConfig }}'
      InstanceType: '{{ item.InstanceType }}'
      Platform: '{{ item.Platform }}'
      IamRoleArn: '{{ item.IamRoleArn }}'
      State: '{{ item.State }}'
      StateChangeReason: '{{ item.StateChangeReason }}'
      CreatedTime: '{{ item.CreatedTime }}'
      EnableDefaultInternetAccess: '{{ item.EnableDefaultInternetAccess }}'
      DomainJoinInfo: '{{ item.DomainJoinInfo }}'
      NetworkAccessConfiguration: '{{ item.NetworkAccessConfiguration }}'
      ImageBuilderErrors: '{{ item.ImageBuilderErrors }}'
      AppstreamAgentVersion: '{{ item.AppstreamAgentVersion }}'
      AccessEndpoints: '{{ item.AccessEndpoints }}'
      RootVolumeConfig: '{{ item.RootVolumeConfig }}'
      LatestAppstreamAgentVersion: '{{ item.LatestAppstreamAgentVersion }}'
- discovery_id: aws.appstream.describeImages
  calls:
  - action: describeImages
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Images }}'
    item:
      Name: '{{ item.Name }}'
      Arn: '{{ item.Arn }}'
      BaseImageArn: '{{ item.BaseImageArn }}'
      DisplayName: '{{ item.DisplayName }}'
      State: '{{ item.State }}'
      Visibility: '{{ item.Visibility }}'
      ImageBuilderSupported: '{{ item.ImageBuilderSupported }}'
      ImageBuilderName: '{{ item.ImageBuilderName }}'
      Platform: '{{ item.Platform }}'
      Description: '{{ item.Description }}'
      StateChangeReason: '{{ item.StateChangeReason }}'
      Applications: '{{ item.Applications }}'
      CreatedTime: '{{ item.CreatedTime }}'
      PublicBaseImageReleasedDate: '{{ item.PublicBaseImageReleasedDate }}'
      AppstreamAgentVersion: '{{ item.AppstreamAgentVersion }}'
      ImagePermissions: '{{ item.ImagePermissions }}'
      ImageErrors: '{{ item.ImageErrors }}'
      LatestAppstreamAgentVersion: '{{ item.LatestAppstreamAgentVersion }}'
      SupportedInstanceFamilies: '{{ item.SupportedInstanceFamilies }}'
      DynamicAppProvidersEnabled: '{{ item.DynamicAppProvidersEnabled }}'
      ImageSharedWithOthers: '{{ item.ImageSharedWithOthers }}'
      ManagedSoftwareIncluded: '{{ item.ManagedSoftwareIncluded }}'
      ImageType: '{{ item.ImageType }}'
- discovery_id: aws.appstream.describeStacks
  calls:
  - action: describeStacks
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Stacks }}'
    item:
      Arn: '{{ item.Arn }}'
      Name: '{{ item.Name }}'
      Description: '{{ item.Description }}'
      DisplayName: '{{ item.DisplayName }}'
      CreatedTime: '{{ item.CreatedTime }}'
      StorageConnectors: '{{ item.StorageConnectors }}'
      RedirectURL: '{{ item.RedirectURL }}'
      FeedbackURL: '{{ item.FeedbackURL }}'
      StackErrors: '{{ item.StackErrors }}'
      UserSettings: '{{ item.UserSettings }}'
      ApplicationSettings: '{{ item.ApplicationSettings }}'
      AccessEndpoints: '{{ item.AccessEndpoints }}'
      EmbedHostDomains: '{{ item.EmbedHostDomains }}'
      StreamingExperienceSettings: '{{ item.StreamingExperienceSettings }}'
- discovery_id: aws.appstream.describeUsageReportSubscriptions
  calls:
  - action: describeUsageReportSubscriptions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.UsageReportSubscriptions }}'
    item:
      S3BucketName: '{{ item.S3BucketName }}'
      Schedule: '{{ item.Schedule }}'
      LastGeneratedReportDate: '{{ item.LastGeneratedReportDate }}'
      SubscriptionErrors: '{{ item.SubscriptionErrors }}'
- discovery_id: aws.appstream.describeUserStackAssociations
  calls:
  - action: describeUserStackAssociations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.UserStackAssociations }}'
    item:
      StackName: '{{ item.StackName }}'
      UserName: '{{ item.UserName }}'
      AuthenticationType: '{{ item.AuthenticationType }}'
      SendEmailNotification: '{{ item.SendEmailNotification }}'
- discovery_id: aws.appstream.getExportImageTask
  calls:
  - action: getExportImageTask
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ExportImageTask }}'
    item:
      TaskId: '{{ item.TaskId }}'
      ImageArn: '{{ item.ImageArn }}'
      AmiName: '{{ item.AmiName }}'
      CreatedDate: '{{ item.CreatedDate }}'
      AmiDescription: '{{ item.AmiDescription }}'
      State: '{{ item.State }}'
      AmiId: '{{ item.AmiId }}'
      TagSpecifications: '{{ item.TagSpecifications }}'
      ErrorDetails: '{{ item.ErrorDetails }}'
- discovery_id: aws.appstream.listExportImageTasks
  calls:
  - action: listExportImageTasks
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.ExportImageTasks }}'
    item:
      TaskId: '{{ item.TaskId }}'
      ImageArn: '{{ item.ImageArn }}'
      AmiName: '{{ item.AmiName }}'
      CreatedDate: '{{ item.CreatedDate }}'
      AmiDescription: '{{ item.AmiDescription }}'
      State: '{{ item.State }}'
      AmiId: '{{ item.AmiId }}'
      TagSpecifications: '{{ item.TagSpecifications }}'
      ErrorDetails: '{{ item.ErrorDetails }}'
- discovery_id: aws.appstream.describeAppLicenseUsage
  calls:
  - action: describeAppLicenseUsage
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AppLicenseUsages }}'
    item:
      UserArn: '{{ item.UserArn }}'
      BillingPeriod: '{{ item.BillingPeriod }}'
      OwnerAWSAccountId: '{{ item.OwnerAWSAccountId }}'
      SubscriptionFirstUsedDate: '{{ item.SubscriptionFirstUsedDate }}'
      SubscriptionLastUsedDate: '{{ item.SubscriptionLastUsedDate }}'
      LicenseType: '{{ item.LicenseType }}'
      UserId: '{{ item.UserId }}'
- discovery_id: aws.appstream.describeEntitlements
  calls:
  - action: describeEntitlements
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Entitlements }}'
    item:
      Name: '{{ item.Name }}'
      StackName: '{{ item.StackName }}'
      Description: '{{ item.Description }}'
      AppVisibility: '{{ item.AppVisibility }}'
      Attributes: '{{ item.Attributes }}'
      CreatedTime: '{{ item.CreatedTime }}'
      LastModifiedTime: '{{ item.LastModifiedTime }}'
- discovery_id: aws.appstream.describeImagePermissions
  calls:
  - action: describeImagePermissions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.SharedImagePermissionsList }}'
    item:
      sharedAccountId: '{{ item.sharedAccountId }}'
      imagePermissions: '{{ item.imagePermissions }}'
- discovery_id: aws.appstream.describeSessions
  calls:
  - action: describeSessions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Sessions }}'
    item:
      Id: '{{ item.Id }}'
      UserId: '{{ item.UserId }}'
      StackName: '{{ item.StackName }}'
      FleetName: '{{ item.FleetName }}'
      State: '{{ item.State }}'
      ConnectionState: '{{ item.ConnectionState }}'
      StartTime: '{{ item.StartTime }}'
      MaxExpirationTime: '{{ item.MaxExpirationTime }}'
      AuthenticationType: '{{ item.AuthenticationType }}'
      NetworkAccessConfiguration: '{{ item.NetworkAccessConfiguration }}'
      InstanceId: '{{ item.InstanceId }}'
- discovery_id: aws.appstream.describeSoftwareAssociations
  calls:
  - action: describeSoftwareAssociations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.SoftwareAssociations }}'
    item:
      SoftwareName: '{{ item.SoftwareName }}'
      Status: '{{ item.Status }}'
      DeploymentError: '{{ item.DeploymentError }}'
- discovery_id: aws.appstream.describeThemeForStack
  calls:
  - action: describeThemeForStack
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Theme }}'
    item:
      StackName: '{{ item.StackName }}'
      State: '{{ item.State }}'
      ThemeTitleText: '{{ item.ThemeTitleText }}'
      ThemeStyling: '{{ item.ThemeStyling }}'
      ThemeFooterLinks: '{{ item.ThemeFooterLinks }}'
      ThemeOrganizationLogoURL: '{{ item.ThemeOrganizationLogoURL }}'
      ThemeFaviconURL: '{{ item.ThemeFaviconURL }}'
      CreatedTime: '{{ item.CreatedTime }}'
- discovery_id: aws.appstream.describeUsers
  calls:
  - action: describeUsers
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Users }}'
    item:
      Arn: '{{ item.Arn }}'
      UserName: '{{ item.UserName }}'
      Enabled: '{{ item.Enabled }}'
      Status: '{{ item.Status }}'
      FirstName: '{{ item.FirstName }}'
      LastName: '{{ item.LastName }}'
      CreatedTime: '{{ item.CreatedTime }}'
      AuthenticationType: '{{ item.AuthenticationType }}'
- discovery_id: aws.appstream.listAssociatedFleets
  calls:
  - action: listAssociatedFleets
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Names }}'
- discovery_id: aws.appstream.listAssociatedStacks
  calls:
  - action: listAssociatedStacks
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Names }}'
- discovery_id: aws.appstream.listEntitledApplications
  calls:
  - action: listEntitledApplications
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.EntitledApplications }}'
    item:
      ApplicationIdentifier: '{{ item.ApplicationIdentifier }}'
- discovery_id: aws.appstream.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Tags }}'
checks: []
