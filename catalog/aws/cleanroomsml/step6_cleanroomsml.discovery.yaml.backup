version: '1.0'
provider: aws
service: cleanroomsml
services:
  client: cleanroomsml
  module: boto3.client
discovery:
- discovery_id: aws.cleanroomsml.listAudienceExportJobs
  calls:
  - action: listAudienceExportJobs
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.audienceExportJobs }}'
    item:
      createTime: '{{ item.createTime }}'
      updateTime: '{{ item.updateTime }}'
      name: '{{ item.name }}'
      audienceGenerationJobArn: '{{ item.audienceGenerationJobArn }}'
      audienceSize: '{{ item.audienceSize }}'
      description: '{{ item.description }}'
      status: '{{ item.status }}'
      statusDetails: '{{ item.statusDetails }}'
      outputLocation: '{{ item.outputLocation }}'
- discovery_id: aws.cleanroomsml.listAudienceGenerationJobs
  calls:
  - action: listAudienceGenerationJobs
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.audienceGenerationJobs }}'
    item:
      createTime: '{{ item.createTime }}'
      updateTime: '{{ item.updateTime }}'
      audienceGenerationJobArn: '{{ item.audienceGenerationJobArn }}'
      name: '{{ item.name }}'
      description: '{{ item.description }}'
      status: '{{ item.status }}'
      configuredAudienceModelArn: '{{ item.configuredAudienceModelArn }}'
      collaborationId: '{{ item.collaborationId }}'
      startedBy: '{{ item.startedBy }}'
- discovery_id: aws.cleanroomsml.listAudienceModels
  calls:
  - action: listAudienceModels
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.audienceModels }}'
    item:
      createTime: '{{ item.createTime }}'
      updateTime: '{{ item.updateTime }}'
      audienceModelArn: '{{ item.audienceModelArn }}'
      name: '{{ item.name }}'
      trainingDatasetArn: '{{ item.trainingDatasetArn }}'
      status: '{{ item.status }}'
      description: '{{ item.description }}'
- discovery_id: aws.cleanroomsml.listConfiguredAudienceModels
  calls:
  - action: listConfiguredAudienceModels
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.configuredAudienceModels }}'
    item:
      createTime: '{{ item.createTime }}'
      updateTime: '{{ item.updateTime }}'
      name: '{{ item.name }}'
      audienceModelArn: '{{ item.audienceModelArn }}'
      outputConfig: '{{ item.outputConfig }}'
      description: '{{ item.description }}'
      configuredAudienceModelArn: '{{ item.configuredAudienceModelArn }}'
      status: '{{ item.status }}'
- discovery_id: aws.cleanroomsml.listConfiguredModelAlgorithms
  calls:
  - action: listConfiguredModelAlgorithms
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.configuredModelAlgorithms }}'
    item:
      createTime: '{{ item.createTime }}'
      updateTime: '{{ item.updateTime }}'
      configuredModelAlgorithmArn: '{{ item.configuredModelAlgorithmArn }}'
      name: '{{ item.name }}'
      description: '{{ item.description }}'
- discovery_id: aws.cleanroomsml.listTrainingDatasets
  calls:
  - action: listTrainingDatasets
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.trainingDatasets }}'
    item:
      createTime: '{{ item.createTime }}'
      updateTime: '{{ item.updateTime }}'
      trainingDatasetArn: '{{ item.trainingDatasetArn }}'
      name: '{{ item.name }}'
      status: '{{ item.status }}'
      description: '{{ item.description }}'
- discovery_id: aws.cleanroomsml.getAudienceGenerationJob
  calls:
  - action: getAudienceGenerationJob
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.statusDetails }}'
    item:
      statusCode: '{{ item.statusCode }}'
      message: '{{ item.message }}'
- discovery_id: aws.cleanroomsml.getAudienceModel
  calls:
  - action: getAudienceModel
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.statusDetails }}'
    item:
      statusCode: '{{ item.statusCode }}'
      message: '{{ item.message }}'
- discovery_id: aws.cleanroomsml.getCollaborationConfiguredModelAlgorithmAssociation
  calls:
  - action: getCollaborationConfiguredModelAlgorithmAssociation
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.privacyConfiguration }}'
    item:
      policies: '{{ item.policies }}'
- discovery_id: aws.cleanroomsml.getCollaborationMlInputChannel
  calls:
  - action: getCollaborationMlInputChannel
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.configuredModelAlgorithmAssociations }}'
- discovery_id: aws.cleanroomsml.getCollaborationTrainedModel
  calls:
  - action: getCollaborationTrainedModel
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.incrementalTrainingDataChannels }}'
    item:
      channelName: '{{ item.channelName }}'
      versionIdentifier: '{{ item.versionIdentifier }}'
      modelName: '{{ item.modelName }}'
- discovery_id: aws.cleanroomsml.getConfiguredAudienceModel
  calls:
  - action: getConfiguredAudienceModel
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.sharedAudienceMetrics }}'
- discovery_id: aws.cleanroomsml.getConfiguredAudienceModelPolicy
  calls:
  - action: getConfiguredAudienceModelPolicy
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.configuredAudienceModelArn }}'
- discovery_id: aws.cleanroomsml.getConfiguredModelAlgorithm
  calls:
  - action: getConfiguredModelAlgorithm
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.trainingContainerConfig }}'
    item:
      imageUri: '{{ item.imageUri }}'
      entrypoint: '{{ item.entrypoint }}'
      arguments: '{{ item.arguments }}'
      metricDefinitions: '{{ item.metricDefinitions }}'
- discovery_id: aws.cleanroomsml.getConfiguredModelAlgorithmAssociation
  calls:
  - action: getConfiguredModelAlgorithmAssociation
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.privacyConfiguration }}'
    item:
      policies: '{{ item.policies }}'
- discovery_id: aws.cleanroomsml.getMlConfiguration
  calls:
  - action: getMlConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.defaultOutputLocation }}'
    item:
      destination: '{{ item.destination }}'
      roleArn: '{{ item.roleArn }}'
- discovery_id: aws.cleanroomsml.getMlInputChannel
  calls:
  - action: getMlInputChannel
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.configuredModelAlgorithmAssociations }}'
- discovery_id: aws.cleanroomsml.getTrainedModel
  calls:
  - action: getTrainedModel
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.incrementalTrainingDataChannels }}'
    item:
      channelName: '{{ item.channelName }}'
      versionIdentifier: '{{ item.versionIdentifier }}'
      modelName: '{{ item.modelName }}'
- discovery_id: aws.cleanroomsml.getTrainedModelInferenceJob
  calls:
  - action: getTrainedModelInferenceJob
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.resourceConfig }}'
    item:
      instanceType: '{{ item.instanceType }}'
      instanceCount: '{{ item.instanceCount }}'
- discovery_id: aws.cleanroomsml.getTrainingDataset
  calls:
  - action: getTrainingDataset
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.trainingData }}'
    item:
      type: '{{ item.type }}'
      inputConfig: '{{ item.inputConfig }}'
- discovery_id: aws.cleanroomsml.listCollaborationConfiguredModelAlgorithmAssociations
  calls:
  - action: listCollaborationConfiguredModelAlgorithmAssociations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.collaborationConfiguredModelAlgorithmAssociations }}'
    item:
      createTime: '{{ item.createTime }}'
      updateTime: '{{ item.updateTime }}'
      configuredModelAlgorithmAssociationArn: '{{ item.configuredModelAlgorithmAssociationArn
        }}'
      name: '{{ item.name }}'
      description: '{{ item.description }}'
      membershipIdentifier: '{{ item.membershipIdentifier }}'
      collaborationIdentifier: '{{ item.collaborationIdentifier }}'
      configuredModelAlgorithmArn: '{{ item.configuredModelAlgorithmArn }}'
      creatorAccountId: '{{ item.creatorAccountId }}'
- discovery_id: aws.cleanroomsml.listCollaborationMlInputChannels
  calls:
  - action: listCollaborationMlInputChannels
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.collaborationMLInputChannelsList }}'
    item:
      createTime: '{{ item.createTime }}'
      updateTime: '{{ item.updateTime }}'
      membershipIdentifier: '{{ item.membershipIdentifier }}'
      collaborationIdentifier: '{{ item.collaborationIdentifier }}'
      name: '{{ item.name }}'
      configuredModelAlgorithmAssociations: '{{ item.configuredModelAlgorithmAssociations
        }}'
      mlInputChannelArn: '{{ item.mlInputChannelArn }}'
      status: '{{ item.status }}'
      creatorAccountId: '{{ item.creatorAccountId }}'
      description: '{{ item.description }}'
- discovery_id: aws.cleanroomsml.listCollaborationTrainedModelExportJobs
  calls:
  - action: listCollaborationTrainedModelExportJobs
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.collaborationTrainedModelExportJobs }}'
    item:
      createTime: '{{ item.createTime }}'
      updateTime: '{{ item.updateTime }}'
      name: '{{ item.name }}'
      outputConfiguration: '{{ item.outputConfiguration }}'
      status: '{{ item.status }}'
      statusDetails: '{{ item.statusDetails }}'
      description: '{{ item.description }}'
      creatorAccountId: '{{ item.creatorAccountId }}'
      trainedModelArn: '{{ item.trainedModelArn }}'
      trainedModelVersionIdentifier: '{{ item.trainedModelVersionIdentifier }}'
      membershipIdentifier: '{{ item.membershipIdentifier }}'
      collaborationIdentifier: '{{ item.collaborationIdentifier }}'
- discovery_id: aws.cleanroomsml.listCollaborationTrainedModelInferenceJobs
  calls:
  - action: listCollaborationTrainedModelInferenceJobs
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.collaborationTrainedModelInferenceJobs }}'
    item:
      trainedModelInferenceJobArn: '{{ item.trainedModelInferenceJobArn }}'
      configuredModelAlgorithmAssociationArn: '{{ item.configuredModelAlgorithmAssociationArn
        }}'
      membershipIdentifier: '{{ item.membershipIdentifier }}'
      trainedModelArn: '{{ item.trainedModelArn }}'
      trainedModelVersionIdentifier: '{{ item.trainedModelVersionIdentifier }}'
      collaborationIdentifier: '{{ item.collaborationIdentifier }}'
      status: '{{ item.status }}'
      outputConfiguration: '{{ item.outputConfiguration }}'
      name: '{{ item.name }}'
      description: '{{ item.description }}'
      metricsStatus: '{{ item.metricsStatus }}'
      metricsStatusDetails: '{{ item.metricsStatusDetails }}'
      logsStatus: '{{ item.logsStatus }}'
      logsStatusDetails: '{{ item.logsStatusDetails }}'
      createTime: '{{ item.createTime }}'
      updateTime: '{{ item.updateTime }}'
      creatorAccountId: '{{ item.creatorAccountId }}'
- discovery_id: aws.cleanroomsml.listCollaborationTrainedModels
  calls:
  - action: listCollaborationTrainedModels
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.collaborationTrainedModels }}'
    item:
      createTime: '{{ item.createTime }}'
      updateTime: '{{ item.updateTime }}'
      trainedModelArn: '{{ item.trainedModelArn }}'
      name: '{{ item.name }}'
      versionIdentifier: '{{ item.versionIdentifier }}'
      incrementalTrainingDataChannels: '{{ item.incrementalTrainingDataChannels }}'
      description: '{{ item.description }}'
      membershipIdentifier: '{{ item.membershipIdentifier }}'
      collaborationIdentifier: '{{ item.collaborationIdentifier }}'
      status: '{{ item.status }}'
      configuredModelAlgorithmAssociationArn: '{{ item.configuredModelAlgorithmAssociationArn
        }}'
      creatorAccountId: '{{ item.creatorAccountId }}'
- discovery_id: aws.cleanroomsml.listConfiguredModelAlgorithmAssociations
  calls:
  - action: listConfiguredModelAlgorithmAssociations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.configuredModelAlgorithmAssociations }}'
    item:
      createTime: '{{ item.createTime }}'
      updateTime: '{{ item.updateTime }}'
      configuredModelAlgorithmAssociationArn: '{{ item.configuredModelAlgorithmAssociationArn
        }}'
      configuredModelAlgorithmArn: '{{ item.configuredModelAlgorithmArn }}'
      name: '{{ item.name }}'
      description: '{{ item.description }}'
      membershipIdentifier: '{{ item.membershipIdentifier }}'
      collaborationIdentifier: '{{ item.collaborationIdentifier }}'
- discovery_id: aws.cleanroomsml.listMlInputChannels
  calls:
  - action: listMlInputChannels
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.mlInputChannelsList }}'
    item:
      createTime: '{{ item.createTime }}'
      updateTime: '{{ item.updateTime }}'
      membershipIdentifier: '{{ item.membershipIdentifier }}'
      collaborationIdentifier: '{{ item.collaborationIdentifier }}'
      name: '{{ item.name }}'
      configuredModelAlgorithmAssociations: '{{ item.configuredModelAlgorithmAssociations
        }}'
      protectedQueryIdentifier: '{{ item.protectedQueryIdentifier }}'
      mlInputChannelArn: '{{ item.mlInputChannelArn }}'
      status: '{{ item.status }}'
      description: '{{ item.description }}'
- discovery_id: aws.cleanroomsml.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tags }}'
- discovery_id: aws.cleanroomsml.listTrainedModelInferenceJobs
  calls:
  - action: listTrainedModelInferenceJobs
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.trainedModelInferenceJobs }}'
    item:
      trainedModelInferenceJobArn: '{{ item.trainedModelInferenceJobArn }}'
      configuredModelAlgorithmAssociationArn: '{{ item.configuredModelAlgorithmAssociationArn
        }}'
      membershipIdentifier: '{{ item.membershipIdentifier }}'
      trainedModelArn: '{{ item.trainedModelArn }}'
      trainedModelVersionIdentifier: '{{ item.trainedModelVersionIdentifier }}'
      collaborationIdentifier: '{{ item.collaborationIdentifier }}'
      status: '{{ item.status }}'
      outputConfiguration: '{{ item.outputConfiguration }}'
      name: '{{ item.name }}'
      description: '{{ item.description }}'
      metricsStatus: '{{ item.metricsStatus }}'
      metricsStatusDetails: '{{ item.metricsStatusDetails }}'
      logsStatus: '{{ item.logsStatus }}'
      logsStatusDetails: '{{ item.logsStatusDetails }}'
      createTime: '{{ item.createTime }}'
      updateTime: '{{ item.updateTime }}'
- discovery_id: aws.cleanroomsml.listTrainedModelVersions
  calls:
  - action: listTrainedModelVersions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.trainedModels }}'
    item:
      createTime: '{{ item.createTime }}'
      updateTime: '{{ item.updateTime }}'
      trainedModelArn: '{{ item.trainedModelArn }}'
      versionIdentifier: '{{ item.versionIdentifier }}'
      incrementalTrainingDataChannels: '{{ item.incrementalTrainingDataChannels }}'
      name: '{{ item.name }}'
      description: '{{ item.description }}'
      membershipIdentifier: '{{ item.membershipIdentifier }}'
      collaborationIdentifier: '{{ item.collaborationIdentifier }}'
      status: '{{ item.status }}'
      configuredModelAlgorithmAssociationArn: '{{ item.configuredModelAlgorithmAssociationArn
        }}'
- discovery_id: aws.cleanroomsml.listTrainedModels
  calls:
  - action: listTrainedModels
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.trainedModels }}'
    item:
      createTime: '{{ item.createTime }}'
      updateTime: '{{ item.updateTime }}'
      trainedModelArn: '{{ item.trainedModelArn }}'
      versionIdentifier: '{{ item.versionIdentifier }}'
      incrementalTrainingDataChannels: '{{ item.incrementalTrainingDataChannels }}'
      name: '{{ item.name }}'
      description: '{{ item.description }}'
      membershipIdentifier: '{{ item.membershipIdentifier }}'
      collaborationIdentifier: '{{ item.collaborationIdentifier }}'
      status: '{{ item.status }}'
      configuredModelAlgorithmAssociationArn: '{{ item.configuredModelAlgorithmAssociationArn
        }}'
checks: []
