version: '1.0'
provider: aws
service: elastictranscoder
services:
  client: elastictranscoder
  module: boto3.client
discovery:
- discovery_id: aws.elastictranscoder.listPipelines
  calls:
  - action: listPipelines
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Pipelines }}'
    item:
      Id: '{{ item.Id }}'
      Arn: '{{ item.Arn }}'
      Name: '{{ item.Name }}'
      Status: '{{ item.Status }}'
      InputBucket: '{{ item.InputBucket }}'
      OutputBucket: '{{ item.OutputBucket }}'
      Role: '{{ item.Role }}'
      AwsKmsKeyArn: '{{ item.AwsKmsKeyArn }}'
      Notifications: '{{ item.Notifications }}'
      ContentConfig: '{{ item.ContentConfig }}'
      ThumbnailConfig: '{{ item.ThumbnailConfig }}'
- discovery_id: aws.elastictranscoder.listPresets
  calls:
  - action: listPresets
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Presets }}'
    item:
      Id: '{{ item.Id }}'
      Arn: '{{ item.Arn }}'
      Name: '{{ item.Name }}'
      Description: '{{ item.Description }}'
      Container: '{{ item.Container }}'
      Audio: '{{ item.Audio }}'
      Video: '{{ item.Video }}'
      Thumbnails: '{{ item.Thumbnails }}'
      Type: '{{ item.Type }}'
- discovery_id: aws.elastictranscoder.listJobsByPipeline
  calls:
  - action: listJobsByPipeline
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Jobs }}'
    item:
      Id: '{{ item.Id }}'
      Arn: '{{ item.Arn }}'
      PipelineId: '{{ item.PipelineId }}'
      Input: '{{ item.Input }}'
      Inputs: '{{ item.Inputs }}'
      Output: '{{ item.Output }}'
      Outputs: '{{ item.Outputs }}'
      OutputKeyPrefix: '{{ item.OutputKeyPrefix }}'
      Playlists: '{{ item.Playlists }}'
      Status: '{{ item.Status }}'
      UserMetadata: '{{ item.UserMetadata }}'
      Timing: '{{ item.Timing }}'
- discovery_id: aws.elastictranscoder.listJobsByStatus
  calls:
  - action: listJobsByStatus
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Jobs }}'
    item:
      Id: '{{ item.Id }}'
      Arn: '{{ item.Arn }}'
      PipelineId: '{{ item.PipelineId }}'
      Input: '{{ item.Input }}'
      Inputs: '{{ item.Inputs }}'
      Output: '{{ item.Output }}'
      Outputs: '{{ item.Outputs }}'
      OutputKeyPrefix: '{{ item.OutputKeyPrefix }}'
      Playlists: '{{ item.Playlists }}'
      Status: '{{ item.Status }}'
      UserMetadata: '{{ item.UserMetadata }}'
      Timing: '{{ item.Timing }}'
- discovery_id: aws.elastictranscoder.readJob
  calls:
  - action: readJob
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Job }}'
    item:
      Id: '{{ item.Id }}'
      Arn: '{{ item.Arn }}'
      PipelineId: '{{ item.PipelineId }}'
      Input: '{{ item.Input }}'
      Inputs: '{{ item.Inputs }}'
      Output: '{{ item.Output }}'
      Outputs: '{{ item.Outputs }}'
      OutputKeyPrefix: '{{ item.OutputKeyPrefix }}'
      Playlists: '{{ item.Playlists }}'
      Status: '{{ item.Status }}'
      UserMetadata: '{{ item.UserMetadata }}'
      Timing: '{{ item.Timing }}'
- discovery_id: aws.elastictranscoder.readPipeline
  calls:
  - action: readPipeline
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Warnings }}'
    item:
      Code: '{{ item.Code }}'
      Message: '{{ item.Message }}'
- discovery_id: aws.elastictranscoder.readPreset
  calls:
  - action: readPreset
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Preset }}'
    item:
      Id: '{{ item.Id }}'
      Arn: '{{ item.Arn }}'
      Name: '{{ item.Name }}'
      Description: '{{ item.Description }}'
      Container: '{{ item.Container }}'
      Audio: '{{ item.Audio }}'
      Video: '{{ item.Video }}'
      Thumbnails: '{{ item.Thumbnails }}'
      Type: '{{ item.Type }}'
checks: []
