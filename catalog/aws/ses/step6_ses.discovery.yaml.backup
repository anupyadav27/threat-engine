version: '1.0'
provider: aws
service: ses
services:
  client: ses
  module: boto3.client
discovery:
- discovery_id: aws.ses.describeActiveReceiptRuleSet
  calls:
  - action: describeActiveReceiptRuleSet
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Rules }}'
    item:
      Name: '{{ item.Name }}'
      Enabled: '{{ item.Enabled }}'
      TlsPolicy: '{{ item.TlsPolicy }}'
      Recipients: '{{ item.Recipients }}'
      Actions: '{{ item.Actions }}'
      ScanEnabled: '{{ item.ScanEnabled }}'
- discovery_id: aws.ses.getAccountSendingEnabled
  calls:
  - action: getAccountSendingEnabled
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Enabled }}'
- discovery_id: aws.ses.getSendQuota
  calls:
  - action: getSendQuota
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Max24HourSend }}'
- discovery_id: aws.ses.getSendStatistics
  calls:
  - action: getSendStatistics
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.SendDataPoints }}'
    item:
      Timestamp: '{{ item.Timestamp }}'
      DeliveryAttempts: '{{ item.DeliveryAttempts }}'
      Bounces: '{{ item.Bounces }}'
      Complaints: '{{ item.Complaints }}'
      Rejects: '{{ item.Rejects }}'
- discovery_id: aws.ses.listConfigurationSets
  calls:
  - action: listConfigurationSets
    save_as: response
    on_error: continue
    params:
      MaxItems: 1000
  emit:
    as: item
    items_for: '{{ response.ConfigurationSets }}'
    item:
      Name: '{{ item.Name }}'
- discovery_id: aws.ses.listCustomVerificationEmailTemplates
  calls:
  - action: listCustomVerificationEmailTemplates
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.CustomVerificationEmailTemplates }}'
    item:
      TemplateName: '{{ item.TemplateName }}'
      FromEmailAddress: '{{ item.FromEmailAddress }}'
      TemplateSubject: '{{ item.TemplateSubject }}'
      SuccessRedirectionURL: '{{ item.SuccessRedirectionURL }}'
      FailureRedirectionURL: '{{ item.FailureRedirectionURL }}'
- discovery_id: aws.ses.listIdentities
  calls:
  - action: listIdentities
    save_as: response
    on_error: continue
    params:
      MaxItems: 1000
  emit:
    as: item
    items_for: '{{ response.Identities }}'
- discovery_id: aws.ses.listReceiptFilters
  calls:
  - action: listReceiptFilters
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Filters }}'
    item:
      Name: '{{ item.Name }}'
      IpFilter: '{{ item.IpFilter }}'
- discovery_id: aws.ses.listReceiptRuleSets
  calls:
  - action: listReceiptRuleSets
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.RuleSets }}'
    item:
      Name: '{{ item.Name }}'
      CreatedTimestamp: '{{ item.CreatedTimestamp }}'
- discovery_id: aws.ses.listTemplates
  calls:
  - action: listTemplates
    save_as: response
    on_error: continue
    params:
      MaxItems: 1000
  emit:
    as: item
    items_for: '{{ response.TemplatesMetadata }}'
    item:
      Name: '{{ item.Name }}'
      CreatedTimestamp: '{{ item.CreatedTimestamp }}'
- discovery_id: aws.ses.listVerifiedEmailAddresses
  calls:
  - action: listVerifiedEmailAddresses
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.VerifiedEmailAddresses }}'
- discovery_id: aws.ses.describeConfigurationSet
  calls:
  - action: describeConfigurationSet
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.EventDestinations }}'
    item:
      Name: '{{ item.Name }}'
      Enabled: '{{ item.Enabled }}'
      MatchingEventTypes: '{{ item.MatchingEventTypes }}'
      KinesisFirehoseDestination: '{{ item.KinesisFirehoseDestination }}'
      CloudWatchDestination: '{{ item.CloudWatchDestination }}'
      SNSDestination: '{{ item.SNSDestination }}'
- discovery_id: aws.ses.describeReceiptRule
  calls:
  - action: describeReceiptRule
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Rule }}'
    item:
      Name: '{{ item.Name }}'
      Enabled: '{{ item.Enabled }}'
      TlsPolicy: '{{ item.TlsPolicy }}'
      Recipients: '{{ item.Recipients }}'
      Actions: '{{ item.Actions }}'
      ScanEnabled: '{{ item.ScanEnabled }}'
- discovery_id: aws.ses.describeReceiptRuleSet
  calls:
  - action: describeReceiptRuleSet
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Rules }}'
    item:
      Name: '{{ item.Name }}'
      Enabled: '{{ item.Enabled }}'
      TlsPolicy: '{{ item.TlsPolicy }}'
      Recipients: '{{ item.Recipients }}'
      Actions: '{{ item.Actions }}'
      ScanEnabled: '{{ item.ScanEnabled }}'
- discovery_id: aws.ses.getCustomVerificationEmailTemplate
  calls:
  - action: getCustomVerificationEmailTemplate
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.TemplateName }}'
- discovery_id: aws.ses.getIdentityDkimAttributes
  calls:
  - action: getIdentityDkimAttributes
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.DkimAttributes }}'
- discovery_id: aws.ses.getIdentityMailFromDomainAttributes
  calls:
  - action: getIdentityMailFromDomainAttributes
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.MailFromDomainAttributes }}'
- discovery_id: aws.ses.getIdentityNotificationAttributes
  calls:
  - action: getIdentityNotificationAttributes
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.NotificationAttributes }}'
- discovery_id: aws.ses.getIdentityPolicies
  calls:
  - action: getIdentityPolicies
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Policies }}'
- discovery_id: aws.ses.getIdentityVerificationAttributes
  calls:
  - action: getIdentityVerificationAttributes
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.VerificationAttributes }}'
- discovery_id: aws.ses.getTemplate
  calls:
  - action: getTemplate
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Template }}'
    item:
      TemplateName: '{{ item.TemplateName }}'
      SubjectPart: '{{ item.SubjectPart }}'
      TextPart: '{{ item.TextPart }}'
      HtmlPart: '{{ item.HtmlPart }}'
- discovery_id: aws.ses.listIdentityPolicies
  calls:
  - action: listIdentityPolicies
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.PolicyNames }}'
checks: []
