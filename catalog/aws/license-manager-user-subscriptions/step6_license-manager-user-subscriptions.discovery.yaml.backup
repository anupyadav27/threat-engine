version: '1.0'
provider: aws
service: license-manager-user-subscriptions
services:
  client: license-manager-user-subscriptions
  module: boto3.client
discovery:
- discovery_id: aws.license-manager-user-subscriptions.listIdentityProviders
  calls:
  - action: listIdentityProviders
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.IdentityProviderSummaries }}'
    item:
      IdentityProvider: '{{ item.IdentityProvider }}'
      Settings: '{{ item.Settings }}'
      Product: '{{ item.Product }}'
      Status: '{{ item.Status }}'
      IdentityProviderArn: '{{ item.IdentityProviderArn }}'
      FailureMessage: '{{ item.FailureMessage }}'
      OwnerAccountId: '{{ item.OwnerAccountId }}'
- discovery_id: aws.license-manager-user-subscriptions.listInstances
  calls:
  - action: listInstances
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.InstanceSummaries }}'
    item:
      InstanceId: '{{ item.InstanceId }}'
      Status: '{{ item.Status }}'
      Products: '{{ item.Products }}'
      LastStatusCheckDate: '{{ item.LastStatusCheckDate }}'
      StatusMessage: '{{ item.StatusMessage }}'
      OwnerAccountId: '{{ item.OwnerAccountId }}'
      IdentityProvider: '{{ item.IdentityProvider }}'
- discovery_id: aws.license-manager-user-subscriptions.listLicenseServerEndpoints
  calls:
  - action: listLicenseServerEndpoints
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.LicenseServerEndpoints }}'
    item:
      IdentityProviderArn: '{{ item.IdentityProviderArn }}'
      ServerType: '{{ item.ServerType }}'
      ServerEndpoint: '{{ item.ServerEndpoint }}'
      StatusMessage: '{{ item.StatusMessage }}'
      LicenseServerEndpointId: '{{ item.LicenseServerEndpointId }}'
      LicenseServerEndpointArn: '{{ item.LicenseServerEndpointArn }}'
      LicenseServerEndpointProvisioningStatus: '{{ item.LicenseServerEndpointProvisioningStatus
        }}'
      LicenseServers: '{{ item.LicenseServers }}'
      CreationTime: '{{ item.CreationTime }}'
- discovery_id: aws.license-manager-user-subscriptions.listProductSubscriptions
  calls:
  - action: listProductSubscriptions
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.ProductUserSummaries }}'
    item:
      Username: '{{ item.Username }}'
      Product: '{{ item.Product }}'
      IdentityProvider: '{{ item.IdentityProvider }}'
      Status: '{{ item.Status }}'
      ProductUserArn: '{{ item.ProductUserArn }}'
      StatusMessage: '{{ item.StatusMessage }}'
      Domain: '{{ item.Domain }}'
      SubscriptionStartDate: '{{ item.SubscriptionStartDate }}'
      SubscriptionEndDate: '{{ item.SubscriptionEndDate }}'
- discovery_id: aws.license-manager-user-subscriptions.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Tags }}'
- discovery_id: aws.license-manager-user-subscriptions.listUserAssociations
  calls:
  - action: listUserAssociations
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.InstanceUserSummaries }}'
    item:
      Username: '{{ item.Username }}'
      InstanceId: '{{ item.InstanceId }}'
      IdentityProvider: '{{ item.IdentityProvider }}'
      Status: '{{ item.Status }}'
      InstanceUserArn: '{{ item.InstanceUserArn }}'
      StatusMessage: '{{ item.StatusMessage }}'
      Domain: '{{ item.Domain }}'
      AssociationDate: '{{ item.AssociationDate }}'
      DisassociationDate: '{{ item.DisassociationDate }}'
checks: []
