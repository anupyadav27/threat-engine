version: '1.0'
provider: aws
service: geo-places
services:
  client: geo-places
  module: boto3.client
discovery:
- discovery_id: aws.geo-places.searchText
  calls:
  - action: searchText
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ResultItems }}'
    item:
      PlaceId: '{{ item.PlaceId }}'
      PlaceType: '{{ item.PlaceType }}'
      Title: '{{ item.Title }}'
      Address: '{{ item.Address }}'
      AddressNumberCorrected: '{{ item.AddressNumberCorrected }}'
      Position: '{{ item.Position }}'
      Distance: '{{ item.Distance }}'
      MapView: '{{ item.MapView }}'
      Categories: '{{ item.Categories }}'
      FoodTypes: '{{ item.FoodTypes }}'
      BusinessChains: '{{ item.BusinessChains }}'
      Contacts: '{{ item.Contacts }}'
      OpeningHours: '{{ item.OpeningHours }}'
      AccessPoints: '{{ item.AccessPoints }}'
      AccessRestrictions: '{{ item.AccessRestrictions }}'
      TimeZone: '{{ item.TimeZone }}'
      PoliticalView: '{{ item.PoliticalView }}'
      Phonemes: '{{ item.Phonemes }}'
- discovery_id: aws.geo-places.getPlace
  calls:
  - action: getPlace
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.PostalCodeDetails }}'
    item:
      PostalCode: '{{ item.PostalCode }}'
      PostalAuthority: '{{ item.PostalAuthority }}'
      PostalCodeType: '{{ item.PostalCodeType }}'
      UspsZip: '{{ item.UspsZip }}'
      UspsZipPlus4: '{{ item.UspsZipPlus4 }}'
- discovery_id: aws.geo-places.searchNearby
  calls:
  - action: searchNearby
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ResultItems }}'
    item:
      PlaceId: '{{ item.PlaceId }}'
      PlaceType: '{{ item.PlaceType }}'
      Title: '{{ item.Title }}'
      Address: '{{ item.Address }}'
      AddressNumberCorrected: '{{ item.AddressNumberCorrected }}'
      Position: '{{ item.Position }}'
      Distance: '{{ item.Distance }}'
      MapView: '{{ item.MapView }}'
      Categories: '{{ item.Categories }}'
      FoodTypes: '{{ item.FoodTypes }}'
      BusinessChains: '{{ item.BusinessChains }}'
      Contacts: '{{ item.Contacts }}'
      OpeningHours: '{{ item.OpeningHours }}'
      AccessPoints: '{{ item.AccessPoints }}'
      AccessRestrictions: '{{ item.AccessRestrictions }}'
      TimeZone: '{{ item.TimeZone }}'
      PoliticalView: '{{ item.PoliticalView }}'
      Phonemes: '{{ item.Phonemes }}'
checks: []
