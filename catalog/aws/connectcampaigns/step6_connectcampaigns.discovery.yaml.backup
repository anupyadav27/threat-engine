version: '1.0'
provider: aws
service: connectcampaigns
services:
  client: connectcampaigns
  module: boto3.client
discovery:
- discovery_id: aws.connectcampaigns.listCampaigns
  calls:
  - action: listCampaigns
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.campaignSummaryList }}'
    item:
      id: '{{ item.id }}'
      arn: '{{ item.arn }}'
      name: '{{ item.name }}'
      connectInstanceId: '{{ item.connectInstanceId }}'
- discovery_id: aws.connectcampaigns.describeCampaign
  calls:
  - action: describeCampaign
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.campaign }}'
    item:
      id: '{{ item.id }}'
      arn: '{{ item.arn }}'
      name: '{{ item.name }}'
      connectInstanceId: '{{ item.connectInstanceId }}'
      dialerConfig: '{{ item.dialerConfig }}'
      outboundCallConfig: '{{ item.outboundCallConfig }}'
      tags: '{{ item.tags }}'
- discovery_id: aws.connectcampaigns.getCampaignState
  calls:
  - action: getCampaignState
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.state }}'
- discovery_id: aws.connectcampaigns.getCampaignStateBatch
  calls:
  - action: getCampaignStateBatch
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.successfulRequests }}'
    item:
      campaignId: '{{ item.campaignId }}'
      state: '{{ item.state }}'
- discovery_id: aws.connectcampaigns.getConnectInstanceConfig
  calls:
  - action: getConnectInstanceConfig
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.connectInstanceConfig }}'
    item:
      connectInstanceId: '{{ item.connectInstanceId }}'
      serviceLinkedRoleArn: '{{ item.serviceLinkedRoleArn }}'
      encryptionConfig: '{{ item.encryptionConfig }}'
- discovery_id: aws.connectcampaigns.getInstanceOnboardingJobStatus
  calls:
  - action: getInstanceOnboardingJobStatus
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.connectInstanceOnboardingJobStatus }}'
    item:
      connectInstanceId: '{{ item.connectInstanceId }}'
      status: '{{ item.status }}'
      failureCode: '{{ item.failureCode }}'
- discovery_id: aws.connectcampaigns.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tags }}'
checks: []
