    items_for: '{{ response.items }}'
    item:
      taskId: '{{ item.taskId }}'
      status: '{{ item.status }}'
      name: '{{ item.name }}'
      cpus: '{{ item.cpus }}'
      cacheHit: '{{ item.cacheHit }}'
      cacheS3Uri: '{{ item.cacheS3Uri }}'
      memory: '{{ item.memory }}'
      creationTime: '{{ item.creationTime }}'
      startTime: '{{ item.startTime }}'
      stopTime: '{{ item.stopTime }}'
      gpus: '{{ item.gpus }}'
      instanceType: '{{ item.instanceType }}'
- discovery_id: aws.omics.listShares
  calls:
  - action: listShares
    save_as: response
    on_error: continue
  emit:
