version: '1.0'
provider: aws
service: omics
services:
  client: omics
  module: boto3.client
discovery:
- discovery_id: aws.omics.listAnnotationImportJobs
  calls:
  - action: listAnnotationImportJobs
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.annotationImportJobs }}'
    item:
      id: '{{ item.id }}'
      destinationName: '{{ item.destinationName }}'
      versionName: '{{ item.versionName }}'
      roleArn: '{{ item.roleArn }}'
      status: '{{ item.status }}'
      creationTime: '{{ item.creationTime }}'
      updateTime: '{{ item.updateTime }}'
      completionTime: '{{ item.completionTime }}'
      runLeftNormalization: '{{ item.runLeftNormalization }}'
      annotationFields: '{{ item.annotationFields }}'
- discovery_id: aws.omics.listAnnotationStores
  calls:
  - action: listAnnotationStores
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.annotationStores }}'
    item:
      id: '{{ item.id }}'
      reference: '{{ item.reference }}'
      status: '{{ item.status }}'
      storeArn: '{{ item.storeArn }}'
      name: '{{ item.name }}'
      storeFormat: '{{ item.storeFormat }}'
      description: '{{ item.description }}'
      sseConfig: '{{ item.sseConfig }}'
      creationTime: '{{ item.creationTime }}'
      updateTime: '{{ item.updateTime }}'
      statusMessage: '{{ item.statusMessage }}'
      storeSizeBytes: '{{ item.storeSizeBytes }}'
- discovery_id: aws.omics.listReferenceStores
  calls:
  - action: listReferenceStores
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.referenceStores }}'
    item:
      arn: '{{ item.arn }}'
      id: '{{ item.id }}'
      name: '{{ item.name }}'
      description: '{{ item.description }}'
      sseConfig: '{{ item.sseConfig }}'
      creationTime: '{{ item.creationTime }}'
- discovery_id: aws.omics.listRunCaches
  calls:
  - action: listRunCaches
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
    item:
      arn: '{{ item.arn }}'
      cacheBehavior: '{{ item.cacheBehavior }}'
      cacheS3Uri: '{{ item.cacheS3Uri }}'
      creationTime: '{{ item.creationTime }}'
      id: '{{ item.id }}'
      name: '{{ item.name }}'
      status: '{{ item.status }}'
- discovery_id: aws.omics.listRunGroups
  calls:
  - action: listRunGroups
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
    item:
      arn: '{{ item.arn }}'
      id: '{{ item.id }}'
      name: '{{ item.name }}'
      maxCpus: '{{ item.maxCpus }}'
      maxRuns: '{{ item.maxRuns }}'
      maxDuration: '{{ item.maxDuration }}'
      creationTime: '{{ item.creationTime }}'
      maxGpus: '{{ item.maxGpus }}'
- discovery_id: aws.omics.listRuns
  calls:
  - action: listRuns
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
    item:
      arn: '{{ item.arn }}'
      id: '{{ item.id }}'
      status: '{{ item.status }}'
      workflowId: '{{ item.workflowId }}'
      name: '{{ item.name }}'
      priority: '{{ item.priority }}'
      storageCapacity: '{{ item.storageCapacity }}'
      creationTime: '{{ item.creationTime }}'
      startTime: '{{ item.startTime }}'
      stopTime: '{{ item.stopTime }}'
      storageType: '{{ item.storageType }}'
      workflowVersionName: '{{ item.workflowVersionName }}'
- discovery_id: aws.omics.listSequenceStores
  calls:
  - action: listSequenceStores
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.sequenceStores }}'
    item:
      arn: '{{ item.arn }}'
      id: '{{ item.id }}'
      name: '{{ item.name }}'
      description: '{{ item.description }}'
      sseConfig: '{{ item.sseConfig }}'
      creationTime: '{{ item.creationTime }}'
      fallbackLocation: '{{ item.fallbackLocation }}'
      eTagAlgorithmFamily: '{{ item.eTagAlgorithmFamily }}'
      status: '{{ item.status }}'
      statusMessage: '{{ item.statusMessage }}'
      updateTime: '{{ item.updateTime }}'
- discovery_id: aws.omics.listVariantImportJobs
  calls:
  - action: listVariantImportJobs
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.variantImportJobs }}'
    item:
      id: '{{ item.id }}'
      destinationName: '{{ item.destinationName }}'
      roleArn: '{{ item.roleArn }}'
      status: '{{ item.status }}'
      creationTime: '{{ item.creationTime }}'
      updateTime: '{{ item.updateTime }}'
      completionTime: '{{ item.completionTime }}'
      runLeftNormalization: '{{ item.runLeftNormalization }}'
      annotationFields: '{{ item.annotationFields }}'
- discovery_id: aws.omics.listVariantStores
  calls:
  - action: listVariantStores
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.variantStores }}'
    item:
      id: '{{ item.id }}'
      reference: '{{ item.reference }}'
      status: '{{ item.status }}'
      storeArn: '{{ item.storeArn }}'
      name: '{{ item.name }}'
      description: '{{ item.description }}'
      sseConfig: '{{ item.sseConfig }}'
      creationTime: '{{ item.creationTime }}'
      updateTime: '{{ item.updateTime }}'
      statusMessage: '{{ item.statusMessage }}'
      storeSizeBytes: '{{ item.storeSizeBytes }}'
- discovery_id: aws.omics.listWorkflows
  calls:
  - action: listWorkflows
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
    item:
      arn: '{{ item.arn }}'
      id: '{{ item.id }}'
      name: '{{ item.name }}'
      status: '{{ item.status }}'
      type: '{{ item.type }}'
      digest: '{{ item.digest }}'
      creationTime: '{{ item.creationTime }}'
      metadata: '{{ item.metadata }}'
- discovery_id: aws.omics.getAnnotationImportJob
  calls:
  - action: getAnnotationImportJob
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
    item:
      source: '{{ item.source }}'
      jobStatus: '{{ item.jobStatus }}'
- discovery_id: aws.omics.getAnnotationStore
  calls:
  - action: getAnnotationStore
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.reference }}'
    item:
      referenceArn: '{{ item.referenceArn }}'
- discovery_id: aws.omics.getAnnotationStoreVersion
  calls:
  - action: getAnnotationStoreVersion
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.versionOptions }}'
    item:
      tsvVersionOptions: '{{ item.tsvVersionOptions }}'
- discovery_id: aws.omics.getReadSet
  calls:
  - action: getReadSet
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.payload }}'
- discovery_id: aws.omics.getReadSetActivationJob
  calls:
  - action: getReadSetActivationJob
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.sources }}'
    item:
      readSetId: '{{ item.readSetId }}'
      status: '{{ item.status }}'
      statusMessage: '{{ item.statusMessage }}'
- discovery_id: aws.omics.getReadSetExportJob
  calls:
  - action: getReadSetExportJob
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.readSets }}'
    item:
      id: '{{ item.id }}'
      status: '{{ item.status }}'
      statusMessage: '{{ item.statusMessage }}'
- discovery_id: aws.omics.getReadSetImportJob
  calls:
  - action: getReadSetImportJob
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.sources }}'
    item:
      sourceFiles: '{{ item.sourceFiles }}'
      sourceFileType: '{{ item.sourceFileType }}'
      status: '{{ item.status }}'
      statusMessage: '{{ item.statusMessage }}'
      subjectId: '{{ item.subjectId }}'
      sampleId: '{{ item.sampleId }}'
      generatedFrom: '{{ item.generatedFrom }}'
      referenceArn: '{{ item.referenceArn }}'
      name: '{{ item.name }}'
      description: '{{ item.description }}'
      tags: '{{ item.tags }}'
      readSetId: '{{ item.readSetId }}'
- discovery_id: aws.omics.getReadSetMetadata
  calls:
  - action: getReadSetMetadata
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.sequenceInformation }}'
    item:
      totalReadCount: '{{ item.totalReadCount }}'
      totalBaseCount: '{{ item.totalBaseCount }}'
      generatedFrom: '{{ item.generatedFrom }}'
      alignment: '{{ item.alignment }}'
- discovery_id: aws.omics.getReference
  calls:
  - action: getReference
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.payload }}'
- discovery_id: aws.omics.getReferenceImportJob
  calls:
  - action: getReferenceImportJob
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.sources }}'
    item:
      sourceFile: '{{ item.sourceFile }}'
      status: '{{ item.status }}'
      statusMessage: '{{ item.statusMessage }}'
      name: '{{ item.name }}'
      description: '{{ item.description }}'
      tags: '{{ item.tags }}'
      referenceId: '{{ item.referenceId }}'
- discovery_id: aws.omics.getReferenceMetadata
  calls:
  - action: getReferenceMetadata
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.files }}'
    item:
      source: '{{ item.source }}'
      index: '{{ item.index }}'
- discovery_id: aws.omics.getReferenceStore
  calls:
  - action: getReferenceStore
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.sseConfig }}'
    item:
      type: '{{ item.type }}'
      keyArn: '{{ item.keyArn }}'
- discovery_id: aws.omics.getRun
  calls:
  - action: getRun
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.parameters }}'
- discovery_id: aws.omics.getRunCache
  calls:
  - action: getRunCache
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.arn }}'
- discovery_id: aws.omics.getRunGroup
  calls:
  - action: getRunGroup
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.arn }}'
- discovery_id: aws.omics.getRunTask
  calls:
  - action: getRunTask
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.imageDetails }}'
    item:
      image: '{{ item.image }}'
      imageDigest: '{{ item.imageDigest }}'
      sourceImage: '{{ item.sourceImage }}'
- discovery_id: aws.omics.getS3AccessPolicy
  calls:
  - action: getS3AccessPolicy
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.s3AccessPointArn }}'
- discovery_id: aws.omics.getSequenceStore
  calls:
  - action: getSequenceStore
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.propagatedSetLevelTags }}'
- discovery_id: aws.omics.getShare
  calls:
  - action: getShare
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.share }}'
    item:
      shareId: '{{ item.shareId }}'
      resourceArn: '{{ item.resourceArn }}'
      resourceId: '{{ item.resourceId }}'
      principalSubscriber: '{{ item.principalSubscriber }}'
      ownerId: '{{ item.ownerId }}'
      status: '{{ item.status }}'
      statusMessage: '{{ item.statusMessage }}'
      shareName: '{{ item.shareName }}'
      creationTime: '{{ item.creationTime }}'
      updateTime: '{{ item.updateTime }}'
- discovery_id: aws.omics.getVariantImportJob
  calls:
  - action: getVariantImportJob
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
    item:
      source: '{{ item.source }}'
      jobStatus: '{{ item.jobStatus }}'
      statusMessage: '{{ item.statusMessage }}'
- discovery_id: aws.omics.getVariantStore
  calls:
  - action: getVariantStore
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.reference }}'
    item:
      referenceArn: '{{ item.referenceArn }}'
- discovery_id: aws.omics.getWorkflow
  calls:
  - action: getWorkflow
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.containerRegistryMap }}'
    item:
      registryMappings: '{{ item.registryMappings }}'
      imageMappings: '{{ item.imageMappings }}'
- discovery_id: aws.omics.getWorkflowVersion
  calls:
  - action: getWorkflowVersion
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.containerRegistryMap }}'
    item:
      registryMappings: '{{ item.registryMappings }}'
      imageMappings: '{{ item.imageMappings }}'
- discovery_id: aws.omics.listAnnotationStoreVersions
  calls:
  - action: listAnnotationStoreVersions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.annotationStoreVersions }}'
    item:
      storeId: '{{ item.storeId }}'
      id: '{{ item.id }}'
      status: '{{ item.status }}'
      versionArn: '{{ item.versionArn }}'
      name: '{{ item.name }}'
      versionName: '{{ item.versionName }}'
      description: '{{ item.description }}'
      creationTime: '{{ item.creationTime }}'
      updateTime: '{{ item.updateTime }}'
      statusMessage: '{{ item.statusMessage }}'
      versionSizeBytes: '{{ item.versionSizeBytes }}'
- discovery_id: aws.omics.listMultipartReadSetUploads
  calls:
  - action: listMultipartReadSetUploads
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.uploads }}'
    item:
      sequenceStoreId: '{{ item.sequenceStoreId }}'
      uploadId: '{{ item.uploadId }}'
      sourceFileType: '{{ item.sourceFileType }}'
      subjectId: '{{ item.subjectId }}'
      sampleId: '{{ item.sampleId }}'
      generatedFrom: '{{ item.generatedFrom }}'
      referenceArn: '{{ item.referenceArn }}'
      name: '{{ item.name }}'
      description: '{{ item.description }}'
      tags: '{{ item.tags }}'
      creationTime: '{{ item.creationTime }}'
- discovery_id: aws.omics.listReadSetActivationJobs
  calls:
  - action: listReadSetActivationJobs
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.activationJobs }}'
    item:
      id: '{{ item.id }}'
      sequenceStoreId: '{{ item.sequenceStoreId }}'
      status: '{{ item.status }}'
      creationTime: '{{ item.creationTime }}'
      completionTime: '{{ item.completionTime }}'
- discovery_id: aws.omics.listReadSetExportJobs
  calls:
  - action: listReadSetExportJobs
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.exportJobs }}'
    item:
      id: '{{ item.id }}'
      sequenceStoreId: '{{ item.sequenceStoreId }}'
      destination: '{{ item.destination }}'
      status: '{{ item.status }}'
      creationTime: '{{ item.creationTime }}'
      completionTime: '{{ item.completionTime }}'
- discovery_id: aws.omics.listReadSetImportJobs
  calls:
  - action: listReadSetImportJobs
    save_as: response
    on_error: continue
  emit:
