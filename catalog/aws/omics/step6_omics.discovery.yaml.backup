    items_for: '{{ response.importJobs }}'
    item:
      id: '{{ item.id }}'
      sequenceStoreId: '{{ item.sequenceStoreId }}'
      roleArn: '{{ item.roleArn }}'
      status: '{{ item.status }}'
      creationTime: '{{ item.creationTime }}'
      completionTime: '{{ item.completionTime }}'
- discovery_id: aws.omics.listReadSetUploadParts
  calls:
  - action: listReadSetUploadParts
    save_as: response
    on_error: continue
  emit:
