      status: '{{ item.status }}'
      name: '{{ item.name }}'
      description: '{{ item.description }}'
      referenceArn: '{{ item.referenceArn }}'
      fileType: '{{ item.fileType }}'
      sequenceInformation: '{{ item.sequenceInformation }}'
      creationTime: '{{ item.creationTime }}'
      statusMessage: '{{ item.statusMessage }}'
      creationType: '{{ item.creationType }}'
      etag: '{{ item.etag }}'
- discovery_id: aws.omics.listReferenceImportJobs
  calls:
  - action: listReferenceImportJobs
    save_as: response
    on_error: continue
  emit:
