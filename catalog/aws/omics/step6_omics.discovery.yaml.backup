    item:
      shareId: '{{ item.shareId }}'
      resourceArn: '{{ item.resourceArn }}'
      resourceId: '{{ item.resourceId }}'
      principalSubscriber: '{{ item.principalSubscriber }}'
      ownerId: '{{ item.ownerId }}'
      status: '{{ item.status }}'
      statusMessage: '{{ item.statusMessage }}'
      shareName: '{{ item.shareName }}'
      creationTime: '{{ item.creationTime }}'
      updateTime: '{{ item.updateTime }}'
- discovery_id: aws.omics.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tags }}'
- discovery_id: aws.omics.listWorkflowVersions
  calls:
  - action: listWorkflowVersions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
    item:
      arn: '{{ item.arn }}'
      workflowId: '{{ item.workflowId }}'
      versionName: '{{ item.versionName }}'
      description: '{{ item.description }}'
      status: '{{ item.status }}'
      type: '{{ item.type }}'
      digest: '{{ item.digest }}'
      creationTime: '{{ item.creationTime }}'
      metadata: '{{ item.metadata }}'
checks: []
