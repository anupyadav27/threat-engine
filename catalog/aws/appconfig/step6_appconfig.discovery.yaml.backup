version: '1.0'
provider: aws
service: appconfig
services:
  client: appconfig
  module: boto3.client
discovery:
- discovery_id: aws.appconfig.getAccountSettings
  calls:
  - action: getAccountSettings
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.DeletionProtection }}'
    item:
      Enabled: '{{ item.Enabled }}'
      ProtectionPeriodInMinutes: '{{ item.ProtectionPeriodInMinutes }}'
- discovery_id: aws.appconfig.listApplications
  calls:
  - action: listApplications
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Items }}'
    item:
      Id: '{{ item.Id }}'
      Name: '{{ item.Name }}'
      Description: '{{ item.Description }}'
- discovery_id: aws.appconfig.listDeploymentStrategies
  calls:
  - action: listDeploymentStrategies
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Items }}'
    item:
      Id: '{{ item.Id }}'
      Name: '{{ item.Name }}'
      Description: '{{ item.Description }}'
      DeploymentDurationInMinutes: '{{ item.DeploymentDurationInMinutes }}'
      GrowthType: '{{ item.GrowthType }}'
      GrowthFactor: '{{ item.GrowthFactor }}'
      FinalBakeTimeInMinutes: '{{ item.FinalBakeTimeInMinutes }}'
      ReplicateTo: '{{ item.ReplicateTo }}'
- discovery_id: aws.appconfig.listExtensionAssociations
  calls:
  - action: listExtensionAssociations
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Items }}'
    item:
      Id: '{{ item.Id }}'
      ExtensionArn: '{{ item.ExtensionArn }}'
      ResourceArn: '{{ item.ResourceArn }}'
- discovery_id: aws.appconfig.listExtensions
  calls:
  - action: listExtensions
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Items }}'
    item:
      Id: '{{ item.Id }}'
      Name: '{{ item.Name }}'
      VersionNumber: '{{ item.VersionNumber }}'
      Arn: '{{ item.Arn }}'
      Description: '{{ item.Description }}'
- discovery_id: aws.appconfig.getApplication
  calls:
  - action: getApplication
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Id }}'
- discovery_id: aws.appconfig.getConfiguration
  calls:
  - action: getConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Content }}'
- discovery_id: aws.appconfig.getConfigurationProfile
  calls:
  - action: getConfigurationProfile
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Validators }}'
    item:
      Type: '{{ item.Type }}'
      Content: '{{ item.Content }}'
- discovery_id: aws.appconfig.getDeployment
  calls:
  - action: getDeployment
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.EventLog }}'
    item:
      EventType: '{{ item.EventType }}'
      TriggeredBy: '{{ item.TriggeredBy }}'
      Description: '{{ item.Description }}'
      ActionInvocations: '{{ item.ActionInvocations }}'
      OccurredAt: '{{ item.OccurredAt }}'
- discovery_id: aws.appconfig.getDeploymentStrategy
  calls:
  - action: getDeploymentStrategy
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Id }}'
- discovery_id: aws.appconfig.getEnvironment
  calls:
  - action: getEnvironment
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Monitors }}'
    item:
      AlarmArn: '{{ item.AlarmArn }}'
      AlarmRoleArn: '{{ item.AlarmRoleArn }}'
- discovery_id: aws.appconfig.getExtension
  calls:
  - action: getExtension
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Id }}'
- discovery_id: aws.appconfig.getExtensionAssociation
  calls:
  - action: getExtensionAssociation
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Id }}'
- discovery_id: aws.appconfig.getHostedConfigurationVersion
  calls:
  - action: getHostedConfigurationVersion
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ApplicationId }}'
- discovery_id: aws.appconfig.listConfigurationProfiles
  calls:
  - action: listConfigurationProfiles
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Items }}'
    item:
      ApplicationId: '{{ item.ApplicationId }}'
      Id: '{{ item.Id }}'
      Name: '{{ item.Name }}'
      LocationUri: '{{ item.LocationUri }}'
      ValidatorTypes: '{{ item.ValidatorTypes }}'
      Type: '{{ item.Type }}'
- discovery_id: aws.appconfig.listDeployments
  calls:
  - action: listDeployments
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Items }}'
    item:
      DeploymentNumber: '{{ item.DeploymentNumber }}'
      ConfigurationName: '{{ item.ConfigurationName }}'
      ConfigurationVersion: '{{ item.ConfigurationVersion }}'
      DeploymentDurationInMinutes: '{{ item.DeploymentDurationInMinutes }}'
      GrowthType: '{{ item.GrowthType }}'
      GrowthFactor: '{{ item.GrowthFactor }}'
      FinalBakeTimeInMinutes: '{{ item.FinalBakeTimeInMinutes }}'
      State: '{{ item.State }}'
      PercentageComplete: '{{ item.PercentageComplete }}'
      StartedAt: '{{ item.StartedAt }}'
      CompletedAt: '{{ item.CompletedAt }}'
      VersionLabel: '{{ item.VersionLabel }}'
- discovery_id: aws.appconfig.listEnvironments
  calls:
  - action: listEnvironments
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Items }}'
    item:
      ApplicationId: '{{ item.ApplicationId }}'
      Id: '{{ item.Id }}'
      Name: '{{ item.Name }}'
      Description: '{{ item.Description }}'
      State: '{{ item.State }}'
      Monitors: '{{ item.Monitors }}'
- discovery_id: aws.appconfig.listHostedConfigurationVersions
  calls:
  - action: listHostedConfigurationVersions
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Items }}'
    item:
      ApplicationId: '{{ item.ApplicationId }}'
      ConfigurationProfileId: '{{ item.ConfigurationProfileId }}'
      VersionNumber: '{{ item.VersionNumber }}'
      Description: '{{ item.Description }}'
      ContentType: '{{ item.ContentType }}'
      VersionLabel: '{{ item.VersionLabel }}'
      KmsKeyArn: '{{ item.KmsKeyArn }}'
- discovery_id: aws.appconfig.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Tags }}'
checks: []
