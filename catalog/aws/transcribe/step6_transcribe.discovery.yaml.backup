version: '1.0'
provider: aws
service: transcribe
services:
  client: transcribe
  module: boto3.client
discovery:
- discovery_id: aws.transcribe.listCallAnalyticsCategories
  calls:
  - action: listCallAnalyticsCategories
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Categories }}'
    item:
      CategoryName: '{{ item.CategoryName }}'
      Rules: '{{ item.Rules }}'
      CreateTime: '{{ item.CreateTime }}'
      LastUpdateTime: '{{ item.LastUpdateTime }}'
      Tags: '{{ item.Tags }}'
      InputType: '{{ item.InputType }}'
- discovery_id: aws.transcribe.listCallAnalyticsJobs
  calls:
  - action: listCallAnalyticsJobs
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.CallAnalyticsJobSummaries }}'
    item:
      CallAnalyticsJobName: '{{ item.CallAnalyticsJobName }}'
      CreationTime: '{{ item.CreationTime }}'
      StartTime: '{{ item.StartTime }}'
      CompletionTime: '{{ item.CompletionTime }}'
      LanguageCode: '{{ item.LanguageCode }}'
      CallAnalyticsJobStatus: '{{ item.CallAnalyticsJobStatus }}'
      CallAnalyticsJobDetails: '{{ item.CallAnalyticsJobDetails }}'
      FailureReason: '{{ item.FailureReason }}'
- discovery_id: aws.transcribe.listLanguageModels
  calls:
  - action: listLanguageModels
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Models }}'
    item:
      ModelName: '{{ item.ModelName }}'
      CreateTime: '{{ item.CreateTime }}'
      LastModifiedTime: '{{ item.LastModifiedTime }}'
      LanguageCode: '{{ item.LanguageCode }}'
      BaseModelName: '{{ item.BaseModelName }}'
      ModelStatus: '{{ item.ModelStatus }}'
      UpgradeAvailability: '{{ item.UpgradeAvailability }}'
      FailureReason: '{{ item.FailureReason }}'
      InputDataConfig: '{{ item.InputDataConfig }}'
- discovery_id: aws.transcribe.listMedicalScribeJobs
  calls:
  - action: listMedicalScribeJobs
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.MedicalScribeJobSummaries }}'
    item:
      MedicalScribeJobName: '{{ item.MedicalScribeJobName }}'
      CreationTime: '{{ item.CreationTime }}'
      StartTime: '{{ item.StartTime }}'
      CompletionTime: '{{ item.CompletionTime }}'
      LanguageCode: '{{ item.LanguageCode }}'
      MedicalScribeJobStatus: '{{ item.MedicalScribeJobStatus }}'
      FailureReason: '{{ item.FailureReason }}'
- discovery_id: aws.transcribe.listMedicalTranscriptionJobs
  calls:
  - action: listMedicalTranscriptionJobs
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.MedicalTranscriptionJobSummaries }}'
    item:
      MedicalTranscriptionJobName: '{{ item.MedicalTranscriptionJobName }}'
      CreationTime: '{{ item.CreationTime }}'
      StartTime: '{{ item.StartTime }}'
      CompletionTime: '{{ item.CompletionTime }}'
      LanguageCode: '{{ item.LanguageCode }}'
      TranscriptionJobStatus: '{{ item.TranscriptionJobStatus }}'
      FailureReason: '{{ item.FailureReason }}'
      OutputLocationType: '{{ item.OutputLocationType }}'
      Specialty: '{{ item.Specialty }}'
      ContentIdentificationType: '{{ item.ContentIdentificationType }}'
      Type: '{{ item.Type }}'
- discovery_id: aws.transcribe.listMedicalVocabularies
  calls:
  - action: listMedicalVocabularies
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Vocabularies }}'
    item:
      VocabularyName: '{{ item.VocabularyName }}'
      LanguageCode: '{{ item.LanguageCode }}'
      LastModifiedTime: '{{ item.LastModifiedTime }}'
      VocabularyState: '{{ item.VocabularyState }}'
- discovery_id: aws.transcribe.listTranscriptionJobs
  calls:
  - action: listTranscriptionJobs
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.TranscriptionJobSummaries }}'
    item:
      TranscriptionJobName: '{{ item.TranscriptionJobName }}'
      CreationTime: '{{ item.CreationTime }}'
      StartTime: '{{ item.StartTime }}'
      CompletionTime: '{{ item.CompletionTime }}'
      LanguageCode: '{{ item.LanguageCode }}'
      TranscriptionJobStatus: '{{ item.TranscriptionJobStatus }}'
      FailureReason: '{{ item.FailureReason }}'
      OutputLocationType: '{{ item.OutputLocationType }}'
      ContentRedaction: '{{ item.ContentRedaction }}'
      ModelSettings: '{{ item.ModelSettings }}'
      IdentifyLanguage: '{{ item.IdentifyLanguage }}'
      IdentifyMultipleLanguages: '{{ item.IdentifyMultipleLanguages }}'
      IdentifiedLanguageScore: '{{ item.IdentifiedLanguageScore }}'
      LanguageCodes: '{{ item.LanguageCodes }}'
      ToxicityDetection: '{{ item.ToxicityDetection }}'
- discovery_id: aws.transcribe.listVocabularies
  calls:
  - action: listVocabularies
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Vocabularies }}'
    item:
      VocabularyName: '{{ item.VocabularyName }}'
      LanguageCode: '{{ item.LanguageCode }}'
      LastModifiedTime: '{{ item.LastModifiedTime }}'
      VocabularyState: '{{ item.VocabularyState }}'
- discovery_id: aws.transcribe.listVocabularyFilters
  calls:
  - action: listVocabularyFilters
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.VocabularyFilters }}'
    item:
      VocabularyFilterName: '{{ item.VocabularyFilterName }}'
      LanguageCode: '{{ item.LanguageCode }}'
      LastModifiedTime: '{{ item.LastModifiedTime }}'
- discovery_id: aws.transcribe.describeLanguageModel
  calls:
  - action: describeLanguageModel
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.LanguageModel }}'
    item:
      ModelName: '{{ item.ModelName }}'
      CreateTime: '{{ item.CreateTime }}'
      LastModifiedTime: '{{ item.LastModifiedTime }}'
      LanguageCode: '{{ item.LanguageCode }}'
      BaseModelName: '{{ item.BaseModelName }}'
      ModelStatus: '{{ item.ModelStatus }}'
      UpgradeAvailability: '{{ item.UpgradeAvailability }}'
      FailureReason: '{{ item.FailureReason }}'
      InputDataConfig: '{{ item.InputDataConfig }}'
- discovery_id: aws.transcribe.getCallAnalyticsCategory
  calls:
  - action: getCallAnalyticsCategory
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.CategoryProperties }}'
    item:
      CategoryName: '{{ item.CategoryName }}'
      Rules: '{{ item.Rules }}'
      CreateTime: '{{ item.CreateTime }}'
      LastUpdateTime: '{{ item.LastUpdateTime }}'
      Tags: '{{ item.Tags }}'
      InputType: '{{ item.InputType }}'
- discovery_id: aws.transcribe.getCallAnalyticsJob
  calls:
  - action: getCallAnalyticsJob
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.CallAnalyticsJob }}'
    item:
      CallAnalyticsJobName: '{{ item.CallAnalyticsJobName }}'
      CallAnalyticsJobStatus: '{{ item.CallAnalyticsJobStatus }}'
      CallAnalyticsJobDetails: '{{ item.CallAnalyticsJobDetails }}'
      LanguageCode: '{{ item.LanguageCode }}'
      MediaSampleRateHertz: '{{ item.MediaSampleRateHertz }}'
      MediaFormat: '{{ item.MediaFormat }}'
      Media: '{{ item.Media }}'
      Transcript: '{{ item.Transcript }}'
      StartTime: '{{ item.StartTime }}'
      CreationTime: '{{ item.CreationTime }}'
      CompletionTime: '{{ item.CompletionTime }}'
      FailureReason: '{{ item.FailureReason }}'
      DataAccessRoleArn: '{{ item.DataAccessRoleArn }}'
      IdentifiedLanguageScore: '{{ item.IdentifiedLanguageScore }}'
      Settings: '{{ item.Settings }}'
      ChannelDefinitions: '{{ item.ChannelDefinitions }}'
      Tags: '{{ item.Tags }}'
- discovery_id: aws.transcribe.getMedicalScribeJob
  calls:
  - action: getMedicalScribeJob
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.MedicalScribeJob }}'
    item:
      MedicalScribeJobName: '{{ item.MedicalScribeJobName }}'
      MedicalScribeJobStatus: '{{ item.MedicalScribeJobStatus }}'
      LanguageCode: '{{ item.LanguageCode }}'
      Media: '{{ item.Media }}'
      MedicalScribeOutput: '{{ item.MedicalScribeOutput }}'
      StartTime: '{{ item.StartTime }}'
      CreationTime: '{{ item.CreationTime }}'
      CompletionTime: '{{ item.CompletionTime }}'
      FailureReason: '{{ item.FailureReason }}'
      Settings: '{{ item.Settings }}'
      DataAccessRoleArn: '{{ item.DataAccessRoleArn }}'
      ChannelDefinitions: '{{ item.ChannelDefinitions }}'
      MedicalScribeContextProvided: '{{ item.MedicalScribeContextProvided }}'
      Tags: '{{ item.Tags }}'
- discovery_id: aws.transcribe.getMedicalTranscriptionJob
  calls:
  - action: getMedicalTranscriptionJob
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.MedicalTranscriptionJob }}'
    item:
      MedicalTranscriptionJobName: '{{ item.MedicalTranscriptionJobName }}'
      TranscriptionJobStatus: '{{ item.TranscriptionJobStatus }}'
      LanguageCode: '{{ item.LanguageCode }}'
      MediaSampleRateHertz: '{{ item.MediaSampleRateHertz }}'
      MediaFormat: '{{ item.MediaFormat }}'
      Media: '{{ item.Media }}'
      Transcript: '{{ item.Transcript }}'
      StartTime: '{{ item.StartTime }}'
      CreationTime: '{{ item.CreationTime }}'
      CompletionTime: '{{ item.CompletionTime }}'
      FailureReason: '{{ item.FailureReason }}'
      Settings: '{{ item.Settings }}'
      ContentIdentificationType: '{{ item.ContentIdentificationType }}'
      Specialty: '{{ item.Specialty }}'
      Type: '{{ item.Type }}'
      Tags: '{{ item.Tags }}'
- discovery_id: aws.transcribe.getMedicalVocabulary
  calls:
  - action: getMedicalVocabulary
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.VocabularyName }}'
- discovery_id: aws.transcribe.getTranscriptionJob
  calls:
  - action: getTranscriptionJob
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.TranscriptionJob }}'
    item:
      TranscriptionJobName: '{{ item.TranscriptionJobName }}'
      TranscriptionJobStatus: '{{ item.TranscriptionJobStatus }}'
      LanguageCode: '{{ item.LanguageCode }}'
      MediaSampleRateHertz: '{{ item.MediaSampleRateHertz }}'
      MediaFormat: '{{ item.MediaFormat }}'
      Media: '{{ item.Media }}'
      Transcript: '{{ item.Transcript }}'
      StartTime: '{{ item.StartTime }}'
      CreationTime: '{{ item.CreationTime }}'
      CompletionTime: '{{ item.CompletionTime }}'
      FailureReason: '{{ item.FailureReason }}'
      Settings: '{{ item.Settings }}'
      ModelSettings: '{{ item.ModelSettings }}'
      JobExecutionSettings: '{{ item.JobExecutionSettings }}'
      ContentRedaction: '{{ item.ContentRedaction }}'
      IdentifyLanguage: '{{ item.IdentifyLanguage }}'
      IdentifyMultipleLanguages: '{{ item.IdentifyMultipleLanguages }}'
      LanguageOptions: '{{ item.LanguageOptions }}'
      IdentifiedLanguageScore: '{{ item.IdentifiedLanguageScore }}'
      LanguageCodes: '{{ item.LanguageCodes }}'
      Tags: '{{ item.Tags }}'
      Subtitles: '{{ item.Subtitles }}'
      LanguageIdSettings: '{{ item.LanguageIdSettings }}'
      ToxicityDetection: '{{ item.ToxicityDetection }}'
- discovery_id: aws.transcribe.getVocabulary
  calls:
  - action: getVocabulary
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.VocabularyName }}'
- discovery_id: aws.transcribe.getVocabularyFilter
  calls:
  - action: getVocabularyFilter
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.VocabularyFilterName }}'
- discovery_id: aws.transcribe.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Tags }}'
    item:
      Key: '{{ item.Key }}'
      Value: '{{ item.Value }}'
checks: []
