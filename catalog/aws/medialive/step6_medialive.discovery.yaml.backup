  emit:
    as: item
    items_for: '{{ response.ScheduleActions }}'
    item:
      ActionName: '{{ item.ActionName }}'
      ScheduleActionSettings: '{{ item.ScheduleActionSettings }}'
      ScheduleActionStartSettings: '{{ item.ScheduleActionStartSettings }}'
- discovery_id: aws.medialive.describeThumbnails
  calls:
  - action: describeThumbnails
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ThumbnailDetails }}'
    item:
      PipelineId: '{{ item.PipelineId }}'
      Thumbnails: '{{ item.Thumbnails }}'
- discovery_id: aws.medialive.listInputDeviceTransfers
  calls:
  - action: listInputDeviceTransfers
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.InputDeviceTransfers }}'
    item:
      Id: '{{ item.Id }}'
