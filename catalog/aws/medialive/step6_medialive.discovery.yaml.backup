    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Alerts }}'
    item:
      AlertType: '{{ item.AlertType }}'
      ClearedTimestamp: '{{ item.ClearedTimestamp }}'
      Id: '{{ item.Id }}'
      Message: '{{ item.Message }}'
      PipelineId: '{{ item.PipelineId }}'
      SetTimestamp: '{{ item.SetTimestamp }}'
      State: '{{ item.State }}'
checks: []
