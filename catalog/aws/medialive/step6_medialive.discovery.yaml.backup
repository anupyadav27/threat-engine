    items_for: '{{ response.PipelineDetails }}'
    item:
      ActiveChannelPipeline: '{{ item.ActiveChannelPipeline }}'
      PipelineId: '{{ item.PipelineId }}'
- discovery_id: aws.medialive.describeOffering
  calls:
  - action: describeOffering
    save_as: response
    on_error: continue
  emit:
