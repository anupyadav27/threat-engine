version: '1.0'
provider: aws
service: medialive
services:
  client: medialive
  module: boto3.client
discovery:
- discovery_id: aws.medialive.describeAccountConfiguration
  calls:
  - action: describeAccountConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AccountConfiguration }}'
    item:
      KmsKeyId: '{{ item.KmsKeyId }}'
- discovery_id: aws.medialive.listChannels
  calls:
  - action: listChannels
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Channels }}'
    item:
      Arn: '{{ item.Arn }}'
      CdiInputSpecification: '{{ item.CdiInputSpecification }}'
      ChannelClass: '{{ item.ChannelClass }}'
      Destinations: '{{ item.Destinations }}'
      EgressEndpoints: '{{ item.EgressEndpoints }}'
      Id: '{{ item.Id }}'
      InputAttachments: '{{ item.InputAttachments }}'
      InputSpecification: '{{ item.InputSpecification }}'
      LogLevel: '{{ item.LogLevel }}'
      Maintenance: '{{ item.Maintenance }}'
      Name: '{{ item.Name }}'
      PipelinesRunningCount: '{{ item.PipelinesRunningCount }}'
      RoleArn: '{{ item.RoleArn }}'
      State: '{{ item.State }}'
      Tags: '{{ item.Tags }}'
      Vpc: '{{ item.Vpc }}'
      AnywhereSettings: '{{ item.AnywhereSettings }}'
      ChannelEngineVersion: '{{ item.ChannelEngineVersion }}'
      UsedChannelEngineVersions: '{{ item.UsedChannelEngineVersions }}'
- discovery_id: aws.medialive.listInputDevices
  calls:
  - action: listInputDevices
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.InputDevices }}'
    item:
      Arn: '{{ item.Arn }}'
      ConnectionState: '{{ item.ConnectionState }}'
      DeviceSettingsSyncState: '{{ item.DeviceSettingsSyncState }}'
      DeviceUpdateStatus: '{{ item.DeviceUpdateStatus }}'
      HdDeviceSettings: '{{ item.HdDeviceSettings }}'
      Id: '{{ item.Id }}'
      MacAddress: '{{ item.MacAddress }}'
      Name: '{{ item.Name }}'
      NetworkSettings: '{{ item.NetworkSettings }}'
      SerialNumber: '{{ item.SerialNumber }}'
      Type: '{{ item.Type }}'
      UhdDeviceSettings: '{{ item.UhdDeviceSettings }}'
      Tags: '{{ item.Tags }}'
      AvailabilityZone: '{{ item.AvailabilityZone }}'
      MedialiveInputArns: '{{ item.MedialiveInputArns }}'
      OutputType: '{{ item.OutputType }}'
- discovery_id: aws.medialive.listInputSecurityGroups
  calls:
  - action: listInputSecurityGroups
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.InputSecurityGroups }}'
    item:
      Arn: '{{ item.Arn }}'
      Id: '{{ item.Id }}'
      Inputs: '{{ item.Inputs }}'
      State: '{{ item.State }}'
      Tags: '{{ item.Tags }}'
      WhitelistRules: '{{ item.WhitelistRules }}'
- discovery_id: aws.medialive.listInputs
  calls:
  - action: listInputs
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Inputs }}'
    item:
      Arn: '{{ item.Arn }}'
      AttachedChannels: '{{ item.AttachedChannels }}'
      Destinations: '{{ item.Destinations }}'
      Id: '{{ item.Id }}'
      InputClass: '{{ item.InputClass }}'
      InputDevices: '{{ item.InputDevices }}'
      InputPartnerIds: '{{ item.InputPartnerIds }}'
      InputSourceType: '{{ item.InputSourceType }}'
      MediaConnectFlows: '{{ item.MediaConnectFlows }}'
      Name: '{{ item.Name }}'
      RoleArn: '{{ item.RoleArn }}'
      SecurityGroups: '{{ item.SecurityGroups }}'
      Sources: '{{ item.Sources }}'
      State: '{{ item.State }}'
      Tags: '{{ item.Tags }}'
      Type: '{{ item.Type }}'
      SrtSettings: '{{ item.SrtSettings }}'
      InputNetworkLocation: '{{ item.InputNetworkLocation }}'
      MulticastSettings: '{{ item.MulticastSettings }}'
      Smpte2110ReceiverGroupSettings: '{{ item.Smpte2110ReceiverGroupSettings }}'
      SdiSources: '{{ item.SdiSources }}'
      RouterSettings: '{{ item.RouterSettings }}'
- discovery_id: aws.medialive.listMultiplexes
  calls:
  - action: listMultiplexes
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Multiplexes }}'
    item:
      Arn: '{{ item.Arn }}'
      AvailabilityZones: '{{ item.AvailabilityZones }}'
      Id: '{{ item.Id }}'
      MultiplexSettings: '{{ item.MultiplexSettings }}'
      Name: '{{ item.Name }}'
      PipelinesRunningCount: '{{ item.PipelinesRunningCount }}'
      ProgramCount: '{{ item.ProgramCount }}'
      State: '{{ item.State }}'
      Tags: '{{ item.Tags }}'
- discovery_id: aws.medialive.listOfferings
  calls:
  - action: listOfferings
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Offerings }}'
    item:
      Arn: '{{ item.Arn }}'
      CurrencyCode: '{{ item.CurrencyCode }}'
      Duration: '{{ item.Duration }}'
      DurationUnits: '{{ item.DurationUnits }}'
      FixedPrice: '{{ item.FixedPrice }}'
      OfferingDescription: '{{ item.OfferingDescription }}'
      OfferingId: '{{ item.OfferingId }}'
      OfferingType: '{{ item.OfferingType }}'
      Region: '{{ item.Region }}'
      ResourceSpecification: '{{ item.ResourceSpecification }}'
      UsagePrice: '{{ item.UsagePrice }}'
- discovery_id: aws.medialive.listReservations
  calls:
  - action: listReservations
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Reservations }}'
    item:
      Arn: '{{ item.Arn }}'
      Count: '{{ item.Count }}'
      CurrencyCode: '{{ item.CurrencyCode }}'
      Duration: '{{ item.Duration }}'
      DurationUnits: '{{ item.DurationUnits }}'
      End: '{{ item.End }}'
      FixedPrice: '{{ item.FixedPrice }}'
      Name: '{{ item.Name }}'
      OfferingDescription: '{{ item.OfferingDescription }}'
      OfferingId: '{{ item.OfferingId }}'
      OfferingType: '{{ item.OfferingType }}'
      Region: '{{ item.Region }}'
      RenewalSettings: '{{ item.RenewalSettings }}'
      ReservationId: '{{ item.ReservationId }}'
      ResourceSpecification: '{{ item.ResourceSpecification }}'
      Start: '{{ item.Start }}'
      State: '{{ item.State }}'
      Tags: '{{ item.Tags }}'
      UsagePrice: '{{ item.UsagePrice }}'
- discovery_id: aws.medialive.listCloudWatchAlarmTemplateGroups
  calls:
  - action: listCloudWatchAlarmTemplateGroups
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.CloudWatchAlarmTemplateGroups }}'
    item:
      Arn: '{{ item.Arn }}'
      CreatedAt: '{{ item.CreatedAt }}'
      Description: '{{ item.Description }}'
      Id: '{{ item.Id }}'
      ModifiedAt: '{{ item.ModifiedAt }}'
      Name: '{{ item.Name }}'
      Tags: '{{ item.Tags }}'
      TemplateCount: '{{ item.TemplateCount }}'
- discovery_id: aws.medialive.listCloudWatchAlarmTemplates
  calls:
  - action: listCloudWatchAlarmTemplates
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.CloudWatchAlarmTemplates }}'
    item:
      Arn: '{{ item.Arn }}'
      ComparisonOperator: '{{ item.ComparisonOperator }}'
      CreatedAt: '{{ item.CreatedAt }}'
      DatapointsToAlarm: '{{ item.DatapointsToAlarm }}'
      Description: '{{ item.Description }}'
      EvaluationPeriods: '{{ item.EvaluationPeriods }}'
      GroupId: '{{ item.GroupId }}'
      Id: '{{ item.Id }}'
      MetricName: '{{ item.MetricName }}'
      ModifiedAt: '{{ item.ModifiedAt }}'
      Name: '{{ item.Name }}'
      Period: '{{ item.Period }}'
      Statistic: '{{ item.Statistic }}'
      Tags: '{{ item.Tags }}'
      TargetResourceType: '{{ item.TargetResourceType }}'
      Threshold: '{{ item.Threshold }}'
      TreatMissingData: '{{ item.TreatMissingData }}'
- discovery_id: aws.medialive.listEventBridgeRuleTemplateGroups
  calls:
  - action: listEventBridgeRuleTemplateGroups
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.EventBridgeRuleTemplateGroups }}'
    item:
      Arn: '{{ item.Arn }}'
      CreatedAt: '{{ item.CreatedAt }}'
      Description: '{{ item.Description }}'
      Id: '{{ item.Id }}'
      ModifiedAt: '{{ item.ModifiedAt }}'
      Name: '{{ item.Name }}'
      Tags: '{{ item.Tags }}'
      TemplateCount: '{{ item.TemplateCount }}'
- discovery_id: aws.medialive.listEventBridgeRuleTemplates
  calls:
  - action: listEventBridgeRuleTemplates
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.EventBridgeRuleTemplates }}'
    item:
      Arn: '{{ item.Arn }}'
      CreatedAt: '{{ item.CreatedAt }}'
      Description: '{{ item.Description }}'
      EventTargetCount: '{{ item.EventTargetCount }}'
      EventType: '{{ item.EventType }}'
      GroupId: '{{ item.GroupId }}'
      Id: '{{ item.Id }}'
      ModifiedAt: '{{ item.ModifiedAt }}'
      Name: '{{ item.Name }}'
      Tags: '{{ item.Tags }}'
- discovery_id: aws.medialive.listSignalMaps
  calls:
  - action: listSignalMaps
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.SignalMaps }}'
    item:
      Arn: '{{ item.Arn }}'
      CreatedAt: '{{ item.CreatedAt }}'
      Description: '{{ item.Description }}'
      Id: '{{ item.Id }}'
      ModifiedAt: '{{ item.ModifiedAt }}'
      MonitorDeploymentStatus: '{{ item.MonitorDeploymentStatus }}'
      Name: '{{ item.Name }}'
      Status: '{{ item.Status }}'
      Tags: '{{ item.Tags }}'
- discovery_id: aws.medialive.listClusters
  calls:
  - action: listClusters
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Clusters }}'
    item:
      Arn: '{{ item.Arn }}'
      ChannelIds: '{{ item.ChannelIds }}'
      ClusterType: '{{ item.ClusterType }}'
      Id: '{{ item.Id }}'
      InstanceRoleArn: '{{ item.InstanceRoleArn }}'
      Name: '{{ item.Name }}'
      NetworkSettings: '{{ item.NetworkSettings }}'
      State: '{{ item.State }}'
- discovery_id: aws.medialive.listNetworks
  calls:
  - action: listNetworks
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Networks }}'
    item:
      Arn: '{{ item.Arn }}'
      AssociatedClusterIds: '{{ item.AssociatedClusterIds }}'
      Id: '{{ item.Id }}'
      IpPools: '{{ item.IpPools }}'
      Name: '{{ item.Name }}'
      Routes: '{{ item.Routes }}'
      State: '{{ item.State }}'
- discovery_id: aws.medialive.listVersions
  calls:
  - action: listVersions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Versions }}'
    item:
      ExpirationDate: '{{ item.ExpirationDate }}'
      Version: '{{ item.Version }}'
- discovery_id: aws.medialive.listSdiSources
  calls:
  - action: listSdiSources
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.SdiSources }}'
    item:
      Arn: '{{ item.Arn }}'
      Id: '{{ item.Id }}'
      Inputs: '{{ item.Inputs }}'
      Mode: '{{ item.Mode }}'
      Name: '{{ item.Name }}'
      State: '{{ item.State }}'
      Type: '{{ item.Type }}'
- discovery_id: aws.medialive.describeChannel
  calls:
  - action: describeChannel
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Destinations }}'
    item:
      Id: '{{ item.Id }}'
      MediaPackageSettings: '{{ item.MediaPackageSettings }}'
      MultiplexSettings: '{{ item.MultiplexSettings }}'
      Settings: '{{ item.Settings }}'
      SrtSettings: '{{ item.SrtSettings }}'
      LogicalInterfaceNames: '{{ item.LogicalInterfaceNames }}'
- discovery_id: aws.medialive.describeInput
  calls:
  - action: describeInput
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.SecurityGroups }}'
- discovery_id: aws.medialive.describeInputDevice
  calls:
  - action: describeInputDevice
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.MedialiveInputArns }}'
- discovery_id: aws.medialive.describeInputDeviceThumbnail
  calls:
  - action: describeInputDeviceThumbnail
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Body }}'
- discovery_id: aws.medialive.describeInputSecurityGroup
  calls:
  - action: describeInputSecurityGroup
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.WhitelistRules }}'
    item:
      Cidr: '{{ item.Cidr }}'
- discovery_id: aws.medialive.describeMultiplex
  calls:
  - action: describeMultiplex
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AvailabilityZones }}'
- discovery_id: aws.medialive.describeMultiplexProgram
  calls:
  - action: describeMultiplexProgram
    save_as: response
    on_error: continue
  emit:
