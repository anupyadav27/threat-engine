    item:
      ChannelClass: '{{ item.ChannelClass }}'
      Codec: '{{ item.Codec }}'
      MaximumBitrate: '{{ item.MaximumBitrate }}'
      MaximumFramerate: '{{ item.MaximumFramerate }}'
      Resolution: '{{ item.Resolution }}'
      ResourceType: '{{ item.ResourceType }}'
      SpecialFeature: '{{ item.SpecialFeature }}'
      VideoQuality: '{{ item.VideoQuality }}'
