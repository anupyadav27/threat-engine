version: '1.0'
provider: aws
service: resource-explorer-2
services:
  client: resource-explorer-2
  module: boto3.client
discovery:
- discovery_id: aws.resource-explorer-2.getAccountLevelServiceConfiguration
  calls:
  - action: getAccountLevelServiceConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.OrgConfiguration }}'
    item:
      AWSServiceAccessStatus: '{{ item.AWSServiceAccessStatus }}'
      ServiceLinkedRole: '{{ item.ServiceLinkedRole }}'
- discovery_id: aws.resource-explorer-2.getDefaultView
  calls:
  - action: getDefaultView
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ViewArn }}'
- discovery_id: aws.resource-explorer-2.getIndex
  calls:
  - action: getIndex
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ReplicatingFrom }}'
- discovery_id: aws.resource-explorer-2.getServiceIndex
  calls:
  - action: getServiceIndex
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Arn }}'
- discovery_id: aws.resource-explorer-2.listIndexes
  calls:
  - action: listIndexes
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Indexes }}'
    item:
      Region: '{{ item.Region }}'
      Arn: '{{ item.Arn }}'
      Type: '{{ item.Type }}'
- discovery_id: aws.resource-explorer-2.listManagedViews
  calls:
  - action: listManagedViews
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.ManagedViews }}'
- discovery_id: aws.resource-explorer-2.listResources
  calls:
  - action: listResources
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Resources }}'
    item:
      Arn: '{{ item.Arn }}'
      OwningAccountId: '{{ item.OwningAccountId }}'
      Region: '{{ item.Region }}'
      ResourceType: '{{ item.ResourceType }}'
      Service: '{{ item.Service }}'
      LastReportedAt: '{{ item.LastReportedAt }}'
      Properties: '{{ item.Properties }}'
- discovery_id: aws.resource-explorer-2.listServiceIndexes
  calls:
  - action: listServiceIndexes
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Indexes }}'
    item:
      Region: '{{ item.Region }}'
      Arn: '{{ item.Arn }}'
      Type: '{{ item.Type }}'
- discovery_id: aws.resource-explorer-2.listServiceViews
  calls:
  - action: listServiceViews
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.ServiceViews }}'
- discovery_id: aws.resource-explorer-2.listStreamingAccessForServices
  calls:
  - action: listStreamingAccessForServices
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.StreamingAccessForServices }}'
    item:
      ServicePrincipal: '{{ item.ServicePrincipal }}'
      CreatedAt: '{{ item.CreatedAt }}'
- discovery_id: aws.resource-explorer-2.listSupportedResourceTypes
  calls:
  - action: listSupportedResourceTypes
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.ResourceTypes }}'
    item:
      Service: '{{ item.Service }}'
      ResourceType: '{{ item.ResourceType }}'
- discovery_id: aws.resource-explorer-2.listViews
  calls:
  - action: listViews
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Views }}'
- discovery_id: aws.resource-explorer-2.getManagedView
  calls:
  - action: getManagedView
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ManagedView }}'
    item:
      ManagedViewArn: '{{ item.ManagedViewArn }}'
      ManagedViewName: '{{ item.ManagedViewName }}'
      TrustedService: '{{ item.TrustedService }}'
      LastUpdatedAt: '{{ item.LastUpdatedAt }}'
      Owner: '{{ item.Owner }}'
      Scope: '{{ item.Scope }}'
      IncludedProperties: '{{ item.IncludedProperties }}'
      Filters: '{{ item.Filters }}'
      ResourcePolicy: '{{ item.ResourcePolicy }}'
      Version: '{{ item.Version }}'
- discovery_id: aws.resource-explorer-2.getResourceExplorerSetup
  calls:
  - action: getResourceExplorerSetup
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Regions }}'
    item:
      Region: '{{ item.Region }}'
      Index: '{{ item.Index }}'
      View: '{{ item.View }}'
- discovery_id: aws.resource-explorer-2.getServiceView
  calls:
  - action: getServiceView
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.View }}'
    item:
      ServiceViewArn: '{{ item.ServiceViewArn }}'
      Filters: '{{ item.Filters }}'
      IncludedProperties: '{{ item.IncludedProperties }}'
      StreamingAccessForService: '{{ item.StreamingAccessForService }}'
      ScopeType: '{{ item.ScopeType }}'
- discovery_id: aws.resource-explorer-2.getView
  calls:
  - action: getView
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.View }}'
    item:
      ViewArn: '{{ item.ViewArn }}'
      Owner: '{{ item.Owner }}'
      LastUpdatedAt: '{{ item.LastUpdatedAt }}'
      Scope: '{{ item.Scope }}'
      IncludedProperties: '{{ item.IncludedProperties }}'
      Filters: '{{ item.Filters }}'
- discovery_id: aws.resource-explorer-2.listIndexesForMembers
  calls:
  - action: listIndexesForMembers
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Indexes }}'
    item:
      AccountId: '{{ item.AccountId }}'
      Region: '{{ item.Region }}'
      Arn: '{{ item.Arn }}'
      Type: '{{ item.Type }}'
- discovery_id: aws.resource-explorer-2.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Tags }}'
- discovery_id: aws.resource-explorer-2.search
  calls:
  - action: search
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Resources }}'
    item:
      Arn: '{{ item.Arn }}'
      OwningAccountId: '{{ item.OwningAccountId }}'
      Region: '{{ item.Region }}'
      ResourceType: '{{ item.ResourceType }}'
      Service: '{{ item.Service }}'
      LastReportedAt: '{{ item.LastReportedAt }}'
      Properties: '{{ item.Properties }}'
checks: []
