version: '1.0'
provider: aws
service: iotwireless
services:
  client: iotwireless
  module: boto3.client
discovery:
- discovery_id: aws.iotwireless.getEventConfigurationByResourceTypes
  calls:
  - action: getEventConfigurationByResourceTypes
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.DeviceRegistrationState }}'
    item:
      Sidewalk: '{{ item.Sidewalk }}'
- discovery_id: aws.iotwireless.getLogLevelsByResourceTypes
  calls:
  - action: getLogLevelsByResourceTypes
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.WirelessGatewayLogOptions }}'
    item:
      Type: '{{ item.Type }}'
      LogLevel: '{{ item.LogLevel }}'
      Events: '{{ item.Events }}'
- discovery_id: aws.iotwireless.getMetricConfiguration
  calls:
  - action: getMetricConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.SummaryMetric }}'
    item:
      Status: '{{ item.Status }}'
- discovery_id: aws.iotwireless.getMetrics
  calls:
  - action: getMetrics
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.SummaryMetricQueryResults }}'
    item:
      QueryId: '{{ item.QueryId }}'
      QueryStatus: '{{ item.QueryStatus }}'
      Error: '{{ item.Error }}'
      MetricName: '{{ item.MetricName }}'
      Dimensions: '{{ item.Dimensions }}'
      AggregationPeriod: '{{ item.AggregationPeriod }}'
      StartTimestamp: '{{ item.StartTimestamp }}'
      EndTimestamp: '{{ item.EndTimestamp }}'
      Timestamps: '{{ item.Timestamps }}'
      Values: '{{ item.Values }}'
      Unit: '{{ item.Unit }}'
- discovery_id: aws.iotwireless.getPositionEstimate
  calls:
  - action: getPositionEstimate
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.GeoJsonPayload }}'
- discovery_id: aws.iotwireless.getServiceEndpoint
  calls:
  - action: getServiceEndpoint
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ServiceType }}'
- discovery_id: aws.iotwireless.listDestinations
  calls:
  - action: listDestinations
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.DestinationList }}'
    item:
      Arn: '{{ item.Arn }}'
      Name: '{{ item.Name }}'
      ExpressionType: '{{ item.ExpressionType }}'
      Expression: '{{ item.Expression }}'
      Description: '{{ item.Description }}'
      RoleArn: '{{ item.RoleArn }}'
- discovery_id: aws.iotwireless.listDeviceProfiles
  calls:
  - action: listDeviceProfiles
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.DeviceProfileList }}'
    item:
      Arn: '{{ item.Arn }}'
      Name: '{{ item.Name }}'
      Id: '{{ item.Id }}'
- discovery_id: aws.iotwireless.listFuotaTasks
  calls:
  - action: listFuotaTasks
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.FuotaTaskList }}'
    item:
      Id: '{{ item.Id }}'
      Arn: '{{ item.Arn }}'
      Name: '{{ item.Name }}'
- discovery_id: aws.iotwireless.listMulticastGroups
  calls:
  - action: listMulticastGroups
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.MulticastGroupList }}'
    item:
      Id: '{{ item.Id }}'
      Arn: '{{ item.Arn }}'
      Name: '{{ item.Name }}'
- discovery_id: aws.iotwireless.listNetworkAnalyzerConfigurations
  calls:
  - action: listNetworkAnalyzerConfigurations
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.NetworkAnalyzerConfigurationList }}'
    item:
      Arn: '{{ item.Arn }}'
      Name: '{{ item.Name }}'
- discovery_id: aws.iotwireless.listPartnerAccounts
  calls:
  - action: listPartnerAccounts
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Sidewalk }}'
    item:
      AmazonId: '{{ item.AmazonId }}'
      Fingerprint: '{{ item.Fingerprint }}'
      Arn: '{{ item.Arn }}'
- discovery_id: aws.iotwireless.listPositionConfigurations
  calls:
  - action: listPositionConfigurations
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.PositionConfigurationList }}'
    item:
      ResourceIdentifier: '{{ item.ResourceIdentifier }}'
      ResourceType: '{{ item.ResourceType }}'
      Solvers: '{{ item.Solvers }}'
      Destination: '{{ item.Destination }}'
- discovery_id: aws.iotwireless.listServiceProfiles
  calls:
  - action: listServiceProfiles
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.ServiceProfileList }}'
    item:
      Arn: '{{ item.Arn }}'
      Name: '{{ item.Name }}'
      Id: '{{ item.Id }}'
- discovery_id: aws.iotwireless.listWirelessDeviceImportTasks
  calls:
  - action: listWirelessDeviceImportTasks
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.WirelessDeviceImportTaskList }}'
    item:
      Id: '{{ item.Id }}'
      Arn: '{{ item.Arn }}'
      DestinationName: '{{ item.DestinationName }}'
      Positioning: '{{ item.Positioning }}'
      Sidewalk: '{{ item.Sidewalk }}'
      CreationTime: '{{ item.CreationTime }}'
      Status: '{{ item.Status }}'
      StatusReason: '{{ item.StatusReason }}'
      InitializedImportedDeviceCount: '{{ item.InitializedImportedDeviceCount }}'
      PendingImportedDeviceCount: '{{ item.PendingImportedDeviceCount }}'
      OnboardedImportedDeviceCount: '{{ item.OnboardedImportedDeviceCount }}'
      FailedImportedDeviceCount: '{{ item.FailedImportedDeviceCount }}'
- discovery_id: aws.iotwireless.listWirelessDevices
  calls:
  - action: listWirelessDevices
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.WirelessDeviceList }}'
    item:
      Arn: '{{ item.Arn }}'
      Id: '{{ item.Id }}'
      Type: '{{ item.Type }}'
      Name: '{{ item.Name }}'
      DestinationName: '{{ item.DestinationName }}'
      LastUplinkReceivedAt: '{{ item.LastUplinkReceivedAt }}'
      LoRaWAN: '{{ item.LoRaWAN }}'
      Sidewalk: '{{ item.Sidewalk }}'
      FuotaDeviceStatus: '{{ item.FuotaDeviceStatus }}'
      MulticastDeviceStatus: '{{ item.MulticastDeviceStatus }}'
      McGroupId: '{{ item.McGroupId }}'
      Positioning: '{{ item.Positioning }}'
- discovery_id: aws.iotwireless.listWirelessGatewayTaskDefinitions
  calls:
  - action: listWirelessGatewayTaskDefinitions
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.TaskDefinitions }}'
    item:
      Id: '{{ item.Id }}'
      LoRaWAN: '{{ item.LoRaWAN }}'
      Arn: '{{ item.Arn }}'
- discovery_id: aws.iotwireless.listWirelessGateways
  calls:
  - action: listWirelessGateways
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.WirelessGatewayList }}'
    item:
      Arn: '{{ item.Arn }}'
      Id: '{{ item.Id }}'
      Name: '{{ item.Name }}'
      Description: '{{ item.Description }}'
      LoRaWAN: '{{ item.LoRaWAN }}'
      LastUplinkReceivedAt: '{{ item.LastUplinkReceivedAt }}'
- discovery_id: aws.iotwireless.getDestination
  calls:
  - action: getDestination
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Arn }}'
- discovery_id: aws.iotwireless.getDeviceProfile
  calls:
  - action: getDeviceProfile
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.LoRaWAN }}'
    item:
      SupportsClassB: '{{ item.SupportsClassB }}'
      ClassBTimeout: '{{ item.ClassBTimeout }}'
      PingSlotPeriod: '{{ item.PingSlotPeriod }}'
      PingSlotDr: '{{ item.PingSlotDr }}'
      PingSlotFreq: '{{ item.PingSlotFreq }}'
      SupportsClassC: '{{ item.SupportsClassC }}'
      ClassCTimeout: '{{ item.ClassCTimeout }}'
      MacVersion: '{{ item.MacVersion }}'
      RegParamsRevision: '{{ item.RegParamsRevision }}'
      RxDelay1: '{{ item.RxDelay1 }}'
      RxDrOffset1: '{{ item.RxDrOffset1 }}'
      RxDataRate2: '{{ item.RxDataRate2 }}'
      RxFreq2: '{{ item.RxFreq2 }}'
      FactoryPresetFreqsList: '{{ item.FactoryPresetFreqsList }}'
      MaxEirp: '{{ item.MaxEirp }}'
      MaxDutyCycle: '{{ item.MaxDutyCycle }}'
      RfRegion: '{{ item.RfRegion }}'
      SupportsJoin: '{{ item.SupportsJoin }}'
      Supports32BitFCnt: '{{ item.Supports32BitFCnt }}'
- discovery_id: aws.iotwireless.getFuotaTask
  calls:
  - action: getFuotaTask
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.LoRaWAN }}'
    item:
      RfRegion: '{{ item.RfRegion }}'
      StartTime: '{{ item.StartTime }}'
- discovery_id: aws.iotwireless.getMulticastGroup
  calls:
  - action: getMulticastGroup
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.LoRaWAN }}'
    item:
      RfRegion: '{{ item.RfRegion }}'
      DlClass: '{{ item.DlClass }}'
      NumberOfDevicesRequested: '{{ item.NumberOfDevicesRequested }}'
      NumberOfDevicesInGroup: '{{ item.NumberOfDevicesInGroup }}'
      ParticipatingGateways: '{{ item.ParticipatingGateways }}'
- discovery_id: aws.iotwireless.getMulticastGroupSession
  calls:
  - action: getMulticastGroupSession
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.LoRaWAN }}'
    item:
      DlDr: '{{ item.DlDr }}'
      DlFreq: '{{ item.DlFreq }}'
      SessionStartTime: '{{ item.SessionStartTime }}'
      SessionTimeout: '{{ item.SessionTimeout }}'
      PingSlotPeriod: '{{ item.PingSlotPeriod }}'
- discovery_id: aws.iotwireless.getNetworkAnalyzerConfiguration
  calls:
  - action: getNetworkAnalyzerConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.MulticastGroups }}'
- discovery_id: aws.iotwireless.getPartnerAccount
  calls:
  - action: getPartnerAccount
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Sidewalk }}'
    item:
      AmazonId: '{{ item.AmazonId }}'
      Fingerprint: '{{ item.Fingerprint }}'
      Arn: '{{ item.Arn }}'
- discovery_id: aws.iotwireless.getPosition
  calls:
  - action: getPosition
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Position }}'
- discovery_id: aws.iotwireless.getPositionConfiguration
  calls:
  - action: getPositionConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Solvers }}'
    item:
      SemtechGnss: '{{ item.SemtechGnss }}'
- discovery_id: aws.iotwireless.getResourceEventConfiguration
  calls:
  - action: getResourceEventConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.DeviceRegistrationState }}'
    item:
      Sidewalk: '{{ item.Sidewalk }}'
      WirelessDeviceIdEventTopic: '{{ item.WirelessDeviceIdEventTopic }}'
- discovery_id: aws.iotwireless.getResourceLogLevel
  calls:
  - action: getResourceLogLevel
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.LogLevel }}'
- discovery_id: aws.iotwireless.getResourcePosition
  calls:
  - action: getResourcePosition
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.GeoJsonPayload }}'
- discovery_id: aws.iotwireless.getServiceProfile
  calls:
  - action: getServiceProfile
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.LoRaWAN }}'
    item:
      UlRate: '{{ item.UlRate }}'
      UlBucketSize: '{{ item.UlBucketSize }}'
      UlRatePolicy: '{{ item.UlRatePolicy }}'
      DlRate: '{{ item.DlRate }}'
      DlBucketSize: '{{ item.DlBucketSize }}'
      DlRatePolicy: '{{ item.DlRatePolicy }}'
      AddGwMetadata: '{{ item.AddGwMetadata }}'
      DevStatusReqFreq: '{{ item.DevStatusReqFreq }}'
      ReportDevStatusBattery: '{{ item.ReportDevStatusBattery }}'
      ReportDevStatusMargin: '{{ item.ReportDevStatusMargin }}'
      DrMin: '{{ item.DrMin }}'
      DrMax: '{{ item.DrMax }}'
      ChannelMask: '{{ item.ChannelMask }}'
      PrAllowed: '{{ item.PrAllowed }}'
      HrAllowed: '{{ item.HrAllowed }}'
      RaAllowed: '{{ item.RaAllowed }}'
      NwkGeoLoc: '{{ item.NwkGeoLoc }}'
      TargetPer: '{{ item.TargetPer }}'
      MinGwDiversity: '{{ item.MinGwDiversity }}'
      TxPowerIndexMin: '{{ item.TxPowerIndexMin }}'
      TxPowerIndexMax: '{{ item.TxPowerIndexMax }}'
      NbTransMin: '{{ item.NbTransMin }}'
      NbTransMax: '{{ item.NbTransMax }}'
- discovery_id: aws.iotwireless.getWirelessDevice
  calls:
  - action: getWirelessDevice
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.LoRaWAN }}'
    item:
      DevEui: '{{ item.DevEui }}'
      DeviceProfileId: '{{ item.DeviceProfileId }}'
      ServiceProfileId: '{{ item.ServiceProfileId }}'
      OtaaV1_1: '{{ item.OtaaV1_1 }}'
      OtaaV1_0_x: '{{ item.OtaaV1_0_x }}'
      AbpV1_1: '{{ item.AbpV1_1 }}'
      AbpV1_0_x: '{{ item.AbpV1_0_x }}'
      FPorts: '{{ item.FPorts }}'
- discovery_id: aws.iotwireless.getWirelessDeviceImportTask
  calls:
  - action: getWirelessDeviceImportTask
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Sidewalk }}'
    item:
      DeviceCreationFileList: '{{ item.DeviceCreationFileList }}'
      Role: '{{ item.Role }}'
      Positioning: '{{ item.Positioning }}'
- discovery_id: aws.iotwireless.getWirelessDeviceStatistics
  calls:
  - action: getWirelessDeviceStatistics
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.LoRaWAN }}'
    item:
      DevEui: '{{ item.DevEui }}'
      FPort: '{{ item.FPort }}'
      DataRate: '{{ item.DataRate }}'
      Frequency: '{{ item.Frequency }}'
      Timestamp: '{{ item.Timestamp }}'
      Gateways: '{{ item.Gateways }}'
      PublicGateways: '{{ item.PublicGateways }}'
- discovery_id: aws.iotwireless.getWirelessGateway
  calls:
  - action: getWirelessGateway
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.LoRaWAN }}'
    item:
      GatewayEui: '{{ item.GatewayEui }}'
      RfRegion: '{{ item.RfRegion }}'
      JoinEuiFilters: '{{ item.JoinEuiFilters }}'
      NetIdFilters: '{{ item.NetIdFilters }}'
      SubBands: '{{ item.SubBands }}'
      Beaconing: '{{ item.Beaconing }}'
      MaxEirp: '{{ item.MaxEirp }}'
- discovery_id: aws.iotwireless.getWirelessGatewayCertificate
  calls:
  - action: getWirelessGatewayCertificate
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.IotCertificateId }}'
- discovery_id: aws.iotwireless.getWirelessGatewayFirmwareInformation
  calls:
  - action: getWirelessGatewayFirmwareInformation
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.LoRaWAN }}'
    item:
      CurrentVersion: '{{ item.CurrentVersion }}'
- discovery_id: aws.iotwireless.getWirelessGatewayStatistics
  calls:
  - action: getWirelessGatewayStatistics
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.WirelessGatewayId }}'
- discovery_id: aws.iotwireless.getWirelessGatewayTask
  calls:
  - action: getWirelessGatewayTask
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.WirelessGatewayId }}'
- discovery_id: aws.iotwireless.getWirelessGatewayTaskDefinition
  calls:
  - action: getWirelessGatewayTaskDefinition
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Update }}'
    item:
      UpdateDataSource: '{{ item.UpdateDataSource }}'
      UpdateDataRole: '{{ item.UpdateDataRole }}'
      LoRaWAN: '{{ item.LoRaWAN }}'
- discovery_id: aws.iotwireless.listDevicesForWirelessDeviceImportTask
  calls:
  - action: listDevicesForWirelessDeviceImportTask
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.ImportedWirelessDeviceList }}'
    item:
      Sidewalk: '{{ item.Sidewalk }}'
- discovery_id: aws.iotwireless.listEventConfigurations
  calls:
  - action: listEventConfigurations
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.EventConfigurationsList }}'
    item:
      Identifier: '{{ item.Identifier }}'
      IdentifierType: '{{ item.IdentifierType }}'
      PartnerType: '{{ item.PartnerType }}'
      Events: '{{ item.Events }}'
- discovery_id: aws.iotwireless.listMulticastGroupsByFuotaTask
  calls:
  - action: listMulticastGroupsByFuotaTask
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.MulticastGroupList }}'
    item:
      Id: '{{ item.Id }}'
- discovery_id: aws.iotwireless.listQueuedMessages
  calls:
  - action: listQueuedMessages
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.DownlinkQueueMessagesList }}'
    item:
      MessageId: '{{ item.MessageId }}'
      TransmitMode: '{{ item.TransmitMode }}'
      ReceivedAt: '{{ item.ReceivedAt }}'
      LoRaWAN: '{{ item.LoRaWAN }}'
- discovery_id: aws.iotwireless.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Tags }}'
    item:
      Key: '{{ item.Key }}'
      Value: '{{ item.Value }}'
checks: []
