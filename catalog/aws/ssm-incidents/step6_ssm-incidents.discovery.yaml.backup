version: '1.0'
provider: aws
service: ssm-incidents
services:
  client: ssm-incidents
  module: boto3.client
discovery:
- discovery_id: aws.ssm-incidents.listIncidentRecords
  calls:
  - action: listIncidentRecords
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.incidentRecordSummaries }}'
    item:
      arn: '{{ item.arn }}'
      creationTime: '{{ item.creationTime }}'
      impact: '{{ item.impact }}'
      incidentRecordSource: '{{ item.incidentRecordSource }}'
      resolvedTime: '{{ item.resolvedTime }}'
      status: '{{ item.status }}'
      title: '{{ item.title }}'
- discovery_id: aws.ssm-incidents.listReplicationSets
  calls:
  - action: listReplicationSets
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.replicationSetArns }}'
- discovery_id: aws.ssm-incidents.listResponsePlans
  calls:
  - action: listResponsePlans
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.responsePlanSummaries }}'
    item:
      arn: '{{ item.arn }}'
      displayName: '{{ item.displayName }}'
      name: '{{ item.name }}'
- discovery_id: aws.ssm-incidents.getIncidentRecord
  calls:
  - action: getIncidentRecord
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.incidentRecord }}'
    item:
      arn: '{{ item.arn }}'
      automationExecutions: '{{ item.automationExecutions }}'
      chatChannel: '{{ item.chatChannel }}'
      creationTime: '{{ item.creationTime }}'
      dedupeString: '{{ item.dedupeString }}'
      impact: '{{ item.impact }}'
      incidentRecordSource: '{{ item.incidentRecordSource }}'
      lastModifiedBy: '{{ item.lastModifiedBy }}'
      lastModifiedTime: '{{ item.lastModifiedTime }}'
      notificationTargets: '{{ item.notificationTargets }}'
      resolvedTime: '{{ item.resolvedTime }}'
      status: '{{ item.status }}'
      summary: '{{ item.summary }}'
      title: '{{ item.title }}'
- discovery_id: aws.ssm-incidents.getReplicationSet
  calls:
  - action: getReplicationSet
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.replicationSet }}'
    item:
      arn: '{{ item.arn }}'
      createdBy: '{{ item.createdBy }}'
      createdTime: '{{ item.createdTime }}'
      deletionProtected: '{{ item.deletionProtected }}'
      lastModifiedBy: '{{ item.lastModifiedBy }}'
      lastModifiedTime: '{{ item.lastModifiedTime }}'
      regionMap: '{{ item.regionMap }}'
      status: '{{ item.status }}'
- discovery_id: aws.ssm-incidents.getResourcePolicies
  calls:
  - action: getResourcePolicies
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.resourcePolicies }}'
    item:
      policyDocument: '{{ item.policyDocument }}'
      policyId: '{{ item.policyId }}'
      ramResourceShareRegion: '{{ item.ramResourceShareRegion }}'
- discovery_id: aws.ssm-incidents.getResponsePlan
  calls:
  - action: getResponsePlan
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.actions }}'
    item:
      ssmAutomation: '{{ item.ssmAutomation }}'
- discovery_id: aws.ssm-incidents.getTimelineEvent
  calls:
  - action: getTimelineEvent
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.event }}'
    item:
      eventData: '{{ item.eventData }}'
      eventId: '{{ item.eventId }}'
      eventReferences: '{{ item.eventReferences }}'
      eventTime: '{{ item.eventTime }}'
      eventType: '{{ item.eventType }}'
      eventUpdatedTime: '{{ item.eventUpdatedTime }}'
      incidentRecordArn: '{{ item.incidentRecordArn }}'
- discovery_id: aws.ssm-incidents.listIncidentFindings
  calls:
  - action: listIncidentFindings
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.findings }}'
    item:
      id: '{{ item.id }}'
      lastModifiedTime: '{{ item.lastModifiedTime }}'
- discovery_id: aws.ssm-incidents.listRelatedItems
  calls:
  - action: listRelatedItems
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.relatedItems }}'
    item:
      generatedId: '{{ item.generatedId }}'
      identifier: '{{ item.identifier }}'
      title: '{{ item.title }}'
- discovery_id: aws.ssm-incidents.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tags }}'
- discovery_id: aws.ssm-incidents.listTimelineEvents
  calls:
  - action: listTimelineEvents
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.eventSummaries }}'
    item:
      eventId: '{{ item.eventId }}'
      eventReferences: '{{ item.eventReferences }}'
      eventTime: '{{ item.eventTime }}'
      eventType: '{{ item.eventType }}'
      eventUpdatedTime: '{{ item.eventUpdatedTime }}'
      incidentRecordArn: '{{ item.incidentRecordArn }}'
checks: []
