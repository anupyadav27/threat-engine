version: '1.0'
provider: aws
service: kinesis-video-signaling
services:
  client: kinesis-video-signaling
  module: boto3.client
discovery:
- discovery_id: aws.kinesis-video-signaling.getIceServerConfig
  calls:
  - action: getIceServerConfig
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.IceServerList }}'
    item:
      Uris: '{{ item.Uris }}'
      Username: '{{ item.Username }}'
      Password: '{{ item.Password }}'
      Ttl: '{{ item.Ttl }}'
checks: []
