version: '1.0'
provider: aws
service: pcs
services:
  client: pcs
  module: boto3.client
discovery:
- discovery_id: aws.pcs.listClusters
  calls:
  - action: listClusters
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.clusters }}'
    item:
      name: '{{ item.name }}'
      id: '{{ item.id }}'
      arn: '{{ item.arn }}'
      createdAt: '{{ item.createdAt }}'
      modifiedAt: '{{ item.modifiedAt }}'
      status: '{{ item.status }}'
- discovery_id: aws.pcs.getCluster
  calls:
  - action: getCluster
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.cluster }}'
    item:
      name: '{{ item.name }}'
      id: '{{ item.id }}'
      arn: '{{ item.arn }}'
      status: '{{ item.status }}'
      createdAt: '{{ item.createdAt }}'
      modifiedAt: '{{ item.modifiedAt }}'
      scheduler: '{{ item.scheduler }}'
      size: '{{ item.size }}'
      slurmConfiguration: '{{ item.slurmConfiguration }}'
      networking: '{{ item.networking }}'
      endpoints: '{{ item.endpoints }}'
      errorInfo: '{{ item.errorInfo }}'
- discovery_id: aws.pcs.getComputeNodeGroup
  calls:
  - action: getComputeNodeGroup
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.computeNodeGroup }}'
    item:
      name: '{{ item.name }}'
      id: '{{ item.id }}'
      arn: '{{ item.arn }}'
      clusterId: '{{ item.clusterId }}'
      createdAt: '{{ item.createdAt }}'
      modifiedAt: '{{ item.modifiedAt }}'
      status: '{{ item.status }}'
      amiId: '{{ item.amiId }}'
      subnetIds: '{{ item.subnetIds }}'
      purchaseOption: '{{ item.purchaseOption }}'
      customLaunchTemplate: '{{ item.customLaunchTemplate }}'
      iamInstanceProfileArn: '{{ item.iamInstanceProfileArn }}'
      scalingConfiguration: '{{ item.scalingConfiguration }}'
      instanceConfigs: '{{ item.instanceConfigs }}'
      spotOptions: '{{ item.spotOptions }}'
      slurmConfiguration: '{{ item.slurmConfiguration }}'
      errorInfo: '{{ item.errorInfo }}'
- discovery_id: aws.pcs.getQueue
  calls:
  - action: getQueue
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.queue }}'
    item:
      name: '{{ item.name }}'
      id: '{{ item.id }}'
      arn: '{{ item.arn }}'
      clusterId: '{{ item.clusterId }}'
      createdAt: '{{ item.createdAt }}'
      modifiedAt: '{{ item.modifiedAt }}'
      status: '{{ item.status }}'
      computeNodeGroupConfigurations: '{{ item.computeNodeGroupConfigurations }}'
      slurmConfiguration: '{{ item.slurmConfiguration }}'
      errorInfo: '{{ item.errorInfo }}'
- discovery_id: aws.pcs.listComputeNodeGroups
  calls:
  - action: listComputeNodeGroups
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.computeNodeGroups }}'
    item:
      name: '{{ item.name }}'
      id: '{{ item.id }}'
      arn: '{{ item.arn }}'
      clusterId: '{{ item.clusterId }}'
      createdAt: '{{ item.createdAt }}'
      modifiedAt: '{{ item.modifiedAt }}'
      status: '{{ item.status }}'
- discovery_id: aws.pcs.listQueues
  calls:
  - action: listQueues
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.queues }}'
    item:
      name: '{{ item.name }}'
      id: '{{ item.id }}'
      arn: '{{ item.arn }}'
      clusterId: '{{ item.clusterId }}'
      createdAt: '{{ item.createdAt }}'
      modifiedAt: '{{ item.modifiedAt }}'
      status: '{{ item.status }}'
- discovery_id: aws.pcs.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tags }}'
checks: []
