version: '1.0'
provider: aws
service: artifact
services:
  client: artifact
  module: boto3.client
discovery:
- discovery_id: aws.artifact.getAccountSettings
  calls:
  - action: getAccountSettings
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.accountSettings }}'
    item:
      notificationSubscriptionStatus: '{{ item.notificationSubscriptionStatus }}'
- discovery_id: aws.artifact.listCustomerAgreements
  calls:
  - action: listCustomerAgreements
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.customerAgreements }}'
    item:
      name: '{{ item.name }}'
      arn: '{{ item.arn }}'
      id: '{{ item.id }}'
      agreementArn: '{{ item.agreementArn }}'
      awsAccountId: '{{ item.awsAccountId }}'
      organizationArn: '{{ item.organizationArn }}'
      effectiveStart: '{{ item.effectiveStart }}'
      effectiveEnd: '{{ item.effectiveEnd }}'
      state: '{{ item.state }}'
      description: '{{ item.description }}'
      acceptanceTerms: '{{ item.acceptanceTerms }}'
      terminateTerms: '{{ item.terminateTerms }}'
      type: '{{ item.type }}'
- discovery_id: aws.artifact.listReports
  calls:
  - action: listReports
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.reports }}'
    item:
      id: '{{ item.id }}'
      name: '{{ item.name }}'
      state: '{{ item.state }}'
      arn: '{{ item.arn }}'
      version: '{{ item.version }}'
      uploadState: '{{ item.uploadState }}'
      description: '{{ item.description }}'
      periodStart: '{{ item.periodStart }}'
      periodEnd: '{{ item.periodEnd }}'
      series: '{{ item.series }}'
      category: '{{ item.category }}'
      companyName: '{{ item.companyName }}'
      productName: '{{ item.productName }}'
      statusMessage: '{{ item.statusMessage }}'
      acceptanceType: '{{ item.acceptanceType }}'
- discovery_id: aws.artifact.getReport
  calls:
  - action: getReport
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.documentPresignedUrl }}'
- discovery_id: aws.artifact.getReportMetadata
  calls:
  - action: getReportMetadata
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.reportDetails }}'
    item:
      id: '{{ item.id }}'
      name: '{{ item.name }}'
      description: '{{ item.description }}'
      periodStart: '{{ item.periodStart }}'
      periodEnd: '{{ item.periodEnd }}'
      createdAt: '{{ item.createdAt }}'
      lastModifiedAt: '{{ item.lastModifiedAt }}'
      deletedAt: '{{ item.deletedAt }}'
      state: '{{ item.state }}'
      arn: '{{ item.arn }}'
      series: '{{ item.series }}'
      category: '{{ item.category }}'
      companyName: '{{ item.companyName }}'
      productName: '{{ item.productName }}'
      termArn: '{{ item.termArn }}'
      version: '{{ item.version }}'
      acceptanceType: '{{ item.acceptanceType }}'
      sequenceNumber: '{{ item.sequenceNumber }}'
      uploadState: '{{ item.uploadState }}'
      statusMessage: '{{ item.statusMessage }}'
- discovery_id: aws.artifact.getTermForReport
  calls:
  - action: getTermForReport
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.documentPresignedUrl }}'
checks: []
