version: '1.0'
provider: aws
service: fsx
services:
  client: fsx
  module: boto3.client
discovery:
- discovery_id: aws.fsx.describeBackups
  calls:
  - action: describeBackups
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Backups }}'
    item:
      BackupId: '{{ item.BackupId }}'
      Lifecycle: '{{ item.Lifecycle }}'
      FailureDetails: '{{ item.FailureDetails }}'
      Type: '{{ item.Type }}'
      ProgressPercent: '{{ item.ProgressPercent }}'
      CreationTime: '{{ item.CreationTime }}'
      KmsKeyId: '{{ item.KmsKeyId }}'
      ResourceARN: '{{ item.ResourceARN }}'
      Tags: '{{ item.Tags }}'
      FileSystem: '{{ item.FileSystem }}'
      DirectoryInformation: '{{ item.DirectoryInformation }}'
      OwnerId: '{{ item.OwnerId }}'
      SourceBackupId: '{{ item.SourceBackupId }}'
      SourceBackupRegion: '{{ item.SourceBackupRegion }}'
      ResourceType: '{{ item.ResourceType }}'
      Volume: '{{ item.Volume }}'
      SizeInBytes: '{{ item.SizeInBytes }}'
- discovery_id: aws.fsx.describeDataRepositoryAssociations
  calls:
  - action: describeDataRepositoryAssociations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Associations }}'
    item:
      AssociationId: '{{ item.AssociationId }}'
      ResourceARN: '{{ item.ResourceARN }}'
      FileSystemId: '{{ item.FileSystemId }}'
      Lifecycle: '{{ item.Lifecycle }}'
      FailureDetails: '{{ item.FailureDetails }}'
      FileSystemPath: '{{ item.FileSystemPath }}'
      DataRepositoryPath: '{{ item.DataRepositoryPath }}'
      BatchImportMetaDataOnCreate: '{{ item.BatchImportMetaDataOnCreate }}'
      ImportedFileChunkSize: '{{ item.ImportedFileChunkSize }}'
      S3: '{{ item.S3 }}'
      Tags: '{{ item.Tags }}'
      CreationTime: '{{ item.CreationTime }}'
      FileCacheId: '{{ item.FileCacheId }}'
      FileCachePath: '{{ item.FileCachePath }}'
      DataRepositorySubdirectories: '{{ item.DataRepositorySubdirectories }}'
      NFS: '{{ item.NFS }}'
- discovery_id: aws.fsx.describeDataRepositoryTasks
  calls:
  - action: describeDataRepositoryTasks
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.DataRepositoryTasks }}'
    item:
      TaskId: '{{ item.TaskId }}'
      Lifecycle: '{{ item.Lifecycle }}'
      Type: '{{ item.Type }}'
      CreationTime: '{{ item.CreationTime }}'
      StartTime: '{{ item.StartTime }}'
      EndTime: '{{ item.EndTime }}'
      ResourceARN: '{{ item.ResourceARN }}'
      Tags: '{{ item.Tags }}'
      FileSystemId: '{{ item.FileSystemId }}'
      Paths: '{{ item.Paths }}'
      FailureDetails: '{{ item.FailureDetails }}'
      Status: '{{ item.Status }}'
      Report: '{{ item.Report }}'
      CapacityToRelease: '{{ item.CapacityToRelease }}'
      FileCacheId: '{{ item.FileCacheId }}'
      ReleaseConfiguration: '{{ item.ReleaseConfiguration }}'
- discovery_id: aws.fsx.describeFileCaches
  calls:
  - action: describeFileCaches
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.FileCaches }}'
    item:
      OwnerId: '{{ item.OwnerId }}'
      CreationTime: '{{ item.CreationTime }}'
      FileCacheId: '{{ item.FileCacheId }}'
      FileCacheType: '{{ item.FileCacheType }}'
      FileCacheTypeVersion: '{{ item.FileCacheTypeVersion }}'
      Lifecycle: '{{ item.Lifecycle }}'
      FailureDetails: '{{ item.FailureDetails }}'
      StorageCapacity: '{{ item.StorageCapacity }}'
      VpcId: '{{ item.VpcId }}'
      SubnetIds: '{{ item.SubnetIds }}'
      NetworkInterfaceIds: '{{ item.NetworkInterfaceIds }}'
      DNSName: '{{ item.DNSName }}'
      KmsKeyId: '{{ item.KmsKeyId }}'
      ResourceARN: '{{ item.ResourceARN }}'
      LustreConfiguration: '{{ item.LustreConfiguration }}'
      DataRepositoryAssociationIds: '{{ item.DataRepositoryAssociationIds }}'
- discovery_id: aws.fsx.describeFileSystems
  calls:
  - action: describeFileSystems
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.FileSystems }}'
    item:
      OwnerId: '{{ item.OwnerId }}'
      CreationTime: '{{ item.CreationTime }}'
      FileSystemId: '{{ item.FileSystemId }}'
      FileSystemType: '{{ item.FileSystemType }}'
      Lifecycle: '{{ item.Lifecycle }}'
      FailureDetails: '{{ item.FailureDetails }}'
      StorageCapacity: '{{ item.StorageCapacity }}'
      StorageType: '{{ item.StorageType }}'
      VpcId: '{{ item.VpcId }}'
      SubnetIds: '{{ item.SubnetIds }}'
      NetworkInterfaceIds: '{{ item.NetworkInterfaceIds }}'
      DNSName: '{{ item.DNSName }}'
      KmsKeyId: '{{ item.KmsKeyId }}'
      ResourceARN: '{{ item.ResourceARN }}'
      Tags: '{{ item.Tags }}'
      WindowsConfiguration: '{{ item.WindowsConfiguration }}'
      LustreConfiguration: '{{ item.LustreConfiguration }}'
      AdministrativeActions: '{{ item.AdministrativeActions }}'
      OntapConfiguration: '{{ item.OntapConfiguration }}'
      FileSystemTypeVersion: '{{ item.FileSystemTypeVersion }}'
      OpenZFSConfiguration: '{{ item.OpenZFSConfiguration }}'
      NetworkType: '{{ item.NetworkType }}'
- discovery_id: aws.fsx.describeS3AccessPointAttachments
  calls:
  - action: describeS3AccessPointAttachments
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.S3AccessPointAttachments }}'
    item:
      Lifecycle: '{{ item.Lifecycle }}'
      LifecycleTransitionReason: '{{ item.LifecycleTransitionReason }}'
      CreationTime: '{{ item.CreationTime }}'
      Name: '{{ item.Name }}'
      Type: '{{ item.Type }}'
      OpenZFSConfiguration: '{{ item.OpenZFSConfiguration }}'
      S3AccessPoint: '{{ item.S3AccessPoint }}'
- discovery_id: aws.fsx.describeSharedVpcConfiguration
  calls:
  - action: describeSharedVpcConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.EnableFsxRouteTableUpdatesFromParticipantAccounts }}'
- discovery_id: aws.fsx.describeSnapshots
  calls:
  - action: describeSnapshots
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Snapshots }}'
    item:
      ResourceARN: '{{ item.ResourceARN }}'
      SnapshotId: '{{ item.SnapshotId }}'
      Name: '{{ item.Name }}'
      VolumeId: '{{ item.VolumeId }}'
      CreationTime: '{{ item.CreationTime }}'
      Lifecycle: '{{ item.Lifecycle }}'
      LifecycleTransitionReason: '{{ item.LifecycleTransitionReason }}'
      Tags: '{{ item.Tags }}'
      AdministrativeActions: '{{ item.AdministrativeActions }}'
- discovery_id: aws.fsx.describeStorageVirtualMachines
  calls:
  - action: describeStorageVirtualMachines
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.StorageVirtualMachines }}'
    item:
      ActiveDirectoryConfiguration: '{{ item.ActiveDirectoryConfiguration }}'
      CreationTime: '{{ item.CreationTime }}'
      Endpoints: '{{ item.Endpoints }}'
      FileSystemId: '{{ item.FileSystemId }}'
      Lifecycle: '{{ item.Lifecycle }}'
      Name: '{{ item.Name }}'
      ResourceARN: '{{ item.ResourceARN }}'
      StorageVirtualMachineId: '{{ item.StorageVirtualMachineId }}'
      Subtype: '{{ item.Subtype }}'
      UUID: '{{ item.UUID }}'
      Tags: '{{ item.Tags }}'
      LifecycleTransitionReason: '{{ item.LifecycleTransitionReason }}'
      RootVolumeSecurityStyle: '{{ item.RootVolumeSecurityStyle }}'
- discovery_id: aws.fsx.describeVolumes
  calls:
  - action: describeVolumes
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Volumes }}'
    item:
      CreationTime: '{{ item.CreationTime }}'
      FileSystemId: '{{ item.FileSystemId }}'
      Lifecycle: '{{ item.Lifecycle }}'
      Name: '{{ item.Name }}'
      OntapConfiguration: '{{ item.OntapConfiguration }}'
      ResourceARN: '{{ item.ResourceARN }}'
      Tags: '{{ item.Tags }}'
      VolumeId: '{{ item.VolumeId }}'
      VolumeType: '{{ item.VolumeType }}'
      LifecycleTransitionReason: '{{ item.LifecycleTransitionReason }}'
      AdministrativeActions: '{{ item.AdministrativeActions }}'
      OpenZFSConfiguration: '{{ item.OpenZFSConfiguration }}'
- discovery_id: aws.fsx.describeFileSystemAliases
  calls:
  - action: describeFileSystemAliases
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Aliases }}'
    item:
      Name: '{{ item.Name }}'
      Lifecycle: '{{ item.Lifecycle }}'
- discovery_id: aws.fsx.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Tags }}'
    item:
      Key: '{{ item.Key }}'
      Value: '{{ item.Value }}'
checks: []
