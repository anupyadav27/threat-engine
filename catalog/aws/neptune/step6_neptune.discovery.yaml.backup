version: '1.0'
provider: aws
service: neptune
services:
  client: neptune
  module: boto3.client
discovery:
- discovery_id: aws.neptune.describeDbClusterEndpoints
  calls:
  - action: describeDbClusterEndpoints
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.DBClusterEndpoints }}'
    item:
      DBClusterEndpointIdentifier: '{{ item.DBClusterEndpointIdentifier }}'
      DBClusterIdentifier: '{{ item.DBClusterIdentifier }}'
      DBClusterEndpointResourceIdentifier: '{{ item.DBClusterEndpointResourceIdentifier
        }}'
      Endpoint: '{{ item.Endpoint }}'
      Status: '{{ item.Status }}'
      EndpointType: '{{ item.EndpointType }}'
      CustomEndpointType: '{{ item.CustomEndpointType }}'
      StaticMembers: '{{ item.StaticMembers }}'
      ExcludedMembers: '{{ item.ExcludedMembers }}'
      DBClusterEndpointArn: '{{ item.DBClusterEndpointArn }}'
- discovery_id: aws.neptune.describeDbClusterParameterGroups
  calls:
  - action: describeDbClusterParameterGroups
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.DBClusterParameterGroups }}'
    item:
      DBClusterParameterGroupName: '{{ item.DBClusterParameterGroupName }}'
      DBParameterGroupFamily: '{{ item.DBParameterGroupFamily }}'
      Description: '{{ item.Description }}'
      DBClusterParameterGroupArn: '{{ item.DBClusterParameterGroupArn }}'
- discovery_id: aws.neptune.describeDbClusterSnapshots
  calls:
  - action: describeDbClusterSnapshots
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.DBClusterSnapshots }}'
    item:
      AvailabilityZones: '{{ item.AvailabilityZones }}'
      DBClusterSnapshotIdentifier: '{{ item.DBClusterSnapshotIdentifier }}'
      DBClusterIdentifier: '{{ item.DBClusterIdentifier }}'
      SnapshotCreateTime: '{{ item.SnapshotCreateTime }}'
      Engine: '{{ item.Engine }}'
      AllocatedStorage: '{{ item.AllocatedStorage }}'
      Status: '{{ item.Status }}'
      Port: '{{ item.Port }}'
      VpcId: '{{ item.VpcId }}'
      ClusterCreateTime: '{{ item.ClusterCreateTime }}'
      MasterUsername: '{{ item.MasterUsername }}'
      EngineVersion: '{{ item.EngineVersion }}'
      LicenseModel: '{{ item.LicenseModel }}'
      SnapshotType: '{{ item.SnapshotType }}'
      PercentProgress: '{{ item.PercentProgress }}'
      StorageEncrypted: '{{ item.StorageEncrypted }}'
      KmsKeyId: '{{ item.KmsKeyId }}'
      DBClusterSnapshotArn: '{{ item.DBClusterSnapshotArn }}'
      SourceDBClusterSnapshotArn: '{{ item.SourceDBClusterSnapshotArn }}'
      IAMDatabaseAuthenticationEnabled: '{{ item.IAMDatabaseAuthenticationEnabled
        }}'
      StorageType: '{{ item.StorageType }}'
- discovery_id: aws.neptune.describeDbClusters
  calls:
  - action: describeDbClusters
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.DBClusters }}'
    item:
      AllocatedStorage: '{{ item.AllocatedStorage }}'
      AvailabilityZones: '{{ item.AvailabilityZones }}'
      BackupRetentionPeriod: '{{ item.BackupRetentionPeriod }}'
      CharacterSetName: '{{ item.CharacterSetName }}'
      DatabaseName: '{{ item.DatabaseName }}'
      DBClusterIdentifier: '{{ item.DBClusterIdentifier }}'
      DBClusterParameterGroup: '{{ item.DBClusterParameterGroup }}'
      DBSubnetGroup: '{{ item.DBSubnetGroup }}'
      Status: '{{ item.Status }}'
      PercentProgress: '{{ item.PercentProgress }}'
      EarliestRestorableTime: '{{ item.EarliestRestorableTime }}'
      Endpoint: '{{ item.Endpoint }}'
      ReaderEndpoint: '{{ item.ReaderEndpoint }}'
      MultiAZ: '{{ item.MultiAZ }}'
      Engine: '{{ item.Engine }}'
      EngineVersion: '{{ item.EngineVersion }}'
      LatestRestorableTime: '{{ item.LatestRestorableTime }}'
      Port: '{{ item.Port }}'
      MasterUsername: '{{ item.MasterUsername }}'
      DBClusterOptionGroupMemberships: '{{ item.DBClusterOptionGroupMemberships }}'
      PreferredBackupWindow: '{{ item.PreferredBackupWindow }}'
      PreferredMaintenanceWindow: '{{ item.PreferredMaintenanceWindow }}'
      ReplicationSourceIdentifier: '{{ item.ReplicationSourceIdentifier }}'
      ReadReplicaIdentifiers: '{{ item.ReadReplicaIdentifiers }}'
      DBClusterMembers: '{{ item.DBClusterMembers }}'
      VpcSecurityGroups: '{{ item.VpcSecurityGroups }}'
      HostedZoneId: '{{ item.HostedZoneId }}'
      StorageEncrypted: '{{ item.StorageEncrypted }}'
      KmsKeyId: '{{ item.KmsKeyId }}'
      DbClusterResourceId: '{{ item.DbClusterResourceId }}'
      DBClusterArn: '{{ item.DBClusterArn }}'
      AssociatedRoles: '{{ item.AssociatedRoles }}'
      IAMDatabaseAuthenticationEnabled: '{{ item.IAMDatabaseAuthenticationEnabled
        }}'
      CloneGroupId: '{{ item.CloneGroupId }}'
      ClusterCreateTime: '{{ item.ClusterCreateTime }}'
      CopyTagsToSnapshot: '{{ item.CopyTagsToSnapshot }}'
      EnabledCloudwatchLogsExports: '{{ item.EnabledCloudwatchLogsExports }}'
      PendingModifiedValues: '{{ item.PendingModifiedValues }}'
      DeletionProtection: '{{ item.DeletionProtection }}'
      CrossAccountClone: '{{ item.CrossAccountClone }}'
      AutomaticRestartTime: '{{ item.AutomaticRestartTime }}'
      ServerlessV2ScalingConfiguration: '{{ item.ServerlessV2ScalingConfiguration
        }}'
      GlobalClusterIdentifier: '{{ item.GlobalClusterIdentifier }}'
      IOOptimizedNextAllowedModificationTime: '{{ item.IOOptimizedNextAllowedModificationTime
        }}'
      StorageType: '{{ item.StorageType }}'
- discovery_id: aws.neptune.describeDbEngineVersions
  calls:
  - action: describeDbEngineVersions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.DBEngineVersions }}'
    item:
      Engine: '{{ item.Engine }}'
      EngineVersion: '{{ item.EngineVersion }}'
      DBParameterGroupFamily: '{{ item.DBParameterGroupFamily }}'
      DBEngineDescription: '{{ item.DBEngineDescription }}'
      DBEngineVersionDescription: '{{ item.DBEngineVersionDescription }}'
      DefaultCharacterSet: '{{ item.DefaultCharacterSet }}'
      SupportedCharacterSets: '{{ item.SupportedCharacterSets }}'
      ValidUpgradeTarget: '{{ item.ValidUpgradeTarget }}'
      SupportedTimezones: '{{ item.SupportedTimezones }}'
      ExportableLogTypes: '{{ item.ExportableLogTypes }}'
      SupportsLogExportsToCloudwatchLogs: '{{ item.SupportsLogExportsToCloudwatchLogs
        }}'
      SupportsReadReplica: '{{ item.SupportsReadReplica }}'
      SupportsGlobalDatabases: '{{ item.SupportsGlobalDatabases }}'
- discovery_id: aws.neptune.describeDbInstances
  calls:
  - action: describeDbInstances
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.DBInstances }}'
    item:
      DBInstanceIdentifier: '{{ item.DBInstanceIdentifier }}'
      DBInstanceClass: '{{ item.DBInstanceClass }}'
      Engine: '{{ item.Engine }}'
      DBInstanceStatus: '{{ item.DBInstanceStatus }}'
      MasterUsername: '{{ item.MasterUsername }}'
      DBName: '{{ item.DBName }}'
      Endpoint: '{{ item.Endpoint }}'
      AllocatedStorage: '{{ item.AllocatedStorage }}'
      InstanceCreateTime: '{{ item.InstanceCreateTime }}'
      PreferredBackupWindow: '{{ item.PreferredBackupWindow }}'
      BackupRetentionPeriod: '{{ item.BackupRetentionPeriod }}'
      DBSecurityGroups: '{{ item.DBSecurityGroups }}'
      VpcSecurityGroups: '{{ item.VpcSecurityGroups }}'
      DBParameterGroups: '{{ item.DBParameterGroups }}'
      AvailabilityZone: '{{ item.AvailabilityZone }}'
      DBSubnetGroup: '{{ item.DBSubnetGroup }}'
      PreferredMaintenanceWindow: '{{ item.PreferredMaintenanceWindow }}'
      PendingModifiedValues: '{{ item.PendingModifiedValues }}'
      LatestRestorableTime: '{{ item.LatestRestorableTime }}'
      MultiAZ: '{{ item.MultiAZ }}'
      EngineVersion: '{{ item.EngineVersion }}'
      AutoMinorVersionUpgrade: '{{ item.AutoMinorVersionUpgrade }}'
      ReadReplicaSourceDBInstanceIdentifier: '{{ item.ReadReplicaSourceDBInstanceIdentifier
        }}'
      ReadReplicaDBInstanceIdentifiers: '{{ item.ReadReplicaDBInstanceIdentifiers
        }}'
      ReadReplicaDBClusterIdentifiers: '{{ item.ReadReplicaDBClusterIdentifiers }}'
      LicenseModel: '{{ item.LicenseModel }}'
      Iops: '{{ item.Iops }}'
      OptionGroupMemberships: '{{ item.OptionGroupMemberships }}'
      CharacterSetName: '{{ item.CharacterSetName }}'
      SecondaryAvailabilityZone: '{{ item.SecondaryAvailabilityZone }}'
      PubliclyAccessible: '{{ item.PubliclyAccessible }}'
      StatusInfos: '{{ item.StatusInfos }}'
      StorageType: '{{ item.StorageType }}'
      TdeCredentialArn: '{{ item.TdeCredentialArn }}'
      DbInstancePort: '{{ item.DbInstancePort }}'
      DBClusterIdentifier: '{{ item.DBClusterIdentifier }}'
      StorageEncrypted: '{{ item.StorageEncrypted }}'
      KmsKeyId: '{{ item.KmsKeyId }}'
      DbiResourceId: '{{ item.DbiResourceId }}'
      CACertificateIdentifier: '{{ item.CACertificateIdentifier }}'
      DomainMemberships: '{{ item.DomainMemberships }}'
      CopyTagsToSnapshot: '{{ item.CopyTagsToSnapshot }}'
      MonitoringInterval: '{{ item.MonitoringInterval }}'
      EnhancedMonitoringResourceArn: '{{ item.EnhancedMonitoringResourceArn }}'
      MonitoringRoleArn: '{{ item.MonitoringRoleArn }}'
      PromotionTier: '{{ item.PromotionTier }}'
      DBInstanceArn: '{{ item.DBInstanceArn }}'
      Timezone: '{{ item.Timezone }}'
      IAMDatabaseAuthenticationEnabled: '{{ item.IAMDatabaseAuthenticationEnabled
        }}'
      PerformanceInsightsEnabled: '{{ item.PerformanceInsightsEnabled }}'
      PerformanceInsightsKMSKeyId: '{{ item.PerformanceInsightsKMSKeyId }}'
      EnabledCloudwatchLogsExports: '{{ item.EnabledCloudwatchLogsExports }}'
      DeletionProtection: '{{ item.DeletionProtection }}'
- discovery_id: aws.neptune.describeDbParameterGroups
  calls:
  - action: describeDbParameterGroups
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.DBParameterGroups }}'
    item:
      DBParameterGroupName: '{{ item.DBParameterGroupName }}'
      DBParameterGroupFamily: '{{ item.DBParameterGroupFamily }}'
      Description: '{{ item.Description }}'
      DBParameterGroupArn: '{{ item.DBParameterGroupArn }}'
- discovery_id: aws.neptune.describeDbSubnetGroups
  calls:
  - action: describeDbSubnetGroups
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.DBSubnetGroups }}'
    item:
      DBSubnetGroupName: '{{ item.DBSubnetGroupName }}'
      DBSubnetGroupDescription: '{{ item.DBSubnetGroupDescription }}'
      VpcId: '{{ item.VpcId }}'
      SubnetGroupStatus: '{{ item.SubnetGroupStatus }}'
      Subnets: '{{ item.Subnets }}'
      DBSubnetGroupArn: '{{ item.DBSubnetGroupArn }}'
- discovery_id: aws.neptune.describeEventCategories
  calls:
  - action: describeEventCategories
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.EventCategoriesMapList }}'
    item:
      SourceType: '{{ item.SourceType }}'
      EventCategories: '{{ item.EventCategories }}'
- discovery_id: aws.neptune.describeEventSubscriptions
  calls:
  - action: describeEventSubscriptions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.EventSubscriptionsList }}'
    item:
      CustomerAwsId: '{{ item.CustomerAwsId }}'
      CustSubscriptionId: '{{ item.CustSubscriptionId }}'
      SnsTopicArn: '{{ item.SnsTopicArn }}'
      Status: '{{ item.Status }}'
      SubscriptionCreationTime: '{{ item.SubscriptionCreationTime }}'
      SourceType: '{{ item.SourceType }}'
      SourceIdsList: '{{ item.SourceIdsList }}'
      EventCategoriesList: '{{ item.EventCategoriesList }}'
      Enabled: '{{ item.Enabled }}'
      EventSubscriptionArn: '{{ item.EventSubscriptionArn }}'
- discovery_id: aws.neptune.describeEvents
  calls:
  - action: describeEvents
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Events }}'
    item:
      SourceIdentifier: '{{ item.SourceIdentifier }}'
      SourceType: '{{ item.SourceType }}'
      Message: '{{ item.Message }}'
      EventCategories: '{{ item.EventCategories }}'
      Date: '{{ item.Date }}'
      SourceArn: '{{ item.SourceArn }}'
- discovery_id: aws.neptune.describeGlobalClusters
  calls:
  - action: describeGlobalClusters
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.GlobalClusters }}'
    item:
      GlobalClusterIdentifier: '{{ item.GlobalClusterIdentifier }}'
      GlobalClusterResourceId: '{{ item.GlobalClusterResourceId }}'
      GlobalClusterArn: '{{ item.GlobalClusterArn }}'
      Status: '{{ item.Status }}'
      Engine: '{{ item.Engine }}'
      EngineVersion: '{{ item.EngineVersion }}'
      StorageEncrypted: '{{ item.StorageEncrypted }}'
      DeletionProtection: '{{ item.DeletionProtection }}'
      GlobalClusterMembers: '{{ item.GlobalClusterMembers }}'
      FailoverState: '{{ item.FailoverState }}'
- discovery_id: aws.neptune.describePendingMaintenanceActions
  calls:
  - action: describePendingMaintenanceActions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.PendingMaintenanceActions }}'
    item:
      ResourceIdentifier: '{{ item.ResourceIdentifier }}'
      PendingMaintenanceActionDetails: '{{ item.PendingMaintenanceActionDetails }}'
- discovery_id: aws.neptune.describeDbClusterParameters
  calls:
  - action: describeDbClusterParameters
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Parameters }}'
    item:
      ParameterName: '{{ item.ParameterName }}'
      ParameterValue: '{{ item.ParameterValue }}'
      Description: '{{ item.Description }}'
      Source: '{{ item.Source }}'
      ApplyType: '{{ item.ApplyType }}'
      DataType: '{{ item.DataType }}'
      AllowedValues: '{{ item.AllowedValues }}'
      IsModifiable: '{{ item.IsModifiable }}'
      MinimumEngineVersion: '{{ item.MinimumEngineVersion }}'
      ApplyMethod: '{{ item.ApplyMethod }}'
- discovery_id: aws.neptune.describeDbClusterSnapshotAttributes
  calls:
  - action: describeDbClusterSnapshotAttributes
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.DBClusterSnapshotAttributesResult }}'
    item:
      DBClusterSnapshotIdentifier: '{{ item.DBClusterSnapshotIdentifier }}'
      DBClusterSnapshotAttributes: '{{ item.DBClusterSnapshotAttributes }}'
- discovery_id: aws.neptune.describeDbParameters
  calls:
  - action: describeDbParameters
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Parameters }}'
    item:
      ParameterName: '{{ item.ParameterName }}'
      ParameterValue: '{{ item.ParameterValue }}'
      Description: '{{ item.Description }}'
      Source: '{{ item.Source }}'
      ApplyType: '{{ item.ApplyType }}'
      DataType: '{{ item.DataType }}'
      AllowedValues: '{{ item.AllowedValues }}'
      IsModifiable: '{{ item.IsModifiable }}'
      MinimumEngineVersion: '{{ item.MinimumEngineVersion }}'
      ApplyMethod: '{{ item.ApplyMethod }}'
- discovery_id: aws.neptune.describeEngineDefaultClusterParameters
  calls:
  - action: describeEngineDefaultClusterParameters
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.EngineDefaults }}'
    item:
      DBParameterGroupFamily: '{{ item.DBParameterGroupFamily }}'
      Marker: '{{ item.Marker }}'
      Parameters: '{{ item.Parameters }}'
- discovery_id: aws.neptune.describeEngineDefaultParameters
  calls:
  - action: describeEngineDefaultParameters
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.EngineDefaults }}'
    item:
      DBParameterGroupFamily: '{{ item.DBParameterGroupFamily }}'
      Marker: '{{ item.Marker }}'
      Parameters: '{{ item.Parameters }}'
- discovery_id: aws.neptune.describeOrderableDbInstanceOptions
  calls:
  - action: describeOrderableDbInstanceOptions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.OrderableDBInstanceOptions }}'
    item:
      Engine: '{{ item.Engine }}'
      EngineVersion: '{{ item.EngineVersion }}'
      DBInstanceClass: '{{ item.DBInstanceClass }}'
      LicenseModel: '{{ item.LicenseModel }}'
      AvailabilityZones: '{{ item.AvailabilityZones }}'
      MultiAZCapable: '{{ item.MultiAZCapable }}'
      ReadReplicaCapable: '{{ item.ReadReplicaCapable }}'
      Vpc: '{{ item.Vpc }}'
      SupportsStorageEncryption: '{{ item.SupportsStorageEncryption }}'
      StorageType: '{{ item.StorageType }}'
      SupportsIops: '{{ item.SupportsIops }}'
      SupportsEnhancedMonitoring: '{{ item.SupportsEnhancedMonitoring }}'
      SupportsIAMDatabaseAuthentication: '{{ item.SupportsIAMDatabaseAuthentication
        }}'
      SupportsPerformanceInsights: '{{ item.SupportsPerformanceInsights }}'
      MinStorageSize: '{{ item.MinStorageSize }}'
      MaxStorageSize: '{{ item.MaxStorageSize }}'
      MinIopsPerDbInstance: '{{ item.MinIopsPerDbInstance }}'
      MaxIopsPerDbInstance: '{{ item.MaxIopsPerDbInstance }}'
      MinIopsPerGib: '{{ item.MinIopsPerGib }}'
      MaxIopsPerGib: '{{ item.MaxIopsPerGib }}'
      SupportsGlobalDatabases: '{{ item.SupportsGlobalDatabases }}'
- discovery_id: aws.neptune.describeValidDbInstanceModifications
  calls:
  - action: describeValidDbInstanceModifications
    save_as: response
    on_error: continue
    params:
      DBInstanceIdentifier: '{{ item.DBInstanceIdentifier }}'
  emit:
    as: item
    items_for: '{{ response.ValidDBInstanceModificationsMessage }}'
    item:
      Storage: '{{ item.Storage }}'
  for_each: aws.neptune.describeDBInstances
- discovery_id: aws.neptune.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.TagList }}'
    item:
      Key: '{{ item.Key }}'
      Value: '{{ item.Value }}'
checks: []
