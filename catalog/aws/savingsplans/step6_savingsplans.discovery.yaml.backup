version: '1.0'
provider: aws
service: savingsplans
services:
  client: savingsplans
  module: boto3.client
discovery:
- discovery_id: aws.savingsplans.describeSavingsPlans
  calls:
  - action: describeSavingsPlans
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.savingsPlans }}'
    item:
      offeringId: '{{ item.offeringId }}'
      savingsPlanId: '{{ item.savingsPlanId }}'
      savingsPlanArn: '{{ item.savingsPlanArn }}'
      description: '{{ item.description }}'
      start: '{{ item.start }}'
      end: '{{ item.end }}'
      state: '{{ item.state }}'
      region: '{{ item.region }}'
      ec2InstanceFamily: '{{ item.ec2InstanceFamily }}'
      savingsPlanType: '{{ item.savingsPlanType }}'
      paymentOption: '{{ item.paymentOption }}'
      productTypes: '{{ item.productTypes }}'
      currency: '{{ item.currency }}'
      commitment: '{{ item.commitment }}'
      upfrontPaymentAmount: '{{ item.upfrontPaymentAmount }}'
      recurringPaymentAmount: '{{ item.recurringPaymentAmount }}'
      termDurationInSeconds: '{{ item.termDurationInSeconds }}'
      tags: '{{ item.tags }}'
      returnableUntil: '{{ item.returnableUntil }}'
- discovery_id: aws.savingsplans.describeSavingsPlansOfferingRates
  calls:
  - action: describeSavingsPlansOfferingRates
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.searchResults }}'
    item:
      savingsPlanOffering: '{{ item.savingsPlanOffering }}'
      rate: '{{ item.rate }}'
      unit: '{{ item.unit }}'
      productType: '{{ item.productType }}'
      serviceCode: '{{ item.serviceCode }}'
      usageType: '{{ item.usageType }}'
      operation: '{{ item.operation }}'
      properties: '{{ item.properties }}'
- discovery_id: aws.savingsplans.describeSavingsPlansOfferings
  calls:
  - action: describeSavingsPlansOfferings
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.searchResults }}'
    item:
      offeringId: '{{ item.offeringId }}'
      productTypes: '{{ item.productTypes }}'
      planType: '{{ item.planType }}'
      description: '{{ item.description }}'
      paymentOption: '{{ item.paymentOption }}'
      durationSeconds: '{{ item.durationSeconds }}'
      currency: '{{ item.currency }}'
      serviceCode: '{{ item.serviceCode }}'
      usageType: '{{ item.usageType }}'
      operation: '{{ item.operation }}'
      properties: '{{ item.properties }}'
- discovery_id: aws.savingsplans.describeSavingsPlanRates
  calls:
  - action: describeSavingsPlanRates
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.searchResults }}'
    item:
      rate: '{{ item.rate }}'
      currency: '{{ item.currency }}'
      unit: '{{ item.unit }}'
      productType: '{{ item.productType }}'
      serviceCode: '{{ item.serviceCode }}'
      usageType: '{{ item.usageType }}'
      operation: '{{ item.operation }}'
      properties: '{{ item.properties }}'
- discovery_id: aws.savingsplans.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tags }}'
checks: []
