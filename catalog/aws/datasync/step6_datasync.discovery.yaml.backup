version: '1.0'
provider: aws
service: datasync
services:
  client: datasync
  module: boto3.client
discovery:
- discovery_id: aws.datasync.listAgents
  calls:
  - action: listAgents
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Agents }}'
    item:
      AgentArn: '{{ item.AgentArn }}'
      Name: '{{ item.Name }}'
      Status: '{{ item.Status }}'
      Platform: '{{ item.Platform }}'
- discovery_id: aws.datasync.listLocations
  calls:
  - action: listLocations
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Locations }}'
    item:
      LocationArn: '{{ item.LocationArn }}'
      LocationUri: '{{ item.LocationUri }}'
- discovery_id: aws.datasync.listTaskExecutions
  calls:
  - action: listTaskExecutions
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.TaskExecutions }}'
    item:
      TaskExecutionArn: '{{ item.TaskExecutionArn }}'
      Status: '{{ item.Status }}'
      TaskMode: '{{ item.TaskMode }}'
- discovery_id: aws.datasync.listTasks
  calls:
  - action: listTasks
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Tasks }}'
    item:
      TaskArn: '{{ item.TaskArn }}'
      Status: '{{ item.Status }}'
      Name: '{{ item.Name }}'
      TaskMode: '{{ item.TaskMode }}'
- discovery_id: aws.datasync.describeAgent
  calls:
  - action: describeAgent
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.PrivateLinkConfig }}'
    item:
      VpcEndpointId: '{{ item.VpcEndpointId }}'
      PrivateLinkEndpoint: '{{ item.PrivateLinkEndpoint }}'
      SubnetArns: '{{ item.SubnetArns }}'
      SecurityGroupArns: '{{ item.SecurityGroupArns }}'
- discovery_id: aws.datasync.describeLocationAzureBlob
  calls:
  - action: describeLocationAzureBlob
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AgentArns }}'
- discovery_id: aws.datasync.describeLocationEfs
  calls:
  - action: describeLocationEfs
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Ec2Config }}'
    item:
      SubnetArn: '{{ item.SubnetArn }}'
      SecurityGroupArns: '{{ item.SecurityGroupArns }}'
- discovery_id: aws.datasync.describeLocationFsxLustre
  calls:
  - action: describeLocationFsxLustre
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.SecurityGroupArns }}'
- discovery_id: aws.datasync.describeLocationFsxOntap
  calls:
  - action: describeLocationFsxOntap
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.SecurityGroupArns }}'
- discovery_id: aws.datasync.describeLocationFsxOpenZfs
  calls:
  - action: describeLocationFsxOpenZfs
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.SecurityGroupArns }}'
- discovery_id: aws.datasync.describeLocationFsxWindows
  calls:
  - action: describeLocationFsxWindows
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.SecurityGroupArns }}'
- discovery_id: aws.datasync.describeLocationHdfs
  calls:
  - action: describeLocationHdfs
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.NameNodes }}'
    item:
      Hostname: '{{ item.Hostname }}'
      Port: '{{ item.Port }}'
- discovery_id: aws.datasync.describeLocationNfs
  calls:
  - action: describeLocationNfs
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.OnPremConfig }}'
    item:
      AgentArns: '{{ item.AgentArns }}'
- discovery_id: aws.datasync.describeLocationObjectStorage
  calls:
  - action: describeLocationObjectStorage
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AgentArns }}'
- discovery_id: aws.datasync.describeLocationS3
  calls:
  - action: describeLocationS3
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AgentArns }}'
- discovery_id: aws.datasync.describeLocationSmb
  calls:
  - action: describeLocationSmb
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AgentArns }}'
- discovery_id: aws.datasync.describeTask
  calls:
  - action: describeTask
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.SourceNetworkInterfaceArns }}'
- discovery_id: aws.datasync.describeTaskExecution
  calls:
  - action: describeTaskExecution
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Excludes }}'
    item:
      FilterType: '{{ item.FilterType }}'
      Value: '{{ item.Value }}'
- discovery_id: aws.datasync.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Tags }}'
    item:
      Key: '{{ item.Key }}'
      Value: '{{ item.Value }}'
checks: []
