version: '1.0'
provider: aws
service: controlcatalog
services:
  client: controlcatalog
  module: boto3.client
discovery:
- discovery_id: aws.controlcatalog.listCommonControls
  calls:
  - action: listCommonControls
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.CommonControls }}'
    item:
      Arn: '{{ item.Arn }}'
      Name: '{{ item.Name }}'
      Description: '{{ item.Description }}'
      Domain: '{{ item.Domain }}'
      Objective: '{{ item.Objective }}'
      CreateTime: '{{ item.CreateTime }}'
      LastUpdateTime: '{{ item.LastUpdateTime }}'
- discovery_id: aws.controlcatalog.listControlMappings
  calls:
  - action: listControlMappings
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.ControlMappings }}'
    item:
      ControlArn: '{{ item.ControlArn }}'
      MappingType: '{{ item.MappingType }}'
      Mapping: '{{ item.Mapping }}'
- discovery_id: aws.controlcatalog.listControls
  calls:
  - action: listControls
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Controls }}'
    item:
      Arn: '{{ item.Arn }}'
      Aliases: '{{ item.Aliases }}'
      Name: '{{ item.Name }}'
      Description: '{{ item.Description }}'
      Behavior: '{{ item.Behavior }}'
      Severity: '{{ item.Severity }}'
      Implementation: '{{ item.Implementation }}'
      CreateTime: '{{ item.CreateTime }}'
      GovernedResources: '{{ item.GovernedResources }}'
- discovery_id: aws.controlcatalog.listDomains
  calls:
  - action: listDomains
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Domains }}'
    item:
      Arn: '{{ item.Arn }}'
      Name: '{{ item.Name }}'
      Description: '{{ item.Description }}'
      CreateTime: '{{ item.CreateTime }}'
      LastUpdateTime: '{{ item.LastUpdateTime }}'
- discovery_id: aws.controlcatalog.listObjectives
  calls:
  - action: listObjectives
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Objectives }}'
    item:
      Arn: '{{ item.Arn }}'
      Name: '{{ item.Name }}'
      Description: '{{ item.Description }}'
      Domain: '{{ item.Domain }}'
      CreateTime: '{{ item.CreateTime }}'
      LastUpdateTime: '{{ item.LastUpdateTime }}'
- discovery_id: aws.controlcatalog.getControl
  calls:
  - action: getControl
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.GovernedResources }}'
checks: []
