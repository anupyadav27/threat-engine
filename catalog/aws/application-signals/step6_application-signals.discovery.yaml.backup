version: '1.0'
provider: aws
service: application-signals
services:
  client: application-signals
  module: boto3.client
discovery:
- discovery_id: aws.application-signals.listGroupingAttributeDefinitions
  calls:
  - action: listGroupingAttributeDefinitions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.GroupingAttributeDefinitions }}'
    item:
      GroupingName: '{{ item.GroupingName }}'
      GroupingSourceKeys: '{{ item.GroupingSourceKeys }}'
      DefaultGroupingValue: '{{ item.DefaultGroupingValue }}'
- discovery_id: aws.application-signals.listServiceLevelObjectives
  calls:
  - action: listServiceLevelObjectives
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.SloSummaries }}'
    item:
      Arn: '{{ item.Arn }}'
      Name: '{{ item.Name }}'
      KeyAttributes: '{{ item.KeyAttributes }}'
      OperationName: '{{ item.OperationName }}'
      DependencyConfig: '{{ item.DependencyConfig }}'
      CreatedTime: '{{ item.CreatedTime }}'
      EvaluationType: '{{ item.EvaluationType }}'
      MetricSourceType: '{{ item.MetricSourceType }}'
- discovery_id: aws.application-signals.getService
  calls:
  - action: getService
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.LogGroupReferences }}'
- discovery_id: aws.application-signals.getServiceLevelObjective
  calls:
  - action: getServiceLevelObjective
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Slo }}'
    item:
      Arn: '{{ item.Arn }}'
      Name: '{{ item.Name }}'
      Description: '{{ item.Description }}'
      CreatedTime: '{{ item.CreatedTime }}'
      LastUpdatedTime: '{{ item.LastUpdatedTime }}'
      Sli: '{{ item.Sli }}'
      RequestBasedSli: '{{ item.RequestBasedSli }}'
      EvaluationType: '{{ item.EvaluationType }}'
      Goal: '{{ item.Goal }}'
      BurnRateConfigurations: '{{ item.BurnRateConfigurations }}'
      MetricSourceType: '{{ item.MetricSourceType }}'
- discovery_id: aws.application-signals.listAuditFindings
  calls:
  - action: listAuditFindings
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.AuditFindings }}'
    item:
      KeyAttributes: '{{ item.KeyAttributes }}'
      AuditorResults: '{{ item.AuditorResults }}'
      Operation: '{{ item.Operation }}'
      MetricGraph: '{{ item.MetricGraph }}'
      DependencyGraph: '{{ item.DependencyGraph }}'
      Type: '{{ item.Type }}'
- discovery_id: aws.application-signals.listEntityEvents
  calls:
  - action: listEntityEvents
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.ChangeEvents }}'
    item:
      Timestamp: '{{ item.Timestamp }}'
      AccountId: '{{ item.AccountId }}'
      Region: '{{ item.Region }}'
      Entity: '{{ item.Entity }}'
      ChangeEventType: '{{ item.ChangeEventType }}'
      EventId: '{{ item.EventId }}'
      UserName: '{{ item.UserName }}'
      EventName: '{{ item.EventName }}'
- discovery_id: aws.application-signals.listServiceDependencies
  calls:
  - action: listServiceDependencies
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.ServiceDependencies }}'
    item:
      OperationName: '{{ item.OperationName }}'
      DependencyKeyAttributes: '{{ item.DependencyKeyAttributes }}'
      DependencyOperationName: '{{ item.DependencyOperationName }}'
      MetricReferences: '{{ item.MetricReferences }}'
- discovery_id: aws.application-signals.listServiceDependents
  calls:
  - action: listServiceDependents
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.ServiceDependents }}'
    item:
      OperationName: '{{ item.OperationName }}'
      DependentKeyAttributes: '{{ item.DependentKeyAttributes }}'
      DependentOperationName: '{{ item.DependentOperationName }}'
      MetricReferences: '{{ item.MetricReferences }}'
- discovery_id: aws.application-signals.listServiceLevelObjectiveExclusionWindows
  calls:
  - action: listServiceLevelObjectiveExclusionWindows
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.ExclusionWindows }}'
    item:
      Window: '{{ item.Window }}'
      StartTime: '{{ item.StartTime }}'
      RecurrenceRule: '{{ item.RecurrenceRule }}'
      Reason: '{{ item.Reason }}'
- discovery_id: aws.application-signals.listServiceOperations
  calls:
  - action: listServiceOperations
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.ServiceOperations }}'
    item:
      Name: '{{ item.Name }}'
      MetricReferences: '{{ item.MetricReferences }}'
- discovery_id: aws.application-signals.listServiceStates
  calls:
  - action: listServiceStates
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.ServiceStates }}'
    item:
      AttributeFilters: '{{ item.AttributeFilters }}'
      Service: '{{ item.Service }}'
      LatestChangeEvents: '{{ item.LatestChangeEvents }}'
- discovery_id: aws.application-signals.listServices
  calls:
  - action: listServices
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.ServiceSummaries }}'
    item:
      KeyAttributes: '{{ item.KeyAttributes }}'
      AttributeMaps: '{{ item.AttributeMaps }}'
      MetricReferences: '{{ item.MetricReferences }}'
      ServiceGroups: '{{ item.ServiceGroups }}'
- discovery_id: aws.application-signals.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Tags }}'
    item:
      Key: '{{ item.Key }}'
      Value: '{{ item.Value }}'
checks: []
