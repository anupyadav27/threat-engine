      dataDeletionJobArn: '{{ item.dataDeletionJobArn }}'
      datasetGroupArn: '{{ item.datasetGroupArn }}'
      dataSource: '{{ item.dataSource }}'
      roleArn: '{{ item.roleArn }}'
      status: '{{ item.status }}'
      numDeleted: '{{ item.numDeleted }}'
      creationDateTime: '{{ item.creationDateTime }}'
      lastUpdatedDateTime: '{{ item.lastUpdatedDateTime }}'
      failureReason: '{{ item.failureReason }}'
- discovery_id: aws.personalize.describeDataset
  calls:
  - action: describeDataset
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.dataset }}'
    item:
      name: '{{ item.name }}'
      datasetArn: '{{ item.datasetArn }}'
      datasetGroupArn: '{{ item.datasetGroupArn }}'
      datasetType: '{{ item.datasetType }}'
      schemaArn: '{{ item.schemaArn }}'
      status: '{{ item.status }}'
      creationDateTime: '{{ item.creationDateTime }}'
      lastUpdatedDateTime: '{{ item.lastUpdatedDateTime }}'
      latestDatasetUpdate: '{{ item.latestDatasetUpdate }}'
      trackingId: '{{ item.trackingId }}'
- discovery_id: aws.personalize.describeDatasetExportJob
  calls:
  - action: describeDatasetExportJob
    save_as: response
