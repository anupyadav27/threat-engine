    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Filters }}'
    item:
      name: '{{ item.name }}'
      filterArn: '{{ item.filterArn }}'
      creationDateTime: '{{ item.creationDateTime }}'
      lastUpdatedDateTime: '{{ item.lastUpdatedDateTime }}'
      datasetGroupArn: '{{ item.datasetGroupArn }}'
      failureReason: '{{ item.failureReason }}'
      status: '{{ item.status }}'
- discovery_id: aws.personalize.listMetricAttributionMetrics
  calls:
  - action: listMetricAttributionMetrics
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.metrics }}'
    item:
      eventType: '{{ item.eventType }}'
      metricName: '{{ item.metricName }}'
      expression: '{{ item.expression }}'
- discovery_id: aws.personalize.listMetricAttributions
  calls:
  - action: listMetricAttributions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.metricAttributions }}'
    item:
      name: '{{ item.name }}'
      metricAttributionArn: '{{ item.metricAttributionArn }}'
      status: '{{ item.status }}'
      creationDateTime: '{{ item.creationDateTime }}'
      lastUpdatedDateTime: '{{ item.lastUpdatedDateTime }}'
      failureReason: '{{ item.failureReason }}'
- discovery_id: aws.personalize.listRecipes
  calls:
  - action: listRecipes
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.recipes }}'
    item:
      name: '{{ item.name }}'
      recipeArn: '{{ item.recipeArn }}'
      status: '{{ item.status }}'
      creationDateTime: '{{ item.creationDateTime }}'
      lastUpdatedDateTime: '{{ item.lastUpdatedDateTime }}'
      domain: '{{ item.domain }}'
- discovery_id: aws.personalize.listRecommenders
  calls:
  - action: listRecommenders
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.recommenders }}'
    item:
      name: '{{ item.name }}'
      recommenderArn: '{{ item.recommenderArn }}'
      datasetGroupArn: '{{ item.datasetGroupArn }}'
      recipeArn: '{{ item.recipeArn }}'
      recommenderConfig: '{{ item.recommenderConfig }}'
      status: '{{ item.status }}'
      creationDateTime: '{{ item.creationDateTime }}'
      lastUpdatedDateTime: '{{ item.lastUpdatedDateTime }}'
- discovery_id: aws.personalize.listSchemas
  calls:
  - action: listSchemas
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.schemas }}'
    item:
      name: '{{ item.name }}'
      schemaArn: '{{ item.schemaArn }}'
      creationDateTime: '{{ item.creationDateTime }}'
      lastUpdatedDateTime: '{{ item.lastUpdatedDateTime }}'
      domain: '{{ item.domain }}'
- discovery_id: aws.personalize.listSolutionVersions
  calls:
  - action: listSolutionVersions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.solutionVersions }}'
    item:
      solutionVersionArn: '{{ item.solutionVersionArn }}'
      status: '{{ item.status }}'
      trainingMode: '{{ item.trainingMode }}'
      trainingType: '{{ item.trainingType }}'
      creationDateTime: '{{ item.creationDateTime }}'
      lastUpdatedDateTime: '{{ item.lastUpdatedDateTime }}'
      failureReason: '{{ item.failureReason }}'
- discovery_id: aws.personalize.listSolutions
  calls:
  - action: listSolutions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.solutions }}'
    item:
      name: '{{ item.name }}'
      solutionArn: '{{ item.solutionArn }}'
      status: '{{ item.status }}'
      creationDateTime: '{{ item.creationDateTime }}'
      lastUpdatedDateTime: '{{ item.lastUpdatedDateTime }}'
      recipeArn: '{{ item.recipeArn }}'
- discovery_id: aws.personalize.describeAlgorithm
  calls:
  - action: describeAlgorithm
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.algorithm }}'
    item:
      name: '{{ item.name }}'
      algorithmArn: '{{ item.algorithmArn }}'
      algorithmImage: '{{ item.algorithmImage }}'
      defaultHyperParameters: '{{ item.defaultHyperParameters }}'
      defaultHyperParameterRanges: '{{ item.defaultHyperParameterRanges }}'
      defaultResourceConfig: '{{ item.defaultResourceConfig }}'
      trainingInputMode: '{{ item.trainingInputMode }}'
      roleArn: '{{ item.roleArn }}'
      creationDateTime: '{{ item.creationDateTime }}'
      lastUpdatedDateTime: '{{ item.lastUpdatedDateTime }}'
- discovery_id: aws.personalize.describeBatchInferenceJob
  calls:
  - action: describeBatchInferenceJob
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.batchInferenceJob }}'
    item:
      jobName: '{{ item.jobName }}'
      batchInferenceJobArn: '{{ item.batchInferenceJobArn }}'
      filterArn: '{{ item.filterArn }}'
      failureReason: '{{ item.failureReason }}'
      solutionVersionArn: '{{ item.solutionVersionArn }}'
      numResults: '{{ item.numResults }}'
      jobInput: '{{ item.jobInput }}'
      jobOutput: '{{ item.jobOutput }}'
      batchInferenceJobConfig: '{{ item.batchInferenceJobConfig }}'
      roleArn: '{{ item.roleArn }}'
      batchInferenceJobMode: '{{ item.batchInferenceJobMode }}'
      themeGenerationConfig: '{{ item.themeGenerationConfig }}'
      status: '{{ item.status }}'
      creationDateTime: '{{ item.creationDateTime }}'
      lastUpdatedDateTime: '{{ item.lastUpdatedDateTime }}'
- discovery_id: aws.personalize.describeBatchSegmentJob
  calls:
