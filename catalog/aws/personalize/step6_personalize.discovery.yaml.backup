      description: '{{ item.description }}'
      creationDateTime: '{{ item.creationDateTime }}'
      recipeType: '{{ item.recipeType }}'
      lastUpdatedDateTime: '{{ item.lastUpdatedDateTime }}'
- discovery_id: aws.personalize.describeRecommender
  calls:
