version: '1.0'
provider: aws
service: personalize
services:
  client: personalize
  module: boto3.client
discovery:
- discovery_id: aws.personalize.listBatchInferenceJobs
  calls:
  - action: listBatchInferenceJobs
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.batchInferenceJobs }}'
    item:
      batchInferenceJobArn: '{{ item.batchInferenceJobArn }}'
      jobName: '{{ item.jobName }}'
      status: '{{ item.status }}'
      creationDateTime: '{{ item.creationDateTime }}'
      lastUpdatedDateTime: '{{ item.lastUpdatedDateTime }}'
      failureReason: '{{ item.failureReason }}'
      solutionVersionArn: '{{ item.solutionVersionArn }}'
      batchInferenceJobMode: '{{ item.batchInferenceJobMode }}'
- discovery_id: aws.personalize.listBatchSegmentJobs
  calls:
  - action: listBatchSegmentJobs
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.batchSegmentJobs }}'
    item:
      batchSegmentJobArn: '{{ item.batchSegmentJobArn }}'
      jobName: '{{ item.jobName }}'
      status: '{{ item.status }}'
      creationDateTime: '{{ item.creationDateTime }}'
      lastUpdatedDateTime: '{{ item.lastUpdatedDateTime }}'
      failureReason: '{{ item.failureReason }}'
      solutionVersionArn: '{{ item.solutionVersionArn }}'
- discovery_id: aws.personalize.listCampaigns
  calls:
  - action: listCampaigns
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.campaigns }}'
    item:
      name: '{{ item.name }}'
      campaignArn: '{{ item.campaignArn }}'
      status: '{{ item.status }}'
      creationDateTime: '{{ item.creationDateTime }}'
      lastUpdatedDateTime: '{{ item.lastUpdatedDateTime }}'
      failureReason: '{{ item.failureReason }}'
- discovery_id: aws.personalize.listDataDeletionJobs
  calls:
  - action: listDataDeletionJobs
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.dataDeletionJobs }}'
    item:
      dataDeletionJobArn: '{{ item.dataDeletionJobArn }}'
      datasetGroupArn: '{{ item.datasetGroupArn }}'
      jobName: '{{ item.jobName }}'
      status: '{{ item.status }}'
      creationDateTime: '{{ item.creationDateTime }}'
      lastUpdatedDateTime: '{{ item.lastUpdatedDateTime }}'
      failureReason: '{{ item.failureReason }}'
- discovery_id: aws.personalize.listDatasetExportJobs
  calls:
  - action: listDatasetExportJobs
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.datasetExportJobs }}'
    item:
      datasetExportJobArn: '{{ item.datasetExportJobArn }}'
      jobName: '{{ item.jobName }}'
      status: '{{ item.status }}'
      creationDateTime: '{{ item.creationDateTime }}'
      lastUpdatedDateTime: '{{ item.lastUpdatedDateTime }}'
      failureReason: '{{ item.failureReason }}'
- discovery_id: aws.personalize.listDatasetGroups
  calls:
  - action: listDatasetGroups
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.datasetGroups }}'
    item:
      name: '{{ item.name }}'
      datasetGroupArn: '{{ item.datasetGroupArn }}'
      status: '{{ item.status }}'
      creationDateTime: '{{ item.creationDateTime }}'
      lastUpdatedDateTime: '{{ item.lastUpdatedDateTime }}'
      failureReason: '{{ item.failureReason }}'
      domain: '{{ item.domain }}'
- discovery_id: aws.personalize.listDatasetImportJobs
  calls:
  - action: listDatasetImportJobs
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.datasetImportJobs }}'
    item:
      datasetImportJobArn: '{{ item.datasetImportJobArn }}'
      jobName: '{{ item.jobName }}'
      status: '{{ item.status }}'
      creationDateTime: '{{ item.creationDateTime }}'
      lastUpdatedDateTime: '{{ item.lastUpdatedDateTime }}'
      failureReason: '{{ item.failureReason }}'
      importMode: '{{ item.importMode }}'
- discovery_id: aws.personalize.listDatasets
  calls:
  - action: listDatasets
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.datasets }}'
    item:
      name: '{{ item.name }}'
      datasetArn: '{{ item.datasetArn }}'
      datasetType: '{{ item.datasetType }}'
      status: '{{ item.status }}'
      creationDateTime: '{{ item.creationDateTime }}'
      lastUpdatedDateTime: '{{ item.lastUpdatedDateTime }}'
- discovery_id: aws.personalize.listEventTrackers
  calls:
  - action: listEventTrackers
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.eventTrackers }}'
    item:
      name: '{{ item.name }}'
      eventTrackerArn: '{{ item.eventTrackerArn }}'
      status: '{{ item.status }}'
      creationDateTime: '{{ item.creationDateTime }}'
