- discovery_id: aws.personalize.getSolutionMetrics
  calls:
  - action: getSolutionMetrics
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.solutionVersionArn }}'
- discovery_id: aws.personalize.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tags }}'
    item:
      tagKey: '{{ item.tagKey }}'
      tagValue: '{{ item.tagValue }}'
checks: []
