    items_for: '{{ response.eventTracker }}'
    item:
      name: '{{ item.name }}'
      eventTrackerArn: '{{ item.eventTrackerArn }}'
      accountId: '{{ item.accountId }}'
      trackingId: '{{ item.trackingId }}'
      datasetGroupArn: '{{ item.datasetGroupArn }}'
      status: '{{ item.status }}'
      creationDateTime: '{{ item.creationDateTime }}'
      lastUpdatedDateTime: '{{ item.lastUpdatedDateTime }}'
- discovery_id: aws.personalize.describeFeatureTransformation
  calls:
  - action: describeFeatureTransformation
    save_as: response
    on_error: continue
  emit:
