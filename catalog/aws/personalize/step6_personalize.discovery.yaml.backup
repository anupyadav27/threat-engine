      domain: '{{ item.domain }}'
- discovery_id: aws.personalize.describeSolution
  calls:
  - action: describeSolution
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.solution }}'
    item:
      name: '{{ item.name }}'
      solutionArn: '{{ item.solutionArn }}'
      performHPO: '{{ item.performHPO }}'
