  calls:
  - action: describeSolutionVersion
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.solutionVersion }}'
    item:
      name: '{{ item.name }}'
      solutionVersionArn: '{{ item.solutionVersionArn }}'
      solutionArn: '{{ item.solutionArn }}'
      performHPO: '{{ item.performHPO }}'
      performAutoML: '{{ item.performAutoML }}'
      recipeArn: '{{ item.recipeArn }}'
      eventType: '{{ item.eventType }}'
      datasetGroupArn: '{{ item.datasetGroupArn }}'
      solutionConfig: '{{ item.solutionConfig }}'
      trainingHours: '{{ item.trainingHours }}'
      trainingMode: '{{ item.trainingMode }}'
