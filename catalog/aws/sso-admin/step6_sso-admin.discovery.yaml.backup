version: '1.0'
provider: aws
service: sso-admin
services:
  client: sso-admin
  module: boto3.client
discovery:
- discovery_id: aws.sso-admin.listApplicationProviders
  calls:
  - action: listApplicationProviders
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.ApplicationProviders }}'
    item:
      ApplicationProviderArn: '{{ item.ApplicationProviderArn }}'
      FederationProtocol: '{{ item.FederationProtocol }}'
      DisplayData: '{{ item.DisplayData }}'
      ResourceServerConfig: '{{ item.ResourceServerConfig }}'
- discovery_id: aws.sso-admin.listInstances
  calls:
  - action: listInstances
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Instances }}'
    item:
      InstanceArn: '{{ item.InstanceArn }}'
      IdentityStoreId: '{{ item.IdentityStoreId }}'
      OwnerAccountId: '{{ item.OwnerAccountId }}'
      Name: '{{ item.Name }}'
      CreatedDate: '{{ item.CreatedDate }}'
      Status: '{{ item.Status }}'
      StatusReason: '{{ item.StatusReason }}'
- discovery_id: aws.sso-admin.describeAccountAssignmentCreationStatus
  calls:
  - action: describeAccountAssignmentCreationStatus
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AccountAssignmentCreationStatus }}'
    item:
      Status: '{{ item.Status }}'
      RequestId: '{{ item.RequestId }}'
      FailureReason: '{{ item.FailureReason }}'
      TargetId: '{{ item.TargetId }}'
      TargetType: '{{ item.TargetType }}'
      PermissionSetArn: '{{ item.PermissionSetArn }}'
      PrincipalType: '{{ item.PrincipalType }}'
      PrincipalId: '{{ item.PrincipalId }}'
      CreatedDate: '{{ item.CreatedDate }}'
- discovery_id: aws.sso-admin.describeAccountAssignmentDeletionStatus
  calls:
  - action: describeAccountAssignmentDeletionStatus
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AccountAssignmentDeletionStatus }}'
    item:
      Status: '{{ item.Status }}'
      RequestId: '{{ item.RequestId }}'
      FailureReason: '{{ item.FailureReason }}'
      TargetId: '{{ item.TargetId }}'
      TargetType: '{{ item.TargetType }}'
      PermissionSetArn: '{{ item.PermissionSetArn }}'
      PrincipalType: '{{ item.PrincipalType }}'
      PrincipalId: '{{ item.PrincipalId }}'
      CreatedDate: '{{ item.CreatedDate }}'
- discovery_id: aws.sso-admin.describeApplication
  calls:
  - action: describeApplication
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.PortalOptions }}'
    item:
      SignInOptions: '{{ item.SignInOptions }}'
      Visibility: '{{ item.Visibility }}'
- discovery_id: aws.sso-admin.describeApplicationAssignment
  calls:
  - action: describeApplicationAssignment
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.PrincipalType }}'
- discovery_id: aws.sso-admin.describeApplicationProvider
  calls:
  - action: describeApplicationProvider
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.DisplayData }}'
    item:
      DisplayName: '{{ item.DisplayName }}'
      IconUrl: '{{ item.IconUrl }}'
      Description: '{{ item.Description }}'
- discovery_id: aws.sso-admin.describeInstance
  calls:
  - action: describeInstance
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.EncryptionConfigurationDetails }}'
    item:
      KeyType: '{{ item.KeyType }}'
      KmsKeyArn: '{{ item.KmsKeyArn }}'
      EncryptionStatus: '{{ item.EncryptionStatus }}'
      EncryptionStatusReason: '{{ item.EncryptionStatusReason }}'
- discovery_id: aws.sso-admin.describeInstanceAccessControlAttributeConfiguration
  calls:
  - action: describeInstanceAccessControlAttributeConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.InstanceAccessControlAttributeConfiguration }}'
    item:
      AccessControlAttributes: '{{ item.AccessControlAttributes }}'
- discovery_id: aws.sso-admin.describePermissionSet
  calls:
  - action: describePermissionSet
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.PermissionSet }}'
    item:
      Name: '{{ item.Name }}'
      PermissionSetArn: '{{ item.PermissionSetArn }}'
      Description: '{{ item.Description }}'
      CreatedDate: '{{ item.CreatedDate }}'
      SessionDuration: '{{ item.SessionDuration }}'
      RelayState: '{{ item.RelayState }}'
- discovery_id: aws.sso-admin.describePermissionSetProvisioningStatus
  calls:
  - action: describePermissionSetProvisioningStatus
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.PermissionSetProvisioningStatus }}'
    item:
      Status: '{{ item.Status }}'
      RequestId: '{{ item.RequestId }}'
      AccountId: '{{ item.AccountId }}'
      PermissionSetArn: '{{ item.PermissionSetArn }}'
      FailureReason: '{{ item.FailureReason }}'
      CreatedDate: '{{ item.CreatedDate }}'
- discovery_id: aws.sso-admin.describeTrustedTokenIssuer
  calls:
  - action: describeTrustedTokenIssuer
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.TrustedTokenIssuerConfiguration }}'
    item:
      OidcJwtConfiguration: '{{ item.OidcJwtConfiguration }}'
- discovery_id: aws.sso-admin.getApplicationAccessScope
  calls:
  - action: getApplicationAccessScope
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AuthorizedTargets }}'
- discovery_id: aws.sso-admin.getApplicationAssignmentConfiguration
  calls:
  - action: getApplicationAssignmentConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AssignmentRequired }}'
- discovery_id: aws.sso-admin.getApplicationAuthenticationMethod
  calls:
  - action: getApplicationAuthenticationMethod
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AuthenticationMethod }}'
    item:
      Iam: '{{ item.Iam }}'
- discovery_id: aws.sso-admin.getApplicationGrant
  calls:
  - action: getApplicationGrant
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Grant }}'
    item:
      AuthorizationCode: '{{ item.AuthorizationCode }}'
      JwtBearer: '{{ item.JwtBearer }}'
      RefreshToken: '{{ item.RefreshToken }}'
      TokenExchange: '{{ item.TokenExchange }}'
- discovery_id: aws.sso-admin.getApplicationSessionConfiguration
  calls:
  - action: getApplicationSessionConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.UserBackgroundSessionApplicationStatus }}'
- discovery_id: aws.sso-admin.getInlinePolicyForPermissionSet
  calls:
  - action: getInlinePolicyForPermissionSet
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.InlinePolicy }}'
- discovery_id: aws.sso-admin.getPermissionsBoundaryForPermissionSet
  calls:
  - action: getPermissionsBoundaryForPermissionSet
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.PermissionsBoundary }}'
    item:
      CustomerManagedPolicyReference: '{{ item.CustomerManagedPolicyReference }}'
      ManagedPolicyArn: '{{ item.ManagedPolicyArn }}'
- discovery_id: aws.sso-admin.listAccountAssignmentCreationStatus
  calls:
  - action: listAccountAssignmentCreationStatus
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.AccountAssignmentsCreationStatus }}'
    item:
      Status: '{{ item.Status }}'
      RequestId: '{{ item.RequestId }}'
      CreatedDate: '{{ item.CreatedDate }}'
- discovery_id: aws.sso-admin.listAccountAssignmentDeletionStatus
  calls:
  - action: listAccountAssignmentDeletionStatus
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.AccountAssignmentsDeletionStatus }}'
    item:
      Status: '{{ item.Status }}'
      RequestId: '{{ item.RequestId }}'
      CreatedDate: '{{ item.CreatedDate }}'
- discovery_id: aws.sso-admin.listAccountAssignments
  calls:
  - action: listAccountAssignments
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.AccountAssignments }}'
    item:
      AccountId: '{{ item.AccountId }}'
      PermissionSetArn: '{{ item.PermissionSetArn }}'
      PrincipalType: '{{ item.PrincipalType }}'
      PrincipalId: '{{ item.PrincipalId }}'
- discovery_id: aws.sso-admin.listAccountAssignmentsForPrincipal
  calls:
  - action: listAccountAssignmentsForPrincipal
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.AccountAssignments }}'
    item:
      AccountId: '{{ item.AccountId }}'
      PermissionSetArn: '{{ item.PermissionSetArn }}'
      PrincipalId: '{{ item.PrincipalId }}'
      PrincipalType: '{{ item.PrincipalType }}'
- discovery_id: aws.sso-admin.listAccountsForProvisionedPermissionSet
  calls:
  - action: listAccountsForProvisionedPermissionSet
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.AccountIds }}'
- discovery_id: aws.sso-admin.listApplicationAccessScopes
  calls:
  - action: listApplicationAccessScopes
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Scopes }}'
    item:
      Scope: '{{ item.Scope }}'
      AuthorizedTargets: '{{ item.AuthorizedTargets }}'
- discovery_id: aws.sso-admin.listApplicationAssignments
  calls:
  - action: listApplicationAssignments
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.ApplicationAssignments }}'
    item:
      ApplicationArn: '{{ item.ApplicationArn }}'
      PrincipalId: '{{ item.PrincipalId }}'
      PrincipalType: '{{ item.PrincipalType }}'
- discovery_id: aws.sso-admin.listApplicationAssignmentsForPrincipal
  calls:
  - action: listApplicationAssignmentsForPrincipal
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.ApplicationAssignments }}'
    item:
      ApplicationArn: '{{ item.ApplicationArn }}'
      PrincipalId: '{{ item.PrincipalId }}'
      PrincipalType: '{{ item.PrincipalType }}'
- discovery_id: aws.sso-admin.listApplicationAuthenticationMethods
  calls:
  - action: listApplicationAuthenticationMethods
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AuthenticationMethods }}'
    item:
      AuthenticationMethodType: '{{ item.AuthenticationMethodType }}'
      AuthenticationMethod: '{{ item.AuthenticationMethod }}'
- discovery_id: aws.sso-admin.listApplicationGrants
  calls:
  - action: listApplicationGrants
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Grants }}'
    item:
      GrantType: '{{ item.GrantType }}'
      Grant: '{{ item.Grant }}'
- discovery_id: aws.sso-admin.listApplications
  calls:
  - action: listApplications
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Applications }}'
    item:
      ApplicationArn: '{{ item.ApplicationArn }}'
      ApplicationProviderArn: '{{ item.ApplicationProviderArn }}'
      Name: '{{ item.Name }}'
      ApplicationAccount: '{{ item.ApplicationAccount }}'
      InstanceArn: '{{ item.InstanceArn }}'
      Status: '{{ item.Status }}'
      PortalOptions: '{{ item.PortalOptions }}'
      Description: '{{ item.Description }}'
      CreatedDate: '{{ item.CreatedDate }}'
- discovery_id: aws.sso-admin.listCustomerManagedPolicyReferencesInPermissionSet
  calls:
  - action: listCustomerManagedPolicyReferencesInPermissionSet
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.CustomerManagedPolicyReferences }}'
    item:
      Name: '{{ item.Name }}'
      Path: '{{ item.Path }}'
- discovery_id: aws.sso-admin.listManagedPoliciesInPermissionSet
  calls:
  - action: listManagedPoliciesInPermissionSet
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.AttachedManagedPolicies }}'
    item:
      Name: '{{ item.Name }}'
      Arn: '{{ item.Arn }}'
- discovery_id: aws.sso-admin.listPermissionSetProvisioningStatus
  calls:
  - action: listPermissionSetProvisioningStatus
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.PermissionSetsProvisioningStatus }}'
    item:
      Status: '{{ item.Status }}'
      RequestId: '{{ item.RequestId }}'
      CreatedDate: '{{ item.CreatedDate }}'
- discovery_id: aws.sso-admin.listPermissionSets
  calls:
  - action: listPermissionSets
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.PermissionSets }}'
- discovery_id: aws.sso-admin.listPermissionSetsProvisionedToAccount
  calls:
  - action: listPermissionSetsProvisionedToAccount
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.PermissionSets }}'
- discovery_id: aws.sso-admin.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Tags }}'
    item:
      Key: '{{ item.Key }}'
      Value: '{{ item.Value }}'
- discovery_id: aws.sso-admin.listTrustedTokenIssuers
  calls:
  - action: listTrustedTokenIssuers
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.TrustedTokenIssuers }}'
    item:
      TrustedTokenIssuerArn: '{{ item.TrustedTokenIssuerArn }}'
      Name: '{{ item.Name }}'
      TrustedTokenIssuerType: '{{ item.TrustedTokenIssuerType }}'
checks: []
