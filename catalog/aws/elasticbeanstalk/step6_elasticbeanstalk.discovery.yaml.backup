version: '1.0'
provider: aws
service: elasticbeanstalk
services:
  client: elasticbeanstalk
  module: boto3.client
discovery:
- discovery_id: aws.elasticbeanstalk.describeAccountAttributes
  calls:
  - action: describeAccountAttributes
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ResourceQuotas }}'
    item:
      ApplicationQuota: '{{ item.ApplicationQuota }}'
      ApplicationVersionQuota: '{{ item.ApplicationVersionQuota }}'
      EnvironmentQuota: '{{ item.EnvironmentQuota }}'
      ConfigurationTemplateQuota: '{{ item.ConfigurationTemplateQuota }}'
      CustomPlatformQuota: '{{ item.CustomPlatformQuota }}'
- discovery_id: aws.elasticbeanstalk.describeApplicationVersions
  calls:
  - action: describeApplicationVersions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ApplicationVersions }}'
    item:
      ApplicationVersionArn: '{{ item.ApplicationVersionArn }}'
      ApplicationName: '{{ item.ApplicationName }}'
      Description: '{{ item.Description }}'
      VersionLabel: '{{ item.VersionLabel }}'
      SourceBuildInformation: '{{ item.SourceBuildInformation }}'
      BuildArn: '{{ item.BuildArn }}'
      SourceBundle: '{{ item.SourceBundle }}'
      DateCreated: '{{ item.DateCreated }}'
      DateUpdated: '{{ item.DateUpdated }}'
      Status: '{{ item.Status }}'
- discovery_id: aws.elasticbeanstalk.describeApplications
  calls:
  - action: describeApplications
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Applications }}'
    item:
      ApplicationArn: '{{ item.ApplicationArn }}'
      ApplicationName: '{{ item.ApplicationName }}'
      Description: '{{ item.Description }}'
      DateCreated: '{{ item.DateCreated }}'
      DateUpdated: '{{ item.DateUpdated }}'
      Versions: '{{ item.Versions }}'
      ConfigurationTemplates: '{{ item.ConfigurationTemplates }}'
      ResourceLifecycleConfig: '{{ item.ResourceLifecycleConfig }}'
- discovery_id: aws.elasticbeanstalk.describeConfigurationOptions
  calls:
  - action: describeConfigurationOptions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Options }}'
    item:
      Namespace: '{{ item.Namespace }}'
      Name: '{{ item.Name }}'
      DefaultValue: '{{ item.DefaultValue }}'
      ChangeSeverity: '{{ item.ChangeSeverity }}'
      UserDefined: '{{ item.UserDefined }}'
      ValueType: '{{ item.ValueType }}'
      ValueOptions: '{{ item.ValueOptions }}'
      MinValue: '{{ item.MinValue }}'
      MaxValue: '{{ item.MaxValue }}'
      MaxLength: '{{ item.MaxLength }}'
      Regex: '{{ item.Regex }}'
- discovery_id: aws.elasticbeanstalk.describeEnvironmentHealth
  calls:
  - action: describeEnvironmentHealth
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Causes }}'
- discovery_id: aws.elasticbeanstalk.describeEnvironmentManagedActionHistory
  calls:
  - action: describeEnvironmentManagedActionHistory
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ManagedActionHistoryItems }}'
    item:
      ActionId: '{{ item.ActionId }}'
      ActionType: '{{ item.ActionType }}'
      ActionDescription: '{{ item.ActionDescription }}'
      FailureType: '{{ item.FailureType }}'
      Status: '{{ item.Status }}'
      FailureDescription: '{{ item.FailureDescription }}'
      ExecutedTime: '{{ item.ExecutedTime }}'
      FinishedTime: '{{ item.FinishedTime }}'
- discovery_id: aws.elasticbeanstalk.describeEnvironmentManagedActions
  calls:
  - action: describeEnvironmentManagedActions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ManagedActions }}'
    item:
      ActionId: '{{ item.ActionId }}'
      ActionDescription: '{{ item.ActionDescription }}'
      ActionType: '{{ item.ActionType }}'
      Status: '{{ item.Status }}'
      WindowStartTime: '{{ item.WindowStartTime }}'
- discovery_id: aws.elasticbeanstalk.describeEnvironmentResources
  calls:
  - action: describeEnvironmentResources
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.EnvironmentResources }}'
    item:
      EnvironmentName: '{{ item.EnvironmentName }}'
      AutoScalingGroups: '{{ item.AutoScalingGroups }}'
      Instances: '{{ item.Instances }}'
      LaunchConfigurations: '{{ item.LaunchConfigurations }}'
      LaunchTemplates: '{{ item.LaunchTemplates }}'
      LoadBalancers: '{{ item.LoadBalancers }}'
      Triggers: '{{ item.Triggers }}'
      Queues: '{{ item.Queues }}'
- discovery_id: aws.elasticbeanstalk.describeEnvironments
  calls:
  - action: describeEnvironments
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Environments }}'
    item:
      EnvironmentName: '{{ item.EnvironmentName }}'
      EnvironmentId: '{{ item.EnvironmentId }}'
      ApplicationName: '{{ item.ApplicationName }}'
      VersionLabel: '{{ item.VersionLabel }}'
      SolutionStackName: '{{ item.SolutionStackName }}'
      PlatformArn: '{{ item.PlatformArn }}'
      TemplateName: '{{ item.TemplateName }}'
      Description: '{{ item.Description }}'
      EndpointURL: '{{ item.EndpointURL }}'
      CNAME: '{{ item.CNAME }}'
      DateCreated: '{{ item.DateCreated }}'
      DateUpdated: '{{ item.DateUpdated }}'
      Status: '{{ item.Status }}'
      AbortableOperationInProgress: '{{ item.AbortableOperationInProgress }}'
      Health: '{{ item.Health }}'
      HealthStatus: '{{ item.HealthStatus }}'
      Resources: '{{ item.Resources }}'
      Tier: '{{ item.Tier }}'
      EnvironmentLinks: '{{ item.EnvironmentLinks }}'
      EnvironmentArn: '{{ item.EnvironmentArn }}'
      OperationsRole: '{{ item.OperationsRole }}'
- discovery_id: aws.elasticbeanstalk.describeEvents
  calls:
  - action: describeEvents
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Events }}'
    item:
      EventDate: '{{ item.EventDate }}'
      Message: '{{ item.Message }}'
      ApplicationName: '{{ item.ApplicationName }}'
      VersionLabel: '{{ item.VersionLabel }}'
      TemplateName: '{{ item.TemplateName }}'
      EnvironmentName: '{{ item.EnvironmentName }}'
      PlatformArn: '{{ item.PlatformArn }}'
      RequestId: '{{ item.RequestId }}'
      Severity: '{{ item.Severity }}'
- discovery_id: aws.elasticbeanstalk.describeInstancesHealth
  calls:
  - action: describeInstancesHealth
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.InstanceHealthList }}'
    item:
      InstanceId: '{{ item.InstanceId }}'
      HealthStatus: '{{ item.HealthStatus }}'
      Color: '{{ item.Color }}'
      Causes: '{{ item.Causes }}'
      LaunchedAt: '{{ item.LaunchedAt }}'
      ApplicationMetrics: '{{ item.ApplicationMetrics }}'
      System: '{{ item.System }}'
      Deployment: '{{ item.Deployment }}'
      AvailabilityZone: '{{ item.AvailabilityZone }}'
      InstanceType: '{{ item.InstanceType }}'
- discovery_id: aws.elasticbeanstalk.describePlatformVersion
  calls:
  - action: describePlatformVersion
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.PlatformDescription }}'
    item:
      PlatformArn: '{{ item.PlatformArn }}'
      PlatformOwner: '{{ item.PlatformOwner }}'
      PlatformName: '{{ item.PlatformName }}'
      PlatformVersion: '{{ item.PlatformVersion }}'
      SolutionStackName: '{{ item.SolutionStackName }}'
      PlatformStatus: '{{ item.PlatformStatus }}'
      DateCreated: '{{ item.DateCreated }}'
      DateUpdated: '{{ item.DateUpdated }}'
      PlatformCategory: '{{ item.PlatformCategory }}'
      Description: '{{ item.Description }}'
      Maintainer: '{{ item.Maintainer }}'
      OperatingSystemName: '{{ item.OperatingSystemName }}'
      OperatingSystemVersion: '{{ item.OperatingSystemVersion }}'
      ProgrammingLanguages: '{{ item.ProgrammingLanguages }}'
      Frameworks: '{{ item.Frameworks }}'
      CustomAmiList: '{{ item.CustomAmiList }}'
      SupportedTierList: '{{ item.SupportedTierList }}'
      SupportedAddonList: '{{ item.SupportedAddonList }}'
      PlatformLifecycleState: '{{ item.PlatformLifecycleState }}'
      PlatformBranchName: '{{ item.PlatformBranchName }}'
      PlatformBranchLifecycleState: '{{ item.PlatformBranchLifecycleState }}'
- discovery_id: aws.elasticbeanstalk.listAvailableSolutionStacks
  calls:
  - action: listAvailableSolutionStacks
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.SolutionStacks }}'
- discovery_id: aws.elasticbeanstalk.listPlatformBranches
  calls:
  - action: listPlatformBranches
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.PlatformBranchSummaryList }}'
    item:
      PlatformName: '{{ item.PlatformName }}'
      BranchName: '{{ item.BranchName }}'
      LifecycleState: '{{ item.LifecycleState }}'
      BranchOrder: '{{ item.BranchOrder }}'
      SupportedTierList: '{{ item.SupportedTierList }}'
- discovery_id: aws.elasticbeanstalk.listPlatformVersions
  calls:
  - action: listPlatformVersions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.PlatformSummaryList }}'
    item:
      PlatformArn: '{{ item.PlatformArn }}'
      PlatformOwner: '{{ item.PlatformOwner }}'
      PlatformStatus: '{{ item.PlatformStatus }}'
      PlatformCategory: '{{ item.PlatformCategory }}'
      OperatingSystemName: '{{ item.OperatingSystemName }}'
      OperatingSystemVersion: '{{ item.OperatingSystemVersion }}'
      SupportedTierList: '{{ item.SupportedTierList }}'
      SupportedAddonList: '{{ item.SupportedAddonList }}'
      PlatformLifecycleState: '{{ item.PlatformLifecycleState }}'
      PlatformVersion: '{{ item.PlatformVersion }}'
      PlatformBranchName: '{{ item.PlatformBranchName }}'
      PlatformBranchLifecycleState: '{{ item.PlatformBranchLifecycleState }}'
- discovery_id: aws.elasticbeanstalk.describeConfigurationSettings
  calls:
  - action: describeConfigurationSettings
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ConfigurationSettings }}'
    item:
      SolutionStackName: '{{ item.SolutionStackName }}'
      PlatformArn: '{{ item.PlatformArn }}'
      ApplicationName: '{{ item.ApplicationName }}'
      TemplateName: '{{ item.TemplateName }}'
      Description: '{{ item.Description }}'
      EnvironmentName: '{{ item.EnvironmentName }}'
      DeploymentStatus: '{{ item.DeploymentStatus }}'
      DateCreated: '{{ item.DateCreated }}'
      DateUpdated: '{{ item.DateUpdated }}'
      OptionSettings: '{{ item.OptionSettings }}'
- discovery_id: aws.elasticbeanstalk.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ResourceTags }}'
    item:
      Key: '{{ item.Key }}'
      Value: '{{ item.Value }}'
- discovery_id: aws.elasticbeanstalk.retrieveEnvironmentInfo
  calls:
  - action: retrieveEnvironmentInfo
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.EnvironmentInfo }}'
    item:
      InfoType: '{{ item.InfoType }}'
      Ec2InstanceId: '{{ item.Ec2InstanceId }}'
      SampleTimestamp: '{{ item.SampleTimestamp }}'
      Message: '{{ item.Message }}'
checks: []
