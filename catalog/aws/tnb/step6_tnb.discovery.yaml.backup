version: '1.0'
provider: aws
service: tnb
services:
  client: tnb
  module: boto3.client
discovery:
- discovery_id: aws.tnb.listSolFunctionInstances
  calls:
  - action: listSolFunctionInstances
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.functionInstances }}'
    item:
      arn: '{{ item.arn }}'
      id: '{{ item.id }}'
      instantiatedVnfInfo: '{{ item.instantiatedVnfInfo }}'
      instantiationState: '{{ item.instantiationState }}'
      metadata: '{{ item.metadata }}'
      nsInstanceId: '{{ item.nsInstanceId }}'
      vnfPkgId: '{{ item.vnfPkgId }}'
      vnfPkgName: '{{ item.vnfPkgName }}'
- discovery_id: aws.tnb.listSolFunctionPackages
  calls:
  - action: listSolFunctionPackages
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.functionPackages }}'
    item:
      arn: '{{ item.arn }}'
      id: '{{ item.id }}'
      metadata: '{{ item.metadata }}'
      onboardingState: '{{ item.onboardingState }}'
      operationalState: '{{ item.operationalState }}'
      usageState: '{{ item.usageState }}'
      vnfProductName: '{{ item.vnfProductName }}'
      vnfProvider: '{{ item.vnfProvider }}'
      vnfdId: '{{ item.vnfdId }}'
      vnfdVersion: '{{ item.vnfdVersion }}'
- discovery_id: aws.tnb.listSolNetworkInstances
  calls:
  - action: listSolNetworkInstances
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.networkInstances }}'
    item:
      arn: '{{ item.arn }}'
      id: '{{ item.id }}'
      metadata: '{{ item.metadata }}'
      nsInstanceDescription: '{{ item.nsInstanceDescription }}'
      nsInstanceName: '{{ item.nsInstanceName }}'
      nsState: '{{ item.nsState }}'
      nsdId: '{{ item.nsdId }}'
      nsdInfoId: '{{ item.nsdInfoId }}'
- discovery_id: aws.tnb.listSolNetworkOperations
  calls:
  - action: listSolNetworkOperations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.networkOperations }}'
    item:
      arn: '{{ item.arn }}'
      error: '{{ item.error }}'
      id: '{{ item.id }}'
      lcmOperationType: '{{ item.lcmOperationType }}'
      metadata: '{{ item.metadata }}'
      nsInstanceId: '{{ item.nsInstanceId }}'
      operationState: '{{ item.operationState }}'
      updateType: '{{ item.updateType }}'
- discovery_id: aws.tnb.listSolNetworkPackages
  calls:
  - action: listSolNetworkPackages
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.networkPackages }}'
    item:
      arn: '{{ item.arn }}'
      id: '{{ item.id }}'
      metadata: '{{ item.metadata }}'
      nsdDesigner: '{{ item.nsdDesigner }}'
      nsdId: '{{ item.nsdId }}'
      nsdInvariantId: '{{ item.nsdInvariantId }}'
      nsdName: '{{ item.nsdName }}'
      nsdOnboardingState: '{{ item.nsdOnboardingState }}'
      nsdOperationalState: '{{ item.nsdOperationalState }}'
      nsdUsageState: '{{ item.nsdUsageState }}'
      nsdVersion: '{{ item.nsdVersion }}'
      vnfPkgIds: '{{ item.vnfPkgIds }}'
- discovery_id: aws.tnb.getSolFunctionInstance
  calls:
  - action: getSolFunctionInstance
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.instantiatedVnfInfo }}'
    item:
      vnfState: '{{ item.vnfState }}'
      vnfcResourceInfo: '{{ item.vnfcResourceInfo }}'
- discovery_id: aws.tnb.getSolFunctionPackage
  calls:
  - action: getSolFunctionPackage
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.metadata }}'
    item:
      createdAt: '{{ item.createdAt }}'
      lastModified: '{{ item.lastModified }}'
      vnfd: '{{ item.vnfd }}'
- discovery_id: aws.tnb.getSolFunctionPackageContent
  calls:
  - action: getSolFunctionPackageContent
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.contentType }}'
- discovery_id: aws.tnb.getSolFunctionPackageDescriptor
  calls:
  - action: getSolFunctionPackageDescriptor
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.contentType }}'
- discovery_id: aws.tnb.getSolNetworkInstance
  calls:
  - action: getSolNetworkInstance
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.lcmOpInfo }}'
    item:
      nsLcmOpOccId: '{{ item.nsLcmOpOccId }}'
- discovery_id: aws.tnb.getSolNetworkOperation
  calls:
  - action: getSolNetworkOperation
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tasks }}'
    item:
      taskContext: '{{ item.taskContext }}'
      taskEndTime: '{{ item.taskEndTime }}'
      taskErrorDetails: '{{ item.taskErrorDetails }}'
      taskName: '{{ item.taskName }}'
      taskStartTime: '{{ item.taskStartTime }}'
      taskStatus: '{{ item.taskStatus }}'
- discovery_id: aws.tnb.getSolNetworkPackage
  calls:
  - action: getSolNetworkPackage
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.vnfPkgIds }}'
- discovery_id: aws.tnb.getSolNetworkPackageContent
  calls:
  - action: getSolNetworkPackageContent
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.contentType }}'
- discovery_id: aws.tnb.getSolNetworkPackageDescriptor
  calls:
  - action: getSolNetworkPackageDescriptor
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.contentType }}'
- discovery_id: aws.tnb.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tags }}'
checks: []
