version: '1.0'
provider: aws
service: cloudtrail
services:
  client: cloudtrail
  module: boto3.client
discovery:
- discovery_id: aws.cloudtrail.describeQuery
  calls:
  - action: describeQuery
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.QueryStatistics }}'
    item:
      EventsMatched: '{{ item.EventsMatched }}'
      EventsScanned: '{{ item.EventsScanned }}'
      BytesScanned: '{{ item.BytesScanned }}'
      ExecutionTimeInMillis: '{{ item.ExecutionTimeInMillis }}'
      CreationTime: '{{ item.CreationTime }}'
- discovery_id: aws.cloudtrail.describeTrails
  calls:
  - action: describeTrails
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.trailList }}'
    item:
      Name: '{{ item.Name }}'
      S3BucketName: '{{ item.S3BucketName }}'
      S3KeyPrefix: '{{ item.S3KeyPrefix }}'
      SnsTopicName: '{{ item.SnsTopicName }}'
      SnsTopicARN: '{{ item.SnsTopicARN }}'
      IncludeGlobalServiceEvents: '{{ item.IncludeGlobalServiceEvents }}'
      IsMultiRegionTrail: '{{ item.IsMultiRegionTrail }}'
      HomeRegion: '{{ item.HomeRegion }}'
      TrailARN: '{{ item.TrailARN }}'
      LogFileValidationEnabled: '{{ item.LogFileValidationEnabled }}'
      CloudWatchLogsLogGroupArn: '{{ item.CloudWatchLogsLogGroupArn }}'
      CloudWatchLogsRoleArn: '{{ item.CloudWatchLogsRoleArn }}'
      KmsKeyId: '{{ item.KmsKeyId }}'
      HasCustomEventSelectors: '{{ item.HasCustomEventSelectors }}'
      HasInsightSelectors: '{{ item.HasInsightSelectors }}'
      IsOrganizationTrail: '{{ item.IsOrganizationTrail }}'
- discovery_id: aws.cloudtrail.getEventConfiguration
  calls:
  - action: getEventConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ContextKeySelectors }}'
    item:
      Type: '{{ item.Type }}'
      Equals: '{{ item.Equals }}'
- discovery_id: aws.cloudtrail.getInsightSelectors
  calls:
  - action: getInsightSelectors
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.InsightSelectors }}'
    item:
      InsightType: '{{ item.InsightType }}'
      EventCategories: '{{ item.EventCategories }}'
- discovery_id: aws.cloudtrail.listChannels
  calls:
  - action: listChannels
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Channels }}'
    item:
      ChannelArn: '{{ item.ChannelArn }}'
      Name: '{{ item.Name }}'
- discovery_id: aws.cloudtrail.listDashboards
  calls:
  - action: listDashboards
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Dashboards }}'
    item:
      DashboardArn: '{{ item.DashboardArn }}'
      Type: '{{ item.Type }}'
- discovery_id: aws.cloudtrail.listEventDataStores
  calls:
  - action: listEventDataStores
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.EventDataStores }}'
    item:
      EventDataStoreArn: '{{ item.EventDataStoreArn }}'
      Name: '{{ item.Name }}'
      TerminationProtectionEnabled: '{{ item.TerminationProtectionEnabled }}'
      Status: '{{ item.Status }}'
      AdvancedEventSelectors: '{{ item.AdvancedEventSelectors }}'
      MultiRegionEnabled: '{{ item.MultiRegionEnabled }}'
      OrganizationEnabled: '{{ item.OrganizationEnabled }}'
      RetentionPeriod: '{{ item.RetentionPeriod }}'
      CreatedTimestamp: '{{ item.CreatedTimestamp }}'
      UpdatedTimestamp: '{{ item.UpdatedTimestamp }}'
- discovery_id: aws.cloudtrail.listImports
  calls:
  - action: listImports
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Imports }}'
    item:
      ImportId: '{{ item.ImportId }}'
      ImportStatus: '{{ item.ImportStatus }}'
      Destinations: '{{ item.Destinations }}'
      CreatedTimestamp: '{{ item.CreatedTimestamp }}'
      UpdatedTimestamp: '{{ item.UpdatedTimestamp }}'
- discovery_id: aws.cloudtrail.listPublicKeys
  calls:
  - action: listPublicKeys
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.PublicKeyList }}'
    item:
      Value: '{{ item.Value }}'
      ValidityStartTime: '{{ item.ValidityStartTime }}'
      ValidityEndTime: '{{ item.ValidityEndTime }}'
      Fingerprint: '{{ item.Fingerprint }}'
- discovery_id: aws.cloudtrail.listTrails
  calls:
  - action: listTrails
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Trails }}'
    item:
      TrailARN: '{{ item.TrailARN }}'
      Name: '{{ item.Name }}'
      HomeRegion: '{{ item.HomeRegion }}'
- discovery_id: aws.cloudtrail.lookupEvents
  calls:
  - action: lookupEvents
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Events }}'
    item:
      EventId: '{{ item.EventId }}'
      EventName: '{{ item.EventName }}'
      ReadOnly: '{{ item.ReadOnly }}'
      AccessKeyId: '{{ item.AccessKeyId }}'
      EventTime: '{{ item.EventTime }}'
      EventSource: '{{ item.EventSource }}'
      Username: '{{ item.Username }}'
      Resources: '{{ item.Resources }}'
      CloudTrailEvent: '{{ item.CloudTrailEvent }}'
- discovery_id: aws.cloudtrail.getChannel
  calls:
  - action: getChannel
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Destinations }}'
    item:
      Type: '{{ item.Type }}'
      Location: '{{ item.Location }}'
- discovery_id: aws.cloudtrail.getDashboard
  calls:
  - action: getDashboard
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Widgets }}'
    item:
      QueryAlias: '{{ item.QueryAlias }}'
      QueryStatement: '{{ item.QueryStatement }}'
      QueryParameters: '{{ item.QueryParameters }}'
      ViewProperties: '{{ item.ViewProperties }}'
- discovery_id: aws.cloudtrail.getEventDataStore
  calls:
  - action: getEventDataStore
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.PartitionKeys }}'
    item:
      Name: '{{ item.Name }}'
      Type: '{{ item.Type }}'
- discovery_id: aws.cloudtrail.getEventSelectors
  calls:
  - action: getEventSelectors
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.EventSelectors }}'
    item:
      ReadWriteType: '{{ item.ReadWriteType }}'
      IncludeManagementEvents: '{{ item.IncludeManagementEvents }}'
      DataResources: '{{ item.DataResources }}'
      ExcludeManagementEventSources: '{{ item.ExcludeManagementEventSources }}'
- discovery_id: aws.cloudtrail.getImport
  calls:
  - action: getImport
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Destinations }}'
- discovery_id: aws.cloudtrail.getQueryResults
  calls:
  - action: getQueryResults
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.QueryResultRows }}'
- discovery_id: aws.cloudtrail.getResourcePolicy
  calls:
  - action: getResourcePolicy
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ResourceArn }}'
- discovery_id: aws.cloudtrail.getTrail
  calls:
  - action: getTrail
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Trail }}'
    item:
      Name: '{{ item.Name }}'
      S3BucketName: '{{ item.S3BucketName }}'
      S3KeyPrefix: '{{ item.S3KeyPrefix }}'
      SnsTopicName: '{{ item.SnsTopicName }}'
      SnsTopicARN: '{{ item.SnsTopicARN }}'
      IncludeGlobalServiceEvents: '{{ item.IncludeGlobalServiceEvents }}'
      IsMultiRegionTrail: '{{ item.IsMultiRegionTrail }}'
      HomeRegion: '{{ item.HomeRegion }}'
      TrailARN: '{{ item.TrailARN }}'
      LogFileValidationEnabled: '{{ item.LogFileValidationEnabled }}'
      CloudWatchLogsLogGroupArn: '{{ item.CloudWatchLogsLogGroupArn }}'
      CloudWatchLogsRoleArn: '{{ item.CloudWatchLogsRoleArn }}'
      KmsKeyId: '{{ item.KmsKeyId }}'
      HasCustomEventSelectors: '{{ item.HasCustomEventSelectors }}'
      HasInsightSelectors: '{{ item.HasInsightSelectors }}'
      IsOrganizationTrail: '{{ item.IsOrganizationTrail }}'
- discovery_id: aws.cloudtrail.getTrailStatus
  calls:
  - action: getTrailStatus
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.IsLogging }}'
- discovery_id: aws.cloudtrail.listImportFailures
  calls:
  - action: listImportFailures
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Failures }}'
    item:
      Location: '{{ item.Location }}'
      Status: '{{ item.Status }}'
      ErrorType: '{{ item.ErrorType }}'
      ErrorMessage: '{{ item.ErrorMessage }}'
      LastUpdatedTime: '{{ item.LastUpdatedTime }}'
- discovery_id: aws.cloudtrail.listInsightsData
  calls:
  - action: listInsightsData
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Events }}'
    item:
      EventId: '{{ item.EventId }}'
      EventName: '{{ item.EventName }}'
      ReadOnly: '{{ item.ReadOnly }}'
      AccessKeyId: '{{ item.AccessKeyId }}'
      EventTime: '{{ item.EventTime }}'
      EventSource: '{{ item.EventSource }}'
      Username: '{{ item.Username }}'
      Resources: '{{ item.Resources }}'
      CloudTrailEvent: '{{ item.CloudTrailEvent }}'
- discovery_id: aws.cloudtrail.listInsightsMetricData
  calls:
  - action: listInsightsMetricData
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Timestamps }}'
- discovery_id: aws.cloudtrail.listQueries
  calls:
  - action: listQueries
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Queries }}'
    item:
      QueryId: '{{ item.QueryId }}'
      QueryStatus: '{{ item.QueryStatus }}'
      CreationTime: '{{ item.CreationTime }}'
- discovery_id: aws.cloudtrail.listTags
  calls:
  - action: listTags
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ResourceTagList }}'
    item:
      ResourceId: '{{ item.ResourceId }}'
      TagsList: '{{ item.TagsList }}'
- discovery_id: aws.cloudtrail.searchSampleQueries
  calls:
  - action: searchSampleQueries
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.SearchResults }}'
    item:
      Name: '{{ item.Name }}'
      Description: '{{ item.Description }}'
      SQL: '{{ item.SQL }}'
      Relevance: '{{ item.Relevance }}'
checks: []
