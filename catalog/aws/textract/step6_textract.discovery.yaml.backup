version: '1.0'
provider: aws
service: textract
services:
  client: textract
  module: boto3.client
discovery:
- discovery_id: aws.textract.listAdapterVersions
  calls:
  - action: listAdapterVersions
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.AdapterVersions }}'
    item:
      AdapterId: '{{ item.AdapterId }}'
      AdapterVersion: '{{ item.AdapterVersion }}'
      CreationTime: '{{ item.CreationTime }}'
      FeatureTypes: '{{ item.FeatureTypes }}'
      Status: '{{ item.Status }}'
      StatusMessage: '{{ item.StatusMessage }}'
- discovery_id: aws.textract.listAdapters
  calls:
  - action: listAdapters
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Adapters }}'
    item:
      AdapterId: '{{ item.AdapterId }}'
      AdapterName: '{{ item.AdapterName }}'
      CreationTime: '{{ item.CreationTime }}'
      FeatureTypes: '{{ item.FeatureTypes }}'
- discovery_id: aws.textract.getAdapter
  calls:
  - action: getAdapter
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.FeatureTypes }}'
- discovery_id: aws.textract.getAdapterVersion
  calls:
  - action: getAdapterVersion
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.FeatureTypes }}'
- discovery_id: aws.textract.getDocumentAnalysis
  calls:
  - action: getDocumentAnalysis
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Blocks }}'
    item:
      BlockType: '{{ item.BlockType }}'
      Confidence: '{{ item.Confidence }}'
      Text: '{{ item.Text }}'
      TextType: '{{ item.TextType }}'
      RowIndex: '{{ item.RowIndex }}'
      ColumnIndex: '{{ item.ColumnIndex }}'
      RowSpan: '{{ item.RowSpan }}'
      ColumnSpan: '{{ item.ColumnSpan }}'
      Geometry: '{{ item.Geometry }}'
      Id: '{{ item.Id }}'
      Relationships: '{{ item.Relationships }}'
      EntityTypes: '{{ item.EntityTypes }}'
      SelectionStatus: '{{ item.SelectionStatus }}'
      Page: '{{ item.Page }}'
      Query: '{{ item.Query }}'
- discovery_id: aws.textract.getDocumentTextDetection
  calls:
  - action: getDocumentTextDetection
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Blocks }}'
    item:
      BlockType: '{{ item.BlockType }}'
      Confidence: '{{ item.Confidence }}'
      Text: '{{ item.Text }}'
      TextType: '{{ item.TextType }}'
      RowIndex: '{{ item.RowIndex }}'
      ColumnIndex: '{{ item.ColumnIndex }}'
      RowSpan: '{{ item.RowSpan }}'
      ColumnSpan: '{{ item.ColumnSpan }}'
      Geometry: '{{ item.Geometry }}'
      Id: '{{ item.Id }}'
      Relationships: '{{ item.Relationships }}'
      EntityTypes: '{{ item.EntityTypes }}'
      SelectionStatus: '{{ item.SelectionStatus }}'
      Page: '{{ item.Page }}'
      Query: '{{ item.Query }}'
- discovery_id: aws.textract.getExpenseAnalysis
  calls:
  - action: getExpenseAnalysis
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ExpenseDocuments }}'
    item:
      ExpenseIndex: '{{ item.ExpenseIndex }}'
      SummaryFields: '{{ item.SummaryFields }}'
      LineItemGroups: '{{ item.LineItemGroups }}'
      Blocks: '{{ item.Blocks }}'
- discovery_id: aws.textract.getLendingAnalysis
  calls:
  - action: getLendingAnalysis
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Results }}'
    item:
      Page: '{{ item.Page }}'
      PageClassification: '{{ item.PageClassification }}'
      Extractions: '{{ item.Extractions }}'
- discovery_id: aws.textract.getLendingAnalysisSummary
  calls:
  - action: getLendingAnalysisSummary
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Warnings }}'
    item:
      ErrorCode: '{{ item.ErrorCode }}'
      Pages: '{{ item.Pages }}'
- discovery_id: aws.textract.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Tags }}'
checks: []
