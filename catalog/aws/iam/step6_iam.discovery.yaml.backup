- discovery_id: aws.iam.listPolicies
  calls:
  - action: listPolicies
    save_as: response
    on_error: continue
    params:
      MaxItems: 1000
  emit:
    as: item
    items_for: '{{ response.Policies }}'
    item:
      PolicyName: '{{ item.PolicyName }}'
      PolicyId: '{{ item.PolicyId }}'
      Arn: '{{ item.Arn }}'
      Path: '{{ item.Path }}'
      DefaultVersionId: '{{ item.DefaultVersionId }}'
      AttachmentCount: '{{ item.AttachmentCount }}'
      PermissionsBoundaryUsageCount: '{{ item.PermissionsBoundaryUsageCount }}'
      IsAttachable: '{{ item.IsAttachable }}'
      Description: '{{ item.Description }}'
      CreateDate: '{{ item.CreateDate }}'
      UpdateDate: '{{ item.UpdateDate }}'
      Tags: '{{ item.Tags }}'
- discovery_id: aws.iam.listRoles
  calls:
  - action: listRoles
    save_as: response
    on_error: continue
