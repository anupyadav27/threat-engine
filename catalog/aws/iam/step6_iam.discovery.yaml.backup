version: '1.0'
provider: aws
service: iam
services:
  client: iam
  module: boto3.client
discovery:
- discovery_id: aws.iam.getAccountAuthorizationDetails
  calls:
  - action: getAccountAuthorizationDetails
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.UserDetailList }}'
    item:
      Path: '{{ item.Path }}'
      UserName: '{{ item.UserName }}'
      UserId: '{{ item.UserId }}'
      Arn: '{{ item.Arn }}'
      CreateDate: '{{ item.CreateDate }}'
      UserPolicyList: '{{ item.UserPolicyList }}'
      GroupList: '{{ item.GroupList }}'
      AttachedManagedPolicies: '{{ item.AttachedManagedPolicies }}'
      PermissionsBoundary: '{{ item.PermissionsBoundary }}'
      Tags: '{{ item.Tags }}'
- discovery_id: aws.iam.getAccountPasswordPolicy
  calls:
  - action: getAccountPasswordPolicy
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.PasswordPolicy }}'
    item:
      MinimumPasswordLength: '{{ item.MinimumPasswordLength }}'
      RequireSymbols: '{{ item.RequireSymbols }}'
      RequireNumbers: '{{ item.RequireNumbers }}'
      RequireUppercaseCharacters: '{{ item.RequireUppercaseCharacters }}'
      RequireLowercaseCharacters: '{{ item.RequireLowercaseCharacters }}'
      AllowUsersToChangePassword: '{{ item.AllowUsersToChangePassword }}'
      ExpirePasswords: '{{ item.ExpirePasswords }}'
      MaxPasswordAge: '{{ item.MaxPasswordAge }}'
      PasswordReusePrevention: '{{ item.PasswordReusePrevention }}'
      HardExpiry: '{{ item.HardExpiry }}'
- discovery_id: aws.iam.getAccountSummary
  calls:
  - action: getAccountSummary
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.SummaryMap }}'
- discovery_id: aws.iam.getCredentialReport
  calls:
  - action: getCredentialReport
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Content }}'
- discovery_id: aws.iam.getLoginProfile
  calls:
  - action: getLoginProfile
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.LoginProfile }}'
    item:
      UserName: '{{ item.UserName }}'
      CreateDate: '{{ item.CreateDate }}'
      PasswordResetRequired: '{{ item.PasswordResetRequired }}'
- discovery_id: aws.iam.getOutboundWebIdentityFederationInfo
  calls:
  - action: getOutboundWebIdentityFederationInfo
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.IssuerIdentifier }}'
- discovery_id: aws.iam.getUser
  calls:
  - action: getUser
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.User }}'
    item:
      Path: '{{ item.Path }}'
      UserName: '{{ item.UserName }}'
      UserId: '{{ item.UserId }}'
      Arn: '{{ item.Arn }}'
      CreateDate: '{{ item.CreateDate }}'
      PasswordLastUsed: '{{ item.PasswordLastUsed }}'
      PermissionsBoundary: '{{ item.PermissionsBoundary }}'
      Tags: '{{ item.Tags }}'
- discovery_id: aws.iam.listAccessKeys
  calls:
  - action: listAccessKeys
    save_as: response
    on_error: continue
    params:
      MaxItems: 1000
  emit:
    as: item
    items_for: '{{ response.AccessKeyMetadata }}'
    item:
      UserName: '{{ item.UserName }}'
      AccessKeyId: '{{ item.AccessKeyId }}'
      Status: '{{ item.Status }}'
      CreateDate: '{{ item.CreateDate }}'
- discovery_id: aws.iam.listAccountAliases
  calls:
  - action: listAccountAliases
    save_as: response
    on_error: continue
    params:
      MaxItems: 1000
  emit:
    as: item
    items_for: '{{ response.AccountAliases }}'
- discovery_id: aws.iam.listDelegationRequests
  calls:
  - action: listDelegationRequests
    save_as: response
    on_error: continue
    params:
      MaxItems: 1000
  emit:
    as: item
    items_for: '{{ response.DelegationRequests }}'
    item:
      DelegationRequestId: '{{ item.DelegationRequestId }}'
      OwnerAccountId: '{{ item.OwnerAccountId }}'
      Description: '{{ item.Description }}'
      RequestMessage: '{{ item.RequestMessage }}'
      Permissions: '{{ item.Permissions }}'
      PermissionPolicy: '{{ item.PermissionPolicy }}'
      RolePermissionRestrictionArns: '{{ item.RolePermissionRestrictionArns }}'
      OwnerId: '{{ item.OwnerId }}'
      ApproverId: '{{ item.ApproverId }}'
      State: '{{ item.State }}'
      RequestorId: '{{ item.RequestorId }}'
      RequestorName: '{{ item.RequestorName }}'
      CreateDate: '{{ item.CreateDate }}'
      SessionDuration: '{{ item.SessionDuration }}'
      RedirectUrl: '{{ item.RedirectUrl }}'
      Notes: '{{ item.Notes }}'
      RejectionReason: '{{ item.RejectionReason }}'
      OnlySendByOwner: '{{ item.OnlySendByOwner }}'
      UpdatedTime: '{{ item.UpdatedTime }}'
- discovery_id: aws.iam.listGroups
  calls:
  - action: listGroups
    save_as: response
    on_error: continue
    params:
      MaxItems: 1000
  emit:
    as: item
    items_for: '{{ response.Groups }}'
    item:
      Path: '{{ item.Path }}'
      GroupName: '{{ item.GroupName }}'
      GroupId: '{{ item.GroupId }}'
      Arn: '{{ item.Arn }}'
      CreateDate: '{{ item.CreateDate }}'
- discovery_id: aws.iam.listInstanceProfiles
  calls:
  - action: listInstanceProfiles
    save_as: response
    on_error: continue
    params:
      MaxItems: 1000
  emit:
    as: item
    items_for: '{{ response.InstanceProfiles }}'
    item:
      Path: '{{ item.Path }}'
      InstanceProfileName: '{{ item.InstanceProfileName }}'
      InstanceProfileId: '{{ item.InstanceProfileId }}'
      Arn: '{{ item.Arn }}'
      CreateDate: '{{ item.CreateDate }}'
      Roles: '{{ item.Roles }}'
      Tags: '{{ item.Tags }}'
- discovery_id: aws.iam.listMfaDevices
  calls:
  - action: listMfaDevices
    save_as: response
    on_error: continue
    params:
      MaxItems: 1000
  emit:
    as: item
    items_for: '{{ response.MFADevices }}'
    item:
      UserName: '{{ item.UserName }}'
      SerialNumber: '{{ item.SerialNumber }}'
      EnableDate: '{{ item.EnableDate }}'
- discovery_id: aws.iam.listOpenIdConnectProviders
  calls:
  - action: listOpenIdConnectProviders
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.OpenIDConnectProviderList }}'
    item:
      Arn: '{{ item.Arn }}'
