version: '1.0'
provider: aws
service: compute-optimizer
services:
  client: compute-optimizer
  module: boto3.client
discovery:
- discovery_id: aws.compute-optimizer.describeRecommendationExportJobs
  calls:
  - action: describeRecommendationExportJobs
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.recommendationExportJobs }}'
    item:
      jobId: '{{ item.jobId }}'
      destination: '{{ item.destination }}'
      resourceType: '{{ item.resourceType }}'
      status: '{{ item.status }}'
      creationTimestamp: '{{ item.creationTimestamp }}'
      lastUpdatedTimestamp: '{{ item.lastUpdatedTimestamp }}'
      failureReason: '{{ item.failureReason }}'
- discovery_id: aws.compute-optimizer.getAutoScalingGroupRecommendations
  calls:
  - action: getAutoScalingGroupRecommendations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.autoScalingGroupRecommendations }}'
    item:
      accountId: '{{ item.accountId }}'
      autoScalingGroupArn: '{{ item.autoScalingGroupArn }}'
      autoScalingGroupName: '{{ item.autoScalingGroupName }}'
      finding: '{{ item.finding }}'
      utilizationMetrics: '{{ item.utilizationMetrics }}'
      lookBackPeriodInDays: '{{ item.lookBackPeriodInDays }}'
      currentConfiguration: '{{ item.currentConfiguration }}'
      currentInstanceGpuInfo: '{{ item.currentInstanceGpuInfo }}'
      recommendationOptions: '{{ item.recommendationOptions }}'
      lastRefreshTimestamp: '{{ item.lastRefreshTimestamp }}'
      currentPerformanceRisk: '{{ item.currentPerformanceRisk }}'
      effectiveRecommendationPreferences: '{{ item.effectiveRecommendationPreferences
        }}'
      inferredWorkloadTypes: '{{ item.inferredWorkloadTypes }}'
- discovery_id: aws.compute-optimizer.getEbsVolumeRecommendations
  calls:
  - action: getEbsVolumeRecommendations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.volumeRecommendations }}'
    item:
      volumeArn: '{{ item.volumeArn }}'
      accountId: '{{ item.accountId }}'
      currentConfiguration: '{{ item.currentConfiguration }}'
      finding: '{{ item.finding }}'
      utilizationMetrics: '{{ item.utilizationMetrics }}'
      lookBackPeriodInDays: '{{ item.lookBackPeriodInDays }}'
      volumeRecommendationOptions: '{{ item.volumeRecommendationOptions }}'
      lastRefreshTimestamp: '{{ item.lastRefreshTimestamp }}'
      currentPerformanceRisk: '{{ item.currentPerformanceRisk }}'
      effectiveRecommendationPreferences: '{{ item.effectiveRecommendationPreferences
        }}'
      tags: '{{ item.tags }}'
- discovery_id: aws.compute-optimizer.getEc2InstanceRecommendations
  calls:
  - action: getEc2InstanceRecommendations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.instanceRecommendations }}'
    item:
      instanceArn: '{{ item.instanceArn }}'
      accountId: '{{ item.accountId }}'
      instanceName: '{{ item.instanceName }}'
      currentInstanceType: '{{ item.currentInstanceType }}'
      finding: '{{ item.finding }}'
      findingReasonCodes: '{{ item.findingReasonCodes }}'
      utilizationMetrics: '{{ item.utilizationMetrics }}'
      lookBackPeriodInDays: '{{ item.lookBackPeriodInDays }}'
      recommendationOptions: '{{ item.recommendationOptions }}'
      recommendationSources: '{{ item.recommendationSources }}'
      lastRefreshTimestamp: '{{ item.lastRefreshTimestamp }}'
      currentPerformanceRisk: '{{ item.currentPerformanceRisk }}'
      effectiveRecommendationPreferences: '{{ item.effectiveRecommendationPreferences
        }}'
      inferredWorkloadTypes: '{{ item.inferredWorkloadTypes }}'
      instanceState: '{{ item.instanceState }}'
      tags: '{{ item.tags }}'
      externalMetricStatus: '{{ item.externalMetricStatus }}'
      currentInstanceGpuInfo: '{{ item.currentInstanceGpuInfo }}'
      idle: '{{ item.idle }}'
- discovery_id: aws.compute-optimizer.getEcsServiceRecommendations
  calls:
  - action: getEcsServiceRecommendations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ecsServiceRecommendations }}'
    item:
      serviceArn: '{{ item.serviceArn }}'
      accountId: '{{ item.accountId }}'
      currentServiceConfiguration: '{{ item.currentServiceConfiguration }}'
      utilizationMetrics: '{{ item.utilizationMetrics }}'
      lookbackPeriodInDays: '{{ item.lookbackPeriodInDays }}'
      launchType: '{{ item.launchType }}'
      lastRefreshTimestamp: '{{ item.lastRefreshTimestamp }}'
      finding: '{{ item.finding }}'
      findingReasonCodes: '{{ item.findingReasonCodes }}'
      serviceRecommendationOptions: '{{ item.serviceRecommendationOptions }}'
      currentPerformanceRisk: '{{ item.currentPerformanceRisk }}'
      effectiveRecommendationPreferences: '{{ item.effectiveRecommendationPreferences
        }}'
      tags: '{{ item.tags }}'
- discovery_id: aws.compute-optimizer.getEnrollmentStatus
  calls:
  - action: getEnrollmentStatus
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.status }}'
- discovery_id: aws.compute-optimizer.getEnrollmentStatusesForOrganization
  calls:
  - action: getEnrollmentStatusesForOrganization
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.accountEnrollmentStatuses }}'
    item:
      accountId: '{{ item.accountId }}'
      status: '{{ item.status }}'
      statusReason: '{{ item.statusReason }}'
      lastUpdatedTimestamp: '{{ item.lastUpdatedTimestamp }}'
- discovery_id: aws.compute-optimizer.getIdleRecommendations
  calls:
  - action: getIdleRecommendations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.idleRecommendations }}'
    item:
      resourceArn: '{{ item.resourceArn }}'
      resourceId: '{{ item.resourceId }}'
      resourceType: '{{ item.resourceType }}'
      accountId: '{{ item.accountId }}'
      finding: '{{ item.finding }}'
      findingDescription: '{{ item.findingDescription }}'
      savingsOpportunity: '{{ item.savingsOpportunity }}'
      savingsOpportunityAfterDiscounts: '{{ item.savingsOpportunityAfterDiscounts
        }}'
      utilizationMetrics: '{{ item.utilizationMetrics }}'
      lookBackPeriodInDays: '{{ item.lookBackPeriodInDays }}'
      lastRefreshTimestamp: '{{ item.lastRefreshTimestamp }}'
      tags: '{{ item.tags }}'
- discovery_id: aws.compute-optimizer.getLambdaFunctionRecommendations
  calls:
  - action: getLambdaFunctionRecommendations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.lambdaFunctionRecommendations }}'
    item:
      functionArn: '{{ item.functionArn }}'
      functionVersion: '{{ item.functionVersion }}'
      accountId: '{{ item.accountId }}'
      currentMemorySize: '{{ item.currentMemorySize }}'
      numberOfInvocations: '{{ item.numberOfInvocations }}'
      utilizationMetrics: '{{ item.utilizationMetrics }}'
      lookbackPeriodInDays: '{{ item.lookbackPeriodInDays }}'
      lastRefreshTimestamp: '{{ item.lastRefreshTimestamp }}'
      finding: '{{ item.finding }}'
      findingReasonCodes: '{{ item.findingReasonCodes }}'
      memorySizeRecommendationOptions: '{{ item.memorySizeRecommendationOptions }}'
      currentPerformanceRisk: '{{ item.currentPerformanceRisk }}'
      effectiveRecommendationPreferences: '{{ item.effectiveRecommendationPreferences
        }}'
      tags: '{{ item.tags }}'
- discovery_id: aws.compute-optimizer.getLicenseRecommendations
  calls:
  - action: getLicenseRecommendations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.licenseRecommendations }}'
    item:
      resourceArn: '{{ item.resourceArn }}'
      accountId: '{{ item.accountId }}'
      currentLicenseConfiguration: '{{ item.currentLicenseConfiguration }}'
      lookbackPeriodInDays: '{{ item.lookbackPeriodInDays }}'
      lastRefreshTimestamp: '{{ item.lastRefreshTimestamp }}'
      finding: '{{ item.finding }}'
      findingReasonCodes: '{{ item.findingReasonCodes }}'
      licenseRecommendationOptions: '{{ item.licenseRecommendationOptions }}'
      tags: '{{ item.tags }}'
- discovery_id: aws.compute-optimizer.getRdsDatabaseRecommendations
  calls:
  - action: getRdsDatabaseRecommendations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.rdsDBRecommendations }}'
    item:
      resourceArn: '{{ item.resourceArn }}'
      accountId: '{{ item.accountId }}'
      engine: '{{ item.engine }}'
      engineVersion: '{{ item.engineVersion }}'
      promotionTier: '{{ item.promotionTier }}'
      currentDBInstanceClass: '{{ item.currentDBInstanceClass }}'
      currentStorageConfiguration: '{{ item.currentStorageConfiguration }}'
      dbClusterIdentifier: '{{ item.dbClusterIdentifier }}'
      idle: '{{ item.idle }}'
      instanceFinding: '{{ item.instanceFinding }}'
      storageFinding: '{{ item.storageFinding }}'
      instanceFindingReasonCodes: '{{ item.instanceFindingReasonCodes }}'
      currentInstancePerformanceRisk: '{{ item.currentInstancePerformanceRisk }}'
      currentStorageEstimatedMonthlyVolumeIOPsCostVariation: '{{ item.currentStorageEstimatedMonthlyVolumeIOPsCostVariation
        }}'
      storageFindingReasonCodes: '{{ item.storageFindingReasonCodes }}'
      instanceRecommendationOptions: '{{ item.instanceRecommendationOptions }}'
      storageRecommendationOptions: '{{ item.storageRecommendationOptions }}'
      utilizationMetrics: '{{ item.utilizationMetrics }}'
      effectiveRecommendationPreferences: '{{ item.effectiveRecommendationPreferences
        }}'
      lookbackPeriodInDays: '{{ item.lookbackPeriodInDays }}'
      lastRefreshTimestamp: '{{ item.lastRefreshTimestamp }}'
      tags: '{{ item.tags }}'
- discovery_id: aws.compute-optimizer.getRecommendationSummaries
  calls:
  - action: getRecommendationSummaries
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.recommendationSummaries }}'
    item:
      summaries: '{{ item.summaries }}'
      idleSummaries: '{{ item.idleSummaries }}'
      recommendationResourceType: '{{ item.recommendationResourceType }}'
      accountId: '{{ item.accountId }}'
      savingsOpportunity: '{{ item.savingsOpportunity }}'
      idleSavingsOpportunity: '{{ item.idleSavingsOpportunity }}'
      aggregatedSavingsOpportunity: '{{ item.aggregatedSavingsOpportunity }}'
      currentPerformanceRiskRatings: '{{ item.currentPerformanceRiskRatings }}'
      inferredWorkloadSavings: '{{ item.inferredWorkloadSavings }}'
- discovery_id: aws.compute-optimizer.getEc2RecommendationProjectedMetrics
  calls:
  - action: getEc2RecommendationProjectedMetrics
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.recommendedOptionProjectedMetrics }}'
    item:
      recommendedInstanceType: '{{ item.recommendedInstanceType }}'
      rank: '{{ item.rank }}'
      projectedMetrics: '{{ item.projectedMetrics }}'
- discovery_id: aws.compute-optimizer.getEcsServiceRecommendationProjectedMetrics
  calls:
  - action: getEcsServiceRecommendationProjectedMetrics
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.recommendedOptionProjectedMetrics }}'
    item:
      recommendedCpuUnits: '{{ item.recommendedCpuUnits }}'
      recommendedMemorySize: '{{ item.recommendedMemorySize }}'
      projectedMetrics: '{{ item.projectedMetrics }}'
- discovery_id: aws.compute-optimizer.getEffectiveRecommendationPreferences
  calls:
  - action: getEffectiveRecommendationPreferences
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.preferredResources }}'
    item:
      name: '{{ item.name }}'
      includeList: '{{ item.includeList }}'
      effectiveIncludeList: '{{ item.effectiveIncludeList }}'
      excludeList: '{{ item.excludeList }}'
- discovery_id: aws.compute-optimizer.getRdsDatabaseRecommendationProjectedMetrics
  calls:
  - action: getRdsDatabaseRecommendationProjectedMetrics
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.recommendedOptionProjectedMetrics }}'
    item:
      recommendedDBInstanceClass: '{{ item.recommendedDBInstanceClass }}'
      rank: '{{ item.rank }}'
      projectedMetrics: '{{ item.projectedMetrics }}'
- discovery_id: aws.compute-optimizer.getRecommendationPreferences
  calls:
  - action: getRecommendationPreferences
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.recommendationPreferencesDetails }}'
    item:
      scope: '{{ item.scope }}'
      resourceType: '{{ item.resourceType }}'
      enhancedInfrastructureMetrics: '{{ item.enhancedInfrastructureMetrics }}'
      inferredWorkloadTypes: '{{ item.inferredWorkloadTypes }}'
      externalMetricsPreference: '{{ item.externalMetricsPreference }}'
      lookBackPeriod: '{{ item.lookBackPeriod }}'
      utilizationPreferences: '{{ item.utilizationPreferences }}'
      preferredResources: '{{ item.preferredResources }}'
      savingsEstimationMode: '{{ item.savingsEstimationMode }}'
checks: []
