version: '1.0'
provider: aws
service: clouddirectory
services:
  client: clouddirectory
  module: boto3.client
discovery:
- discovery_id: aws.clouddirectory.listDevelopmentSchemaArns
  calls:
  - action: listDevelopmentSchemaArns
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.SchemaArns }}'
- discovery_id: aws.clouddirectory.listDirectories
  calls:
  - action: listDirectories
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Directories }}'
    item:
      Name: '{{ item.Name }}'
      DirectoryArn: '{{ item.DirectoryArn }}'
      State: '{{ item.State }}'
      CreationDateTime: '{{ item.CreationDateTime }}'
- discovery_id: aws.clouddirectory.listManagedSchemaArns
  calls:
  - action: listManagedSchemaArns
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.SchemaArns }}'
- discovery_id: aws.clouddirectory.listPublishedSchemaArns
  calls:
  - action: listPublishedSchemaArns
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.SchemaArns }}'
- discovery_id: aws.clouddirectory.getAppliedSchemaVersion
  calls:
  - action: getAppliedSchemaVersion
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AppliedSchemaArn }}'
- discovery_id: aws.clouddirectory.getDirectory
  calls:
  - action: getDirectory
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Directory }}'
    item:
      Name: '{{ item.Name }}'
      DirectoryArn: '{{ item.DirectoryArn }}'
      State: '{{ item.State }}'
      CreationDateTime: '{{ item.CreationDateTime }}'
- discovery_id: aws.clouddirectory.getFacet
  calls:
  - action: getFacet
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Facet }}'
    item:
      Name: '{{ item.Name }}'
      ObjectType: '{{ item.ObjectType }}'
      FacetStyle: '{{ item.FacetStyle }}'
- discovery_id: aws.clouddirectory.getLinkAttributes
  calls:
  - action: getLinkAttributes
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Attributes }}'
    item:
      Key: '{{ item.Key }}'
      Value: '{{ item.Value }}'
- discovery_id: aws.clouddirectory.getObjectAttributes
  calls:
  - action: getObjectAttributes
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Attributes }}'
    item:
      Key: '{{ item.Key }}'
      Value: '{{ item.Value }}'
- discovery_id: aws.clouddirectory.getObjectInformation
  calls:
  - action: getObjectInformation
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.SchemaFacets }}'
    item:
      SchemaArn: '{{ item.SchemaArn }}'
      FacetName: '{{ item.FacetName }}'
- discovery_id: aws.clouddirectory.getSchemaAsJson
  calls:
  - action: getSchemaAsJson
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Name }}'
- discovery_id: aws.clouddirectory.getTypedLinkFacetInformation
  calls:
  - action: getTypedLinkFacetInformation
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.IdentityAttributeOrder }}'
- discovery_id: aws.clouddirectory.listAppliedSchemaArns
  calls:
  - action: listAppliedSchemaArns
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.SchemaArns }}'
- discovery_id: aws.clouddirectory.listAttachedIndices
  calls:
  - action: listAttachedIndices
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.IndexAttachments }}'
    item:
      IndexedAttributes: '{{ item.IndexedAttributes }}'
      ObjectIdentifier: '{{ item.ObjectIdentifier }}'
- discovery_id: aws.clouddirectory.listFacetAttributes
  calls:
  - action: listFacetAttributes
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Attributes }}'
    item:
      Name: '{{ item.Name }}'
      AttributeDefinition: '{{ item.AttributeDefinition }}'
      AttributeReference: '{{ item.AttributeReference }}'
      RequiredBehavior: '{{ item.RequiredBehavior }}'
- discovery_id: aws.clouddirectory.listFacetNames
  calls:
  - action: listFacetNames
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.FacetNames }}'
- discovery_id: aws.clouddirectory.listIncomingTypedLinks
  calls:
  - action: listIncomingTypedLinks
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.LinkSpecifiers }}'
    item:
      TypedLinkFacet: '{{ item.TypedLinkFacet }}'
      SourceObjectReference: '{{ item.SourceObjectReference }}'
      TargetObjectReference: '{{ item.TargetObjectReference }}'
      IdentityAttributeValues: '{{ item.IdentityAttributeValues }}'
- discovery_id: aws.clouddirectory.listIndex
  calls:
  - action: listIndex
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.IndexAttachments }}'
    item:
      IndexedAttributes: '{{ item.IndexedAttributes }}'
      ObjectIdentifier: '{{ item.ObjectIdentifier }}'
- discovery_id: aws.clouddirectory.listObjectAttributes
  calls:
  - action: listObjectAttributes
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Attributes }}'
    item:
      Key: '{{ item.Key }}'
      Value: '{{ item.Value }}'
- discovery_id: aws.clouddirectory.listObjectChildren
  calls:
  - action: listObjectChildren
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Children }}'
- discovery_id: aws.clouddirectory.listObjectParentPaths
  calls:
  - action: listObjectParentPaths
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.PathToObjectIdentifiersList }}'
    item:
      Path: '{{ item.Path }}'
      ObjectIdentifiers: '{{ item.ObjectIdentifiers }}'
- discovery_id: aws.clouddirectory.listObjectParents
  calls:
  - action: listObjectParents
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.ParentLinks }}'
    item:
      ObjectIdentifier: '{{ item.ObjectIdentifier }}'
      LinkName: '{{ item.LinkName }}'
- discovery_id: aws.clouddirectory.listObjectPolicies
  calls:
  - action: listObjectPolicies
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.AttachedPolicyIds }}'
- discovery_id: aws.clouddirectory.listOutgoingTypedLinks
  calls:
  - action: listOutgoingTypedLinks
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.TypedLinkSpecifiers }}'
    item:
      TypedLinkFacet: '{{ item.TypedLinkFacet }}'
      SourceObjectReference: '{{ item.SourceObjectReference }}'
      TargetObjectReference: '{{ item.TargetObjectReference }}'
      IdentityAttributeValues: '{{ item.IdentityAttributeValues }}'
- discovery_id: aws.clouddirectory.listPolicyAttachments
  calls:
  - action: listPolicyAttachments
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.ObjectIdentifiers }}'
- discovery_id: aws.clouddirectory.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Tags }}'
    item:
      Key: '{{ item.Key }}'
      Value: '{{ item.Value }}'
- discovery_id: aws.clouddirectory.listTypedLinkFacetAttributes
  calls:
  - action: listTypedLinkFacetAttributes
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Attributes }}'
    item:
      Name: '{{ item.Name }}'
      Type: '{{ item.Type }}'
      DefaultValue: '{{ item.DefaultValue }}'
      IsImmutable: '{{ item.IsImmutable }}'
      Rules: '{{ item.Rules }}'
      RequiredBehavior: '{{ item.RequiredBehavior }}'
- discovery_id: aws.clouddirectory.listTypedLinkFacetNames
  calls:
  - action: listTypedLinkFacetNames
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.FacetNames }}'
- discovery_id: aws.clouddirectory.lookupPolicy
  calls:
  - action: lookupPolicy
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.PolicyToPathList }}'
    item:
      Path: '{{ item.Path }}'
      Policies: '{{ item.Policies }}'
checks: []
