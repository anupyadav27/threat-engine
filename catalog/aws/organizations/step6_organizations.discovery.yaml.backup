  calls:
  - action: listOutboundResponsibilityTransfers
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.ResponsibilityTransfers }}'
    item:
      Arn: '{{ item.Arn }}'
      Name: '{{ item.Name }}'
      Id: '{{ item.Id }}'
      Type: '{{ item.Type }}'
      Status: '{{ item.Status }}'
      Source: '{{ item.Source }}'
      Target: '{{ item.Target }}'
      StartTimestamp: '{{ item.StartTimestamp }}'
      EndTimestamp: '{{ item.EndTimestamp }}'
      ActiveHandshakeId: '{{ item.ActiveHandshakeId }}'
- discovery_id: aws.organizations.listParents
  calls:
  - action: listParents
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Parents }}'
    item:
      Id: '{{ item.Id }}'
      Type: '{{ item.Type }}'
- discovery_id: aws.organizations.listPolicies
  calls:
  - action: listPolicies
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Policies }}'
    item:
      Id: '{{ item.Id }}'
      Arn: '{{ item.Arn }}'
      Name: '{{ item.Name }}'
      Description: '{{ item.Description }}'
      Type: '{{ item.Type }}'
      AwsManaged: '{{ item.AwsManaged }}'
- discovery_id: aws.organizations.listPoliciesForTarget
  calls:
  - action: listPoliciesForTarget
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Policies }}'
    item:
      Id: '{{ item.Id }}'
      Arn: '{{ item.Arn }}'
      Name: '{{ item.Name }}'
      Description: '{{ item.Description }}'
      Type: '{{ item.Type }}'
      AwsManaged: '{{ item.AwsManaged }}'
- discovery_id: aws.organizations.listTagsForResource
  calls:
