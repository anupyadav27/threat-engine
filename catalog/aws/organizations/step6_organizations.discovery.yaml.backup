version: '1.0'
provider: aws
service: organizations
services:
  client: organizations
  module: boto3.client
discovery:
- discovery_id: aws.organizations.describeOrganization
  calls:
  - action: describeOrganization
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Organization }}'
    item:
      Id: '{{ item.Id }}'
      Arn: '{{ item.Arn }}'
      FeatureSet: '{{ item.FeatureSet }}'
      MasterAccountArn: '{{ item.MasterAccountArn }}'
      MasterAccountId: '{{ item.MasterAccountId }}'
      MasterAccountEmail: '{{ item.MasterAccountEmail }}'
      AvailablePolicyTypes: '{{ item.AvailablePolicyTypes }}'
- discovery_id: aws.organizations.describeResourcePolicy
  calls:
  - action: describeResourcePolicy
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ResourcePolicy }}'
    item:
      ResourcePolicySummary: '{{ item.ResourcePolicySummary }}'
      Content: '{{ item.Content }}'
- discovery_id: aws.organizations.listAwsServiceAccessForOrganization
  calls:
  - action: listAwsServiceAccessForOrganization
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.EnabledServicePrincipals }}'
    item:
      ServicePrincipal: '{{ item.ServicePrincipal }}'
      DateEnabled: '{{ item.DateEnabled }}'
- discovery_id: aws.organizations.listAccounts
  calls:
  - action: listAccounts
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Accounts }}'
    item:
      Id: '{{ item.Id }}'
      Arn: '{{ item.Arn }}'
      Email: '{{ item.Email }}'
      Name: '{{ item.Name }}'
      Status: '{{ item.Status }}'
      State: '{{ item.State }}'
      JoinedMethod: '{{ item.JoinedMethod }}'
      JoinedTimestamp: '{{ item.JoinedTimestamp }}'
- discovery_id: aws.organizations.listCreateAccountStatus
  calls:
  - action: listCreateAccountStatus
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.CreateAccountStatuses }}'
    item:
      Id: '{{ item.Id }}'
      AccountName: '{{ item.AccountName }}'
      State: '{{ item.State }}'
      RequestedTimestamp: '{{ item.RequestedTimestamp }}'
      CompletedTimestamp: '{{ item.CompletedTimestamp }}'
      AccountId: '{{ item.AccountId }}'
      GovCloudAccountId: '{{ item.GovCloudAccountId }}'
      FailureReason: '{{ item.FailureReason }}'
- discovery_id: aws.organizations.listDelegatedAdministrators
  calls:
  - action: listDelegatedAdministrators
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.DelegatedAdministrators }}'
    item:
      Id: '{{ item.Id }}'
      Arn: '{{ item.Arn }}'
      Email: '{{ item.Email }}'
      Name: '{{ item.Name }}'
      Status: '{{ item.Status }}'
      State: '{{ item.State }}'
      JoinedMethod: '{{ item.JoinedMethod }}'
      JoinedTimestamp: '{{ item.JoinedTimestamp }}'
      DelegationEnabledDate: '{{ item.DelegationEnabledDate }}'
- discovery_id: aws.organizations.listHandshakesForAccount
  calls:
  - action: listHandshakesForAccount
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Handshakes }}'
    item:
      Id: '{{ item.Id }}'
      Arn: '{{ item.Arn }}'
      Parties: '{{ item.Parties }}'
      State: '{{ item.State }}'
      RequestedTimestamp: '{{ item.RequestedTimestamp }}'
      ExpirationTimestamp: '{{ item.ExpirationTimestamp }}'
      Action: '{{ item.Action }}'
      Resources: '{{ item.Resources }}'
- discovery_id: aws.organizations.listHandshakesForOrganization
  calls:
  - action: listHandshakesForOrganization
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Handshakes }}'
    item:
      Id: '{{ item.Id }}'
      Arn: '{{ item.Arn }}'
      Parties: '{{ item.Parties }}'
      State: '{{ item.State }}'
      RequestedTimestamp: '{{ item.RequestedTimestamp }}'
      ExpirationTimestamp: '{{ item.ExpirationTimestamp }}'
      Action: '{{ item.Action }}'
      Resources: '{{ item.Resources }}'
- discovery_id: aws.organizations.listRoots
  calls:
  - action: listRoots
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Roots }}'
    item:
      Id: '{{ item.Id }}'
      Arn: '{{ item.Arn }}'
      Name: '{{ item.Name }}'
      PolicyTypes: '{{ item.PolicyTypes }}'
- discovery_id: aws.organizations.describeAccount
  calls:
  - action: describeAccount
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Account }}'
    item:
      Id: '{{ item.Id }}'
      Arn: '{{ item.Arn }}'
      Email: '{{ item.Email }}'
      Name: '{{ item.Name }}'
      Status: '{{ item.Status }}'
      State: '{{ item.State }}'
      JoinedMethod: '{{ item.JoinedMethod }}'
      JoinedTimestamp: '{{ item.JoinedTimestamp }}'
- discovery_id: aws.organizations.describeCreateAccountStatus
  calls:
  - action: describeCreateAccountStatus
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.CreateAccountStatus }}'
    item:
      Id: '{{ item.Id }}'
      AccountName: '{{ item.AccountName }}'
      State: '{{ item.State }}'
      RequestedTimestamp: '{{ item.RequestedTimestamp }}'
      CompletedTimestamp: '{{ item.CompletedTimestamp }}'
      AccountId: '{{ item.AccountId }}'
      GovCloudAccountId: '{{ item.GovCloudAccountId }}'
      FailureReason: '{{ item.FailureReason }}'
- discovery_id: aws.organizations.describeEffectivePolicy
  calls:
  - action: describeEffectivePolicy
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.EffectivePolicy }}'
    item:
      PolicyContent: '{{ item.PolicyContent }}'
      LastUpdatedTimestamp: '{{ item.LastUpdatedTimestamp }}'
      TargetId: '{{ item.TargetId }}'
      PolicyType: '{{ item.PolicyType }}'
- discovery_id: aws.organizations.describeHandshake
  calls:
  - action: describeHandshake
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Handshake }}'
    item:
      Id: '{{ item.Id }}'
      Arn: '{{ item.Arn }}'
      Parties: '{{ item.Parties }}'
      State: '{{ item.State }}'
      RequestedTimestamp: '{{ item.RequestedTimestamp }}'
      ExpirationTimestamp: '{{ item.ExpirationTimestamp }}'
      Action: '{{ item.Action }}'
      Resources: '{{ item.Resources }}'
- discovery_id: aws.organizations.describeOrganizationalUnit
  calls:
  - action: describeOrganizationalUnit
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.OrganizationalUnit }}'
    item:
      Id: '{{ item.Id }}'
      Arn: '{{ item.Arn }}'
      Name: '{{ item.Name }}'
- discovery_id: aws.organizations.describePolicy
  calls:
  - action: describePolicy
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Policy }}'
    item:
      PolicySummary: '{{ item.PolicySummary }}'
      Content: '{{ item.Content }}'
- discovery_id: aws.organizations.describeResponsibilityTransfer
  calls:
  - action: describeResponsibilityTransfer
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ResponsibilityTransfer }}'
    item:
      Arn: '{{ item.Arn }}'
      Name: '{{ item.Name }}'
      Id: '{{ item.Id }}'
      Type: '{{ item.Type }}'
      Status: '{{ item.Status }}'
      Source: '{{ item.Source }}'
      Target: '{{ item.Target }}'
      StartTimestamp: '{{ item.StartTimestamp }}'
      EndTimestamp: '{{ item.EndTimestamp }}'
      ActiveHandshakeId: '{{ item.ActiveHandshakeId }}'
- discovery_id: aws.organizations.listAccountsForParent
  calls:
  - action: listAccountsForParent
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Accounts }}'
    item:
      Id: '{{ item.Id }}'
      Arn: '{{ item.Arn }}'
      Email: '{{ item.Email }}'
      Name: '{{ item.Name }}'
      Status: '{{ item.Status }}'
      State: '{{ item.State }}'
      JoinedMethod: '{{ item.JoinedMethod }}'
      JoinedTimestamp: '{{ item.JoinedTimestamp }}'
- discovery_id: aws.organizations.listAccountsWithInvalidEffectivePolicy
  calls:
  - action: listAccountsWithInvalidEffectivePolicy
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Accounts }}'
    item:
      Id: '{{ item.Id }}'
      Arn: '{{ item.Arn }}'
      Email: '{{ item.Email }}'
      Name: '{{ item.Name }}'
      Status: '{{ item.Status }}'
      State: '{{ item.State }}'
      JoinedMethod: '{{ item.JoinedMethod }}'
      JoinedTimestamp: '{{ item.JoinedTimestamp }}'
- discovery_id: aws.organizations.listChildren
  calls:
  - action: listChildren
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Children }}'
    item:
      Id: '{{ item.Id }}'
      Type: '{{ item.Type }}'
- discovery_id: aws.organizations.listDelegatedServicesForAccount
  calls:
  - action: listDelegatedServicesForAccount
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.DelegatedServices }}'
    item:
      ServicePrincipal: '{{ item.ServicePrincipal }}'
