version: '1.0'
provider: aws
service: mailmanager
services:
  client: mailmanager
  module: boto3.client
discovery:
- discovery_id: aws.mailmanager.listAddonInstances
  calls:
  - action: listAddonInstances
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AddonInstances }}'
    item:
      AddonInstanceId: '{{ item.AddonInstanceId }}'
      AddonSubscriptionId: '{{ item.AddonSubscriptionId }}'
      AddonName: '{{ item.AddonName }}'
      AddonInstanceArn: '{{ item.AddonInstanceArn }}'
      CreatedTimestamp: '{{ item.CreatedTimestamp }}'
- discovery_id: aws.mailmanager.listAddonSubscriptions
  calls:
  - action: listAddonSubscriptions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AddonSubscriptions }}'
    item:
      AddonSubscriptionId: '{{ item.AddonSubscriptionId }}'
      AddonName: '{{ item.AddonName }}'
      AddonSubscriptionArn: '{{ item.AddonSubscriptionArn }}'
      CreatedTimestamp: '{{ item.CreatedTimestamp }}'
- discovery_id: aws.mailmanager.listAddressLists
  calls:
  - action: listAddressLists
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AddressLists }}'
    item:
      AddressListId: '{{ item.AddressListId }}'
      AddressListArn: '{{ item.AddressListArn }}'
      AddressListName: '{{ item.AddressListName }}'
      CreatedTimestamp: '{{ item.CreatedTimestamp }}'
      LastUpdatedTimestamp: '{{ item.LastUpdatedTimestamp }}'
- discovery_id: aws.mailmanager.listArchives
  calls:
  - action: listArchives
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Archives }}'
    item:
      ArchiveId: '{{ item.ArchiveId }}'
      ArchiveName: '{{ item.ArchiveName }}'
      ArchiveState: '{{ item.ArchiveState }}'
      LastUpdatedTimestamp: '{{ item.LastUpdatedTimestamp }}'
- discovery_id: aws.mailmanager.listIngressPoints
  calls:
  - action: listIngressPoints
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.IngressPoints }}'
    item:
      IngressPointName: '{{ item.IngressPointName }}'
      IngressPointId: '{{ item.IngressPointId }}'
      Status: '{{ item.Status }}'
      Type: '{{ item.Type }}'
      ARecord: '{{ item.ARecord }}'
- discovery_id: aws.mailmanager.listRelays
  calls:
  - action: listRelays
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Relays }}'
    item:
      RelayId: '{{ item.RelayId }}'
      RelayName: '{{ item.RelayName }}'
      LastModifiedTimestamp: '{{ item.LastModifiedTimestamp }}'
- discovery_id: aws.mailmanager.listRuleSets
  calls:
  - action: listRuleSets
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.RuleSets }}'
    item:
      RuleSetId: '{{ item.RuleSetId }}'
      RuleSetName: '{{ item.RuleSetName }}'
      LastModificationDate: '{{ item.LastModificationDate }}'
- discovery_id: aws.mailmanager.listTrafficPolicies
  calls:
  - action: listTrafficPolicies
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.TrafficPolicies }}'
    item:
      TrafficPolicyName: '{{ item.TrafficPolicyName }}'
      TrafficPolicyId: '{{ item.TrafficPolicyId }}'
      DefaultAction: '{{ item.DefaultAction }}'
- discovery_id: aws.mailmanager.getAddonInstance
  calls:
  - action: getAddonInstance
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AddonSubscriptionId }}'
- discovery_id: aws.mailmanager.getAddonSubscription
  calls:
  - action: getAddonSubscription
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AddonName }}'
- discovery_id: aws.mailmanager.getAddressList
  calls:
  - action: getAddressList
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AddressListId }}'
- discovery_id: aws.mailmanager.getAddressListImportJob
  calls:
  - action: getAddressListImportJob
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ImportDataFormat }}'
    item:
      ImportDataType: '{{ item.ImportDataType }}'
- discovery_id: aws.mailmanager.getArchive
  calls:
  - action: getArchive
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Retention }}'
    item:
      RetentionPeriod: '{{ item.RetentionPeriod }}'
- discovery_id: aws.mailmanager.getArchiveExport
  calls:
  - action: getArchiveExport
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Filters }}'
    item:
      Include: '{{ item.Include }}'
      Unless: '{{ item.Unless }}'
- discovery_id: aws.mailmanager.getArchiveMessage
  calls:
  - action: getArchiveMessage
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Metadata }}'
    item:
      Timestamp: '{{ item.Timestamp }}'
      IngressPointId: '{{ item.IngressPointId }}'
      TrafficPolicyId: '{{ item.TrafficPolicyId }}'
      RuleSetId: '{{ item.RuleSetId }}'
      SenderHostname: '{{ item.SenderHostname }}'
      SenderIpAddress: '{{ item.SenderIpAddress }}'
      TlsCipherSuite: '{{ item.TlsCipherSuite }}'
      TlsProtocol: '{{ item.TlsProtocol }}'
      SendingMethod: '{{ item.SendingMethod }}'
      SourceIdentity: '{{ item.SourceIdentity }}'
      SendingPool: '{{ item.SendingPool }}'
      ConfigurationSet: '{{ item.ConfigurationSet }}'
      SourceArn: '{{ item.SourceArn }}'
- discovery_id: aws.mailmanager.getArchiveMessageContent
  calls:
  - action: getArchiveMessageContent
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Body }}'
    item:
      Text: '{{ item.Text }}'
      Html: '{{ item.Html }}'
      MessageMalformed: '{{ item.MessageMalformed }}'
- discovery_id: aws.mailmanager.getArchiveSearch
  calls:
  - action: getArchiveSearch
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Filters }}'
    item:
      Include: '{{ item.Include }}'
      Unless: '{{ item.Unless }}'
- discovery_id: aws.mailmanager.getArchiveSearchResults
  calls:
  - action: getArchiveSearchResults
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Rows }}'
    item:
      ArchivedMessageId: '{{ item.ArchivedMessageId }}'
      ReceivedTimestamp: '{{ item.ReceivedTimestamp }}'
      Date: '{{ item.Date }}'
      To: '{{ item.To }}'
      From: '{{ item.From }}'
      Cc: '{{ item.Cc }}'
      Subject: '{{ item.Subject }}'
      MessageId: '{{ item.MessageId }}'
      HasAttachments: '{{ item.HasAttachments }}'
      ReceivedHeaders: '{{ item.ReceivedHeaders }}'
      InReplyTo: '{{ item.InReplyTo }}'
      XMailer: '{{ item.XMailer }}'
      XOriginalMailer: '{{ item.XOriginalMailer }}'
      XPriority: '{{ item.XPriority }}'
      IngressPointId: '{{ item.IngressPointId }}'
      SenderHostname: '{{ item.SenderHostname }}'
      SenderIpAddress: '{{ item.SenderIpAddress }}'
      Envelope: '{{ item.Envelope }}'
      SourceArn: '{{ item.SourceArn }}'
- discovery_id: aws.mailmanager.getIngressPoint
  calls:
  - action: getIngressPoint
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.IngressPointAuthConfiguration }}'
    item:
      IngressPointPasswordConfiguration: '{{ item.IngressPointPasswordConfiguration
        }}'
      SecretArn: '{{ item.SecretArn }}'
- discovery_id: aws.mailmanager.getMemberOfAddressList
  calls:
  - action: getMemberOfAddressList
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Address }}'
- discovery_id: aws.mailmanager.getRelay
  calls:
  - action: getRelay
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Authentication }}'
    item:
      SecretArn: '{{ item.SecretArn }}'
      NoAuthentication: '{{ item.NoAuthentication }}'
- discovery_id: aws.mailmanager.getRuleSet
  calls:
  - action: getRuleSet
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Rules }}'
    item:
      Name: '{{ item.Name }}'
      Conditions: '{{ item.Conditions }}'
      Unless: '{{ item.Unless }}'
      Actions: '{{ item.Actions }}'
- discovery_id: aws.mailmanager.getTrafficPolicy
  calls:
  - action: getTrafficPolicy
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.PolicyStatements }}'
    item:
      Conditions: '{{ item.Conditions }}'
      Action: '{{ item.Action }}'
- discovery_id: aws.mailmanager.listAddressListImportJobs
  calls:
  - action: listAddressListImportJobs
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ImportJobs }}'
    item:
      JobId: '{{ item.JobId }}'
      Name: '{{ item.Name }}'
      Status: '{{ item.Status }}'
      PreSignedUrl: '{{ item.PreSignedUrl }}'
      ImportedItemsCount: '{{ item.ImportedItemsCount }}'
      FailedItemsCount: '{{ item.FailedItemsCount }}'
      ImportDataFormat: '{{ item.ImportDataFormat }}'
      AddressListId: '{{ item.AddressListId }}'
      CreatedTimestamp: '{{ item.CreatedTimestamp }}'
      StartTimestamp: '{{ item.StartTimestamp }}'
      CompletedTimestamp: '{{ item.CompletedTimestamp }}'
      Error: '{{ item.Error }}'
- discovery_id: aws.mailmanager.listArchiveExports
  calls:
  - action: listArchiveExports
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Exports }}'
    item:
      ExportId: '{{ item.ExportId }}'
      Status: '{{ item.Status }}'
- discovery_id: aws.mailmanager.listArchiveSearches
  calls:
  - action: listArchiveSearches
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Searches }}'
    item:
      SearchId: '{{ item.SearchId }}'
      Status: '{{ item.Status }}'
- discovery_id: aws.mailmanager.listMembersOfAddressList
  calls:
  - action: listMembersOfAddressList
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Addresses }}'
    item:
      Address: '{{ item.Address }}'
      CreatedTimestamp: '{{ item.CreatedTimestamp }}'
- discovery_id: aws.mailmanager.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Tags }}'
    item:
      Key: '{{ item.Key }}'
      Value: '{{ item.Value }}'
checks: []
