version: '1.0'
provider: aws
service: outposts
services:
  client: outposts
  module: boto3.client
discovery:
- discovery_id: aws.outposts.listCapacityTasks
  calls:
  - action: listCapacityTasks
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.CapacityTasks }}'
    item:
      CapacityTaskId: '{{ item.CapacityTaskId }}'
      OutpostId: '{{ item.OutpostId }}'
      OrderId: '{{ item.OrderId }}'
      AssetId: '{{ item.AssetId }}'
      CapacityTaskStatus: '{{ item.CapacityTaskStatus }}'
      CreationDate: '{{ item.CreationDate }}'
      CompletionDate: '{{ item.CompletionDate }}'
      LastModifiedDate: '{{ item.LastModifiedDate }}'
- discovery_id: aws.outposts.listCatalogItems
  calls:
  - action: listCatalogItems
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.CatalogItems }}'
    item:
      CatalogItemId: '{{ item.CatalogItemId }}'
      ItemStatus: '{{ item.ItemStatus }}'
      EC2Capacities: '{{ item.EC2Capacities }}'
      PowerKva: '{{ item.PowerKva }}'
      WeightLbs: '{{ item.WeightLbs }}'
      SupportedUplinkGbps: '{{ item.SupportedUplinkGbps }}'
      SupportedStorage: '{{ item.SupportedStorage }}'
- discovery_id: aws.outposts.listOrders
  calls:
  - action: listOrders
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Orders }}'
    item:
      OutpostId: '{{ item.OutpostId }}'
      OrderId: '{{ item.OrderId }}'
      OrderType: '{{ item.OrderType }}'
      Status: '{{ item.Status }}'
      LineItemCountsByStatus: '{{ item.LineItemCountsByStatus }}'
      OrderSubmissionDate: '{{ item.OrderSubmissionDate }}'
      OrderFulfilledDate: '{{ item.OrderFulfilledDate }}'
- discovery_id: aws.outposts.listOutposts
  calls:
  - action: listOutposts
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Outposts }}'
    item:
      OutpostId: '{{ item.OutpostId }}'
      OwnerId: '{{ item.OwnerId }}'
      OutpostArn: '{{ item.OutpostArn }}'
      SiteId: '{{ item.SiteId }}'
      Name: '{{ item.Name }}'
      Description: '{{ item.Description }}'
      LifeCycleStatus: '{{ item.LifeCycleStatus }}'
      AvailabilityZone: '{{ item.AvailabilityZone }}'
      AvailabilityZoneId: '{{ item.AvailabilityZoneId }}'
      Tags: '{{ item.Tags }}'
      SiteArn: '{{ item.SiteArn }}'
      SupportedHardwareType: '{{ item.SupportedHardwareType }}'
- discovery_id: aws.outposts.listSites
  calls:
  - action: listSites
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Sites }}'
    item:
      SiteId: '{{ item.SiteId }}'
      AccountId: '{{ item.AccountId }}'
      Name: '{{ item.Name }}'
      Description: '{{ item.Description }}'
      Tags: '{{ item.Tags }}'
      SiteArn: '{{ item.SiteArn }}'
      Notes: '{{ item.Notes }}'
      OperatingAddressCountryCode: '{{ item.OperatingAddressCountryCode }}'
      OperatingAddressStateOrRegion: '{{ item.OperatingAddressStateOrRegion }}'
      OperatingAddressCity: '{{ item.OperatingAddressCity }}'
      RackPhysicalProperties: '{{ item.RackPhysicalProperties }}'
- discovery_id: aws.outposts.getCapacityTask
  calls:
  - action: getCapacityTask
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.RequestedInstancePools }}'
    item:
      InstanceType: '{{ item.InstanceType }}'
      Count: '{{ item.Count }}'
- discovery_id: aws.outposts.getCatalogItem
  calls:
  - action: getCatalogItem
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.CatalogItem }}'
    item:
      CatalogItemId: '{{ item.CatalogItemId }}'
      ItemStatus: '{{ item.ItemStatus }}'
      EC2Capacities: '{{ item.EC2Capacities }}'
      PowerKva: '{{ item.PowerKva }}'
      WeightLbs: '{{ item.WeightLbs }}'
      SupportedUplinkGbps: '{{ item.SupportedUplinkGbps }}'
      SupportedStorage: '{{ item.SupportedStorage }}'
- discovery_id: aws.outposts.getConnection
  calls:
  - action: getConnection
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ConnectionDetails }}'
    item:
      ClientPublicKey: '{{ item.ClientPublicKey }}'
      ServerPublicKey: '{{ item.ServerPublicKey }}'
      ServerEndpoint: '{{ item.ServerEndpoint }}'
      ClientTunnelAddress: '{{ item.ClientTunnelAddress }}'
      ServerTunnelAddress: '{{ item.ServerTunnelAddress }}'
      AllowedIps: '{{ item.AllowedIps }}'
- discovery_id: aws.outposts.getOrder
  calls:
  - action: getOrder
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Order }}'
    item:
      OutpostId: '{{ item.OutpostId }}'
      OrderId: '{{ item.OrderId }}'
      Status: '{{ item.Status }}'
      LineItems: '{{ item.LineItems }}'
      PaymentOption: '{{ item.PaymentOption }}'
      OrderSubmissionDate: '{{ item.OrderSubmissionDate }}'
      OrderFulfilledDate: '{{ item.OrderFulfilledDate }}'
      PaymentTerm: '{{ item.PaymentTerm }}'
      OrderType: '{{ item.OrderType }}'
- discovery_id: aws.outposts.getOutpost
  calls:
  - action: getOutpost
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Outpost }}'
    item:
      OutpostId: '{{ item.OutpostId }}'
      OwnerId: '{{ item.OwnerId }}'
      OutpostArn: '{{ item.OutpostArn }}'
      SiteId: '{{ item.SiteId }}'
      Name: '{{ item.Name }}'
      Description: '{{ item.Description }}'
      LifeCycleStatus: '{{ item.LifeCycleStatus }}'
      AvailabilityZone: '{{ item.AvailabilityZone }}'
      AvailabilityZoneId: '{{ item.AvailabilityZoneId }}'
      Tags: '{{ item.Tags }}'
      SiteArn: '{{ item.SiteArn }}'
      SupportedHardwareType: '{{ item.SupportedHardwareType }}'
- discovery_id: aws.outposts.getOutpostBillingInformation
  calls:
  - action: getOutpostBillingInformation
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Subscriptions }}'
    item:
      SubscriptionId: '{{ item.SubscriptionId }}'
      SubscriptionType: '{{ item.SubscriptionType }}'
      SubscriptionStatus: '{{ item.SubscriptionStatus }}'
      OrderIds: '{{ item.OrderIds }}'
      BeginDate: '{{ item.BeginDate }}'
      EndDate: '{{ item.EndDate }}'
      MonthlyRecurringPrice: '{{ item.MonthlyRecurringPrice }}'
      UpfrontPrice: '{{ item.UpfrontPrice }}'
- discovery_id: aws.outposts.getOutpostInstanceTypes
  calls:
  - action: getOutpostInstanceTypes
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.InstanceTypes }}'
    item:
      InstanceType: '{{ item.InstanceType }}'
      VCPUs: '{{ item.VCPUs }}'
- discovery_id: aws.outposts.getOutpostSupportedInstanceTypes
  calls:
  - action: getOutpostSupportedInstanceTypes
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.InstanceTypes }}'
    item:
      InstanceType: '{{ item.InstanceType }}'
      VCPUs: '{{ item.VCPUs }}'
- discovery_id: aws.outposts.getSite
  calls:
  - action: getSite
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Site }}'
    item:
      SiteId: '{{ item.SiteId }}'
      AccountId: '{{ item.AccountId }}'
      Name: '{{ item.Name }}'
      Description: '{{ item.Description }}'
      Tags: '{{ item.Tags }}'
      SiteArn: '{{ item.SiteArn }}'
      Notes: '{{ item.Notes }}'
      OperatingAddressCountryCode: '{{ item.OperatingAddressCountryCode }}'
      OperatingAddressStateOrRegion: '{{ item.OperatingAddressStateOrRegion }}'
      OperatingAddressCity: '{{ item.OperatingAddressCity }}'
      RackPhysicalProperties: '{{ item.RackPhysicalProperties }}'
- discovery_id: aws.outposts.getSiteAddress
  calls:
  - action: getSiteAddress
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Address }}'
    item:
      ContactName: '{{ item.ContactName }}'
      ContactPhoneNumber: '{{ item.ContactPhoneNumber }}'
      AddressLine1: '{{ item.AddressLine1 }}'
      AddressLine2: '{{ item.AddressLine2 }}'
      AddressLine3: '{{ item.AddressLine3 }}'
      City: '{{ item.City }}'
      StateOrRegion: '{{ item.StateOrRegion }}'
      DistrictOrCounty: '{{ item.DistrictOrCounty }}'
      PostalCode: '{{ item.PostalCode }}'
      CountryCode: '{{ item.CountryCode }}'
      Municipality: '{{ item.Municipality }}'
- discovery_id: aws.outposts.listAssetInstances
  calls:
  - action: listAssetInstances
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.AssetInstances }}'
    item:
      InstanceId: '{{ item.InstanceId }}'
      InstanceType: '{{ item.InstanceType }}'
      AssetId: '{{ item.AssetId }}'
      AccountId: '{{ item.AccountId }}'
      AwsServiceName: '{{ item.AwsServiceName }}'
- discovery_id: aws.outposts.listAssets
  calls:
  - action: listAssets
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Assets }}'
    item:
      AssetId: '{{ item.AssetId }}'
      RackId: '{{ item.RackId }}'
      AssetType: '{{ item.AssetType }}'
      ComputeAttributes: '{{ item.ComputeAttributes }}'
      AssetLocation: '{{ item.AssetLocation }}'
- discovery_id: aws.outposts.listBlockingInstancesForCapacityTask
  calls:
  - action: listBlockingInstancesForCapacityTask
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.BlockingInstances }}'
    item:
      InstanceId: '{{ item.InstanceId }}'
      AccountId: '{{ item.AccountId }}'
      AwsServiceName: '{{ item.AwsServiceName }}'
- discovery_id: aws.outposts.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Tags }}'
checks: []
