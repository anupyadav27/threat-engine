version: '1.0'
provider: aws
service: emr-containers
services:
  client: emr-containers
  module: boto3.client
discovery:
- discovery_id: aws.emr-containers.listJobTemplates
  calls:
  - action: listJobTemplates
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.templates }}'
    item:
      name: '{{ item.name }}'
      id: '{{ item.id }}'
      arn: '{{ item.arn }}'
      createdAt: '{{ item.createdAt }}'
      createdBy: '{{ item.createdBy }}'
      tags: '{{ item.tags }}'
      jobTemplateData: '{{ item.jobTemplateData }}'
      kmsKeyArn: '{{ item.kmsKeyArn }}'
      decryptionError: '{{ item.decryptionError }}'
- discovery_id: aws.emr-containers.listSecurityConfigurations
  calls:
  - action: listSecurityConfigurations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.securityConfigurations }}'
    item:
      id: '{{ item.id }}'
      name: '{{ item.name }}'
      arn: '{{ item.arn }}'
      createdAt: '{{ item.createdAt }}'
      createdBy: '{{ item.createdBy }}'
      securityConfigurationData: '{{ item.securityConfigurationData }}'
      tags: '{{ item.tags }}'
- discovery_id: aws.emr-containers.listVirtualClusters
  calls:
  - action: listVirtualClusters
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.virtualClusters }}'
    item:
      id: '{{ item.id }}'
      name: '{{ item.name }}'
      arn: '{{ item.arn }}'
      state: '{{ item.state }}'
      containerProvider: '{{ item.containerProvider }}'
      createdAt: '{{ item.createdAt }}'
      tags: '{{ item.tags }}'
      securityConfigurationId: '{{ item.securityConfigurationId }}'
- discovery_id: aws.emr-containers.describeJobRun
  calls:
  - action: describeJobRun
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.jobRun }}'
    item:
      id: '{{ item.id }}'
      name: '{{ item.name }}'
      virtualClusterId: '{{ item.virtualClusterId }}'
      arn: '{{ item.arn }}'
      state: '{{ item.state }}'
      clientToken: '{{ item.clientToken }}'
      executionRoleArn: '{{ item.executionRoleArn }}'
      releaseLabel: '{{ item.releaseLabel }}'
      configurationOverrides: '{{ item.configurationOverrides }}'
      jobDriver: '{{ item.jobDriver }}'
      createdAt: '{{ item.createdAt }}'
      createdBy: '{{ item.createdBy }}'
      finishedAt: '{{ item.finishedAt }}'
      stateDetails: '{{ item.stateDetails }}'
      failureReason: '{{ item.failureReason }}'
      tags: '{{ item.tags }}'
      retryPolicyConfiguration: '{{ item.retryPolicyConfiguration }}'
      retryPolicyExecution: '{{ item.retryPolicyExecution }}'
- discovery_id: aws.emr-containers.describeJobTemplate
  calls:
  - action: describeJobTemplate
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.jobTemplate }}'
    item:
      name: '{{ item.name }}'
      id: '{{ item.id }}'
      arn: '{{ item.arn }}'
      createdAt: '{{ item.createdAt }}'
      createdBy: '{{ item.createdBy }}'
      tags: '{{ item.tags }}'
      jobTemplateData: '{{ item.jobTemplateData }}'
      kmsKeyArn: '{{ item.kmsKeyArn }}'
      decryptionError: '{{ item.decryptionError }}'
- discovery_id: aws.emr-containers.describeManagedEndpoint
  calls:
  - action: describeManagedEndpoint
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.endpoint }}'
    item:
      id: '{{ item.id }}'
      name: '{{ item.name }}'
      arn: '{{ item.arn }}'
      virtualClusterId: '{{ item.virtualClusterId }}'
      type: '{{ item.type }}'
      state: '{{ item.state }}'
      releaseLabel: '{{ item.releaseLabel }}'
      executionRoleArn: '{{ item.executionRoleArn }}'
      certificateArn: '{{ item.certificateArn }}'
      certificateAuthority: '{{ item.certificateAuthority }}'
      configurationOverrides: '{{ item.configurationOverrides }}'
      serverUrl: '{{ item.serverUrl }}'
      createdAt: '{{ item.createdAt }}'
      securityGroup: '{{ item.securityGroup }}'
      subnetIds: '{{ item.subnetIds }}'
      stateDetails: '{{ item.stateDetails }}'
      failureReason: '{{ item.failureReason }}'
      tags: '{{ item.tags }}'
- discovery_id: aws.emr-containers.describeSecurityConfiguration
  calls:
  - action: describeSecurityConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.securityConfiguration }}'
    item:
      id: '{{ item.id }}'
      name: '{{ item.name }}'
      arn: '{{ item.arn }}'
      createdAt: '{{ item.createdAt }}'
      createdBy: '{{ item.createdBy }}'
      securityConfigurationData: '{{ item.securityConfigurationData }}'
      tags: '{{ item.tags }}'
- discovery_id: aws.emr-containers.describeVirtualCluster
  calls:
  - action: describeVirtualCluster
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.virtualCluster }}'
    item:
      id: '{{ item.id }}'
      name: '{{ item.name }}'
      arn: '{{ item.arn }}'
      state: '{{ item.state }}'
      containerProvider: '{{ item.containerProvider }}'
      createdAt: '{{ item.createdAt }}'
      tags: '{{ item.tags }}'
      securityConfigurationId: '{{ item.securityConfigurationId }}'
- discovery_id: aws.emr-containers.getManagedEndpointSessionCredentials
  calls:
  - action: getManagedEndpointSessionCredentials
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.credentials }}'
    item:
      token: '{{ item.token }}'
- discovery_id: aws.emr-containers.listJobRuns
  calls:
  - action: listJobRuns
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.jobRuns }}'
    item:
      id: '{{ item.id }}'
      name: '{{ item.name }}'
      virtualClusterId: '{{ item.virtualClusterId }}'
      arn: '{{ item.arn }}'
      state: '{{ item.state }}'
      clientToken: '{{ item.clientToken }}'
      executionRoleArn: '{{ item.executionRoleArn }}'
      releaseLabel: '{{ item.releaseLabel }}'
      configurationOverrides: '{{ item.configurationOverrides }}'
      jobDriver: '{{ item.jobDriver }}'
      createdAt: '{{ item.createdAt }}'
      createdBy: '{{ item.createdBy }}'
      finishedAt: '{{ item.finishedAt }}'
      stateDetails: '{{ item.stateDetails }}'
      failureReason: '{{ item.failureReason }}'
      tags: '{{ item.tags }}'
      retryPolicyConfiguration: '{{ item.retryPolicyConfiguration }}'
      retryPolicyExecution: '{{ item.retryPolicyExecution }}'
- discovery_id: aws.emr-containers.listManagedEndpoints
  calls:
  - action: listManagedEndpoints
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.endpoints }}'
    item:
      id: '{{ item.id }}'
      name: '{{ item.name }}'
      arn: '{{ item.arn }}'
      virtualClusterId: '{{ item.virtualClusterId }}'
      type: '{{ item.type }}'
      state: '{{ item.state }}'
      releaseLabel: '{{ item.releaseLabel }}'
      executionRoleArn: '{{ item.executionRoleArn }}'
      certificateArn: '{{ item.certificateArn }}'
      certificateAuthority: '{{ item.certificateAuthority }}'
      configurationOverrides: '{{ item.configurationOverrides }}'
      serverUrl: '{{ item.serverUrl }}'
      createdAt: '{{ item.createdAt }}'
      securityGroup: '{{ item.securityGroup }}'
      subnetIds: '{{ item.subnetIds }}'
      stateDetails: '{{ item.stateDetails }}'
      failureReason: '{{ item.failureReason }}'
      tags: '{{ item.tags }}'
- discovery_id: aws.emr-containers.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tags }}'
checks: []
