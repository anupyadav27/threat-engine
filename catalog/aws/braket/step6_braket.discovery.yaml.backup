version: '1.0'
provider: aws
service: braket
services:
  client: braket
  module: boto3.client
discovery:
- discovery_id: aws.braket.searchSpendingLimits
  calls:
  - action: searchSpendingLimits
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.spendingLimits }}'
    item:
      spendingLimitArn: '{{ item.spendingLimitArn }}'
      deviceArn: '{{ item.deviceArn }}'
      timePeriod: '{{ item.timePeriod }}'
      spendingLimit: '{{ item.spendingLimit }}'
      queuedSpend: '{{ item.queuedSpend }}'
      totalSpend: '{{ item.totalSpend }}'
      createdAt: '{{ item.createdAt }}'
      updatedAt: '{{ item.updatedAt }}'
      tags: '{{ item.tags }}'
- discovery_id: aws.braket.getDevice
  calls:
  - action: getDevice
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.deviceQueueInfo }}'
    item:
      queue: '{{ item.queue }}'
      queueSize: '{{ item.queueSize }}'
      queuePriority: '{{ item.queuePriority }}'
- discovery_id: aws.braket.getJob
  calls:
  - action: getJob
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.inputDataConfig }}'
    item:
      channelName: '{{ item.channelName }}'
      contentType: '{{ item.contentType }}'
      dataSource: '{{ item.dataSource }}'
- discovery_id: aws.braket.getQuantumTask
  calls:
  - action: getQuantumTask
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.associations }}'
    item:
      arn: '{{ item.arn }}'
      type: '{{ item.type }}'
- discovery_id: aws.braket.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tags }}'
- discovery_id: aws.braket.searchDevices
  calls:
  - action: searchDevices
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.devices }}'
    item:
      deviceArn: '{{ item.deviceArn }}'
      deviceName: '{{ item.deviceName }}'
      providerName: '{{ item.providerName }}'
      deviceType: '{{ item.deviceType }}'
      deviceStatus: '{{ item.deviceStatus }}'
- discovery_id: aws.braket.searchJobs
  calls:
  - action: searchJobs
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.jobs }}'
    item:
      status: '{{ item.status }}'
      jobArn: '{{ item.jobArn }}'
      jobName: '{{ item.jobName }}'
      device: '{{ item.device }}'
      createdAt: '{{ item.createdAt }}'
      startedAt: '{{ item.startedAt }}'
      endedAt: '{{ item.endedAt }}'
      tags: '{{ item.tags }}'
- discovery_id: aws.braket.searchQuantumTasks
  calls:
  - action: searchQuantumTasks
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.quantumTasks }}'
    item:
      quantumTaskArn: '{{ item.quantumTaskArn }}'
      status: '{{ item.status }}'
      deviceArn: '{{ item.deviceArn }}'
      shots: '{{ item.shots }}'
      outputS3Bucket: '{{ item.outputS3Bucket }}'
      outputS3Directory: '{{ item.outputS3Directory }}'
      createdAt: '{{ item.createdAt }}'
      endedAt: '{{ item.endedAt }}'
      tags: '{{ item.tags }}'
checks: []
