version: '1.0'
provider: aws
service: opensearchserverless
services:
  client: opensearchserverless
  module: boto3.client
discovery:
- discovery_id: aws.opensearchserverless.getAccountSettings
  calls:
  - action: getAccountSettings
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.accountSettingsDetail }}'
    item:
      capacityLimits: '{{ item.capacityLimits }}'
- discovery_id: aws.opensearchserverless.getPoliciesStats
  calls:
  - action: getPoliciesStats
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AccessPolicyStats }}'
    item:
      DataPolicyCount: '{{ item.DataPolicyCount }}'
- discovery_id: aws.opensearchserverless.listCollections
  calls:
  - action: listCollections
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.collectionSummaries }}'
    item:
      id: '{{ item.id }}'
      name: '{{ item.name }}'
      status: '{{ item.status }}'
      arn: '{{ item.arn }}'
- discovery_id: aws.opensearchserverless.listVpcEndpoints
  calls:
  - action: listVpcEndpoints
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.vpcEndpointSummaries }}'
    item:
      id: '{{ item.id }}'
      name: '{{ item.name }}'
      status: '{{ item.status }}'
- discovery_id: aws.opensearchserverless.getAccessPolicy
  calls:
  - action: getAccessPolicy
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.accessPolicyDetail }}'
    item:
      type: '{{ item.type }}'
      name: '{{ item.name }}'
      policyVersion: '{{ item.policyVersion }}'
      description: '{{ item.description }}'
      policy: '{{ item.policy }}'
      createdDate: '{{ item.createdDate }}'
      lastModifiedDate: '{{ item.lastModifiedDate }}'
- discovery_id: aws.opensearchserverless.getIndex
  calls:
  - action: getIndex
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.indexSchema }}'
- discovery_id: aws.opensearchserverless.getSecurityConfig
  calls:
  - action: getSecurityConfig
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.securityConfigDetail }}'
    item:
      id: '{{ item.id }}'
      type: '{{ item.type }}'
      configVersion: '{{ item.configVersion }}'
      description: '{{ item.description }}'
      samlOptions: '{{ item.samlOptions }}'
      iamIdentityCenterOptions: '{{ item.iamIdentityCenterOptions }}'
      iamFederationOptions: '{{ item.iamFederationOptions }}'
      createdDate: '{{ item.createdDate }}'
      lastModifiedDate: '{{ item.lastModifiedDate }}'
- discovery_id: aws.opensearchserverless.getSecurityPolicy
  calls:
  - action: getSecurityPolicy
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.securityPolicyDetail }}'
    item:
      type: '{{ item.type }}'
      name: '{{ item.name }}'
      policyVersion: '{{ item.policyVersion }}'
      description: '{{ item.description }}'
      policy: '{{ item.policy }}'
      createdDate: '{{ item.createdDate }}'
      lastModifiedDate: '{{ item.lastModifiedDate }}'
- discovery_id: aws.opensearchserverless.listAccessPolicies
  calls:
  - action: listAccessPolicies
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.accessPolicySummaries }}'
    item:
      type: '{{ item.type }}'
      name: '{{ item.name }}'
      policyVersion: '{{ item.policyVersion }}'
      description: '{{ item.description }}'
      createdDate: '{{ item.createdDate }}'
      lastModifiedDate: '{{ item.lastModifiedDate }}'
- discovery_id: aws.opensearchserverless.listLifecyclePolicies
  calls:
  - action: listLifecyclePolicies
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.lifecyclePolicySummaries }}'
    item:
      type: '{{ item.type }}'
      name: '{{ item.name }}'
      policyVersion: '{{ item.policyVersion }}'
      description: '{{ item.description }}'
      createdDate: '{{ item.createdDate }}'
      lastModifiedDate: '{{ item.lastModifiedDate }}'
- discovery_id: aws.opensearchserverless.listSecurityConfigs
  calls:
  - action: listSecurityConfigs
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.securityConfigSummaries }}'
    item:
      id: '{{ item.id }}'
      type: '{{ item.type }}'
      configVersion: '{{ item.configVersion }}'
      description: '{{ item.description }}'
      createdDate: '{{ item.createdDate }}'
      lastModifiedDate: '{{ item.lastModifiedDate }}'
- discovery_id: aws.opensearchserverless.listSecurityPolicies
  calls:
  - action: listSecurityPolicies
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.securityPolicySummaries }}'
    item:
      type: '{{ item.type }}'
      name: '{{ item.name }}'
      policyVersion: '{{ item.policyVersion }}'
      description: '{{ item.description }}'
      createdDate: '{{ item.createdDate }}'
      lastModifiedDate: '{{ item.lastModifiedDate }}'
- discovery_id: aws.opensearchserverless.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tags }}'
    item:
      key: '{{ item.key }}'
      value: '{{ item.value }}'
checks: []
