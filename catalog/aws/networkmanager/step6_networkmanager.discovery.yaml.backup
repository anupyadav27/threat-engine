version: '1.0'
provider: aws
service: networkmanager
services:
  client: networkmanager
  module: boto3.client
discovery:
- discovery_id: aws.networkmanager.describeGlobalNetworks
  calls:
  - action: describeGlobalNetworks
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.GlobalNetworks }}'
    item:
      GlobalNetworkId: '{{ item.GlobalNetworkId }}'
      GlobalNetworkArn: '{{ item.GlobalNetworkArn }}'
      Description: '{{ item.Description }}'
      CreatedAt: '{{ item.CreatedAt }}'
      State: '{{ item.State }}'
      Tags: '{{ item.Tags }}'
- discovery_id: aws.networkmanager.listAttachments
  calls:
  - action: listAttachments
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Attachments }}'
    item:
      CoreNetworkId: '{{ item.CoreNetworkId }}'
      CoreNetworkArn: '{{ item.CoreNetworkArn }}'
      AttachmentId: '{{ item.AttachmentId }}'
      OwnerAccountId: '{{ item.OwnerAccountId }}'
      AttachmentType: '{{ item.AttachmentType }}'
      State: '{{ item.State }}'
      EdgeLocation: '{{ item.EdgeLocation }}'
      EdgeLocations: '{{ item.EdgeLocations }}'
      ResourceArn: '{{ item.ResourceArn }}'
      AttachmentPolicyRuleNumber: '{{ item.AttachmentPolicyRuleNumber }}'
      SegmentName: '{{ item.SegmentName }}'
      NetworkFunctionGroupName: '{{ item.NetworkFunctionGroupName }}'
      Tags: '{{ item.Tags }}'
      ProposedSegmentChange: '{{ item.ProposedSegmentChange }}'
      ProposedNetworkFunctionGroupChange: '{{ item.ProposedNetworkFunctionGroupChange
        }}'
      CreatedAt: '{{ item.CreatedAt }}'
      UpdatedAt: '{{ item.UpdatedAt }}'
      LastModificationErrors: '{{ item.LastModificationErrors }}'
- discovery_id: aws.networkmanager.listConnectPeers
  calls:
  - action: listConnectPeers
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.ConnectPeers }}'
    item:
      CoreNetworkId: '{{ item.CoreNetworkId }}'
      ConnectAttachmentId: '{{ item.ConnectAttachmentId }}'
      ConnectPeerId: '{{ item.ConnectPeerId }}'
      EdgeLocation: '{{ item.EdgeLocation }}'
      ConnectPeerState: '{{ item.ConnectPeerState }}'
      CreatedAt: '{{ item.CreatedAt }}'
      Tags: '{{ item.Tags }}'
      SubnetArn: '{{ item.SubnetArn }}'
- discovery_id: aws.networkmanager.listCoreNetworks
  calls:
  - action: listCoreNetworks
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.CoreNetworks }}'
    item:
      CoreNetworkId: '{{ item.CoreNetworkId }}'
      CoreNetworkArn: '{{ item.CoreNetworkArn }}'
      GlobalNetworkId: '{{ item.GlobalNetworkId }}'
      OwnerAccountId: '{{ item.OwnerAccountId }}'
      State: '{{ item.State }}'
      Description: '{{ item.Description }}'
      Tags: '{{ item.Tags }}'
- discovery_id: aws.networkmanager.listOrganizationServiceAccessStatus
  calls:
  - action: listOrganizationServiceAccessStatus
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.OrganizationStatus }}'
    item:
      OrganizationId: '{{ item.OrganizationId }}'
      OrganizationAwsServiceAccessStatus: '{{ item.OrganizationAwsServiceAccessStatus
        }}'
      SLRDeploymentStatus: '{{ item.SLRDeploymentStatus }}'
      AccountStatusList: '{{ item.AccountStatusList }}'
- discovery_id: aws.networkmanager.listPeerings
  calls:
  - action: listPeerings
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Peerings }}'
    item:
      CoreNetworkId: '{{ item.CoreNetworkId }}'
      CoreNetworkArn: '{{ item.CoreNetworkArn }}'
      PeeringId: '{{ item.PeeringId }}'
      OwnerAccountId: '{{ item.OwnerAccountId }}'
      PeeringType: '{{ item.PeeringType }}'
      State: '{{ item.State }}'
      EdgeLocation: '{{ item.EdgeLocation }}'
      ResourceArn: '{{ item.ResourceArn }}'
      Tags: '{{ item.Tags }}'
      CreatedAt: '{{ item.CreatedAt }}'
      LastModificationErrors: '{{ item.LastModificationErrors }}'
- discovery_id: aws.networkmanager.getConnectAttachment
  calls:
  - action: getConnectAttachment
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ConnectAttachment }}'
    item:
      Attachment: '{{ item.Attachment }}'
      TransportAttachmentId: '{{ item.TransportAttachmentId }}'
      Options: '{{ item.Options }}'
- discovery_id: aws.networkmanager.getConnectPeer
  calls:
  - action: getConnectPeer
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ConnectPeer }}'
    item:
      CoreNetworkId: '{{ item.CoreNetworkId }}'
      ConnectAttachmentId: '{{ item.ConnectAttachmentId }}'
      ConnectPeerId: '{{ item.ConnectPeerId }}'
      EdgeLocation: '{{ item.EdgeLocation }}'
      State: '{{ item.State }}'
      CreatedAt: '{{ item.CreatedAt }}'
      Configuration: '{{ item.Configuration }}'
      Tags: '{{ item.Tags }}'
      SubnetArn: '{{ item.SubnetArn }}'
      LastModificationErrors: '{{ item.LastModificationErrors }}'
- discovery_id: aws.networkmanager.getConnectPeerAssociations
  calls:
  - action: getConnectPeerAssociations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ConnectPeerAssociations }}'
    item:
      ConnectPeerId: '{{ item.ConnectPeerId }}'
      GlobalNetworkId: '{{ item.GlobalNetworkId }}'
      DeviceId: '{{ item.DeviceId }}'
      LinkId: '{{ item.LinkId }}'
      State: '{{ item.State }}'
- discovery_id: aws.networkmanager.getConnections
  calls:
  - action: getConnections
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Connections }}'
    item:
      ConnectionId: '{{ item.ConnectionId }}'
      ConnectionArn: '{{ item.ConnectionArn }}'
      GlobalNetworkId: '{{ item.GlobalNetworkId }}'
      DeviceId: '{{ item.DeviceId }}'
      ConnectedDeviceId: '{{ item.ConnectedDeviceId }}'
      LinkId: '{{ item.LinkId }}'
      ConnectedLinkId: '{{ item.ConnectedLinkId }}'
      Description: '{{ item.Description }}'
      CreatedAt: '{{ item.CreatedAt }}'
      State: '{{ item.State }}'
      Tags: '{{ item.Tags }}'
- discovery_id: aws.networkmanager.getCoreNetwork
  calls:
  - action: getCoreNetwork
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.CoreNetwork }}'
    item:
      GlobalNetworkId: '{{ item.GlobalNetworkId }}'
      CoreNetworkId: '{{ item.CoreNetworkId }}'
      CoreNetworkArn: '{{ item.CoreNetworkArn }}'
      Description: '{{ item.Description }}'
      CreatedAt: '{{ item.CreatedAt }}'
      State: '{{ item.State }}'
      Segments: '{{ item.Segments }}'
      NetworkFunctionGroups: '{{ item.NetworkFunctionGroups }}'
      Edges: '{{ item.Edges }}'
      Tags: '{{ item.Tags }}'
- discovery_id: aws.networkmanager.getCoreNetworkChangeEvents
  calls:
  - action: getCoreNetworkChangeEvents
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.CoreNetworkChangeEvents }}'
    item:
      Type: '{{ item.Type }}'
      Action: '{{ item.Action }}'
      IdentifierPath: '{{ item.IdentifierPath }}'
      EventTime: '{{ item.EventTime }}'
      Status: '{{ item.Status }}'
      Values: '{{ item.Values }}'
- discovery_id: aws.networkmanager.getCoreNetworkChangeSet
  calls:
  - action: getCoreNetworkChangeSet
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.CoreNetworkChanges }}'
    item:
      Type: '{{ item.Type }}'
      Action: '{{ item.Action }}'
      Identifier: '{{ item.Identifier }}'
      PreviousValues: '{{ item.PreviousValues }}'
      NewValues: '{{ item.NewValues }}'
      IdentifierPath: '{{ item.IdentifierPath }}'
- discovery_id: aws.networkmanager.getCoreNetworkPolicy
  calls:
  - action: getCoreNetworkPolicy
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.CoreNetworkPolicy }}'
    item:
      CoreNetworkId: '{{ item.CoreNetworkId }}'
      PolicyVersionId: '{{ item.PolicyVersionId }}'
      Alias: '{{ item.Alias }}'
      Description: '{{ item.Description }}'
      CreatedAt: '{{ item.CreatedAt }}'
      ChangeSetState: '{{ item.ChangeSetState }}'
      PolicyErrors: '{{ item.PolicyErrors }}'
      PolicyDocument: '{{ item.PolicyDocument }}'
- discovery_id: aws.networkmanager.getCustomerGatewayAssociations
  calls:
  - action: getCustomerGatewayAssociations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.CustomerGatewayAssociations }}'
    item:
      CustomerGatewayArn: '{{ item.CustomerGatewayArn }}'
      GlobalNetworkId: '{{ item.GlobalNetworkId }}'
      DeviceId: '{{ item.DeviceId }}'
      LinkId: '{{ item.LinkId }}'
      State: '{{ item.State }}'
- discovery_id: aws.networkmanager.getDevices
  calls:
  - action: getDevices
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Devices }}'
    item:
      DeviceId: '{{ item.DeviceId }}'
      DeviceArn: '{{ item.DeviceArn }}'
      GlobalNetworkId: '{{ item.GlobalNetworkId }}'
      AWSLocation: '{{ item.AWSLocation }}'
      Description: '{{ item.Description }}'
      Type: '{{ item.Type }}'
      Vendor: '{{ item.Vendor }}'
      Model: '{{ item.Model }}'
      SerialNumber: '{{ item.SerialNumber }}'
      Location: '{{ item.Location }}'
      SiteId: '{{ item.SiteId }}'
      CreatedAt: '{{ item.CreatedAt }}'
      State: '{{ item.State }}'
      Tags: '{{ item.Tags }}'
- discovery_id: aws.networkmanager.getDirectConnectGatewayAttachment
  calls:
  - action: getDirectConnectGatewayAttachment
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.DirectConnectGatewayAttachment }}'
    item:
      Attachment: '{{ item.Attachment }}'
      DirectConnectGatewayArn: '{{ item.DirectConnectGatewayArn }}'
- discovery_id: aws.networkmanager.getLinkAssociations
  calls:
  - action: getLinkAssociations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.LinkAssociations }}'
    item:
      GlobalNetworkId: '{{ item.GlobalNetworkId }}'
      DeviceId: '{{ item.DeviceId }}'
      LinkId: '{{ item.LinkId }}'
      LinkAssociationState: '{{ item.LinkAssociationState }}'
- discovery_id: aws.networkmanager.getLinks
  calls:
  - action: getLinks
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Links }}'
    item:
      LinkId: '{{ item.LinkId }}'
      LinkArn: '{{ item.LinkArn }}'
      GlobalNetworkId: '{{ item.GlobalNetworkId }}'
      SiteId: '{{ item.SiteId }}'
      Description: '{{ item.Description }}'
      Type: '{{ item.Type }}'
      Bandwidth: '{{ item.Bandwidth }}'
      Provider: '{{ item.Provider }}'
      CreatedAt: '{{ item.CreatedAt }}'
      State: '{{ item.State }}'
      Tags: '{{ item.Tags }}'
- discovery_id: aws.networkmanager.getNetworkResourceCounts
  calls:
  - action: getNetworkResourceCounts
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.NetworkResourceCounts }}'
    item:
      ResourceType: '{{ item.ResourceType }}'
      Count: '{{ item.Count }}'
- discovery_id: aws.networkmanager.getNetworkResourceRelationships
  calls:
  - action: getNetworkResourceRelationships
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Relationships }}'
    item:
      From: '{{ item.From }}'
      To: '{{ item.To }}'
- discovery_id: aws.networkmanager.getNetworkResources
  calls:
  - action: getNetworkResources
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.NetworkResources }}'
    item:
      RegisteredGatewayArn: '{{ item.RegisteredGatewayArn }}'
      CoreNetworkId: '{{ item.CoreNetworkId }}'
      AwsRegion: '{{ item.AwsRegion }}'
      AccountId: '{{ item.AccountId }}'
      ResourceType: '{{ item.ResourceType }}'
      ResourceId: '{{ item.ResourceId }}'
      ResourceArn: '{{ item.ResourceArn }}'
      Definition: '{{ item.Definition }}'
      DefinitionTimestamp: '{{ item.DefinitionTimestamp }}'
      Tags: '{{ item.Tags }}'
      Metadata: '{{ item.Metadata }}'
- discovery_id: aws.networkmanager.getNetworkRoutes
  calls:
  - action: getNetworkRoutes
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.NetworkRoutes }}'
    item:
      DestinationCidrBlock: '{{ item.DestinationCidrBlock }}'
      Destinations: '{{ item.Destinations }}'
      PrefixListId: '{{ item.PrefixListId }}'
      State: '{{ item.State }}'
      Type: '{{ item.Type }}'
- discovery_id: aws.networkmanager.getNetworkTelemetry
  calls:
  - action: getNetworkTelemetry
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.NetworkTelemetry }}'
    item:
      RegisteredGatewayArn: '{{ item.RegisteredGatewayArn }}'
      CoreNetworkId: '{{ item.CoreNetworkId }}'
      AwsRegion: '{{ item.AwsRegion }}'
      AccountId: '{{ item.AccountId }}'
      ResourceType: '{{ item.ResourceType }}'
      ResourceId: '{{ item.ResourceId }}'
      ResourceArn: '{{ item.ResourceArn }}'
      Address: '{{ item.Address }}'
      Health: '{{ item.Health }}'
- discovery_id: aws.networkmanager.getResourcePolicy
  calls:
  - action: getResourcePolicy
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.PolicyDocument }}'
- discovery_id: aws.networkmanager.getRouteAnalysis
  calls:
  - action: getRouteAnalysis
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.RouteAnalysis }}'
    item:
      GlobalNetworkId: '{{ item.GlobalNetworkId }}'
      OwnerAccountId: '{{ item.OwnerAccountId }}'
      RouteAnalysisId: '{{ item.RouteAnalysisId }}'
      StartTimestamp: '{{ item.StartTimestamp }}'
      Status: '{{ item.Status }}'
      Source: '{{ item.Source }}'
      Destination: '{{ item.Destination }}'
      IncludeReturnPath: '{{ item.IncludeReturnPath }}'
      UseMiddleboxes: '{{ item.UseMiddleboxes }}'
      ForwardPath: '{{ item.ForwardPath }}'
      ReturnPath: '{{ item.ReturnPath }}'
- discovery_id: aws.networkmanager.getSiteToSiteVpnAttachment
  calls:
  - action: getSiteToSiteVpnAttachment
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.SiteToSiteVpnAttachment }}'
    item:
      Attachment: '{{ item.Attachment }}'
      VpnConnectionArn: '{{ item.VpnConnectionArn }}'
- discovery_id: aws.networkmanager.getSites
  calls:
  - action: getSites
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Sites }}'
    item:
      SiteId: '{{ item.SiteId }}'
      SiteArn: '{{ item.SiteArn }}'
      GlobalNetworkId: '{{ item.GlobalNetworkId }}'
      Description: '{{ item.Description }}'
      Location: '{{ item.Location }}'
      CreatedAt: '{{ item.CreatedAt }}'
      State: '{{ item.State }}'
      Tags: '{{ item.Tags }}'
- discovery_id: aws.networkmanager.getTransitGatewayConnectPeerAssociations
  calls:
  - action: getTransitGatewayConnectPeerAssociations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.TransitGatewayConnectPeerAssociations }}'
    item:
      TransitGatewayConnectPeerArn: '{{ item.TransitGatewayConnectPeerArn }}'
      GlobalNetworkId: '{{ item.GlobalNetworkId }}'
      DeviceId: '{{ item.DeviceId }}'
      LinkId: '{{ item.LinkId }}'
      State: '{{ item.State }}'
- discovery_id: aws.networkmanager.getTransitGatewayPeering
  calls:
  - action: getTransitGatewayPeering
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.TransitGatewayPeering }}'
    item:
      Peering: '{{ item.Peering }}'
      TransitGatewayArn: '{{ item.TransitGatewayArn }}'
      TransitGatewayPeeringAttachmentId: '{{ item.TransitGatewayPeeringAttachmentId
        }}'
- discovery_id: aws.networkmanager.getTransitGatewayRegistrations
  calls:
  - action: getTransitGatewayRegistrations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.TransitGatewayRegistrations }}'
    item:
      GlobalNetworkId: '{{ item.GlobalNetworkId }}'
      TransitGatewayArn: '{{ item.TransitGatewayArn }}'
      State: '{{ item.State }}'
- discovery_id: aws.networkmanager.getTransitGatewayRouteTableAttachment
  calls:
  - action: getTransitGatewayRouteTableAttachment
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.TransitGatewayRouteTableAttachment }}'
    item:
      Attachment: '{{ item.Attachment }}'
      PeeringId: '{{ item.PeeringId }}'
      TransitGatewayRouteTableArn: '{{ item.TransitGatewayRouteTableArn }}'
- discovery_id: aws.networkmanager.getVpcAttachment
  calls:
  - action: getVpcAttachment
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.VpcAttachment }}'
    item:
      Attachment: '{{ item.Attachment }}'
      SubnetArns: '{{ item.SubnetArns }}'
      Options: '{{ item.Options }}'
- discovery_id: aws.networkmanager.listAttachmentRoutingPolicyAssociations
  calls:
  - action: listAttachmentRoutingPolicyAssociations
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.AttachmentRoutingPolicyAssociations }}'
    item:
      AttachmentId: '{{ item.AttachmentId }}'
      PendingRoutingPolicies: '{{ item.PendingRoutingPolicies }}'
      AssociatedRoutingPolicies: '{{ item.AssociatedRoutingPolicies }}'
      RoutingPolicyLabel: '{{ item.RoutingPolicyLabel }}'
- discovery_id: aws.networkmanager.listCoreNetworkPolicyVersions
  calls:
  - action: listCoreNetworkPolicyVersions
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.CoreNetworkPolicyVersions }}'
    item:
      CoreNetworkId: '{{ item.CoreNetworkId }}'
      PolicyVersionId: '{{ item.PolicyVersionId }}'
      Alias: '{{ item.Alias }}'
      Description: '{{ item.Description }}'
      CreatedAt: '{{ item.CreatedAt }}'
      ChangeSetState: '{{ item.ChangeSetState }}'
- discovery_id: aws.networkmanager.listCoreNetworkPrefixListAssociations
  calls:
  - action: listCoreNetworkPrefixListAssociations
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.PrefixListAssociations }}'
    item:
      CoreNetworkId: '{{ item.CoreNetworkId }}'
      PrefixListArn: '{{ item.PrefixListArn }}'
      PrefixListAlias: '{{ item.PrefixListAlias }}'
- discovery_id: aws.networkmanager.listCoreNetworkRoutingInformation
  calls:
  - action: listCoreNetworkRoutingInformation
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.CoreNetworkRoutingInformation }}'
    item:
      Prefix: '{{ item.Prefix }}'
      NextHop: '{{ item.NextHop }}'
      LocalPreference: '{{ item.LocalPreference }}'
      Med: '{{ item.Med }}'
      AsPath: '{{ item.AsPath }}'
      Communities: '{{ item.Communities }}'
- discovery_id: aws.networkmanager.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.TagList }}'
    item:
      Key: '{{ item.Key }}'
      Value: '{{ item.Value }}'
checks: []
