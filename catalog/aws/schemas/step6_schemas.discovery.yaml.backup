version: '1.0'
provider: aws
service: schemas
services:
  client: schemas
  module: boto3.client
discovery:
- discovery_id: aws.schemas.getResourcePolicy
  calls:
  - action: getResourcePolicy
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Policy }}'
- discovery_id: aws.schemas.listDiscoverers
  calls:
  - action: listDiscoverers
    save_as: response
    on_error: continue
    params:
      Limit: 1000
  emit:
    as: item
    items_for: '{{ response.Discoverers }}'
    item:
      DiscovererArn: '{{ item.DiscovererArn }}'
      DiscovererId: '{{ item.DiscovererId }}'
      SourceArn: '{{ item.SourceArn }}'
      State: '{{ item.State }}'
      CrossAccount: '{{ item.CrossAccount }}'
      Tags: '{{ item.Tags }}'
- discovery_id: aws.schemas.listRegistries
  calls:
  - action: listRegistries
    save_as: response
    on_error: continue
    params:
      Limit: 1000
  emit:
    as: item
    items_for: '{{ response.Registries }}'
    item:
      RegistryArn: '{{ item.RegistryArn }}'
      RegistryName: '{{ item.RegistryName }}'
      Tags: '{{ item.Tags }}'
- discovery_id: aws.schemas.describeCodeBinding
  calls:
  - action: describeCodeBinding
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.CreationDate }}'
- discovery_id: aws.schemas.describeDiscoverer
  calls:
  - action: describeDiscoverer
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Description }}'
- discovery_id: aws.schemas.describeRegistry
  calls:
  - action: describeRegistry
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Description }}'
- discovery_id: aws.schemas.describeSchema
  calls:
  - action: describeSchema
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Content }}'
- discovery_id: aws.schemas.getCodeBindingSource
  calls:
  - action: getCodeBindingSource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Body }}'
- discovery_id: aws.schemas.getDiscoveredSchema
  calls:
  - action: getDiscoveredSchema
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Content }}'
- discovery_id: aws.schemas.listSchemaVersions
  calls:
  - action: listSchemaVersions
    save_as: response
    on_error: continue
    params:
      Limit: 1000
  emit:
    as: item
    items_for: '{{ response.SchemaVersions }}'
    item:
      SchemaArn: '{{ item.SchemaArn }}'
      SchemaName: '{{ item.SchemaName }}'
      SchemaVersion: '{{ item.SchemaVersion }}'
      Type: '{{ item.Type }}'
- discovery_id: aws.schemas.listSchemas
  calls:
  - action: listSchemas
    save_as: response
    on_error: continue
    params:
      Limit: 1000
  emit:
    as: item
    items_for: '{{ response.Schemas }}'
    item:
      LastModified: '{{ item.LastModified }}'
      SchemaArn: '{{ item.SchemaArn }}'
      SchemaName: '{{ item.SchemaName }}'
      Tags: '{{ item.Tags }}'
      VersionCount: '{{ item.VersionCount }}'
- discovery_id: aws.schemas.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Tags }}'
- discovery_id: aws.schemas.searchSchemas
  calls:
  - action: searchSchemas
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Schemas }}'
    item:
      RegistryName: '{{ item.RegistryName }}'
      SchemaArn: '{{ item.SchemaArn }}'
      SchemaName: '{{ item.SchemaName }}'
      SchemaVersions: '{{ item.SchemaVersions }}'
checks: []
