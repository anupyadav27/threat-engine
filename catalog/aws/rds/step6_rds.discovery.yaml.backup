      SupportedEngineModes: '{{ item.SupportedEngineModes }}'
      SupportedFeatureNames: '{{ item.SupportedFeatureNames }}'
      Status: '{{ item.Status }}'
      SupportsParallelQuery: '{{ item.SupportsParallelQuery }}'
      SupportsGlobalDatabases: '{{ item.SupportsGlobalDatabases }}'
      TagList: '{{ item.TagList }}'
      SupportsBabelfish: '{{ item.SupportsBabelfish }}'
      SupportsLimitlessDatabase: '{{ item.SupportsLimitlessDatabase }}'
      SupportsCertificateRotationWithoutRestart: '{{ item.SupportsCertificateRotationWithoutRestart
        }}'
      SupportedCACertificateIdentifiers: '{{ item.SupportedCACertificateIdentifiers
        }}'
      SupportsLocalWriteForwarding: '{{ item.SupportsLocalWriteForwarding }}'
