  emit:
    as: item
    items_for: '{{ response.DBClusters }}'
    item:
      AllocatedStorage: '{{ item.AllocatedStorage }}'
      AvailabilityZones: '{{ item.AvailabilityZones }}'
      BackupRetentionPeriod: '{{ item.BackupRetentionPeriod }}'
      CharacterSetName: '{{ item.CharacterSetName }}'
      DatabaseName: '{{ item.DatabaseName }}'
      DBClusterIdentifier: '{{ item.DBClusterIdentifier }}'
      DBClusterParameterGroup: '{{ item.DBClusterParameterGroup }}'
      DBSubnetGroup: '{{ item.DBSubnetGroup }}'
      Status: '{{ item.Status }}'
      PercentProgress: '{{ item.PercentProgress }}'
      EarliestRestorableTime: '{{ item.EarliestRestorableTime }}'
      Endpoint: '{{ item.Endpoint }}'
      ReaderEndpoint: '{{ item.ReaderEndpoint }}'
      CustomEndpoints: '{{ item.CustomEndpoints }}'
      MultiAZ: '{{ item.MultiAZ }}'
      Engine: '{{ item.Engine }}'
      EngineVersion: '{{ item.EngineVersion }}'
      LatestRestorableTime: '{{ item.LatestRestorableTime }}'
      Port: '{{ item.Port }}'
      MasterUsername: '{{ item.MasterUsername }}'
      DBClusterOptionGroupMemberships: '{{ item.DBClusterOptionGroupMemberships }}'
