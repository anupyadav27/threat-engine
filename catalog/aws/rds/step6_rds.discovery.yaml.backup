version: '1.0'
provider: aws
service: rds
services:
  client: rds
  module: boto3.client
discovery:
- discovery_id: aws.rds.describeAccountAttributes
  calls:
  - action: describeAccountAttributes
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AccountQuotas }}'
    item:
      AccountQuotaName: '{{ item.AccountQuotaName }}'
      Used: '{{ item.Used }}'
      Max: '{{ item.Max }}'
- discovery_id: aws.rds.describeBlueGreenDeployments
  calls:
  - action: describeBlueGreenDeployments
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.BlueGreenDeployments }}'
    item:
      BlueGreenDeploymentIdentifier: '{{ item.BlueGreenDeploymentIdentifier }}'
      BlueGreenDeploymentName: '{{ item.BlueGreenDeploymentName }}'
      Source: '{{ item.Source }}'
      Target: '{{ item.Target }}'
      SwitchoverDetails: '{{ item.SwitchoverDetails }}'
      Tasks: '{{ item.Tasks }}'
      Status: '{{ item.Status }}'
      StatusDetails: '{{ item.StatusDetails }}'
      CreateTime: '{{ item.CreateTime }}'
      DeleteTime: '{{ item.DeleteTime }}'
      TagList: '{{ item.TagList }}'
- discovery_id: aws.rds.describeCertificates
  calls:
  - action: describeCertificates
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Certificates }}'
    item:
      CertificateIdentifier: '{{ item.CertificateIdentifier }}'
      CertificateType: '{{ item.CertificateType }}'
      Thumbprint: '{{ item.Thumbprint }}'
      ValidFrom: '{{ item.ValidFrom }}'
      ValidTill: '{{ item.ValidTill }}'
      CertificateArn: '{{ item.CertificateArn }}'
      CustomerOverride: '{{ item.CustomerOverride }}'
      CustomerOverrideValidTill: '{{ item.CustomerOverrideValidTill }}'
- discovery_id: aws.rds.describeDbClusterAutomatedBackups
  calls:
  - action: describeDbClusterAutomatedBackups
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.DBClusterAutomatedBackups }}'
    item:
      Engine: '{{ item.Engine }}'
      VpcId: '{{ item.VpcId }}'
      DBClusterAutomatedBackupsArn: '{{ item.DBClusterAutomatedBackupsArn }}'
      DBClusterIdentifier: '{{ item.DBClusterIdentifier }}'
      RestoreWindow: '{{ item.RestoreWindow }}'
      MasterUsername: '{{ item.MasterUsername }}'
      DbClusterResourceId: '{{ item.DbClusterResourceId }}'
      Region: '{{ item.Region }}'
      LicenseModel: '{{ item.LicenseModel }}'
      Status: '{{ item.Status }}'
      IAMDatabaseAuthenticationEnabled: '{{ item.IAMDatabaseAuthenticationEnabled
        }}'
      ClusterCreateTime: '{{ item.ClusterCreateTime }}'
      StorageEncrypted: '{{ item.StorageEncrypted }}'
      AllocatedStorage: '{{ item.AllocatedStorage }}'
      EngineVersion: '{{ item.EngineVersion }}'
      DBClusterArn: '{{ item.DBClusterArn }}'
      BackupRetentionPeriod: '{{ item.BackupRetentionPeriod }}'
      EngineMode: '{{ item.EngineMode }}'
      AvailabilityZones: '{{ item.AvailabilityZones }}'
      Port: '{{ item.Port }}'
      KmsKeyId: '{{ item.KmsKeyId }}'
      StorageType: '{{ item.StorageType }}'
      Iops: '{{ item.Iops }}'
      StorageThroughput: '{{ item.StorageThroughput }}'
      AwsBackupRecoveryPointArn: '{{ item.AwsBackupRecoveryPointArn }}'
- discovery_id: aws.rds.describeDbClusterEndpoints
  calls:
  - action: describeDbClusterEndpoints
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.DBClusterEndpoints }}'
    item:
      DBClusterEndpointIdentifier: '{{ item.DBClusterEndpointIdentifier }}'
      DBClusterIdentifier: '{{ item.DBClusterIdentifier }}'
      DBClusterEndpointResourceIdentifier: '{{ item.DBClusterEndpointResourceIdentifier
        }}'
      Endpoint: '{{ item.Endpoint }}'
      Status: '{{ item.Status }}'
      EndpointType: '{{ item.EndpointType }}'
      CustomEndpointType: '{{ item.CustomEndpointType }}'
      StaticMembers: '{{ item.StaticMembers }}'
      ExcludedMembers: '{{ item.ExcludedMembers }}'
      DBClusterEndpointArn: '{{ item.DBClusterEndpointArn }}'
- discovery_id: aws.rds.describeDbClusterParameterGroups
  calls:
  - action: describeDbClusterParameterGroups
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.DBClusterParameterGroups }}'
    item:
      DBClusterParameterGroupName: '{{ item.DBClusterParameterGroupName }}'
      DBParameterGroupFamily: '{{ item.DBParameterGroupFamily }}'
      Description: '{{ item.Description }}'
      DBClusterParameterGroupArn: '{{ item.DBClusterParameterGroupArn }}'
- discovery_id: aws.rds.describeDbClusterSnapshots
  calls:
  - action: describeDbClusterSnapshots
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.DBClusterSnapshots }}'
    item:
      AvailabilityZones: '{{ item.AvailabilityZones }}'
      DBClusterSnapshotIdentifier: '{{ item.DBClusterSnapshotIdentifier }}'
      DBClusterIdentifier: '{{ item.DBClusterIdentifier }}'
      SnapshotCreateTime: '{{ item.SnapshotCreateTime }}'
      Engine: '{{ item.Engine }}'
      EngineMode: '{{ item.EngineMode }}'
      AllocatedStorage: '{{ item.AllocatedStorage }}'
      Status: '{{ item.Status }}'
      Port: '{{ item.Port }}'
      VpcId: '{{ item.VpcId }}'
      ClusterCreateTime: '{{ item.ClusterCreateTime }}'
      MasterUsername: '{{ item.MasterUsername }}'
      EngineVersion: '{{ item.EngineVersion }}'
      LicenseModel: '{{ item.LicenseModel }}'
      SnapshotType: '{{ item.SnapshotType }}'
      PercentProgress: '{{ item.PercentProgress }}'
      StorageEncrypted: '{{ item.StorageEncrypted }}'
      KmsKeyId: '{{ item.KmsKeyId }}'
      DBClusterSnapshotArn: '{{ item.DBClusterSnapshotArn }}'
      SourceDBClusterSnapshotArn: '{{ item.SourceDBClusterSnapshotArn }}'
      IAMDatabaseAuthenticationEnabled: '{{ item.IAMDatabaseAuthenticationEnabled
        }}'
      TagList: '{{ item.TagList }}'
      StorageType: '{{ item.StorageType }}'
      StorageThroughput: '{{ item.StorageThroughput }}'
      DbClusterResourceId: '{{ item.DbClusterResourceId }}'
      DBSystemId: '{{ item.DBSystemId }}'
- discovery_id: aws.rds.describeDbClusters
  calls:
