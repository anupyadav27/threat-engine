version: '1.0'
provider: aws
service: autoscaling-plans
services:
  client: autoscaling-plans
  module: boto3.client
discovery:
- discovery_id: aws.autoscaling-plans.describeScalingPlans
  calls:
  - action: describeScalingPlans
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ScalingPlans }}'
    item:
      ScalingPlanName: '{{ item.ScalingPlanName }}'
      ScalingPlanVersion: '{{ item.ScalingPlanVersion }}'
      ApplicationSource: '{{ item.ApplicationSource }}'
      ScalingInstructions: '{{ item.ScalingInstructions }}'
      StatusCode: '{{ item.StatusCode }}'
      StatusMessage: '{{ item.StatusMessage }}'
      StatusStartTime: '{{ item.StatusStartTime }}'
      CreationTime: '{{ item.CreationTime }}'
- discovery_id: aws.autoscaling-plans.describeScalingPlanResources
  calls:
  - action: describeScalingPlanResources
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ScalingPlanResources }}'
    item:
      ScalingPlanName: '{{ item.ScalingPlanName }}'
      ScalingPlanVersion: '{{ item.ScalingPlanVersion }}'
      ServiceNamespace: '{{ item.ServiceNamespace }}'
      ResourceId: '{{ item.ResourceId }}'
      ScalableDimension: '{{ item.ScalableDimension }}'
      ScalingPolicies: '{{ item.ScalingPolicies }}'
      ScalingStatusCode: '{{ item.ScalingStatusCode }}'
      ScalingStatusMessage: '{{ item.ScalingStatusMessage }}'
- discovery_id: aws.autoscaling-plans.getScalingPlanResourceForecastData
  calls:
  - action: getScalingPlanResourceForecastData
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Datapoints }}'
    item:
      Timestamp: '{{ item.Timestamp }}'
      Value: '{{ item.Value }}'
checks: []
