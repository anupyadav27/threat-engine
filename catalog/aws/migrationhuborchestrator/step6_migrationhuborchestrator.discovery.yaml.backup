version: '1.0'
provider: aws
service: migrationhuborchestrator
services:
  client: migrationhuborchestrator
  module: boto3.client
discovery:
- discovery_id: aws.migrationhuborchestrator.listPlugins
  calls:
  - action: listPlugins
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.plugins }}'
    item:
      pluginId: '{{ item.pluginId }}'
      hostname: '{{ item.hostname }}'
      status: '{{ item.status }}'
      ipAddress: '{{ item.ipAddress }}'
      version: '{{ item.version }}'
      registeredTime: '{{ item.registeredTime }}'
- discovery_id: aws.migrationhuborchestrator.listTemplates
  calls:
  - action: listTemplates
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.templateSummary }}'
    item:
      id: '{{ item.id }}'
      name: '{{ item.name }}'
      arn: '{{ item.arn }}'
      description: '{{ item.description }}'
- discovery_id: aws.migrationhuborchestrator.listWorkflows
  calls:
  - action: listWorkflows
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.migrationWorkflowSummary }}'
    item:
      id: '{{ item.id }}'
      name: '{{ item.name }}'
      templateId: '{{ item.templateId }}'
      adsApplicationConfigurationName: '{{ item.adsApplicationConfigurationName }}'
      status: '{{ item.status }}'
      creationTime: '{{ item.creationTime }}'
      endTime: '{{ item.endTime }}'
      statusMessage: '{{ item.statusMessage }}'
      completedSteps: '{{ item.completedSteps }}'
      totalSteps: '{{ item.totalSteps }}'
- discovery_id: aws.migrationhuborchestrator.getTemplate
  calls:
  - action: getTemplate
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.inputs }}'
    item:
      inputName: '{{ item.inputName }}'
      dataType: '{{ item.dataType }}'
      required: '{{ item.required }}'
- discovery_id: aws.migrationhuborchestrator.getTemplateStep
  calls:
  - action: getTemplateStep
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.previous }}'
- discovery_id: aws.migrationhuborchestrator.getTemplateStepGroup
  calls:
  - action: getTemplateStepGroup
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tools }}'
    item:
      name: '{{ item.name }}'
      url: '{{ item.url }}'
- discovery_id: aws.migrationhuborchestrator.getWorkflow
  calls:
  - action: getWorkflow
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tools }}'
    item:
      name: '{{ item.name }}'
      url: '{{ item.url }}'
- discovery_id: aws.migrationhuborchestrator.getWorkflowStep
  calls:
  - action: getWorkflowStep
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.stepTarget }}'
- discovery_id: aws.migrationhuborchestrator.getWorkflowStepGroup
  calls:
  - action: getWorkflowStepGroup
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tools }}'
    item:
      name: '{{ item.name }}'
      url: '{{ item.url }}'
- discovery_id: aws.migrationhuborchestrator.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tags }}'
- discovery_id: aws.migrationhuborchestrator.listTemplateStepGroups
  calls:
  - action: listTemplateStepGroups
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.templateStepGroupSummary }}'
    item:
      id: '{{ item.id }}'
      name: '{{ item.name }}'
      previous: '{{ item.previous }}'
      next: '{{ item.next }}'
- discovery_id: aws.migrationhuborchestrator.listTemplateSteps
  calls:
  - action: listTemplateSteps
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.templateStepSummaryList }}'
    item:
      id: '{{ item.id }}'
      stepGroupId: '{{ item.stepGroupId }}'
      templateId: '{{ item.templateId }}'
      name: '{{ item.name }}'
      stepActionType: '{{ item.stepActionType }}'
      targetType: '{{ item.targetType }}'
      owner: '{{ item.owner }}'
      previous: '{{ item.previous }}'
      next: '{{ item.next }}'
- discovery_id: aws.migrationhuborchestrator.listWorkflowStepGroups
  calls:
  - action: listWorkflowStepGroups
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.workflowStepGroupsSummary }}'
    item:
      id: '{{ item.id }}'
      name: '{{ item.name }}'
      owner: '{{ item.owner }}'
      status: '{{ item.status }}'
      previous: '{{ item.previous }}'
      next: '{{ item.next }}'
- discovery_id: aws.migrationhuborchestrator.listWorkflowSteps
  calls:
  - action: listWorkflowSteps
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.workflowStepsSummary }}'
    item:
      stepId: '{{ item.stepId }}'
      name: '{{ item.name }}'
      stepActionType: '{{ item.stepActionType }}'
      owner: '{{ item.owner }}'
      previous: '{{ item.previous }}'
      next: '{{ item.next }}'
      status: '{{ item.status }}'
      statusMessage: '{{ item.statusMessage }}'
      noOfSrvCompleted: '{{ item.noOfSrvCompleted }}'
      noOfSrvFailed: '{{ item.noOfSrvFailed }}'
      totalNoOfSrv: '{{ item.totalNoOfSrv }}'
      description: '{{ item.description }}'
      scriptLocation: '{{ item.scriptLocation }}'
checks: []
