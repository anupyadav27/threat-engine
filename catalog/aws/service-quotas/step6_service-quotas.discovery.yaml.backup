version: '1.0'
provider: aws
service: service-quotas
services:
  client: service-quotas
  module: boto3.client
discovery:
- discovery_id: aws.service-quotas.getAssociationForServiceQuotaTemplate
  calls:
  - action: getAssociationForServiceQuotaTemplate
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ServiceQuotaTemplateAssociationStatus }}'
- discovery_id: aws.service-quotas.getAutoManagementConfiguration
  calls:
  - action: getAutoManagementConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.OptInLevel }}'
- discovery_id: aws.service-quotas.listRequestedServiceQuotaChangeHistory
  calls:
  - action: listRequestedServiceQuotaChangeHistory
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.RequestedQuotas }}'
    item:
      Id: '{{ item.Id }}'
      CaseId: '{{ item.CaseId }}'
      ServiceCode: '{{ item.ServiceCode }}'
      ServiceName: '{{ item.ServiceName }}'
      QuotaCode: '{{ item.QuotaCode }}'
      QuotaName: '{{ item.QuotaName }}'
      DesiredValue: '{{ item.DesiredValue }}'
      Status: '{{ item.Status }}'
      Created: '{{ item.Created }}'
      LastUpdated: '{{ item.LastUpdated }}'
      Requester: '{{ item.Requester }}'
      QuotaArn: '{{ item.QuotaArn }}'
      GlobalQuota: '{{ item.GlobalQuota }}'
      Unit: '{{ item.Unit }}'
      QuotaRequestedAtLevel: '{{ item.QuotaRequestedAtLevel }}'
      QuotaContext: '{{ item.QuotaContext }}'
- discovery_id: aws.service-quotas.listServiceQuotaIncreaseRequestsInTemplate
  calls:
  - action: listServiceQuotaIncreaseRequestsInTemplate
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.ServiceQuotaIncreaseRequestInTemplateList }}'
    item:
      ServiceCode: '{{ item.ServiceCode }}'
      ServiceName: '{{ item.ServiceName }}'
      QuotaCode: '{{ item.QuotaCode }}'
      QuotaName: '{{ item.QuotaName }}'
      DesiredValue: '{{ item.DesiredValue }}'
      AwsRegion: '{{ item.AwsRegion }}'
      Unit: '{{ item.Unit }}'
      GlobalQuota: '{{ item.GlobalQuota }}'
- discovery_id: aws.service-quotas.listServices
  calls:
  - action: listServices
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Services }}'
    item:
      ServiceCode: '{{ item.ServiceCode }}'
      ServiceName: '{{ item.ServiceName }}'
- discovery_id: aws.service-quotas.getAwsDefaultServiceQuota
  calls:
  - action: getAwsDefaultServiceQuota
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Quota }}'
    item:
      ServiceCode: '{{ item.ServiceCode }}'
      ServiceName: '{{ item.ServiceName }}'
      QuotaArn: '{{ item.QuotaArn }}'
      QuotaCode: '{{ item.QuotaCode }}'
      QuotaName: '{{ item.QuotaName }}'
      Value: '{{ item.Value }}'
      Unit: '{{ item.Unit }}'
      Adjustable: '{{ item.Adjustable }}'
      GlobalQuota: '{{ item.GlobalQuota }}'
      UsageMetric: '{{ item.UsageMetric }}'
      Period: '{{ item.Period }}'
      ErrorReason: '{{ item.ErrorReason }}'
      QuotaAppliedAtLevel: '{{ item.QuotaAppliedAtLevel }}'
      QuotaContext: '{{ item.QuotaContext }}'
      Description: '{{ item.Description }}'
- discovery_id: aws.service-quotas.getRequestedServiceQuotaChange
  calls:
  - action: getRequestedServiceQuotaChange
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.RequestedQuota }}'
    item:
      Id: '{{ item.Id }}'
      CaseId: '{{ item.CaseId }}'
      ServiceCode: '{{ item.ServiceCode }}'
      ServiceName: '{{ item.ServiceName }}'
      QuotaCode: '{{ item.QuotaCode }}'
      QuotaName: '{{ item.QuotaName }}'
      DesiredValue: '{{ item.DesiredValue }}'
      Status: '{{ item.Status }}'
      Created: '{{ item.Created }}'
      LastUpdated: '{{ item.LastUpdated }}'
      Requester: '{{ item.Requester }}'
      QuotaArn: '{{ item.QuotaArn }}'
      GlobalQuota: '{{ item.GlobalQuota }}'
      Unit: '{{ item.Unit }}'
      QuotaRequestedAtLevel: '{{ item.QuotaRequestedAtLevel }}'
      QuotaContext: '{{ item.QuotaContext }}'
- discovery_id: aws.service-quotas.getServiceQuota
  calls:
  - action: getServiceQuota
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Quota }}'
    item:
      ServiceCode: '{{ item.ServiceCode }}'
      ServiceName: '{{ item.ServiceName }}'
      QuotaArn: '{{ item.QuotaArn }}'
      QuotaCode: '{{ item.QuotaCode }}'
      QuotaName: '{{ item.QuotaName }}'
      Value: '{{ item.Value }}'
      Unit: '{{ item.Unit }}'
      Adjustable: '{{ item.Adjustable }}'
      GlobalQuota: '{{ item.GlobalQuota }}'
      UsageMetric: '{{ item.UsageMetric }}'
      Period: '{{ item.Period }}'
      ErrorReason: '{{ item.ErrorReason }}'
      QuotaAppliedAtLevel: '{{ item.QuotaAppliedAtLevel }}'
      QuotaContext: '{{ item.QuotaContext }}'
      Description: '{{ item.Description }}'
- discovery_id: aws.service-quotas.getServiceQuotaIncreaseRequestFromTemplate
  calls:
  - action: getServiceQuotaIncreaseRequestFromTemplate
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ServiceQuotaIncreaseRequestInTemplate }}'
    item:
      ServiceCode: '{{ item.ServiceCode }}'
      ServiceName: '{{ item.ServiceName }}'
      QuotaCode: '{{ item.QuotaCode }}'
      QuotaName: '{{ item.QuotaName }}'
      DesiredValue: '{{ item.DesiredValue }}'
      AwsRegion: '{{ item.AwsRegion }}'
      Unit: '{{ item.Unit }}'
      GlobalQuota: '{{ item.GlobalQuota }}'
- discovery_id: aws.service-quotas.listAwsDefaultServiceQuotas
  calls:
  - action: listAwsDefaultServiceQuotas
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Quotas }}'
    item:
      ServiceCode: '{{ item.ServiceCode }}'
      ServiceName: '{{ item.ServiceName }}'
      QuotaArn: '{{ item.QuotaArn }}'
      QuotaCode: '{{ item.QuotaCode }}'
      QuotaName: '{{ item.QuotaName }}'
      Value: '{{ item.Value }}'
      Unit: '{{ item.Unit }}'
      Adjustable: '{{ item.Adjustable }}'
      GlobalQuota: '{{ item.GlobalQuota }}'
      UsageMetric: '{{ item.UsageMetric }}'
      Period: '{{ item.Period }}'
      ErrorReason: '{{ item.ErrorReason }}'
      QuotaAppliedAtLevel: '{{ item.QuotaAppliedAtLevel }}'
      QuotaContext: '{{ item.QuotaContext }}'
      Description: '{{ item.Description }}'
- discovery_id: aws.service-quotas.listRequestedServiceQuotaChangeHistoryByQuota
  calls:
  - action: listRequestedServiceQuotaChangeHistoryByQuota
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.RequestedQuotas }}'
    item:
      Id: '{{ item.Id }}'
      CaseId: '{{ item.CaseId }}'
      ServiceCode: '{{ item.ServiceCode }}'
      ServiceName: '{{ item.ServiceName }}'
      QuotaCode: '{{ item.QuotaCode }}'
      QuotaName: '{{ item.QuotaName }}'
      DesiredValue: '{{ item.DesiredValue }}'
      Status: '{{ item.Status }}'
      Created: '{{ item.Created }}'
      LastUpdated: '{{ item.LastUpdated }}'
      Requester: '{{ item.Requester }}'
      QuotaArn: '{{ item.QuotaArn }}'
      GlobalQuota: '{{ item.GlobalQuota }}'
      Unit: '{{ item.Unit }}'
      QuotaRequestedAtLevel: '{{ item.QuotaRequestedAtLevel }}'
      QuotaContext: '{{ item.QuotaContext }}'
- discovery_id: aws.service-quotas.listServiceQuotas
  calls:
  - action: listServiceQuotas
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Quotas }}'
    item:
      ServiceCode: '{{ item.ServiceCode }}'
      ServiceName: '{{ item.ServiceName }}'
      QuotaArn: '{{ item.QuotaArn }}'
      QuotaCode: '{{ item.QuotaCode }}'
      QuotaName: '{{ item.QuotaName }}'
      Value: '{{ item.Value }}'
      Unit: '{{ item.Unit }}'
      Adjustable: '{{ item.Adjustable }}'
      GlobalQuota: '{{ item.GlobalQuota }}'
      UsageMetric: '{{ item.UsageMetric }}'
      Period: '{{ item.Period }}'
      ErrorReason: '{{ item.ErrorReason }}'
      QuotaAppliedAtLevel: '{{ item.QuotaAppliedAtLevel }}'
      QuotaContext: '{{ item.QuotaContext }}'
      Description: '{{ item.Description }}'
- discovery_id: aws.service-quotas.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Tags }}'
    item:
      Key: '{{ item.Key }}'
      Value: '{{ item.Value }}'
checks: []
