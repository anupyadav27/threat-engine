version: '1.0'
provider: aws
service: wisdom
services:
  client: wisdom
  module: boto3.client
discovery:
- discovery_id: aws.wisdom.listAssistants
  calls:
  - action: listAssistants
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.assistantSummaries }}'
    item:
      assistantArn: '{{ item.assistantArn }}'
      assistantId: '{{ item.assistantId }}'
      description: '{{ item.description }}'
      integrationConfiguration: '{{ item.integrationConfiguration }}'
      name: '{{ item.name }}'
      serverSideEncryptionConfiguration: '{{ item.serverSideEncryptionConfiguration
        }}'
      status: '{{ item.status }}'
      tags: '{{ item.tags }}'
      type: '{{ item.type }}'
- discovery_id: aws.wisdom.listKnowledgeBases
  calls:
  - action: listKnowledgeBases
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.knowledgeBaseSummaries }}'
    item:
      description: '{{ item.description }}'
      knowledgeBaseArn: '{{ item.knowledgeBaseArn }}'
      knowledgeBaseId: '{{ item.knowledgeBaseId }}'
      knowledgeBaseType: '{{ item.knowledgeBaseType }}'
      name: '{{ item.name }}'
      renderingConfiguration: '{{ item.renderingConfiguration }}'
      serverSideEncryptionConfiguration: '{{ item.serverSideEncryptionConfiguration
        }}'
      sourceConfiguration: '{{ item.sourceConfiguration }}'
      status: '{{ item.status }}'
      tags: '{{ item.tags }}'
- discovery_id: aws.wisdom.getAssistant
  calls:
  - action: getAssistant
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.assistant }}'
    item:
      assistantArn: '{{ item.assistantArn }}'
      assistantId: '{{ item.assistantId }}'
      description: '{{ item.description }}'
      integrationConfiguration: '{{ item.integrationConfiguration }}'
      name: '{{ item.name }}'
      serverSideEncryptionConfiguration: '{{ item.serverSideEncryptionConfiguration
        }}'
      status: '{{ item.status }}'
      tags: '{{ item.tags }}'
      type: '{{ item.type }}'
- discovery_id: aws.wisdom.getAssistantAssociation
  calls:
  - action: getAssistantAssociation
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.assistantAssociation }}'
    item:
      assistantArn: '{{ item.assistantArn }}'
      assistantAssociationArn: '{{ item.assistantAssociationArn }}'
      assistantAssociationId: '{{ item.assistantAssociationId }}'
      assistantId: '{{ item.assistantId }}'
      associationData: '{{ item.associationData }}'
      associationType: '{{ item.associationType }}'
      tags: '{{ item.tags }}'
- discovery_id: aws.wisdom.getContent
  calls:
  - action: getContent
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.content }}'
    item:
      contentArn: '{{ item.contentArn }}'
      contentId: '{{ item.contentId }}'
      contentType: '{{ item.contentType }}'
      knowledgeBaseArn: '{{ item.knowledgeBaseArn }}'
      knowledgeBaseId: '{{ item.knowledgeBaseId }}'
      linkOutUri: '{{ item.linkOutUri }}'
      metadata: '{{ item.metadata }}'
      name: '{{ item.name }}'
      revisionId: '{{ item.revisionId }}'
      status: '{{ item.status }}'
      tags: '{{ item.tags }}'
      title: '{{ item.title }}'
      url: '{{ item.url }}'
      urlExpiry: '{{ item.urlExpiry }}'
- discovery_id: aws.wisdom.getContentSummary
  calls:
  - action: getContentSummary
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.contentSummary }}'
    item:
      contentArn: '{{ item.contentArn }}'
      contentId: '{{ item.contentId }}'
      contentType: '{{ item.contentType }}'
      knowledgeBaseArn: '{{ item.knowledgeBaseArn }}'
      knowledgeBaseId: '{{ item.knowledgeBaseId }}'
      metadata: '{{ item.metadata }}'
      name: '{{ item.name }}'
      revisionId: '{{ item.revisionId }}'
      status: '{{ item.status }}'
      tags: '{{ item.tags }}'
      title: '{{ item.title }}'
- discovery_id: aws.wisdom.getImportJob
  calls:
  - action: getImportJob
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.importJob }}'
    item:
      createdTime: '{{ item.createdTime }}'
      externalSourceConfiguration: '{{ item.externalSourceConfiguration }}'
      failedRecordReport: '{{ item.failedRecordReport }}'
      importJobId: '{{ item.importJobId }}'
      importJobType: '{{ item.importJobType }}'
      knowledgeBaseArn: '{{ item.knowledgeBaseArn }}'
      knowledgeBaseId: '{{ item.knowledgeBaseId }}'
      lastModifiedTime: '{{ item.lastModifiedTime }}'
      metadata: '{{ item.metadata }}'
      status: '{{ item.status }}'
      uploadId: '{{ item.uploadId }}'
      url: '{{ item.url }}'
      urlExpiry: '{{ item.urlExpiry }}'
- discovery_id: aws.wisdom.getKnowledgeBase
  calls:
  - action: getKnowledgeBase
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.knowledgeBase }}'
    item:
      description: '{{ item.description }}'
      knowledgeBaseArn: '{{ item.knowledgeBaseArn }}'
      knowledgeBaseId: '{{ item.knowledgeBaseId }}'
      knowledgeBaseType: '{{ item.knowledgeBaseType }}'
      lastContentModificationTime: '{{ item.lastContentModificationTime }}'
      name: '{{ item.name }}'
      renderingConfiguration: '{{ item.renderingConfiguration }}'
      serverSideEncryptionConfiguration: '{{ item.serverSideEncryptionConfiguration
        }}'
      sourceConfiguration: '{{ item.sourceConfiguration }}'
      status: '{{ item.status }}'
      tags: '{{ item.tags }}'
- discovery_id: aws.wisdom.getQuickResponse
  calls:
  - action: getQuickResponse
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.quickResponse }}'
    item:
      channels: '{{ item.channels }}'
      contentType: '{{ item.contentType }}'
      contents: '{{ item.contents }}'
      createdTime: '{{ item.createdTime }}'
      description: '{{ item.description }}'
      groupingConfiguration: '{{ item.groupingConfiguration }}'
      isActive: '{{ item.isActive }}'
      knowledgeBaseArn: '{{ item.knowledgeBaseArn }}'
      knowledgeBaseId: '{{ item.knowledgeBaseId }}'
      language: '{{ item.language }}'
      lastModifiedBy: '{{ item.lastModifiedBy }}'
      lastModifiedTime: '{{ item.lastModifiedTime }}'
      name: '{{ item.name }}'
      quickResponseArn: '{{ item.quickResponseArn }}'
      quickResponseId: '{{ item.quickResponseId }}'
      shortcutKey: '{{ item.shortcutKey }}'
      status: '{{ item.status }}'
      tags: '{{ item.tags }}'
- discovery_id: aws.wisdom.getRecommendations
  calls:
  - action: getRecommendations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.recommendations }}'
    item:
      document: '{{ item.document }}'
      recommendationId: '{{ item.recommendationId }}'
      relevanceLevel: '{{ item.relevanceLevel }}'
      relevanceScore: '{{ item.relevanceScore }}'
      type: '{{ item.type }}'
- discovery_id: aws.wisdom.getSession
  calls:
  - action: getSession
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.session }}'
    item:
      description: '{{ item.description }}'
      integrationConfiguration: '{{ item.integrationConfiguration }}'
      name: '{{ item.name }}'
      sessionArn: '{{ item.sessionArn }}'
      sessionId: '{{ item.sessionId }}'
      tags: '{{ item.tags }}'
- discovery_id: aws.wisdom.listAssistantAssociations
  calls:
  - action: listAssistantAssociations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.assistantAssociationSummaries }}'
    item:
      assistantArn: '{{ item.assistantArn }}'
      assistantAssociationArn: '{{ item.assistantAssociationArn }}'
      assistantAssociationId: '{{ item.assistantAssociationId }}'
      assistantId: '{{ item.assistantId }}'
      associationData: '{{ item.associationData }}'
      associationType: '{{ item.associationType }}'
      tags: '{{ item.tags }}'
- discovery_id: aws.wisdom.listContents
  calls:
  - action: listContents
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.contentSummaries }}'
    item:
      contentArn: '{{ item.contentArn }}'
      contentId: '{{ item.contentId }}'
      contentType: '{{ item.contentType }}'
      knowledgeBaseArn: '{{ item.knowledgeBaseArn }}'
      knowledgeBaseId: '{{ item.knowledgeBaseId }}'
      metadata: '{{ item.metadata }}'
      name: '{{ item.name }}'
      revisionId: '{{ item.revisionId }}'
      status: '{{ item.status }}'
      tags: '{{ item.tags }}'
      title: '{{ item.title }}'
- discovery_id: aws.wisdom.listImportJobs
  calls:
  - action: listImportJobs
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.importJobSummaries }}'
    item:
      createdTime: '{{ item.createdTime }}'
      externalSourceConfiguration: '{{ item.externalSourceConfiguration }}'
      importJobId: '{{ item.importJobId }}'
      importJobType: '{{ item.importJobType }}'
      knowledgeBaseArn: '{{ item.knowledgeBaseArn }}'
      knowledgeBaseId: '{{ item.knowledgeBaseId }}'
      lastModifiedTime: '{{ item.lastModifiedTime }}'
      metadata: '{{ item.metadata }}'
      status: '{{ item.status }}'
      uploadId: '{{ item.uploadId }}'
- discovery_id: aws.wisdom.listQuickResponses
  calls:
  - action: listQuickResponses
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.quickResponseSummaries }}'
    item:
      channels: '{{ item.channels }}'
      contentType: '{{ item.contentType }}'
      createdTime: '{{ item.createdTime }}'
      description: '{{ item.description }}'
      isActive: '{{ item.isActive }}'
      knowledgeBaseArn: '{{ item.knowledgeBaseArn }}'
      knowledgeBaseId: '{{ item.knowledgeBaseId }}'
      lastModifiedBy: '{{ item.lastModifiedBy }}'
      lastModifiedTime: '{{ item.lastModifiedTime }}'
      name: '{{ item.name }}'
      quickResponseArn: '{{ item.quickResponseArn }}'
      quickResponseId: '{{ item.quickResponseId }}'
      status: '{{ item.status }}'
      tags: '{{ item.tags }}'
- discovery_id: aws.wisdom.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tags }}'
- discovery_id: aws.wisdom.queryAssistant
  calls:
  - action: queryAssistant
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.results }}'
    item:
      document: '{{ item.document }}'
      relevanceScore: '{{ item.relevanceScore }}'
      resultId: '{{ item.resultId }}'
- discovery_id: aws.wisdom.searchContent
  calls:
  - action: searchContent
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.contentSummaries }}'
    item:
      contentArn: '{{ item.contentArn }}'
      contentId: '{{ item.contentId }}'
      contentType: '{{ item.contentType }}'
      knowledgeBaseArn: '{{ item.knowledgeBaseArn }}'
      knowledgeBaseId: '{{ item.knowledgeBaseId }}'
      metadata: '{{ item.metadata }}'
      name: '{{ item.name }}'
      revisionId: '{{ item.revisionId }}'
      status: '{{ item.status }}'
      tags: '{{ item.tags }}'
      title: '{{ item.title }}'
- discovery_id: aws.wisdom.searchQuickResponses
  calls:
  - action: searchQuickResponses
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.results }}'
    item:
      attributesInterpolated: '{{ item.attributesInterpolated }}'
      attributesNotInterpolated: '{{ item.attributesNotInterpolated }}'
      channels: '{{ item.channels }}'
      contentType: '{{ item.contentType }}'
      contents: '{{ item.contents }}'
      createdTime: '{{ item.createdTime }}'
      description: '{{ item.description }}'
      groupingConfiguration: '{{ item.groupingConfiguration }}'
      isActive: '{{ item.isActive }}'
      knowledgeBaseArn: '{{ item.knowledgeBaseArn }}'
      knowledgeBaseId: '{{ item.knowledgeBaseId }}'
      language: '{{ item.language }}'
      lastModifiedBy: '{{ item.lastModifiedBy }}'
      lastModifiedTime: '{{ item.lastModifiedTime }}'
      name: '{{ item.name }}'
      quickResponseArn: '{{ item.quickResponseArn }}'
      quickResponseId: '{{ item.quickResponseId }}'
      shortcutKey: '{{ item.shortcutKey }}'
      status: '{{ item.status }}'
      tags: '{{ item.tags }}'
- discovery_id: aws.wisdom.searchSessions
  calls:
  - action: searchSessions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.sessionSummaries }}'
    item:
      assistantArn: '{{ item.assistantArn }}'
      assistantId: '{{ item.assistantId }}'
      sessionArn: '{{ item.sessionArn }}'
      sessionId: '{{ item.sessionId }}'
checks: []
