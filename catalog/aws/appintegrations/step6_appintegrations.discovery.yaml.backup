version: '1.0'
provider: aws
service: appintegrations
services:
  client: appintegrations
  module: boto3.client
discovery:
- discovery_id: aws.appintegrations.listApplications
  calls:
  - action: listApplications
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Applications }}'
    item:
      Arn: '{{ item.Arn }}'
      Id: '{{ item.Id }}'
      Name: '{{ item.Name }}'
      Namespace: '{{ item.Namespace }}'
      CreatedTime: '{{ item.CreatedTime }}'
      LastModifiedTime: '{{ item.LastModifiedTime }}'
      IsService: '{{ item.IsService }}'
- discovery_id: aws.appintegrations.listDataIntegrations
  calls:
  - action: listDataIntegrations
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.DataIntegrations }}'
    item:
      Arn: '{{ item.Arn }}'
      Name: '{{ item.Name }}'
      SourceURI: '{{ item.SourceURI }}'
- discovery_id: aws.appintegrations.listEventIntegrations
  calls:
  - action: listEventIntegrations
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.EventIntegrations }}'
    item:
      EventIntegrationArn: '{{ item.EventIntegrationArn }}'
      Name: '{{ item.Name }}'
      Description: '{{ item.Description }}'
      EventFilter: '{{ item.EventFilter }}'
      EventBridgeBus: '{{ item.EventBridgeBus }}'
      Tags: '{{ item.Tags }}'
- discovery_id: aws.appintegrations.getApplication
  calls:
  - action: getApplication
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Subscriptions }}'
    item:
      Event: '{{ item.Event }}'
      Description: '{{ item.Description }}'
- discovery_id: aws.appintegrations.getDataIntegration
  calls:
  - action: getDataIntegration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ScheduleConfiguration }}'
    item:
      FirstExecutionFrom: '{{ item.FirstExecutionFrom }}'
      Object: '{{ item.Object }}'
      ScheduleExpression: '{{ item.ScheduleExpression }}'
- discovery_id: aws.appintegrations.getEventIntegration
  calls:
  - action: getEventIntegration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.EventFilter }}'
    item:
      Source: '{{ item.Source }}'
- discovery_id: aws.appintegrations.listApplicationAssociations
  calls:
  - action: listApplicationAssociations
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.ApplicationAssociations }}'
    item:
      ApplicationAssociationArn: '{{ item.ApplicationAssociationArn }}'
      ApplicationArn: '{{ item.ApplicationArn }}'
      ClientId: '{{ item.ClientId }}'
- discovery_id: aws.appintegrations.listDataIntegrationAssociations
  calls:
  - action: listDataIntegrationAssociations
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.DataIntegrationAssociations }}'
    item:
      DataIntegrationAssociationArn: '{{ item.DataIntegrationAssociationArn }}'
      DataIntegrationArn: '{{ item.DataIntegrationArn }}'
      ClientId: '{{ item.ClientId }}'
      DestinationURI: '{{ item.DestinationURI }}'
      LastExecutionStatus: '{{ item.LastExecutionStatus }}'
      ExecutionConfiguration: '{{ item.ExecutionConfiguration }}'
- discovery_id: aws.appintegrations.listEventIntegrationAssociations
  calls:
  - action: listEventIntegrationAssociations
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.EventIntegrationAssociations }}'
    item:
      EventIntegrationAssociationArn: '{{ item.EventIntegrationAssociationArn }}'
      EventIntegrationAssociationId: '{{ item.EventIntegrationAssociationId }}'
      EventIntegrationName: '{{ item.EventIntegrationName }}'
      ClientId: '{{ item.ClientId }}'
      EventBridgeRuleName: '{{ item.EventBridgeRuleName }}'
      ClientAssociationMetadata: '{{ item.ClientAssociationMetadata }}'
- discovery_id: aws.appintegrations.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tags }}'
checks: []
