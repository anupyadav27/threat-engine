version: '1.0'
provider: aws
service: xray
services:
  client: xray
  module: boto3.client
discovery:
- discovery_id: aws.xray.getEncryptionConfig
  calls:
  - action: getEncryptionConfig
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.EncryptionConfig }}'
    item:
      KeyId: '{{ item.KeyId }}'
      Status: '{{ item.Status }}'
      Type: '{{ item.Type }}'
- discovery_id: aws.xray.getGroup
  calls:
  - action: getGroup
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Group }}'
    item:
      GroupName: '{{ item.GroupName }}'
      GroupARN: '{{ item.GroupARN }}'
      FilterExpression: '{{ item.FilterExpression }}'
      InsightsConfiguration: '{{ item.InsightsConfiguration }}'
- discovery_id: aws.xray.getGroups
  calls:
  - action: getGroups
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Groups }}'
    item:
      GroupName: '{{ item.GroupName }}'
      GroupARN: '{{ item.GroupARN }}'
      FilterExpression: '{{ item.FilterExpression }}'
      InsightsConfiguration: '{{ item.InsightsConfiguration }}'
- discovery_id: aws.xray.getIndexingRules
  calls:
  - action: getIndexingRules
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.IndexingRules }}'
    item:
      Name: '{{ item.Name }}'
      ModifiedAt: '{{ item.ModifiedAt }}'
      Rule: '{{ item.Rule }}'
- discovery_id: aws.xray.getSamplingRules
  calls:
  - action: getSamplingRules
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.SamplingRuleRecords }}'
    item:
      SamplingRule: '{{ item.SamplingRule }}'
      CreatedAt: '{{ item.CreatedAt }}'
      ModifiedAt: '{{ item.ModifiedAt }}'
- discovery_id: aws.xray.getSamplingStatisticSummaries
  calls:
  - action: getSamplingStatisticSummaries
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.SamplingStatisticSummaries }}'
    item:
      RuleName: '{{ item.RuleName }}'
      Timestamp: '{{ item.Timestamp }}'
      RequestCount: '{{ item.RequestCount }}'
      BorrowCount: '{{ item.BorrowCount }}'
      SampledCount: '{{ item.SampledCount }}'
- discovery_id: aws.xray.getTraceSegmentDestination
  calls:
  - action: getTraceSegmentDestination
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Destination }}'
- discovery_id: aws.xray.listResourcePolicies
  calls:
  - action: listResourcePolicies
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ResourcePolicies }}'
    item:
      PolicyName: '{{ item.PolicyName }}'
      PolicyDocument: '{{ item.PolicyDocument }}'
      PolicyRevisionId: '{{ item.PolicyRevisionId }}'
      LastUpdatedTime: '{{ item.LastUpdatedTime }}'
- discovery_id: aws.xray.getInsight
  calls:
  - action: getInsight
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Insight }}'
    item:
      InsightId: '{{ item.InsightId }}'
      GroupARN: '{{ item.GroupARN }}'
      GroupName: '{{ item.GroupName }}'
      RootCauseServiceId: '{{ item.RootCauseServiceId }}'
      Categories: '{{ item.Categories }}'
      State: '{{ item.State }}'
      StartTime: '{{ item.StartTime }}'
      EndTime: '{{ item.EndTime }}'
      Summary: '{{ item.Summary }}'
      ClientRequestImpactStatistics: '{{ item.ClientRequestImpactStatistics }}'
      RootCauseServiceRequestImpactStatistics: '{{ item.RootCauseServiceRequestImpactStatistics
        }}'
      TopAnomalousServices: '{{ item.TopAnomalousServices }}'
- discovery_id: aws.xray.getInsightEvents
  calls:
  - action: getInsightEvents
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.InsightEvents }}'
    item:
      Summary: '{{ item.Summary }}'
      EventTime: '{{ item.EventTime }}'
      ClientRequestImpactStatistics: '{{ item.ClientRequestImpactStatistics }}'
      RootCauseServiceRequestImpactStatistics: '{{ item.RootCauseServiceRequestImpactStatistics
        }}'
      TopAnomalousServices: '{{ item.TopAnomalousServices }}'
- discovery_id: aws.xray.getInsightImpactGraph
  calls:
  - action: getInsightImpactGraph
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Services }}'
    item:
      ReferenceId: '{{ item.ReferenceId }}'
      Type: '{{ item.Type }}'
      Name: '{{ item.Name }}'
      Names: '{{ item.Names }}'
      AccountId: '{{ item.AccountId }}'
      Edges: '{{ item.Edges }}'
- discovery_id: aws.xray.getInsightSummaries
  calls:
  - action: getInsightSummaries
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.InsightSummaries }}'
    item:
      InsightId: '{{ item.InsightId }}'
      GroupARN: '{{ item.GroupARN }}'
      GroupName: '{{ item.GroupName }}'
      RootCauseServiceId: '{{ item.RootCauseServiceId }}'
      Categories: '{{ item.Categories }}'
      State: '{{ item.State }}'
      StartTime: '{{ item.StartTime }}'
      EndTime: '{{ item.EndTime }}'
      Summary: '{{ item.Summary }}'
      ClientRequestImpactStatistics: '{{ item.ClientRequestImpactStatistics }}'
      RootCauseServiceRequestImpactStatistics: '{{ item.RootCauseServiceRequestImpactStatistics
        }}'
      TopAnomalousServices: '{{ item.TopAnomalousServices }}'
      LastUpdateTime: '{{ item.LastUpdateTime }}'
- discovery_id: aws.xray.getRetrievedTracesGraph
  calls:
  - action: getRetrievedTracesGraph
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Services }}'
    item:
      Service: '{{ item.Service }}'
      Links: '{{ item.Links }}'
- discovery_id: aws.xray.getSamplingTargets
  calls:
  - action: getSamplingTargets
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.SamplingTargetDocuments }}'
    item:
      RuleName: '{{ item.RuleName }}'
      FixedRate: '{{ item.FixedRate }}'
      ReservoirQuota: '{{ item.ReservoirQuota }}'
      ReservoirQuotaTTL: '{{ item.ReservoirQuotaTTL }}'
      Interval: '{{ item.Interval }}'
      SamplingBoost: '{{ item.SamplingBoost }}'
- discovery_id: aws.xray.getServiceGraph
  calls:
  - action: getServiceGraph
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Services }}'
    item:
      ReferenceId: '{{ item.ReferenceId }}'
      Name: '{{ item.Name }}'
      Names: '{{ item.Names }}'
      Root: '{{ item.Root }}'
      AccountId: '{{ item.AccountId }}'
      Type: '{{ item.Type }}'
      State: '{{ item.State }}'
      StartTime: '{{ item.StartTime }}'
      EndTime: '{{ item.EndTime }}'
      Edges: '{{ item.Edges }}'
      SummaryStatistics: '{{ item.SummaryStatistics }}'
      DurationHistogram: '{{ item.DurationHistogram }}'
      ResponseTimeHistogram: '{{ item.ResponseTimeHistogram }}'
- discovery_id: aws.xray.getTimeSeriesServiceStatistics
  calls:
  - action: getTimeSeriesServiceStatistics
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.TimeSeriesServiceStatistics }}'
    item:
      Timestamp: '{{ item.Timestamp }}'
      EdgeSummaryStatistics: '{{ item.EdgeSummaryStatistics }}'
      ServiceSummaryStatistics: '{{ item.ServiceSummaryStatistics }}'
      ServiceForecastStatistics: '{{ item.ServiceForecastStatistics }}'
      ResponseTimeHistogram: '{{ item.ResponseTimeHistogram }}'
- discovery_id: aws.xray.getTraceGraph
  calls:
  - action: getTraceGraph
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Services }}'
    item:
      ReferenceId: '{{ item.ReferenceId }}'
      Name: '{{ item.Name }}'
      Names: '{{ item.Names }}'
      Root: '{{ item.Root }}'
      AccountId: '{{ item.AccountId }}'
      Type: '{{ item.Type }}'
      State: '{{ item.State }}'
      StartTime: '{{ item.StartTime }}'
      EndTime: '{{ item.EndTime }}'
      Edges: '{{ item.Edges }}'
      SummaryStatistics: '{{ item.SummaryStatistics }}'
      DurationHistogram: '{{ item.DurationHistogram }}'
      ResponseTimeHistogram: '{{ item.ResponseTimeHistogram }}'
- discovery_id: aws.xray.getTraceSummaries
  calls:
  - action: getTraceSummaries
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.TraceSummaries }}'
    item:
      Id: '{{ item.Id }}'
      StartTime: '{{ item.StartTime }}'
      Duration: '{{ item.Duration }}'
      ResponseTime: '{{ item.ResponseTime }}'
      HasFault: '{{ item.HasFault }}'
      HasError: '{{ item.HasError }}'
      HasThrottle: '{{ item.HasThrottle }}'
      IsPartial: '{{ item.IsPartial }}'
      Http: '{{ item.Http }}'
      Annotations: '{{ item.Annotations }}'
      Users: '{{ item.Users }}'
      ServiceIds: '{{ item.ServiceIds }}'
      ResourceARNs: '{{ item.ResourceARNs }}'
      InstanceIds: '{{ item.InstanceIds }}'
      AvailabilityZones: '{{ item.AvailabilityZones }}'
      EntryPoint: '{{ item.EntryPoint }}'
      FaultRootCauses: '{{ item.FaultRootCauses }}'
      ErrorRootCauses: '{{ item.ErrorRootCauses }}'
      ResponseTimeRootCauses: '{{ item.ResponseTimeRootCauses }}'
      Revision: '{{ item.Revision }}'
      MatchedEventTime: '{{ item.MatchedEventTime }}'
- discovery_id: aws.xray.listRetrievedTraces
  calls:
  - action: listRetrievedTraces
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Traces }}'
    item:
      Id: '{{ item.Id }}'
      Duration: '{{ item.Duration }}'
      Spans: '{{ item.Spans }}'
- discovery_id: aws.xray.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Tags }}'
    item:
      Key: '{{ item.Key }}'
      Value: '{{ item.Value }}'
checks: []
