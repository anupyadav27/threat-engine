version: '1.0'
provider: aws
service: connectcampaignsv2
services:
  client: connectcampaignsv2
  module: boto3.client
discovery:
- discovery_id: aws.connectcampaignsv2.listCampaigns
  calls:
  - action: listCampaigns
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.campaignSummaryList }}'
    item:
      id: '{{ item.id }}'
      arn: '{{ item.arn }}'
      name: '{{ item.name }}'
      connectInstanceId: '{{ item.connectInstanceId }}'
      channelSubtypes: '{{ item.channelSubtypes }}'
      schedule: '{{ item.schedule }}'
      connectCampaignFlowArn: '{{ item.connectCampaignFlowArn }}'
- discovery_id: aws.connectcampaignsv2.describeCampaign
  calls:
  - action: describeCampaign
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.campaign }}'
    item:
      id: '{{ item.id }}'
      arn: '{{ item.arn }}'
      name: '{{ item.name }}'
      connectInstanceId: '{{ item.connectInstanceId }}'
      channelSubtypeConfig: '{{ item.channelSubtypeConfig }}'
      source: '{{ item.source }}'
      connectCampaignFlowArn: '{{ item.connectCampaignFlowArn }}'
      schedule: '{{ item.schedule }}'
      communicationTimeConfig: '{{ item.communicationTimeConfig }}'
      communicationLimitsOverride: '{{ item.communicationLimitsOverride }}'
      tags: '{{ item.tags }}'
- discovery_id: aws.connectcampaignsv2.getCampaignState
  calls:
  - action: getCampaignState
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.state }}'
- discovery_id: aws.connectcampaignsv2.getCampaignStateBatch
  calls:
  - action: getCampaignStateBatch
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.successfulRequests }}'
    item:
      campaignId: '{{ item.campaignId }}'
      state: '{{ item.state }}'
- discovery_id: aws.connectcampaignsv2.getConnectInstanceConfig
  calls:
  - action: getConnectInstanceConfig
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.connectInstanceConfig }}'
    item:
      connectInstanceId: '{{ item.connectInstanceId }}'
      serviceLinkedRoleArn: '{{ item.serviceLinkedRoleArn }}'
      encryptionConfig: '{{ item.encryptionConfig }}'
- discovery_id: aws.connectcampaignsv2.getInstanceCommunicationLimits
  calls:
  - action: getInstanceCommunicationLimits
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.communicationLimitsConfig }}'
    item:
      allChannelSubtypes: '{{ item.allChannelSubtypes }}'
- discovery_id: aws.connectcampaignsv2.getInstanceOnboardingJobStatus
  calls:
  - action: getInstanceOnboardingJobStatus
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.connectInstanceOnboardingJobStatus }}'
    item:
      connectInstanceId: '{{ item.connectInstanceId }}'
      status: '{{ item.status }}'
      failureCode: '{{ item.failureCode }}'
- discovery_id: aws.connectcampaignsv2.listConnectInstanceIntegrations
  calls:
  - action: listConnectInstanceIntegrations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.integrationSummaryList }}'
    item:
      customerProfiles: '{{ item.customerProfiles }}'
      qConnect: '{{ item.qConnect }}'
- discovery_id: aws.connectcampaignsv2.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tags }}'
checks: []
