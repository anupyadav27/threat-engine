version: '1.0'
provider: aws
service: athena
services:
  client: athena
  module: boto3.client
discovery:
- discovery_id: aws.athena.listApplicationDpuSizes
  calls:
  - action: listApplicationDpuSizes
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.ApplicationDPUSizes }}'
    item:
      ApplicationRuntimeId: '{{ item.ApplicationRuntimeId }}'
      SupportedDPUSizes: '{{ item.SupportedDPUSizes }}'
- discovery_id: aws.athena.listCapacityReservations
  calls:
  - action: listCapacityReservations
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.CapacityReservations }}'
    item:
      Name: '{{ item.Name }}'
      Status: '{{ item.Status }}'
      TargetDpus: '{{ item.TargetDpus }}'
      AllocatedDpus: '{{ item.AllocatedDpus }}'
      LastAllocation: '{{ item.LastAllocation }}'
      LastSuccessfulAllocationTime: '{{ item.LastSuccessfulAllocationTime }}'
      CreationTime: '{{ item.CreationTime }}'
- discovery_id: aws.athena.listDataCatalogs
  calls:
  - action: listDataCatalogs
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.DataCatalogsSummary }}'
    item:
      CatalogName: '{{ item.CatalogName }}'
      Type: '{{ item.Type }}'
      Status: '{{ item.Status }}'
      ConnectionType: '{{ item.ConnectionType }}'
      Error: '{{ item.Error }}'
- discovery_id: aws.athena.listEngineVersions
  calls:
  - action: listEngineVersions
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.EngineVersions }}'
    item:
      SelectedEngineVersion: '{{ item.SelectedEngineVersion }}'
      EffectiveEngineVersion: '{{ item.EffectiveEngineVersion }}'
- discovery_id: aws.athena.listNamedQueries
  calls:
  - action: listNamedQueries
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.NamedQueryIds }}'
- discovery_id: aws.athena.listQueryExecutions
  calls:
  - action: listQueryExecutions
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.QueryExecutionIds }}'
- discovery_id: aws.athena.listWorkGroups
  calls:
  - action: listWorkGroups
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.WorkGroups }}'
    item:
      Name: '{{ item.Name }}'
      State: '{{ item.State }}'
      Description: '{{ item.Description }}'
      CreationTime: '{{ item.CreationTime }}'
      EngineVersion: '{{ item.EngineVersion }}'
      IdentityCenterApplicationArn: '{{ item.IdentityCenterApplicationArn }}'
- discovery_id: aws.athena.getCalculationExecution
  calls:
  - action: getCalculationExecution
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Status }}'
    item:
      SubmissionDateTime: '{{ item.SubmissionDateTime }}'
      CompletionDateTime: '{{ item.CompletionDateTime }}'
      State: '{{ item.State }}'
      StateChangeReason: '{{ item.StateChangeReason }}'
- discovery_id: aws.athena.getCalculationExecutionCode
  calls:
  - action: getCalculationExecutionCode
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.CodeBlock }}'
- discovery_id: aws.athena.getCalculationExecutionStatus
  calls:
  - action: getCalculationExecutionStatus
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Status }}'
    item:
      SubmissionDateTime: '{{ item.SubmissionDateTime }}'
      CompletionDateTime: '{{ item.CompletionDateTime }}'
      State: '{{ item.State }}'
      StateChangeReason: '{{ item.StateChangeReason }}'
- discovery_id: aws.athena.getCapacityAssignmentConfiguration
  calls:
  - action: getCapacityAssignmentConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.CapacityAssignmentConfiguration }}'
    item:
      CapacityReservationName: '{{ item.CapacityReservationName }}'
      CapacityAssignments: '{{ item.CapacityAssignments }}'
- discovery_id: aws.athena.getCapacityReservation
  calls:
  - action: getCapacityReservation
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.CapacityReservation }}'
    item:
      Name: '{{ item.Name }}'
      Status: '{{ item.Status }}'
      TargetDpus: '{{ item.TargetDpus }}'
      AllocatedDpus: '{{ item.AllocatedDpus }}'
      LastAllocation: '{{ item.LastAllocation }}'
      LastSuccessfulAllocationTime: '{{ item.LastSuccessfulAllocationTime }}'
      CreationTime: '{{ item.CreationTime }}'
- discovery_id: aws.athena.getDataCatalog
  calls:
  - action: getDataCatalog
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.DataCatalog }}'
    item:
      Name: '{{ item.Name }}'
      Description: '{{ item.Description }}'
      Type: '{{ item.Type }}'
      Parameters: '{{ item.Parameters }}'
      Status: '{{ item.Status }}'
      ConnectionType: '{{ item.ConnectionType }}'
      Error: '{{ item.Error }}'
- discovery_id: aws.athena.getDatabase
  calls:
  - action: getDatabase
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Database }}'
    item:
      Name: '{{ item.Name }}'
      Description: '{{ item.Description }}'
      Parameters: '{{ item.Parameters }}'
- discovery_id: aws.athena.getNamedQuery
  calls:
  - action: getNamedQuery
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.NamedQuery }}'
    item:
      Name: '{{ item.Name }}'
      Description: '{{ item.Description }}'
      Database: '{{ item.Database }}'
      QueryString: '{{ item.QueryString }}'
      NamedQueryId: '{{ item.NamedQueryId }}'
      WorkGroup: '{{ item.WorkGroup }}'
- discovery_id: aws.athena.getNotebookMetadata
  calls:
  - action: getNotebookMetadata
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.NotebookMetadata }}'
    item:
      NotebookId: '{{ item.NotebookId }}'
      Name: '{{ item.Name }}'
      WorkGroup: '{{ item.WorkGroup }}'
      CreationTime: '{{ item.CreationTime }}'
      Type: '{{ item.Type }}'
      LastModifiedTime: '{{ item.LastModifiedTime }}'
- discovery_id: aws.athena.getPreparedStatement
  calls:
  - action: getPreparedStatement
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.PreparedStatement }}'
    item:
      StatementName: '{{ item.StatementName }}'
      QueryStatement: '{{ item.QueryStatement }}'
      WorkGroupName: '{{ item.WorkGroupName }}'
      Description: '{{ item.Description }}'
      LastModifiedTime: '{{ item.LastModifiedTime }}'
- discovery_id: aws.athena.getQueryExecution
  calls:
  - action: getQueryExecution
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.QueryExecution }}'
    item:
      QueryExecutionId: '{{ item.QueryExecutionId }}'
      Query: '{{ item.Query }}'
      StatementType: '{{ item.StatementType }}'
      ManagedQueryResultsConfiguration: '{{ item.ManagedQueryResultsConfiguration
        }}'
      ResultConfiguration: '{{ item.ResultConfiguration }}'
      ResultReuseConfiguration: '{{ item.ResultReuseConfiguration }}'
      QueryExecutionContext: '{{ item.QueryExecutionContext }}'
      Status: '{{ item.Status }}'
      Statistics: '{{ item.Statistics }}'
      WorkGroup: '{{ item.WorkGroup }}'
      EngineVersion: '{{ item.EngineVersion }}'
      ExecutionParameters: '{{ item.ExecutionParameters }}'
      SubstatementType: '{{ item.SubstatementType }}'
      QueryResultsS3AccessGrantsConfiguration: '{{ item.QueryResultsS3AccessGrantsConfiguration
        }}'
- discovery_id: aws.athena.getQueryResults
  calls:
  - action: getQueryResults
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ResultSet }}'
    item:
      Rows: '{{ item.Rows }}'
      ResultSetMetadata: '{{ item.ResultSetMetadata }}'
- discovery_id: aws.athena.getQueryRuntimeStatistics
  calls:
  - action: getQueryRuntimeStatistics
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.QueryRuntimeStatistics }}'
    item:
      Timeline: '{{ item.Timeline }}'
      Rows: '{{ item.Rows }}'
      OutputStage: '{{ item.OutputStage }}'
- discovery_id: aws.athena.getResourceDashboard
  calls:
  - action: getResourceDashboard
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Url }}'
- discovery_id: aws.athena.getSession
  calls:
  - action: getSession
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.EngineConfiguration }}'
    item:
      CoordinatorDpuSize: '{{ item.CoordinatorDpuSize }}'
      MaxConcurrentDpus: '{{ item.MaxConcurrentDpus }}'
      DefaultExecutorDpuSize: '{{ item.DefaultExecutorDpuSize }}'
      AdditionalConfigs: '{{ item.AdditionalConfigs }}'
      SparkProperties: '{{ item.SparkProperties }}'
      Classifications: '{{ item.Classifications }}'
- discovery_id: aws.athena.getSessionEndpoint
  calls:
  - action: getSessionEndpoint
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.EndpointUrl }}'
- discovery_id: aws.athena.getSessionStatus
  calls:
  - action: getSessionStatus
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Status }}'
    item:
      StartDateTime: '{{ item.StartDateTime }}'
      LastModifiedDateTime: '{{ item.LastModifiedDateTime }}'
      EndDateTime: '{{ item.EndDateTime }}'
      IdleSinceDateTime: '{{ item.IdleSinceDateTime }}'
      State: '{{ item.State }}'
      StateChangeReason: '{{ item.StateChangeReason }}'
- discovery_id: aws.athena.getTableMetadata
  calls:
  - action: getTableMetadata
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.TableMetadata }}'
    item:
      Name: '{{ item.Name }}'
      CreateTime: '{{ item.CreateTime }}'
      LastAccessTime: '{{ item.LastAccessTime }}'
      TableType: '{{ item.TableType }}'
      Columns: '{{ item.Columns }}'
      PartitionKeys: '{{ item.PartitionKeys }}'
      Parameters: '{{ item.Parameters }}'
- discovery_id: aws.athena.getWorkGroup
  calls:
  - action: getWorkGroup
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.WorkGroup }}'
    item:
      Name: '{{ item.Name }}'
      State: '{{ item.State }}'
      Configuration: '{{ item.Configuration }}'
      Description: '{{ item.Description }}'
      CreationTime: '{{ item.CreationTime }}'
      IdentityCenterApplicationArn: '{{ item.IdentityCenterApplicationArn }}'
- discovery_id: aws.athena.listCalculationExecutions
  calls:
  - action: listCalculationExecutions
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Calculations }}'
    item:
      CalculationExecutionId: '{{ item.CalculationExecutionId }}'
      Description: '{{ item.Description }}'
      Status: '{{ item.Status }}'
- discovery_id: aws.athena.listDatabases
  calls:
  - action: listDatabases
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.DatabaseList }}'
    item:
      Name: '{{ item.Name }}'
      Description: '{{ item.Description }}'
      Parameters: '{{ item.Parameters }}'
- discovery_id: aws.athena.listExecutors
  calls:
  - action: listExecutors
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.ExecutorsSummary }}'
    item:
      ExecutorId: '{{ item.ExecutorId }}'
      ExecutorType: '{{ item.ExecutorType }}'
      StartDateTime: '{{ item.StartDateTime }}'
      TerminationDateTime: '{{ item.TerminationDateTime }}'
      ExecutorState: '{{ item.ExecutorState }}'
      ExecutorSize: '{{ item.ExecutorSize }}'
- discovery_id: aws.athena.listNotebookMetadata
  calls:
  - action: listNotebookMetadata
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.NotebookMetadataList }}'
    item:
      NotebookId: '{{ item.NotebookId }}'
      Name: '{{ item.Name }}'
      WorkGroup: '{{ item.WorkGroup }}'
      CreationTime: '{{ item.CreationTime }}'
      Type: '{{ item.Type }}'
      LastModifiedTime: '{{ item.LastModifiedTime }}'
- discovery_id: aws.athena.listNotebookSessions
  calls:
  - action: listNotebookSessions
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.NotebookSessionsList }}'
    item:
      SessionId: '{{ item.SessionId }}'
      CreationTime: '{{ item.CreationTime }}'
- discovery_id: aws.athena.listPreparedStatements
  calls:
  - action: listPreparedStatements
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.PreparedStatements }}'
    item:
      StatementName: '{{ item.StatementName }}'
      LastModifiedTime: '{{ item.LastModifiedTime }}'
- discovery_id: aws.athena.listSessions
  calls:
  - action: listSessions
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Sessions }}'
    item:
      SessionId: '{{ item.SessionId }}'
      Description: '{{ item.Description }}'
      EngineVersion: '{{ item.EngineVersion }}'
      NotebookVersion: '{{ item.NotebookVersion }}'
      Status: '{{ item.Status }}'
- discovery_id: aws.athena.listTableMetadata
  calls:
  - action: listTableMetadata
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.TableMetadataList }}'
    item:
      Name: '{{ item.Name }}'
      CreateTime: '{{ item.CreateTime }}'
      LastAccessTime: '{{ item.LastAccessTime }}'
      TableType: '{{ item.TableType }}'
      Columns: '{{ item.Columns }}'
      PartitionKeys: '{{ item.PartitionKeys }}'
      Parameters: '{{ item.Parameters }}'
- discovery_id: aws.athena.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Tags }}'
    item:
      Key: '{{ item.Key }}'
      Value: '{{ item.Value }}'
checks: []
