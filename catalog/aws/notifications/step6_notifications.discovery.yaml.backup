version: '1.0'
provider: aws
service: notifications
services:
  client: notifications
  module: boto3.client
discovery:
- discovery_id: aws.notifications.getNotificationsAccessForOrganization
  calls:
  - action: getNotificationsAccessForOrganization
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.notificationsAccessForOrganization }}'
    item:
      accessStatus: '{{ item.accessStatus }}'
- discovery_id: aws.notifications.listManagedNotificationConfigurations
  calls:
  - action: listManagedNotificationConfigurations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.managedNotificationConfigurations }}'
    item:
      arn: '{{ item.arn }}'
      name: '{{ item.name }}'
      description: '{{ item.description }}'
- discovery_id: aws.notifications.listManagedNotificationEvents
  calls:
  - action: listManagedNotificationEvents
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.managedNotificationEvents }}'
    item:
      arn: '{{ item.arn }}'
      managedNotificationConfigurationArn: '{{ item.managedNotificationConfigurationArn
        }}'
      relatedAccount: '{{ item.relatedAccount }}'
      creationTime: '{{ item.creationTime }}'
      notificationEvent: '{{ item.notificationEvent }}'
      aggregationEventType: '{{ item.aggregationEventType }}'
      organizationalUnitId: '{{ item.organizationalUnitId }}'
      aggregationSummary: '{{ item.aggregationSummary }}'
      aggregatedNotificationRegions: '{{ item.aggregatedNotificationRegions }}'
- discovery_id: aws.notifications.listNotificationConfigurations
  calls:
  - action: listNotificationConfigurations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.notificationConfigurations }}'
    item:
      arn: '{{ item.arn }}'
      name: '{{ item.name }}'
      description: '{{ item.description }}'
      status: '{{ item.status }}'
      creationTime: '{{ item.creationTime }}'
      aggregationDuration: '{{ item.aggregationDuration }}'
      subtype: '{{ item.subtype }}'
- discovery_id: aws.notifications.listNotificationEvents
  calls:
  - action: listNotificationEvents
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.notificationEvents }}'
    item:
      arn: '{{ item.arn }}'
      notificationConfigurationArn: '{{ item.notificationConfigurationArn }}'
      relatedAccount: '{{ item.relatedAccount }}'
      creationTime: '{{ item.creationTime }}'
      notificationEvent: '{{ item.notificationEvent }}'
      aggregationEventType: '{{ item.aggregationEventType }}'
      aggregateNotificationEventArn: '{{ item.aggregateNotificationEventArn }}'
      aggregationSummary: '{{ item.aggregationSummary }}'
      organizationalUnitId: '{{ item.organizationalUnitId }}'
- discovery_id: aws.notifications.listNotificationHubs
  calls:
  - action: listNotificationHubs
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.notificationHubs }}'
    item:
      notificationHubRegion: '{{ item.notificationHubRegion }}'
      statusSummary: '{{ item.statusSummary }}'
      creationTime: '{{ item.creationTime }}'
      lastActivationTime: '{{ item.lastActivationTime }}'
- discovery_id: aws.notifications.getEventRule
  calls:
  - action: getEventRule
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.regions }}'
- discovery_id: aws.notifications.getManagedNotificationChildEvent
  calls:
  - action: getManagedNotificationChildEvent
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.content }}'
    item:
      schemaVersion: '{{ item.schemaVersion }}'
      id: '{{ item.id }}'
      messageComponents: '{{ item.messageComponents }}'
      sourceEventDetailUrl: '{{ item.sourceEventDetailUrl }}'
      sourceEventDetailUrlDisplayText: '{{ item.sourceEventDetailUrlDisplayText }}'
      notificationType: '{{ item.notificationType }}'
      eventStatus: '{{ item.eventStatus }}'
      aggregateManagedNotificationEventArn: '{{ item.aggregateManagedNotificationEventArn
        }}'
      startTime: '{{ item.startTime }}'
      endTime: '{{ item.endTime }}'
      textParts: '{{ item.textParts }}'
      organizationalUnitId: '{{ item.organizationalUnitId }}'
      aggregationDetail: '{{ item.aggregationDetail }}'
- discovery_id: aws.notifications.getManagedNotificationConfiguration
  calls:
  - action: getManagedNotificationConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.arn }}'
- discovery_id: aws.notifications.getManagedNotificationEvent
  calls:
  - action: getManagedNotificationEvent
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.content }}'
    item:
      schemaVersion: '{{ item.schemaVersion }}'
      id: '{{ item.id }}'
      messageComponents: '{{ item.messageComponents }}'
      sourceEventDetailUrl: '{{ item.sourceEventDetailUrl }}'
      sourceEventDetailUrlDisplayText: '{{ item.sourceEventDetailUrlDisplayText }}'
      notificationType: '{{ item.notificationType }}'
      eventStatus: '{{ item.eventStatus }}'
      aggregationEventType: '{{ item.aggregationEventType }}'
      aggregationSummary: '{{ item.aggregationSummary }}'
      startTime: '{{ item.startTime }}'
      endTime: '{{ item.endTime }}'
      textParts: '{{ item.textParts }}'
      organizationalUnitId: '{{ item.organizationalUnitId }}'
- discovery_id: aws.notifications.getNotificationConfiguration
  calls:
  - action: getNotificationConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.arn }}'
- discovery_id: aws.notifications.getNotificationEvent
  calls:
  - action: getNotificationEvent
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.content }}'
    item:
      schemaVersion: '{{ item.schemaVersion }}'
      id: '{{ item.id }}'
      sourceEventMetadata: '{{ item.sourceEventMetadata }}'
      messageComponents: '{{ item.messageComponents }}'
      sourceEventDetailUrl: '{{ item.sourceEventDetailUrl }}'
      sourceEventDetailUrlDisplayText: '{{ item.sourceEventDetailUrlDisplayText }}'
      notificationType: '{{ item.notificationType }}'
      eventStatus: '{{ item.eventStatus }}'
      aggregationEventType: '{{ item.aggregationEventType }}'
      aggregateNotificationEventArn: '{{ item.aggregateNotificationEventArn }}'
      aggregationSummary: '{{ item.aggregationSummary }}'
      startTime: '{{ item.startTime }}'
      endTime: '{{ item.endTime }}'
      textParts: '{{ item.textParts }}'
      media: '{{ item.media }}'
      organizationalUnitId: '{{ item.organizationalUnitId }}'
- discovery_id: aws.notifications.listChannels
  calls:
  - action: listChannels
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.channels }}'
- discovery_id: aws.notifications.listEventRules
  calls:
  - action: listEventRules
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.eventRules }}'
    item:
      arn: '{{ item.arn }}'
      notificationConfigurationArn: '{{ item.notificationConfigurationArn }}'
      creationTime: '{{ item.creationTime }}'
      source: '{{ item.source }}'
      eventType: '{{ item.eventType }}'
      eventPattern: '{{ item.eventPattern }}'
      regions: '{{ item.regions }}'
      managedRules: '{{ item.managedRules }}'
      statusSummaryByRegion: '{{ item.statusSummaryByRegion }}'
- discovery_id: aws.notifications.listManagedNotificationChannelAssociations
  calls:
  - action: listManagedNotificationChannelAssociations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.channelAssociations }}'
    item:
      channelIdentifier: '{{ item.channelIdentifier }}'
      channelType: '{{ item.channelType }}'
      overrideOption: '{{ item.overrideOption }}'
- discovery_id: aws.notifications.listManagedNotificationChildEvents
  calls:
  - action: listManagedNotificationChildEvents
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.managedNotificationChildEvents }}'
    item:
      arn: '{{ item.arn }}'
      managedNotificationConfigurationArn: '{{ item.managedNotificationConfigurationArn
        }}'
      relatedAccount: '{{ item.relatedAccount }}'
      creationTime: '{{ item.creationTime }}'
      childEvent: '{{ item.childEvent }}'
      aggregateManagedNotificationEventArn: '{{ item.aggregateManagedNotificationEventArn
        }}'
      organizationalUnitId: '{{ item.organizationalUnitId }}'
- discovery_id: aws.notifications.listMemberAccounts
  calls:
  - action: listMemberAccounts
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.memberAccounts }}'
    item:
      notificationConfigurationArn: '{{ item.notificationConfigurationArn }}'
      accountId: '{{ item.accountId }}'
      status: '{{ item.status }}'
      statusReason: '{{ item.statusReason }}'
      organizationalUnitId: '{{ item.organizationalUnitId }}'
- discovery_id: aws.notifications.listOrganizationalUnits
  calls:
  - action: listOrganizationalUnits
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.organizationalUnits }}'
- discovery_id: aws.notifications.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tags }}'
checks: []
