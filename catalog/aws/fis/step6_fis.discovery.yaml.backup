version: '1.0'
provider: aws
service: fis
services:
  client: fis
  module: boto3.client
discovery:
- discovery_id: aws.fis.listActions
  calls:
  - action: listActions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.actions }}'
    item:
      id: '{{ item.id }}'
      arn: '{{ item.arn }}'
      description: '{{ item.description }}'
      targets: '{{ item.targets }}'
      tags: '{{ item.tags }}'
- discovery_id: aws.fis.listExperimentTemplates
  calls:
  - action: listExperimentTemplates
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.experimentTemplates }}'
    item:
      id: '{{ item.id }}'
      arn: '{{ item.arn }}'
      description: '{{ item.description }}'
      creationTime: '{{ item.creationTime }}'
      lastUpdateTime: '{{ item.lastUpdateTime }}'
      tags: '{{ item.tags }}'
- discovery_id: aws.fis.listExperiments
  calls:
  - action: listExperiments
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.experiments }}'
    item:
      id: '{{ item.id }}'
      arn: '{{ item.arn }}'
      experimentTemplateId: '{{ item.experimentTemplateId }}'
      state: '{{ item.state }}'
      creationTime: '{{ item.creationTime }}'
      tags: '{{ item.tags }}'
      experimentOptions: '{{ item.experimentOptions }}'
- discovery_id: aws.fis.listTargetResourceTypes
  calls:
  - action: listTargetResourceTypes
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.targetResourceTypes }}'
    item:
      resourceType: '{{ item.resourceType }}'
      description: '{{ item.description }}'
- discovery_id: aws.fis.getAction
  calls:
  - action: getAction
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.action }}'
    item:
      id: '{{ item.id }}'
      arn: '{{ item.arn }}'
      description: '{{ item.description }}'
      parameters: '{{ item.parameters }}'
      targets: '{{ item.targets }}'
      tags: '{{ item.tags }}'
- discovery_id: aws.fis.getExperiment
  calls:
  - action: getExperiment
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.experiment }}'
    item:
      id: '{{ item.id }}'
      arn: '{{ item.arn }}'
      experimentTemplateId: '{{ item.experimentTemplateId }}'
      roleArn: '{{ item.roleArn }}'
      state: '{{ item.state }}'
      targets: '{{ item.targets }}'
      actions: '{{ item.actions }}'
      stopConditions: '{{ item.stopConditions }}'
      creationTime: '{{ item.creationTime }}'
      startTime: '{{ item.startTime }}'
      endTime: '{{ item.endTime }}'
      tags: '{{ item.tags }}'
      logConfiguration: '{{ item.logConfiguration }}'
      experimentOptions: '{{ item.experimentOptions }}'
      targetAccountConfigurationsCount: '{{ item.targetAccountConfigurationsCount
        }}'
      experimentReportConfiguration: '{{ item.experimentReportConfiguration }}'
      experimentReport: '{{ item.experimentReport }}'
- discovery_id: aws.fis.getExperimentTargetAccountConfiguration
  calls:
  - action: getExperimentTargetAccountConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.targetAccountConfiguration }}'
    item:
      roleArn: '{{ item.roleArn }}'
      accountId: '{{ item.accountId }}'
      description: '{{ item.description }}'
- discovery_id: aws.fis.getExperimentTemplate
  calls:
  - action: getExperimentTemplate
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.experimentTemplate }}'
    item:
      id: '{{ item.id }}'
      arn: '{{ item.arn }}'
      description: '{{ item.description }}'
      targets: '{{ item.targets }}'
      actions: '{{ item.actions }}'
      stopConditions: '{{ item.stopConditions }}'
      creationTime: '{{ item.creationTime }}'
      lastUpdateTime: '{{ item.lastUpdateTime }}'
      roleArn: '{{ item.roleArn }}'
      tags: '{{ item.tags }}'
      logConfiguration: '{{ item.logConfiguration }}'
      experimentOptions: '{{ item.experimentOptions }}'
      targetAccountConfigurationsCount: '{{ item.targetAccountConfigurationsCount
        }}'
      experimentReportConfiguration: '{{ item.experimentReportConfiguration }}'
- discovery_id: aws.fis.getSafetyLever
  calls:
  - action: getSafetyLever
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.safetyLever }}'
    item:
      id: '{{ item.id }}'
      arn: '{{ item.arn }}'
      state: '{{ item.state }}'
- discovery_id: aws.fis.getTargetAccountConfiguration
  calls:
  - action: getTargetAccountConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.targetAccountConfiguration }}'
    item:
      roleArn: '{{ item.roleArn }}'
      accountId: '{{ item.accountId }}'
      description: '{{ item.description }}'
- discovery_id: aws.fis.getTargetResourceType
  calls:
  - action: getTargetResourceType
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.targetResourceType }}'
    item:
      resourceType: '{{ item.resourceType }}'
      description: '{{ item.description }}'
      parameters: '{{ item.parameters }}'
- discovery_id: aws.fis.listExperimentResolvedTargets
  calls:
  - action: listExperimentResolvedTargets
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.resolvedTargets }}'
    item:
      resourceType: '{{ item.resourceType }}'
      targetName: '{{ item.targetName }}'
      targetInformation: '{{ item.targetInformation }}'
- discovery_id: aws.fis.listExperimentTargetAccountConfigurations
  calls:
  - action: listExperimentTargetAccountConfigurations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.targetAccountConfigurations }}'
    item:
      roleArn: '{{ item.roleArn }}'
      accountId: '{{ item.accountId }}'
      description: '{{ item.description }}'
- discovery_id: aws.fis.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tags }}'
- discovery_id: aws.fis.listTargetAccountConfigurations
  calls:
  - action: listTargetAccountConfigurations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.targetAccountConfigurations }}'
    item:
      roleArn: '{{ item.roleArn }}'
      accountId: '{{ item.accountId }}'
      description: '{{ item.description }}'
checks: []
