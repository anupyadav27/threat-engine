version: '1.0'
provider: aws
service: cloudsearchdomain
services:
  client: cloudsearchdomain
  module: boto3.client
discovery:
- discovery_id: aws.cloudsearchdomain.search
  calls:
  - action: search
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.status }}'
    item:
      timems: '{{ item.timems }}'
      rid: '{{ item.rid }}'
checks: []
