version: '1.0'
provider: aws
service: importexport
services:
  client: importexport
  module: boto3.client
discovery:
- discovery_id: aws.importexport.listJobs
  calls:
  - action: listJobs
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Jobs }}'
    item:
      JobId: '{{ item.JobId }}'
      CreationDate: '{{ item.CreationDate }}'
      IsCanceled: '{{ item.IsCanceled }}'
      JobType: '{{ item.JobType }}'
- discovery_id: aws.importexport.getShippingLabel
  calls:
  - action: getShippingLabel
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ShippingLabelURL }}'
- discovery_id: aws.importexport.getStatus
  calls:
  - action: getStatus
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ArtifactList }}'
    item:
      Description: '{{ item.Description }}'
      URL: '{{ item.URL }}'
checks: []
