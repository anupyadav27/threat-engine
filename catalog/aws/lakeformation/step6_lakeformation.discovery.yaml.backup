version: '1.0'
provider: aws
service: lakeformation
services:
  client: lakeformation
  module: boto3.client
discovery:
- discovery_id: aws.lakeformation.describeLakeFormationIdentityCenterConfiguration
  calls:
  - action: describeLakeFormationIdentityCenterConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ShareRecipients }}'
    item:
      DataLakePrincipalIdentifier: '{{ item.DataLakePrincipalIdentifier }}'
- discovery_id: aws.lakeformation.getDataLakePrincipal
  calls:
  - action: getDataLakePrincipal
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Identity }}'
- discovery_id: aws.lakeformation.getDataLakeSettings
  calls:
  - action: getDataLakeSettings
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.DataLakeSettings }}'
    item:
      DataLakeAdmins: '{{ item.DataLakeAdmins }}'
      ReadOnlyAdmins: '{{ item.ReadOnlyAdmins }}'
      CreateDatabaseDefaultPermissions: '{{ item.CreateDatabaseDefaultPermissions
        }}'
      CreateTableDefaultPermissions: '{{ item.CreateTableDefaultPermissions }}'
      Parameters: '{{ item.Parameters }}'
      TrustedResourceOwners: '{{ item.TrustedResourceOwners }}'
      AllowExternalDataFiltering: '{{ item.AllowExternalDataFiltering }}'
      AllowFullTableExternalDataAccess: '{{ item.AllowFullTableExternalDataAccess
        }}'
      ExternalDataFilteringAllowList: '{{ item.ExternalDataFilteringAllowList }}'
      AuthorizedSessionTagValueList: '{{ item.AuthorizedSessionTagValueList }}'
- discovery_id: aws.lakeformation.listDataCellsFilter
  calls:
  - action: listDataCellsFilter
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.DataCellsFilters }}'
    item:
      TableCatalogId: '{{ item.TableCatalogId }}'
      DatabaseName: '{{ item.DatabaseName }}'
      TableName: '{{ item.TableName }}'
      Name: '{{ item.Name }}'
      RowFilter: '{{ item.RowFilter }}'
      ColumnNames: '{{ item.ColumnNames }}'
      ColumnWildcard: '{{ item.ColumnWildcard }}'
      VersionId: '{{ item.VersionId }}'
- discovery_id: aws.lakeformation.listLfTagExpressions
  calls:
  - action: listLfTagExpressions
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.LFTagExpressions }}'
    item:
      Name: '{{ item.Name }}'
      Description: '{{ item.Description }}'
      CatalogId: '{{ item.CatalogId }}'
      Expression: '{{ item.Expression }}'
- discovery_id: aws.lakeformation.listLfTags
  calls:
  - action: listLfTags
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.LFTags }}'
    item:
      CatalogId: '{{ item.CatalogId }}'
      TagKey: '{{ item.TagKey }}'
      TagValues: '{{ item.TagValues }}'
- discovery_id: aws.lakeformation.listLakeFormationOptIns
  calls:
  - action: listLakeFormationOptIns
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.LakeFormationOptInsInfoList }}'
    item:
      Resource: '{{ item.Resource }}'
      Principal: '{{ item.Principal }}'
      Condition: '{{ item.Condition }}'
      LastModified: '{{ item.LastModified }}'
      LastUpdatedBy: '{{ item.LastUpdatedBy }}'
- discovery_id: aws.lakeformation.listPermissions
  calls:
  - action: listPermissions
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.PrincipalResourcePermissions }}'
    item:
      Principal: '{{ item.Principal }}'
      Resource: '{{ item.Resource }}'
      Condition: '{{ item.Condition }}'
      Permissions: '{{ item.Permissions }}'
      PermissionsWithGrantOption: '{{ item.PermissionsWithGrantOption }}'
      AdditionalDetails: '{{ item.AdditionalDetails }}'
      LastUpdated: '{{ item.LastUpdated }}'
      LastUpdatedBy: '{{ item.LastUpdatedBy }}'
- discovery_id: aws.lakeformation.listResources
  calls:
  - action: listResources
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.ResourceInfoList }}'
    item:
      ResourceArn: '{{ item.ResourceArn }}'
      RoleArn: '{{ item.RoleArn }}'
      LastModified: '{{ item.LastModified }}'
      WithFederation: '{{ item.WithFederation }}'
      HybridAccessEnabled: '{{ item.HybridAccessEnabled }}'
      WithPrivilegedAccess: '{{ item.WithPrivilegedAccess }}'
- discovery_id: aws.lakeformation.listTransactions
  calls:
  - action: listTransactions
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Transactions }}'
    item:
      TransactionId: '{{ item.TransactionId }}'
      TransactionStatus: '{{ item.TransactionStatus }}'
      TransactionStartTime: '{{ item.TransactionStartTime }}'
      TransactionEndTime: '{{ item.TransactionEndTime }}'
- discovery_id: aws.lakeformation.describeResource
  calls:
  - action: describeResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ResourceInfo }}'
    item:
      ResourceArn: '{{ item.ResourceArn }}'
      RoleArn: '{{ item.RoleArn }}'
      LastModified: '{{ item.LastModified }}'
      WithFederation: '{{ item.WithFederation }}'
      HybridAccessEnabled: '{{ item.HybridAccessEnabled }}'
      WithPrivilegedAccess: '{{ item.WithPrivilegedAccess }}'
- discovery_id: aws.lakeformation.describeTransaction
  calls:
  - action: describeTransaction
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.TransactionDescription }}'
    item:
      TransactionId: '{{ item.TransactionId }}'
      TransactionStatus: '{{ item.TransactionStatus }}'
      TransactionStartTime: '{{ item.TransactionStartTime }}'
      TransactionEndTime: '{{ item.TransactionEndTime }}'
- discovery_id: aws.lakeformation.getDataCellsFilter
  calls:
  - action: getDataCellsFilter
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.DataCellsFilter }}'
    item:
      TableCatalogId: '{{ item.TableCatalogId }}'
      DatabaseName: '{{ item.DatabaseName }}'
      TableName: '{{ item.TableName }}'
      Name: '{{ item.Name }}'
      RowFilter: '{{ item.RowFilter }}'
      ColumnNames: '{{ item.ColumnNames }}'
      ColumnWildcard: '{{ item.ColumnWildcard }}'
      VersionId: '{{ item.VersionId }}'
- discovery_id: aws.lakeformation.getEffectivePermissionsForPath
  calls:
  - action: getEffectivePermissionsForPath
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Permissions }}'
    item:
      Principal: '{{ item.Principal }}'
      Resource: '{{ item.Resource }}'
      Condition: '{{ item.Condition }}'
      Permissions: '{{ item.Permissions }}'
      PermissionsWithGrantOption: '{{ item.PermissionsWithGrantOption }}'
      AdditionalDetails: '{{ item.AdditionalDetails }}'
      LastUpdated: '{{ item.LastUpdated }}'
      LastUpdatedBy: '{{ item.LastUpdatedBy }}'
- discovery_id: aws.lakeformation.getLfTag
  calls:
  - action: getLfTag
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.TagValues }}'
- discovery_id: aws.lakeformation.getLfTagExpression
  calls:
  - action: getLfTagExpression
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Expression }}'
    item:
      TagKey: '{{ item.TagKey }}'
      TagValues: '{{ item.TagValues }}'
- discovery_id: aws.lakeformation.getQueryState
  calls:
  - action: getQueryState
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Error }}'
- discovery_id: aws.lakeformation.getQueryStatistics
  calls:
  - action: getQueryStatistics
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ExecutionStatistics }}'
    item:
      AverageExecutionTimeMillis: '{{ item.AverageExecutionTimeMillis }}'
      DataScannedBytes: '{{ item.DataScannedBytes }}'
      WorkUnitsExecutedCount: '{{ item.WorkUnitsExecutedCount }}'
- discovery_id: aws.lakeformation.getResourceLfTags
  calls:
  - action: getResourceLfTags
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.LFTagOnDatabase }}'
    item:
      CatalogId: '{{ item.CatalogId }}'
      TagKey: '{{ item.TagKey }}'
      TagValues: '{{ item.TagValues }}'
- discovery_id: aws.lakeformation.getTableObjects
  calls:
  - action: getTableObjects
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Objects }}'
    item:
      PartitionValues: '{{ item.PartitionValues }}'
      Objects: '{{ item.Objects }}'
- discovery_id: aws.lakeformation.getTemporaryGluePartitionCredentials
  calls:
  - action: getTemporaryGluePartitionCredentials
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AccessKeyId }}'
- discovery_id: aws.lakeformation.getTemporaryGlueTableCredentials
  calls:
  - action: getTemporaryGlueTableCredentials
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.VendedS3Path }}'
- discovery_id: aws.lakeformation.getWorkUnitResults
  calls:
  - action: getWorkUnitResults
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ResultStream }}'
- discovery_id: aws.lakeformation.getWorkUnits
  calls:
  - action: getWorkUnits
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.WorkUnitRanges }}'
    item:
      WorkUnitIdMax: '{{ item.WorkUnitIdMax }}'
      WorkUnitIdMin: '{{ item.WorkUnitIdMin }}'
      WorkUnitToken: '{{ item.WorkUnitToken }}'
- discovery_id: aws.lakeformation.listTableStorageOptimizers
  calls:
  - action: listTableStorageOptimizers
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.StorageOptimizerList }}'
    item:
      StorageOptimizerType: '{{ item.StorageOptimizerType }}'
      Config: '{{ item.Config }}'
      ErrorMessage: '{{ item.ErrorMessage }}'
      Warnings: '{{ item.Warnings }}'
      LastRunDetails: '{{ item.LastRunDetails }}'
- discovery_id: aws.lakeformation.searchDatabasesByLfTags
  calls:
  - action: searchDatabasesByLfTags
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.DatabaseList }}'
    item:
      Database: '{{ item.Database }}'
      LFTags: '{{ item.LFTags }}'
- discovery_id: aws.lakeformation.searchTablesByLfTags
  calls:
  - action: searchTablesByLfTags
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.TableList }}'
    item:
      Table: '{{ item.Table }}'
      LFTagOnDatabase: '{{ item.LFTagOnDatabase }}'
      LFTagsOnTable: '{{ item.LFTagsOnTable }}'
      LFTagsOnColumns: '{{ item.LFTagsOnColumns }}'
checks: []
