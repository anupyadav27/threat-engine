version: '1.0'
provider: aws
service: route53
services:
  client: route53
  module: boto3.client
discovery:
- discovery_id: aws.route53.getCheckerIpRanges
  calls:
  - action: getCheckerIpRanges
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.CheckerIpRanges }}'
- discovery_id: aws.route53.getGeoLocation
  calls:
  - action: getGeoLocation
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.GeoLocationDetails }}'
    item:
      ContinentCode: '{{ item.ContinentCode }}'
      ContinentName: '{{ item.ContinentName }}'
      CountryCode: '{{ item.CountryCode }}'
      CountryName: '{{ item.CountryName }}'
      SubdivisionCode: '{{ item.SubdivisionCode }}'
      SubdivisionName: '{{ item.SubdivisionName }}'
- discovery_id: aws.route53.getHealthCheckCount
  calls:
  - action: getHealthCheckCount
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.HealthCheckCount }}'
- discovery_id: aws.route53.getHostedZoneCount
  calls:
  - action: getHostedZoneCount
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.HostedZoneCount }}'
- discovery_id: aws.route53.getTrafficPolicyInstanceCount
  calls:
  - action: getTrafficPolicyInstanceCount
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.TrafficPolicyInstanceCount }}'
- discovery_id: aws.route53.listCidrCollections
  calls:
  - action: listCidrCollections
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.CidrCollections }}'
    item:
      Arn: '{{ item.Arn }}'
      Id: '{{ item.Id }}'
      Name: '{{ item.Name }}'
      Version: '{{ item.Version }}'
- discovery_id: aws.route53.listGeoLocations
  calls:
  - action: listGeoLocations
    save_as: response
    on_error: continue
    params:
      MaxItems: 1000
  emit:
    as: item
    items_for: '{{ response.GeoLocationDetailsList }}'
    item:
      ContinentCode: '{{ item.ContinentCode }}'
      ContinentName: '{{ item.ContinentName }}'
      CountryCode: '{{ item.CountryCode }}'
      CountryName: '{{ item.CountryName }}'
      SubdivisionCode: '{{ item.SubdivisionCode }}'
      SubdivisionName: '{{ item.SubdivisionName }}'
- discovery_id: aws.route53.listHealthChecks
  calls:
  - action: listHealthChecks
    save_as: response
    on_error: continue
    params:
      MaxItems: 1000
  emit:
    as: item
    items_for: '{{ response.HealthChecks }}'
    item:
      Id: '{{ item.Id }}'
      CallerReference: '{{ item.CallerReference }}'
      LinkedService: '{{ item.LinkedService }}'
      HealthCheckConfig: '{{ item.HealthCheckConfig }}'
      HealthCheckVersion: '{{ item.HealthCheckVersion }}'
      CloudWatchAlarmConfiguration: '{{ item.CloudWatchAlarmConfiguration }}'
- discovery_id: aws.route53.listHostedZones
  calls:
  - action: listHostedZones
    save_as: response
    on_error: continue
    params:
      MaxItems: 1000
  emit:
    as: item
    items_for: '{{ response.HostedZones }}'
    item:
      Id: '{{ item.Id }}'
      Name: '{{ item.Name }}'
      CallerReference: '{{ item.CallerReference }}'
      Config: '{{ item.Config }}'
      ResourceRecordSetCount: '{{ item.ResourceRecordSetCount }}'
      LinkedService: '{{ item.LinkedService }}'
      Features: '{{ item.Features }}'
- discovery_id: aws.route53.listHostedZonesByName
  calls:
  - action: listHostedZonesByName
    save_as: response
    on_error: continue
    params:
      MaxItems: 1000
  emit:
    as: item
    items_for: '{{ response.HostedZones }}'
    item:
      Id: '{{ item.Id }}'
      Name: '{{ item.Name }}'
      CallerReference: '{{ item.CallerReference }}'
      Config: '{{ item.Config }}'
      ResourceRecordSetCount: '{{ item.ResourceRecordSetCount }}'
      LinkedService: '{{ item.LinkedService }}'
      Features: '{{ item.Features }}'
- discovery_id: aws.route53.listQueryLoggingConfigs
  calls:
  - action: listQueryLoggingConfigs
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.QueryLoggingConfigs }}'
    item:
      Id: '{{ item.Id }}'
      HostedZoneId: '{{ item.HostedZoneId }}'
      CloudWatchLogsLogGroupArn: '{{ item.CloudWatchLogsLogGroupArn }}'
- discovery_id: aws.route53.listReusableDelegationSets
  calls:
  - action: listReusableDelegationSets
    save_as: response
    on_error: continue
    params:
      MaxItems: 1000
  emit:
    as: item
    items_for: '{{ response.DelegationSets }}'
    item:
      Id: '{{ item.Id }}'
      CallerReference: '{{ item.CallerReference }}'
      NameServers: '{{ item.NameServers }}'
- discovery_id: aws.route53.listTrafficPolicies
  calls:
  - action: listTrafficPolicies
    save_as: response
    on_error: continue
    params:
      MaxItems: 1000
  emit:
    as: item
    items_for: '{{ response.TrafficPolicySummaries }}'
    item:
      Id: '{{ item.Id }}'
      Name: '{{ item.Name }}'
      Type: '{{ item.Type }}'
      LatestVersion: '{{ item.LatestVersion }}'
      TrafficPolicyCount: '{{ item.TrafficPolicyCount }}'
- discovery_id: aws.route53.listTrafficPolicyInstances
  calls:
  - action: listTrafficPolicyInstances
    save_as: response
    on_error: continue
    params:
      MaxItems: 1000
  emit:
    as: item
    items_for: '{{ response.TrafficPolicyInstances }}'
    item:
      Id: '{{ item.Id }}'
      HostedZoneId: '{{ item.HostedZoneId }}'
      Name: '{{ item.Name }}'
      TTL: '{{ item.TTL }}'
      State: '{{ item.State }}'
      Message: '{{ item.Message }}'
      TrafficPolicyId: '{{ item.TrafficPolicyId }}'
      TrafficPolicyVersion: '{{ item.TrafficPolicyVersion }}'
      TrafficPolicyType: '{{ item.TrafficPolicyType }}'
- discovery_id: aws.route53.getAccountLimit
  calls:
  - action: getAccountLimit
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Limit }}'
    item:
      Type: '{{ item.Type }}'
      Value: '{{ item.Value }}'
- discovery_id: aws.route53.getChange
  calls:
  - action: getChange
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ChangeInfo }}'
    item:
      Id: '{{ item.Id }}'
      Status: '{{ item.Status }}'
      SubmittedAt: '{{ item.SubmittedAt }}'
      Comment: '{{ item.Comment }}'
- discovery_id: aws.route53.getDnssec
  calls:
  - action: getDnssec
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.KeySigningKeys }}'
    item:
      Name: '{{ item.Name }}'
      KmsArn: '{{ item.KmsArn }}'
      Flag: '{{ item.Flag }}'
      SigningAlgorithmMnemonic: '{{ item.SigningAlgorithmMnemonic }}'
      SigningAlgorithmType: '{{ item.SigningAlgorithmType }}'
      DigestAlgorithmMnemonic: '{{ item.DigestAlgorithmMnemonic }}'
      DigestAlgorithmType: '{{ item.DigestAlgorithmType }}'
      KeyTag: '{{ item.KeyTag }}'
      DigestValue: '{{ item.DigestValue }}'
      PublicKey: '{{ item.PublicKey }}'
      DSRecord: '{{ item.DSRecord }}'
      DNSKEYRecord: '{{ item.DNSKEYRecord }}'
      Status: '{{ item.Status }}'
      StatusMessage: '{{ item.StatusMessage }}'
      CreatedDate: '{{ item.CreatedDate }}'
      LastModifiedDate: '{{ item.LastModifiedDate }}'
- discovery_id: aws.route53.getHealthCheck
  calls:
  - action: getHealthCheck
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.HealthCheck }}'
    item:
      Id: '{{ item.Id }}'
      CallerReference: '{{ item.CallerReference }}'
      LinkedService: '{{ item.LinkedService }}'
      HealthCheckConfig: '{{ item.HealthCheckConfig }}'
      HealthCheckVersion: '{{ item.HealthCheckVersion }}'
      CloudWatchAlarmConfiguration: '{{ item.CloudWatchAlarmConfiguration }}'
- discovery_id: aws.route53.getHealthCheckLastFailureReason
  calls:
  - action: getHealthCheckLastFailureReason
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.HealthCheckObservations }}'
    item:
      Region: '{{ item.Region }}'
      IPAddress: '{{ item.IPAddress }}'
      StatusReport: '{{ item.StatusReport }}'
- discovery_id: aws.route53.getHealthCheckStatus
  calls:
  - action: getHealthCheckStatus
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.HealthCheckObservations }}'
    item:
      Region: '{{ item.Region }}'
      IPAddress: '{{ item.IPAddress }}'
      StatusReport: '{{ item.StatusReport }}'
- discovery_id: aws.route53.getHostedZone
  calls:
  - action: getHostedZone
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.VPCs }}'
    item:
      VPCRegion: '{{ item.VPCRegion }}'
      VPCId: '{{ item.VPCId }}'
- discovery_id: aws.route53.getHostedZoneLimit
  calls:
  - action: getHostedZoneLimit
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Limit }}'
    item:
      Type: '{{ item.Type }}'
      Value: '{{ item.Value }}'
- discovery_id: aws.route53.getQueryLoggingConfig
  calls:
  - action: getQueryLoggingConfig
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.QueryLoggingConfig }}'
    item:
      Id: '{{ item.Id }}'
      HostedZoneId: '{{ item.HostedZoneId }}'
      CloudWatchLogsLogGroupArn: '{{ item.CloudWatchLogsLogGroupArn }}'
- discovery_id: aws.route53.getReusableDelegationSet
  calls:
  - action: getReusableDelegationSet
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.DelegationSet }}'
    item:
      Id: '{{ item.Id }}'
      CallerReference: '{{ item.CallerReference }}'
      NameServers: '{{ item.NameServers }}'
- discovery_id: aws.route53.getReusableDelegationSetLimit
  calls:
  - action: getReusableDelegationSetLimit
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Limit }}'
    item:
      Type: '{{ item.Type }}'
      Value: '{{ item.Value }}'
- discovery_id: aws.route53.getTrafficPolicy
  calls:
  - action: getTrafficPolicy
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.TrafficPolicy }}'
    item:
      Id: '{{ item.Id }}'
      Version: '{{ item.Version }}'
      Name: '{{ item.Name }}'
      Type: '{{ item.Type }}'
      Document: '{{ item.Document }}'
      Comment: '{{ item.Comment }}'
- discovery_id: aws.route53.getTrafficPolicyInstance
  calls:
  - action: getTrafficPolicyInstance
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.TrafficPolicyInstance }}'
    item:
      Id: '{{ item.Id }}'
      HostedZoneId: '{{ item.HostedZoneId }}'
      Name: '{{ item.Name }}'
      TTL: '{{ item.TTL }}'
      State: '{{ item.State }}'
      Message: '{{ item.Message }}'
      TrafficPolicyId: '{{ item.TrafficPolicyId }}'
      TrafficPolicyVersion: '{{ item.TrafficPolicyVersion }}'
      TrafficPolicyType: '{{ item.TrafficPolicyType }}'
- discovery_id: aws.route53.listCidrBlocks
  calls:
  - action: listCidrBlocks
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.CidrBlocks }}'
    item:
      CidrBlock: '{{ item.CidrBlock }}'
      LocationName: '{{ item.LocationName }}'
- discovery_id: aws.route53.listCidrLocations
  calls:
  - action: listCidrLocations
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.CidrLocations }}'
    item:
      LocationName: '{{ item.LocationName }}'
- discovery_id: aws.route53.listHostedZonesByVpc
  calls:
  - action: listHostedZonesByVpc
    save_as: response
    on_error: continue
    params:
      MaxItems: 1000
  emit:
    as: item
    items_for: '{{ response.HostedZoneSummaries }}'
    item:
      HostedZoneId: '{{ item.HostedZoneId }}'
      Name: '{{ item.Name }}'
      Owner: '{{ item.Owner }}'
- discovery_id: aws.route53.listResourceRecordSets
  calls:
  - action: listResourceRecordSets
    save_as: response
    on_error: continue
    params:
      MaxItems: 1000
  emit:
    as: item
    items_for: '{{ response.ResourceRecordSets }}'
    item:
      Name: '{{ item.Name }}'
      Type: '{{ item.Type }}'
      SetIdentifier: '{{ item.SetIdentifier }}'
      Weight: '{{ item.Weight }}'
      Region: '{{ item.Region }}'
      GeoLocation: '{{ item.GeoLocation }}'
      Failover: '{{ item.Failover }}'
      MultiValueAnswer: '{{ item.MultiValueAnswer }}'
      TTL: '{{ item.TTL }}'
      ResourceRecords: '{{ item.ResourceRecords }}'
      AliasTarget: '{{ item.AliasTarget }}'
      HealthCheckId: '{{ item.HealthCheckId }}'
      TrafficPolicyInstanceId: '{{ item.TrafficPolicyInstanceId }}'
      CidrRoutingConfig: '{{ item.CidrRoutingConfig }}'
      GeoProximityLocation: '{{ item.GeoProximityLocation }}'
- discovery_id: aws.route53.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ResourceTagSet }}'
    item:
      ResourceType: '{{ item.ResourceType }}'
      ResourceId: '{{ item.ResourceId }}'
      Tags: '{{ item.Tags }}'
- discovery_id: aws.route53.listTagsForResources
  calls:
  - action: listTagsForResources
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ResourceTagSets }}'
    item:
      ResourceType: '{{ item.ResourceType }}'
      ResourceId: '{{ item.ResourceId }}'
      Tags: '{{ item.Tags }}'
- discovery_id: aws.route53.listTrafficPolicyInstancesByHostedZone
  calls:
  - action: listTrafficPolicyInstancesByHostedZone
    save_as: response
    on_error: continue
    params:
      MaxItems: 1000
  emit:
    as: item
    items_for: '{{ response.TrafficPolicyInstances }}'
    item:
      Id: '{{ item.Id }}'
      HostedZoneId: '{{ item.HostedZoneId }}'
      Name: '{{ item.Name }}'
      TTL: '{{ item.TTL }}'
      State: '{{ item.State }}'
      Message: '{{ item.Message }}'
      TrafficPolicyId: '{{ item.TrafficPolicyId }}'
      TrafficPolicyVersion: '{{ item.TrafficPolicyVersion }}'
      TrafficPolicyType: '{{ item.TrafficPolicyType }}'
- discovery_id: aws.route53.listTrafficPolicyInstancesByPolicy
  calls:
  - action: listTrafficPolicyInstancesByPolicy
    save_as: response
    on_error: continue
    params:
      MaxItems: 1000
  emit:
    as: item
    items_for: '{{ response.TrafficPolicyInstances }}'
    item:
      Id: '{{ item.Id }}'
      HostedZoneId: '{{ item.HostedZoneId }}'
      Name: '{{ item.Name }}'
      TTL: '{{ item.TTL }}'
      State: '{{ item.State }}'
      Message: '{{ item.Message }}'
      TrafficPolicyId: '{{ item.TrafficPolicyId }}'
      TrafficPolicyVersion: '{{ item.TrafficPolicyVersion }}'
      TrafficPolicyType: '{{ item.TrafficPolicyType }}'
- discovery_id: aws.route53.listTrafficPolicyVersions
  calls:
  - action: listTrafficPolicyVersions
    save_as: response
    on_error: continue
    params:
      MaxItems: 1000
  emit:
    as: item
    items_for: '{{ response.TrafficPolicies }}'
    item:
      Id: '{{ item.Id }}'
      Version: '{{ item.Version }}'
      Name: '{{ item.Name }}'
      Type: '{{ item.Type }}'
      Document: '{{ item.Document }}'
      Comment: '{{ item.Comment }}'
- discovery_id: aws.route53.listVpcAssociationAuthorizations
  calls:
  - action: listVpcAssociationAuthorizations
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.VPCs }}'
    item:
      VPCRegion: '{{ item.VPCRegion }}'
      VPCId: '{{ item.VPCId }}'
checks: []
