version: '1.0'
provider: aws
service: bcm-recommended-actions
services:
  client: bcm-recommended-actions
  module: boto3.client
discovery:
- discovery_id: aws.bcm-recommended-actions.listRecommendedActions
  calls:
  - action: listRecommendedActions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.recommendedActions }}'
    item:
      id: '{{ item.id }}'
      type: '{{ item.type }}'
      accountId: '{{ item.accountId }}'
      severity: '{{ item.severity }}'
      feature: '{{ item.feature }}'
      context: '{{ item.context }}'
      nextSteps: '{{ item.nextSteps }}'
      lastUpdatedTimeStamp: '{{ item.lastUpdatedTimeStamp }}'
checks: []
