version: '1.0'
provider: aws
service: panorama
services:
  client: panorama
  module: boto3.client
discovery:
- discovery_id: aws.panorama.listApplicationInstances
  calls:
  - action: listApplicationInstances
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.ApplicationInstances }}'
    item:
      ApplicationInstanceId: '{{ item.ApplicationInstanceId }}'
      Arn: '{{ item.Arn }}'
      CreatedTime: '{{ item.CreatedTime }}'
      DefaultRuntimeContextDevice: '{{ item.DefaultRuntimeContextDevice }}'
      DefaultRuntimeContextDeviceName: '{{ item.DefaultRuntimeContextDeviceName }}'
      Description: '{{ item.Description }}'
      HealthStatus: '{{ item.HealthStatus }}'
      Name: '{{ item.Name }}'
      RuntimeContextStates: '{{ item.RuntimeContextStates }}'
      Status: '{{ item.Status }}'
      StatusDescription: '{{ item.StatusDescription }}'
      Tags: '{{ item.Tags }}'
- discovery_id: aws.panorama.listDevices
  calls:
  - action: listDevices
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Devices }}'
    item:
      Brand: '{{ item.Brand }}'
      CreatedTime: '{{ item.CreatedTime }}'
      CurrentSoftware: '{{ item.CurrentSoftware }}'
      Description: '{{ item.Description }}'
      DeviceAggregatedStatus: '{{ item.DeviceAggregatedStatus }}'
      DeviceId: '{{ item.DeviceId }}'
      LastUpdatedTime: '{{ item.LastUpdatedTime }}'
      LatestDeviceJob: '{{ item.LatestDeviceJob }}'
      LeaseExpirationTime: '{{ item.LeaseExpirationTime }}'
      Name: '{{ item.Name }}'
      ProvisioningStatus: '{{ item.ProvisioningStatus }}'
      Tags: '{{ item.Tags }}'
      Type: '{{ item.Type }}'
- discovery_id: aws.panorama.listDevicesJobs
  calls:
  - action: listDevicesJobs
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.DeviceJobs }}'
    item:
      CreatedTime: '{{ item.CreatedTime }}'
      DeviceId: '{{ item.DeviceId }}'
      DeviceName: '{{ item.DeviceName }}'
      JobId: '{{ item.JobId }}'
      JobType: '{{ item.JobType }}'
- discovery_id: aws.panorama.listNodeFromTemplateJobs
  calls:
  - action: listNodeFromTemplateJobs
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.NodeFromTemplateJobs }}'
    item:
      CreatedTime: '{{ item.CreatedTime }}'
      JobId: '{{ item.JobId }}'
      NodeName: '{{ item.NodeName }}'
      Status: '{{ item.Status }}'
      StatusMessage: '{{ item.StatusMessage }}'
      TemplateType: '{{ item.TemplateType }}'
- discovery_id: aws.panorama.listNodes
  calls:
  - action: listNodes
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Nodes }}'
    item:
      Category: '{{ item.Category }}'
      CreatedTime: '{{ item.CreatedTime }}'
      Description: '{{ item.Description }}'
      Name: '{{ item.Name }}'
      NodeId: '{{ item.NodeId }}'
      OwnerAccount: '{{ item.OwnerAccount }}'
      PackageArn: '{{ item.PackageArn }}'
      PackageId: '{{ item.PackageId }}'
      PackageName: '{{ item.PackageName }}'
      PackageVersion: '{{ item.PackageVersion }}'
      PatchVersion: '{{ item.PatchVersion }}'
- discovery_id: aws.panorama.listPackageImportJobs
  calls:
  - action: listPackageImportJobs
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.PackageImportJobs }}'
    item:
      CreatedTime: '{{ item.CreatedTime }}'
      JobId: '{{ item.JobId }}'
      JobType: '{{ item.JobType }}'
      LastUpdatedTime: '{{ item.LastUpdatedTime }}'
      Status: '{{ item.Status }}'
      StatusMessage: '{{ item.StatusMessage }}'
- discovery_id: aws.panorama.listPackages
  calls:
  - action: listPackages
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Packages }}'
    item:
      Arn: '{{ item.Arn }}'
      CreatedTime: '{{ item.CreatedTime }}'
      PackageId: '{{ item.PackageId }}'
      PackageName: '{{ item.PackageName }}'
      Tags: '{{ item.Tags }}'
- discovery_id: aws.panorama.describeApplicationInstance
  calls:
  - action: describeApplicationInstance
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.RuntimeContextStates }}'
    item:
      DesiredState: '{{ item.DesiredState }}'
      DeviceReportedStatus: '{{ item.DeviceReportedStatus }}'
      DeviceReportedTime: '{{ item.DeviceReportedTime }}'
      RuntimeContextName: '{{ item.RuntimeContextName }}'
- discovery_id: aws.panorama.describeApplicationInstanceDetails
  calls:
  - action: describeApplicationInstanceDetails
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ManifestOverridesPayload }}'
    item:
      PayloadData: '{{ item.PayloadData }}'
- discovery_id: aws.panorama.describeDevice
  calls:
  - action: describeDevice
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AlternateSoftwares }}'
    item:
      Version: '{{ item.Version }}'
- discovery_id: aws.panorama.describeDeviceJob
  calls:
  - action: describeDeviceJob
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.CreatedTime }}'
- discovery_id: aws.panorama.describeNode
  calls:
  - action: describeNode
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.NodeInterface }}'
    item:
      Inputs: '{{ item.Inputs }}'
      Outputs: '{{ item.Outputs }}'
- discovery_id: aws.panorama.describeNodeFromTemplateJob
  calls:
  - action: describeNodeFromTemplateJob
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.JobTags }}'
    item:
      ResourceType: '{{ item.ResourceType }}'
      Tags: '{{ item.Tags }}'
- discovery_id: aws.panorama.describePackage
  calls:
  - action: describePackage
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ReadAccessPrincipalArns }}'
- discovery_id: aws.panorama.describePackageImportJob
  calls:
  - action: describePackageImportJob
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.JobTags }}'
    item:
      ResourceType: '{{ item.ResourceType }}'
      Tags: '{{ item.Tags }}'
- discovery_id: aws.panorama.describePackageVersion
  calls:
  - action: describePackageVersion
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.IsLatestPatch }}'
- discovery_id: aws.panorama.listApplicationInstanceDependencies
  calls:
  - action: listApplicationInstanceDependencies
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.PackageObjects }}'
    item:
      Name: '{{ item.Name }}'
      PackageVersion: '{{ item.PackageVersion }}'
      PatchVersion: '{{ item.PatchVersion }}'
- discovery_id: aws.panorama.listApplicationInstanceNodeInstances
  calls:
  - action: listApplicationInstanceNodeInstances
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.NodeInstances }}'
    item:
      CurrentStatus: '{{ item.CurrentStatus }}'
      NodeId: '{{ item.NodeId }}'
      NodeInstanceId: '{{ item.NodeInstanceId }}'
      NodeName: '{{ item.NodeName }}'
      PackageName: '{{ item.PackageName }}'
      PackagePatchVersion: '{{ item.PackagePatchVersion }}'
      PackageVersion: '{{ item.PackageVersion }}'
- discovery_id: aws.panorama.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Tags }}'
checks: []
