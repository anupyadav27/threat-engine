version: '1.0'
provider: aws
service: cognito-idp
services:
  client: cognito-idp
  module: boto3.client
discovery:
- discovery_id: aws.cognito-idp.describeIdentityProvider
  calls:
  - action: describeIdentityProvider
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.IdentityProvider }}'
    item:
      UserPoolId: '{{ item.UserPoolId }}'
      ProviderName: '{{ item.ProviderName }}'
      ProviderType: '{{ item.ProviderType }}'
      ProviderDetails: '{{ item.ProviderDetails }}'
      AttributeMapping: '{{ item.AttributeMapping }}'
      IdpIdentifiers: '{{ item.IdpIdentifiers }}'
      LastModifiedDate: '{{ item.LastModifiedDate }}'
      CreationDate: '{{ item.CreationDate }}'
- discovery_id: aws.cognito-idp.describeManagedLoginBranding
  calls:
  - action: describeManagedLoginBranding
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ManagedLoginBranding }}'
    item:
      ManagedLoginBrandingId: '{{ item.ManagedLoginBrandingId }}'
      UserPoolId: '{{ item.UserPoolId }}'
      UseCognitoProvidedValues: '{{ item.UseCognitoProvidedValues }}'
      Settings: '{{ item.Settings }}'
      Assets: '{{ item.Assets }}'
      CreationDate: '{{ item.CreationDate }}'
      LastModifiedDate: '{{ item.LastModifiedDate }}'
- discovery_id: aws.cognito-idp.describeManagedLoginBrandingByClient
  calls:
  - action: describeManagedLoginBrandingByClient
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ManagedLoginBranding }}'
    item:
      ManagedLoginBrandingId: '{{ item.ManagedLoginBrandingId }}'
      UserPoolId: '{{ item.UserPoolId }}'
      UseCognitoProvidedValues: '{{ item.UseCognitoProvidedValues }}'
      Settings: '{{ item.Settings }}'
      Assets: '{{ item.Assets }}'
      CreationDate: '{{ item.CreationDate }}'
      LastModifiedDate: '{{ item.LastModifiedDate }}'
- discovery_id: aws.cognito-idp.describeResourceServer
  calls:
  - action: describeResourceServer
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ResourceServer }}'
    item:
      UserPoolId: '{{ item.UserPoolId }}'
      Identifier: '{{ item.Identifier }}'
      Name: '{{ item.Name }}'
      Scopes: '{{ item.Scopes }}'
- discovery_id: aws.cognito-idp.describeRiskConfiguration
  calls:
  - action: describeRiskConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.RiskConfiguration }}'
    item:
      UserPoolId: '{{ item.UserPoolId }}'
      ClientId: '{{ item.ClientId }}'
      CompromisedCredentialsRiskConfiguration: '{{ item.CompromisedCredentialsRiskConfiguration
        }}'
      AccountTakeoverRiskConfiguration: '{{ item.AccountTakeoverRiskConfiguration
        }}'
      RiskExceptionConfiguration: '{{ item.RiskExceptionConfiguration }}'
      LastModifiedDate: '{{ item.LastModifiedDate }}'
- discovery_id: aws.cognito-idp.describeTerms
  calls:
  - action: describeTerms
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Terms }}'
    item:
      TermsId: '{{ item.TermsId }}'
      UserPoolId: '{{ item.UserPoolId }}'
      ClientId: '{{ item.ClientId }}'
      TermsName: '{{ item.TermsName }}'
      TermsSource: '{{ item.TermsSource }}'
      Enforcement: '{{ item.Enforcement }}'
      Links: '{{ item.Links }}'
      CreationDate: '{{ item.CreationDate }}'
      LastModifiedDate: '{{ item.LastModifiedDate }}'
- discovery_id: aws.cognito-idp.describeUserImportJob
  calls:
  - action: describeUserImportJob
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.UserImportJob }}'
    item:
      JobName: '{{ item.JobName }}'
      JobId: '{{ item.JobId }}'
      UserPoolId: '{{ item.UserPoolId }}'
      PreSignedUrl: '{{ item.PreSignedUrl }}'
      CreationDate: '{{ item.CreationDate }}'
      StartDate: '{{ item.StartDate }}'
      CompletionDate: '{{ item.CompletionDate }}'
      Status: '{{ item.Status }}'
      CloudWatchLogsRoleArn: '{{ item.CloudWatchLogsRoleArn }}'
      ImportedUsers: '{{ item.ImportedUsers }}'
      SkippedUsers: '{{ item.SkippedUsers }}'
      FailedUsers: '{{ item.FailedUsers }}'
      CompletionMessage: '{{ item.CompletionMessage }}'
- discovery_id: aws.cognito-idp.describeUserPool
  calls:
  - action: describeUserPool
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.UserPool }}'
    item:
      Id: '{{ item.Id }}'
      Name: '{{ item.Name }}'
      Policies: '{{ item.Policies }}'
      DeletionProtection: '{{ item.DeletionProtection }}'
      LambdaConfig: '{{ item.LambdaConfig }}'
      Status: '{{ item.Status }}'
      LastModifiedDate: '{{ item.LastModifiedDate }}'
      CreationDate: '{{ item.CreationDate }}'
      SchemaAttributes: '{{ item.SchemaAttributes }}'
      AutoVerifiedAttributes: '{{ item.AutoVerifiedAttributes }}'
      AliasAttributes: '{{ item.AliasAttributes }}'
      UsernameAttributes: '{{ item.UsernameAttributes }}'
      SmsVerificationMessage: '{{ item.SmsVerificationMessage }}'
      EmailVerificationMessage: '{{ item.EmailVerificationMessage }}'
      EmailVerificationSubject: '{{ item.EmailVerificationSubject }}'
      VerificationMessageTemplate: '{{ item.VerificationMessageTemplate }}'
      SmsAuthenticationMessage: '{{ item.SmsAuthenticationMessage }}'
      UserAttributeUpdateSettings: '{{ item.UserAttributeUpdateSettings }}'
      MfaConfiguration: '{{ item.MfaConfiguration }}'
      DeviceConfiguration: '{{ item.DeviceConfiguration }}'
      EstimatedNumberOfUsers: '{{ item.EstimatedNumberOfUsers }}'
      EmailConfiguration: '{{ item.EmailConfiguration }}'
      SmsConfiguration: '{{ item.SmsConfiguration }}'
      UserPoolTags: '{{ item.UserPoolTags }}'
      SmsConfigurationFailure: '{{ item.SmsConfigurationFailure }}'
      EmailConfigurationFailure: '{{ item.EmailConfigurationFailure }}'
      Domain: '{{ item.Domain }}'
      CustomDomain: '{{ item.CustomDomain }}'
      AdminCreateUserConfig: '{{ item.AdminCreateUserConfig }}'
      UserPoolAddOns: '{{ item.UserPoolAddOns }}'
      UsernameConfiguration: '{{ item.UsernameConfiguration }}'
      Arn: '{{ item.Arn }}'
      AccountRecoverySetting: '{{ item.AccountRecoverySetting }}'
      UserPoolTier: '{{ item.UserPoolTier }}'
- discovery_id: aws.cognito-idp.describeUserPoolClient
  calls:
  - action: describeUserPoolClient
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.UserPoolClient }}'
    item:
      UserPoolId: '{{ item.UserPoolId }}'
      ClientName: '{{ item.ClientName }}'
      ClientId: '{{ item.ClientId }}'
      ClientSecret: '{{ item.ClientSecret }}'
      LastModifiedDate: '{{ item.LastModifiedDate }}'
      CreationDate: '{{ item.CreationDate }}'
      RefreshTokenValidity: '{{ item.RefreshTokenValidity }}'
      AccessTokenValidity: '{{ item.AccessTokenValidity }}'
      IdTokenValidity: '{{ item.IdTokenValidity }}'
      TokenValidityUnits: '{{ item.TokenValidityUnits }}'
      ReadAttributes: '{{ item.ReadAttributes }}'
      WriteAttributes: '{{ item.WriteAttributes }}'
      ExplicitAuthFlows: '{{ item.ExplicitAuthFlows }}'
      SupportedIdentityProviders: '{{ item.SupportedIdentityProviders }}'
      CallbackURLs: '{{ item.CallbackURLs }}'
      LogoutURLs: '{{ item.LogoutURLs }}'
      DefaultRedirectURI: '{{ item.DefaultRedirectURI }}'
      AllowedOAuthFlows: '{{ item.AllowedOAuthFlows }}'
      AllowedOAuthScopes: '{{ item.AllowedOAuthScopes }}'
      AllowedOAuthFlowsUserPoolClient: '{{ item.AllowedOAuthFlowsUserPoolClient }}'
      AnalyticsConfiguration: '{{ item.AnalyticsConfiguration }}'
      PreventUserExistenceErrors: '{{ item.PreventUserExistenceErrors }}'
      EnableTokenRevocation: '{{ item.EnableTokenRevocation }}'
      EnablePropagateAdditionalUserContextData: '{{ item.EnablePropagateAdditionalUserContextData
        }}'
      AuthSessionValidity: '{{ item.AuthSessionValidity }}'
      RefreshTokenRotation: '{{ item.RefreshTokenRotation }}'
- discovery_id: aws.cognito-idp.describeUserPoolDomain
  calls:
  - action: describeUserPoolDomain
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.DomainDescription }}'
    item:
      UserPoolId: '{{ item.UserPoolId }}'
      AWSAccountId: '{{ item.AWSAccountId }}'
      Domain: '{{ item.Domain }}'
      S3Bucket: '{{ item.S3Bucket }}'
      CloudFrontDistribution: '{{ item.CloudFrontDistribution }}'
      Version: '{{ item.Version }}'
      Status: '{{ item.Status }}'
      CustomDomainConfig: '{{ item.CustomDomainConfig }}'
      ManagedLoginVersion: '{{ item.ManagedLoginVersion }}'
- discovery_id: aws.cognito-idp.getCsvHeader
  calls:
  - action: getCsvHeader
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.CSVHeader }}'
- discovery_id: aws.cognito-idp.getDevice
  calls:
  - action: getDevice
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Device }}'
    item:
      DeviceKey: '{{ item.DeviceKey }}'
      DeviceAttributes: '{{ item.DeviceAttributes }}'
      DeviceCreateDate: '{{ item.DeviceCreateDate }}'
      DeviceLastModifiedDate: '{{ item.DeviceLastModifiedDate }}'
      DeviceLastAuthenticatedDate: '{{ item.DeviceLastAuthenticatedDate }}'
- discovery_id: aws.cognito-idp.getGroup
  calls:
  - action: getGroup
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Group }}'
    item:
      GroupName: '{{ item.GroupName }}'
      UserPoolId: '{{ item.UserPoolId }}'
      Description: '{{ item.Description }}'
      RoleArn: '{{ item.RoleArn }}'
      Precedence: '{{ item.Precedence }}'
      LastModifiedDate: '{{ item.LastModifiedDate }}'
      CreationDate: '{{ item.CreationDate }}'
- discovery_id: aws.cognito-idp.getIdentityProviderByIdentifier
  calls:
  - action: getIdentityProviderByIdentifier
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.IdentityProvider }}'
    item:
      UserPoolId: '{{ item.UserPoolId }}'
      ProviderName: '{{ item.ProviderName }}'
      ProviderType: '{{ item.ProviderType }}'
      ProviderDetails: '{{ item.ProviderDetails }}'
      AttributeMapping: '{{ item.AttributeMapping }}'
      IdpIdentifiers: '{{ item.IdpIdentifiers }}'
      LastModifiedDate: '{{ item.LastModifiedDate }}'
      CreationDate: '{{ item.CreationDate }}'
- discovery_id: aws.cognito-idp.getLogDeliveryConfiguration
  calls:
  - action: getLogDeliveryConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.LogDeliveryConfiguration }}'
    item:
      UserPoolId: '{{ item.UserPoolId }}'
      LogConfigurations: '{{ item.LogConfigurations }}'
- discovery_id: aws.cognito-idp.getSigningCertificate
  calls:
  - action: getSigningCertificate
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Certificate }}'
- discovery_id: aws.cognito-idp.getTokensFromRefreshToken
  calls:
  - action: getTokensFromRefreshToken
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AuthenticationResult }}'
    item:
      AccessToken: '{{ item.AccessToken }}'
      ExpiresIn: '{{ item.ExpiresIn }}'
      TokenType: '{{ item.TokenType }}'
      RefreshToken: '{{ item.RefreshToken }}'
      IdToken: '{{ item.IdToken }}'
      NewDeviceMetadata: '{{ item.NewDeviceMetadata }}'
- discovery_id: aws.cognito-idp.getUiCustomization
  calls:
  - action: getUiCustomization
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.UICustomization }}'
    item:
      UserPoolId: '{{ item.UserPoolId }}'
      ClientId: '{{ item.ClientId }}'
      ImageUrl: '{{ item.ImageUrl }}'
      CSS: '{{ item.CSS }}'
      CSSVersion: '{{ item.CSSVersion }}'
      LastModifiedDate: '{{ item.LastModifiedDate }}'
      CreationDate: '{{ item.CreationDate }}'
- discovery_id: aws.cognito-idp.getUser
  calls:
  - action: getUser
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.UserMFASettingList }}'
- discovery_id: aws.cognito-idp.getUserAttributeVerificationCode
  calls:
  - action: getUserAttributeVerificationCode
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.CodeDeliveryDetails }}'
    item:
      Destination: '{{ item.Destination }}'
      DeliveryMedium: '{{ item.DeliveryMedium }}'
      AttributeName: '{{ item.AttributeName }}'
- discovery_id: aws.cognito-idp.getUserAuthFactors
  calls:
  - action: getUserAuthFactors
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.UserMFASettingList }}'
- discovery_id: aws.cognito-idp.getUserPoolMfaConfig
  calls:
  - action: getUserPoolMfaConfig
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.SmsMfaConfiguration }}'
    item:
      SmsAuthenticationMessage: '{{ item.SmsAuthenticationMessage }}'
      SmsConfiguration: '{{ item.SmsConfiguration }}'
- discovery_id: aws.cognito-idp.listDevices
  calls:
  - action: listDevices
    save_as: response
    on_error: continue
    params:
      Limit: 1000
  emit:
    as: item
    items_for: '{{ response.Devices }}'
    item:
      DeviceKey: '{{ item.DeviceKey }}'
      DeviceAttributes: '{{ item.DeviceAttributes }}'
      DeviceCreateDate: '{{ item.DeviceCreateDate }}'
      DeviceLastModifiedDate: '{{ item.DeviceLastModifiedDate }}'
      DeviceLastAuthenticatedDate: '{{ item.DeviceLastAuthenticatedDate }}'
- discovery_id: aws.cognito-idp.listGroups
  calls:
  - action: listGroups
    save_as: response
    on_error: continue
    params:
      Limit: 1000
  emit:
    as: item
    items_for: '{{ response.Groups }}'
    item:
      GroupName: '{{ item.GroupName }}'
      UserPoolId: '{{ item.UserPoolId }}'
      Description: '{{ item.Description }}'
      RoleArn: '{{ item.RoleArn }}'
      Precedence: '{{ item.Precedence }}'
      LastModifiedDate: '{{ item.LastModifiedDate }}'
      CreationDate: '{{ item.CreationDate }}'
- discovery_id: aws.cognito-idp.listIdentityProviders
  calls:
  - action: listIdentityProviders
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Providers }}'
    item:
      ProviderName: '{{ item.ProviderName }}'
      ProviderType: '{{ item.ProviderType }}'
      LastModifiedDate: '{{ item.LastModifiedDate }}'
      CreationDate: '{{ item.CreationDate }}'
- discovery_id: aws.cognito-idp.listResourceServers
  calls:
  - action: listResourceServers
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.ResourceServers }}'
    item:
      UserPoolId: '{{ item.UserPoolId }}'
      Identifier: '{{ item.Identifier }}'
      Name: '{{ item.Name }}'
      Scopes: '{{ item.Scopes }}'
- discovery_id: aws.cognito-idp.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Tags }}'
- discovery_id: aws.cognito-idp.listTerms
  calls:
  - action: listTerms
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Terms }}'
    item:
      TermsId: '{{ item.TermsId }}'
      TermsName: '{{ item.TermsName }}'
      Enforcement: '{{ item.Enforcement }}'
      CreationDate: '{{ item.CreationDate }}'
      LastModifiedDate: '{{ item.LastModifiedDate }}'
- discovery_id: aws.cognito-idp.listUserImportJobs
  calls:
  - action: listUserImportJobs
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.UserImportJobs }}'
    item:
      JobName: '{{ item.JobName }}'
      JobId: '{{ item.JobId }}'
      UserPoolId: '{{ item.UserPoolId }}'
      PreSignedUrl: '{{ item.PreSignedUrl }}'
      CreationDate: '{{ item.CreationDate }}'
      StartDate: '{{ item.StartDate }}'
      CompletionDate: '{{ item.CompletionDate }}'
      Status: '{{ item.Status }}'
      CloudWatchLogsRoleArn: '{{ item.CloudWatchLogsRoleArn }}'
      ImportedUsers: '{{ item.ImportedUsers }}'
      SkippedUsers: '{{ item.SkippedUsers }}'
      FailedUsers: '{{ item.FailedUsers }}'
      CompletionMessage: '{{ item.CompletionMessage }}'
- discovery_id: aws.cognito-idp.listUserPoolClients
  calls:
  - action: listUserPoolClients
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.UserPoolClients }}'
    item:
      ClientId: '{{ item.ClientId }}'
      UserPoolId: '{{ item.UserPoolId }}'
      ClientName: '{{ item.ClientName }}'
- discovery_id: aws.cognito-idp.listUserPools
  calls:
  - action: listUserPools
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.UserPools }}'
    item:
      Id: '{{ item.Id }}'
      Name: '{{ item.Name }}'
      LambdaConfig: '{{ item.LambdaConfig }}'
      Status: '{{ item.Status }}'
      LastModifiedDate: '{{ item.LastModifiedDate }}'
      CreationDate: '{{ item.CreationDate }}'
- discovery_id: aws.cognito-idp.listUsers
  calls:
  - action: listUsers
    save_as: response
    on_error: continue
    params:
      Limit: 1000
  emit:
    as: item
    items_for: '{{ response.Users }}'
    item:
      Username: '{{ item.Username }}'
      Attributes: '{{ item.Attributes }}'
      UserCreateDate: '{{ item.UserCreateDate }}'
      UserLastModifiedDate: '{{ item.UserLastModifiedDate }}'
      Enabled: '{{ item.Enabled }}'
      UserStatus: '{{ item.UserStatus }}'
      MFAOptions: '{{ item.MFAOptions }}'
- discovery_id: aws.cognito-idp.listUsersInGroup
  calls:
  - action: listUsersInGroup
    save_as: response
    on_error: continue
    params:
      Limit: 1000
  emit:
    as: item
    items_for: '{{ response.Users }}'
    item:
      Username: '{{ item.Username }}'
      Attributes: '{{ item.Attributes }}'
      UserCreateDate: '{{ item.UserCreateDate }}'
      UserLastModifiedDate: '{{ item.UserLastModifiedDate }}'
      Enabled: '{{ item.Enabled }}'
      UserStatus: '{{ item.UserStatus }}'
      MFAOptions: '{{ item.MFAOptions }}'
- discovery_id: aws.cognito-idp.listWebAuthnCredentials
  calls:
  - action: listWebAuthnCredentials
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Credentials }}'
    item:
      CredentialId: '{{ item.CredentialId }}'
      FriendlyCredentialName: '{{ item.FriendlyCredentialName }}'
      RelyingPartyId: '{{ item.RelyingPartyId }}'
      AuthenticatorAttachment: '{{ item.AuthenticatorAttachment }}'
      AuthenticatorTransports: '{{ item.AuthenticatorTransports }}'
      CreatedAt: '{{ item.CreatedAt }}'
checks: []
