version: '1.0'
provider: aws
service: chime-sdk-messaging
services:
  client: chime-sdk-messaging
  module: boto3.client
discovery:
- discovery_id: aws.chime-sdk-messaging.getMessagingSessionEndpoint
  calls:
  - action: getMessagingSessionEndpoint
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Endpoint }}'
    item:
      Url: '{{ item.Url }}'
- discovery_id: aws.chime-sdk-messaging.describeChannel
  calls:
  - action: describeChannel
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Channel }}'
    item:
      Name: '{{ item.Name }}'
      ChannelArn: '{{ item.ChannelArn }}'
      Mode: '{{ item.Mode }}'
      Privacy: '{{ item.Privacy }}'
      Metadata: '{{ item.Metadata }}'
      CreatedBy: '{{ item.CreatedBy }}'
      CreatedTimestamp: '{{ item.CreatedTimestamp }}'
      LastMessageTimestamp: '{{ item.LastMessageTimestamp }}'
      LastUpdatedTimestamp: '{{ item.LastUpdatedTimestamp }}'
      ChannelFlowArn: '{{ item.ChannelFlowArn }}'
      ElasticChannelConfiguration: '{{ item.ElasticChannelConfiguration }}'
      ExpirationSettings: '{{ item.ExpirationSettings }}'
- discovery_id: aws.chime-sdk-messaging.describeChannelBan
  calls:
  - action: describeChannelBan
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ChannelBan }}'
    item:
      Member: '{{ item.Member }}'
      ChannelArn: '{{ item.ChannelArn }}'
      CreatedTimestamp: '{{ item.CreatedTimestamp }}'
      CreatedBy: '{{ item.CreatedBy }}'
- discovery_id: aws.chime-sdk-messaging.describeChannelFlow
  calls:
  - action: describeChannelFlow
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ChannelFlow }}'
    item:
      ChannelFlowArn: '{{ item.ChannelFlowArn }}'
      Processors: '{{ item.Processors }}'
      Name: '{{ item.Name }}'
      CreatedTimestamp: '{{ item.CreatedTimestamp }}'
      LastUpdatedTimestamp: '{{ item.LastUpdatedTimestamp }}'
- discovery_id: aws.chime-sdk-messaging.describeChannelMembership
  calls:
  - action: describeChannelMembership
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ChannelMembership }}'
    item:
      InvitedBy: '{{ item.InvitedBy }}'
      Type: '{{ item.Type }}'
      Member: '{{ item.Member }}'
      ChannelArn: '{{ item.ChannelArn }}'
      CreatedTimestamp: '{{ item.CreatedTimestamp }}'
      LastUpdatedTimestamp: '{{ item.LastUpdatedTimestamp }}'
      SubChannelId: '{{ item.SubChannelId }}'
- discovery_id: aws.chime-sdk-messaging.describeChannelMembershipForAppInstanceUser
  calls:
  - action: describeChannelMembershipForAppInstanceUser
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ChannelMembership }}'
    item:
      ChannelSummary: '{{ item.ChannelSummary }}'
      AppInstanceUserMembershipSummary: '{{ item.AppInstanceUserMembershipSummary
        }}'
- discovery_id: aws.chime-sdk-messaging.describeChannelModeratedByAppInstanceUser
  calls:
  - action: describeChannelModeratedByAppInstanceUser
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Channel }}'
    item:
      ChannelSummary: '{{ item.ChannelSummary }}'
- discovery_id: aws.chime-sdk-messaging.describeChannelModerator
  calls:
  - action: describeChannelModerator
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ChannelModerator }}'
    item:
      Moderator: '{{ item.Moderator }}'
      ChannelArn: '{{ item.ChannelArn }}'
      CreatedTimestamp: '{{ item.CreatedTimestamp }}'
      CreatedBy: '{{ item.CreatedBy }}'
- discovery_id: aws.chime-sdk-messaging.getChannelMembershipPreferences
  calls:
  - action: getChannelMembershipPreferences
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Member }}'
    item:
      Arn: '{{ item.Arn }}'
      Name: '{{ item.Name }}'
- discovery_id: aws.chime-sdk-messaging.getChannelMessage
  calls:
  - action: getChannelMessage
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ChannelMessage }}'
    item:
      ChannelArn: '{{ item.ChannelArn }}'
      MessageId: '{{ item.MessageId }}'
      Content: '{{ item.Content }}'
      Metadata: '{{ item.Metadata }}'
      Type: '{{ item.Type }}'
      CreatedTimestamp: '{{ item.CreatedTimestamp }}'
      LastEditedTimestamp: '{{ item.LastEditedTimestamp }}'
      LastUpdatedTimestamp: '{{ item.LastUpdatedTimestamp }}'
      Sender: '{{ item.Sender }}'
      Redacted: '{{ item.Redacted }}'
      Persistence: '{{ item.Persistence }}'
      Status: '{{ item.Status }}'
      MessageAttributes: '{{ item.MessageAttributes }}'
      SubChannelId: '{{ item.SubChannelId }}'
      ContentType: '{{ item.ContentType }}'
      Target: '{{ item.Target }}'
- discovery_id: aws.chime-sdk-messaging.getChannelMessageStatus
  calls:
  - action: getChannelMessageStatus
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Status }}'
    item:
      Value: '{{ item.Value }}'
      Detail: '{{ item.Detail }}'
- discovery_id: aws.chime-sdk-messaging.getMessagingStreamingConfigurations
  calls:
  - action: getMessagingStreamingConfigurations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.StreamingConfigurations }}'
    item:
      DataType: '{{ item.DataType }}'
      ResourceArn: '{{ item.ResourceArn }}'
- discovery_id: aws.chime-sdk-messaging.listChannelBans
  calls:
  - action: listChannelBans
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.ChannelBans }}'
    item:
      Member: '{{ item.Member }}'
- discovery_id: aws.chime-sdk-messaging.listChannelFlows
  calls:
  - action: listChannelFlows
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.ChannelFlows }}'
    item:
      ChannelFlowArn: '{{ item.ChannelFlowArn }}'
      Name: '{{ item.Name }}'
      Processors: '{{ item.Processors }}'
- discovery_id: aws.chime-sdk-messaging.listChannelMemberships
  calls:
  - action: listChannelMemberships
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.ChannelMemberships }}'
    item:
      Member: '{{ item.Member }}'
- discovery_id: aws.chime-sdk-messaging.listChannelMembershipsForAppInstanceUser
  calls:
  - action: listChannelMembershipsForAppInstanceUser
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.ChannelMemberships }}'
    item:
      ChannelSummary: '{{ item.ChannelSummary }}'
      AppInstanceUserMembershipSummary: '{{ item.AppInstanceUserMembershipSummary
        }}'
- discovery_id: aws.chime-sdk-messaging.listChannelMessages
  calls:
  - action: listChannelMessages
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.ChannelMessages }}'
    item:
      MessageId: '{{ item.MessageId }}'
      Content: '{{ item.Content }}'
      Metadata: '{{ item.Metadata }}'
      Type: '{{ item.Type }}'
      CreatedTimestamp: '{{ item.CreatedTimestamp }}'
      LastUpdatedTimestamp: '{{ item.LastUpdatedTimestamp }}'
      LastEditedTimestamp: '{{ item.LastEditedTimestamp }}'
      Sender: '{{ item.Sender }}'
      Redacted: '{{ item.Redacted }}'
      Status: '{{ item.Status }}'
      MessageAttributes: '{{ item.MessageAttributes }}'
      ContentType: '{{ item.ContentType }}'
      Target: '{{ item.Target }}'
- discovery_id: aws.chime-sdk-messaging.listChannelModerators
  calls:
  - action: listChannelModerators
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.ChannelModerators }}'
    item:
      Moderator: '{{ item.Moderator }}'
- discovery_id: aws.chime-sdk-messaging.listChannels
  calls:
  - action: listChannels
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Channels }}'
    item:
      Name: '{{ item.Name }}'
      ChannelArn: '{{ item.ChannelArn }}'
      Mode: '{{ item.Mode }}'
      Privacy: '{{ item.Privacy }}'
      Metadata: '{{ item.Metadata }}'
      LastMessageTimestamp: '{{ item.LastMessageTimestamp }}'
- discovery_id: aws.chime-sdk-messaging.listChannelsAssociatedWithChannelFlow
  calls:
  - action: listChannelsAssociatedWithChannelFlow
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Channels }}'
    item:
      Name: '{{ item.Name }}'
      ChannelArn: '{{ item.ChannelArn }}'
      Mode: '{{ item.Mode }}'
      Privacy: '{{ item.Privacy }}'
      Metadata: '{{ item.Metadata }}'
- discovery_id: aws.chime-sdk-messaging.listChannelsModeratedByAppInstanceUser
  calls:
  - action: listChannelsModeratedByAppInstanceUser
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Channels }}'
    item:
      ChannelSummary: '{{ item.ChannelSummary }}'
- discovery_id: aws.chime-sdk-messaging.listSubChannels
  calls:
  - action: listSubChannels
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.SubChannels }}'
    item:
      SubChannelId: '{{ item.SubChannelId }}'
      MembershipCount: '{{ item.MembershipCount }}'
- discovery_id: aws.chime-sdk-messaging.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Tags }}'
    item:
      Key: '{{ item.Key }}'
      Value: '{{ item.Value }}'
- discovery_id: aws.chime-sdk-messaging.searchChannels
  calls:
  - action: searchChannels
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Channels }}'
    item:
      Name: '{{ item.Name }}'
      ChannelArn: '{{ item.ChannelArn }}'
      Mode: '{{ item.Mode }}'
      Privacy: '{{ item.Privacy }}'
      Metadata: '{{ item.Metadata }}'
      LastMessageTimestamp: '{{ item.LastMessageTimestamp }}'
checks: []
