version: '1.0'
provider: aws
service: kinesisvideo
services:
  client: kinesisvideo
  module: boto3.client
discovery:
- discovery_id: aws.kinesisvideo.describeEdgeConfiguration
  calls:
  - action: describeEdgeConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.EdgeConfig }}'
    item:
      HubDeviceArn: '{{ item.HubDeviceArn }}'
      RecorderConfig: '{{ item.RecorderConfig }}'
      UploaderConfig: '{{ item.UploaderConfig }}'
      DeletionConfig: '{{ item.DeletionConfig }}'
- discovery_id: aws.kinesisvideo.describeImageGenerationConfiguration
  calls:
  - action: describeImageGenerationConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ImageGenerationConfiguration }}'
    item:
      Status: '{{ item.Status }}'
      ImageSelectorType: '{{ item.ImageSelectorType }}'
      DestinationConfig: '{{ item.DestinationConfig }}'
      SamplingInterval: '{{ item.SamplingInterval }}'
      Format: '{{ item.Format }}'
      FormatConfig: '{{ item.FormatConfig }}'
      WidthPixels: '{{ item.WidthPixels }}'
      HeightPixels: '{{ item.HeightPixels }}'
- discovery_id: aws.kinesisvideo.describeMappedResourceConfiguration
  calls:
  - action: describeMappedResourceConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.MappedResourceConfigurationList }}'
    item:
      Type: '{{ item.Type }}'
      ARN: '{{ item.ARN }}'
- discovery_id: aws.kinesisvideo.describeMediaStorageConfiguration
  calls:
  - action: describeMediaStorageConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.MediaStorageConfiguration }}'
    item:
      StreamARN: '{{ item.StreamARN }}'
      Status: '{{ item.Status }}'
- discovery_id: aws.kinesisvideo.describeNotificationConfiguration
  calls:
  - action: describeNotificationConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.NotificationConfiguration }}'
    item:
      Status: '{{ item.Status }}'
      DestinationConfig: '{{ item.DestinationConfig }}'
- discovery_id: aws.kinesisvideo.describeSignalingChannel
  calls:
  - action: describeSignalingChannel
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ChannelInfo }}'
    item:
      ChannelName: '{{ item.ChannelName }}'
      ChannelARN: '{{ item.ChannelARN }}'
      ChannelType: '{{ item.ChannelType }}'
      ChannelStatus: '{{ item.ChannelStatus }}'
      CreationTime: '{{ item.CreationTime }}'
      SingleMasterConfiguration: '{{ item.SingleMasterConfiguration }}'
      Version: '{{ item.Version }}'
- discovery_id: aws.kinesisvideo.describeStream
  calls:
  - action: describeStream
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.StreamInfo }}'
    item:
      DeviceName: '{{ item.DeviceName }}'
      StreamName: '{{ item.StreamName }}'
      StreamARN: '{{ item.StreamARN }}'
      MediaType: '{{ item.MediaType }}'
      KmsKeyId: '{{ item.KmsKeyId }}'
      Version: '{{ item.Version }}'
      Status: '{{ item.Status }}'
      CreationTime: '{{ item.CreationTime }}'
      DataRetentionInHours: '{{ item.DataRetentionInHours }}'
- discovery_id: aws.kinesisvideo.describeStreamStorageConfiguration
  calls:
  - action: describeStreamStorageConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.StreamStorageConfiguration }}'
    item:
      DefaultStorageTier: '{{ item.DefaultStorageTier }}'
- discovery_id: aws.kinesisvideo.listSignalingChannels
  calls:
  - action: listSignalingChannels
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.ChannelInfoList }}'
    item:
      ChannelName: '{{ item.ChannelName }}'
      ChannelARN: '{{ item.ChannelARN }}'
      ChannelType: '{{ item.ChannelType }}'
      ChannelStatus: '{{ item.ChannelStatus }}'
      CreationTime: '{{ item.CreationTime }}'
      SingleMasterConfiguration: '{{ item.SingleMasterConfiguration }}'
      Version: '{{ item.Version }}'
- discovery_id: aws.kinesisvideo.listStreams
  calls:
  - action: listStreams
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.StreamInfoList }}'
    item:
      DeviceName: '{{ item.DeviceName }}'
      StreamName: '{{ item.StreamName }}'
      StreamARN: '{{ item.StreamARN }}'
      MediaType: '{{ item.MediaType }}'
      KmsKeyId: '{{ item.KmsKeyId }}'
      Version: '{{ item.Version }}'
      Status: '{{ item.Status }}'
      CreationTime: '{{ item.CreationTime }}'
      DataRetentionInHours: '{{ item.DataRetentionInHours }}'
- discovery_id: aws.kinesisvideo.listTagsForStream
  calls:
  - action: listTagsForStream
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.NextToken }}'
- discovery_id: aws.kinesisvideo.getDataEndpoint
  calls:
  - action: getDataEndpoint
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.DataEndpoint }}'
- discovery_id: aws.kinesisvideo.getSignalingChannelEndpoint
  calls:
  - action: getSignalingChannelEndpoint
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ResourceEndpointList }}'
    item:
      Protocol: '{{ item.Protocol }}'
      ResourceEndpoint: '{{ item.ResourceEndpoint }}'
- discovery_id: aws.kinesisvideo.listEdgeAgentConfigurations
  calls:
  - action: listEdgeAgentConfigurations
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.EdgeConfigs }}'
    item:
      StreamName: '{{ item.StreamName }}'
      StreamARN: '{{ item.StreamARN }}'
      CreationTime: '{{ item.CreationTime }}'
      LastUpdatedTime: '{{ item.LastUpdatedTime }}'
      SyncStatus: '{{ item.SyncStatus }}'
      FailedStatusDetails: '{{ item.FailedStatusDetails }}'
      EdgeConfig: '{{ item.EdgeConfig }}'
- discovery_id: aws.kinesisvideo.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.NextToken }}'
checks: []
