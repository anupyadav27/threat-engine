version: '1.0'
provider: aws
service: elasticache
services:
  client: elasticache
  module: boto3.client
discovery:
- discovery_id: aws.elasticache.describeCacheClusters
  calls:
  - action: describeCacheClusters
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.CacheClusters }}'
    item:
      CacheClusterId: '{{ item.CacheClusterId }}'
      ConfigurationEndpoint: '{{ item.ConfigurationEndpoint }}'
      ClientDownloadLandingPage: '{{ item.ClientDownloadLandingPage }}'
      CacheNodeType: '{{ item.CacheNodeType }}'
      Engine: '{{ item.Engine }}'
      EngineVersion: '{{ item.EngineVersion }}'
      CacheClusterStatus: '{{ item.CacheClusterStatus }}'
      NumCacheNodes: '{{ item.NumCacheNodes }}'
      PreferredAvailabilityZone: '{{ item.PreferredAvailabilityZone }}'
      PreferredOutpostArn: '{{ item.PreferredOutpostArn }}'
      CacheClusterCreateTime: '{{ item.CacheClusterCreateTime }}'
      PreferredMaintenanceWindow: '{{ item.PreferredMaintenanceWindow }}'
      PendingModifiedValues: '{{ item.PendingModifiedValues }}'
      NotificationConfiguration: '{{ item.NotificationConfiguration }}'
      CacheSecurityGroups: '{{ item.CacheSecurityGroups }}'
      CacheParameterGroup: '{{ item.CacheParameterGroup }}'
      CacheSubnetGroupName: '{{ item.CacheSubnetGroupName }}'
      CacheNodes: '{{ item.CacheNodes }}'
      AutoMinorVersionUpgrade: '{{ item.AutoMinorVersionUpgrade }}'
      SecurityGroups: '{{ item.SecurityGroups }}'
      ReplicationGroupId: '{{ item.ReplicationGroupId }}'
      SnapshotRetentionLimit: '{{ item.SnapshotRetentionLimit }}'
      SnapshotWindow: '{{ item.SnapshotWindow }}'
      AuthTokenEnabled: '{{ item.AuthTokenEnabled }}'
      AuthTokenLastModifiedDate: '{{ item.AuthTokenLastModifiedDate }}'
      TransitEncryptionEnabled: '{{ item.TransitEncryptionEnabled }}'
      AtRestEncryptionEnabled: '{{ item.AtRestEncryptionEnabled }}'
      ARN: '{{ item.ARN }}'
      ReplicationGroupLogDeliveryEnabled: '{{ item.ReplicationGroupLogDeliveryEnabled
        }}'
      LogDeliveryConfigurations: '{{ item.LogDeliveryConfigurations }}'
      NetworkType: '{{ item.NetworkType }}'
      IpDiscovery: '{{ item.IpDiscovery }}'
      TransitEncryptionMode: '{{ item.TransitEncryptionMode }}'
- discovery_id: aws.elasticache.describeCacheEngineVersions
  calls:
  - action: describeCacheEngineVersions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.CacheEngineVersions }}'
    item:
      Engine: '{{ item.Engine }}'
      EngineVersion: '{{ item.EngineVersion }}'
      CacheParameterGroupFamily: '{{ item.CacheParameterGroupFamily }}'
      CacheEngineDescription: '{{ item.CacheEngineDescription }}'
      CacheEngineVersionDescription: '{{ item.CacheEngineVersionDescription }}'
- discovery_id: aws.elasticache.describeCacheParameterGroups
  calls:
  - action: describeCacheParameterGroups
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.CacheParameterGroups }}'
    item:
      CacheParameterGroupName: '{{ item.CacheParameterGroupName }}'
      CacheParameterGroupFamily: '{{ item.CacheParameterGroupFamily }}'
      Description: '{{ item.Description }}'
      IsGlobal: '{{ item.IsGlobal }}'
      ARN: '{{ item.ARN }}'
- discovery_id: aws.elasticache.describeCacheSecurityGroups
  calls:
  - action: describeCacheSecurityGroups
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.CacheSecurityGroups }}'
    item:
      OwnerId: '{{ item.OwnerId }}'
      CacheSecurityGroupName: '{{ item.CacheSecurityGroupName }}'
      Description: '{{ item.Description }}'
      EC2SecurityGroups: '{{ item.EC2SecurityGroups }}'
      ARN: '{{ item.ARN }}'
- discovery_id: aws.elasticache.describeCacheSubnetGroups
  calls:
  - action: describeCacheSubnetGroups
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.CacheSubnetGroups }}'
    item:
      CacheSubnetGroupName: '{{ item.CacheSubnetGroupName }}'
      CacheSubnetGroupDescription: '{{ item.CacheSubnetGroupDescription }}'
      VpcId: '{{ item.VpcId }}'
      Subnets: '{{ item.Subnets }}'
      ARN: '{{ item.ARN }}'
      SupportedNetworkTypes: '{{ item.SupportedNetworkTypes }}'
- discovery_id: aws.elasticache.describeEvents
  calls:
  - action: describeEvents
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Events }}'
    item:
      SourceIdentifier: '{{ item.SourceIdentifier }}'
      SourceType: '{{ item.SourceType }}'
      Message: '{{ item.Message }}'
      Date: '{{ item.Date }}'
- discovery_id: aws.elasticache.describeGlobalReplicationGroups
  calls:
  - action: describeGlobalReplicationGroups
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.GlobalReplicationGroups }}'
    item:
      GlobalReplicationGroupId: '{{ item.GlobalReplicationGroupId }}'
      GlobalReplicationGroupDescription: '{{ item.GlobalReplicationGroupDescription
        }}'
      Status: '{{ item.Status }}'
      CacheNodeType: '{{ item.CacheNodeType }}'
      Engine: '{{ item.Engine }}'
      EngineVersion: '{{ item.EngineVersion }}'
      Members: '{{ item.Members }}'
      ClusterEnabled: '{{ item.ClusterEnabled }}'
      GlobalNodeGroups: '{{ item.GlobalNodeGroups }}'
      AuthTokenEnabled: '{{ item.AuthTokenEnabled }}'
      TransitEncryptionEnabled: '{{ item.TransitEncryptionEnabled }}'
      AtRestEncryptionEnabled: '{{ item.AtRestEncryptionEnabled }}'
      ARN: '{{ item.ARN }}'
- discovery_id: aws.elasticache.describeReplicationGroups
  calls:
  - action: describeReplicationGroups
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ReplicationGroups }}'
    item:
      ReplicationGroupId: '{{ item.ReplicationGroupId }}'
      Description: '{{ item.Description }}'
      GlobalReplicationGroupInfo: '{{ item.GlobalReplicationGroupInfo }}'
      Status: '{{ item.Status }}'
      PendingModifiedValues: '{{ item.PendingModifiedValues }}'
      MemberClusters: '{{ item.MemberClusters }}'
      NodeGroups: '{{ item.NodeGroups }}'
      SnapshottingClusterId: '{{ item.SnapshottingClusterId }}'
      AutomaticFailover: '{{ item.AutomaticFailover }}'
      MultiAZ: '{{ item.MultiAZ }}'
      ConfigurationEndpoint: '{{ item.ConfigurationEndpoint }}'
      SnapshotRetentionLimit: '{{ item.SnapshotRetentionLimit }}'
      SnapshotWindow: '{{ item.SnapshotWindow }}'
      ClusterEnabled: '{{ item.ClusterEnabled }}'
      CacheNodeType: '{{ item.CacheNodeType }}'
      AuthTokenEnabled: '{{ item.AuthTokenEnabled }}'
      AuthTokenLastModifiedDate: '{{ item.AuthTokenLastModifiedDate }}'
      TransitEncryptionEnabled: '{{ item.TransitEncryptionEnabled }}'
      AtRestEncryptionEnabled: '{{ item.AtRestEncryptionEnabled }}'
      MemberClustersOutpostArns: '{{ item.MemberClustersOutpostArns }}'
      KmsKeyId: '{{ item.KmsKeyId }}'
      ARN: '{{ item.ARN }}'
      UserGroupIds: '{{ item.UserGroupIds }}'
      LogDeliveryConfigurations: '{{ item.LogDeliveryConfigurations }}'
      ReplicationGroupCreateTime: '{{ item.ReplicationGroupCreateTime }}'
      DataTiering: '{{ item.DataTiering }}'
      AutoMinorVersionUpgrade: '{{ item.AutoMinorVersionUpgrade }}'
      NetworkType: '{{ item.NetworkType }}'
      IpDiscovery: '{{ item.IpDiscovery }}'
      TransitEncryptionMode: '{{ item.TransitEncryptionMode }}'
      ClusterMode: '{{ item.ClusterMode }}'
      Engine: '{{ item.Engine }}'
- discovery_id: aws.elasticache.describeReservedCacheNodes
  calls:
  - action: describeReservedCacheNodes
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ReservedCacheNodes }}'
    item:
      ReservedCacheNodeId: '{{ item.ReservedCacheNodeId }}'
      ReservedCacheNodesOfferingId: '{{ item.ReservedCacheNodesOfferingId }}'
      CacheNodeType: '{{ item.CacheNodeType }}'
      StartTime: '{{ item.StartTime }}'
      Duration: '{{ item.Duration }}'
      FixedPrice: '{{ item.FixedPrice }}'
      UsagePrice: '{{ item.UsagePrice }}'
      CacheNodeCount: '{{ item.CacheNodeCount }}'
      ProductDescription: '{{ item.ProductDescription }}'
      OfferingType: '{{ item.OfferingType }}'
      State: '{{ item.State }}'
      RecurringCharges: '{{ item.RecurringCharges }}'
      ReservationARN: '{{ item.ReservationARN }}'
- discovery_id: aws.elasticache.describeReservedCacheNodesOfferings
  calls:
  - action: describeReservedCacheNodesOfferings
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ReservedCacheNodesOfferings }}'
    item:
      ReservedCacheNodesOfferingId: '{{ item.ReservedCacheNodesOfferingId }}'
      CacheNodeType: '{{ item.CacheNodeType }}'
      Duration: '{{ item.Duration }}'
      FixedPrice: '{{ item.FixedPrice }}'
      UsagePrice: '{{ item.UsagePrice }}'
      ProductDescription: '{{ item.ProductDescription }}'
      OfferingType: '{{ item.OfferingType }}'
      RecurringCharges: '{{ item.RecurringCharges }}'
- discovery_id: aws.elasticache.describeServerlessCacheSnapshots
  calls:
  - action: describeServerlessCacheSnapshots
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ServerlessCacheSnapshots }}'
    item:
      ServerlessCacheSnapshotName: '{{ item.ServerlessCacheSnapshotName }}'
      ARN: '{{ item.ARN }}'
      KmsKeyId: '{{ item.KmsKeyId }}'
      SnapshotType: '{{ item.SnapshotType }}'
      Status: '{{ item.Status }}'
      CreateTime: '{{ item.CreateTime }}'
      ExpiryTime: '{{ item.ExpiryTime }}'
      BytesUsedForCache: '{{ item.BytesUsedForCache }}'
      ServerlessCacheConfiguration: '{{ item.ServerlessCacheConfiguration }}'
- discovery_id: aws.elasticache.describeServerlessCaches
  calls:
  - action: describeServerlessCaches
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ServerlessCaches }}'
    item:
      ServerlessCacheName: '{{ item.ServerlessCacheName }}'
      Description: '{{ item.Description }}'
      CreateTime: '{{ item.CreateTime }}'
      Status: '{{ item.Status }}'
      Engine: '{{ item.Engine }}'
      MajorEngineVersion: '{{ item.MajorEngineVersion }}'
      FullEngineVersion: '{{ item.FullEngineVersion }}'
      CacheUsageLimits: '{{ item.CacheUsageLimits }}'
      KmsKeyId: '{{ item.KmsKeyId }}'
      SecurityGroupIds: '{{ item.SecurityGroupIds }}'
      Endpoint: '{{ item.Endpoint }}'
      ReaderEndpoint: '{{ item.ReaderEndpoint }}'
      ARN: '{{ item.ARN }}'
      UserGroupId: '{{ item.UserGroupId }}'
      SubnetIds: '{{ item.SubnetIds }}'
      SnapshotRetentionLimit: '{{ item.SnapshotRetentionLimit }}'
      DailySnapshotTime: '{{ item.DailySnapshotTime }}'
- discovery_id: aws.elasticache.describeServiceUpdates
  calls:
  - action: describeServiceUpdates
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ServiceUpdates }}'
    item:
      ServiceUpdateName: '{{ item.ServiceUpdateName }}'
      ServiceUpdateReleaseDate: '{{ item.ServiceUpdateReleaseDate }}'
      ServiceUpdateEndDate: '{{ item.ServiceUpdateEndDate }}'
      ServiceUpdateSeverity: '{{ item.ServiceUpdateSeverity }}'
      ServiceUpdateRecommendedApplyByDate: '{{ item.ServiceUpdateRecommendedApplyByDate
        }}'
      ServiceUpdateStatus: '{{ item.ServiceUpdateStatus }}'
      ServiceUpdateDescription: '{{ item.ServiceUpdateDescription }}'
      ServiceUpdateType: '{{ item.ServiceUpdateType }}'
      Engine: '{{ item.Engine }}'
      EngineVersion: '{{ item.EngineVersion }}'
      AutoUpdateAfterRecommendedApplyByDate: '{{ item.AutoUpdateAfterRecommendedApplyByDate
        }}'
      EstimatedUpdateTime: '{{ item.EstimatedUpdateTime }}'
- discovery_id: aws.elasticache.describeSnapshots
  calls:
  - action: describeSnapshots
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Snapshots }}'
    item:
      SnapshotName: '{{ item.SnapshotName }}'
      ReplicationGroupId: '{{ item.ReplicationGroupId }}'
      ReplicationGroupDescription: '{{ item.ReplicationGroupDescription }}'
      CacheClusterId: '{{ item.CacheClusterId }}'
      SnapshotStatus: '{{ item.SnapshotStatus }}'
      SnapshotSource: '{{ item.SnapshotSource }}'
      CacheNodeType: '{{ item.CacheNodeType }}'
      Engine: '{{ item.Engine }}'
      EngineVersion: '{{ item.EngineVersion }}'
      NumCacheNodes: '{{ item.NumCacheNodes }}'
      PreferredAvailabilityZone: '{{ item.PreferredAvailabilityZone }}'
      PreferredOutpostArn: '{{ item.PreferredOutpostArn }}'
      CacheClusterCreateTime: '{{ item.CacheClusterCreateTime }}'
      PreferredMaintenanceWindow: '{{ item.PreferredMaintenanceWindow }}'
      TopicArn: '{{ item.TopicArn }}'
      Port: '{{ item.Port }}'
      CacheParameterGroupName: '{{ item.CacheParameterGroupName }}'
      CacheSubnetGroupName: '{{ item.CacheSubnetGroupName }}'
      VpcId: '{{ item.VpcId }}'
      AutoMinorVersionUpgrade: '{{ item.AutoMinorVersionUpgrade }}'
      SnapshotRetentionLimit: '{{ item.SnapshotRetentionLimit }}'
      SnapshotWindow: '{{ item.SnapshotWindow }}'
      NumNodeGroups: '{{ item.NumNodeGroups }}'
      AutomaticFailover: '{{ item.AutomaticFailover }}'
      NodeSnapshots: '{{ item.NodeSnapshots }}'
      KmsKeyId: '{{ item.KmsKeyId }}'
      ARN: '{{ item.ARN }}'
      DataTiering: '{{ item.DataTiering }}'
- discovery_id: aws.elasticache.describeUpdateActions
  calls:
  - action: describeUpdateActions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.UpdateActions }}'
    item:
      ReplicationGroupId: '{{ item.ReplicationGroupId }}'
      CacheClusterId: '{{ item.CacheClusterId }}'
      ServiceUpdateName: '{{ item.ServiceUpdateName }}'
      ServiceUpdateReleaseDate: '{{ item.ServiceUpdateReleaseDate }}'
      ServiceUpdateSeverity: '{{ item.ServiceUpdateSeverity }}'
      ServiceUpdateStatus: '{{ item.ServiceUpdateStatus }}'
      ServiceUpdateRecommendedApplyByDate: '{{ item.ServiceUpdateRecommendedApplyByDate
        }}'
      ServiceUpdateType: '{{ item.ServiceUpdateType }}'
      UpdateActionAvailableDate: '{{ item.UpdateActionAvailableDate }}'
      UpdateActionStatus: '{{ item.UpdateActionStatus }}'
      NodesUpdated: '{{ item.NodesUpdated }}'
      UpdateActionStatusModifiedDate: '{{ item.UpdateActionStatusModifiedDate }}'
      SlaMet: '{{ item.SlaMet }}'
      NodeGroupUpdateStatus: '{{ item.NodeGroupUpdateStatus }}'
      CacheNodeUpdateStatus: '{{ item.CacheNodeUpdateStatus }}'
      EstimatedUpdateTime: '{{ item.EstimatedUpdateTime }}'
      Engine: '{{ item.Engine }}'
- discovery_id: aws.elasticache.describeUserGroups
  calls:
  - action: describeUserGroups
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.UserGroups }}'
    item:
      UserGroupId: '{{ item.UserGroupId }}'
      Status: '{{ item.Status }}'
      Engine: '{{ item.Engine }}'
      UserIds: '{{ item.UserIds }}'
      MinimumEngineVersion: '{{ item.MinimumEngineVersion }}'
      PendingChanges: '{{ item.PendingChanges }}'
      ReplicationGroups: '{{ item.ReplicationGroups }}'
      ServerlessCaches: '{{ item.ServerlessCaches }}'
      ARN: '{{ item.ARN }}'
- discovery_id: aws.elasticache.describeUsers
  calls:
  - action: describeUsers
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Users }}'
    item:
      UserId: '{{ item.UserId }}'
      UserName: '{{ item.UserName }}'
      Status: '{{ item.Status }}'
      Engine: '{{ item.Engine }}'
      MinimumEngineVersion: '{{ item.MinimumEngineVersion }}'
      AccessString: '{{ item.AccessString }}'
      UserGroupIds: '{{ item.UserGroupIds }}'
      Authentication: '{{ item.Authentication }}'
      ARN: '{{ item.ARN }}'
- discovery_id: aws.elasticache.listAllowedNodeTypeModifications
  calls:
  - action: listAllowedNodeTypeModifications
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ScaleUpModifications }}'
- discovery_id: aws.elasticache.describeCacheParameters
  calls:
  - action: describeCacheParameters
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Parameters }}'
    item:
      ParameterName: '{{ item.ParameterName }}'
      ParameterValue: '{{ item.ParameterValue }}'
      Description: '{{ item.Description }}'
      Source: '{{ item.Source }}'
      DataType: '{{ item.DataType }}'
      AllowedValues: '{{ item.AllowedValues }}'
      IsModifiable: '{{ item.IsModifiable }}'
      MinimumEngineVersion: '{{ item.MinimumEngineVersion }}'
      ChangeType: '{{ item.ChangeType }}'
- discovery_id: aws.elasticache.describeEngineDefaultParameters
  calls:
  - action: describeEngineDefaultParameters
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.EngineDefaults }}'
    item:
      CacheParameterGroupFamily: '{{ item.CacheParameterGroupFamily }}'
      Marker: '{{ item.Marker }}'
      Parameters: '{{ item.Parameters }}'
      CacheNodeTypeSpecificParameters: '{{ item.CacheNodeTypeSpecificParameters }}'
- discovery_id: aws.elasticache.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.TagList }}'
    item:
      Key: '{{ item.Key }}'
      Value: '{{ item.Value }}'
checks: []
