    items_for: '{{ response.Errors }}'
    item:
      Type: '{{ item.Type }}'
      Message: '{{ item.Message }}'
      ViolatedEntities: '{{ item.ViolatedEntities }}'
- discovery_id: aws.quicksight.describeDashboardPermissions
  calls:
  - action: describeDashboardPermissions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Permissions }}'
    item:
      Principal: '{{ item.Principal }}'
      Actions: '{{ item.Actions }}'
- discovery_id: aws.quicksight.describeDashboardSnapshotJob
  calls:
  - action: describeDashboardSnapshotJob
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.UserConfiguration }}'
    item:
      AnonymousUsers: '{{ item.AnonymousUsers }}'
- discovery_id: aws.quicksight.describeDashboardSnapshotJobResult
  calls:
  - action: describeDashboardSnapshotJobResult
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Result }}'
    item:
