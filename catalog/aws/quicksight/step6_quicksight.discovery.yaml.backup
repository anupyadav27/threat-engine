  emit:
    as: item
    items_for: '{{ response.DataSet }}'
    item:
      Arn: '{{ item.Arn }}'
      DataSetId: '{{ item.DataSetId }}'
      Name: '{{ item.Name }}'
      CreatedTime: '{{ item.CreatedTime }}'
      LastUpdatedTime: '{{ item.LastUpdatedTime }}'
      PhysicalTableMap: '{{ item.PhysicalTableMap }}'
      LogicalTableMap: '{{ item.LogicalTableMap }}'
      OutputColumns: '{{ item.OutputColumns }}'
      ImportMode: '{{ item.ImportMode }}'
      ConsumedSpiceCapacityInBytes: '{{ item.ConsumedSpiceCapacityInBytes }}'
      ColumnGroups: '{{ item.ColumnGroups }}'
      FieldFolders: '{{ item.FieldFolders }}'
      RowLevelPermissionDataSet: '{{ item.RowLevelPermissionDataSet }}'
      RowLevelPermissionTagConfiguration: '{{ item.RowLevelPermissionTagConfiguration
        }}'
      ColumnLevelPermissionRules: '{{ item.ColumnLevelPermissionRules }}'
      DataSetUsageConfiguration: '{{ item.DataSetUsageConfiguration }}'
      DatasetParameters: '{{ item.DatasetParameters }}'
      PerformanceConfiguration: '{{ item.PerformanceConfiguration }}'
      UseAs: '{{ item.UseAs }}'
      DataPrepConfiguration: '{{ item.DataPrepConfiguration }}'
      SemanticModelConfiguration: '{{ item.SemanticModelConfiguration }}'
