version: '1.0'
provider: aws
service: quicksight
services:
  client: quicksight
  module: boto3.client
discovery:
- discovery_id: aws.quicksight.describeAccountCustomPermission
  calls:
  - action: describeAccountCustomPermission
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.CustomPermissionsName }}'
- discovery_id: aws.quicksight.describeAccountCustomization
  calls:
  - action: describeAccountCustomization
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AccountCustomization }}'
    item:
      DefaultTheme: '{{ item.DefaultTheme }}'
      DefaultEmailCustomizationTemplate: '{{ item.DefaultEmailCustomizationTemplate
        }}'
- discovery_id: aws.quicksight.describeAccountSettings
  calls:
  - action: describeAccountSettings
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AccountSettings }}'
    item:
      AccountName: '{{ item.AccountName }}'
      Edition: '{{ item.Edition }}'
      DefaultNamespace: '{{ item.DefaultNamespace }}'
      NotificationEmail: '{{ item.NotificationEmail }}'
      PublicSharingEnabled: '{{ item.PublicSharingEnabled }}'
      TerminationProtectionEnabled: '{{ item.TerminationProtectionEnabled }}'
- discovery_id: aws.quicksight.describeAccountSubscription
  calls:
  - action: describeAccountSubscription
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AccountInfo }}'
    item:
      AccountName: '{{ item.AccountName }}'
      Edition: '{{ item.Edition }}'
      NotificationEmail: '{{ item.NotificationEmail }}'
      AuthenticationType: '{{ item.AuthenticationType }}'
      AccountSubscriptionStatus: '{{ item.AccountSubscriptionStatus }}'
      IAMIdentityCenterInstanceArn: '{{ item.IAMIdentityCenterInstanceArn }}'
- discovery_id: aws.quicksight.describeActionConnector
  calls:
  - action: describeActionConnector
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ActionConnector }}'
    item:
      Arn: '{{ item.Arn }}'
      ActionConnectorId: '{{ item.ActionConnectorId }}'
      Type: '{{ item.Type }}'
      Name: '{{ item.Name }}'
      CreatedTime: '{{ item.CreatedTime }}'
      LastUpdatedTime: '{{ item.LastUpdatedTime }}'
      Status: '{{ item.Status }}'
      Error: '{{ item.Error }}'
      Description: '{{ item.Description }}'
      AuthenticationConfig: '{{ item.AuthenticationConfig }}'
      EnabledActions: '{{ item.EnabledActions }}'
      VpcConnectionArn: '{{ item.VpcConnectionArn }}'
- discovery_id: aws.quicksight.describeActionConnectorPermissions
  calls:
  - action: describeActionConnectorPermissions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Permissions }}'
    item:
      Principal: '{{ item.Principal }}'
      Actions: '{{ item.Actions }}'
- discovery_id: aws.quicksight.describeAnalysis
  calls:
  - action: describeAnalysis
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Analysis }}'
    item:
      AnalysisId: '{{ item.AnalysisId }}'
      Arn: '{{ item.Arn }}'
      Name: '{{ item.Name }}'
      Status: '{{ item.Status }}'
      Errors: '{{ item.Errors }}'
      DataSetArns: '{{ item.DataSetArns }}'
      ThemeArn: '{{ item.ThemeArn }}'
      CreatedTime: '{{ item.CreatedTime }}'
      LastUpdatedTime: '{{ item.LastUpdatedTime }}'
      Sheets: '{{ item.Sheets }}'
- discovery_id: aws.quicksight.describeAnalysisDefinition
  calls:
  - action: describeAnalysisDefinition
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Errors }}'
    item:
      Type: '{{ item.Type }}'
      Message: '{{ item.Message }}'
      ViolatedEntities: '{{ item.ViolatedEntities }}'
- discovery_id: aws.quicksight.describeAnalysisPermissions
  calls:
  - action: describeAnalysisPermissions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Permissions }}'
    item:
      Principal: '{{ item.Principal }}'
      Actions: '{{ item.Actions }}'
- discovery_id: aws.quicksight.describeAssetBundleExportJob
  calls:
  - action: describeAssetBundleExportJob
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Errors }}'
    item:
      Arn: '{{ item.Arn }}'
      Type: '{{ item.Type }}'
      Message: '{{ item.Message }}'
- discovery_id: aws.quicksight.describeAssetBundleImportJob
  calls:
  - action: describeAssetBundleImportJob
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Errors }}'
    item:
      Arn: '{{ item.Arn }}'
      Type: '{{ item.Type }}'
      Message: '{{ item.Message }}'
- discovery_id: aws.quicksight.describeBrand
  calls:
  - action: describeBrand
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.BrandDetail }}'
    item:
      BrandId: '{{ item.BrandId }}'
      Arn: '{{ item.Arn }}'
      BrandStatus: '{{ item.BrandStatus }}'
      CreatedTime: '{{ item.CreatedTime }}'
      LastUpdatedTime: '{{ item.LastUpdatedTime }}'
      VersionId: '{{ item.VersionId }}'
      VersionStatus: '{{ item.VersionStatus }}'
      Errors: '{{ item.Errors }}'
      Logo: '{{ item.Logo }}'
- discovery_id: aws.quicksight.describeBrandAssignment
  calls:
  - action: describeBrandAssignment
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.RequestId }}'
- discovery_id: aws.quicksight.describeBrandPublishedVersion
  calls:
  - action: describeBrandPublishedVersion
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.BrandDetail }}'
    item:
      BrandId: '{{ item.BrandId }}'
      Arn: '{{ item.Arn }}'
      BrandStatus: '{{ item.BrandStatus }}'
      CreatedTime: '{{ item.CreatedTime }}'
      LastUpdatedTime: '{{ item.LastUpdatedTime }}'
      VersionId: '{{ item.VersionId }}'
      VersionStatus: '{{ item.VersionStatus }}'
      Errors: '{{ item.Errors }}'
      Logo: '{{ item.Logo }}'
- discovery_id: aws.quicksight.describeCustomPermissions
  calls:
  - action: describeCustomPermissions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.CustomPermissions }}'
    item:
      Arn: '{{ item.Arn }}'
      CustomPermissionsName: '{{ item.CustomPermissionsName }}'
      Capabilities: '{{ item.Capabilities }}'
- discovery_id: aws.quicksight.describeDashboard
  calls:
  - action: describeDashboard
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Dashboard }}'
    item:
      DashboardId: '{{ item.DashboardId }}'
      Arn: '{{ item.Arn }}'
      Name: '{{ item.Name }}'
      Version: '{{ item.Version }}'
      CreatedTime: '{{ item.CreatedTime }}'
      LastPublishedTime: '{{ item.LastPublishedTime }}'
