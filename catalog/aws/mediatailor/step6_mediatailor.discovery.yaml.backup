version: '1.0'
provider: aws
service: mediatailor
services:
  client: mediatailor
  module: boto3.client
discovery:
- discovery_id: aws.mediatailor.listChannels
  calls:
  - action: listChannels
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Items }}'
    item:
      Arn: '{{ item.Arn }}'
      ChannelName: '{{ item.ChannelName }}'
      ChannelState: '{{ item.ChannelState }}'
      CreationTime: '{{ item.CreationTime }}'
      FillerSlate: '{{ item.FillerSlate }}'
      LastModifiedTime: '{{ item.LastModifiedTime }}'
      Outputs: '{{ item.Outputs }}'
      PlaybackMode: '{{ item.PlaybackMode }}'
      Tags: '{{ item.Tags }}'
      Tier: '{{ item.Tier }}'
      LogConfiguration: '{{ item.LogConfiguration }}'
      Audiences: '{{ item.Audiences }}'
- discovery_id: aws.mediatailor.listPlaybackConfigurations
  calls:
  - action: listPlaybackConfigurations
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Items }}'
    item:
      AdDecisionServerUrl: '{{ item.AdDecisionServerUrl }}'
      AvailSuppression: '{{ item.AvailSuppression }}'
      Bumper: '{{ item.Bumper }}'
      CdnConfiguration: '{{ item.CdnConfiguration }}'
      ConfigurationAliases: '{{ item.ConfigurationAliases }}'
      DashConfiguration: '{{ item.DashConfiguration }}'
      HlsConfiguration: '{{ item.HlsConfiguration }}'
      InsertionMode: '{{ item.InsertionMode }}'
      LivePreRollConfiguration: '{{ item.LivePreRollConfiguration }}'
      LogConfiguration: '{{ item.LogConfiguration }}'
      ManifestProcessingRules: '{{ item.ManifestProcessingRules }}'
      Name: '{{ item.Name }}'
      PersonalizationThresholdSeconds: '{{ item.PersonalizationThresholdSeconds }}'
      PlaybackConfigurationArn: '{{ item.PlaybackConfigurationArn }}'
      PlaybackEndpointPrefix: '{{ item.PlaybackEndpointPrefix }}'
      SessionInitializationEndpointPrefix: '{{ item.SessionInitializationEndpointPrefix
        }}'
      SlateAdUrl: '{{ item.SlateAdUrl }}'
      Tags: '{{ item.Tags }}'
      TranscodeProfileName: '{{ item.TranscodeProfileName }}'
      VideoContentSourceUrl: '{{ item.VideoContentSourceUrl }}'
      AdConditioningConfiguration: '{{ item.AdConditioningConfiguration }}'
- discovery_id: aws.mediatailor.listSourceLocations
  calls:
  - action: listSourceLocations
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Items }}'
    item:
      AccessConfiguration: '{{ item.AccessConfiguration }}'
      Arn: '{{ item.Arn }}'
      CreationTime: '{{ item.CreationTime }}'
      DefaultSegmentDeliveryConfiguration: '{{ item.DefaultSegmentDeliveryConfiguration
        }}'
      HttpConfiguration: '{{ item.HttpConfiguration }}'
      LastModifiedTime: '{{ item.LastModifiedTime }}'
      SegmentDeliveryConfigurations: '{{ item.SegmentDeliveryConfigurations }}'
      SourceLocationName: '{{ item.SourceLocationName }}'
      Tags: '{{ item.Tags }}'
- discovery_id: aws.mediatailor.describeChannel
  calls:
  - action: describeChannel
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Outputs }}'
    item:
      DashPlaylistSettings: '{{ item.DashPlaylistSettings }}'
      HlsPlaylistSettings: '{{ item.HlsPlaylistSettings }}'
      ManifestName: '{{ item.ManifestName }}'
      PlaybackUrl: '{{ item.PlaybackUrl }}'
      SourceGroup: '{{ item.SourceGroup }}'
- discovery_id: aws.mediatailor.describeLiveSource
  calls:
  - action: describeLiveSource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.HttpPackageConfigurations }}'
    item:
      Path: '{{ item.Path }}'
      SourceGroup: '{{ item.SourceGroup }}'
      Type: '{{ item.Type }}'
- discovery_id: aws.mediatailor.describeProgram
  calls:
  - action: describeProgram
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AdBreaks }}'
    item:
      MessageType: '{{ item.MessageType }}'
      OffsetMillis: '{{ item.OffsetMillis }}'
      Slate: '{{ item.Slate }}'
      SpliceInsertMessage: '{{ item.SpliceInsertMessage }}'
      TimeSignalMessage: '{{ item.TimeSignalMessage }}'
      AdBreakMetadata: '{{ item.AdBreakMetadata }}'
- discovery_id: aws.mediatailor.describeSourceLocation
  calls:
  - action: describeSourceLocation
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.SegmentDeliveryConfigurations }}'
    item:
      BaseUrl: '{{ item.BaseUrl }}'
      Name: '{{ item.Name }}'
- discovery_id: aws.mediatailor.describeVodSource
  calls:
  - action: describeVodSource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AdBreakOpportunities }}'
    item:
      OffsetMillis: '{{ item.OffsetMillis }}'
- discovery_id: aws.mediatailor.getChannelPolicy
  calls:
  - action: getChannelPolicy
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Policy }}'
- discovery_id: aws.mediatailor.getChannelSchedule
  calls:
  - action: getChannelSchedule
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Items }}'
    item:
      ApproximateDurationSeconds: '{{ item.ApproximateDurationSeconds }}'
      ApproximateStartTime: '{{ item.ApproximateStartTime }}'
      Arn: '{{ item.Arn }}'
      ChannelName: '{{ item.ChannelName }}'
      LiveSourceName: '{{ item.LiveSourceName }}'
      ProgramName: '{{ item.ProgramName }}'
      ScheduleAdBreaks: '{{ item.ScheduleAdBreaks }}'
      ScheduleEntryType: '{{ item.ScheduleEntryType }}'
      SourceLocationName: '{{ item.SourceLocationName }}'
      VodSourceName: '{{ item.VodSourceName }}'
      Audiences: '{{ item.Audiences }}'
- discovery_id: aws.mediatailor.getPlaybackConfiguration
  calls:
  - action: getPlaybackConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AvailSuppression }}'
    item:
      Mode: '{{ item.Mode }}'
      Value: '{{ item.Value }}'
      FillPolicy: '{{ item.FillPolicy }}'
- discovery_id: aws.mediatailor.getPrefetchSchedule
  calls:
  - action: getPrefetchSchedule
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Consumption }}'
    item:
      AvailMatchingCriteria: '{{ item.AvailMatchingCriteria }}'
      EndTime: '{{ item.EndTime }}'
      StartTime: '{{ item.StartTime }}'
- discovery_id: aws.mediatailor.listAlerts
  calls:
  - action: listAlerts
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Items }}'
    item:
      AlertCode: '{{ item.AlertCode }}'
      AlertMessage: '{{ item.AlertMessage }}'
      LastModifiedTime: '{{ item.LastModifiedTime }}'
      RelatedResourceArns: '{{ item.RelatedResourceArns }}'
      ResourceArn: '{{ item.ResourceArn }}'
      Category: '{{ item.Category }}'
- discovery_id: aws.mediatailor.listLiveSources
  calls:
  - action: listLiveSources
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Items }}'
    item:
      Arn: '{{ item.Arn }}'
      CreationTime: '{{ item.CreationTime }}'
      HttpPackageConfigurations: '{{ item.HttpPackageConfigurations }}'
      LastModifiedTime: '{{ item.LastModifiedTime }}'
      LiveSourceName: '{{ item.LiveSourceName }}'
      SourceLocationName: '{{ item.SourceLocationName }}'
      Tags: '{{ item.Tags }}'
- discovery_id: aws.mediatailor.listPrefetchSchedules
  calls:
  - action: listPrefetchSchedules
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Items }}'
    item:
      Arn: '{{ item.Arn }}'
      Consumption: '{{ item.Consumption }}'
      Name: '{{ item.Name }}'
      PlaybackConfigurationName: '{{ item.PlaybackConfigurationName }}'
      Retrieval: '{{ item.Retrieval }}'
      ScheduleType: '{{ item.ScheduleType }}'
      RecurringPrefetchConfiguration: '{{ item.RecurringPrefetchConfiguration }}'
      StreamId: '{{ item.StreamId }}'
- discovery_id: aws.mediatailor.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Tags }}'
- discovery_id: aws.mediatailor.listVodSources
  calls:
  - action: listVodSources
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Items }}'
    item:
      Arn: '{{ item.Arn }}'
      CreationTime: '{{ item.CreationTime }}'
      HttpPackageConfigurations: '{{ item.HttpPackageConfigurations }}'
      LastModifiedTime: '{{ item.LastModifiedTime }}'
      SourceLocationName: '{{ item.SourceLocationName }}'
      Tags: '{{ item.Tags }}'
      VodSourceName: '{{ item.VodSourceName }}'
checks: []
