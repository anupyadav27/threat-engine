version: '1.0'
provider: aws
service: timestream-influxdb
services:
  client: timestream-influxdb
  module: boto3.client
discovery:
- discovery_id: aws.timestream-influxdb.listDbClusters
  calls:
  - action: listDbClusters
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
    item:
      id: '{{ item.id }}'
      name: '{{ item.name }}'
      arn: '{{ item.arn }}'
      status: '{{ item.status }}'
      endpoint: '{{ item.endpoint }}'
      readerEndpoint: '{{ item.readerEndpoint }}'
      port: '{{ item.port }}'
      deploymentType: '{{ item.deploymentType }}'
      dbInstanceType: '{{ item.dbInstanceType }}'
      networkType: '{{ item.networkType }}'
      dbStorageType: '{{ item.dbStorageType }}'
      allocatedStorage: '{{ item.allocatedStorage }}'
      engineType: '{{ item.engineType }}'
- discovery_id: aws.timestream-influxdb.listDbInstances
  calls:
  - action: listDbInstances
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
    item:
      id: '{{ item.id }}'
      name: '{{ item.name }}'
      arn: '{{ item.arn }}'
      status: '{{ item.status }}'
      endpoint: '{{ item.endpoint }}'
      port: '{{ item.port }}'
      networkType: '{{ item.networkType }}'
      dbInstanceType: '{{ item.dbInstanceType }}'
      dbStorageType: '{{ item.dbStorageType }}'
      allocatedStorage: '{{ item.allocatedStorage }}'
      deploymentType: '{{ item.deploymentType }}'
- discovery_id: aws.timestream-influxdb.listDbParameterGroups
  calls:
  - action: listDbParameterGroups
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
    item:
      id: '{{ item.id }}'
      name: '{{ item.name }}'
      arn: '{{ item.arn }}'
      description: '{{ item.description }}'
- discovery_id: aws.timestream-influxdb.getDbCluster
  calls:
  - action: getDbCluster
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.vpcSubnetIds }}'
- discovery_id: aws.timestream-influxdb.getDbInstance
  calls:
  - action: getDbInstance
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.vpcSubnetIds }}'
- discovery_id: aws.timestream-influxdb.getDbParameterGroup
  calls:
  - action: getDbParameterGroup
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.parameters }}'
    item:
      InfluxDBv2: '{{ item.InfluxDBv2 }}'
      InfluxDBv3Core: '{{ item.InfluxDBv3Core }}'
      InfluxDBv3Enterprise: '{{ item.InfluxDBv3Enterprise }}'
- discovery_id: aws.timestream-influxdb.listDbInstancesForCluster
  calls:
  - action: listDbInstancesForCluster
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
    item:
      id: '{{ item.id }}'
      name: '{{ item.name }}'
      arn: '{{ item.arn }}'
      status: '{{ item.status }}'
      endpoint: '{{ item.endpoint }}'
      port: '{{ item.port }}'
      networkType: '{{ item.networkType }}'
      dbInstanceType: '{{ item.dbInstanceType }}'
      dbStorageType: '{{ item.dbStorageType }}'
      allocatedStorage: '{{ item.allocatedStorage }}'
      deploymentType: '{{ item.deploymentType }}'
      instanceMode: '{{ item.instanceMode }}'
      instanceModes: '{{ item.instanceModes }}'
- discovery_id: aws.timestream-influxdb.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tags }}'
checks: []
