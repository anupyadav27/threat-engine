version: '1.0'
provider: aws
service: ssm-sap
services:
  client: ssm-sap
  module: boto3.client
discovery:
- discovery_id: aws.ssm-sap.getApplication
  calls:
  - action: getApplication
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Application }}'
    item:
      Id: '{{ item.Id }}'
      Type: '{{ item.Type }}'
      Arn: '{{ item.Arn }}'
      AppRegistryArn: '{{ item.AppRegistryArn }}'
      Status: '{{ item.Status }}'
      DiscoveryStatus: '{{ item.DiscoveryStatus }}'
      Components: '{{ item.Components }}'
      LastUpdated: '{{ item.LastUpdated }}'
      StatusMessage: '{{ item.StatusMessage }}'
      AssociatedApplicationArns: '{{ item.AssociatedApplicationArns }}'
- discovery_id: aws.ssm-sap.getDatabase
  calls:
  - action: getDatabase
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Database }}'
    item:
      ApplicationId: '{{ item.ApplicationId }}'
      ComponentId: '{{ item.ComponentId }}'
      Credentials: '{{ item.Credentials }}'
      DatabaseId: '{{ item.DatabaseId }}'
      DatabaseName: '{{ item.DatabaseName }}'
      DatabaseType: '{{ item.DatabaseType }}'
      Arn: '{{ item.Arn }}'
      Status: '{{ item.Status }}'
      PrimaryHost: '{{ item.PrimaryHost }}'
      SQLPort: '{{ item.SQLPort }}'
      LastUpdated: '{{ item.LastUpdated }}'
      ConnectedComponentArns: '{{ item.ConnectedComponentArns }}'
- discovery_id: aws.ssm-sap.listApplications
  calls:
  - action: listApplications
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Applications }}'
    item:
      Id: '{{ item.Id }}'
      DiscoveryStatus: '{{ item.DiscoveryStatus }}'
      Type: '{{ item.Type }}'
      Arn: '{{ item.Arn }}'
      Tags: '{{ item.Tags }}'
- discovery_id: aws.ssm-sap.listComponents
  calls:
  - action: listComponents
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Components }}'
    item:
      ApplicationId: '{{ item.ApplicationId }}'
      ComponentId: '{{ item.ComponentId }}'
      ComponentType: '{{ item.ComponentType }}'
      Tags: '{{ item.Tags }}'
      Arn: '{{ item.Arn }}'
- discovery_id: aws.ssm-sap.listConfigurationCheckDefinitions
  calls:
  - action: listConfigurationCheckDefinitions
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.ConfigurationChecks }}'
    item:
      Id: '{{ item.Id }}'
      Name: '{{ item.Name }}'
      Description: '{{ item.Description }}'
      ApplicableApplicationTypes: '{{ item.ApplicableApplicationTypes }}'
- discovery_id: aws.ssm-sap.listDatabases
  calls:
  - action: listDatabases
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Databases }}'
    item:
      ApplicationId: '{{ item.ApplicationId }}'
      ComponentId: '{{ item.ComponentId }}'
      DatabaseId: '{{ item.DatabaseId }}'
      DatabaseType: '{{ item.DatabaseType }}'
      Arn: '{{ item.Arn }}'
      Tags: '{{ item.Tags }}'
- discovery_id: aws.ssm-sap.getComponent
  calls:
  - action: getComponent
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Component }}'
    item:
      ComponentId: '{{ item.ComponentId }}'
      Sid: '{{ item.Sid }}'
      SystemNumber: '{{ item.SystemNumber }}'
      ParentComponent: '{{ item.ParentComponent }}'
      ChildComponents: '{{ item.ChildComponents }}'
      ApplicationId: '{{ item.ApplicationId }}'
      ComponentType: '{{ item.ComponentType }}'
      Status: '{{ item.Status }}'
      SapHostname: '{{ item.SapHostname }}'
      SapFeature: '{{ item.SapFeature }}'
      SapKernelVersion: '{{ item.SapKernelVersion }}'
      HdbVersion: '{{ item.HdbVersion }}'
      Resilience: '{{ item.Resilience }}'
      AssociatedHost: '{{ item.AssociatedHost }}'
      Databases: '{{ item.Databases }}'
      Hosts: '{{ item.Hosts }}'
      PrimaryHost: '{{ item.PrimaryHost }}'
      DatabaseConnection: '{{ item.DatabaseConnection }}'
      LastUpdated: '{{ item.LastUpdated }}'
      Arn: '{{ item.Arn }}'
- discovery_id: aws.ssm-sap.getConfigurationCheckOperation
  calls:
  - action: getConfigurationCheckOperation
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ConfigurationCheckOperation }}'
    item:
      Id: '{{ item.Id }}'
      ApplicationId: '{{ item.ApplicationId }}'
      Status: '{{ item.Status }}'
      StatusMessage: '{{ item.StatusMessage }}'
      ConfigurationCheckId: '{{ item.ConfigurationCheckId }}'
      ConfigurationCheckName: '{{ item.ConfigurationCheckName }}'
      ConfigurationCheckDescription: '{{ item.ConfigurationCheckDescription }}'
      StartTime: '{{ item.StartTime }}'
      EndTime: '{{ item.EndTime }}'
      RuleStatusCounts: '{{ item.RuleStatusCounts }}'
- discovery_id: aws.ssm-sap.getOperation
  calls:
  - action: getOperation
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Operation }}'
    item:
      Id: '{{ item.Id }}'
      Type: '{{ item.Type }}'
      Status: '{{ item.Status }}'
      StatusMessage: '{{ item.StatusMessage }}'
      Properties: '{{ item.Properties }}'
      ResourceType: '{{ item.ResourceType }}'
      ResourceId: '{{ item.ResourceId }}'
      ResourceArn: '{{ item.ResourceArn }}'
      StartTime: '{{ item.StartTime }}'
      EndTime: '{{ item.EndTime }}'
      LastUpdatedTime: '{{ item.LastUpdatedTime }}'
- discovery_id: aws.ssm-sap.getResourcePermission
  calls:
  - action: getResourcePermission
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Policy }}'
- discovery_id: aws.ssm-sap.listConfigurationCheckOperations
  calls:
  - action: listConfigurationCheckOperations
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.ConfigurationCheckOperations }}'
    item:
      Id: '{{ item.Id }}'
      ApplicationId: '{{ item.ApplicationId }}'
      Status: '{{ item.Status }}'
      StatusMessage: '{{ item.StatusMessage }}'
      ConfigurationCheckId: '{{ item.ConfigurationCheckId }}'
      ConfigurationCheckName: '{{ item.ConfigurationCheckName }}'
      ConfigurationCheckDescription: '{{ item.ConfigurationCheckDescription }}'
      StartTime: '{{ item.StartTime }}'
      EndTime: '{{ item.EndTime }}'
      RuleStatusCounts: '{{ item.RuleStatusCounts }}'
- discovery_id: aws.ssm-sap.listOperationEvents
  calls:
  - action: listOperationEvents
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.OperationEvents }}'
    item:
      Description: '{{ item.Description }}'
      Resource: '{{ item.Resource }}'
      Status: '{{ item.Status }}'
      StatusMessage: '{{ item.StatusMessage }}'
      Timestamp: '{{ item.Timestamp }}'
- discovery_id: aws.ssm-sap.listOperations
  calls:
  - action: listOperations
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Operations }}'
    item:
      Id: '{{ item.Id }}'
      Type: '{{ item.Type }}'
      Status: '{{ item.Status }}'
      StatusMessage: '{{ item.StatusMessage }}'
      Properties: '{{ item.Properties }}'
      ResourceType: '{{ item.ResourceType }}'
      ResourceId: '{{ item.ResourceId }}'
      ResourceArn: '{{ item.ResourceArn }}'
      StartTime: '{{ item.StartTime }}'
      EndTime: '{{ item.EndTime }}'
      LastUpdatedTime: '{{ item.LastUpdatedTime }}'
- discovery_id: aws.ssm-sap.listSubCheckResults
  calls:
  - action: listSubCheckResults
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.SubCheckResults }}'
    item:
      Id: '{{ item.Id }}'
      Name: '{{ item.Name }}'
      Description: '{{ item.Description }}'
      References: '{{ item.References }}'
- discovery_id: aws.ssm-sap.listSubCheckRuleResults
  calls:
  - action: listSubCheckRuleResults
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.RuleResults }}'
    item:
      Id: '{{ item.Id }}'
      Description: '{{ item.Description }}'
      Status: '{{ item.Status }}'
      Message: '{{ item.Message }}'
      Metadata: '{{ item.Metadata }}'
- discovery_id: aws.ssm-sap.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tags }}'
checks: []
