version: '1.0'
provider: aws
service: grafana
services:
  client: grafana
  module: boto3.client
discovery:
- discovery_id: aws.grafana.listVersions
  calls:
  - action: listVersions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.grafanaVersions }}'
- discovery_id: aws.grafana.listWorkspaces
  calls:
  - action: listWorkspaces
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.workspaces }}'
    item:
      authentication: '{{ item.authentication }}'
      created: '{{ item.created }}'
      description: '{{ item.description }}'
      endpoint: '{{ item.endpoint }}'
      grafanaToken: '{{ item.grafanaToken }}'
      grafanaVersion: '{{ item.grafanaVersion }}'
      id: '{{ item.id }}'
      licenseType: '{{ item.licenseType }}'
      modified: '{{ item.modified }}'
      name: '{{ item.name }}'
      notificationDestinations: '{{ item.notificationDestinations }}'
      status: '{{ item.status }}'
      tags: '{{ item.tags }}'
- discovery_id: aws.grafana.describeWorkspace
  calls:
  - action: describeWorkspace
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.workspace }}'
    item:
      accountAccessType: '{{ item.accountAccessType }}'
      authentication: '{{ item.authentication }}'
      created: '{{ item.created }}'
      dataSources: '{{ item.dataSources }}'
      description: '{{ item.description }}'
      endpoint: '{{ item.endpoint }}'
      freeTrialConsumed: '{{ item.freeTrialConsumed }}'
      freeTrialExpiration: '{{ item.freeTrialExpiration }}'
      grafanaToken: '{{ item.grafanaToken }}'
      grafanaVersion: '{{ item.grafanaVersion }}'
      id: '{{ item.id }}'
      licenseExpiration: '{{ item.licenseExpiration }}'
      licenseType: '{{ item.licenseType }}'
      modified: '{{ item.modified }}'
      name: '{{ item.name }}'
      networkAccessControl: '{{ item.networkAccessControl }}'
      notificationDestinations: '{{ item.notificationDestinations }}'
      organizationRoleName: '{{ item.organizationRoleName }}'
      organizationalUnits: '{{ item.organizationalUnits }}'
      permissionType: '{{ item.permissionType }}'
      stackSetName: '{{ item.stackSetName }}'
      status: '{{ item.status }}'
      tags: '{{ item.tags }}'
      vpcConfiguration: '{{ item.vpcConfiguration }}'
      workspaceRoleArn: '{{ item.workspaceRoleArn }}'
- discovery_id: aws.grafana.describeWorkspaceAuthentication
  calls:
  - action: describeWorkspaceAuthentication
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.authentication }}'
    item:
      awsSso: '{{ item.awsSso }}'
      providers: '{{ item.providers }}'
      saml: '{{ item.saml }}'
- discovery_id: aws.grafana.describeWorkspaceConfiguration
  calls:
  - action: describeWorkspaceConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.configuration }}'
- discovery_id: aws.grafana.listPermissions
  calls:
  - action: listPermissions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.permissions }}'
    item:
      role: '{{ item.role }}'
      user: '{{ item.user }}'
- discovery_id: aws.grafana.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tags }}'
- discovery_id: aws.grafana.listWorkspaceServiceAccountTokens
  calls:
  - action: listWorkspaceServiceAccountTokens
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.serviceAccountTokens }}'
    item:
      createdAt: '{{ item.createdAt }}'
      expiresAt: '{{ item.expiresAt }}'
      id: '{{ item.id }}'
      lastUsedAt: '{{ item.lastUsedAt }}'
      name: '{{ item.name }}'
- discovery_id: aws.grafana.listWorkspaceServiceAccounts
  calls:
  - action: listWorkspaceServiceAccounts
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.serviceAccounts }}'
    item:
      grafanaRole: '{{ item.grafanaRole }}'
      id: '{{ item.id }}'
      isDisabled: '{{ item.isDisabled }}'
      name: '{{ item.name }}'
checks: []
