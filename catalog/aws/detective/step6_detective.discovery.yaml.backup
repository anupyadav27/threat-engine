version: '1.0'
provider: aws
service: detective
services:
  client: detective
  module: boto3.client
discovery:
- discovery_id: aws.detective.listGraphs
  calls:
  - action: listGraphs
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.GraphList }}'
    item:
      Arn: '{{ item.Arn }}'
      CreatedTime: '{{ item.CreatedTime }}'
- discovery_id: aws.detective.listInvitations
  calls:
  - action: listInvitations
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Invitations }}'
    item:
      AccountId: '{{ item.AccountId }}'
      EmailAddress: '{{ item.EmailAddress }}'
      GraphArn: '{{ item.GraphArn }}'
      MasterId: '{{ item.MasterId }}'
      AdministratorId: '{{ item.AdministratorId }}'
      Status: '{{ item.Status }}'
      DisabledReason: '{{ item.DisabledReason }}'
      InvitedTime: '{{ item.InvitedTime }}'
      UpdatedTime: '{{ item.UpdatedTime }}'
      VolumeUsageInBytes: '{{ item.VolumeUsageInBytes }}'
      VolumeUsageUpdatedTime: '{{ item.VolumeUsageUpdatedTime }}'
      PercentOfGraphUtilization: '{{ item.PercentOfGraphUtilization }}'
      PercentOfGraphUtilizationUpdatedTime: '{{ item.PercentOfGraphUtilizationUpdatedTime
        }}'
      InvitationType: '{{ item.InvitationType }}'
      VolumeUsageByDatasourcePackage: '{{ item.VolumeUsageByDatasourcePackage }}'
      DatasourcePackageIngestStates: '{{ item.DatasourcePackageIngestStates }}'
- discovery_id: aws.detective.listOrganizationAdminAccounts
  calls:
  - action: listOrganizationAdminAccounts
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Administrators }}'
    item:
      AccountId: '{{ item.AccountId }}'
      GraphArn: '{{ item.GraphArn }}'
      DelegationTime: '{{ item.DelegationTime }}'
- discovery_id: aws.detective.describeOrganizationConfiguration
  calls:
  - action: describeOrganizationConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AutoEnable }}'
- discovery_id: aws.detective.getInvestigation
  calls:
  - action: getInvestigation
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.GraphArn }}'
- discovery_id: aws.detective.getMembers
  calls:
  - action: getMembers
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.MemberDetails }}'
    item:
      AccountId: '{{ item.AccountId }}'
      EmailAddress: '{{ item.EmailAddress }}'
      GraphArn: '{{ item.GraphArn }}'
      MasterId: '{{ item.MasterId }}'
      AdministratorId: '{{ item.AdministratorId }}'
      Status: '{{ item.Status }}'
      DisabledReason: '{{ item.DisabledReason }}'
      InvitedTime: '{{ item.InvitedTime }}'
      UpdatedTime: '{{ item.UpdatedTime }}'
      VolumeUsageInBytes: '{{ item.VolumeUsageInBytes }}'
      VolumeUsageUpdatedTime: '{{ item.VolumeUsageUpdatedTime }}'
      PercentOfGraphUtilization: '{{ item.PercentOfGraphUtilization }}'
      PercentOfGraphUtilizationUpdatedTime: '{{ item.PercentOfGraphUtilizationUpdatedTime
        }}'
      InvitationType: '{{ item.InvitationType }}'
      VolumeUsageByDatasourcePackage: '{{ item.VolumeUsageByDatasourcePackage }}'
      DatasourcePackageIngestStates: '{{ item.DatasourcePackageIngestStates }}'
- discovery_id: aws.detective.listDatasourcePackages
  calls:
  - action: listDatasourcePackages
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.DatasourcePackages }}'
- discovery_id: aws.detective.listIndicators
  calls:
  - action: listIndicators
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Indicators }}'
    item:
      IndicatorType: '{{ item.IndicatorType }}'
      IndicatorDetail: '{{ item.IndicatorDetail }}'
- discovery_id: aws.detective.listInvestigations
  calls:
  - action: listInvestigations
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.InvestigationDetails }}'
    item:
      InvestigationId: '{{ item.InvestigationId }}'
      Severity: '{{ item.Severity }}'
      Status: '{{ item.Status }}'
      State: '{{ item.State }}'
      CreatedTime: '{{ item.CreatedTime }}'
      EntityArn: '{{ item.EntityArn }}'
      EntityType: '{{ item.EntityType }}'
- discovery_id: aws.detective.listMembers
  calls:
  - action: listMembers
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.MemberDetails }}'
    item:
      AccountId: '{{ item.AccountId }}'
      EmailAddress: '{{ item.EmailAddress }}'
      GraphArn: '{{ item.GraphArn }}'
      MasterId: '{{ item.MasterId }}'
      AdministratorId: '{{ item.AdministratorId }}'
      Status: '{{ item.Status }}'
      DisabledReason: '{{ item.DisabledReason }}'
      InvitedTime: '{{ item.InvitedTime }}'
      UpdatedTime: '{{ item.UpdatedTime }}'
      VolumeUsageInBytes: '{{ item.VolumeUsageInBytes }}'
      VolumeUsageUpdatedTime: '{{ item.VolumeUsageUpdatedTime }}'
      PercentOfGraphUtilization: '{{ item.PercentOfGraphUtilization }}'
      PercentOfGraphUtilizationUpdatedTime: '{{ item.PercentOfGraphUtilizationUpdatedTime
        }}'
      InvitationType: '{{ item.InvitationType }}'
      VolumeUsageByDatasourcePackage: '{{ item.VolumeUsageByDatasourcePackage }}'
      DatasourcePackageIngestStates: '{{ item.DatasourcePackageIngestStates }}'
- discovery_id: aws.detective.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Tags }}'
checks: []
