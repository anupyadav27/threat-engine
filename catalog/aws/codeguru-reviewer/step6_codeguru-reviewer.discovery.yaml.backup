version: '1.0'
provider: aws
service: codeguru-reviewer
services:
  client: codeguru-reviewer
  module: boto3.client
discovery:
- discovery_id: aws.codeguru-reviewer.listRepositoryAssociations
  calls:
  - action: listRepositoryAssociations
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.RepositoryAssociationSummaries }}'
    item:
      AssociationArn: '{{ item.AssociationArn }}'
      ConnectionArn: '{{ item.ConnectionArn }}'
      LastUpdatedTimeStamp: '{{ item.LastUpdatedTimeStamp }}'
      AssociationId: '{{ item.AssociationId }}'
      Name: '{{ item.Name }}'
      Owner: '{{ item.Owner }}'
      ProviderType: '{{ item.ProviderType }}'
      State: '{{ item.State }}'
- discovery_id: aws.codeguru-reviewer.describeCodeReview
  calls:
  - action: describeCodeReview
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.CodeReview }}'
    item:
      Name: '{{ item.Name }}'
      CodeReviewArn: '{{ item.CodeReviewArn }}'
      RepositoryName: '{{ item.RepositoryName }}'
      Owner: '{{ item.Owner }}'
      ProviderType: '{{ item.ProviderType }}'
      State: '{{ item.State }}'
      StateReason: '{{ item.StateReason }}'
      CreatedTimeStamp: '{{ item.CreatedTimeStamp }}'
      LastUpdatedTimeStamp: '{{ item.LastUpdatedTimeStamp }}'
      Type: '{{ item.Type }}'
      PullRequestId: '{{ item.PullRequestId }}'
      SourceCodeType: '{{ item.SourceCodeType }}'
      AssociationArn: '{{ item.AssociationArn }}'
      Metrics: '{{ item.Metrics }}'
      AnalysisTypes: '{{ item.AnalysisTypes }}'
      ConfigFileState: '{{ item.ConfigFileState }}'
- discovery_id: aws.codeguru-reviewer.describeRecommendationFeedback
  calls:
  - action: describeRecommendationFeedback
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.RecommendationFeedback }}'
    item:
      CodeReviewArn: '{{ item.CodeReviewArn }}'
      RecommendationId: '{{ item.RecommendationId }}'
      Reactions: '{{ item.Reactions }}'
      UserId: '{{ item.UserId }}'
      CreatedTimeStamp: '{{ item.CreatedTimeStamp }}'
      LastUpdatedTimeStamp: '{{ item.LastUpdatedTimeStamp }}'
- discovery_id: aws.codeguru-reviewer.describeRepositoryAssociation
  calls:
  - action: describeRepositoryAssociation
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.RepositoryAssociation }}'
    item:
      AssociationId: '{{ item.AssociationId }}'
      AssociationArn: '{{ item.AssociationArn }}'
      ConnectionArn: '{{ item.ConnectionArn }}'
      Name: '{{ item.Name }}'
      Owner: '{{ item.Owner }}'
      ProviderType: '{{ item.ProviderType }}'
      State: '{{ item.State }}'
      StateReason: '{{ item.StateReason }}'
      LastUpdatedTimeStamp: '{{ item.LastUpdatedTimeStamp }}'
      CreatedTimeStamp: '{{ item.CreatedTimeStamp }}'
      KMSKeyDetails: '{{ item.KMSKeyDetails }}'
      S3RepositoryDetails: '{{ item.S3RepositoryDetails }}'
- discovery_id: aws.codeguru-reviewer.listCodeReviews
  calls:
  - action: listCodeReviews
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.CodeReviewSummaries }}'
    item:
      Name: '{{ item.Name }}'
      CodeReviewArn: '{{ item.CodeReviewArn }}'
      RepositoryName: '{{ item.RepositoryName }}'
      Owner: '{{ item.Owner }}'
      ProviderType: '{{ item.ProviderType }}'
      State: '{{ item.State }}'
      CreatedTimeStamp: '{{ item.CreatedTimeStamp }}'
      LastUpdatedTimeStamp: '{{ item.LastUpdatedTimeStamp }}'
      Type: '{{ item.Type }}'
      PullRequestId: '{{ item.PullRequestId }}'
      MetricsSummary: '{{ item.MetricsSummary }}'
      SourceCodeType: '{{ item.SourceCodeType }}'
- discovery_id: aws.codeguru-reviewer.listRecommendationFeedback
  calls:
  - action: listRecommendationFeedback
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.RecommendationFeedbackSummaries }}'
    item:
      RecommendationId: '{{ item.RecommendationId }}'
      Reactions: '{{ item.Reactions }}'
      UserId: '{{ item.UserId }}'
- discovery_id: aws.codeguru-reviewer.listRecommendations
  calls:
  - action: listRecommendations
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.RecommendationSummaries }}'
    item:
      FilePath: '{{ item.FilePath }}'
      RecommendationId: '{{ item.RecommendationId }}'
      StartLine: '{{ item.StartLine }}'
      EndLine: '{{ item.EndLine }}'
      Description: '{{ item.Description }}'
      RecommendationCategory: '{{ item.RecommendationCategory }}'
      RuleMetadata: '{{ item.RuleMetadata }}'
      Severity: '{{ item.Severity }}'
- discovery_id: aws.codeguru-reviewer.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Tags }}'
checks: []
