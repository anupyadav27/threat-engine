version: '1.0'
provider: aws
service: sagemaker-geospatial
services:
  client: sagemaker-geospatial
  module: boto3.client
discovery:
- discovery_id: aws.sagemaker-geospatial.listEarthObservationJobs
  calls:
  - action: listEarthObservationJobs
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.EarthObservationJobSummaries }}'
    item:
      Arn: '{{ item.Arn }}'
      CreationTime: '{{ item.CreationTime }}'
      DurationInSeconds: '{{ item.DurationInSeconds }}'
      Name: '{{ item.Name }}'
      OperationType: '{{ item.OperationType }}'
      Status: '{{ item.Status }}'
      Tags: '{{ item.Tags }}'
- discovery_id: aws.sagemaker-geospatial.listRasterDataCollections
  calls:
  - action: listRasterDataCollections
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.RasterDataCollectionSummaries }}'
    item:
      Arn: '{{ item.Arn }}'
      Description: '{{ item.Description }}'
      DescriptionPageUrl: '{{ item.DescriptionPageUrl }}'
      Name: '{{ item.Name }}'
      SupportedFilters: '{{ item.SupportedFilters }}'
      Tags: '{{ item.Tags }}'
      Type: '{{ item.Type }}'
- discovery_id: aws.sagemaker-geospatial.listVectorEnrichmentJobs
  calls:
  - action: listVectorEnrichmentJobs
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.VectorEnrichmentJobSummaries }}'
    item:
      Arn: '{{ item.Arn }}'
      CreationTime: '{{ item.CreationTime }}'
      DurationInSeconds: '{{ item.DurationInSeconds }}'
      Name: '{{ item.Name }}'
      Status: '{{ item.Status }}'
      Tags: '{{ item.Tags }}'
      Type: '{{ item.Type }}'
- discovery_id: aws.sagemaker-geospatial.getEarthObservationJob
  calls:
  - action: getEarthObservationJob
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.OutputBands }}'
    item:
      BandName: '{{ item.BandName }}'
      OutputDataType: '{{ item.OutputDataType }}'
- discovery_id: aws.sagemaker-geospatial.getRasterDataCollection
  calls:
  - action: getRasterDataCollection
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ImageSourceBands }}'
- discovery_id: aws.sagemaker-geospatial.getTile
  calls:
  - action: getTile
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.BinaryFile }}'
- discovery_id: aws.sagemaker-geospatial.getVectorEnrichmentJob
  calls:
  - action: getVectorEnrichmentJob
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ErrorDetails }}'
    item:
      ErrorMessage: '{{ item.ErrorMessage }}'
      ErrorType: '{{ item.ErrorType }}'
- discovery_id: aws.sagemaker-geospatial.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Tags }}'
- discovery_id: aws.sagemaker-geospatial.searchRasterDataCollection
  calls:
  - action: searchRasterDataCollection
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Items }}'
    item:
      Assets: '{{ item.Assets }}'
      DateTime: '{{ item.DateTime }}'
      Geometry: '{{ item.Geometry }}'
      Id: '{{ item.Id }}'
      Properties: '{{ item.Properties }}'
checks: []
