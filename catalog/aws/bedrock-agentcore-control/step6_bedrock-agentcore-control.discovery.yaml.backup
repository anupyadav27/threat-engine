version: '1.0'
provider: aws
service: bedrock-agentcore-control
services:
  client: bedrock-agentcore-control
  module: boto3.client
discovery:
- discovery_id: aws.bedrock-agentcore-control.getTokenVault
  calls:
  - action: getTokenVault
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.kmsConfiguration }}'
    item:
      keyType: '{{ item.keyType }}'
      kmsKeyArn: '{{ item.kmsKeyArn }}'
- discovery_id: aws.bedrock-agentcore-control.listAgentRuntimes
  calls:
  - action: listAgentRuntimes
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.agentRuntimes }}'
    item:
      agentRuntimeArn: '{{ item.agentRuntimeArn }}'
      agentRuntimeId: '{{ item.agentRuntimeId }}'
      agentRuntimeVersion: '{{ item.agentRuntimeVersion }}'
      agentRuntimeName: '{{ item.agentRuntimeName }}'
      description: '{{ item.description }}'
      lastUpdatedAt: '{{ item.lastUpdatedAt }}'
      status: '{{ item.status }}'
- discovery_id: aws.bedrock-agentcore-control.listApiKeyCredentialProviders
  calls:
  - action: listApiKeyCredentialProviders
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.credentialProviders }}'
    item:
      name: '{{ item.name }}'
      credentialProviderArn: '{{ item.credentialProviderArn }}'
      createdTime: '{{ item.createdTime }}'
      lastUpdatedTime: '{{ item.lastUpdatedTime }}'
- discovery_id: aws.bedrock-agentcore-control.listBrowsers
  calls:
  - action: listBrowsers
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.browserSummaries }}'
    item:
      browserId: '{{ item.browserId }}'
      browserArn: '{{ item.browserArn }}'
      name: '{{ item.name }}'
      description: '{{ item.description }}'
      status: '{{ item.status }}'
      createdAt: '{{ item.createdAt }}'
      lastUpdatedAt: '{{ item.lastUpdatedAt }}'
- discovery_id: aws.bedrock-agentcore-control.listCodeInterpreters
  calls:
  - action: listCodeInterpreters
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.codeInterpreterSummaries }}'
    item:
      codeInterpreterId: '{{ item.codeInterpreterId }}'
      codeInterpreterArn: '{{ item.codeInterpreterArn }}'
      name: '{{ item.name }}'
      description: '{{ item.description }}'
      status: '{{ item.status }}'
      createdAt: '{{ item.createdAt }}'
      lastUpdatedAt: '{{ item.lastUpdatedAt }}'
- discovery_id: aws.bedrock-agentcore-control.listGateways
  calls:
  - action: listGateways
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
    item:
      gatewayId: '{{ item.gatewayId }}'
      name: '{{ item.name }}'
      status: '{{ item.status }}'
      description: '{{ item.description }}'
      createdAt: '{{ item.createdAt }}'
      updatedAt: '{{ item.updatedAt }}'
      authorizerType: '{{ item.authorizerType }}'
      protocolType: '{{ item.protocolType }}'
- discovery_id: aws.bedrock-agentcore-control.listMemories
  calls:
  - action: listMemories
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.memories }}'
    item:
      arn: '{{ item.arn }}'
      id: '{{ item.id }}'
      status: '{{ item.status }}'
      createdAt: '{{ item.createdAt }}'
      updatedAt: '{{ item.updatedAt }}'
- discovery_id: aws.bedrock-agentcore-control.listOauth2CredentialProviders
  calls:
  - action: listOauth2CredentialProviders
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.credentialProviders }}'
    item:
      name: '{{ item.name }}'
      credentialProviderVendor: '{{ item.credentialProviderVendor }}'
      credentialProviderArn: '{{ item.credentialProviderArn }}'
      createdTime: '{{ item.createdTime }}'
      lastUpdatedTime: '{{ item.lastUpdatedTime }}'
- discovery_id: aws.bedrock-agentcore-control.listWorkloadIdentities
  calls:
  - action: listWorkloadIdentities
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.workloadIdentities }}'
    item:
      name: '{{ item.name }}'
      workloadIdentityArn: '{{ item.workloadIdentityArn }}'
- discovery_id: aws.bedrock-agentcore-control.getAgentRuntime
  calls:
  - action: getAgentRuntime
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.networkConfiguration }}'
    item:
      networkMode: '{{ item.networkMode }}'
      networkModeConfig: '{{ item.networkModeConfig }}'
- discovery_id: aws.bedrock-agentcore-control.getAgentRuntimeEndpoint
  calls:
  - action: getAgentRuntimeEndpoint
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.liveVersion }}'
- discovery_id: aws.bedrock-agentcore-control.getApiKeyCredentialProvider
  calls:
  - action: getApiKeyCredentialProvider
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.apiKeySecretArn }}'
    item:
      secretArn: '{{ item.secretArn }}'
- discovery_id: aws.bedrock-agentcore-control.getBrowser
  calls:
  - action: getBrowser
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.networkConfiguration }}'
    item:
      networkMode: '{{ item.networkMode }}'
      vpcConfig: '{{ item.vpcConfig }}'
- discovery_id: aws.bedrock-agentcore-control.getCodeInterpreter
  calls:
  - action: getCodeInterpreter
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.networkConfiguration }}'
    item:
      networkMode: '{{ item.networkMode }}'
      vpcConfig: '{{ item.vpcConfig }}'
- discovery_id: aws.bedrock-agentcore-control.getGateway
  calls:
  - action: getGateway
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.statusReasons }}'
- discovery_id: aws.bedrock-agentcore-control.getGatewayTarget
  calls:
  - action: getGatewayTarget
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.statusReasons }}'
- discovery_id: aws.bedrock-agentcore-control.getMemory
  calls:
  - action: getMemory
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.memory }}'
    item:
      arn: '{{ item.arn }}'
      id: '{{ item.id }}'
      name: '{{ item.name }}'
      description: '{{ item.description }}'
      encryptionKeyArn: '{{ item.encryptionKeyArn }}'
      memoryExecutionRoleArn: '{{ item.memoryExecutionRoleArn }}'
      eventExpiryDuration: '{{ item.eventExpiryDuration }}'
      status: '{{ item.status }}'
      failureReason: '{{ item.failureReason }}'
      createdAt: '{{ item.createdAt }}'
      updatedAt: '{{ item.updatedAt }}'
      strategies: '{{ item.strategies }}'
- discovery_id: aws.bedrock-agentcore-control.getOauth2CredentialProvider
  calls:
  - action: getOauth2CredentialProvider
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.clientSecretArn }}'
    item:
      secretArn: '{{ item.secretArn }}'
- discovery_id: aws.bedrock-agentcore-control.getWorkloadIdentity
  calls:
  - action: getWorkloadIdentity
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.allowedResourceOauth2ReturnUrls }}'
- discovery_id: aws.bedrock-agentcore-control.listAgentRuntimeEndpoints
  calls:
  - action: listAgentRuntimeEndpoints
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.runtimeEndpoints }}'
    item:
      name: '{{ item.name }}'
      liveVersion: '{{ item.liveVersion }}'
      targetVersion: '{{ item.targetVersion }}'
      agentRuntimeEndpointArn: '{{ item.agentRuntimeEndpointArn }}'
      agentRuntimeArn: '{{ item.agentRuntimeArn }}'
      status: '{{ item.status }}'
      id: '{{ item.id }}'
      description: '{{ item.description }}'
      createdAt: '{{ item.createdAt }}'
      lastUpdatedAt: '{{ item.lastUpdatedAt }}'
- discovery_id: aws.bedrock-agentcore-control.listAgentRuntimeVersions
  calls:
  - action: listAgentRuntimeVersions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.agentRuntimes }}'
    item:
      agentRuntimeArn: '{{ item.agentRuntimeArn }}'
      agentRuntimeId: '{{ item.agentRuntimeId }}'
      agentRuntimeVersion: '{{ item.agentRuntimeVersion }}'
      agentRuntimeName: '{{ item.agentRuntimeName }}'
      description: '{{ item.description }}'
      lastUpdatedAt: '{{ item.lastUpdatedAt }}'
      status: '{{ item.status }}'
- discovery_id: aws.bedrock-agentcore-control.listGatewayTargets
  calls:
  - action: listGatewayTargets
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
    item:
      targetId: '{{ item.targetId }}'
      name: '{{ item.name }}'
      status: '{{ item.status }}'
      description: '{{ item.description }}'
      createdAt: '{{ item.createdAt }}'
      updatedAt: '{{ item.updatedAt }}'
- discovery_id: aws.bedrock-agentcore-control.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tags }}'
checks: []
