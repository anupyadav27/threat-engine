version: '1.0'
provider: aws
service: launch-wizard
services:
  client: launch-wizard
  module: boto3.client
discovery:
- discovery_id: aws.launch-wizard.listDeployments
  calls:
  - action: listDeployments
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.deployments }}'
    item:
      createdAt: '{{ item.createdAt }}'
      id: '{{ item.id }}'
      name: '{{ item.name }}'
      patternName: '{{ item.patternName }}'
      status: '{{ item.status }}'
      workloadName: '{{ item.workloadName }}'
- discovery_id: aws.launch-wizard.listWorkloads
  calls:
  - action: listWorkloads
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.workloads }}'
    item:
      displayName: '{{ item.displayName }}'
      workloadName: '{{ item.workloadName }}'
- discovery_id: aws.launch-wizard.getDeployment
  calls:
  - action: getDeployment
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.deployment }}'
    item:
      createdAt: '{{ item.createdAt }}'
      deletedAt: '{{ item.deletedAt }}'
      deploymentArn: '{{ item.deploymentArn }}'
      id: '{{ item.id }}'
      name: '{{ item.name }}'
      patternName: '{{ item.patternName }}'
      resourceGroup: '{{ item.resourceGroup }}'
      specifications: '{{ item.specifications }}'
      status: '{{ item.status }}'
      tags: '{{ item.tags }}'
      workloadName: '{{ item.workloadName }}'
- discovery_id: aws.launch-wizard.getWorkload
  calls:
  - action: getWorkload
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.workload }}'
    item:
      description: '{{ item.description }}'
      displayName: '{{ item.displayName }}'
      documentationUrl: '{{ item.documentationUrl }}'
      iconUrl: '{{ item.iconUrl }}'
      status: '{{ item.status }}'
      statusMessage: '{{ item.statusMessage }}'
      workloadName: '{{ item.workloadName }}'
- discovery_id: aws.launch-wizard.getWorkloadDeploymentPattern
  calls:
  - action: getWorkloadDeploymentPattern
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.workloadDeploymentPattern }}'
    item:
      deploymentPatternName: '{{ item.deploymentPatternName }}'
      description: '{{ item.description }}'
      displayName: '{{ item.displayName }}'
      specifications: '{{ item.specifications }}'
      status: '{{ item.status }}'
      statusMessage: '{{ item.statusMessage }}'
      workloadName: '{{ item.workloadName }}'
      workloadVersionName: '{{ item.workloadVersionName }}'
- discovery_id: aws.launch-wizard.listDeploymentEvents
  calls:
  - action: listDeploymentEvents
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.deploymentEvents }}'
    item:
      description: '{{ item.description }}'
      name: '{{ item.name }}'
      status: '{{ item.status }}'
      statusReason: '{{ item.statusReason }}'
      timestamp: '{{ item.timestamp }}'
- discovery_id: aws.launch-wizard.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tags }}'
- discovery_id: aws.launch-wizard.listWorkloadDeploymentPatterns
  calls:
  - action: listWorkloadDeploymentPatterns
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.workloadDeploymentPatterns }}'
    item:
      deploymentPatternName: '{{ item.deploymentPatternName }}'
      description: '{{ item.description }}'
      displayName: '{{ item.displayName }}'
      status: '{{ item.status }}'
      statusMessage: '{{ item.statusMessage }}'
      workloadName: '{{ item.workloadName }}'
      workloadVersionName: '{{ item.workloadVersionName }}'
checks: []
