version: '1.0'
provider: aws
service: migration-hub-refactor-spaces
services:
  client: migration-hub-refactor-spaces
  module: boto3.client
discovery:
- discovery_id: aws.migration-hub-refactor-spaces.listEnvironments
  calls:
  - action: listEnvironments
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.EnvironmentSummaryList }}'
    item:
      Arn: '{{ item.Arn }}'
      CreatedTime: '{{ item.CreatedTime }}'
      Description: '{{ item.Description }}'
      EnvironmentId: '{{ item.EnvironmentId }}'
      Error: '{{ item.Error }}'
      LastUpdatedTime: '{{ item.LastUpdatedTime }}'
      Name: '{{ item.Name }}'
      NetworkFabricType: '{{ item.NetworkFabricType }}'
      OwnerAccountId: '{{ item.OwnerAccountId }}'
      State: '{{ item.State }}'
      Tags: '{{ item.Tags }}'
      TransitGatewayId: '{{ item.TransitGatewayId }}'
- discovery_id: aws.migration-hub-refactor-spaces.getApplication
  calls:
  - action: getApplication
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ApiGatewayProxy }}'
    item:
      ApiGatewayId: '{{ item.ApiGatewayId }}'
      EndpointType: '{{ item.EndpointType }}'
      NlbArn: '{{ item.NlbArn }}'
      NlbName: '{{ item.NlbName }}'
      ProxyUrl: '{{ item.ProxyUrl }}'
      StageName: '{{ item.StageName }}'
      VpcLinkId: '{{ item.VpcLinkId }}'
- discovery_id: aws.migration-hub-refactor-spaces.getEnvironment
  calls:
  - action: getEnvironment
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Error }}'
    item:
      AccountId: '{{ item.AccountId }}'
      AdditionalDetails: '{{ item.AdditionalDetails }}'
      Code: '{{ item.Code }}'
      Message: '{{ item.Message }}'
      ResourceIdentifier: '{{ item.ResourceIdentifier }}'
      ResourceType: '{{ item.ResourceType }}'
- discovery_id: aws.migration-hub-refactor-spaces.getResourcePolicy
  calls:
  - action: getResourcePolicy
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Policy }}'
- discovery_id: aws.migration-hub-refactor-spaces.getRoute
  calls:
  - action: getRoute
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Methods }}'
- discovery_id: aws.migration-hub-refactor-spaces.getService
  calls:
  - action: getService
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Error }}'
    item:
      AccountId: '{{ item.AccountId }}'
      AdditionalDetails: '{{ item.AdditionalDetails }}'
      Code: '{{ item.Code }}'
      Message: '{{ item.Message }}'
      ResourceIdentifier: '{{ item.ResourceIdentifier }}'
      ResourceType: '{{ item.ResourceType }}'
- discovery_id: aws.migration-hub-refactor-spaces.listApplications
  calls:
  - action: listApplications
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.ApplicationSummaryList }}'
    item:
      ApiGatewayProxy: '{{ item.ApiGatewayProxy }}'
      ApplicationId: '{{ item.ApplicationId }}'
      Arn: '{{ item.Arn }}'
      CreatedByAccountId: '{{ item.CreatedByAccountId }}'
      CreatedTime: '{{ item.CreatedTime }}'
      EnvironmentId: '{{ item.EnvironmentId }}'
      Error: '{{ item.Error }}'
      LastUpdatedTime: '{{ item.LastUpdatedTime }}'
      Name: '{{ item.Name }}'
      OwnerAccountId: '{{ item.OwnerAccountId }}'
      ProxyType: '{{ item.ProxyType }}'
      State: '{{ item.State }}'
      Tags: '{{ item.Tags }}'
      VpcId: '{{ item.VpcId }}'
- discovery_id: aws.migration-hub-refactor-spaces.listEnvironmentVpcs
  calls:
  - action: listEnvironmentVpcs
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.EnvironmentVpcList }}'
    item:
      AccountId: '{{ item.AccountId }}'
      CidrBlocks: '{{ item.CidrBlocks }}'
      CreatedTime: '{{ item.CreatedTime }}'
      EnvironmentId: '{{ item.EnvironmentId }}'
      LastUpdatedTime: '{{ item.LastUpdatedTime }}'
      VpcId: '{{ item.VpcId }}'
      VpcName: '{{ item.VpcName }}'
- discovery_id: aws.migration-hub-refactor-spaces.listRoutes
  calls:
  - action: listRoutes
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.RouteSummaryList }}'
    item:
      AppendSourcePath: '{{ item.AppendSourcePath }}'
      ApplicationId: '{{ item.ApplicationId }}'
      Arn: '{{ item.Arn }}'
      CreatedByAccountId: '{{ item.CreatedByAccountId }}'
      CreatedTime: '{{ item.CreatedTime }}'
      EnvironmentId: '{{ item.EnvironmentId }}'
      Error: '{{ item.Error }}'
      IncludeChildPaths: '{{ item.IncludeChildPaths }}'
      LastUpdatedTime: '{{ item.LastUpdatedTime }}'
      Methods: '{{ item.Methods }}'
      OwnerAccountId: '{{ item.OwnerAccountId }}'
      PathResourceToId: '{{ item.PathResourceToId }}'
      RouteId: '{{ item.RouteId }}'
      RouteType: '{{ item.RouteType }}'
      ServiceId: '{{ item.ServiceId }}'
      SourcePath: '{{ item.SourcePath }}'
      State: '{{ item.State }}'
      Tags: '{{ item.Tags }}'
- discovery_id: aws.migration-hub-refactor-spaces.listServices
  calls:
  - action: listServices
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.ServiceSummaryList }}'
    item:
      ApplicationId: '{{ item.ApplicationId }}'
      Arn: '{{ item.Arn }}'
      CreatedByAccountId: '{{ item.CreatedByAccountId }}'
      CreatedTime: '{{ item.CreatedTime }}'
      Description: '{{ item.Description }}'
      EndpointType: '{{ item.EndpointType }}'
      EnvironmentId: '{{ item.EnvironmentId }}'
      Error: '{{ item.Error }}'
      LambdaEndpoint: '{{ item.LambdaEndpoint }}'
      LastUpdatedTime: '{{ item.LastUpdatedTime }}'
      Name: '{{ item.Name }}'
      OwnerAccountId: '{{ item.OwnerAccountId }}'
      ServiceId: '{{ item.ServiceId }}'
      State: '{{ item.State }}'
      Tags: '{{ item.Tags }}'
      UrlEndpoint: '{{ item.UrlEndpoint }}'
      VpcId: '{{ item.VpcId }}'
- discovery_id: aws.migration-hub-refactor-spaces.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Tags }}'
checks: []
