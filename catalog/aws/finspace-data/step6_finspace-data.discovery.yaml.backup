version: '1.0'
provider: aws
service: finspace-data
services:
  client: finspace-data
  module: boto3.client
discovery:
- discovery_id: aws.finspace-data.getWorkingLocation
  calls:
  - action: getWorkingLocation
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.s3Uri }}'
- discovery_id: aws.finspace-data.listDatasets
  calls:
  - action: listDatasets
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.datasets }}'
    item:
      datasetId: '{{ item.datasetId }}'
      datasetArn: '{{ item.datasetArn }}'
      datasetTitle: '{{ item.datasetTitle }}'
      kind: '{{ item.kind }}'
      datasetDescription: '{{ item.datasetDescription }}'
      ownerInfo: '{{ item.ownerInfo }}'
      createTime: '{{ item.createTime }}'
      lastModifiedTime: '{{ item.lastModifiedTime }}'
      schemaDefinition: '{{ item.schemaDefinition }}'
      alias: '{{ item.alias }}'
- discovery_id: aws.finspace-data.getChangeset
  calls:
  - action: getChangeset
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.errorInfo }}'
    item:
      errorMessage: '{{ item.errorMessage }}'
      errorCategory: '{{ item.errorCategory }}'
- discovery_id: aws.finspace-data.getDataView
  calls:
  - action: getDataView
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.partitionColumns }}'
- discovery_id: aws.finspace-data.getDataset
  calls:
  - action: getDataset
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.schemaDefinition }}'
    item:
      tabularSchemaConfig: '{{ item.tabularSchemaConfig }}'
- discovery_id: aws.finspace-data.getExternalDataViewAccessDetails
  calls:
  - action: getExternalDataViewAccessDetails
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.credentials }}'
    item:
      accessKeyId: '{{ item.accessKeyId }}'
      secretAccessKey: '{{ item.secretAccessKey }}'
      sessionToken: '{{ item.sessionToken }}'
      expiration: '{{ item.expiration }}'
- discovery_id: aws.finspace-data.getPermissionGroup
  calls:
  - action: getPermissionGroup
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.permissionGroup }}'
    item:
      permissionGroupId: '{{ item.permissionGroupId }}'
      name: '{{ item.name }}'
      description: '{{ item.description }}'
      applicationPermissions: '{{ item.applicationPermissions }}'
      createTime: '{{ item.createTime }}'
      lastModifiedTime: '{{ item.lastModifiedTime }}'
      membershipStatus: '{{ item.membershipStatus }}'
- discovery_id: aws.finspace-data.getProgrammaticAccessCredentials
  calls:
  - action: getProgrammaticAccessCredentials
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.credentials }}'
    item:
      accessKeyId: '{{ item.accessKeyId }}'
      secretAccessKey: '{{ item.secretAccessKey }}'
      sessionToken: '{{ item.sessionToken }}'
- discovery_id: aws.finspace-data.getUser
  calls:
  - action: getUser
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.userId }}'
- discovery_id: aws.finspace-data.listChangesets
  calls:
  - action: listChangesets
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.changesets }}'
    item:
      changesetId: '{{ item.changesetId }}'
      changesetArn: '{{ item.changesetArn }}'
      datasetId: '{{ item.datasetId }}'
      changeType: '{{ item.changeType }}'
      sourceParams: '{{ item.sourceParams }}'
      formatParams: '{{ item.formatParams }}'
      createTime: '{{ item.createTime }}'
      status: '{{ item.status }}'
      errorInfo: '{{ item.errorInfo }}'
      activeUntilTimestamp: '{{ item.activeUntilTimestamp }}'
      activeFromTimestamp: '{{ item.activeFromTimestamp }}'
      updatesChangesetId: '{{ item.updatesChangesetId }}'
      updatedByChangesetId: '{{ item.updatedByChangesetId }}'
- discovery_id: aws.finspace-data.listDataViews
  calls:
  - action: listDataViews
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.dataViews }}'
    item:
      dataViewId: '{{ item.dataViewId }}'
      dataViewArn: '{{ item.dataViewArn }}'
      datasetId: '{{ item.datasetId }}'
      asOfTimestamp: '{{ item.asOfTimestamp }}'
      partitionColumns: '{{ item.partitionColumns }}'
      sortColumns: '{{ item.sortColumns }}'
      status: '{{ item.status }}'
      errorInfo: '{{ item.errorInfo }}'
      destinationTypeProperties: '{{ item.destinationTypeProperties }}'
      autoUpdate: '{{ item.autoUpdate }}'
      createTime: '{{ item.createTime }}'
      lastModifiedTime: '{{ item.lastModifiedTime }}'
- discovery_id: aws.finspace-data.listPermissionGroups
  calls:
  - action: listPermissionGroups
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.permissionGroups }}'
    item:
      permissionGroupId: '{{ item.permissionGroupId }}'
      name: '{{ item.name }}'
      description: '{{ item.description }}'
      applicationPermissions: '{{ item.applicationPermissions }}'
      createTime: '{{ item.createTime }}'
      lastModifiedTime: '{{ item.lastModifiedTime }}'
      membershipStatus: '{{ item.membershipStatus }}'
- discovery_id: aws.finspace-data.listPermissionGroupsByUser
  calls:
  - action: listPermissionGroupsByUser
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.permissionGroups }}'
    item:
      permissionGroupId: '{{ item.permissionGroupId }}'
      name: '{{ item.name }}'
      membershipStatus: '{{ item.membershipStatus }}'
- discovery_id: aws.finspace-data.listUsers
  calls:
  - action: listUsers
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.users }}'
    item:
      userId: '{{ item.userId }}'
      status: '{{ item.status }}'
      firstName: '{{ item.firstName }}'
      lastName: '{{ item.lastName }}'
      emailAddress: '{{ item.emailAddress }}'
      type: '{{ item.type }}'
      apiAccess: '{{ item.apiAccess }}'
      apiAccessPrincipalArn: '{{ item.apiAccessPrincipalArn }}'
      createTime: '{{ item.createTime }}'
      lastEnabledTime: '{{ item.lastEnabledTime }}'
      lastDisabledTime: '{{ item.lastDisabledTime }}'
      lastModifiedTime: '{{ item.lastModifiedTime }}'
      lastLoginTime: '{{ item.lastLoginTime }}'
- discovery_id: aws.finspace-data.listUsersByPermissionGroup
  calls:
  - action: listUsersByPermissionGroup
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.users }}'
    item:
      userId: '{{ item.userId }}'
      status: '{{ item.status }}'
      firstName: '{{ item.firstName }}'
      lastName: '{{ item.lastName }}'
      emailAddress: '{{ item.emailAddress }}'
      type: '{{ item.type }}'
      apiAccess: '{{ item.apiAccess }}'
      apiAccessPrincipalArn: '{{ item.apiAccessPrincipalArn }}'
      membershipStatus: '{{ item.membershipStatus }}'
checks: []
