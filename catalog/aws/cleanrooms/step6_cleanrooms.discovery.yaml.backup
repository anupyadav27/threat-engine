version: '1.0'
provider: aws
service: cleanrooms
services:
  client: cleanrooms
  module: boto3.client
discovery:
- discovery_id: aws.cleanrooms.listCollaborations
  calls:
  - action: listCollaborations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.collaborationList }}'
    item:
      id: '{{ item.id }}'
      arn: '{{ item.arn }}'
      name: '{{ item.name }}'
      creatorAccountId: '{{ item.creatorAccountId }}'
      creatorDisplayName: '{{ item.creatorDisplayName }}'
      createTime: '{{ item.createTime }}'
      updateTime: '{{ item.updateTime }}'
      memberStatus: '{{ item.memberStatus }}'
      membershipId: '{{ item.membershipId }}'
      membershipArn: '{{ item.membershipArn }}'
      analyticsEngine: '{{ item.analyticsEngine }}'
- discovery_id: aws.cleanrooms.listConfiguredTables
  calls:
  - action: listConfiguredTables
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.configuredTableSummaries }}'
    item:
      id: '{{ item.id }}'
      arn: '{{ item.arn }}'
      name: '{{ item.name }}'
      createTime: '{{ item.createTime }}'
      updateTime: '{{ item.updateTime }}'
      analysisRuleTypes: '{{ item.analysisRuleTypes }}'
      analysisMethod: '{{ item.analysisMethod }}'
      selectedAnalysisMethods: '{{ item.selectedAnalysisMethods }}'
- discovery_id: aws.cleanrooms.listMemberships
  calls:
  - action: listMemberships
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.membershipSummaries }}'
    item:
      id: '{{ item.id }}'
      arn: '{{ item.arn }}'
      collaborationArn: '{{ item.collaborationArn }}'
      collaborationId: '{{ item.collaborationId }}'
      collaborationCreatorAccountId: '{{ item.collaborationCreatorAccountId }}'
      collaborationCreatorDisplayName: '{{ item.collaborationCreatorDisplayName }}'
      collaborationName: '{{ item.collaborationName }}'
      createTime: '{{ item.createTime }}'
      updateTime: '{{ item.updateTime }}'
      status: '{{ item.status }}'
      memberAbilities: '{{ item.memberAbilities }}'
      mlMemberAbilities: '{{ item.mlMemberAbilities }}'
      paymentConfiguration: '{{ item.paymentConfiguration }}'
- discovery_id: aws.cleanrooms.getAnalysisTemplate
  calls:
  - action: getAnalysisTemplate
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.analysisTemplate }}'
    item:
      id: '{{ item.id }}'
      arn: '{{ item.arn }}'
      collaborationId: '{{ item.collaborationId }}'
      collaborationArn: '{{ item.collaborationArn }}'
      membershipId: '{{ item.membershipId }}'
      membershipArn: '{{ item.membershipArn }}'
      description: '{{ item.description }}'
      name: '{{ item.name }}'
      createTime: '{{ item.createTime }}'
      updateTime: '{{ item.updateTime }}'
      schema: '{{ item.schema }}'
      format: '{{ item.format }}'
      source: '{{ item.source }}'
      sourceMetadata: '{{ item.sourceMetadata }}'
      analysisParameters: '{{ item.analysisParameters }}'
      validations: '{{ item.validations }}'
      errorMessageConfiguration: '{{ item.errorMessageConfiguration }}'
- discovery_id: aws.cleanrooms.getCollaboration
