version: '1.0'
provider: aws
service: bcm-pricing-calculator
services:
  client: bcm-pricing-calculator
  module: boto3.client
discovery:
- discovery_id: aws.bcm-pricing-calculator.getPreferences
  calls:
  - action: getPreferences
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.managementAccountRateTypeSelections }}'
- discovery_id: aws.bcm-pricing-calculator.listBillEstimates
  calls:
  - action: listBillEstimates
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
    item:
      id: '{{ item.id }}'
      name: '{{ item.name }}'
      status: '{{ item.status }}'
      billInterval: '{{ item.billInterval }}'
      createdAt: '{{ item.createdAt }}'
      expiresAt: '{{ item.expiresAt }}'
- discovery_id: aws.bcm-pricing-calculator.listBillScenarios
  calls:
  - action: listBillScenarios
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
    item:
      id: '{{ item.id }}'
      name: '{{ item.name }}'
      billInterval: '{{ item.billInterval }}'
      status: '{{ item.status }}'
      createdAt: '{{ item.createdAt }}'
      expiresAt: '{{ item.expiresAt }}'
      failureMessage: '{{ item.failureMessage }}'
      groupSharingPreference: '{{ item.groupSharingPreference }}'
      costCategoryGroupSharingPreferenceArn: '{{ item.costCategoryGroupSharingPreferenceArn
        }}'
- discovery_id: aws.bcm-pricing-calculator.listWorkloadEstimates
  calls:
  - action: listWorkloadEstimates
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
    item:
      id: '{{ item.id }}'
      name: '{{ item.name }}'
      createdAt: '{{ item.createdAt }}'
      expiresAt: '{{ item.expiresAt }}'
      rateType: '{{ item.rateType }}'
      rateTimestamp: '{{ item.rateTimestamp }}'
      status: '{{ item.status }}'
      totalCost: '{{ item.totalCost }}'
      costCurrency: '{{ item.costCurrency }}'
      failureMessage: '{{ item.failureMessage }}'
- discovery_id: aws.bcm-pricing-calculator.getBillEstimate
  calls:
  - action: getBillEstimate
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.billInterval }}'
    item:
      start: '{{ item.start }}'
      end: '{{ item.end }}'
- discovery_id: aws.bcm-pricing-calculator.getBillScenario
  calls:
  - action: getBillScenario
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.billInterval }}'
    item:
      start: '{{ item.start }}'
      end: '{{ item.end }}'
- discovery_id: aws.bcm-pricing-calculator.getWorkloadEstimate
  calls:
  - action: getWorkloadEstimate
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.id }}'
- discovery_id: aws.bcm-pricing-calculator.listBillEstimateCommitments
  calls:
  - action: listBillEstimateCommitments
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
    item:
      id: '{{ item.id }}'
      purchaseAgreementType: '{{ item.purchaseAgreementType }}'
      offeringId: '{{ item.offeringId }}'
      usageAccountId: '{{ item.usageAccountId }}'
      region: '{{ item.region }}'
      termLength: '{{ item.termLength }}'
      paymentOption: '{{ item.paymentOption }}'
      upfrontPayment: '{{ item.upfrontPayment }}'
      monthlyPayment: '{{ item.monthlyPayment }}'
- discovery_id: aws.bcm-pricing-calculator.listBillEstimateInputCommitmentModifications
  calls:
  - action: listBillEstimateInputCommitmentModifications
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
    item:
      id: '{{ item.id }}'
      group: '{{ item.group }}'
      usageAccountId: '{{ item.usageAccountId }}'
      commitmentAction: '{{ item.commitmentAction }}'
- discovery_id: aws.bcm-pricing-calculator.listBillEstimateInputUsageModifications
  calls:
  - action: listBillEstimateInputUsageModifications
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
    item:
      serviceCode: '{{ item.serviceCode }}'
      usageType: '{{ item.usageType }}'
      operation: '{{ item.operation }}'
      location: '{{ item.location }}'
      availabilityZone: '{{ item.availabilityZone }}'
      id: '{{ item.id }}'
      group: '{{ item.group }}'
      usageAccountId: '{{ item.usageAccountId }}'
      quantities: '{{ item.quantities }}'
      historicalUsage: '{{ item.historicalUsage }}'
- discovery_id: aws.bcm-pricing-calculator.listBillEstimateLineItems
  calls:
  - action: listBillEstimateLineItems
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
    item:
      serviceCode: '{{ item.serviceCode }}'
      usageType: '{{ item.usageType }}'
      operation: '{{ item.operation }}'
      location: '{{ item.location }}'
      availabilityZone: '{{ item.availabilityZone }}'
      id: '{{ item.id }}'
      lineItemId: '{{ item.lineItemId }}'
      lineItemType: '{{ item.lineItemType }}'
      payerAccountId: '{{ item.payerAccountId }}'
      usageAccountId: '{{ item.usageAccountId }}'
      estimatedUsageQuantity: '{{ item.estimatedUsageQuantity }}'
      estimatedCost: '{{ item.estimatedCost }}'
      historicalUsageQuantity: '{{ item.historicalUsageQuantity }}'
      historicalCost: '{{ item.historicalCost }}'
      savingsPlanArns: '{{ item.savingsPlanArns }}'
- discovery_id: aws.bcm-pricing-calculator.listBillScenarioCommitmentModifications
  calls:
  - action: listBillScenarioCommitmentModifications
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
    item:
      id: '{{ item.id }}'
      usageAccountId: '{{ item.usageAccountId }}'
      group: '{{ item.group }}'
      commitmentAction: '{{ item.commitmentAction }}'
- discovery_id: aws.bcm-pricing-calculator.listBillScenarioUsageModifications
  calls:
  - action: listBillScenarioUsageModifications
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
    item:
      serviceCode: '{{ item.serviceCode }}'
      usageType: '{{ item.usageType }}'
      operation: '{{ item.operation }}'
      location: '{{ item.location }}'
      availabilityZone: '{{ item.availabilityZone }}'
      id: '{{ item.id }}'
      group: '{{ item.group }}'
      usageAccountId: '{{ item.usageAccountId }}'
      quantities: '{{ item.quantities }}'
      historicalUsage: '{{ item.historicalUsage }}'
- discovery_id: aws.bcm-pricing-calculator.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tags }}'
- discovery_id: aws.bcm-pricing-calculator.listWorkloadEstimateUsage
  calls:
  - action: listWorkloadEstimateUsage
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
    item:
      serviceCode: '{{ item.serviceCode }}'
      usageType: '{{ item.usageType }}'
      operation: '{{ item.operation }}'
      location: '{{ item.location }}'
      id: '{{ item.id }}'
      usageAccountId: '{{ item.usageAccountId }}'
      group: '{{ item.group }}'
      quantity: '{{ item.quantity }}'
      cost: '{{ item.cost }}'
      currency: '{{ item.currency }}'
      status: '{{ item.status }}'
      historicalUsage: '{{ item.historicalUsage }}'
checks: []
