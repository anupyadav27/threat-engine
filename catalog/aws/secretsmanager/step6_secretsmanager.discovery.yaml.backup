version: '1.0'
provider: aws
service: secretsmanager
services:
  client: secretsmanager
  module: boto3.client
discovery:
- discovery_id: aws.secretsmanager.getRandomPassword
  calls:
  - action: getRandomPassword
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.RandomPassword }}'
- discovery_id: aws.secretsmanager.listSecrets
  calls:
  - action: listSecrets
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.SecretList }}'
    item:
      ARN: '{{ item.ARN }}'
      Name: '{{ item.Name }}'
      Type: '{{ item.Type }}'
      Description: '{{ item.Description }}'
      KmsKeyId: '{{ item.KmsKeyId }}'
      RotationEnabled: '{{ item.RotationEnabled }}'
      RotationLambdaARN: '{{ item.RotationLambdaARN }}'
      RotationRules: '{{ item.RotationRules }}'
      ExternalSecretRotationMetadata: '{{ item.ExternalSecretRotationMetadata }}'
      ExternalSecretRotationRoleArn: '{{ item.ExternalSecretRotationRoleArn }}'
      LastRotatedDate: '{{ item.LastRotatedDate }}'
      LastChangedDate: '{{ item.LastChangedDate }}'
      LastAccessedDate: '{{ item.LastAccessedDate }}'
      DeletedDate: '{{ item.DeletedDate }}'
      NextRotationDate: '{{ item.NextRotationDate }}'
      Tags: '{{ item.Tags }}'
      SecretVersionsToStages: '{{ item.SecretVersionsToStages }}'
      OwningService: '{{ item.OwningService }}'
      CreatedDate: '{{ item.CreatedDate }}'
      PrimaryRegion: '{{ item.PrimaryRegion }}'
- discovery_id: aws.secretsmanager.describeSecret
  calls:
  - action: describeSecret
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ExternalSecretRotationMetadata }}'
    item:
      Key: '{{ item.Key }}'
      Value: '{{ item.Value }}'
- discovery_id: aws.secretsmanager.getResourcePolicy
  calls:
  - action: getResourcePolicy
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ARN }}'
- discovery_id: aws.secretsmanager.getSecretValue
  calls:
  - action: getSecretValue
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.VersionStages }}'
- discovery_id: aws.secretsmanager.listSecretVersionIds
  calls:
  - action: listSecretVersionIds
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Versions }}'
    item:
      VersionId: '{{ item.VersionId }}'
      VersionStages: '{{ item.VersionStages }}'
      LastAccessedDate: '{{ item.LastAccessedDate }}'
      CreatedDate: '{{ item.CreatedDate }}'
      KmsKeyIds: '{{ item.KmsKeyIds }}'
checks: []
