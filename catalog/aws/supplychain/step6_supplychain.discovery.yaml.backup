version: '1.0'
provider: aws
service: supplychain
services:
  client: supplychain
  module: boto3.client
discovery:
- discovery_id: aws.supplychain.listInstances
  calls:
  - action: listInstances
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.instances }}'
    item:
      instanceId: '{{ item.instanceId }}'
      awsAccountId: '{{ item.awsAccountId }}'
      state: '{{ item.state }}'
      errorMessage: '{{ item.errorMessage }}'
      webAppDnsDomain: '{{ item.webAppDnsDomain }}'
      createdTime: '{{ item.createdTime }}'
      lastModifiedTime: '{{ item.lastModifiedTime }}'
      instanceName: '{{ item.instanceName }}'
      instanceDescription: '{{ item.instanceDescription }}'
      kmsKeyArn: '{{ item.kmsKeyArn }}'
      versionNumber: '{{ item.versionNumber }}'
- discovery_id: aws.supplychain.getBillOfMaterialsImportJob
  calls:
  - action: getBillOfMaterialsImportJob
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.job }}'
    item:
      instanceId: '{{ item.instanceId }}'
      jobId: '{{ item.jobId }}'
      status: '{{ item.status }}'
      s3uri: '{{ item.s3uri }}'
      message: '{{ item.message }}'
- discovery_id: aws.supplychain.getDataIntegrationEvent
  calls:
  - action: getDataIntegrationEvent
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.event }}'
    item:
      instanceId: '{{ item.instanceId }}'
      eventId: '{{ item.eventId }}'
      eventType: '{{ item.eventType }}'
      eventGroupId: '{{ item.eventGroupId }}'
      eventTimestamp: '{{ item.eventTimestamp }}'
      datasetTargetDetails: '{{ item.datasetTargetDetails }}'
- discovery_id: aws.supplychain.getDataIntegrationFlow
  calls:
  - action: getDataIntegrationFlow
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.flow }}'
    item:
      instanceId: '{{ item.instanceId }}'
      name: '{{ item.name }}'
      sources: '{{ item.sources }}'
      transformation: '{{ item.transformation }}'
      target: '{{ item.target }}'
      createdTime: '{{ item.createdTime }}'
      lastModifiedTime: '{{ item.lastModifiedTime }}'
- discovery_id: aws.supplychain.getDataIntegrationFlowExecution
  calls:
  - action: getDataIntegrationFlowExecution
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.flowExecution }}'
    item:
      instanceId: '{{ item.instanceId }}'
      flowName: '{{ item.flowName }}'
      executionId: '{{ item.executionId }}'
      status: '{{ item.status }}'
      sourceInfo: '{{ item.sourceInfo }}'
      message: '{{ item.message }}'
      startTime: '{{ item.startTime }}'
      endTime: '{{ item.endTime }}'
      outputMetadata: '{{ item.outputMetadata }}'
- discovery_id: aws.supplychain.getDataLakeDataset
  calls:
  - action: getDataLakeDataset
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.dataset }}'
    item:
      instanceId: '{{ item.instanceId }}'
      namespace: '{{ item.namespace }}'
      name: '{{ item.name }}'
      arn: '{{ item.arn }}'
      schema: '{{ item.schema }}'
      description: '{{ item.description }}'
      partitionSpec: '{{ item.partitionSpec }}'
      createdTime: '{{ item.createdTime }}'
      lastModifiedTime: '{{ item.lastModifiedTime }}'
- discovery_id: aws.supplychain.getDataLakeNamespace
  calls:
  - action: getDataLakeNamespace
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.namespace }}'
    item:
      instanceId: '{{ item.instanceId }}'
      name: '{{ item.name }}'
      arn: '{{ item.arn }}'
      description: '{{ item.description }}'
      createdTime: '{{ item.createdTime }}'
      lastModifiedTime: '{{ item.lastModifiedTime }}'
- discovery_id: aws.supplychain.getInstance
  calls:
  - action: getInstance
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.instance }}'
    item:
      instanceId: '{{ item.instanceId }}'
      awsAccountId: '{{ item.awsAccountId }}'
      state: '{{ item.state }}'
      errorMessage: '{{ item.errorMessage }}'
      webAppDnsDomain: '{{ item.webAppDnsDomain }}'
      createdTime: '{{ item.createdTime }}'
      lastModifiedTime: '{{ item.lastModifiedTime }}'
      instanceName: '{{ item.instanceName }}'
      instanceDescription: '{{ item.instanceDescription }}'
      kmsKeyArn: '{{ item.kmsKeyArn }}'
      versionNumber: '{{ item.versionNumber }}'
- discovery_id: aws.supplychain.listDataIntegrationEvents
  calls:
  - action: listDataIntegrationEvents
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.events }}'
    item:
      instanceId: '{{ item.instanceId }}'
      eventId: '{{ item.eventId }}'
      eventType: '{{ item.eventType }}'
      eventGroupId: '{{ item.eventGroupId }}'
      eventTimestamp: '{{ item.eventTimestamp }}'
      datasetTargetDetails: '{{ item.datasetTargetDetails }}'
- discovery_id: aws.supplychain.listDataIntegrationFlowExecutions
  calls:
  - action: listDataIntegrationFlowExecutions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.flowExecutions }}'
    item:
      instanceId: '{{ item.instanceId }}'
      flowName: '{{ item.flowName }}'
      executionId: '{{ item.executionId }}'
      status: '{{ item.status }}'
      sourceInfo: '{{ item.sourceInfo }}'
      message: '{{ item.message }}'
      startTime: '{{ item.startTime }}'
      endTime: '{{ item.endTime }}'
      outputMetadata: '{{ item.outputMetadata }}'
- discovery_id: aws.supplychain.listDataIntegrationFlows
  calls:
  - action: listDataIntegrationFlows
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.flows }}'
    item:
      instanceId: '{{ item.instanceId }}'
      name: '{{ item.name }}'
      sources: '{{ item.sources }}'
      transformation: '{{ item.transformation }}'
      target: '{{ item.target }}'
      createdTime: '{{ item.createdTime }}'
      lastModifiedTime: '{{ item.lastModifiedTime }}'
- discovery_id: aws.supplychain.listDataLakeDatasets
  calls:
  - action: listDataLakeDatasets
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.datasets }}'
    item:
      instanceId: '{{ item.instanceId }}'
      namespace: '{{ item.namespace }}'
      name: '{{ item.name }}'
      arn: '{{ item.arn }}'
      schema: '{{ item.schema }}'
      description: '{{ item.description }}'
      partitionSpec: '{{ item.partitionSpec }}'
      createdTime: '{{ item.createdTime }}'
      lastModifiedTime: '{{ item.lastModifiedTime }}'
- discovery_id: aws.supplychain.listDataLakeNamespaces
  calls:
  - action: listDataLakeNamespaces
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.namespaces }}'
    item:
      instanceId: '{{ item.instanceId }}'
      name: '{{ item.name }}'
      arn: '{{ item.arn }}'
      description: '{{ item.description }}'
      createdTime: '{{ item.createdTime }}'
      lastModifiedTime: '{{ item.lastModifiedTime }}'
- discovery_id: aws.supplychain.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tags }}'
checks: []
