version: '1.0'
provider: aws
service: securityhub
services:
  client: securityhub
  module: boto3.client
discovery:
- discovery_id: aws.securityhub.describeActionTargets
  calls:
  - action: describeActionTargets
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ActionTargets }}'
    item:
      ActionTargetArn: '{{ item.ActionTargetArn }}'
      Name: '{{ item.Name }}'
      Description: '{{ item.Description }}'
- discovery_id: aws.securityhub.describeHub
  calls:
  - action: describeHub
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.HubArn }}'
- discovery_id: aws.securityhub.describeOrganizationConfiguration
  calls:
  - action: describeOrganizationConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.OrganizationConfiguration }}'
    item:
      ConfigurationType: '{{ item.ConfigurationType }}'
      Status: '{{ item.Status }}'
      StatusMessage: '{{ item.StatusMessage }}'
- discovery_id: aws.securityhub.describeProducts
  calls:
  - action: describeProducts
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Products }}'
    item:
      ProductArn: '{{ item.ProductArn }}'
      ProductName: '{{ item.ProductName }}'
      CompanyName: '{{ item.CompanyName }}'
      Description: '{{ item.Description }}'
      Categories: '{{ item.Categories }}'
      IntegrationTypes: '{{ item.IntegrationTypes }}'
      MarketplaceUrl: '{{ item.MarketplaceUrl }}'
      ActivationUrl: '{{ item.ActivationUrl }}'
      ProductSubscriptionResourcePolicy: '{{ item.ProductSubscriptionResourcePolicy
        }}'
- discovery_id: aws.securityhub.describeProductsV2
  calls:
  - action: describeProductsV2
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ProductsV2 }}'
    item:
      ProductV2Name: '{{ item.ProductV2Name }}'
      CompanyName: '{{ item.CompanyName }}'
      Description: '{{ item.Description }}'
      Categories: '{{ item.Categories }}'
      IntegrationV2Types: '{{ item.IntegrationV2Types }}'
      MarketplaceUrl: '{{ item.MarketplaceUrl }}'
      ActivationUrl: '{{ item.ActivationUrl }}'
- discovery_id: aws.securityhub.describeSecurityHubV2
  calls:
  - action: describeSecurityHubV2
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.HubV2Arn }}'
- discovery_id: aws.securityhub.describeStandards
  calls:
  - action: describeStandards
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Standards }}'
    item:
      StandardsArn: '{{ item.StandardsArn }}'
      Name: '{{ item.Name }}'
      Description: '{{ item.Description }}'
      EnabledByDefault: '{{ item.EnabledByDefault }}'
      StandardsManagedBy: '{{ item.StandardsManagedBy }}'
- discovery_id: aws.securityhub.getAdministratorAccount
  calls:
  - action: getAdministratorAccount
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Administrator }}'
    item:
      AccountId: '{{ item.AccountId }}'
      InvitationId: '{{ item.InvitationId }}'
      InvitedAt: '{{ item.InvitedAt }}'
      MemberStatus: '{{ item.MemberStatus }}'
- discovery_id: aws.securityhub.getEnabledStandards
  calls:
  - action: getEnabledStandards
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.StandardsSubscriptions }}'
    item:
      StandardsSubscriptionArn: '{{ item.StandardsSubscriptionArn }}'
      StandardsArn: '{{ item.StandardsArn }}'
      StandardsInput: '{{ item.StandardsInput }}'
      StandardsStatus: '{{ item.StandardsStatus }}'
      StandardsControlsUpdatable: '{{ item.StandardsControlsUpdatable }}'
      StandardsStatusReason: '{{ item.StandardsStatusReason }}'
- discovery_id: aws.securityhub.getFindings
  calls:
  - action: getFindings
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Findings }}'
    item:
      SchemaVersion: '{{ item.SchemaVersion }}'
      Id: '{{ item.Id }}'
      ProductArn: '{{ item.ProductArn }}'
      ProductName: '{{ item.ProductName }}'
      CompanyName: '{{ item.CompanyName }}'
      Region: '{{ item.Region }}'
      GeneratorId: '{{ item.GeneratorId }}'
      AwsAccountId: '{{ item.AwsAccountId }}'
      Types: '{{ item.Types }}'
      FirstObservedAt: '{{ item.FirstObservedAt }}'
      LastObservedAt: '{{ item.LastObservedAt }}'
      CreatedAt: '{{ item.CreatedAt }}'
      UpdatedAt: '{{ item.UpdatedAt }}'
      Severity: '{{ item.Severity }}'
      Confidence: '{{ item.Confidence }}'
      Criticality: '{{ item.Criticality }}'
      Title: '{{ item.Title }}'
      Description: '{{ item.Description }}'
      Remediation: '{{ item.Remediation }}'
      SourceUrl: '{{ item.SourceUrl }}'
      ProductFields: '{{ item.ProductFields }}'
      UserDefinedFields: '{{ item.UserDefinedFields }}'
      Malware: '{{ item.Malware }}'
      Network: '{{ item.Network }}'
      NetworkPath: '{{ item.NetworkPath }}'
      Process: '{{ item.Process }}'
      Threats: '{{ item.Threats }}'
      ThreatIntelIndicators: '{{ item.ThreatIntelIndicators }}'
      Resources: '{{ item.Resources }}'
      Compliance: '{{ item.Compliance }}'
      VerificationState: '{{ item.VerificationState }}'
      WorkflowState: '{{ item.WorkflowState }}'
      Workflow: '{{ item.Workflow }}'
      RecordState: '{{ item.RecordState }}'
      RelatedFindings: '{{ item.RelatedFindings }}'
      Note: '{{ item.Note }}'
      Vulnerabilities: '{{ item.Vulnerabilities }}'
      PatchSummary: '{{ item.PatchSummary }}'
      Action: '{{ item.Action }}'
      FindingProviderFields: '{{ item.FindingProviderFields }}'
      Sample: '{{ item.Sample }}'
      GeneratorDetails: '{{ item.GeneratorDetails }}'
      ProcessedAt: '{{ item.ProcessedAt }}'
      AwsAccountName: '{{ item.AwsAccountName }}'
      Detection: '{{ item.Detection }}'
- discovery_id: aws.securityhub.getFindingsV2
  calls:
  - action: getFindingsV2
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Findings }}'
- discovery_id: aws.securityhub.getInsights
  calls:
  - action: getInsights
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Insights }}'
    item:
      InsightArn: '{{ item.InsightArn }}'
      Name: '{{ item.Name }}'
      Filters: '{{ item.Filters }}'
      GroupByAttribute: '{{ item.GroupByAttribute }}'
- discovery_id: aws.securityhub.getInvitationsCount
  calls:
  - action: getInvitationsCount
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.InvitationsCount }}'
- discovery_id: aws.securityhub.getMasterAccount
  calls:
  - action: getMasterAccount
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Master }}'
    item:
      AccountId: '{{ item.AccountId }}'
      InvitationId: '{{ item.InvitationId }}'
      InvitedAt: '{{ item.InvitedAt }}'
      MemberStatus: '{{ item.MemberStatus }}'
- discovery_id: aws.securityhub.getResourcesV2
  calls:
  - action: getResourcesV2
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Resources }}'
    item:
      ResourceGuid: '{{ item.ResourceGuid }}'
      ResourceId: '{{ item.ResourceId }}'
      AccountId: '{{ item.AccountId }}'
      Region: '{{ item.Region }}'
      ResourceCategory: '{{ item.ResourceCategory }}'
      ResourceType: '{{ item.ResourceType }}'
      ResourceName: '{{ item.ResourceName }}'
      ResourceCreationTimeDt: '{{ item.ResourceCreationTimeDt }}'
      ResourceDetailCaptureTimeDt: '{{ item.ResourceDetailCaptureTimeDt }}'
      FindingsSummary: '{{ item.FindingsSummary }}'
      ResourceTags: '{{ item.ResourceTags }}'
      ResourceConfig: '{{ item.ResourceConfig }}'
- discovery_id: aws.securityhub.listAggregatorsV2
  calls:
  - action: listAggregatorsV2
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.AggregatorsV2 }}'
    item:
      AggregatorV2Arn: '{{ item.AggregatorV2Arn }}'
- discovery_id: aws.securityhub.listAutomationRules
  calls:
  - action: listAutomationRules
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.AutomationRulesMetadata }}'
    item:
      RuleArn: '{{ item.RuleArn }}'
      RuleStatus: '{{ item.RuleStatus }}'
      RuleOrder: '{{ item.RuleOrder }}'
      RuleName: '{{ item.RuleName }}'
      Description: '{{ item.Description }}'
      IsTerminal: '{{ item.IsTerminal }}'
      CreatedAt: '{{ item.CreatedAt }}'
      UpdatedAt: '{{ item.UpdatedAt }}'
      CreatedBy: '{{ item.CreatedBy }}'
- discovery_id: aws.securityhub.listAutomationRulesV2
  calls:
  - action: listAutomationRulesV2
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Rules }}'
    item:
      RuleArn: '{{ item.RuleArn }}'
      RuleId: '{{ item.RuleId }}'
      RuleOrder: '{{ item.RuleOrder }}'
      RuleName: '{{ item.RuleName }}'
      RuleStatus: '{{ item.RuleStatus }}'
      Description: '{{ item.Description }}'
      Actions: '{{ item.Actions }}'
      CreatedAt: '{{ item.CreatedAt }}'
      UpdatedAt: '{{ item.UpdatedAt }}'
- discovery_id: aws.securityhub.listConfigurationPolicies
  calls:
  - action: listConfigurationPolicies
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.ConfigurationPolicySummaries }}'
    item:
      Arn: '{{ item.Arn }}'
      Id: '{{ item.Id }}'
      Name: '{{ item.Name }}'
      Description: '{{ item.Description }}'
      UpdatedAt: '{{ item.UpdatedAt }}'
      ServiceEnabled: '{{ item.ServiceEnabled }}'
- discovery_id: aws.securityhub.listConfigurationPolicyAssociations
  calls:
  - action: listConfigurationPolicyAssociations
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.ConfigurationPolicyAssociationSummaries }}'
    item:
      ConfigurationPolicyId: '{{ item.ConfigurationPolicyId }}'
      TargetId: '{{ item.TargetId }}'
      TargetType: '{{ item.TargetType }}'
      AssociationType: '{{ item.AssociationType }}'
      UpdatedAt: '{{ item.UpdatedAt }}'
      AssociationStatus: '{{ item.AssociationStatus }}'
      AssociationStatusMessage: '{{ item.AssociationStatusMessage }}'
- discovery_id: aws.securityhub.listConnectorsV2
  calls:
  - action: listConnectorsV2
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Connectors }}'
    item:
      ConnectorArn: '{{ item.ConnectorArn }}'
      ConnectorId: '{{ item.ConnectorId }}'
      Name: '{{ item.Name }}'
      Description: '{{ item.Description }}'
      ProviderSummary: '{{ item.ProviderSummary }}'
      CreatedAt: '{{ item.CreatedAt }}'
- discovery_id: aws.securityhub.listEnabledProductsForImport
  calls:
  - action: listEnabledProductsForImport
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.ProductSubscriptions }}'
- discovery_id: aws.securityhub.listFindingAggregators
  calls:
  - action: listFindingAggregators
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.FindingAggregators }}'
    item:
      FindingAggregatorArn: '{{ item.FindingAggregatorArn }}'
- discovery_id: aws.securityhub.listInvitations
  calls:
  - action: listInvitations
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Invitations }}'
    item:
      AccountId: '{{ item.AccountId }}'
      InvitationId: '{{ item.InvitationId }}'
      InvitedAt: '{{ item.InvitedAt }}'
      MemberStatus: '{{ item.MemberStatus }}'
- discovery_id: aws.securityhub.listMembers
  calls:
  - action: listMembers
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Members }}'
    item:
      AccountId: '{{ item.AccountId }}'
      Email: '{{ item.Email }}'
      MasterId: '{{ item.MasterId }}'
      AdministratorId: '{{ item.AdministratorId }}'
      MemberStatus: '{{ item.MemberStatus }}'
      InvitedAt: '{{ item.InvitedAt }}'
      UpdatedAt: '{{ item.UpdatedAt }}'
- discovery_id: aws.securityhub.listOrganizationAdminAccounts
  calls:
  - action: listOrganizationAdminAccounts
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.AdminAccounts }}'
    item:
      AccountId: '{{ item.AccountId }}'
      Status: '{{ item.Status }}'
- discovery_id: aws.securityhub.listSecurityControlDefinitions
  calls:
  - action: listSecurityControlDefinitions
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.SecurityControlDefinitions }}'
    item:
      SecurityControlId: '{{ item.SecurityControlId }}'
      Title: '{{ item.Title }}'
      Description: '{{ item.Description }}'
      RemediationUrl: '{{ item.RemediationUrl }}'
      SeverityRating: '{{ item.SeverityRating }}'
      CurrentRegionAvailability: '{{ item.CurrentRegionAvailability }}'
      CustomizableProperties: '{{ item.CustomizableProperties }}'
      ParameterDefinitions: '{{ item.ParameterDefinitions }}'
- discovery_id: aws.securityhub.describeStandardsControls
  calls:
  - action: describeStandardsControls
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Controls }}'
    item:
      StandardsControlArn: '{{ item.StandardsControlArn }}'
      ControlStatus: '{{ item.ControlStatus }}'
      DisabledReason: '{{ item.DisabledReason }}'
      ControlStatusUpdatedAt: '{{ item.ControlStatusUpdatedAt }}'
      ControlId: '{{ item.ControlId }}'
      Title: '{{ item.Title }}'
      Description: '{{ item.Description }}'
      RemediationUrl: '{{ item.RemediationUrl }}'
      SeverityRating: '{{ item.SeverityRating }}'
      RelatedRequirements: '{{ item.RelatedRequirements }}'
- discovery_id: aws.securityhub.getAggregatorV2
  calls:
  - action: getAggregatorV2
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.LinkedRegions }}'
- discovery_id: aws.securityhub.getAutomationRuleV2
  calls:
  - action: getAutomationRuleV2
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Actions }}'
    item:
      Type: '{{ item.Type }}'
      FindingFieldsUpdate: '{{ item.FindingFieldsUpdate }}'
      ExternalIntegrationConfiguration: '{{ item.ExternalIntegrationConfiguration
        }}'
- discovery_id: aws.securityhub.getConfigurationPolicy
  calls:
  - action: getConfigurationPolicy
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ConfigurationPolicy }}'
    item:
      SecurityHub: '{{ item.SecurityHub }}'
- discovery_id: aws.securityhub.getConfigurationPolicyAssociation
  calls:
  - action: getConfigurationPolicyAssociation
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ConfigurationPolicyId }}'
- discovery_id: aws.securityhub.getConnectorV2
  calls:
  - action: getConnectorV2
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Health }}'
    item:
      ConnectorStatus: '{{ item.ConnectorStatus }}'
      Message: '{{ item.Message }}'
      LastCheckedAt: '{{ item.LastCheckedAt }}'
- discovery_id: aws.securityhub.getFindingAggregator
  calls:
  - action: getFindingAggregator
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Regions }}'
- discovery_id: aws.securityhub.getFindingHistory
  calls:
  - action: getFindingHistory
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Records }}'
    item:
      FindingIdentifier: '{{ item.FindingIdentifier }}'
      UpdateTime: '{{ item.UpdateTime }}'
      FindingCreated: '{{ item.FindingCreated }}'
      UpdateSource: '{{ item.UpdateSource }}'
      Updates: '{{ item.Updates }}'
      NextToken: '{{ item.NextToken }}'
- discovery_id: aws.securityhub.getFindingStatisticsV2
  calls:
  - action: getFindingStatisticsV2
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.GroupByResults }}'
    item:
      GroupByField: '{{ item.GroupByField }}'
      GroupByValues: '{{ item.GroupByValues }}'
- discovery_id: aws.securityhub.getFindingsTrendsV2
  calls:
  - action: getFindingsTrendsV2
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.TrendsMetrics }}'
    item:
      Timestamp: '{{ item.Timestamp }}'
      TrendsValues: '{{ item.TrendsValues }}'
- discovery_id: aws.securityhub.getInsightResults
  calls:
  - action: getInsightResults
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.InsightResults }}'
    item:
      InsightArn: '{{ item.InsightArn }}'
      GroupByAttribute: '{{ item.GroupByAttribute }}'
      ResultValues: '{{ item.ResultValues }}'
- discovery_id: aws.securityhub.getMembers
  calls:
  - action: getMembers
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Members }}'
    item:
      AccountId: '{{ item.AccountId }}'
      Email: '{{ item.Email }}'
      MasterId: '{{ item.MasterId }}'
      AdministratorId: '{{ item.AdministratorId }}'
      MemberStatus: '{{ item.MemberStatus }}'
      InvitedAt: '{{ item.InvitedAt }}'
      UpdatedAt: '{{ item.UpdatedAt }}'
- discovery_id: aws.securityhub.getResourcesStatisticsV2
  calls:
  - action: getResourcesStatisticsV2
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.GroupByResults }}'
    item:
      GroupByField: '{{ item.GroupByField }}'
      GroupByValues: '{{ item.GroupByValues }}'
- discovery_id: aws.securityhub.getResourcesTrendsV2
  calls:
  - action: getResourcesTrendsV2
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.TrendsMetrics }}'
    item:
      Timestamp: '{{ item.Timestamp }}'
      TrendsValues: '{{ item.TrendsValues }}'
- discovery_id: aws.securityhub.getSecurityControlDefinition
  calls:
  - action: getSecurityControlDefinition
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.SecurityControlDefinition }}'
    item:
      SecurityControlId: '{{ item.SecurityControlId }}'
      Title: '{{ item.Title }}'
      Description: '{{ item.Description }}'
      RemediationUrl: '{{ item.RemediationUrl }}'
      SeverityRating: '{{ item.SeverityRating }}'
      CurrentRegionAvailability: '{{ item.CurrentRegionAvailability }}'
      CustomizableProperties: '{{ item.CustomizableProperties }}'
      ParameterDefinitions: '{{ item.ParameterDefinitions }}'
- discovery_id: aws.securityhub.listStandardsControlAssociations
  calls:
  - action: listStandardsControlAssociations
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.StandardsControlAssociationSummaries }}'
    item:
      StandardsArn: '{{ item.StandardsArn }}'
      SecurityControlId: '{{ item.SecurityControlId }}'
      SecurityControlArn: '{{ item.SecurityControlArn }}'
      AssociationStatus: '{{ item.AssociationStatus }}'
      RelatedRequirements: '{{ item.RelatedRequirements }}'
      UpdatedAt: '{{ item.UpdatedAt }}'
      UpdatedReason: '{{ item.UpdatedReason }}'
      StandardsControlTitle: '{{ item.StandardsControlTitle }}'
      StandardsControlDescription: '{{ item.StandardsControlDescription }}'
- discovery_id: aws.securityhub.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Tags }}'
checks: []
