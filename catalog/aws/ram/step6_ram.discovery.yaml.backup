version: '1.0'
provider: aws
service: ram
services:
  client: ram
  module: boto3.client
discovery:
- discovery_id: aws.ram.getResourceShareInvitations
  calls:
  - action: getResourceShareInvitations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.resourceShareInvitations }}'
    item:
      resourceShareInvitationArn: '{{ item.resourceShareInvitationArn }}'
      resourceShareName: '{{ item.resourceShareName }}'
      resourceShareArn: '{{ item.resourceShareArn }}'
      senderAccountId: '{{ item.senderAccountId }}'
      receiverAccountId: '{{ item.receiverAccountId }}'
      invitationTimestamp: '{{ item.invitationTimestamp }}'
      status: '{{ item.status }}'
      resourceShareAssociations: '{{ item.resourceShareAssociations }}'
      receiverArn: '{{ item.receiverArn }}'
- discovery_id: aws.ram.listPermissionAssociations
  calls:
  - action: listPermissionAssociations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.permissions }}'
    item:
      arn: '{{ item.arn }}'
      permissionVersion: '{{ item.permissionVersion }}'
      defaultVersion: '{{ item.defaultVersion }}'
      resourceType: '{{ item.resourceType }}'
      status: '{{ item.status }}'
      featureSet: '{{ item.featureSet }}'
      lastUpdatedTime: '{{ item.lastUpdatedTime }}'
      resourceShareArn: '{{ item.resourceShareArn }}'
- discovery_id: aws.ram.listPermissions
  calls:
  - action: listPermissions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.permissions }}'
    item:
      arn: '{{ item.arn }}'
      version: '{{ item.version }}'
      defaultVersion: '{{ item.defaultVersion }}'
      name: '{{ item.name }}'
      resourceType: '{{ item.resourceType }}'
      status: '{{ item.status }}'
      creationTime: '{{ item.creationTime }}'
      lastUpdatedTime: '{{ item.lastUpdatedTime }}'
      isResourceTypeDefault: '{{ item.isResourceTypeDefault }}'
      permissionType: '{{ item.permissionType }}'
      featureSet: '{{ item.featureSet }}'
      tags: '{{ item.tags }}'
- discovery_id: aws.ram.listReplacePermissionAssociationsWork
  calls:
  - action: listReplacePermissionAssociationsWork
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.replacePermissionAssociationsWorks }}'
    item:
      id: '{{ item.id }}'
      fromPermissionArn: '{{ item.fromPermissionArn }}'
      fromPermissionVersion: '{{ item.fromPermissionVersion }}'
      toPermissionArn: '{{ item.toPermissionArn }}'
      toPermissionVersion: '{{ item.toPermissionVersion }}'
      status: '{{ item.status }}'
      statusMessage: '{{ item.statusMessage }}'
      creationTime: '{{ item.creationTime }}'
      lastUpdatedTime: '{{ item.lastUpdatedTime }}'
- discovery_id: aws.ram.listResourceTypes
  calls:
  - action: listResourceTypes
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.resourceTypes }}'
    item:
      resourceType: '{{ item.resourceType }}'
      serviceName: '{{ item.serviceName }}'
      resourceRegionScope: '{{ item.resourceRegionScope }}'
- discovery_id: aws.ram.getPermission
  calls:
  - action: getPermission
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.permission }}'
    item:
      arn: '{{ item.arn }}'
      version: '{{ item.version }}'
      defaultVersion: '{{ item.defaultVersion }}'
      name: '{{ item.name }}'
      resourceType: '{{ item.resourceType }}'
      permission: '{{ item.permission }}'
      creationTime: '{{ item.creationTime }}'
      lastUpdatedTime: '{{ item.lastUpdatedTime }}'
      isResourceTypeDefault: '{{ item.isResourceTypeDefault }}'
      permissionType: '{{ item.permissionType }}'
      featureSet: '{{ item.featureSet }}'
      status: '{{ item.status }}'
      tags: '{{ item.tags }}'
- discovery_id: aws.ram.getResourcePolicies
  calls:
  - action: getResourcePolicies
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.policies }}'
- discovery_id: aws.ram.getResourceShareAssociations
  calls:
  - action: getResourceShareAssociations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.resourceShareAssociations }}'
    item:
      resourceShareArn: '{{ item.resourceShareArn }}'
      resourceShareName: '{{ item.resourceShareName }}'
      associatedEntity: '{{ item.associatedEntity }}'
      associationType: '{{ item.associationType }}'
      status: '{{ item.status }}'
      statusMessage: '{{ item.statusMessage }}'
      creationTime: '{{ item.creationTime }}'
      lastUpdatedTime: '{{ item.lastUpdatedTime }}'
      external: '{{ item.external }}'
- discovery_id: aws.ram.getResourceShares
  calls:
  - action: getResourceShares
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.resourceShares }}'
    item:
      resourceShareArn: '{{ item.resourceShareArn }}'
      name: '{{ item.name }}'
      owningAccountId: '{{ item.owningAccountId }}'
      allowExternalPrincipals: '{{ item.allowExternalPrincipals }}'
      status: '{{ item.status }}'
      statusMessage: '{{ item.statusMessage }}'
      tags: '{{ item.tags }}'
      creationTime: '{{ item.creationTime }}'
      lastUpdatedTime: '{{ item.lastUpdatedTime }}'
      featureSet: '{{ item.featureSet }}'
- discovery_id: aws.ram.listPendingInvitationResources
  calls:
  - action: listPendingInvitationResources
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.resources }}'
    item:
      arn: '{{ item.arn }}'
      type: '{{ item.type }}'
      resourceShareArn: '{{ item.resourceShareArn }}'
      resourceGroupArn: '{{ item.resourceGroupArn }}'
      status: '{{ item.status }}'
      statusMessage: '{{ item.statusMessage }}'
      creationTime: '{{ item.creationTime }}'
      lastUpdatedTime: '{{ item.lastUpdatedTime }}'
      resourceRegionScope: '{{ item.resourceRegionScope }}'
- discovery_id: aws.ram.listPermissionVersions
  calls:
  - action: listPermissionVersions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.permissions }}'
    item:
      arn: '{{ item.arn }}'
      version: '{{ item.version }}'
      defaultVersion: '{{ item.defaultVersion }}'
      name: '{{ item.name }}'
      resourceType: '{{ item.resourceType }}'
      status: '{{ item.status }}'
      creationTime: '{{ item.creationTime }}'
      lastUpdatedTime: '{{ item.lastUpdatedTime }}'
      isResourceTypeDefault: '{{ item.isResourceTypeDefault }}'
      permissionType: '{{ item.permissionType }}'
      featureSet: '{{ item.featureSet }}'
      tags: '{{ item.tags }}'
- discovery_id: aws.ram.listPrincipals
  calls:
  - action: listPrincipals
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.principals }}'
    item:
      id: '{{ item.id }}'
      resourceShareArn: '{{ item.resourceShareArn }}'
      creationTime: '{{ item.creationTime }}'
      lastUpdatedTime: '{{ item.lastUpdatedTime }}'
      external: '{{ item.external }}'
- discovery_id: aws.ram.listResourceSharePermissions
  calls:
  - action: listResourceSharePermissions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.permissions }}'
    item:
      arn: '{{ item.arn }}'
      version: '{{ item.version }}'
      defaultVersion: '{{ item.defaultVersion }}'
      name: '{{ item.name }}'
      resourceType: '{{ item.resourceType }}'
      status: '{{ item.status }}'
      creationTime: '{{ item.creationTime }}'
      lastUpdatedTime: '{{ item.lastUpdatedTime }}'
      isResourceTypeDefault: '{{ item.isResourceTypeDefault }}'
      permissionType: '{{ item.permissionType }}'
      featureSet: '{{ item.featureSet }}'
      tags: '{{ item.tags }}'
- discovery_id: aws.ram.listResources
  calls:
  - action: listResources
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.resources }}'
    item:
      arn: '{{ item.arn }}'
      type: '{{ item.type }}'
      resourceShareArn: '{{ item.resourceShareArn }}'
      resourceGroupArn: '{{ item.resourceGroupArn }}'
      status: '{{ item.status }}'
      statusMessage: '{{ item.statusMessage }}'
      creationTime: '{{ item.creationTime }}'
      lastUpdatedTime: '{{ item.lastUpdatedTime }}'
      resourceRegionScope: '{{ item.resourceRegionScope }}'
checks: []
