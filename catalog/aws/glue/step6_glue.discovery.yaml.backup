    items_for: '{{ response.MetadataInfoMap }}'
- discovery_id: aws.glue.searchTables
  calls:
  - action: searchTables
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.TableList }}'
    item:
      Name: '{{ item.Name }}'
      DatabaseName: '{{ item.DatabaseName }}'
      Description: '{{ item.Description }}'
      Owner: '{{ item.Owner }}'
      CreateTime: '{{ item.CreateTime }}'
      UpdateTime: '{{ item.UpdateTime }}'
      LastAccessTime: '{{ item.LastAccessTime }}'
      LastAnalyzedTime: '{{ item.LastAnalyzedTime }}'
      Retention: '{{ item.Retention }}'
      StorageDescriptor: '{{ item.StorageDescriptor }}'
      PartitionKeys: '{{ item.PartitionKeys }}'
      ViewOriginalText: '{{ item.ViewOriginalText }}'
      ViewExpandedText: '{{ item.ViewExpandedText }}'
      TableType: '{{ item.TableType }}'
      Parameters: '{{ item.Parameters }}'
      CreatedBy: '{{ item.CreatedBy }}'
      IsRegisteredWithLakeFormation: '{{ item.IsRegisteredWithLakeFormation }}'
      TargetTable: '{{ item.TargetTable }}'
      CatalogId: '{{ item.CatalogId }}'
      VersionId: '{{ item.VersionId }}'
      FederatedTable: '{{ item.FederatedTable }}'
      ViewDefinition: '{{ item.ViewDefinition }}'
      IsMultiDialectView: '{{ item.IsMultiDialectView }}'
      Status: '{{ item.Status }}'
- discovery_id: aws.glue.describeConnectionType
  calls:
  - action: describeConnectionType
    save_as: response
    on_error: continue
  emit:
