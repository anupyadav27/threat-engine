- discovery_id: aws.glue.describeEntity
  calls:
  - action: describeEntity
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Fields }}'
    item:
      FieldName: '{{ item.FieldName }}'
      Label: '{{ item.Label }}'
      Description: '{{ item.Description }}'
      FieldType: '{{ item.FieldType }}'
      IsPrimaryKey: '{{ item.IsPrimaryKey }}'
      IsNullable: '{{ item.IsNullable }}'
      IsRetrievable: '{{ item.IsRetrievable }}'
      IsFilterable: '{{ item.IsFilterable }}'
      IsPartitionable: '{{ item.IsPartitionable }}'
      IsCreateable: '{{ item.IsCreateable }}'
      IsUpdateable: '{{ item.IsUpdateable }}'
      IsUpsertable: '{{ item.IsUpsertable }}'
      IsDefaultOnCreate: '{{ item.IsDefaultOnCreate }}'
      SupportedValues: '{{ item.SupportedValues }}'
      SupportedFilterOperators: '{{ item.SupportedFilterOperators }}'
      ParentField: '{{ item.ParentField }}'
      NativeDataType: '{{ item.NativeDataType }}'
      CustomProperties: '{{ item.CustomProperties }}'
