    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.SchemaVersionId }}'
- discovery_id: aws.glue.getSecurityConfigurations
  calls:
  - action: getSecurityConfigurations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.SecurityConfigurations }}'
    item:
      Name: '{{ item.Name }}'
      CreatedTimeStamp: '{{ item.CreatedTimeStamp }}'
      EncryptionConfiguration: '{{ item.EncryptionConfiguration }}'
- discovery_id: aws.glue.getTriggers
  calls:
  - action: getTriggers
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Triggers }}'
    item:
      Name: '{{ item.Name }}'
      WorkflowName: '{{ item.WorkflowName }}'
      Id: '{{ item.Id }}'
      Type: '{{ item.Type }}'
      State: '{{ item.State }}'
      Description: '{{ item.Description }}'
      Schedule: '{{ item.Schedule }}'
      Actions: '{{ item.Actions }}'
      Predicate: '{{ item.Predicate }}'
      EventBatchingCondition: '{{ item.EventBatchingCondition }}'
- discovery_id: aws.glue.listBlueprints
  calls:
  - action: listBlueprints
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Blueprints }}'
- discovery_id: aws.glue.listColumnStatisticsTaskRuns
  calls:
  - action: listColumnStatisticsTaskRuns
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
