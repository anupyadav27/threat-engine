version: '1.0'
provider: aws
service: glue
services:
  client: glue
  module: boto3.client
discovery:
- discovery_id: aws.glue.describeInboundIntegrations
  calls:
  - action: describeInboundIntegrations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.InboundIntegrations }}'
    item:
      SourceArn: '{{ item.SourceArn }}'
      TargetArn: '{{ item.TargetArn }}'
      IntegrationArn: '{{ item.IntegrationArn }}'
      Status: '{{ item.Status }}'
      CreateTime: '{{ item.CreateTime }}'
      IntegrationConfig: '{{ item.IntegrationConfig }}'
      Errors: '{{ item.Errors }}'
- discovery_id: aws.glue.describeIntegrations
  calls:
  - action: describeIntegrations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Integrations }}'
    item:
      SourceArn: '{{ item.SourceArn }}'
      TargetArn: '{{ item.TargetArn }}'
      Description: '{{ item.Description }}'
      IntegrationName: '{{ item.IntegrationName }}'
      IntegrationArn: '{{ item.IntegrationArn }}'
      KmsKeyId: '{{ item.KmsKeyId }}'
      AdditionalEncryptionContext: '{{ item.AdditionalEncryptionContext }}'
      Tags: '{{ item.Tags }}'
      Status: '{{ item.Status }}'
      CreateTime: '{{ item.CreateTime }}'
      IntegrationConfig: '{{ item.IntegrationConfig }}'
      Errors: '{{ item.Errors }}'
      DataFilter: '{{ item.DataFilter }}'
- discovery_id: aws.glue.getCatalogImportStatus
  calls:
  - action: getCatalogImportStatus
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ImportStatus }}'
    item:
      ImportCompleted: '{{ item.ImportCompleted }}'
      ImportTime: '{{ item.ImportTime }}'
      ImportedBy: '{{ item.ImportedBy }}'
- discovery_id: aws.glue.getCatalogs
  calls:
  - action: getCatalogs
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.CatalogList }}'
    item:
      CatalogId: '{{ item.CatalogId }}'
      Name: '{{ item.Name }}'
      ResourceArn: '{{ item.ResourceArn }}'
      Description: '{{ item.Description }}'
      Parameters: '{{ item.Parameters }}'
      CreateTime: '{{ item.CreateTime }}'
      UpdateTime: '{{ item.UpdateTime }}'
      TargetRedshiftCatalog: '{{ item.TargetRedshiftCatalog }}'
      FederatedCatalog: '{{ item.FederatedCatalog }}'
      CatalogProperties: '{{ item.CatalogProperties }}'
      CreateTableDefaultPermissions: '{{ item.CreateTableDefaultPermissions }}'
      CreateDatabaseDefaultPermissions: '{{ item.CreateDatabaseDefaultPermissions
        }}'
      AllowFullTableExternalDataAccess: '{{ item.AllowFullTableExternalDataAccess
        }}'
- discovery_id: aws.glue.getClassifiers
  calls:
  - action: getClassifiers
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Classifiers }}'
    item:
      GrokClassifier: '{{ item.GrokClassifier }}'
      XMLClassifier: '{{ item.XMLClassifier }}'
      JsonClassifier: '{{ item.JsonClassifier }}'
      CsvClassifier: '{{ item.CsvClassifier }}'
- discovery_id: aws.glue.getConnections
  calls:
  - action: getConnections
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ConnectionList }}'
    item:
      Name: '{{ item.Name }}'
      Description: '{{ item.Description }}'
      ConnectionType: '{{ item.ConnectionType }}'
      MatchCriteria: '{{ item.MatchCriteria }}'
      ConnectionProperties: '{{ item.ConnectionProperties }}'
      SparkProperties: '{{ item.SparkProperties }}'
      AthenaProperties: '{{ item.AthenaProperties }}'
      PythonProperties: '{{ item.PythonProperties }}'
      PhysicalConnectionRequirements: '{{ item.PhysicalConnectionRequirements }}'
      CreationTime: '{{ item.CreationTime }}'
      LastUpdatedTime: '{{ item.LastUpdatedTime }}'
      LastUpdatedBy: '{{ item.LastUpdatedBy }}'
      Status: '{{ item.Status }}'
      StatusReason: '{{ item.StatusReason }}'
      LastConnectionValidationTime: '{{ item.LastConnectionValidationTime }}'
      AuthenticationConfiguration: '{{ item.AuthenticationConfiguration }}'
      ConnectionSchemaVersion: '{{ item.ConnectionSchemaVersion }}'
      CompatibleComputeEnvironments: '{{ item.CompatibleComputeEnvironments }}'
- discovery_id: aws.glue.getCrawlerMetrics
  calls:
  - action: getCrawlerMetrics
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.CrawlerMetricsList }}'
    item:
      CrawlerName: '{{ item.CrawlerName }}'
      TimeLeftSeconds: '{{ item.TimeLeftSeconds }}'
      StillEstimating: '{{ item.StillEstimating }}'
      LastRuntimeSeconds: '{{ item.LastRuntimeSeconds }}'
      MedianRuntimeSeconds: '{{ item.MedianRuntimeSeconds }}'
      TablesCreated: '{{ item.TablesCreated }}'
      TablesUpdated: '{{ item.TablesUpdated }}'
      TablesDeleted: '{{ item.TablesDeleted }}'
- discovery_id: aws.glue.getCrawlers
  calls:
  - action: getCrawlers
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Crawlers }}'
    item:
      Name: '{{ item.Name }}'
      Role: '{{ item.Role }}'
      Targets: '{{ item.Targets }}'
      DatabaseName: '{{ item.DatabaseName }}'
      Description: '{{ item.Description }}'
      Classifiers: '{{ item.Classifiers }}'
      RecrawlPolicy: '{{ item.RecrawlPolicy }}'
      SchemaChangePolicy: '{{ item.SchemaChangePolicy }}'
      LineageConfiguration: '{{ item.LineageConfiguration }}'
      State: '{{ item.State }}'
      TablePrefix: '{{ item.TablePrefix }}'
      Schedule: '{{ item.Schedule }}'
      CrawlElapsedTime: '{{ item.CrawlElapsedTime }}'
      CreationTime: '{{ item.CreationTime }}'
      LastUpdated: '{{ item.LastUpdated }}'
      LastCrawl: '{{ item.LastCrawl }}'
      Version: '{{ item.Version }}'
      Configuration: '{{ item.Configuration }}'
      CrawlerSecurityConfiguration: '{{ item.CrawlerSecurityConfiguration }}'
      LakeFormationConfiguration: '{{ item.LakeFormationConfiguration }}'
- discovery_id: aws.glue.getDataCatalogEncryptionSettings
  calls:
  - action: getDataCatalogEncryptionSettings
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.DataCatalogEncryptionSettings }}'
    item:
      EncryptionAtRest: '{{ item.EncryptionAtRest }}'
      ConnectionPasswordEncryption: '{{ item.ConnectionPasswordEncryption }}'
- discovery_id: aws.glue.getDatabases
  calls:
  - action: getDatabases
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.DatabaseList }}'
    item:
      Name: '{{ item.Name }}'
      Description: '{{ item.Description }}'
      LocationUri: '{{ item.LocationUri }}'
      Parameters: '{{ item.Parameters }}'
      CreateTime: '{{ item.CreateTime }}'
      CreateTableDefaultPermissions: '{{ item.CreateTableDefaultPermissions }}'
      TargetDatabase: '{{ item.TargetDatabase }}'
      CatalogId: '{{ item.CatalogId }}'
      FederatedDatabase: '{{ item.FederatedDatabase }}'
- discovery_id: aws.glue.getDataflowGraph
  calls:
  - action: getDataflowGraph
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.DagNodes }}'
    item:
      Id: '{{ item.Id }}'
      NodeType: '{{ item.NodeType }}'
      Args: '{{ item.Args }}'
      LineNumber: '{{ item.LineNumber }}'
- discovery_id: aws.glue.getDevEndpoints
  calls:
  - action: getDevEndpoints
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.DevEndpoints }}'
    item:
      EndpointName: '{{ item.EndpointName }}'
      RoleArn: '{{ item.RoleArn }}'
      SecurityGroupIds: '{{ item.SecurityGroupIds }}'
      SubnetId: '{{ item.SubnetId }}'
      YarnEndpointAddress: '{{ item.YarnEndpointAddress }}'
      PrivateAddress: '{{ item.PrivateAddress }}'
      ZeppelinRemoteSparkInterpreterPort: '{{ item.ZeppelinRemoteSparkInterpreterPort
        }}'
      PublicAddress: '{{ item.PublicAddress }}'
      Status: '{{ item.Status }}'
      WorkerType: '{{ item.WorkerType }}'
      GlueVersion: '{{ item.GlueVersion }}'
      NumberOfWorkers: '{{ item.NumberOfWorkers }}'
      NumberOfNodes: '{{ item.NumberOfNodes }}'
      AvailabilityZone: '{{ item.AvailabilityZone }}'
      VpcId: '{{ item.VpcId }}'
      ExtraPythonLibsS3Path: '{{ item.ExtraPythonLibsS3Path }}'
      ExtraJarsS3Path: '{{ item.ExtraJarsS3Path }}'
      FailureReason: '{{ item.FailureReason }}'
      LastUpdateStatus: '{{ item.LastUpdateStatus }}'
      CreatedTimestamp: '{{ item.CreatedTimestamp }}'
      LastModifiedTimestamp: '{{ item.LastModifiedTimestamp }}'
      PublicKey: '{{ item.PublicKey }}'
      PublicKeys: '{{ item.PublicKeys }}'
      SecurityConfiguration: '{{ item.SecurityConfiguration }}'
      Arguments: '{{ item.Arguments }}'
- discovery_id: aws.glue.getGlueIdentityCenterConfiguration
  calls:
  - action: getGlueIdentityCenterConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Scopes }}'
- discovery_id: aws.glue.getJobs
  calls:
  - action: getJobs
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Jobs }}'
    item:
      Name: '{{ item.Name }}'
      JobMode: '{{ item.JobMode }}'
      JobRunQueuingEnabled: '{{ item.JobRunQueuingEnabled }}'
      Description: '{{ item.Description }}'
      LogUri: '{{ item.LogUri }}'
      Role: '{{ item.Role }}'
      CreatedOn: '{{ item.CreatedOn }}'
      LastModifiedOn: '{{ item.LastModifiedOn }}'
      ExecutionProperty: '{{ item.ExecutionProperty }}'
      Command: '{{ item.Command }}'
      DefaultArguments: '{{ item.DefaultArguments }}'
      NonOverridableArguments: '{{ item.NonOverridableArguments }}'
      Connections: '{{ item.Connections }}'
      MaxRetries: '{{ item.MaxRetries }}'
      AllocatedCapacity: '{{ item.AllocatedCapacity }}'
      Timeout: '{{ item.Timeout }}'
      MaxCapacity: '{{ item.MaxCapacity }}'
      WorkerType: '{{ item.WorkerType }}'
      NumberOfWorkers: '{{ item.NumberOfWorkers }}'
      SecurityConfiguration: '{{ item.SecurityConfiguration }}'
      NotificationProperty: '{{ item.NotificationProperty }}'
      GlueVersion: '{{ item.GlueVersion }}'
      CodeGenConfigurationNodes: '{{ item.CodeGenConfigurationNodes }}'
      ExecutionClass: '{{ item.ExecutionClass }}'
      SourceControlDetails: '{{ item.SourceControlDetails }}'
      MaintenanceWindow: '{{ item.MaintenanceWindow }}'
      ProfileName: '{{ item.ProfileName }}'
- discovery_id: aws.glue.getMlTransforms
  calls:
  - action: getMlTransforms
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Transforms }}'
    item:
      TransformId: '{{ item.TransformId }}'
      Name: '{{ item.Name }}'
      Description: '{{ item.Description }}'
      Status: '{{ item.Status }}'
      CreatedOn: '{{ item.CreatedOn }}'
      LastModifiedOn: '{{ item.LastModifiedOn }}'
      InputRecordTables: '{{ item.InputRecordTables }}'
      Parameters: '{{ item.Parameters }}'
      EvaluationMetrics: '{{ item.EvaluationMetrics }}'
      LabelCount: '{{ item.LabelCount }}'
      Schema: '{{ item.Schema }}'
      Role: '{{ item.Role }}'
      GlueVersion: '{{ item.GlueVersion }}'
      MaxCapacity: '{{ item.MaxCapacity }}'
      WorkerType: '{{ item.WorkerType }}'
      NumberOfWorkers: '{{ item.NumberOfWorkers }}'
      Timeout: '{{ item.Timeout }}'
      MaxRetries: '{{ item.MaxRetries }}'
      TransformEncryption: '{{ item.TransformEncryption }}'
- discovery_id: aws.glue.getResourcePolicies
  calls:
  - action: getResourcePolicies
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.GetResourcePoliciesResponseList }}'
    item:
      PolicyInJson: '{{ item.PolicyInJson }}'
      PolicyHash: '{{ item.PolicyHash }}'
