      DataSource: '{{ item.DataSource }}'
      JobName: '{{ item.JobName }}'
      JobRunId: '{{ item.JobRunId }}'
      StartedOn: '{{ item.StartedOn }}'
- discovery_id: aws.glue.listDataQualityRuleRecommendationRuns
  calls:
  - action: listDataQualityRuleRecommendationRuns
    save_as: response
    on_error: continue
    params:
