version: '1.0'
provider: aws
service: b2bi
services:
  client: b2bi
  module: boto3.client
discovery:
- discovery_id: aws.b2bi.listCapabilities
  calls:
  - action: listCapabilities
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.capabilities }}'
    item:
      capabilityId: '{{ item.capabilityId }}'
      name: '{{ item.name }}'
      type: '{{ item.type }}'
      createdAt: '{{ item.createdAt }}'
      modifiedAt: '{{ item.modifiedAt }}'
- discovery_id: aws.b2bi.listPartnerships
  calls:
  - action: listPartnerships
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.partnerships }}'
    item:
      profileId: '{{ item.profileId }}'
      partnershipId: '{{ item.partnershipId }}'
      name: '{{ item.name }}'
      capabilities: '{{ item.capabilities }}'
      capabilityOptions: '{{ item.capabilityOptions }}'
      tradingPartnerId: '{{ item.tradingPartnerId }}'
      createdAt: '{{ item.createdAt }}'
      modifiedAt: '{{ item.modifiedAt }}'
- discovery_id: aws.b2bi.listProfiles
  calls:
  - action: listProfiles
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.profiles }}'
    item:
      profileId: '{{ item.profileId }}'
      name: '{{ item.name }}'
      businessName: '{{ item.businessName }}'
      logging: '{{ item.logging }}'
      logGroupName: '{{ item.logGroupName }}'
      createdAt: '{{ item.createdAt }}'
      modifiedAt: '{{ item.modifiedAt }}'
- discovery_id: aws.b2bi.listTransformers
  calls:
  - action: listTransformers
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.transformers }}'
    item:
      transformerId: '{{ item.transformerId }}'
      name: '{{ item.name }}'
      status: '{{ item.status }}'
      createdAt: '{{ item.createdAt }}'
      modifiedAt: '{{ item.modifiedAt }}'
      fileFormat: '{{ item.fileFormat }}'
      mappingTemplate: '{{ item.mappingTemplate }}'
      ediType: '{{ item.ediType }}'
      sampleDocument: '{{ item.sampleDocument }}'
      inputConversion: '{{ item.inputConversion }}'
      mapping: '{{ item.mapping }}'
      outputConversion: '{{ item.outputConversion }}'
      sampleDocuments: '{{ item.sampleDocuments }}'
- discovery_id: aws.b2bi.getCapability
  calls:
  - action: getCapability
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.instructionsDocuments }}'
    item:
      bucketName: '{{ item.bucketName }}'
      key: '{{ item.key }}'
- discovery_id: aws.b2bi.getPartnership
  calls:
  - action: getPartnership
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.capabilities }}'
- discovery_id: aws.b2bi.getProfile
  calls:
  - action: getProfile
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.profileId }}'
- discovery_id: aws.b2bi.getTransformer
  calls:
  - action: getTransformer
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ediType }}'
    item:
      x12Details: '{{ item.x12Details }}'
- discovery_id: aws.b2bi.getTransformerJob
  calls:
  - action: getTransformerJob
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.outputFiles }}'
    item:
      bucketName: '{{ item.bucketName }}'
      key: '{{ item.key }}'
- discovery_id: aws.b2bi.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Tags }}'
    item:
      Key: '{{ item.Key }}'
      Value: '{{ item.Value }}'
checks: []
