      Arn: '{{ item.Arn }}'
      Domains: '{{ item.Domains }}'
      ConnectionGroupId: '{{ item.ConnectionGroupId }}'
      Customizations: '{{ item.Customizations }}'
      CreatedTime: '{{ item.CreatedTime }}'
      LastModifiedTime: '{{ item.LastModifiedTime }}'
