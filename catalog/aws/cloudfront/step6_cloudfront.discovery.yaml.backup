version: '1.0'
provider: aws
service: cloudfront
services:
  client: cloudfront
  module: boto3.client
discovery:
- discovery_id: aws.cloudfront.getRealtimeLogConfig
  calls:
  - action: getRealtimeLogConfig
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.RealtimeLogConfig }}'
    item:
      ARN: '{{ item.ARN }}'
      Name: '{{ item.Name }}'
      SamplingRate: '{{ item.SamplingRate }}'
      EndPoints: '{{ item.EndPoints }}'
      Fields: '{{ item.Fields }}'
- discovery_id: aws.cloudfront.listAnycastIpLists
  calls:
  - action: listAnycastIpLists
    save_as: response
    on_error: continue
    params:
      MaxItems: 1000
  emit:
    as: item
    items_for: '{{ response.AnycastIpLists }}'
    item:
      Items: '{{ item.Items }}'
      Marker: '{{ item.Marker }}'
      NextMarker: '{{ item.NextMarker }}'
      MaxItems: '{{ item.MaxItems }}'
      IsTruncated: '{{ item.IsTruncated }}'
      Quantity: '{{ item.Quantity }}'
- discovery_id: aws.cloudfront.listCachePolicies
  calls:
  - action: listCachePolicies
    save_as: response
    on_error: continue
    params:
      MaxItems: 1000
  emit:
    as: item
    items_for: '{{ response.CachePolicyList }}'
    item:
      NextMarker: '{{ item.NextMarker }}'
      MaxItems: '{{ item.MaxItems }}'
      Quantity: '{{ item.Quantity }}'
      Items: '{{ item.Items }}'
- discovery_id: aws.cloudfront.listCloudFrontOriginAccessIdentities
  calls:
  - action: listCloudFrontOriginAccessIdentities
    save_as: response
    on_error: continue
    params:
      MaxItems: 1000
  emit:
    as: item
    items_for: '{{ response.CloudFrontOriginAccessIdentityList }}'
    item:
      Marker: '{{ item.Marker }}'
      NextMarker: '{{ item.NextMarker }}'
      MaxItems: '{{ item.MaxItems }}'
      IsTruncated: '{{ item.IsTruncated }}'
      Quantity: '{{ item.Quantity }}'
      Items: '{{ item.Items }}'
- discovery_id: aws.cloudfront.listConnectionFunctions
  calls:
  - action: listConnectionFunctions
    save_as: response
    on_error: continue
    params:
      MaxItems: 1000
  emit:
    as: item
    items_for: '{{ response.ConnectionFunctions }}'
    item:
      Name: '{{ item.Name }}'
      Id: '{{ item.Id }}'
      ConnectionFunctionConfig: '{{ item.ConnectionFunctionConfig }}'
      ConnectionFunctionArn: '{{ item.ConnectionFunctionArn }}'
      Status: '{{ item.Status }}'
      Stage: '{{ item.Stage }}'
      CreatedTime: '{{ item.CreatedTime }}'
      LastModifiedTime: '{{ item.LastModifiedTime }}'
- discovery_id: aws.cloudfront.listConnectionGroups
  calls:
  - action: listConnectionGroups
    save_as: response
    on_error: continue
    params:
      MaxItems: 1000
  emit:
    as: item
    items_for: '{{ response.ConnectionGroups }}'
    item:
      Id: '{{ item.Id }}'
      Name: '{{ item.Name }}'
      Arn: '{{ item.Arn }}'
      RoutingEndpoint: '{{ item.RoutingEndpoint }}'
      CreatedTime: '{{ item.CreatedTime }}'
      LastModifiedTime: '{{ item.LastModifiedTime }}'
      ETag: '{{ item.ETag }}'
      AnycastIpListId: '{{ item.AnycastIpListId }}'
      Enabled: '{{ item.Enabled }}'
      Status: '{{ item.Status }}'
      IsDefault: '{{ item.IsDefault }}'
- discovery_id: aws.cloudfront.listContinuousDeploymentPolicies
  calls:
  - action: listContinuousDeploymentPolicies
    save_as: response
