version: '1.0'
provider: aws
service: route53profiles
services:
  client: route53profiles
  module: boto3.client
discovery:
- discovery_id: aws.route53profiles.listProfileAssociations
  calls:
  - action: listProfileAssociations
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.ProfileAssociations }}'
    item:
      CreationTime: '{{ item.CreationTime }}'
      Id: '{{ item.Id }}'
      ModificationTime: '{{ item.ModificationTime }}'
      Name: '{{ item.Name }}'
      OwnerId: '{{ item.OwnerId }}'
      ProfileId: '{{ item.ProfileId }}'
      ResourceId: '{{ item.ResourceId }}'
      Status: '{{ item.Status }}'
      StatusMessage: '{{ item.StatusMessage }}'
- discovery_id: aws.route53profiles.listProfiles
  calls:
  - action: listProfiles
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.ProfileSummaries }}'
    item:
      Arn: '{{ item.Arn }}'
      Id: '{{ item.Id }}'
      Name: '{{ item.Name }}'
      ShareStatus: '{{ item.ShareStatus }}'
- discovery_id: aws.route53profiles.getProfile
  calls:
  - action: getProfile
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Profile }}'
    item:
      Arn: '{{ item.Arn }}'
      ClientToken: '{{ item.ClientToken }}'
      CreationTime: '{{ item.CreationTime }}'
      Id: '{{ item.Id }}'
      ModificationTime: '{{ item.ModificationTime }}'
      Name: '{{ item.Name }}'
      OwnerId: '{{ item.OwnerId }}'
      ShareStatus: '{{ item.ShareStatus }}'
      Status: '{{ item.Status }}'
      StatusMessage: '{{ item.StatusMessage }}'
- discovery_id: aws.route53profiles.getProfileAssociation
  calls:
  - action: getProfileAssociation
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ProfileAssociation }}'
    item:
      CreationTime: '{{ item.CreationTime }}'
      Id: '{{ item.Id }}'
      ModificationTime: '{{ item.ModificationTime }}'
      Name: '{{ item.Name }}'
      OwnerId: '{{ item.OwnerId }}'
      ProfileId: '{{ item.ProfileId }}'
      ResourceId: '{{ item.ResourceId }}'
      Status: '{{ item.Status }}'
      StatusMessage: '{{ item.StatusMessage }}'
- discovery_id: aws.route53profiles.getProfileResourceAssociation
  calls:
  - action: getProfileResourceAssociation
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ProfileResourceAssociation }}'
    item:
      CreationTime: '{{ item.CreationTime }}'
      Id: '{{ item.Id }}'
      ModificationTime: '{{ item.ModificationTime }}'
      Name: '{{ item.Name }}'
      OwnerId: '{{ item.OwnerId }}'
      ProfileId: '{{ item.ProfileId }}'
      ResourceArn: '{{ item.ResourceArn }}'
      ResourceProperties: '{{ item.ResourceProperties }}'
      ResourceType: '{{ item.ResourceType }}'
      Status: '{{ item.Status }}'
      StatusMessage: '{{ item.StatusMessage }}'
- discovery_id: aws.route53profiles.listProfileResourceAssociations
  calls:
  - action: listProfileResourceAssociations
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.ProfileResourceAssociations }}'
    item:
      CreationTime: '{{ item.CreationTime }}'
      Id: '{{ item.Id }}'
      ModificationTime: '{{ item.ModificationTime }}'
      Name: '{{ item.Name }}'
      OwnerId: '{{ item.OwnerId }}'
      ProfileId: '{{ item.ProfileId }}'
      ResourceArn: '{{ item.ResourceArn }}'
      ResourceProperties: '{{ item.ResourceProperties }}'
      ResourceType: '{{ item.ResourceType }}'
      Status: '{{ item.Status }}'
      StatusMessage: '{{ item.StatusMessage }}'
- discovery_id: aws.route53profiles.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Tags }}'
checks: []
