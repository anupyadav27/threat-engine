version: '1.0'
provider: aws
service: s3
services:
  client: s3
  module: boto3.client
discovery:
- discovery_id: aws.s3.listBuckets
  calls:
  - action: listBuckets
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Buckets }}'
    item:
      Name: '{{ item.Name }}'
      CreationDate: '{{ item.CreationDate }}'
      BucketRegion: '{{ item.BucketRegion }}'
      BucketArn: '{{ item.BucketArn }}'
- discovery_id: aws.s3.listDirectoryBuckets
  calls:
  - action: listDirectoryBuckets
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Buckets }}'
    item:
      Name: '{{ item.Name }}'
      CreationDate: '{{ item.CreationDate }}'
      BucketRegion: '{{ item.BucketRegion }}'
      BucketArn: '{{ item.BucketArn }}'
- discovery_id: aws.s3.getBucketAbac
  calls:
  - action: getBucketAbac
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AbacStatus }}'
    item:
      Status: '{{ item.Status }}'
- discovery_id: aws.s3.getBucketAccelerateConfiguration
  calls:
  - action: getBucketAccelerateConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Status }}'
- discovery_id: aws.s3.getBucketAcl
  calls:
  - action: getBucketAcl
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Grants }}'
    item:
      Grantee: '{{ item.Grantee }}'
      Permission: '{{ item.Permission }}'
- discovery_id: aws.s3.getBucketAnalyticsConfiguration
  calls:
  - action: getBucketAnalyticsConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AnalyticsConfiguration }}'
    item:
      Id: '{{ item.Id }}'
      Filter: '{{ item.Filter }}'
      StorageClassAnalysis: '{{ item.StorageClassAnalysis }}'
- discovery_id: aws.s3.getBucketCors
  calls:
  - action: getBucketCors
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.CORSRules }}'
    item:
      ID: '{{ item.ID }}'
      AllowedHeaders: '{{ item.AllowedHeaders }}'
      AllowedMethods: '{{ item.AllowedMethods }}'
      AllowedOrigins: '{{ item.AllowedOrigins }}'
      ExposeHeaders: '{{ item.ExposeHeaders }}'
      MaxAgeSeconds: '{{ item.MaxAgeSeconds }}'
- discovery_id: aws.s3.getBucketEncryption
  calls:
  - action: getBucketEncryption
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ServerSideEncryptionConfiguration }}'
    item:
      Rules: '{{ item.Rules }}'
- discovery_id: aws.s3.getBucketIntelligentTieringConfiguration
  calls:
  - action: getBucketIntelligentTieringConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.IntelligentTieringConfiguration }}'
    item:
      Id: '{{ item.Id }}'
      Filter: '{{ item.Filter }}'
      Status: '{{ item.Status }}'
      Tierings: '{{ item.Tierings }}'
- discovery_id: aws.s3.getBucketInventoryConfiguration
  calls:
  - action: getBucketInventoryConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.InventoryConfiguration }}'
    item:
      Destination: '{{ item.Destination }}'
      IsEnabled: '{{ item.IsEnabled }}'
      Filter: '{{ item.Filter }}'
      Id: '{{ item.Id }}'
      IncludedObjectVersions: '{{ item.IncludedObjectVersions }}'
      OptionalFields: '{{ item.OptionalFields }}'
      Schedule: '{{ item.Schedule }}'
- discovery_id: aws.s3.getBucketLifecycle
  calls:
  - action: getBucketLifecycle
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Rules }}'
    item:
      Expiration: '{{ item.Expiration }}'
      ID: '{{ item.ID }}'
      Prefix: '{{ item.Prefix }}'
      Status: '{{ item.Status }}'
      Transition: '{{ item.Transition }}'
      NoncurrentVersionTransition: '{{ item.NoncurrentVersionTransition }}'
      NoncurrentVersionExpiration: '{{ item.NoncurrentVersionExpiration }}'
      AbortIncompleteMultipartUpload: '{{ item.AbortIncompleteMultipartUpload }}'
- discovery_id: aws.s3.getBucketLifecycleConfiguration
  calls:
  - action: getBucketLifecycleConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Rules }}'
    item:
      Expiration: '{{ item.Expiration }}'
      ID: '{{ item.ID }}'
      Prefix: '{{ item.Prefix }}'
      Filter: '{{ item.Filter }}'
      Status: '{{ item.Status }}'
      Transitions: '{{ item.Transitions }}'
      NoncurrentVersionTransitions: '{{ item.NoncurrentVersionTransitions }}'
      NoncurrentVersionExpiration: '{{ item.NoncurrentVersionExpiration }}'
      AbortIncompleteMultipartUpload: '{{ item.AbortIncompleteMultipartUpload }}'
- discovery_id: aws.s3.getBucketLocation
  calls:
  - action: getBucketLocation
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.LocationConstraint }}'
- discovery_id: aws.s3.getBucketLogging
  calls:
  - action: getBucketLogging
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.LoggingEnabled }}'
    item:
      TargetBucket: '{{ item.TargetBucket }}'
      TargetGrants: '{{ item.TargetGrants }}'
      TargetPrefix: '{{ item.TargetPrefix }}'
      TargetObjectKeyFormat: '{{ item.TargetObjectKeyFormat }}'
- discovery_id: aws.s3.getBucketMetadataConfiguration
  calls:
  - action: getBucketMetadataConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.GetBucketMetadataConfigurationResult }}'
    item:
      MetadataConfigurationResult: '{{ item.MetadataConfigurationResult }}'
- discovery_id: aws.s3.getBucketMetadataTableConfiguration
  calls:
  - action: getBucketMetadataTableConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.GetBucketMetadataTableConfigurationResult }}'
    item:
      MetadataTableConfigurationResult: '{{ item.MetadataTableConfigurationResult
        }}'
      Status: '{{ item.Status }}'
      Error: '{{ item.Error }}'
- discovery_id: aws.s3.getBucketMetricsConfiguration
  calls:
  - action: getBucketMetricsConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.MetricsConfiguration }}'
    item:
      Id: '{{ item.Id }}'
      Filter: '{{ item.Filter }}'
- discovery_id: aws.s3.getBucketNotification
  calls:
  - action: getBucketNotification
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.TopicConfiguration }}'
    item:
      Id: '{{ item.Id }}'
      Events: '{{ item.Events }}'
      Event: '{{ item.Event }}'
      Topic: '{{ item.Topic }}'
- discovery_id: aws.s3.getBucketNotificationConfiguration
  calls:
  - action: getBucketNotificationConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.TopicConfigurations }}'
    item:
      Id: '{{ item.Id }}'
      TopicArn: '{{ item.TopicArn }}'
      Events: '{{ item.Events }}'
      Filter: '{{ item.Filter }}'
- discovery_id: aws.s3.getBucketOwnershipControls
  calls:
  - action: getBucketOwnershipControls
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.OwnershipControls }}'
    item:
      Rules: '{{ item.Rules }}'
- discovery_id: aws.s3.getBucketPolicy
  calls:
  - action: getBucketPolicy
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Policy }}'
- discovery_id: aws.s3.getBucketPolicyStatus
  calls:
  - action: getBucketPolicyStatus
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.PolicyStatus }}'
    item:
      IsPublic: '{{ item.IsPublic }}'
- discovery_id: aws.s3.getBucketReplication
  calls:
  - action: getBucketReplication
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ReplicationConfiguration }}'
    item:
      Role: '{{ item.Role }}'
      Rules: '{{ item.Rules }}'
- discovery_id: aws.s3.getBucketRequestPayment
  calls:
  - action: getBucketRequestPayment
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Payer }}'
- discovery_id: aws.s3.getBucketTagging
  calls:
  - action: getBucketTagging
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.TagSet }}'
    item:
      Key: '{{ item.Key }}'
      Value: '{{ item.Value }}'
- discovery_id: aws.s3.getBucketVersioning
  calls:
  - action: getBucketVersioning
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Status }}'
- discovery_id: aws.s3.getBucketWebsite
  calls:
  - action: getBucketWebsite
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.RoutingRules }}'
    item:
      Condition: '{{ item.Condition }}'
      Redirect: '{{ item.Redirect }}'
- discovery_id: aws.s3.getObject
  calls:
  - action: getObject
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Body }}'
- discovery_id: aws.s3.getObjectAcl
  calls:
  - action: getObjectAcl
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Grants }}'
    item:
      Grantee: '{{ item.Grantee }}'
      Permission: '{{ item.Permission }}'
- discovery_id: aws.s3.getObjectAttributes
  calls:
  - action: getObjectAttributes
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Checksum }}'
    item:
      ChecksumCRC32: '{{ item.ChecksumCRC32 }}'
      ChecksumCRC32C: '{{ item.ChecksumCRC32C }}'
      ChecksumCRC64NVME: '{{ item.ChecksumCRC64NVME }}'
      ChecksumSHA1: '{{ item.ChecksumSHA1 }}'
      ChecksumSHA256: '{{ item.ChecksumSHA256 }}'
      ChecksumType: '{{ item.ChecksumType }}'
- discovery_id: aws.s3.getObjectLegalHold
  calls:
  - action: getObjectLegalHold
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.LegalHold }}'
    item:
      Status: '{{ item.Status }}'
- discovery_id: aws.s3.getObjectLockConfiguration
  calls:
  - action: getObjectLockConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ObjectLockConfiguration }}'
    item:
      ObjectLockEnabled: '{{ item.ObjectLockEnabled }}'
      Rule: '{{ item.Rule }}'
- discovery_id: aws.s3.getObjectRetention
  calls:
  - action: getObjectRetention
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Retention }}'
    item:
      Mode: '{{ item.Mode }}'
      RetainUntilDate: '{{ item.RetainUntilDate }}'
- discovery_id: aws.s3.getObjectTagging
  calls:
  - action: getObjectTagging
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.TagSet }}'
    item:
      Key: '{{ item.Key }}'
      Value: '{{ item.Value }}'
- discovery_id: aws.s3.getObjectTorrent
  calls:
  - action: getObjectTorrent
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Body }}'
- discovery_id: aws.s3.getPublicAccessBlock
  calls:
  - action: getPublicAccessBlock
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.PublicAccessBlockConfiguration }}'
    item:
      BlockPublicAcls: '{{ item.BlockPublicAcls }}'
      IgnorePublicAcls: '{{ item.IgnorePublicAcls }}'
      BlockPublicPolicy: '{{ item.BlockPublicPolicy }}'
      RestrictPublicBuckets: '{{ item.RestrictPublicBuckets }}'
- discovery_id: aws.s3.listBucketAnalyticsConfigurations
  calls:
  - action: listBucketAnalyticsConfigurations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AnalyticsConfigurationList }}'
    item:
      Id: '{{ item.Id }}'
      Filter: '{{ item.Filter }}'
      StorageClassAnalysis: '{{ item.StorageClassAnalysis }}'
- discovery_id: aws.s3.listBucketIntelligentTieringConfigurations
  calls:
  - action: listBucketIntelligentTieringConfigurations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.IntelligentTieringConfigurationList }}'
    item:
      Id: '{{ item.Id }}'
      Filter: '{{ item.Filter }}'
      Status: '{{ item.Status }}'
      Tierings: '{{ item.Tierings }}'
- discovery_id: aws.s3.listBucketInventoryConfigurations
  calls:
  - action: listBucketInventoryConfigurations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.InventoryConfigurationList }}'
    item:
      Destination: '{{ item.Destination }}'
      IsEnabled: '{{ item.IsEnabled }}'
      Filter: '{{ item.Filter }}'
      Id: '{{ item.Id }}'
      IncludedObjectVersions: '{{ item.IncludedObjectVersions }}'
      OptionalFields: '{{ item.OptionalFields }}'
      Schedule: '{{ item.Schedule }}'
- discovery_id: aws.s3.listBucketMetricsConfigurations
  calls:
  - action: listBucketMetricsConfigurations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.MetricsConfigurationList }}'
    item:
      Id: '{{ item.Id }}'
      Filter: '{{ item.Filter }}'
- discovery_id: aws.s3.listMultipartUploads
  calls:
  - action: listMultipartUploads
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Uploads }}'
    item:
      UploadId: '{{ item.UploadId }}'
      Key: '{{ item.Key }}'
      Initiated: '{{ item.Initiated }}'
      StorageClass: '{{ item.StorageClass }}'
      Owner: '{{ item.Owner }}'
      Initiator: '{{ item.Initiator }}'
      ChecksumAlgorithm: '{{ item.ChecksumAlgorithm }}'
      ChecksumType: '{{ item.ChecksumType }}'
- discovery_id: aws.s3.listObjectVersions
  calls:
  - action: listObjectVersions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Versions }}'
    item:
      ETag: '{{ item.ETag }}'
      ChecksumAlgorithm: '{{ item.ChecksumAlgorithm }}'
      ChecksumType: '{{ item.ChecksumType }}'
      Size: '{{ item.Size }}'
      StorageClass: '{{ item.StorageClass }}'
      Key: '{{ item.Key }}'
      VersionId: '{{ item.VersionId }}'
      IsLatest: '{{ item.IsLatest }}'
      LastModified: '{{ item.LastModified }}'
      Owner: '{{ item.Owner }}'
      RestoreStatus: '{{ item.RestoreStatus }}'
- discovery_id: aws.s3.listObjects
  calls:
  - action: listObjects
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Contents }}'
    item:
      Key: '{{ item.Key }}'
      LastModified: '{{ item.LastModified }}'
      ETag: '{{ item.ETag }}'
      ChecksumAlgorithm: '{{ item.ChecksumAlgorithm }}'
      ChecksumType: '{{ item.ChecksumType }}'
      Size: '{{ item.Size }}'
      StorageClass: '{{ item.StorageClass }}'
      Owner: '{{ item.Owner }}'
      RestoreStatus: '{{ item.RestoreStatus }}'
- discovery_id: aws.s3.listObjectsV2
  calls:
  - action: listObjectsV2
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Contents }}'
    item:
      Key: '{{ item.Key }}'
      LastModified: '{{ item.LastModified }}'
      ETag: '{{ item.ETag }}'
      ChecksumAlgorithm: '{{ item.ChecksumAlgorithm }}'
      ChecksumType: '{{ item.ChecksumType }}'
      Size: '{{ item.Size }}'
      StorageClass: '{{ item.StorageClass }}'
      Owner: '{{ item.Owner }}'
      RestoreStatus: '{{ item.RestoreStatus }}'
- discovery_id: aws.s3.listParts
  calls:
  - action: listParts
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Parts }}'
    item:
      PartNumber: '{{ item.PartNumber }}'
      LastModified: '{{ item.LastModified }}'
      ETag: '{{ item.ETag }}'
      Size: '{{ item.Size }}'
      ChecksumCRC32: '{{ item.ChecksumCRC32 }}'
      ChecksumCRC32C: '{{ item.ChecksumCRC32C }}'
      ChecksumCRC64NVME: '{{ item.ChecksumCRC64NVME }}'
      ChecksumSHA1: '{{ item.ChecksumSHA1 }}'
      ChecksumSHA256: '{{ item.ChecksumSHA256 }}'
checks: []
