version: '1.0'
provider: aws
service: amplifybackend
services:
  client: amplifybackend
  module: boto3.client
discovery:
- discovery_id: aws.amplifybackend.listS3Buckets
  calls:
  - action: listS3Buckets
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Buckets }}'
    item:
      CreationDate: '{{ item.CreationDate }}'
      Name: '{{ item.Name }}'
- discovery_id: aws.amplifybackend.getBackend
  calls:
  - action: getBackend
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.BackendEnvironmentList }}'
- discovery_id: aws.amplifybackend.getBackendApi
  calls:
  - action: getBackendApi
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ResourceConfig }}'
    item:
      AdditionalAuthTypes: '{{ item.AdditionalAuthTypes }}'
      ApiName: '{{ item.ApiName }}'
      ConflictResolution: '{{ item.ConflictResolution }}'
      DefaultAuthType: '{{ item.DefaultAuthType }}'
      Service: '{{ item.Service }}'
      TransformSchema: '{{ item.TransformSchema }}'
- discovery_id: aws.amplifybackend.getBackendApiModels
  calls:
  - action: getBackendApiModels
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Models }}'
- discovery_id: aws.amplifybackend.getBackendAuth
  calls:
  - action: getBackendAuth
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ResourceConfig }}'
    item:
      AuthResources: '{{ item.AuthResources }}'
      IdentityPoolConfigs: '{{ item.IdentityPoolConfigs }}'
      Service: '{{ item.Service }}'
      UserPoolConfigs: '{{ item.UserPoolConfigs }}'
- discovery_id: aws.amplifybackend.getBackendJob
  calls:
  - action: getBackendJob
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AppId }}'
- discovery_id: aws.amplifybackend.getBackendStorage
  calls:
  - action: getBackendStorage
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ResourceConfig }}'
    item:
      BucketName: '{{ item.BucketName }}'
      Imported: '{{ item.Imported }}'
      Permissions: '{{ item.Permissions }}'
      ServiceName: '{{ item.ServiceName }}'
- discovery_id: aws.amplifybackend.getToken
  calls:
  - action: getToken
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AppId }}'
- discovery_id: aws.amplifybackend.listBackendJobs
  calls:
  - action: listBackendJobs
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Jobs }}'
    item:
      AppId: '{{ item.AppId }}'
      BackendEnvironmentName: '{{ item.BackendEnvironmentName }}'
      CreateTime: '{{ item.CreateTime }}'
      Error: '{{ item.Error }}'
      JobId: '{{ item.JobId }}'
      Operation: '{{ item.Operation }}'
      Status: '{{ item.Status }}'
      UpdateTime: '{{ item.UpdateTime }}'
checks: []
