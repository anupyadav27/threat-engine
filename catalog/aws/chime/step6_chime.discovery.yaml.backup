version: '1.0'
provider: aws
service: chime
services:
  client: chime
  module: boto3.client
discovery:
- discovery_id: aws.chime.getGlobalSettings
  calls:
  - action: getGlobalSettings
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.BusinessCalling }}'
    item:
      CdrBucket: '{{ item.CdrBucket }}'
- discovery_id: aws.chime.getPhoneNumberSettings
  calls:
  - action: getPhoneNumberSettings
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.CallingName }}'
- discovery_id: aws.chime.listAccounts
  calls:
  - action: listAccounts
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Accounts }}'
    item:
      AwsAccountId: '{{ item.AwsAccountId }}'
      AccountId: '{{ item.AccountId }}'
      Name: '{{ item.Name }}'
      AccountType: '{{ item.AccountType }}'
      CreatedTimestamp: '{{ item.CreatedTimestamp }}'
      DefaultLicense: '{{ item.DefaultLicense }}'
      SupportedLicenses: '{{ item.SupportedLicenses }}'
      AccountStatus: '{{ item.AccountStatus }}'
      SigninDelegateGroups: '{{ item.SigninDelegateGroups }}'
- discovery_id: aws.chime.listPhoneNumberOrders
  calls:
  - action: listPhoneNumberOrders
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.PhoneNumberOrders }}'
    item:
      PhoneNumberOrderId: '{{ item.PhoneNumberOrderId }}'
      ProductType: '{{ item.ProductType }}'
      Status: '{{ item.Status }}'
      OrderedPhoneNumbers: '{{ item.OrderedPhoneNumbers }}'
      CreatedTimestamp: '{{ item.CreatedTimestamp }}'
      UpdatedTimestamp: '{{ item.UpdatedTimestamp }}'
- discovery_id: aws.chime.listPhoneNumbers
  calls:
  - action: listPhoneNumbers
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.PhoneNumbers }}'
    item:
      PhoneNumberId: '{{ item.PhoneNumberId }}'
      E164PhoneNumber: '{{ item.E164PhoneNumber }}'
      Country: '{{ item.Country }}'
      Type: '{{ item.Type }}'
      ProductType: '{{ item.ProductType }}'
      Status: '{{ item.Status }}'
      Capabilities: '{{ item.Capabilities }}'
      Associations: '{{ item.Associations }}'
      CallingName: '{{ item.CallingName }}'
      CallingNameStatus: '{{ item.CallingNameStatus }}'
      CreatedTimestamp: '{{ item.CreatedTimestamp }}'
      UpdatedTimestamp: '{{ item.UpdatedTimestamp }}'
      DeletionTimestamp: '{{ item.DeletionTimestamp }}'
- discovery_id: aws.chime.searchAvailablePhoneNumbers
  calls:
  - action: searchAvailablePhoneNumbers
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.E164PhoneNumbers }}'
- discovery_id: aws.chime.getAccount
  calls:
  - action: getAccount
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Account }}'
    item:
      AwsAccountId: '{{ item.AwsAccountId }}'
      AccountId: '{{ item.AccountId }}'
      Name: '{{ item.Name }}'
      AccountType: '{{ item.AccountType }}'
      CreatedTimestamp: '{{ item.CreatedTimestamp }}'
      DefaultLicense: '{{ item.DefaultLicense }}'
      SupportedLicenses: '{{ item.SupportedLicenses }}'
      AccountStatus: '{{ item.AccountStatus }}'
      SigninDelegateGroups: '{{ item.SigninDelegateGroups }}'
- discovery_id: aws.chime.getAccountSettings
  calls:
  - action: getAccountSettings
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AccountSettings }}'
    item:
      DisableRemoteControl: '{{ item.DisableRemoteControl }}'
      EnableDialOut: '{{ item.EnableDialOut }}'
- discovery_id: aws.chime.getBot
  calls:
  - action: getBot
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Bot }}'
    item:
      BotId: '{{ item.BotId }}'
      UserId: '{{ item.UserId }}'
      DisplayName: '{{ item.DisplayName }}'
      BotType: '{{ item.BotType }}'
      Disabled: '{{ item.Disabled }}'
      CreatedTimestamp: '{{ item.CreatedTimestamp }}'
      UpdatedTimestamp: '{{ item.UpdatedTimestamp }}'
      BotEmail: '{{ item.BotEmail }}'
      SecurityToken: '{{ item.SecurityToken }}'
- discovery_id: aws.chime.getEventsConfiguration
  calls:
  - action: getEventsConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.EventsConfiguration }}'
    item:
      BotId: '{{ item.BotId }}'
      OutboundEventsHTTPSEndpoint: '{{ item.OutboundEventsHTTPSEndpoint }}'
      LambdaFunctionArn: '{{ item.LambdaFunctionArn }}'
- discovery_id: aws.chime.getPhoneNumber
  calls:
  - action: getPhoneNumber
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.PhoneNumber }}'
    item:
      PhoneNumberId: '{{ item.PhoneNumberId }}'
      E164PhoneNumber: '{{ item.E164PhoneNumber }}'
      Country: '{{ item.Country }}'
      Type: '{{ item.Type }}'
      ProductType: '{{ item.ProductType }}'
      Status: '{{ item.Status }}'
      Capabilities: '{{ item.Capabilities }}'
      Associations: '{{ item.Associations }}'
      CallingName: '{{ item.CallingName }}'
      CallingNameStatus: '{{ item.CallingNameStatus }}'
      CreatedTimestamp: '{{ item.CreatedTimestamp }}'
      UpdatedTimestamp: '{{ item.UpdatedTimestamp }}'
      DeletionTimestamp: '{{ item.DeletionTimestamp }}'
- discovery_id: aws.chime.getPhoneNumberOrder
  calls:
  - action: getPhoneNumberOrder
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.PhoneNumberOrder }}'
    item:
      PhoneNumberOrderId: '{{ item.PhoneNumberOrderId }}'
      ProductType: '{{ item.ProductType }}'
      Status: '{{ item.Status }}'
      OrderedPhoneNumbers: '{{ item.OrderedPhoneNumbers }}'
      CreatedTimestamp: '{{ item.CreatedTimestamp }}'
      UpdatedTimestamp: '{{ item.UpdatedTimestamp }}'
- discovery_id: aws.chime.getRetentionSettings
  calls:
  - action: getRetentionSettings
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.RetentionSettings }}'
    item:
      RoomRetentionSettings: '{{ item.RoomRetentionSettings }}'
      ConversationRetentionSettings: '{{ item.ConversationRetentionSettings }}'
- discovery_id: aws.chime.getRoom
  calls:
  - action: getRoom
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Room }}'
    item:
      RoomId: '{{ item.RoomId }}'
      Name: '{{ item.Name }}'
      AccountId: '{{ item.AccountId }}'
      CreatedBy: '{{ item.CreatedBy }}'
      CreatedTimestamp: '{{ item.CreatedTimestamp }}'
      UpdatedTimestamp: '{{ item.UpdatedTimestamp }}'
- discovery_id: aws.chime.getUser
  calls:
  - action: getUser
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.User }}'
    item:
      UserId: '{{ item.UserId }}'
      AccountId: '{{ item.AccountId }}'
      PrimaryEmail: '{{ item.PrimaryEmail }}'
      PrimaryProvisionedNumber: '{{ item.PrimaryProvisionedNumber }}'
      DisplayName: '{{ item.DisplayName }}'
      LicenseType: '{{ item.LicenseType }}'
      UserType: '{{ item.UserType }}'
      UserRegistrationStatus: '{{ item.UserRegistrationStatus }}'
      UserInvitationStatus: '{{ item.UserInvitationStatus }}'
      RegisteredOn: '{{ item.RegisteredOn }}'
      InvitedOn: '{{ item.InvitedOn }}'
      AlexaForBusinessMetadata: '{{ item.AlexaForBusinessMetadata }}'
      PersonalPIN: '{{ item.PersonalPIN }}'
- discovery_id: aws.chime.getUserSettings
  calls:
  - action: getUserSettings
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.UserSettings }}'
    item:
      Telephony: '{{ item.Telephony }}'
- discovery_id: aws.chime.listBots
  calls:
  - action: listBots
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Bots }}'
    item:
      BotId: '{{ item.BotId }}'
      UserId: '{{ item.UserId }}'
      DisplayName: '{{ item.DisplayName }}'
      BotType: '{{ item.BotType }}'
      Disabled: '{{ item.Disabled }}'
      CreatedTimestamp: '{{ item.CreatedTimestamp }}'
      UpdatedTimestamp: '{{ item.UpdatedTimestamp }}'
      BotEmail: '{{ item.BotEmail }}'
      SecurityToken: '{{ item.SecurityToken }}'
- discovery_id: aws.chime.listRoomMemberships
  calls:
  - action: listRoomMemberships
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.RoomMemberships }}'
    item:
      RoomId: '{{ item.RoomId }}'
      Member: '{{ item.Member }}'
      Role: '{{ item.Role }}'
      InvitedBy: '{{ item.InvitedBy }}'
      UpdatedTimestamp: '{{ item.UpdatedTimestamp }}'
- discovery_id: aws.chime.listRooms
  calls:
  - action: listRooms
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Rooms }}'
    item:
      RoomId: '{{ item.RoomId }}'
      Name: '{{ item.Name }}'
      AccountId: '{{ item.AccountId }}'
      CreatedBy: '{{ item.CreatedBy }}'
      CreatedTimestamp: '{{ item.CreatedTimestamp }}'
      UpdatedTimestamp: '{{ item.UpdatedTimestamp }}'
- discovery_id: aws.chime.listSupportedPhoneNumberCountries
  calls:
  - action: listSupportedPhoneNumberCountries
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.PhoneNumberCountries }}'
    item:
      CountryCode: '{{ item.CountryCode }}'
      SupportedPhoneNumberTypes: '{{ item.SupportedPhoneNumberTypes }}'
- discovery_id: aws.chime.listUsers
  calls:
  - action: listUsers
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Users }}'
    item:
      UserId: '{{ item.UserId }}'
      AccountId: '{{ item.AccountId }}'
      PrimaryEmail: '{{ item.PrimaryEmail }}'
      PrimaryProvisionedNumber: '{{ item.PrimaryProvisionedNumber }}'
      DisplayName: '{{ item.DisplayName }}'
      LicenseType: '{{ item.LicenseType }}'
      UserType: '{{ item.UserType }}'
      UserRegistrationStatus: '{{ item.UserRegistrationStatus }}'
      UserInvitationStatus: '{{ item.UserInvitationStatus }}'
      RegisteredOn: '{{ item.RegisteredOn }}'
      InvitedOn: '{{ item.InvitedOn }}'
      AlexaForBusinessMetadata: '{{ item.AlexaForBusinessMetadata }}'
      PersonalPIN: '{{ item.PersonalPIN }}'
checks: []
