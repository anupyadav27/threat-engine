version: '1.0'
provider: aws
service: cur
services:
  client: cur
  module: boto3.client
discovery:
- discovery_id: aws.cur.describeReportDefinitions
  calls:
  - action: describeReportDefinitions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ReportDefinitions }}'
    item:
      ReportName: '{{ item.ReportName }}'
      TimeUnit: '{{ item.TimeUnit }}'
      Format: '{{ item.Format }}'
      Compression: '{{ item.Compression }}'
      AdditionalSchemaElements: '{{ item.AdditionalSchemaElements }}'
      S3Bucket: '{{ item.S3Bucket }}'
      S3Prefix: '{{ item.S3Prefix }}'
      S3Region: '{{ item.S3Region }}'
      AdditionalArtifacts: '{{ item.AdditionalArtifacts }}'
      RefreshClosedReports: '{{ item.RefreshClosedReports }}'
      ReportVersioning: '{{ item.ReportVersioning }}'
      BillingViewArn: '{{ item.BillingViewArn }}'
      ReportStatus: '{{ item.ReportStatus }}'
- discovery_id: aws.cur.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Tags }}'
    item:
      Key: '{{ item.Key }}'
      Value: '{{ item.Value }}'
checks: []
