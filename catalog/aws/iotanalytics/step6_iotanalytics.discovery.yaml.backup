version: '1.0'
provider: aws
service: iotanalytics
services:
  client: iotanalytics
  module: boto3.client
discovery:
- discovery_id: aws.iotanalytics.describeLoggingOptions
  calls:
  - action: describeLoggingOptions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.loggingOptions }}'
    item:
      roleArn: '{{ item.roleArn }}'
      level: '{{ item.level }}'
      enabled: '{{ item.enabled }}'
- discovery_id: aws.iotanalytics.listChannels
  calls:
  - action: listChannels
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.channelSummaries }}'
    item:
      channelName: '{{ item.channelName }}'
      channelStorage: '{{ item.channelStorage }}'
      status: '{{ item.status }}'
      creationTime: '{{ item.creationTime }}'
      lastUpdateTime: '{{ item.lastUpdateTime }}'
      lastMessageArrivalTime: '{{ item.lastMessageArrivalTime }}'
- discovery_id: aws.iotanalytics.listDatasets
  calls:
  - action: listDatasets
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.datasetSummaries }}'
    item:
      datasetName: '{{ item.datasetName }}'
      status: '{{ item.status }}'
      creationTime: '{{ item.creationTime }}'
      lastUpdateTime: '{{ item.lastUpdateTime }}'
      triggers: '{{ item.triggers }}'
      actions: '{{ item.actions }}'
- discovery_id: aws.iotanalytics.listDatastores
  calls:
  - action: listDatastores
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.datastoreSummaries }}'
    item:
      datastoreName: '{{ item.datastoreName }}'
      datastoreStorage: '{{ item.datastoreStorage }}'
      status: '{{ item.status }}'
      creationTime: '{{ item.creationTime }}'
      lastUpdateTime: '{{ item.lastUpdateTime }}'
      lastMessageArrivalTime: '{{ item.lastMessageArrivalTime }}'
      fileFormatType: '{{ item.fileFormatType }}'
      datastorePartitions: '{{ item.datastorePartitions }}'
- discovery_id: aws.iotanalytics.listPipelines
  calls:
  - action: listPipelines
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.pipelineSummaries }}'
    item:
      pipelineName: '{{ item.pipelineName }}'
      reprocessingSummaries: '{{ item.reprocessingSummaries }}'
      creationTime: '{{ item.creationTime }}'
      lastUpdateTime: '{{ item.lastUpdateTime }}'
- discovery_id: aws.iotanalytics.describeChannel
  calls:
  - action: describeChannel
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.channel }}'
    item:
      name: '{{ item.name }}'
      storage: '{{ item.storage }}'
      arn: '{{ item.arn }}'
      status: '{{ item.status }}'
      retentionPeriod: '{{ item.retentionPeriod }}'
      creationTime: '{{ item.creationTime }}'
      lastUpdateTime: '{{ item.lastUpdateTime }}'
      lastMessageArrivalTime: '{{ item.lastMessageArrivalTime }}'
- discovery_id: aws.iotanalytics.describeDataset
  calls:
  - action: describeDataset
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.dataset }}'
    item:
      name: '{{ item.name }}'
      arn: '{{ item.arn }}'
      actions: '{{ item.actions }}'
      triggers: '{{ item.triggers }}'
      contentDeliveryRules: '{{ item.contentDeliveryRules }}'
      status: '{{ item.status }}'
      creationTime: '{{ item.creationTime }}'
      lastUpdateTime: '{{ item.lastUpdateTime }}'
      retentionPeriod: '{{ item.retentionPeriod }}'
      versioningConfiguration: '{{ item.versioningConfiguration }}'
      lateDataRules: '{{ item.lateDataRules }}'
- discovery_id: aws.iotanalytics.describeDatastore
  calls:
  - action: describeDatastore
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.datastore }}'
    item:
      name: '{{ item.name }}'
      storage: '{{ item.storage }}'
      arn: '{{ item.arn }}'
      status: '{{ item.status }}'
      retentionPeriod: '{{ item.retentionPeriod }}'
      creationTime: '{{ item.creationTime }}'
      lastUpdateTime: '{{ item.lastUpdateTime }}'
      lastMessageArrivalTime: '{{ item.lastMessageArrivalTime }}'
      fileFormatConfiguration: '{{ item.fileFormatConfiguration }}'
      datastorePartitions: '{{ item.datastorePartitions }}'
- discovery_id: aws.iotanalytics.describePipeline
  calls:
  - action: describePipeline
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.pipeline }}'
    item:
      name: '{{ item.name }}'
      arn: '{{ item.arn }}'
      activities: '{{ item.activities }}'
      reprocessingSummaries: '{{ item.reprocessingSummaries }}'
      creationTime: '{{ item.creationTime }}'
      lastUpdateTime: '{{ item.lastUpdateTime }}'
- discovery_id: aws.iotanalytics.getDatasetContent
  calls:
  - action: getDatasetContent
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.entries }}'
    item:
      entryName: '{{ item.entryName }}'
      dataURI: '{{ item.dataURI }}'
- discovery_id: aws.iotanalytics.listDatasetContents
  calls:
  - action: listDatasetContents
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.datasetContentSummaries }}'
    item:
      version: '{{ item.version }}'
      status: '{{ item.status }}'
      creationTime: '{{ item.creationTime }}'
      scheduleTime: '{{ item.scheduleTime }}'
      completionTime: '{{ item.completionTime }}'
- discovery_id: aws.iotanalytics.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tags }}'
    item:
      key: '{{ item.key }}'
      value: '{{ item.value }}'
checks: []
