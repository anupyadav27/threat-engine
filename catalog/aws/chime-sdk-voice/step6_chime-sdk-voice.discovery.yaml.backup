version: '1.0'
provider: aws
service: chime-sdk-voice
services:
  client: chime-sdk-voice
  module: boto3.client
discovery:
- discovery_id: aws.chime-sdk-voice.getGlobalSettings
  calls:
  - action: getGlobalSettings
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.VoiceConnector }}'
    item:
      CdrBucket: '{{ item.CdrBucket }}'
- discovery_id: aws.chime-sdk-voice.getPhoneNumberSettings
  calls:
  - action: getPhoneNumberSettings
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.CallingName }}'
- discovery_id: aws.chime-sdk-voice.listAvailableVoiceConnectorRegions
  calls:
  - action: listAvailableVoiceConnectorRegions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.VoiceConnectorRegions }}'
- discovery_id: aws.chime-sdk-voice.listPhoneNumberOrders
  calls:
  - action: listPhoneNumberOrders
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.PhoneNumberOrders }}'
    item:
      PhoneNumberOrderId: '{{ item.PhoneNumberOrderId }}'
      ProductType: '{{ item.ProductType }}'
      Status: '{{ item.Status }}'
      OrderType: '{{ item.OrderType }}'
      OrderedPhoneNumbers: '{{ item.OrderedPhoneNumbers }}'
      CreatedTimestamp: '{{ item.CreatedTimestamp }}'
      UpdatedTimestamp: '{{ item.UpdatedTimestamp }}'
      FocDate: '{{ item.FocDate }}'
- discovery_id: aws.chime-sdk-voice.listPhoneNumbers
  calls:
  - action: listPhoneNumbers
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.PhoneNumbers }}'
    item:
      PhoneNumberId: '{{ item.PhoneNumberId }}'
      E164PhoneNumber: '{{ item.E164PhoneNumber }}'
      Country: '{{ item.Country }}'
      Type: '{{ item.Type }}'
      ProductType: '{{ item.ProductType }}'
      Status: '{{ item.Status }}'
      Capabilities: '{{ item.Capabilities }}'
      Associations: '{{ item.Associations }}'
      CallingName: '{{ item.CallingName }}'
      CallingNameStatus: '{{ item.CallingNameStatus }}'
      CreatedTimestamp: '{{ item.CreatedTimestamp }}'
      UpdatedTimestamp: '{{ item.UpdatedTimestamp }}'
      DeletionTimestamp: '{{ item.DeletionTimestamp }}'
      OrderId: '{{ item.OrderId }}'
      Name: '{{ item.Name }}'
- discovery_id: aws.chime-sdk-voice.listSipMediaApplications
  calls:
  - action: listSipMediaApplications
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.SipMediaApplications }}'
    item:
      SipMediaApplicationId: '{{ item.SipMediaApplicationId }}'
      AwsRegion: '{{ item.AwsRegion }}'
      Name: '{{ item.Name }}'
      Endpoints: '{{ item.Endpoints }}'
      CreatedTimestamp: '{{ item.CreatedTimestamp }}'
      UpdatedTimestamp: '{{ item.UpdatedTimestamp }}'
      SipMediaApplicationArn: '{{ item.SipMediaApplicationArn }}'
- discovery_id: aws.chime-sdk-voice.listSipRules
  calls:
  - action: listSipRules
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.SipRules }}'
    item:
      SipRuleId: '{{ item.SipRuleId }}'
      Name: '{{ item.Name }}'
      Disabled: '{{ item.Disabled }}'
      TriggerType: '{{ item.TriggerType }}'
      TriggerValue: '{{ item.TriggerValue }}'
      TargetApplications: '{{ item.TargetApplications }}'
      CreatedTimestamp: '{{ item.CreatedTimestamp }}'
      UpdatedTimestamp: '{{ item.UpdatedTimestamp }}'
- discovery_id: aws.chime-sdk-voice.listVoiceConnectorGroups
  calls:
  - action: listVoiceConnectorGroups
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.VoiceConnectorGroups }}'
    item:
      VoiceConnectorGroupId: '{{ item.VoiceConnectorGroupId }}'
      Name: '{{ item.Name }}'
      VoiceConnectorItems: '{{ item.VoiceConnectorItems }}'
      CreatedTimestamp: '{{ item.CreatedTimestamp }}'
      UpdatedTimestamp: '{{ item.UpdatedTimestamp }}'
      VoiceConnectorGroupArn: '{{ item.VoiceConnectorGroupArn }}'
- discovery_id: aws.chime-sdk-voice.listVoiceConnectors
  calls:
  - action: listVoiceConnectors
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.VoiceConnectors }}'
    item:
      VoiceConnectorId: '{{ item.VoiceConnectorId }}'
      AwsRegion: '{{ item.AwsRegion }}'
      Name: '{{ item.Name }}'
      OutboundHostName: '{{ item.OutboundHostName }}'
      RequireEncryption: '{{ item.RequireEncryption }}'
      CreatedTimestamp: '{{ item.CreatedTimestamp }}'
      UpdatedTimestamp: '{{ item.UpdatedTimestamp }}'
      VoiceConnectorArn: '{{ item.VoiceConnectorArn }}'
      IntegrationType: '{{ item.IntegrationType }}'
      NetworkType: '{{ item.NetworkType }}'
- discovery_id: aws.chime-sdk-voice.listVoiceProfileDomains
  calls:
  - action: listVoiceProfileDomains
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.VoiceProfileDomains }}'
    item:
      VoiceProfileDomainId: '{{ item.VoiceProfileDomainId }}'
      VoiceProfileDomainArn: '{{ item.VoiceProfileDomainArn }}'
      Name: '{{ item.Name }}'
      Description: '{{ item.Description }}'
      CreatedTimestamp: '{{ item.CreatedTimestamp }}'
      UpdatedTimestamp: '{{ item.UpdatedTimestamp }}'
- discovery_id: aws.chime-sdk-voice.searchAvailablePhoneNumbers
  calls:
  - action: searchAvailablePhoneNumbers
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.E164PhoneNumbers }}'
- discovery_id: aws.chime-sdk-voice.getPhoneNumber
  calls:
  - action: getPhoneNumber
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.PhoneNumber }}'
    item:
      PhoneNumberId: '{{ item.PhoneNumberId }}'
      E164PhoneNumber: '{{ item.E164PhoneNumber }}'
      Country: '{{ item.Country }}'
      Type: '{{ item.Type }}'
      ProductType: '{{ item.ProductType }}'
      Status: '{{ item.Status }}'
      Capabilities: '{{ item.Capabilities }}'
      Associations: '{{ item.Associations }}'
      CallingName: '{{ item.CallingName }}'
      CallingNameStatus: '{{ item.CallingNameStatus }}'
      CreatedTimestamp: '{{ item.CreatedTimestamp }}'
      UpdatedTimestamp: '{{ item.UpdatedTimestamp }}'
      DeletionTimestamp: '{{ item.DeletionTimestamp }}'
      OrderId: '{{ item.OrderId }}'
      Name: '{{ item.Name }}'
- discovery_id: aws.chime-sdk-voice.getPhoneNumberOrder
  calls:
  - action: getPhoneNumberOrder
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.PhoneNumberOrder }}'
    item:
      PhoneNumberOrderId: '{{ item.PhoneNumberOrderId }}'
      ProductType: '{{ item.ProductType }}'
      Status: '{{ item.Status }}'
      OrderType: '{{ item.OrderType }}'
      OrderedPhoneNumbers: '{{ item.OrderedPhoneNumbers }}'
      CreatedTimestamp: '{{ item.CreatedTimestamp }}'
      UpdatedTimestamp: '{{ item.UpdatedTimestamp }}'
      FocDate: '{{ item.FocDate }}'
- discovery_id: aws.chime-sdk-voice.getProxySession
  calls:
  - action: getProxySession
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ProxySession }}'
    item:
      VoiceConnectorId: '{{ item.VoiceConnectorId }}'
      ProxySessionId: '{{ item.ProxySessionId }}'
      Name: '{{ item.Name }}'
      Status: '{{ item.Status }}'
      ExpiryMinutes: '{{ item.ExpiryMinutes }}'
      Capabilities: '{{ item.Capabilities }}'
      CreatedTimestamp: '{{ item.CreatedTimestamp }}'
      UpdatedTimestamp: '{{ item.UpdatedTimestamp }}'
      EndedTimestamp: '{{ item.EndedTimestamp }}'
      Participants: '{{ item.Participants }}'
      NumberSelectionBehavior: '{{ item.NumberSelectionBehavior }}'
      GeoMatchLevel: '{{ item.GeoMatchLevel }}'
      GeoMatchParams: '{{ item.GeoMatchParams }}'
- discovery_id: aws.chime-sdk-voice.getSipMediaApplication
  calls:
  - action: getSipMediaApplication
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.SipMediaApplication }}'
    item:
      SipMediaApplicationId: '{{ item.SipMediaApplicationId }}'
      AwsRegion: '{{ item.AwsRegion }}'
      Name: '{{ item.Name }}'
      Endpoints: '{{ item.Endpoints }}'
      CreatedTimestamp: '{{ item.CreatedTimestamp }}'
      UpdatedTimestamp: '{{ item.UpdatedTimestamp }}'
      SipMediaApplicationArn: '{{ item.SipMediaApplicationArn }}'
- discovery_id: aws.chime-sdk-voice.getSipMediaApplicationAlexaSkillConfiguration
  calls:
  - action: getSipMediaApplicationAlexaSkillConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.SipMediaApplicationAlexaSkillConfiguration }}'
    item:
      AlexaSkillStatus: '{{ item.AlexaSkillStatus }}'
      AlexaSkillIds: '{{ item.AlexaSkillIds }}'
- discovery_id: aws.chime-sdk-voice.getSipMediaApplicationLoggingConfiguration
  calls:
  - action: getSipMediaApplicationLoggingConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.SipMediaApplicationLoggingConfiguration }}'
    item:
      EnableSipMediaApplicationMessageLogs: '{{ item.EnableSipMediaApplicationMessageLogs
        }}'
- discovery_id: aws.chime-sdk-voice.getSipRule
  calls:
  - action: getSipRule
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.SipRule }}'
    item:
      SipRuleId: '{{ item.SipRuleId }}'
      Name: '{{ item.Name }}'
      Disabled: '{{ item.Disabled }}'
      TriggerType: '{{ item.TriggerType }}'
      TriggerValue: '{{ item.TriggerValue }}'
      TargetApplications: '{{ item.TargetApplications }}'
      CreatedTimestamp: '{{ item.CreatedTimestamp }}'
      UpdatedTimestamp: '{{ item.UpdatedTimestamp }}'
- discovery_id: aws.chime-sdk-voice.getSpeakerSearchTask
  calls:
  - action: getSpeakerSearchTask
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.SpeakerSearchTask }}'
    item:
      SpeakerSearchTaskId: '{{ item.SpeakerSearchTaskId }}'
      SpeakerSearchTaskStatus: '{{ item.SpeakerSearchTaskStatus }}'
      CallDetails: '{{ item.CallDetails }}'
      SpeakerSearchDetails: '{{ item.SpeakerSearchDetails }}'
      CreatedTimestamp: '{{ item.CreatedTimestamp }}'
      UpdatedTimestamp: '{{ item.UpdatedTimestamp }}'
      StartedTimestamp: '{{ item.StartedTimestamp }}'
      StatusMessage: '{{ item.StatusMessage }}'
- discovery_id: aws.chime-sdk-voice.getVoiceConnector
  calls:
  - action: getVoiceConnector
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.VoiceConnector }}'
    item:
      VoiceConnectorId: '{{ item.VoiceConnectorId }}'
      AwsRegion: '{{ item.AwsRegion }}'
      Name: '{{ item.Name }}'
      OutboundHostName: '{{ item.OutboundHostName }}'
      RequireEncryption: '{{ item.RequireEncryption }}'
      CreatedTimestamp: '{{ item.CreatedTimestamp }}'
      UpdatedTimestamp: '{{ item.UpdatedTimestamp }}'
      VoiceConnectorArn: '{{ item.VoiceConnectorArn }}'
      IntegrationType: '{{ item.IntegrationType }}'
      NetworkType: '{{ item.NetworkType }}'
- discovery_id: aws.chime-sdk-voice.getVoiceConnectorEmergencyCallingConfiguration
  calls:
  - action: getVoiceConnectorEmergencyCallingConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.EmergencyCallingConfiguration }}'
    item:
      DNIS: '{{ item.DNIS }}'
- discovery_id: aws.chime-sdk-voice.getVoiceConnectorExternalSystemsConfiguration
  calls:
  - action: getVoiceConnectorExternalSystemsConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ExternalSystemsConfiguration }}'
    item:
      SessionBorderControllerTypes: '{{ item.SessionBorderControllerTypes }}'
      ContactCenterSystemTypes: '{{ item.ContactCenterSystemTypes }}'
- discovery_id: aws.chime-sdk-voice.getVoiceConnectorGroup
  calls:
  - action: getVoiceConnectorGroup
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.VoiceConnectorGroup }}'
    item:
      VoiceConnectorGroupId: '{{ item.VoiceConnectorGroupId }}'
      Name: '{{ item.Name }}'
      VoiceConnectorItems: '{{ item.VoiceConnectorItems }}'
      CreatedTimestamp: '{{ item.CreatedTimestamp }}'
      UpdatedTimestamp: '{{ item.UpdatedTimestamp }}'
      VoiceConnectorGroupArn: '{{ item.VoiceConnectorGroupArn }}'
- discovery_id: aws.chime-sdk-voice.getVoiceConnectorLoggingConfiguration
  calls:
  - action: getVoiceConnectorLoggingConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.LoggingConfiguration }}'
    item:
      EnableSIPLogs: '{{ item.EnableSIPLogs }}'
      EnableMediaMetricLogs: '{{ item.EnableMediaMetricLogs }}'
- discovery_id: aws.chime-sdk-voice.getVoiceConnectorOrigination
  calls:
  - action: getVoiceConnectorOrigination
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Origination }}'
    item:
      Routes: '{{ item.Routes }}'
      Disabled: '{{ item.Disabled }}'
- discovery_id: aws.chime-sdk-voice.getVoiceConnectorProxy
  calls:
  - action: getVoiceConnectorProxy
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Proxy }}'
    item:
      DefaultSessionExpiryMinutes: '{{ item.DefaultSessionExpiryMinutes }}'
      Disabled: '{{ item.Disabled }}'
      FallBackPhoneNumber: '{{ item.FallBackPhoneNumber }}'
      PhoneNumberCountries: '{{ item.PhoneNumberCountries }}'
- discovery_id: aws.chime-sdk-voice.getVoiceConnectorStreamingConfiguration
  calls:
  - action: getVoiceConnectorStreamingConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.StreamingConfiguration }}'
    item:
      DataRetentionInHours: '{{ item.DataRetentionInHours }}'
      Disabled: '{{ item.Disabled }}'
      StreamingNotificationTargets: '{{ item.StreamingNotificationTargets }}'
      MediaInsightsConfiguration: '{{ item.MediaInsightsConfiguration }}'
- discovery_id: aws.chime-sdk-voice.getVoiceConnectorTermination
  calls:
  - action: getVoiceConnectorTermination
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Termination }}'
    item:
      CpsLimit: '{{ item.CpsLimit }}'
      DefaultPhoneNumber: '{{ item.DefaultPhoneNumber }}'
      CallingRegions: '{{ item.CallingRegions }}'
      CidrAllowedList: '{{ item.CidrAllowedList }}'
      Disabled: '{{ item.Disabled }}'
- discovery_id: aws.chime-sdk-voice.getVoiceConnectorTerminationHealth
  calls:
  - action: getVoiceConnectorTerminationHealth
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.TerminationHealth }}'
    item:
      Timestamp: '{{ item.Timestamp }}'
      Source: '{{ item.Source }}'
- discovery_id: aws.chime-sdk-voice.getVoiceProfile
  calls:
  - action: getVoiceProfile
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.VoiceProfile }}'
    item:
      VoiceProfileId: '{{ item.VoiceProfileId }}'
      VoiceProfileArn: '{{ item.VoiceProfileArn }}'
      VoiceProfileDomainId: '{{ item.VoiceProfileDomainId }}'
      CreatedTimestamp: '{{ item.CreatedTimestamp }}'
      UpdatedTimestamp: '{{ item.UpdatedTimestamp }}'
      ExpirationTimestamp: '{{ item.ExpirationTimestamp }}'
- discovery_id: aws.chime-sdk-voice.getVoiceProfileDomain
  calls:
  - action: getVoiceProfileDomain
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.VoiceProfileDomain }}'
    item:
      VoiceProfileDomainId: '{{ item.VoiceProfileDomainId }}'
      VoiceProfileDomainArn: '{{ item.VoiceProfileDomainArn }}'
      Name: '{{ item.Name }}'
      Description: '{{ item.Description }}'
      ServerSideEncryptionConfiguration: '{{ item.ServerSideEncryptionConfiguration
        }}'
      CreatedTimestamp: '{{ item.CreatedTimestamp }}'
      UpdatedTimestamp: '{{ item.UpdatedTimestamp }}'
- discovery_id: aws.chime-sdk-voice.getVoiceToneAnalysisTask
  calls:
  - action: getVoiceToneAnalysisTask
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.VoiceToneAnalysisTask }}'
    item:
      VoiceToneAnalysisTaskId: '{{ item.VoiceToneAnalysisTaskId }}'
      VoiceToneAnalysisTaskStatus: '{{ item.VoiceToneAnalysisTaskStatus }}'
      CallDetails: '{{ item.CallDetails }}'
      CreatedTimestamp: '{{ item.CreatedTimestamp }}'
      UpdatedTimestamp: '{{ item.UpdatedTimestamp }}'
      StartedTimestamp: '{{ item.StartedTimestamp }}'
      StatusMessage: '{{ item.StatusMessage }}'
- discovery_id: aws.chime-sdk-voice.listProxySessions
  calls:
  - action: listProxySessions
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.ProxySessions }}'
    item:
      VoiceConnectorId: '{{ item.VoiceConnectorId }}'
      ProxySessionId: '{{ item.ProxySessionId }}'
      Name: '{{ item.Name }}'
      Status: '{{ item.Status }}'
      ExpiryMinutes: '{{ item.ExpiryMinutes }}'
      Capabilities: '{{ item.Capabilities }}'
      CreatedTimestamp: '{{ item.CreatedTimestamp }}'
      UpdatedTimestamp: '{{ item.UpdatedTimestamp }}'
      EndedTimestamp: '{{ item.EndedTimestamp }}'
      Participants: '{{ item.Participants }}'
      NumberSelectionBehavior: '{{ item.NumberSelectionBehavior }}'
      GeoMatchLevel: '{{ item.GeoMatchLevel }}'
      GeoMatchParams: '{{ item.GeoMatchParams }}'
- discovery_id: aws.chime-sdk-voice.listSupportedPhoneNumberCountries
  calls:
  - action: listSupportedPhoneNumberCountries
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.PhoneNumberCountries }}'
    item:
      CountryCode: '{{ item.CountryCode }}'
      SupportedPhoneNumberTypes: '{{ item.SupportedPhoneNumberTypes }}'
- discovery_id: aws.chime-sdk-voice.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Tags }}'
    item:
      Key: '{{ item.Key }}'
      Value: '{{ item.Value }}'
- discovery_id: aws.chime-sdk-voice.listVoiceConnectorTerminationCredentials
  calls:
  - action: listVoiceConnectorTerminationCredentials
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Usernames }}'
- discovery_id: aws.chime-sdk-voice.listVoiceProfiles
  calls:
  - action: listVoiceProfiles
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.VoiceProfiles }}'
    item:
      VoiceProfileId: '{{ item.VoiceProfileId }}'
      VoiceProfileArn: '{{ item.VoiceProfileArn }}'
      VoiceProfileDomainId: '{{ item.VoiceProfileDomainId }}'
      CreatedTimestamp: '{{ item.CreatedTimestamp }}'
      UpdatedTimestamp: '{{ item.UpdatedTimestamp }}'
      ExpirationTimestamp: '{{ item.ExpirationTimestamp }}'
checks: []
