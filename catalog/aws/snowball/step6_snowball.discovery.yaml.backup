version: '1.0'
provider: aws
service: snowball
services:
  client: snowball
  module: boto3.client
discovery:
- discovery_id: aws.snowball.describeAddresses
  calls:
  - action: describeAddresses
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Addresses }}'
    item:
      AddressId: '{{ item.AddressId }}'
      Name: '{{ item.Name }}'
      Company: '{{ item.Company }}'
      Street1: '{{ item.Street1 }}'
      Street2: '{{ item.Street2 }}'
      Street3: '{{ item.Street3 }}'
      City: '{{ item.City }}'
      StateOrProvince: '{{ item.StateOrProvince }}'
      PrefectureOrDistrict: '{{ item.PrefectureOrDistrict }}'
      Landmark: '{{ item.Landmark }}'
      Country: '{{ item.Country }}'
      PostalCode: '{{ item.PostalCode }}'
      PhoneNumber: '{{ item.PhoneNumber }}'
      IsRestricted: '{{ item.IsRestricted }}'
      Type: '{{ item.Type }}'
- discovery_id: aws.snowball.getSnowballUsage
  calls:
  - action: getSnowballUsage
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.SnowballLimit }}'
- discovery_id: aws.snowball.listClusters
  calls:
  - action: listClusters
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.ClusterListEntries }}'
    item:
      ClusterId: '{{ item.ClusterId }}'
      ClusterState: '{{ item.ClusterState }}'
      CreationDate: '{{ item.CreationDate }}'
      Description: '{{ item.Description }}'
- discovery_id: aws.snowball.listCompatibleImages
  calls:
  - action: listCompatibleImages
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.CompatibleImages }}'
    item:
      AmiId: '{{ item.AmiId }}'
      Name: '{{ item.Name }}'
- discovery_id: aws.snowball.listJobs
  calls:
  - action: listJobs
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.JobListEntries }}'
    item:
      JobId: '{{ item.JobId }}'
      JobState: '{{ item.JobState }}'
      IsMaster: '{{ item.IsMaster }}'
      JobType: '{{ item.JobType }}'
      SnowballType: '{{ item.SnowballType }}'
      CreationDate: '{{ item.CreationDate }}'
      Description: '{{ item.Description }}'
- discovery_id: aws.snowball.listLongTermPricing
  calls:
  - action: listLongTermPricing
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.LongTermPricingEntries }}'
    item:
      LongTermPricingId: '{{ item.LongTermPricingId }}'
      LongTermPricingEndDate: '{{ item.LongTermPricingEndDate }}'
      LongTermPricingStartDate: '{{ item.LongTermPricingStartDate }}'
      LongTermPricingType: '{{ item.LongTermPricingType }}'
      CurrentActiveJob: '{{ item.CurrentActiveJob }}'
      ReplacementJob: '{{ item.ReplacementJob }}'
      IsLongTermPricingAutoRenew: '{{ item.IsLongTermPricingAutoRenew }}'
      LongTermPricingStatus: '{{ item.LongTermPricingStatus }}'
      SnowballType: '{{ item.SnowballType }}'
      JobIds: '{{ item.JobIds }}'
- discovery_id: aws.snowball.listPickupLocations
  calls:
  - action: listPickupLocations
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Addresses }}'
    item:
      AddressId: '{{ item.AddressId }}'
      Name: '{{ item.Name }}'
      Company: '{{ item.Company }}'
      Street1: '{{ item.Street1 }}'
      Street2: '{{ item.Street2 }}'
      Street3: '{{ item.Street3 }}'
      City: '{{ item.City }}'
      StateOrProvince: '{{ item.StateOrProvince }}'
      PrefectureOrDistrict: '{{ item.PrefectureOrDistrict }}'
      Landmark: '{{ item.Landmark }}'
      Country: '{{ item.Country }}'
      PostalCode: '{{ item.PostalCode }}'
      PhoneNumber: '{{ item.PhoneNumber }}'
      IsRestricted: '{{ item.IsRestricted }}'
      Type: '{{ item.Type }}'
- discovery_id: aws.snowball.describeAddress
  calls:
  - action: describeAddress
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Address }}'
    item:
      AddressId: '{{ item.AddressId }}'
      Name: '{{ item.Name }}'
      Company: '{{ item.Company }}'
      Street1: '{{ item.Street1 }}'
      Street2: '{{ item.Street2 }}'
      Street3: '{{ item.Street3 }}'
      City: '{{ item.City }}'
      StateOrProvince: '{{ item.StateOrProvince }}'
      PrefectureOrDistrict: '{{ item.PrefectureOrDistrict }}'
      Landmark: '{{ item.Landmark }}'
      Country: '{{ item.Country }}'
      PostalCode: '{{ item.PostalCode }}'
      PhoneNumber: '{{ item.PhoneNumber }}'
      IsRestricted: '{{ item.IsRestricted }}'
      Type: '{{ item.Type }}'
- discovery_id: aws.snowball.describeCluster
  calls:
  - action: describeCluster
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ClusterMetadata }}'
    item:
      ClusterId: '{{ item.ClusterId }}'
      Description: '{{ item.Description }}'
      KmsKeyARN: '{{ item.KmsKeyARN }}'
      RoleARN: '{{ item.RoleARN }}'
      ClusterState: '{{ item.ClusterState }}'
      JobType: '{{ item.JobType }}'
      SnowballType: '{{ item.SnowballType }}'
      CreationDate: '{{ item.CreationDate }}'
      Resources: '{{ item.Resources }}'
      AddressId: '{{ item.AddressId }}'
      ShippingOption: '{{ item.ShippingOption }}'
      Notification: '{{ item.Notification }}'
      ForwardingAddressId: '{{ item.ForwardingAddressId }}'
      TaxDocuments: '{{ item.TaxDocuments }}'
      OnDeviceServiceConfiguration: '{{ item.OnDeviceServiceConfiguration }}'
- discovery_id: aws.snowball.describeJob
  calls:
  - action: describeJob
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.SubJobMetadata }}'
    item:
      JobId: '{{ item.JobId }}'
      JobState: '{{ item.JobState }}'
      JobType: '{{ item.JobType }}'
      SnowballType: '{{ item.SnowballType }}'
      CreationDate: '{{ item.CreationDate }}'
      Resources: '{{ item.Resources }}'
      Description: '{{ item.Description }}'
      KmsKeyARN: '{{ item.KmsKeyARN }}'
      RoleARN: '{{ item.RoleARN }}'
      AddressId: '{{ item.AddressId }}'
      ShippingDetails: '{{ item.ShippingDetails }}'
      SnowballCapacityPreference: '{{ item.SnowballCapacityPreference }}'
      Notification: '{{ item.Notification }}'
      DataTransferProgress: '{{ item.DataTransferProgress }}'
      JobLogInfo: '{{ item.JobLogInfo }}'
      ClusterId: '{{ item.ClusterId }}'
      ForwardingAddressId: '{{ item.ForwardingAddressId }}'
      TaxDocuments: '{{ item.TaxDocuments }}'
      DeviceConfiguration: '{{ item.DeviceConfiguration }}'
      RemoteManagement: '{{ item.RemoteManagement }}'
      LongTermPricingId: '{{ item.LongTermPricingId }}'
      OnDeviceServiceConfiguration: '{{ item.OnDeviceServiceConfiguration }}'
      ImpactLevel: '{{ item.ImpactLevel }}'
      PickupDetails: '{{ item.PickupDetails }}'
      SnowballId: '{{ item.SnowballId }}'
- discovery_id: aws.snowball.describeReturnShippingLabel
  calls:
  - action: describeReturnShippingLabel
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Status }}'
- discovery_id: aws.snowball.getJobManifest
  calls:
  - action: getJobManifest
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ManifestURI }}'
- discovery_id: aws.snowball.getJobUnlockCode
  calls:
  - action: getJobUnlockCode
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.UnlockCode }}'
- discovery_id: aws.snowball.getSoftwareUpdates
  calls:
  - action: getSoftwareUpdates
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.UpdatesURI }}'
- discovery_id: aws.snowball.listClusterJobs
  calls:
  - action: listClusterJobs
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.JobListEntries }}'
    item:
      JobId: '{{ item.JobId }}'
      JobState: '{{ item.JobState }}'
      IsMaster: '{{ item.IsMaster }}'
      JobType: '{{ item.JobType }}'
      SnowballType: '{{ item.SnowballType }}'
      CreationDate: '{{ item.CreationDate }}'
      Description: '{{ item.Description }}'
- discovery_id: aws.snowball.listServiceVersions
  calls:
  - action: listServiceVersions
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.ServiceVersions }}'
    item:
      Version: '{{ item.Version }}'
checks: []
