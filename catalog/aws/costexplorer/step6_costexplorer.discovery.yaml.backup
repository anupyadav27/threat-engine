version: '1.0'
provider: aws
service: costexplorer
services:
  client: costexplorer
  module: boto3.client
discovery:
- discovery_id: aws.costexplorer.getAnomalyMonitors
  calls:
  - action: getAnomalyMonitors
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AnomalyMonitors }}'
    item:
      MonitorArn: '{{ item.MonitorArn }}'
      MonitorName: '{{ item.MonitorName }}'
      CreationDate: '{{ item.CreationDate }}'
      LastUpdatedDate: '{{ item.LastUpdatedDate }}'
      LastEvaluatedDate: '{{ item.LastEvaluatedDate }}'
      MonitorType: '{{ item.MonitorType }}'
      MonitorDimension: '{{ item.MonitorDimension }}'
      MonitorSpecification: '{{ item.MonitorSpecification }}'
      DimensionalValueCount: '{{ item.DimensionalValueCount }}'
- discovery_id: aws.costexplorer.getAnomalySubscriptions
  calls:
  - action: getAnomalySubscriptions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AnomalySubscriptions }}'
    item:
      SubscriptionArn: '{{ item.SubscriptionArn }}'
      AccountId: '{{ item.AccountId }}'
      MonitorArnList: '{{ item.MonitorArnList }}'
      Subscribers: '{{ item.Subscribers }}'
      Threshold: '{{ item.Threshold }}'
      Frequency: '{{ item.Frequency }}'
      SubscriptionName: '{{ item.SubscriptionName }}'
      ThresholdExpression: '{{ item.ThresholdExpression }}'
- discovery_id: aws.costexplorer.listCommitmentPurchaseAnalyses
  calls:
  - action: listCommitmentPurchaseAnalyses
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AnalysisSummaryList }}'
    item:
      EstimatedCompletionTime: '{{ item.EstimatedCompletionTime }}'
      AnalysisCompletionTime: '{{ item.AnalysisCompletionTime }}'
      AnalysisStartedTime: '{{ item.AnalysisStartedTime }}'
      AnalysisStatus: '{{ item.AnalysisStatus }}'
      ErrorCode: '{{ item.ErrorCode }}'
      AnalysisId: '{{ item.AnalysisId }}'
      CommitmentPurchaseAnalysisConfiguration: '{{ item.CommitmentPurchaseAnalysisConfiguration
        }}'
- discovery_id: aws.costexplorer.listCostAllocationTagBackfillHistory
  calls:
  - action: listCostAllocationTagBackfillHistory
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.BackfillRequests }}'
    item:
      BackfillFrom: '{{ item.BackfillFrom }}'
      RequestedAt: '{{ item.RequestedAt }}'
      CompletedAt: '{{ item.CompletedAt }}'
      BackfillStatus: '{{ item.BackfillStatus }}'
      LastUpdatedAt: '{{ item.LastUpdatedAt }}'
- discovery_id: aws.costexplorer.listCostAllocationTags
  calls:
  - action: listCostAllocationTags
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.CostAllocationTags }}'
    item:
      TagKey: '{{ item.TagKey }}'
      Type: '{{ item.Type }}'
      Status: '{{ item.Status }}'
      LastUpdatedDate: '{{ item.LastUpdatedDate }}'
      LastUsedDate: '{{ item.LastUsedDate }}'
- discovery_id: aws.costexplorer.listCostCategoryDefinitions
  calls:
  - action: listCostCategoryDefinitions
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.CostCategoryReferences }}'
    item:
      CostCategoryArn: '{{ item.CostCategoryArn }}'
      Name: '{{ item.Name }}'
      EffectiveStart: '{{ item.EffectiveStart }}'
      EffectiveEnd: '{{ item.EffectiveEnd }}'
      NumberOfRules: '{{ item.NumberOfRules }}'
      ProcessingStatus: '{{ item.ProcessingStatus }}'
      Values: '{{ item.Values }}'
      DefaultValue: '{{ item.DefaultValue }}'
- discovery_id: aws.costexplorer.listSavingsPlansPurchaseRecommendationGeneration
  calls:
  - action: listSavingsPlansPurchaseRecommendationGeneration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.GenerationSummaryList }}'
    item:
      RecommendationId: '{{ item.RecommendationId }}'
      GenerationStatus: '{{ item.GenerationStatus }}'
      GenerationStartedTime: '{{ item.GenerationStartedTime }}'
      GenerationCompletionTime: '{{ item.GenerationCompletionTime }}'
      EstimatedCompletionTime: '{{ item.EstimatedCompletionTime }}'
- discovery_id: aws.costexplorer.describeCostCategoryDefinition
  calls:
  - action: describeCostCategoryDefinition
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.CostCategory }}'
    item:
      CostCategoryArn: '{{ item.CostCategoryArn }}'
      EffectiveStart: '{{ item.EffectiveStart }}'
      EffectiveEnd: '{{ item.EffectiveEnd }}'
      Name: '{{ item.Name }}'
      RuleVersion: '{{ item.RuleVersion }}'
      Rules: '{{ item.Rules }}'
      SplitChargeRules: '{{ item.SplitChargeRules }}'
      ProcessingStatus: '{{ item.ProcessingStatus }}'
      DefaultValue: '{{ item.DefaultValue }}'
- discovery_id: aws.costexplorer.getAnomalies
  calls:
  - action: getAnomalies
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Anomalies }}'
    item:
      AnomalyId: '{{ item.AnomalyId }}'
      AnomalyStartDate: '{{ item.AnomalyStartDate }}'
      AnomalyEndDate: '{{ item.AnomalyEndDate }}'
      DimensionValue: '{{ item.DimensionValue }}'
      RootCauses: '{{ item.RootCauses }}'
      AnomalyScore: '{{ item.AnomalyScore }}'
      Impact: '{{ item.Impact }}'
      MonitorArn: '{{ item.MonitorArn }}'
      Feedback: '{{ item.Feedback }}'
- discovery_id: aws.costexplorer.getApproximateUsageRecords
  calls:
  - action: getApproximateUsageRecords
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.LookbackPeriod }}'
    item:
      Start: '{{ item.Start }}'
      End: '{{ item.End }}'
- discovery_id: aws.costexplorer.getCommitmentPurchaseAnalysis
  calls:
  - action: getCommitmentPurchaseAnalysis
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AnalysisDetails }}'
    item:
      SavingsPlansPurchaseAnalysisDetails: '{{ item.SavingsPlansPurchaseAnalysisDetails
        }}'
- discovery_id: aws.costexplorer.getCostAndUsage
  calls:
  - action: getCostAndUsage
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.GroupDefinitions }}'
    item:
      Type: '{{ item.Type }}'
      Key: '{{ item.Key }}'
- discovery_id: aws.costexplorer.getCostAndUsageComparisons
  calls:
  - action: getCostAndUsageComparisons
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.CostAndUsageComparisons }}'
    item:
      CostAndUsageSelector: '{{ item.CostAndUsageSelector }}'
      Metrics: '{{ item.Metrics }}'
- discovery_id: aws.costexplorer.getCostAndUsageWithResources
  calls:
  - action: getCostAndUsageWithResources
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.GroupDefinitions }}'
    item:
      Type: '{{ item.Type }}'
      Key: '{{ item.Key }}'
- discovery_id: aws.costexplorer.getCostCategories
  calls:
  - action: getCostCategories
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.CostCategoryNames }}'
- discovery_id: aws.costexplorer.getCostComparisonDrivers
  calls:
  - action: getCostComparisonDrivers
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.CostComparisonDrivers }}'
    item:
      CostSelector: '{{ item.CostSelector }}'
      Metrics: '{{ item.Metrics }}'
      CostDrivers: '{{ item.CostDrivers }}'
- discovery_id: aws.costexplorer.getCostForecast
  calls:
  - action: getCostForecast
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ForecastResultsByTime }}'
    item:
      TimePeriod: '{{ item.TimePeriod }}'
      MeanValue: '{{ item.MeanValue }}'
      PredictionIntervalLowerBound: '{{ item.PredictionIntervalLowerBound }}'
      PredictionIntervalUpperBound: '{{ item.PredictionIntervalUpperBound }}'
- discovery_id: aws.costexplorer.getDimensionValues
  calls:
  - action: getDimensionValues
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.DimensionValues }}'
    item:
      Value: '{{ item.Value }}'
      Attributes: '{{ item.Attributes }}'
- discovery_id: aws.costexplorer.getReservationCoverage
  calls:
  - action: getReservationCoverage
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.CoveragesByTime }}'
    item:
      TimePeriod: '{{ item.TimePeriod }}'
      Groups: '{{ item.Groups }}'
      Total: '{{ item.Total }}'
- discovery_id: aws.costexplorer.getReservationPurchaseRecommendation
  calls:
  - action: getReservationPurchaseRecommendation
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Recommendations }}'
    item:
      AccountScope: '{{ item.AccountScope }}'
      LookbackPeriodInDays: '{{ item.LookbackPeriodInDays }}'
      TermInYears: '{{ item.TermInYears }}'
      PaymentOption: '{{ item.PaymentOption }}'
      ServiceSpecification: '{{ item.ServiceSpecification }}'
      RecommendationDetails: '{{ item.RecommendationDetails }}'
      RecommendationSummary: '{{ item.RecommendationSummary }}'
- discovery_id: aws.costexplorer.getReservationUtilization
  calls:
  - action: getReservationUtilization
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.UtilizationsByTime }}'
    item:
      TimePeriod: '{{ item.TimePeriod }}'
      Groups: '{{ item.Groups }}'
      Total: '{{ item.Total }}'
- discovery_id: aws.costexplorer.getRightsizingRecommendation
  calls:
  - action: getRightsizingRecommendation
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.RightsizingRecommendations }}'
    item:
      AccountId: '{{ item.AccountId }}'
      CurrentInstance: '{{ item.CurrentInstance }}'
      RightsizingType: '{{ item.RightsizingType }}'
      ModifyRecommendationDetail: '{{ item.ModifyRecommendationDetail }}'
      TerminateRecommendationDetail: '{{ item.TerminateRecommendationDetail }}'
      FindingReasonCodes: '{{ item.FindingReasonCodes }}'
- discovery_id: aws.costexplorer.getSavingsPlanPurchaseRecommendationDetails
  calls:
  - action: getSavingsPlanPurchaseRecommendationDetails
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.RecommendationDetailData }}'
    item:
      AccountScope: '{{ item.AccountScope }}'
      LookbackPeriodInDays: '{{ item.LookbackPeriodInDays }}'
      SavingsPlansType: '{{ item.SavingsPlansType }}'
      TermInYears: '{{ item.TermInYears }}'
      PaymentOption: '{{ item.PaymentOption }}'
      AccountId: '{{ item.AccountId }}'
      CurrencyCode: '{{ item.CurrencyCode }}'
      InstanceFamily: '{{ item.InstanceFamily }}'
      Region: '{{ item.Region }}'
      OfferingId: '{{ item.OfferingId }}'
      GenerationTimestamp: '{{ item.GenerationTimestamp }}'
      LatestUsageTimestamp: '{{ item.LatestUsageTimestamp }}'
      CurrentAverageHourlyOnDemandSpend: '{{ item.CurrentAverageHourlyOnDemandSpend
        }}'
      CurrentMaximumHourlyOnDemandSpend: '{{ item.CurrentMaximumHourlyOnDemandSpend
        }}'
      CurrentMinimumHourlyOnDemandSpend: '{{ item.CurrentMinimumHourlyOnDemandSpend
        }}'
      EstimatedAverageUtilization: '{{ item.EstimatedAverageUtilization }}'
      EstimatedMonthlySavingsAmount: '{{ item.EstimatedMonthlySavingsAmount }}'
      EstimatedOnDemandCost: '{{ item.EstimatedOnDemandCost }}'
      EstimatedOnDemandCostWithCurrentCommitment: '{{ item.EstimatedOnDemandCostWithCurrentCommitment
        }}'
      EstimatedROI: '{{ item.EstimatedROI }}'
      EstimatedSPCost: '{{ item.EstimatedSPCost }}'
      EstimatedSavingsAmount: '{{ item.EstimatedSavingsAmount }}'
      EstimatedSavingsPercentage: '{{ item.EstimatedSavingsPercentage }}'
      ExistingHourlyCommitment: '{{ item.ExistingHourlyCommitment }}'
      HourlyCommitmentToPurchase: '{{ item.HourlyCommitmentToPurchase }}'
      UpfrontCost: '{{ item.UpfrontCost }}'
      CurrentAverageCoverage: '{{ item.CurrentAverageCoverage }}'
      EstimatedAverageCoverage: '{{ item.EstimatedAverageCoverage }}'
      MetricsOverLookbackPeriod: '{{ item.MetricsOverLookbackPeriod }}'
- discovery_id: aws.costexplorer.getSavingsPlansCoverage
  calls:
  - action: getSavingsPlansCoverage
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.SavingsPlansCoverages }}'
    item:
      Attributes: '{{ item.Attributes }}'
      Coverage: '{{ item.Coverage }}'
      TimePeriod: '{{ item.TimePeriod }}'
- discovery_id: aws.costexplorer.getSavingsPlansPurchaseRecommendation
  calls:
  - action: getSavingsPlansPurchaseRecommendation
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Metadata }}'
    item:
      RecommendationId: '{{ item.RecommendationId }}'
      GenerationTimestamp: '{{ item.GenerationTimestamp }}'
      AdditionalMetadata: '{{ item.AdditionalMetadata }}'
- discovery_id: aws.costexplorer.getSavingsPlansUtilization
  calls:
  - action: getSavingsPlansUtilization
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.SavingsPlansUtilizationsByTime }}'
    item:
      TimePeriod: '{{ item.TimePeriod }}'
      Utilization: '{{ item.Utilization }}'
      Savings: '{{ item.Savings }}'
      AmortizedCommitment: '{{ item.AmortizedCommitment }}'
- discovery_id: aws.costexplorer.getSavingsPlansUtilizationDetails
  calls:
  - action: getSavingsPlansUtilizationDetails
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.SavingsPlansUtilizationDetails }}'
    item:
      SavingsPlanArn: '{{ item.SavingsPlanArn }}'
      Attributes: '{{ item.Attributes }}'
      Utilization: '{{ item.Utilization }}'
      Savings: '{{ item.Savings }}'
      AmortizedCommitment: '{{ item.AmortizedCommitment }}'
- discovery_id: aws.costexplorer.getTags
  calls:
  - action: getTags
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Tags }}'
- discovery_id: aws.costexplorer.getUsageForecast
  calls:
  - action: getUsageForecast
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ForecastResultsByTime }}'
    item:
      TimePeriod: '{{ item.TimePeriod }}'
      MeanValue: '{{ item.MeanValue }}'
      PredictionIntervalLowerBound: '{{ item.PredictionIntervalLowerBound }}'
      PredictionIntervalUpperBound: '{{ item.PredictionIntervalUpperBound }}'
- discovery_id: aws.costexplorer.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ResourceTags }}'
    item:
      Key: '{{ item.Key }}'
      Value: '{{ item.Value }}'
checks: []
