- discovery_id: aws.bedrock.getModelInvocationJob
  calls:
  - action: getModelInvocationJob
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.inputDataConfig }}'
    item:
      s3InputDataConfig: '{{ item.s3InputDataConfig }}'
- discovery_id: aws.bedrock.getPromptRouter
  calls:
  - action: getPromptRouter
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.models }}'
    item:
      modelArn: '{{ item.modelArn }}'
- discovery_id: aws.bedrock.getProvisionedModelThroughput
  calls:
  - action: getProvisionedModelThroughput
    save_as: response
    on_error: continue
  emit:
