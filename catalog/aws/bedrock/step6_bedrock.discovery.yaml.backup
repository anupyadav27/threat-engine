    items_for: '{{ response.models }}'
    item:
      modelArn: '{{ item.modelArn }}'
- discovery_id: aws.bedrock.getMarketplaceModelEndpoint
  calls:
  - action: getMarketplaceModelEndpoint
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.marketplaceModelEndpoint }}'
    item:
      endpointArn: '{{ item.endpointArn }}'
      modelSourceIdentifier: '{{ item.modelSourceIdentifier }}'
      status: '{{ item.status }}'
      statusMessage: '{{ item.statusMessage }}'
      createdAt: '{{ item.createdAt }}'
      updatedAt: '{{ item.updatedAt }}'
      endpointConfig: '{{ item.endpointConfig }}'
      endpointStatus: '{{ item.endpointStatus }}'
      endpointStatusMessage: '{{ item.endpointStatusMessage }}'
- discovery_id: aws.bedrock.getModelCopyJob
  calls:
  - action: getModelCopyJob
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.targetModelTags }}'
    item:
      key: '{{ item.key }}'
      value: '{{ item.value }}'
- discovery_id: aws.bedrock.getModelCustomizationJob
  calls:
