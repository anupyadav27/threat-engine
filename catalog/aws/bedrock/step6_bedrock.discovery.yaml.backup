- discovery_id: aws.bedrock.listAutomatedReasoningPolicyBuildWorkflows
  calls:
  - action: listAutomatedReasoningPolicyBuildWorkflows
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.automatedReasoningPolicyBuildWorkflowSummaries }}'
    item:
      policyArn: '{{ item.policyArn }}'
      buildWorkflowId: '{{ item.buildWorkflowId }}'
      status: '{{ item.status }}'
      buildWorkflowType: '{{ item.buildWorkflowType }}'
      createdAt: '{{ item.createdAt }}'
      updatedAt: '{{ item.updatedAt }}'
- discovery_id: aws.bedrock.listAutomatedReasoningPolicyTestCases
  calls:
  - action: listAutomatedReasoningPolicyTestCases
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.testCases }}'
    item:
      testCaseId: '{{ item.testCaseId }}'
      guardContent: '{{ item.guardContent }}'
      queryContent: '{{ item.queryContent }}'
      expectedAggregatedFindingsResult: '{{ item.expectedAggregatedFindingsResult
        }}'
      createdAt: '{{ item.createdAt }}'
      updatedAt: '{{ item.updatedAt }}'
      confidenceThreshold: '{{ item.confidenceThreshold }}'
- discovery_id: aws.bedrock.listAutomatedReasoningPolicyTestResults
  calls:
  - action: listAutomatedReasoningPolicyTestResults
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.testResults }}'
    item:
      testCase: '{{ item.testCase }}'
      policyArn: '{{ item.policyArn }}'
      testRunStatus: '{{ item.testRunStatus }}'
      testFindings: '{{ item.testFindings }}'
      testRunResult: '{{ item.testRunResult }}'
      aggregatedTestFindingsResult: '{{ item.aggregatedTestFindingsResult }}'
      updatedAt: '{{ item.updatedAt }}'
- discovery_id: aws.bedrock.listFoundationModelAgreementOffers
  calls:
  - action: listFoundationModelAgreementOffers
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.offers }}'
    item:
