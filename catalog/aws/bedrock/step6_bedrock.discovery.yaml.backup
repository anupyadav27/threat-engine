version: '1.0'
provider: aws
service: bedrock
services:
  client: bedrock
  module: boto3.client
discovery:
- discovery_id: aws.bedrock.getModelInvocationLoggingConfiguration
  calls:
  - action: getModelInvocationLoggingConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.loggingConfig }}'
    item:
      cloudWatchConfig: '{{ item.cloudWatchConfig }}'
      s3Config: '{{ item.s3Config }}'
      textDataDeliveryEnabled: '{{ item.textDataDeliveryEnabled }}'
      imageDataDeliveryEnabled: '{{ item.imageDataDeliveryEnabled }}'
      embeddingDataDeliveryEnabled: '{{ item.embeddingDataDeliveryEnabled }}'
      videoDataDeliveryEnabled: '{{ item.videoDataDeliveryEnabled }}'
- discovery_id: aws.bedrock.getUseCaseForModelAccess
  calls:
  - action: getUseCaseForModelAccess
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.formData }}'
- discovery_id: aws.bedrock.listAutomatedReasoningPolicies
  calls:
  - action: listAutomatedReasoningPolicies
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.automatedReasoningPolicySummaries }}'
    item:
      policyArn: '{{ item.policyArn }}'
      name: '{{ item.name }}'
      description: '{{ item.description }}'
      version: '{{ item.version }}'
      policyId: '{{ item.policyId }}'
      createdAt: '{{ item.createdAt }}'
      updatedAt: '{{ item.updatedAt }}'
- discovery_id: aws.bedrock.listCustomModelDeployments
  calls:
  - action: listCustomModelDeployments
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.modelDeploymentSummaries }}'
    item:
      customModelDeploymentArn: '{{ item.customModelDeploymentArn }}'
      customModelDeploymentName: '{{ item.customModelDeploymentName }}'
      modelArn: '{{ item.modelArn }}'
      createdAt: '{{ item.createdAt }}'
      status: '{{ item.status }}'
      lastUpdatedAt: '{{ item.lastUpdatedAt }}'
      failureMessage: '{{ item.failureMessage }}'
- discovery_id: aws.bedrock.listCustomModels
  calls:
  - action: listCustomModels
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.modelSummaries }}'
    item:
      modelArn: '{{ item.modelArn }}'
      modelName: '{{ item.modelName }}'
      creationTime: '{{ item.creationTime }}'
      baseModelArn: '{{ item.baseModelArn }}'
      baseModelName: '{{ item.baseModelName }}'
      customizationType: '{{ item.customizationType }}'
      ownerAccountId: '{{ item.ownerAccountId }}'
      modelStatus: '{{ item.modelStatus }}'
- discovery_id: aws.bedrock.listEnforcedGuardrailsConfiguration
  calls:
  - action: listEnforcedGuardrailsConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.guardrailsConfig }}'
    item:
      configId: '{{ item.configId }}'
      guardrailArn: '{{ item.guardrailArn }}'
      guardrailId: '{{ item.guardrailId }}'
      inputTags: '{{ item.inputTags }}'
      guardrailVersion: '{{ item.guardrailVersion }}'
      createdAt: '{{ item.createdAt }}'
      createdBy: '{{ item.createdBy }}'
      updatedAt: '{{ item.updatedAt }}'
      updatedBy: '{{ item.updatedBy }}'
      owner: '{{ item.owner }}'
- discovery_id: aws.bedrock.listEvaluationJobs
  calls:
  - action: listEvaluationJobs
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.jobSummaries }}'
    item:
      jobArn: '{{ item.jobArn }}'
      jobName: '{{ item.jobName }}'
      status: '{{ item.status }}'
      creationTime: '{{ item.creationTime }}'
      jobType: '{{ item.jobType }}'
      evaluationTaskTypes: '{{ item.evaluationTaskTypes }}'
      modelIdentifiers: '{{ item.modelIdentifiers }}'
      ragIdentifiers: '{{ item.ragIdentifiers }}'
      evaluatorModelIdentifiers: '{{ item.evaluatorModelIdentifiers }}'
      customMetricsEvaluatorModelIdentifiers: '{{ item.customMetricsEvaluatorModelIdentifiers
        }}'
      inferenceConfigSummary: '{{ item.inferenceConfigSummary }}'
      applicationType: '{{ item.applicationType }}'
- discovery_id: aws.bedrock.listFoundationModels
  calls:
  - action: listFoundationModels
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.modelSummaries }}'
    item:
      modelArn: '{{ item.modelArn }}'
      modelId: '{{ item.modelId }}'
      modelName: '{{ item.modelName }}'
      providerName: '{{ item.providerName }}'
      inputModalities: '{{ item.inputModalities }}'
      outputModalities: '{{ item.outputModalities }}'
      responseStreamingSupported: '{{ item.responseStreamingSupported }}'
      customizationsSupported: '{{ item.customizationsSupported }}'
      inferenceTypesSupported: '{{ item.inferenceTypesSupported }}'
      modelLifecycle: '{{ item.modelLifecycle }}'
- discovery_id: aws.bedrock.listGuardrails
  calls:
  - action: listGuardrails
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.guardrails }}'
    item:
      id: '{{ item.id }}'
      arn: '{{ item.arn }}'
      status: '{{ item.status }}'
      name: '{{ item.name }}'
      description: '{{ item.description }}'
      version: '{{ item.version }}'
      createdAt: '{{ item.createdAt }}'
      updatedAt: '{{ item.updatedAt }}'
      crossRegionDetails: '{{ item.crossRegionDetails }}'
- discovery_id: aws.bedrock.listImportedModels
  calls:
  - action: listImportedModels
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.modelSummaries }}'
    item:
      modelArn: '{{ item.modelArn }}'
      modelName: '{{ item.modelName }}'
      creationTime: '{{ item.creationTime }}'
      instructSupported: '{{ item.instructSupported }}'
      modelArchitecture: '{{ item.modelArchitecture }}'
- discovery_id: aws.bedrock.listInferenceProfiles
  calls:
  - action: listInferenceProfiles
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.inferenceProfileSummaries }}'
    item:
      inferenceProfileName: '{{ item.inferenceProfileName }}'
      description: '{{ item.description }}'
      createdAt: '{{ item.createdAt }}'
      updatedAt: '{{ item.updatedAt }}'
      inferenceProfileArn: '{{ item.inferenceProfileArn }}'
      models: '{{ item.models }}'
      inferenceProfileId: '{{ item.inferenceProfileId }}'
      status: '{{ item.status }}'
      type: '{{ item.type }}'
- discovery_id: aws.bedrock.listMarketplaceModelEndpoints
  calls:
  - action: listMarketplaceModelEndpoints
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.marketplaceModelEndpoints }}'
    item:
      endpointArn: '{{ item.endpointArn }}'
      modelSourceIdentifier: '{{ item.modelSourceIdentifier }}'
      status: '{{ item.status }}'
      statusMessage: '{{ item.statusMessage }}'
      createdAt: '{{ item.createdAt }}'
      updatedAt: '{{ item.updatedAt }}'
- discovery_id: aws.bedrock.listModelCopyJobs
  calls:
  - action: listModelCopyJobs
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.modelCopyJobSummaries }}'
    item:
      jobArn: '{{ item.jobArn }}'
      status: '{{ item.status }}'
      creationTime: '{{ item.creationTime }}'
      targetModelArn: '{{ item.targetModelArn }}'
      targetModelName: '{{ item.targetModelName }}'
      sourceAccountId: '{{ item.sourceAccountId }}'
      sourceModelArn: '{{ item.sourceModelArn }}'
      targetModelKmsKeyArn: '{{ item.targetModelKmsKeyArn }}'
      targetModelTags: '{{ item.targetModelTags }}'
      failureMessage: '{{ item.failureMessage }}'
      sourceModelName: '{{ item.sourceModelName }}'
- discovery_id: aws.bedrock.listModelCustomizationJobs
  calls:
  - action: listModelCustomizationJobs
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.modelCustomizationJobSummaries }}'
    item:
      jobArn: '{{ item.jobArn }}'
      baseModelArn: '{{ item.baseModelArn }}'
      jobName: '{{ item.jobName }}'
      status: '{{ item.status }}'
      statusDetails: '{{ item.statusDetails }}'
      lastModifiedTime: '{{ item.lastModifiedTime }}'
      creationTime: '{{ item.creationTime }}'
      endTime: '{{ item.endTime }}'
      customModelArn: '{{ item.customModelArn }}'
      customModelName: '{{ item.customModelName }}'
      customizationType: '{{ item.customizationType }}'
- discovery_id: aws.bedrock.listModelImportJobs
  calls:
  - action: listModelImportJobs
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.modelImportJobSummaries }}'
    item:
      jobArn: '{{ item.jobArn }}'
      jobName: '{{ item.jobName }}'
      status: '{{ item.status }}'
      lastModifiedTime: '{{ item.lastModifiedTime }}'
      creationTime: '{{ item.creationTime }}'
      endTime: '{{ item.endTime }}'
      importedModelArn: '{{ item.importedModelArn }}'
      importedModelName: '{{ item.importedModelName }}'
- discovery_id: aws.bedrock.listModelInvocationJobs
  calls:
  - action: listModelInvocationJobs
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.invocationJobSummaries }}'
    item:
      jobArn: '{{ item.jobArn }}'
      jobName: '{{ item.jobName }}'
      modelId: '{{ item.modelId }}'
      clientRequestToken: '{{ item.clientRequestToken }}'
      roleArn: '{{ item.roleArn }}'
      status: '{{ item.status }}'
      message: '{{ item.message }}'
      submitTime: '{{ item.submitTime }}'
      lastModifiedTime: '{{ item.lastModifiedTime }}'
      endTime: '{{ item.endTime }}'
      inputDataConfig: '{{ item.inputDataConfig }}'
      outputDataConfig: '{{ item.outputDataConfig }}'
      vpcConfig: '{{ item.vpcConfig }}'
      timeoutDurationInHours: '{{ item.timeoutDurationInHours }}'
      jobExpirationTime: '{{ item.jobExpirationTime }}'
- discovery_id: aws.bedrock.listPromptRouters
  calls:
  - action: listPromptRouters
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.promptRouterSummaries }}'
    item:
      promptRouterName: '{{ item.promptRouterName }}'
      routingCriteria: '{{ item.routingCriteria }}'
      description: '{{ item.description }}'
      createdAt: '{{ item.createdAt }}'
      updatedAt: '{{ item.updatedAt }}'
      promptRouterArn: '{{ item.promptRouterArn }}'
      models: '{{ item.models }}'
      fallbackModel: '{{ item.fallbackModel }}'
      status: '{{ item.status }}'
      type: '{{ item.type }}'
- discovery_id: aws.bedrock.listProvisionedModelThroughputs
  calls:
  - action: listProvisionedModelThroughputs
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.provisionedModelSummaries }}'
    item:
      provisionedModelName: '{{ item.provisionedModelName }}'
      provisionedModelArn: '{{ item.provisionedModelArn }}'
      modelArn: '{{ item.modelArn }}'
      desiredModelArn: '{{ item.desiredModelArn }}'
      foundationModelArn: '{{ item.foundationModelArn }}'
      modelUnits: '{{ item.modelUnits }}'
      desiredModelUnits: '{{ item.desiredModelUnits }}'
      status: '{{ item.status }}'
      commitmentDuration: '{{ item.commitmentDuration }}'
      commitmentExpirationTime: '{{ item.commitmentExpirationTime }}'
      creationTime: '{{ item.creationTime }}'
      lastModifiedTime: '{{ item.lastModifiedTime }}'
- discovery_id: aws.bedrock.getAutomatedReasoningPolicy
  calls:
  - action: getAutomatedReasoningPolicy
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.policyArn }}'
- discovery_id: aws.bedrock.getAutomatedReasoningPolicyAnnotations
  calls:
  - action: getAutomatedReasoningPolicyAnnotations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.annotations }}'
    item:
      addType: '{{ item.addType }}'
      updateType: '{{ item.updateType }}'
      deleteType: '{{ item.deleteType }}'
      addVariable: '{{ item.addVariable }}'
      updateVariable: '{{ item.updateVariable }}'
      deleteVariable: '{{ item.deleteVariable }}'
      addRule: '{{ item.addRule }}'
      updateRule: '{{ item.updateRule }}'
      deleteRule: '{{ item.deleteRule }}'
      addRuleFromNaturalLanguage: '{{ item.addRuleFromNaturalLanguage }}'
      updateFromRulesFeedback: '{{ item.updateFromRulesFeedback }}'
      updateFromScenarioFeedback: '{{ item.updateFromScenarioFeedback }}'
      ingestContent: '{{ item.ingestContent }}'
- discovery_id: aws.bedrock.getAutomatedReasoningPolicyBuildWorkflow
  calls:
  - action: getAutomatedReasoningPolicyBuildWorkflow
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.policyArn }}'
- discovery_id: aws.bedrock.getAutomatedReasoningPolicyBuildWorkflowResultAssets
  calls:
  - action: getAutomatedReasoningPolicyBuildWorkflowResultAssets
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.buildWorkflowAssets }}'
    item:
      policyDefinition: '{{ item.policyDefinition }}'
      qualityReport: '{{ item.qualityReport }}'
      buildLog: '{{ item.buildLog }}'
      generatedTestCases: '{{ item.generatedTestCases }}'
- discovery_id: aws.bedrock.getAutomatedReasoningPolicyNextScenario
  calls:
  - action: getAutomatedReasoningPolicyNextScenario
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.scenario }}'
    item:
      expression: '{{ item.expression }}'
      alternateExpression: '{{ item.alternateExpression }}'
      ruleIds: '{{ item.ruleIds }}'
      expectedResult: '{{ item.expectedResult }}'
- discovery_id: aws.bedrock.getAutomatedReasoningPolicyTestCase
  calls:
  - action: getAutomatedReasoningPolicyTestCase
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.testCase }}'
    item:
      testCaseId: '{{ item.testCaseId }}'
      guardContent: '{{ item.guardContent }}'
      queryContent: '{{ item.queryContent }}'
      expectedAggregatedFindingsResult: '{{ item.expectedAggregatedFindingsResult
        }}'
      createdAt: '{{ item.createdAt }}'
      updatedAt: '{{ item.updatedAt }}'
      confidenceThreshold: '{{ item.confidenceThreshold }}'
- discovery_id: aws.bedrock.getAutomatedReasoningPolicyTestResult
  calls:
  - action: getAutomatedReasoningPolicyTestResult
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.testResult }}'
    item:
      testCase: '{{ item.testCase }}'
      policyArn: '{{ item.policyArn }}'
      testRunStatus: '{{ item.testRunStatus }}'
      testFindings: '{{ item.testFindings }}'
      testRunResult: '{{ item.testRunResult }}'
      aggregatedTestFindingsResult: '{{ item.aggregatedTestFindingsResult }}'
      updatedAt: '{{ item.updatedAt }}'
- discovery_id: aws.bedrock.getCustomModel
  calls:
  - action: getCustomModel
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.validationMetrics }}'
    item:
      validationLoss: '{{ item.validationLoss }}'
- discovery_id: aws.bedrock.getCustomModelDeployment
  calls:
  - action: getCustomModelDeployment
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.customModelDeploymentArn }}'
- discovery_id: aws.bedrock.getEvaluationJob
  calls:
  - action: getEvaluationJob
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.failureMessages }}'
- discovery_id: aws.bedrock.getFoundationModel
  calls:
  - action: getFoundationModel
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.modelDetails }}'
    item:
      modelArn: '{{ item.modelArn }}'
      modelId: '{{ item.modelId }}'
      modelName: '{{ item.modelName }}'
      providerName: '{{ item.providerName }}'
      inputModalities: '{{ item.inputModalities }}'
      outputModalities: '{{ item.outputModalities }}'
      responseStreamingSupported: '{{ item.responseStreamingSupported }}'
      customizationsSupported: '{{ item.customizationsSupported }}'
      inferenceTypesSupported: '{{ item.inferenceTypesSupported }}'
      modelLifecycle: '{{ item.modelLifecycle }}'
- discovery_id: aws.bedrock.getFoundationModelAvailability
  calls:
  - action: getFoundationModelAvailability
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.agreementAvailability }}'
    item:
      status: '{{ item.status }}'
      errorMessage: '{{ item.errorMessage }}'
- discovery_id: aws.bedrock.getGuardrail
  calls:
  - action: getGuardrail
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.statusReasons }}'
- discovery_id: aws.bedrock.getImportedModel
  calls:
  - action: getImportedModel
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.modelDataSource }}'
    item:
      s3DataSource: '{{ item.s3DataSource }}'
- discovery_id: aws.bedrock.getInferenceProfile
  calls:
  - action: getInferenceProfile
    save_as: response
    on_error: continue
  emit:
