version: '1.0'
provider: aws
service: dax
services:
  client: dax
  module: boto3.client
discovery:
- discovery_id: aws.dax.describeClusters
  calls:
  - action: describeClusters
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Clusters }}'
    item:
      ClusterName: '{{ item.ClusterName }}'
      Description: '{{ item.Description }}'
      ClusterArn: '{{ item.ClusterArn }}'
      TotalNodes: '{{ item.TotalNodes }}'
      ActiveNodes: '{{ item.ActiveNodes }}'
      NodeType: '{{ item.NodeType }}'
      Status: '{{ item.Status }}'
      ClusterDiscoveryEndpoint: '{{ item.ClusterDiscoveryEndpoint }}'
      NodeIdsToRemove: '{{ item.NodeIdsToRemove }}'
      Nodes: '{{ item.Nodes }}'
      PreferredMaintenanceWindow: '{{ item.PreferredMaintenanceWindow }}'
      NotificationConfiguration: '{{ item.NotificationConfiguration }}'
      SubnetGroup: '{{ item.SubnetGroup }}'
      SecurityGroups: '{{ item.SecurityGroups }}'
      IamRoleArn: '{{ item.IamRoleArn }}'
      ParameterGroup: '{{ item.ParameterGroup }}'
      SSEDescription: '{{ item.SSEDescription }}'
      ClusterEndpointEncryptionType: '{{ item.ClusterEndpointEncryptionType }}'
      NetworkType: '{{ item.NetworkType }}'
- discovery_id: aws.dax.describeDefaultParameters
  calls:
  - action: describeDefaultParameters
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Parameters }}'
    item:
      ParameterName: '{{ item.ParameterName }}'
      ParameterType: '{{ item.ParameterType }}'
      ParameterValue: '{{ item.ParameterValue }}'
      NodeTypeSpecificValues: '{{ item.NodeTypeSpecificValues }}'
      Description: '{{ item.Description }}'
      Source: '{{ item.Source }}'
      DataType: '{{ item.DataType }}'
      AllowedValues: '{{ item.AllowedValues }}'
      IsModifiable: '{{ item.IsModifiable }}'
      ChangeType: '{{ item.ChangeType }}'
- discovery_id: aws.dax.describeEvents
  calls:
  - action: describeEvents
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Events }}'
    item:
      SourceName: '{{ item.SourceName }}'
      SourceType: '{{ item.SourceType }}'
      Message: '{{ item.Message }}'
      Date: '{{ item.Date }}'
- discovery_id: aws.dax.describeParameterGroups
  calls:
  - action: describeParameterGroups
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ParameterGroups }}'
    item:
      ParameterGroupName: '{{ item.ParameterGroupName }}'
      Description: '{{ item.Description }}'
- discovery_id: aws.dax.describeSubnetGroups
  calls:
  - action: describeSubnetGroups
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.SubnetGroups }}'
    item:
      SubnetGroupName: '{{ item.SubnetGroupName }}'
      Description: '{{ item.Description }}'
      VpcId: '{{ item.VpcId }}'
      Subnets: '{{ item.Subnets }}'
      SupportedNetworkTypes: '{{ item.SupportedNetworkTypes }}'
- discovery_id: aws.dax.describeParameters
  calls:
  - action: describeParameters
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Parameters }}'
    item:
      ParameterName: '{{ item.ParameterName }}'
      ParameterType: '{{ item.ParameterType }}'
      ParameterValue: '{{ item.ParameterValue }}'
      NodeTypeSpecificValues: '{{ item.NodeTypeSpecificValues }}'
      Description: '{{ item.Description }}'
      Source: '{{ item.Source }}'
      DataType: '{{ item.DataType }}'
      AllowedValues: '{{ item.AllowedValues }}'
      IsModifiable: '{{ item.IsModifiable }}'
      ChangeType: '{{ item.ChangeType }}'
- discovery_id: aws.dax.listTags
  calls:
  - action: listTags
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Tags }}'
    item:
      Key: '{{ item.Key }}'
      Value: '{{ item.Value }}'
checks: []
