version: '1.0'
provider: aws
service: health
services:
  client: health
  module: boto3.client
discovery:
- discovery_id: aws.health.describeAffectedEntitiesForOrganization
  calls:
  - action: describeAffectedEntitiesForOrganization
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.entities }}'
    item:
      entityArn: '{{ item.entityArn }}'
      eventArn: '{{ item.eventArn }}'
      entityValue: '{{ item.entityValue }}'
      entityUrl: '{{ item.entityUrl }}'
      awsAccountId: '{{ item.awsAccountId }}'
      lastUpdatedTime: '{{ item.lastUpdatedTime }}'
      statusCode: '{{ item.statusCode }}'
      tags: '{{ item.tags }}'
      entityMetadata: '{{ item.entityMetadata }}'
- discovery_id: aws.health.describeEntityAggregates
  calls:
  - action: describeEntityAggregates
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.entityAggregates }}'
    item:
      eventArn: '{{ item.eventArn }}'
      count: '{{ item.count }}'
      statuses: '{{ item.statuses }}'
- discovery_id: aws.health.describeEventTypes
  calls:
  - action: describeEventTypes
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.eventTypes }}'
    item:
      service: '{{ item.service }}'
      code: '{{ item.code }}'
      category: '{{ item.category }}'
      actionability: '{{ item.actionability }}'
      personas: '{{ item.personas }}'
- discovery_id: aws.health.describeEvents
  calls:
  - action: describeEvents
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.events }}'
    item:
      arn: '{{ item.arn }}'
      service: '{{ item.service }}'
      eventTypeCode: '{{ item.eventTypeCode }}'
      eventTypeCategory: '{{ item.eventTypeCategory }}'
      region: '{{ item.region }}'
      availabilityZone: '{{ item.availabilityZone }}'
      startTime: '{{ item.startTime }}'
      endTime: '{{ item.endTime }}'
      lastUpdatedTime: '{{ item.lastUpdatedTime }}'
      statusCode: '{{ item.statusCode }}'
      eventScopeCode: '{{ item.eventScopeCode }}'
      actionability: '{{ item.actionability }}'
      personas: '{{ item.personas }}'
- discovery_id: aws.health.describeEventsForOrganization
  calls:
  - action: describeEventsForOrganization
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.events }}'
    item:
      arn: '{{ item.arn }}'
      service: '{{ item.service }}'
      eventTypeCode: '{{ item.eventTypeCode }}'
      eventTypeCategory: '{{ item.eventTypeCategory }}'
      eventScopeCode: '{{ item.eventScopeCode }}'
      region: '{{ item.region }}'
      startTime: '{{ item.startTime }}'
      endTime: '{{ item.endTime }}'
      lastUpdatedTime: '{{ item.lastUpdatedTime }}'
      statusCode: '{{ item.statusCode }}'
      actionability: '{{ item.actionability }}'
      personas: '{{ item.personas }}'
- discovery_id: aws.health.describeHealthServiceStatusForOrganization
  calls:
  - action: describeHealthServiceStatusForOrganization
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.healthServiceAccessStatusForOrganization }}'
- discovery_id: aws.health.describeAffectedAccountsForOrganization
  calls:
  - action: describeAffectedAccountsForOrganization
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.affectedAccounts }}'
- discovery_id: aws.health.describeAffectedEntities
  calls:
  - action: describeAffectedEntities
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.entities }}'
    item:
      entityArn: '{{ item.entityArn }}'
      eventArn: '{{ item.eventArn }}'
      entityValue: '{{ item.entityValue }}'
      entityUrl: '{{ item.entityUrl }}'
      awsAccountId: '{{ item.awsAccountId }}'
      lastUpdatedTime: '{{ item.lastUpdatedTime }}'
      statusCode: '{{ item.statusCode }}'
      tags: '{{ item.tags }}'
      entityMetadata: '{{ item.entityMetadata }}'
- discovery_id: aws.health.describeEntityAggregatesForOrganization
  calls:
  - action: describeEntityAggregatesForOrganization
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.organizationEntityAggregates }}'
    item:
      eventArn: '{{ item.eventArn }}'
      count: '{{ item.count }}'
      statuses: '{{ item.statuses }}'
      accounts: '{{ item.accounts }}'
- discovery_id: aws.health.describeEventAggregates
  calls:
  - action: describeEventAggregates
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.eventAggregates }}'
    item:
      aggregateValue: '{{ item.aggregateValue }}'
      count: '{{ item.count }}'
- discovery_id: aws.health.describeEventDetails
  calls:
  - action: describeEventDetails
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.successfulSet }}'
    item:
      event: '{{ item.event }}'
      eventDescription: '{{ item.eventDescription }}'
      eventMetadata: '{{ item.eventMetadata }}'
- discovery_id: aws.health.describeEventDetailsForOrganization
  calls:
  - action: describeEventDetailsForOrganization
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.successfulSet }}'
    item:
      awsAccountId: '{{ item.awsAccountId }}'
      event: '{{ item.event }}'
      eventDescription: '{{ item.eventDescription }}'
      eventMetadata: '{{ item.eventMetadata }}'
checks: []
