version: '1.0'
provider: aws
service: backup-gateway
services:
  client: backup-gateway
  module: boto3.client
discovery:
- discovery_id: aws.backup-gateway.listGateways
  calls:
  - action: listGateways
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Gateways }}'
    item:
      GatewayArn: '{{ item.GatewayArn }}'
      GatewayDisplayName: '{{ item.GatewayDisplayName }}'
      GatewayType: '{{ item.GatewayType }}'
      HypervisorId: '{{ item.HypervisorId }}'
      LastSeenTime: '{{ item.LastSeenTime }}'
- discovery_id: aws.backup-gateway.listHypervisors
  calls:
  - action: listHypervisors
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Hypervisors }}'
    item:
      Host: '{{ item.Host }}'
      HypervisorArn: '{{ item.HypervisorArn }}'
      KmsKeyArn: '{{ item.KmsKeyArn }}'
      Name: '{{ item.Name }}'
      State: '{{ item.State }}'
- discovery_id: aws.backup-gateway.listVirtualMachines
  calls:
  - action: listVirtualMachines
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.VirtualMachines }}'
    item:
      HostName: '{{ item.HostName }}'
      HypervisorId: '{{ item.HypervisorId }}'
      LastBackupDate: '{{ item.LastBackupDate }}'
      Name: '{{ item.Name }}'
      Path: '{{ item.Path }}'
      ResourceArn: '{{ item.ResourceArn }}'
- discovery_id: aws.backup-gateway.getBandwidthRateLimitSchedule
  calls:
  - action: getBandwidthRateLimitSchedule
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.BandwidthRateLimitIntervals }}'
    item:
      AverageUploadRateLimitInBitsPerSec: '{{ item.AverageUploadRateLimitInBitsPerSec
        }}'
      DaysOfWeek: '{{ item.DaysOfWeek }}'
      EndHourOfDay: '{{ item.EndHourOfDay }}'
      EndMinuteOfHour: '{{ item.EndMinuteOfHour }}'
      StartHourOfDay: '{{ item.StartHourOfDay }}'
      StartMinuteOfHour: '{{ item.StartMinuteOfHour }}'
- discovery_id: aws.backup-gateway.getGateway
  calls:
  - action: getGateway
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Gateway }}'
    item:
      GatewayArn: '{{ item.GatewayArn }}'
      GatewayDisplayName: '{{ item.GatewayDisplayName }}'
      GatewayType: '{{ item.GatewayType }}'
      HypervisorId: '{{ item.HypervisorId }}'
      LastSeenTime: '{{ item.LastSeenTime }}'
      MaintenanceStartTime: '{{ item.MaintenanceStartTime }}'
      NextUpdateAvailabilityTime: '{{ item.NextUpdateAvailabilityTime }}'
      VpcEndpoint: '{{ item.VpcEndpoint }}'
- discovery_id: aws.backup-gateway.getHypervisor
  calls:
  - action: getHypervisor
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Hypervisor }}'
    item:
      Host: '{{ item.Host }}'
      HypervisorArn: '{{ item.HypervisorArn }}'
      KmsKeyArn: '{{ item.KmsKeyArn }}'
      LastSuccessfulMetadataSyncTime: '{{ item.LastSuccessfulMetadataSyncTime }}'
      LatestMetadataSyncStatus: '{{ item.LatestMetadataSyncStatus }}'
      LatestMetadataSyncStatusMessage: '{{ item.LatestMetadataSyncStatusMessage }}'
      LogGroupArn: '{{ item.LogGroupArn }}'
      Name: '{{ item.Name }}'
      State: '{{ item.State }}'
- discovery_id: aws.backup-gateway.getHypervisorPropertyMappings
  calls:
  - action: getHypervisorPropertyMappings
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.VmwareToAwsTagMappings }}'
    item:
      AwsTagKey: '{{ item.AwsTagKey }}'
      AwsTagValue: '{{ item.AwsTagValue }}'
      VmwareCategory: '{{ item.VmwareCategory }}'
      VmwareTagName: '{{ item.VmwareTagName }}'
- discovery_id: aws.backup-gateway.getVirtualMachine
  calls:
  - action: getVirtualMachine
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.VirtualMachine }}'
    item:
      HostName: '{{ item.HostName }}'
      HypervisorId: '{{ item.HypervisorId }}'
      LastBackupDate: '{{ item.LastBackupDate }}'
      Name: '{{ item.Name }}'
      Path: '{{ item.Path }}'
      ResourceArn: '{{ item.ResourceArn }}'
      VmwareTags: '{{ item.VmwareTags }}'
- discovery_id: aws.backup-gateway.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Tags }}'
    item:
      Key: '{{ item.Key }}'
      Value: '{{ item.Value }}'
checks: []
