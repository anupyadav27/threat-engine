version: '1.0'
provider: aws
service: workspaces-thin-client
services:
  client: workspaces-thin-client
  module: boto3.client
discovery:
- discovery_id: aws.workspaces-thin-client.listDevices
  calls:
  - action: listDevices
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.devices }}'
    item:
      id: '{{ item.id }}'
      serialNumber: '{{ item.serialNumber }}'
      name: '{{ item.name }}'
      model: '{{ item.model }}'
      environmentId: '{{ item.environmentId }}'
      status: '{{ item.status }}'
      currentSoftwareSetId: '{{ item.currentSoftwareSetId }}'
      desiredSoftwareSetId: '{{ item.desiredSoftwareSetId }}'
      pendingSoftwareSetId: '{{ item.pendingSoftwareSetId }}'
      softwareSetUpdateSchedule: '{{ item.softwareSetUpdateSchedule }}'
      lastConnectedAt: '{{ item.lastConnectedAt }}'
      lastPostureAt: '{{ item.lastPostureAt }}'
      createdAt: '{{ item.createdAt }}'
      updatedAt: '{{ item.updatedAt }}'
      arn: '{{ item.arn }}'
      lastUserId: '{{ item.lastUserId }}'
- discovery_id: aws.workspaces-thin-client.listEnvironments
  calls:
  - action: listEnvironments
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.environments }}'
    item:
      id: '{{ item.id }}'
      name: '{{ item.name }}'
      desktopArn: '{{ item.desktopArn }}'
      desktopEndpoint: '{{ item.desktopEndpoint }}'
      desktopType: '{{ item.desktopType }}'
      activationCode: '{{ item.activationCode }}'
      softwareSetUpdateSchedule: '{{ item.softwareSetUpdateSchedule }}'
      maintenanceWindow: '{{ item.maintenanceWindow }}'
      softwareSetUpdateMode: '{{ item.softwareSetUpdateMode }}'
      desiredSoftwareSetId: '{{ item.desiredSoftwareSetId }}'
      pendingSoftwareSetId: '{{ item.pendingSoftwareSetId }}'
      createdAt: '{{ item.createdAt }}'
      updatedAt: '{{ item.updatedAt }}'
      arn: '{{ item.arn }}'
- discovery_id: aws.workspaces-thin-client.listSoftwareSets
  calls:
  - action: listSoftwareSets
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.softwareSets }}'
    item:
      id: '{{ item.id }}'
      version: '{{ item.version }}'
      releasedAt: '{{ item.releasedAt }}'
      supportedUntil: '{{ item.supportedUntil }}'
      validationStatus: '{{ item.validationStatus }}'
      arn: '{{ item.arn }}'
- discovery_id: aws.workspaces-thin-client.getDevice
  calls:
  - action: getDevice
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.device }}'
    item:
      id: '{{ item.id }}'
      serialNumber: '{{ item.serialNumber }}'
      name: '{{ item.name }}'
      model: '{{ item.model }}'
      environmentId: '{{ item.environmentId }}'
      status: '{{ item.status }}'
      currentSoftwareSetId: '{{ item.currentSoftwareSetId }}'
      currentSoftwareSetVersion: '{{ item.currentSoftwareSetVersion }}'
      desiredSoftwareSetId: '{{ item.desiredSoftwareSetId }}'
      pendingSoftwareSetId: '{{ item.pendingSoftwareSetId }}'
      pendingSoftwareSetVersion: '{{ item.pendingSoftwareSetVersion }}'
      softwareSetUpdateSchedule: '{{ item.softwareSetUpdateSchedule }}'
      softwareSetComplianceStatus: '{{ item.softwareSetComplianceStatus }}'
      softwareSetUpdateStatus: '{{ item.softwareSetUpdateStatus }}'
      lastConnectedAt: '{{ item.lastConnectedAt }}'
      lastPostureAt: '{{ item.lastPostureAt }}'
      createdAt: '{{ item.createdAt }}'
      updatedAt: '{{ item.updatedAt }}'
      arn: '{{ item.arn }}'
      kmsKeyArn: '{{ item.kmsKeyArn }}'
      lastUserId: '{{ item.lastUserId }}'
- discovery_id: aws.workspaces-thin-client.getEnvironment
  calls:
  - action: getEnvironment
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.environment }}'
    item:
      id: '{{ item.id }}'
      name: '{{ item.name }}'
      desktopArn: '{{ item.desktopArn }}'
      desktopEndpoint: '{{ item.desktopEndpoint }}'
      desktopType: '{{ item.desktopType }}'
      activationCode: '{{ item.activationCode }}'
      registeredDevicesCount: '{{ item.registeredDevicesCount }}'
      softwareSetUpdateSchedule: '{{ item.softwareSetUpdateSchedule }}'
      maintenanceWindow: '{{ item.maintenanceWindow }}'
      softwareSetUpdateMode: '{{ item.softwareSetUpdateMode }}'
      desiredSoftwareSetId: '{{ item.desiredSoftwareSetId }}'
      pendingSoftwareSetId: '{{ item.pendingSoftwareSetId }}'
      pendingSoftwareSetVersion: '{{ item.pendingSoftwareSetVersion }}'
      softwareSetComplianceStatus: '{{ item.softwareSetComplianceStatus }}'
      createdAt: '{{ item.createdAt }}'
      updatedAt: '{{ item.updatedAt }}'
      arn: '{{ item.arn }}'
      kmsKeyArn: '{{ item.kmsKeyArn }}'
      deviceCreationTags: '{{ item.deviceCreationTags }}'
- discovery_id: aws.workspaces-thin-client.getSoftwareSet
  calls:
  - action: getSoftwareSet
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.softwareSet }}'
    item:
      id: '{{ item.id }}'
      version: '{{ item.version }}'
      releasedAt: '{{ item.releasedAt }}'
      supportedUntil: '{{ item.supportedUntil }}'
      validationStatus: '{{ item.validationStatus }}'
      software: '{{ item.software }}'
      arn: '{{ item.arn }}'
- discovery_id: aws.workspaces-thin-client.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tags }}'
checks: []
