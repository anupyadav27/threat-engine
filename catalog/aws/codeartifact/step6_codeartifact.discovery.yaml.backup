version: '1.0'
provider: aws
service: codeartifact
services:
  client: codeartifact
  module: boto3.client
discovery:
- discovery_id: aws.codeartifact.listDomains
  calls:
  - action: listDomains
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.domains }}'
    item:
      name: '{{ item.name }}'
      owner: '{{ item.owner }}'
      arn: '{{ item.arn }}'
      status: '{{ item.status }}'
      createdTime: '{{ item.createdTime }}'
      encryptionKey: '{{ item.encryptionKey }}'
- discovery_id: aws.codeartifact.listRepositories
  calls:
  - action: listRepositories
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.repositories }}'
    item:
      name: '{{ item.name }}'
      administratorAccount: '{{ item.administratorAccount }}'
      domainName: '{{ item.domainName }}'
      domainOwner: '{{ item.domainOwner }}'
      arn: '{{ item.arn }}'
      description: '{{ item.description }}'
      createdTime: '{{ item.createdTime }}'
- discovery_id: aws.codeartifact.describeDomain
  calls:
  - action: describeDomain
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.domain }}'
    item:
      name: '{{ item.name }}'
      owner: '{{ item.owner }}'
      arn: '{{ item.arn }}'
      status: '{{ item.status }}'
      createdTime: '{{ item.createdTime }}'
      encryptionKey: '{{ item.encryptionKey }}'
      repositoryCount: '{{ item.repositoryCount }}'
      assetSizeBytes: '{{ item.assetSizeBytes }}'
      s3BucketArn: '{{ item.s3BucketArn }}'
- discovery_id: aws.codeartifact.describePackage
  calls:
  - action: describePackage
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.package }}'
    item:
      format: '{{ item.format }}'
      namespace: '{{ item.namespace }}'
      name: '{{ item.name }}'
      originConfiguration: '{{ item.originConfiguration }}'
- discovery_id: aws.codeartifact.describePackageGroup
  calls:
  - action: describePackageGroup
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.packageGroup }}'
    item:
      arn: '{{ item.arn }}'
      pattern: '{{ item.pattern }}'
      domainName: '{{ item.domainName }}'
      domainOwner: '{{ item.domainOwner }}'
      createdTime: '{{ item.createdTime }}'
      contactInfo: '{{ item.contactInfo }}'
      description: '{{ item.description }}'
      originConfiguration: '{{ item.originConfiguration }}'
      parent: '{{ item.parent }}'
- discovery_id: aws.codeartifact.describePackageVersion
  calls:
  - action: describePackageVersion
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.packageVersion }}'
    item:
      format: '{{ item.format }}'
      namespace: '{{ item.namespace }}'
      packageName: '{{ item.packageName }}'
      displayName: '{{ item.displayName }}'
      version: '{{ item.version }}'
      summary: '{{ item.summary }}'
      homePage: '{{ item.homePage }}'
      sourceCodeRepository: '{{ item.sourceCodeRepository }}'
      publishedTime: '{{ item.publishedTime }}'
      licenses: '{{ item.licenses }}'
      revision: '{{ item.revision }}'
      status: '{{ item.status }}'
      origin: '{{ item.origin }}'
- discovery_id: aws.codeartifact.describeRepository
  calls:
  - action: describeRepository
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.repository }}'
    item:
      name: '{{ item.name }}'
      administratorAccount: '{{ item.administratorAccount }}'
      domainName: '{{ item.domainName }}'
      domainOwner: '{{ item.domainOwner }}'
      arn: '{{ item.arn }}'
      description: '{{ item.description }}'
      upstreams: '{{ item.upstreams }}'
      externalConnections: '{{ item.externalConnections }}'
      createdTime: '{{ item.createdTime }}'
- discovery_id: aws.codeartifact.getAssociatedPackageGroup
  calls:
  - action: getAssociatedPackageGroup
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.packageGroup }}'
    item:
      arn: '{{ item.arn }}'
      pattern: '{{ item.pattern }}'
      domainName: '{{ item.domainName }}'
      domainOwner: '{{ item.domainOwner }}'
      createdTime: '{{ item.createdTime }}'
      contactInfo: '{{ item.contactInfo }}'
      description: '{{ item.description }}'
      originConfiguration: '{{ item.originConfiguration }}'
      parent: '{{ item.parent }}'
- discovery_id: aws.codeartifact.getAuthorizationToken
  calls:
  - action: getAuthorizationToken
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.authorizationToken }}'
- discovery_id: aws.codeartifact.getDomainPermissionsPolicy
  calls:
  - action: getDomainPermissionsPolicy
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.policy }}'
    item:
      resourceArn: '{{ item.resourceArn }}'
      revision: '{{ item.revision }}'
      document: '{{ item.document }}'
- discovery_id: aws.codeartifact.getPackageVersionAsset
  calls:
  - action: getPackageVersionAsset
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.asset }}'
- discovery_id: aws.codeartifact.getPackageVersionReadme
  calls:
  - action: getPackageVersionReadme
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.format }}'
- discovery_id: aws.codeartifact.getRepositoryEndpoint
  calls:
  - action: getRepositoryEndpoint
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.repositoryEndpoint }}'
- discovery_id: aws.codeartifact.getRepositoryPermissionsPolicy
  calls:
  - action: getRepositoryPermissionsPolicy
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.policy }}'
    item:
      resourceArn: '{{ item.resourceArn }}'
      revision: '{{ item.revision }}'
      document: '{{ item.document }}'
- discovery_id: aws.codeartifact.listAllowedRepositoriesForGroup
  calls:
  - action: listAllowedRepositoriesForGroup
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.allowedRepositories }}'
- discovery_id: aws.codeartifact.listAssociatedPackages
  calls:
  - action: listAssociatedPackages
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.packages }}'
    item:
      format: '{{ item.format }}'
      namespace: '{{ item.namespace }}'
      package: '{{ item.package }}'
      associationType: '{{ item.associationType }}'
- discovery_id: aws.codeartifact.listPackageGroups
  calls:
  - action: listPackageGroups
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.packageGroups }}'
    item:
      arn: '{{ item.arn }}'
      pattern: '{{ item.pattern }}'
      domainName: '{{ item.domainName }}'
      domainOwner: '{{ item.domainOwner }}'
      createdTime: '{{ item.createdTime }}'
      contactInfo: '{{ item.contactInfo }}'
      description: '{{ item.description }}'
      originConfiguration: '{{ item.originConfiguration }}'
      parent: '{{ item.parent }}'
- discovery_id: aws.codeartifact.listPackageVersionAssets
  calls:
  - action: listPackageVersionAssets
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.assets }}'
    item:
      name: '{{ item.name }}'
      size: '{{ item.size }}'
      hashes: '{{ item.hashes }}'
- discovery_id: aws.codeartifact.listPackageVersionDependencies
  calls:
  - action: listPackageVersionDependencies
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.dependencies }}'
    item:
      namespace: '{{ item.namespace }}'
      package: '{{ item.package }}'
      dependencyType: '{{ item.dependencyType }}'
      versionRequirement: '{{ item.versionRequirement }}'
- discovery_id: aws.codeartifact.listPackageVersions
  calls:
  - action: listPackageVersions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.versions }}'
    item:
      version: '{{ item.version }}'
      revision: '{{ item.revision }}'
      status: '{{ item.status }}'
      origin: '{{ item.origin }}'
- discovery_id: aws.codeartifact.listPackages
  calls:
  - action: listPackages
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.packages }}'
    item:
      format: '{{ item.format }}'
      namespace: '{{ item.namespace }}'
      package: '{{ item.package }}'
      originConfiguration: '{{ item.originConfiguration }}'
- discovery_id: aws.codeartifact.listRepositoriesInDomain
  calls:
  - action: listRepositoriesInDomain
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.repositories }}'
    item:
      name: '{{ item.name }}'
      administratorAccount: '{{ item.administratorAccount }}'
      domainName: '{{ item.domainName }}'
      domainOwner: '{{ item.domainOwner }}'
      arn: '{{ item.arn }}'
      description: '{{ item.description }}'
      createdTime: '{{ item.createdTime }}'
- discovery_id: aws.codeartifact.listSubPackageGroups
  calls:
  - action: listSubPackageGroups
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.packageGroups }}'
    item:
      arn: '{{ item.arn }}'
      pattern: '{{ item.pattern }}'
      domainName: '{{ item.domainName }}'
      domainOwner: '{{ item.domainOwner }}'
      createdTime: '{{ item.createdTime }}'
      contactInfo: '{{ item.contactInfo }}'
      description: '{{ item.description }}'
      originConfiguration: '{{ item.originConfiguration }}'
      parent: '{{ item.parent }}'
- discovery_id: aws.codeartifact.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tags }}'
    item:
      key: '{{ item.key }}'
      value: '{{ item.value }}'
checks: []
