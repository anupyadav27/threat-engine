version: '1.0'
provider: aws
service: healthlake
services:
  client: healthlake
  module: boto3.client
discovery:
- discovery_id: aws.healthlake.listFhirDatastores
  calls:
  - action: listFhirDatastores
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.DatastorePropertiesList }}'
    item:
      DatastoreId: '{{ item.DatastoreId }}'
      DatastoreArn: '{{ item.DatastoreArn }}'
      DatastoreName: '{{ item.DatastoreName }}'
      DatastoreStatus: '{{ item.DatastoreStatus }}'
      CreatedAt: '{{ item.CreatedAt }}'
      DatastoreTypeVersion: '{{ item.DatastoreTypeVersion }}'
      DatastoreEndpoint: '{{ item.DatastoreEndpoint }}'
      SseConfiguration: '{{ item.SseConfiguration }}'
      PreloadDataConfig: '{{ item.PreloadDataConfig }}'
      IdentityProviderConfiguration: '{{ item.IdentityProviderConfiguration }}'
      ErrorCause: '{{ item.ErrorCause }}'
- discovery_id: aws.healthlake.describeFhirDatastore
  calls:
  - action: describeFhirDatastore
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.DatastoreProperties }}'
    item:
      DatastoreId: '{{ item.DatastoreId }}'
      DatastoreArn: '{{ item.DatastoreArn }}'
      DatastoreName: '{{ item.DatastoreName }}'
      DatastoreStatus: '{{ item.DatastoreStatus }}'
      CreatedAt: '{{ item.CreatedAt }}'
      DatastoreTypeVersion: '{{ item.DatastoreTypeVersion }}'
      DatastoreEndpoint: '{{ item.DatastoreEndpoint }}'
      SseConfiguration: '{{ item.SseConfiguration }}'
      PreloadDataConfig: '{{ item.PreloadDataConfig }}'
      IdentityProviderConfiguration: '{{ item.IdentityProviderConfiguration }}'
      ErrorCause: '{{ item.ErrorCause }}'
- discovery_id: aws.healthlake.describeFhirExportJob
  calls:
  - action: describeFhirExportJob
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ExportJobProperties }}'
    item:
      JobId: '{{ item.JobId }}'
      JobName: '{{ item.JobName }}'
      JobStatus: '{{ item.JobStatus }}'
      SubmitTime: '{{ item.SubmitTime }}'
      EndTime: '{{ item.EndTime }}'
      DatastoreId: '{{ item.DatastoreId }}'
      OutputDataConfig: '{{ item.OutputDataConfig }}'
      DataAccessRoleArn: '{{ item.DataAccessRoleArn }}'
      Message: '{{ item.Message }}'
- discovery_id: aws.healthlake.describeFhirImportJob
  calls:
  - action: describeFhirImportJob
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ImportJobProperties }}'
    item:
      JobId: '{{ item.JobId }}'
      JobName: '{{ item.JobName }}'
      JobStatus: '{{ item.JobStatus }}'
      SubmitTime: '{{ item.SubmitTime }}'
      EndTime: '{{ item.EndTime }}'
      DatastoreId: '{{ item.DatastoreId }}'
      InputDataConfig: '{{ item.InputDataConfig }}'
      JobOutputDataConfig: '{{ item.JobOutputDataConfig }}'
      JobProgressReport: '{{ item.JobProgressReport }}'
      DataAccessRoleArn: '{{ item.DataAccessRoleArn }}'
      Message: '{{ item.Message }}'
      ValidationLevel: '{{ item.ValidationLevel }}'
- discovery_id: aws.healthlake.listFhirExportJobs
  calls:
  - action: listFhirExportJobs
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.ExportJobPropertiesList }}'
    item:
      JobId: '{{ item.JobId }}'
      JobName: '{{ item.JobName }}'
      JobStatus: '{{ item.JobStatus }}'
      SubmitTime: '{{ item.SubmitTime }}'
      EndTime: '{{ item.EndTime }}'
      DatastoreId: '{{ item.DatastoreId }}'
      OutputDataConfig: '{{ item.OutputDataConfig }}'
      DataAccessRoleArn: '{{ item.DataAccessRoleArn }}'
      Message: '{{ item.Message }}'
- discovery_id: aws.healthlake.listFhirImportJobs
  calls:
  - action: listFhirImportJobs
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.ImportJobPropertiesList }}'
    item:
      JobId: '{{ item.JobId }}'
      JobName: '{{ item.JobName }}'
      JobStatus: '{{ item.JobStatus }}'
      SubmitTime: '{{ item.SubmitTime }}'
      EndTime: '{{ item.EndTime }}'
      DatastoreId: '{{ item.DatastoreId }}'
      InputDataConfig: '{{ item.InputDataConfig }}'
      JobOutputDataConfig: '{{ item.JobOutputDataConfig }}'
      JobProgressReport: '{{ item.JobProgressReport }}'
      DataAccessRoleArn: '{{ item.DataAccessRoleArn }}'
      Message: '{{ item.Message }}'
      ValidationLevel: '{{ item.ValidationLevel }}'
- discovery_id: aws.healthlake.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Tags }}'
    item:
      Key: '{{ item.Key }}'
      Value: '{{ item.Value }}'
checks: []
