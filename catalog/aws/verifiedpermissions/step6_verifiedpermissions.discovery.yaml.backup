version: '1.0'
provider: aws
service: verifiedpermissions
services:
  client: verifiedpermissions
  module: boto3.client
discovery:
- discovery_id: aws.verifiedpermissions.listPolicyStores
  calls:
  - action: listPolicyStores
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.policyStores }}'
    item:
      policyStoreId: '{{ item.policyStoreId }}'
      arn: '{{ item.arn }}'
      createdDate: '{{ item.createdDate }}'
      lastUpdatedDate: '{{ item.lastUpdatedDate }}'
      description: '{{ item.description }}'
- discovery_id: aws.verifiedpermissions.getIdentitySource
  calls:
  - action: getIdentitySource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.details }}'
    item:
      clientIds: '{{ item.clientIds }}'
      userPoolArn: '{{ item.userPoolArn }}'
      discoveryUrl: '{{ item.discoveryUrl }}'
      openIdIssuer: '{{ item.openIdIssuer }}'
- discovery_id: aws.verifiedpermissions.getPolicy
  calls:
  - action: getPolicy
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.actions }}'
    item:
      actionType: '{{ item.actionType }}'
      actionId: '{{ item.actionId }}'
- discovery_id: aws.verifiedpermissions.getPolicyStore
  calls:
  - action: getPolicyStore
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.validationSettings }}'
    item:
      mode: '{{ item.mode }}'
- discovery_id: aws.verifiedpermissions.getPolicyTemplate
  calls:
  - action: getPolicyTemplate
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.policyStoreId }}'
- discovery_id: aws.verifiedpermissions.getSchema
  calls:
  - action: getSchema
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.namespaces }}'
- discovery_id: aws.verifiedpermissions.listIdentitySources
  calls:
  - action: listIdentitySources
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.identitySources }}'
    item:
      createdDate: '{{ item.createdDate }}'
      details: '{{ item.details }}'
      identitySourceId: '{{ item.identitySourceId }}'
      lastUpdatedDate: '{{ item.lastUpdatedDate }}'
      policyStoreId: '{{ item.policyStoreId }}'
      principalEntityType: '{{ item.principalEntityType }}'
      configuration: '{{ item.configuration }}'
- discovery_id: aws.verifiedpermissions.listPolicies
  calls:
  - action: listPolicies
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.policies }}'
    item:
      policyStoreId: '{{ item.policyStoreId }}'
      policyId: '{{ item.policyId }}'
      policyType: '{{ item.policyType }}'
      principal: '{{ item.principal }}'
      resource: '{{ item.resource }}'
      actions: '{{ item.actions }}'
      definition: '{{ item.definition }}'
      createdDate: '{{ item.createdDate }}'
      lastUpdatedDate: '{{ item.lastUpdatedDate }}'
      effect: '{{ item.effect }}'
- discovery_id: aws.verifiedpermissions.listPolicyTemplates
  calls:
  - action: listPolicyTemplates
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.policyTemplates }}'
    item:
      policyStoreId: '{{ item.policyStoreId }}'
      policyTemplateId: '{{ item.policyTemplateId }}'
      description: '{{ item.description }}'
      createdDate: '{{ item.createdDate }}'
      lastUpdatedDate: '{{ item.lastUpdatedDate }}'
- discovery_id: aws.verifiedpermissions.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tags }}'
checks: []
