      Id: '{{ item.Id }}'
      Name: '{{ item.Name }}'
      tags: '{{ item.tags }}'
      CreationDate: '{{ item.CreationDate }}'
- discovery_id: aws.pinpoint.getApplicationDateRangeKpi
  calls:
