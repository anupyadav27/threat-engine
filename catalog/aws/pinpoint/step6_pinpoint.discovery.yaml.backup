version: '1.0'
provider: aws
service: pinpoint
services:
  client: pinpoint
  module: boto3.client
discovery:
- discovery_id: aws.pinpoint.getApps
  calls:
  - action: getApps
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ApplicationsResponse }}'
    item:
      Item: '{{ item.Item }}'
      NextToken: '{{ item.NextToken }}'
- discovery_id: aws.pinpoint.getRecommenderConfigurations
  calls:
  - action: getRecommenderConfigurations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ListRecommenderConfigurationsResponse }}'
    item:
      Item: '{{ item.Item }}'
      NextToken: '{{ item.NextToken }}'
- discovery_id: aws.pinpoint.listTemplates
  calls:
  - action: listTemplates
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.TemplatesResponse }}'
    item:
      Item: '{{ item.Item }}'
      NextToken: '{{ item.NextToken }}'
- discovery_id: aws.pinpoint.getAdmChannel
  calls:
  - action: getAdmChannel
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ADMChannelResponse }}'
    item:
      ApplicationId: '{{ item.ApplicationId }}'
      CreationDate: '{{ item.CreationDate }}'
      Enabled: '{{ item.Enabled }}'
      HasCredential: '{{ item.HasCredential }}'
      Id: '{{ item.Id }}'
      IsArchived: '{{ item.IsArchived }}'
      LastModifiedBy: '{{ item.LastModifiedBy }}'
      LastModifiedDate: '{{ item.LastModifiedDate }}'
      Platform: '{{ item.Platform }}'
      Version: '{{ item.Version }}'
- discovery_id: aws.pinpoint.getApnsChannel
  calls:
  - action: getApnsChannel
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.APNSChannelResponse }}'
    item:
      ApplicationId: '{{ item.ApplicationId }}'
      CreationDate: '{{ item.CreationDate }}'
      DefaultAuthenticationMethod: '{{ item.DefaultAuthenticationMethod }}'
      Enabled: '{{ item.Enabled }}'
      HasCredential: '{{ item.HasCredential }}'
      HasTokenKey: '{{ item.HasTokenKey }}'
      Id: '{{ item.Id }}'
      IsArchived: '{{ item.IsArchived }}'
      LastModifiedBy: '{{ item.LastModifiedBy }}'
      LastModifiedDate: '{{ item.LastModifiedDate }}'
      Platform: '{{ item.Platform }}'
      Version: '{{ item.Version }}'
