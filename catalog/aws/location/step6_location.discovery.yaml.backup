version: '1.0'
provider: aws
service: location
services:
  client: location
  module: boto3.client
discovery:
- discovery_id: aws.location.listGeofenceCollections
  calls:
  - action: listGeofenceCollections
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Entries }}'
    item:
      CollectionName: '{{ item.CollectionName }}'
      Description: '{{ item.Description }}'
      PricingPlan: '{{ item.PricingPlan }}'
      PricingPlanDataSource: '{{ item.PricingPlanDataSource }}'
      CreateTime: '{{ item.CreateTime }}'
      UpdateTime: '{{ item.UpdateTime }}'
- discovery_id: aws.location.listKeys
  calls:
  - action: listKeys
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Entries }}'
    item:
      KeyName: '{{ item.KeyName }}'
      ExpireTime: '{{ item.ExpireTime }}'
      Description: '{{ item.Description }}'
      Restrictions: '{{ item.Restrictions }}'
      CreateTime: '{{ item.CreateTime }}'
      UpdateTime: '{{ item.UpdateTime }}'
- discovery_id: aws.location.listMaps
  calls:
  - action: listMaps
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Entries }}'
    item:
      MapName: '{{ item.MapName }}'
      Description: '{{ item.Description }}'
      DataSource: '{{ item.DataSource }}'
      PricingPlan: '{{ item.PricingPlan }}'
      CreateTime: '{{ item.CreateTime }}'
      UpdateTime: '{{ item.UpdateTime }}'
- discovery_id: aws.location.listPlaceIndexes
  calls:
  - action: listPlaceIndexes
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Entries }}'
    item:
      IndexName: '{{ item.IndexName }}'
      Description: '{{ item.Description }}'
      DataSource: '{{ item.DataSource }}'
      PricingPlan: '{{ item.PricingPlan }}'
      CreateTime: '{{ item.CreateTime }}'
      UpdateTime: '{{ item.UpdateTime }}'
- discovery_id: aws.location.listRouteCalculators
  calls:
  - action: listRouteCalculators
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Entries }}'
    item:
      CalculatorName: '{{ item.CalculatorName }}'
      Description: '{{ item.Description }}'
      DataSource: '{{ item.DataSource }}'
      PricingPlan: '{{ item.PricingPlan }}'
      CreateTime: '{{ item.CreateTime }}'
      UpdateTime: '{{ item.UpdateTime }}'
- discovery_id: aws.location.listTrackers
  calls:
  - action: listTrackers
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Entries }}'
    item:
      TrackerName: '{{ item.TrackerName }}'
      Description: '{{ item.Description }}'
      PricingPlan: '{{ item.PricingPlan }}'
      PricingPlanDataSource: '{{ item.PricingPlanDataSource }}'
      CreateTime: '{{ item.CreateTime }}'
      UpdateTime: '{{ item.UpdateTime }}'
- discovery_id: aws.location.describeGeofenceCollection
  calls:
  - action: describeGeofenceCollection
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.CollectionName }}'
- discovery_id: aws.location.describeKey
  calls:
  - action: describeKey
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Restrictions }}'
    item:
      AllowActions: '{{ item.AllowActions }}'
      AllowResources: '{{ item.AllowResources }}'
      AllowReferers: '{{ item.AllowReferers }}'
      AllowAndroidApps: '{{ item.AllowAndroidApps }}'
      AllowAppleApps: '{{ item.AllowAppleApps }}'
- discovery_id: aws.location.describeMap
  calls:
  - action: describeMap
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Configuration }}'
    item:
      Style: '{{ item.Style }}'
      PoliticalView: '{{ item.PoliticalView }}'
      CustomLayers: '{{ item.CustomLayers }}'
- discovery_id: aws.location.describePlaceIndex
  calls:
  - action: describePlaceIndex
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.DataSourceConfiguration }}'
    item:
      IntendedUse: '{{ item.IntendedUse }}'
- discovery_id: aws.location.describeRouteCalculator
  calls:
  - action: describeRouteCalculator
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.CalculatorName }}'
- discovery_id: aws.location.describeTracker
  calls:
  - action: describeTracker
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.TrackerName }}'
- discovery_id: aws.location.getDevicePosition
  calls:
  - action: getDevicePosition
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Position }}'
- discovery_id: aws.location.getDevicePositionHistory
  calls:
  - action: getDevicePositionHistory
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.DevicePositions }}'
    item:
      DeviceId: '{{ item.DeviceId }}'
      SampleTime: '{{ item.SampleTime }}'
      ReceivedTime: '{{ item.ReceivedTime }}'
      Position: '{{ item.Position }}'
      Accuracy: '{{ item.Accuracy }}'
      PositionProperties: '{{ item.PositionProperties }}'
- discovery_id: aws.location.getGeofence
  calls:
  - action: getGeofence
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Geometry }}'
    item:
      Polygon: '{{ item.Polygon }}'
      Circle: '{{ item.Circle }}'
      Geobuf: '{{ item.Geobuf }}'
      MultiPolygon: '{{ item.MultiPolygon }}'
- discovery_id: aws.location.getMapGlyphs
  calls:
  - action: getMapGlyphs
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Blob }}'
- discovery_id: aws.location.getMapSprites
  calls:
  - action: getMapSprites
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Blob }}'
- discovery_id: aws.location.getMapStyleDescriptor
  calls:
  - action: getMapStyleDescriptor
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Blob }}'
- discovery_id: aws.location.getMapTile
  calls:
  - action: getMapTile
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Blob }}'
- discovery_id: aws.location.getPlace
  calls:
  - action: getPlace
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Place }}'
    item:
      Label: '{{ item.Label }}'
      Geometry: '{{ item.Geometry }}'
      AddressNumber: '{{ item.AddressNumber }}'
      Street: '{{ item.Street }}'
      Neighborhood: '{{ item.Neighborhood }}'
      Municipality: '{{ item.Municipality }}'
      SubRegion: '{{ item.SubRegion }}'
      Region: '{{ item.Region }}'
      Country: '{{ item.Country }}'
      PostalCode: '{{ item.PostalCode }}'
      Interpolated: '{{ item.Interpolated }}'
      TimeZone: '{{ item.TimeZone }}'
      UnitType: '{{ item.UnitType }}'
      UnitNumber: '{{ item.UnitNumber }}'
      Categories: '{{ item.Categories }}'
      SupplementalCategories: '{{ item.SupplementalCategories }}'
      SubMunicipality: '{{ item.SubMunicipality }}'
- discovery_id: aws.location.listDevicePositions
  calls:
  - action: listDevicePositions
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Entries }}'
    item:
      DeviceId: '{{ item.DeviceId }}'
      SampleTime: '{{ item.SampleTime }}'
      Position: '{{ item.Position }}'
      Accuracy: '{{ item.Accuracy }}'
      PositionProperties: '{{ item.PositionProperties }}'
- discovery_id: aws.location.listGeofences
  calls:
  - action: listGeofences
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Entries }}'
    item:
      GeofenceId: '{{ item.GeofenceId }}'
      Geometry: '{{ item.Geometry }}'
      Status: '{{ item.Status }}'
      CreateTime: '{{ item.CreateTime }}'
      UpdateTime: '{{ item.UpdateTime }}'
      GeofenceProperties: '{{ item.GeofenceProperties }}'
- discovery_id: aws.location.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Tags }}'
- discovery_id: aws.location.listTrackerConsumers
  calls:
  - action: listTrackerConsumers
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.ConsumerArns }}'
- discovery_id: aws.location.searchPlaceIndexForPosition
  calls:
  - action: searchPlaceIndexForPosition
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Results }}'
    item:
      Place: '{{ item.Place }}'
      Distance: '{{ item.Distance }}'
      PlaceId: '{{ item.PlaceId }}'
- discovery_id: aws.location.searchPlaceIndexForSuggestions
  calls:
  - action: searchPlaceIndexForSuggestions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Results }}'
    item:
      Text: '{{ item.Text }}'
      PlaceId: '{{ item.PlaceId }}'
      Categories: '{{ item.Categories }}'
      SupplementalCategories: '{{ item.SupplementalCategories }}'
- discovery_id: aws.location.searchPlaceIndexForText
  calls:
  - action: searchPlaceIndexForText
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Results }}'
    item:
      Place: '{{ item.Place }}'
      Distance: '{{ item.Distance }}'
      Relevance: '{{ item.Relevance }}'
      PlaceId: '{{ item.PlaceId }}'
checks: []
