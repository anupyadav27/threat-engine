      MigrationProjectCreationTime: '{{ item.MigrationProjectCreationTime }}'
      SourceDataProviderDescriptors: '{{ item.SourceDataProviderDescriptors }}'
      TargetDataProviderDescriptors: '{{ item.TargetDataProviderDescriptors }}'
      InstanceProfileArn: '{{ item.InstanceProfileArn }}'
      InstanceProfileName: '{{ item.InstanceProfileName }}'
      TransformationRules: '{{ item.TransformationRules }}'
      Description: '{{ item.Description }}'
      SchemaConversionApplicationAttributes: '{{ item.SchemaConversionApplicationAttributes
        }}'
- discovery_id: aws.dms.describeOrderableReplicationInstances
  calls:
