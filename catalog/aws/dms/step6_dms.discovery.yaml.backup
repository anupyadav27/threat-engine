      VersionStatus: '{{ item.VersionStatus }}'
      Description: '{{ item.Description }}'
      S3BucketName: '{{ item.S3BucketName }}'
      ServiceAccessRoleArn: '{{ item.ServiceAccessRoleArn }}'
      CollectorHealthCheck: '{{ item.CollectorHealthCheck }}'
      LastDataReceived: '{{ item.LastDataReceived }}'
      RegisteredDate: '{{ item.RegisteredDate }}'
      CreatedDate: '{{ item.CreatedDate }}'
      ModifiedDate: '{{ item.ModifiedDate }}'
      InventoryData: '{{ item.InventoryData }}'
- discovery_id: aws.dms.describeFleetAdvisorDatabases
  calls:
