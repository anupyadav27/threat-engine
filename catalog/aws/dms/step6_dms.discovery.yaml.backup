version: '1.0'
provider: aws
service: dms
services:
  client: dms
  module: boto3.client
discovery:
- discovery_id: aws.dms.describeAccountAttributes
  calls:
  - action: describeAccountAttributes
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AccountQuotas }}'
    item:
      AccountQuotaName: '{{ item.AccountQuotaName }}'
      Used: '{{ item.Used }}'
      Max: '{{ item.Max }}'
- discovery_id: aws.dms.describeApplicableIndividualAssessments
  calls:
  - action: describeApplicableIndividualAssessments
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.IndividualAssessmentNames }}'
- discovery_id: aws.dms.describeCertificates
  calls:
  - action: describeCertificates
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Certificates }}'
    item:
      CertificateIdentifier: '{{ item.CertificateIdentifier }}'
      CertificateCreationDate: '{{ item.CertificateCreationDate }}'
      CertificatePem: '{{ item.CertificatePem }}'
      CertificateWallet: '{{ item.CertificateWallet }}'
      CertificateArn: '{{ item.CertificateArn }}'
      CertificateOwner: '{{ item.CertificateOwner }}'
      ValidFromDate: '{{ item.ValidFromDate }}'
      ValidToDate: '{{ item.ValidToDate }}'
      SigningAlgorithm: '{{ item.SigningAlgorithm }}'
      KeyLength: '{{ item.KeyLength }}'
      KmsKeyId: '{{ item.KmsKeyId }}'
- discovery_id: aws.dms.describeConnections
  calls:
  - action: describeConnections
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Connections }}'
    item:
      ReplicationInstanceArn: '{{ item.ReplicationInstanceArn }}'
      EndpointArn: '{{ item.EndpointArn }}'
      Status: '{{ item.Status }}'
      LastFailureMessage: '{{ item.LastFailureMessage }}'
      EndpointIdentifier: '{{ item.EndpointIdentifier }}'
      ReplicationInstanceIdentifier: '{{ item.ReplicationInstanceIdentifier }}'
- discovery_id: aws.dms.describeDataMigrations
  calls:
  - action: describeDataMigrations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.DataMigrations }}'
    item:
      DataMigrationName: '{{ item.DataMigrationName }}'
      DataMigrationArn: '{{ item.DataMigrationArn }}'
      DataMigrationCreateTime: '{{ item.DataMigrationCreateTime }}'
      DataMigrationStartTime: '{{ item.DataMigrationStartTime }}'
      DataMigrationEndTime: '{{ item.DataMigrationEndTime }}'
      ServiceAccessRoleArn: '{{ item.ServiceAccessRoleArn }}'
      MigrationProjectArn: '{{ item.MigrationProjectArn }}'
      DataMigrationType: '{{ item.DataMigrationType }}'
      DataMigrationSettings: '{{ item.DataMigrationSettings }}'
      SourceDataSettings: '{{ item.SourceDataSettings }}'
      TargetDataSettings: '{{ item.TargetDataSettings }}'
      DataMigrationStatistics: '{{ item.DataMigrationStatistics }}'
      DataMigrationStatus: '{{ item.DataMigrationStatus }}'
      PublicIpAddresses: '{{ item.PublicIpAddresses }}'
      DataMigrationCidrBlocks: '{{ item.DataMigrationCidrBlocks }}'
      LastFailureMessage: '{{ item.LastFailureMessage }}'
      StopReason: '{{ item.StopReason }}'
- discovery_id: aws.dms.describeDataProviders
  calls:
  - action: describeDataProviders
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.DataProviders }}'
    item:
      DataProviderName: '{{ item.DataProviderName }}'
      DataProviderArn: '{{ item.DataProviderArn }}'
      DataProviderCreationTime: '{{ item.DataProviderCreationTime }}'
      Description: '{{ item.Description }}'
      Engine: '{{ item.Engine }}'
      Virtual: '{{ item.Virtual }}'
      Settings: '{{ item.Settings }}'
- discovery_id: aws.dms.describeEndpointTypes
  calls:
  - action: describeEndpointTypes
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.SupportedEndpointTypes }}'
    item:
      EngineName: '{{ item.EngineName }}'
      SupportsCDC: '{{ item.SupportsCDC }}'
      EndpointType: '{{ item.EndpointType }}'
      ReplicationInstanceEngineMinimumVersion: '{{ item.ReplicationInstanceEngineMinimumVersion
        }}'
      EngineDisplayName: '{{ item.EngineDisplayName }}'
- discovery_id: aws.dms.describeEndpoints
  calls:
  - action: describeEndpoints
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Endpoints }}'
    item:
      EndpointIdentifier: '{{ item.EndpointIdentifier }}'
      EndpointType: '{{ item.EndpointType }}'
      EngineName: '{{ item.EngineName }}'
      EngineDisplayName: '{{ item.EngineDisplayName }}'
      Username: '{{ item.Username }}'
      ServerName: '{{ item.ServerName }}'
      Port: '{{ item.Port }}'
      DatabaseName: '{{ item.DatabaseName }}'
      ExtraConnectionAttributes: '{{ item.ExtraConnectionAttributes }}'
      Status: '{{ item.Status }}'
      KmsKeyId: '{{ item.KmsKeyId }}'
      EndpointArn: '{{ item.EndpointArn }}'
      CertificateArn: '{{ item.CertificateArn }}'
      SslMode: '{{ item.SslMode }}'
      ServiceAccessRoleArn: '{{ item.ServiceAccessRoleArn }}'
      ExternalTableDefinition: '{{ item.ExternalTableDefinition }}'
      ExternalId: '{{ item.ExternalId }}'
      IsReadOnly: '{{ item.IsReadOnly }}'
      DynamoDbSettings: '{{ item.DynamoDbSettings }}'
      S3Settings: '{{ item.S3Settings }}'
      DmsTransferSettings: '{{ item.DmsTransferSettings }}'
      MongoDbSettings: '{{ item.MongoDbSettings }}'
      KinesisSettings: '{{ item.KinesisSettings }}'
      KafkaSettings: '{{ item.KafkaSettings }}'
      ElasticsearchSettings: '{{ item.ElasticsearchSettings }}'
      NeptuneSettings: '{{ item.NeptuneSettings }}'
      RedshiftSettings: '{{ item.RedshiftSettings }}'
      PostgreSQLSettings: '{{ item.PostgreSQLSettings }}'
      MySQLSettings: '{{ item.MySQLSettings }}'
      OracleSettings: '{{ item.OracleSettings }}'
      SybaseSettings: '{{ item.SybaseSettings }}'
      MicrosoftSQLServerSettings: '{{ item.MicrosoftSQLServerSettings }}'
      IBMDb2Settings: '{{ item.IBMDb2Settings }}'
      DocDbSettings: '{{ item.DocDbSettings }}'
      RedisSettings: '{{ item.RedisSettings }}'
      GcpMySQLSettings: '{{ item.GcpMySQLSettings }}'
      TimestreamSettings: '{{ item.TimestreamSettings }}'
      LakehouseSettings: '{{ item.LakehouseSettings }}'
- discovery_id: aws.dms.describeEngineVersions
  calls:
  - action: describeEngineVersions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.EngineVersions }}'
    item:
      Version: '{{ item.Version }}'
      Lifecycle: '{{ item.Lifecycle }}'
      ReleaseStatus: '{{ item.ReleaseStatus }}'
      LaunchDate: '{{ item.LaunchDate }}'
      AutoUpgradeDate: '{{ item.AutoUpgradeDate }}'
      DeprecationDate: '{{ item.DeprecationDate }}'
      ForceUpgradeDate: '{{ item.ForceUpgradeDate }}'
      AvailableUpgrades: '{{ item.AvailableUpgrades }}'
- discovery_id: aws.dms.describeEventCategories
  calls:
  - action: describeEventCategories
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.EventCategoryGroupList }}'
    item:
      SourceType: '{{ item.SourceType }}'
      EventCategories: '{{ item.EventCategories }}'
- discovery_id: aws.dms.describeEventSubscriptions
  calls:
  - action: describeEventSubscriptions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.EventSubscriptionsList }}'
    item:
      CustomerAwsId: '{{ item.CustomerAwsId }}'
      CustSubscriptionId: '{{ item.CustSubscriptionId }}'
      SnsTopicArn: '{{ item.SnsTopicArn }}'
      Status: '{{ item.Status }}'
      SubscriptionCreationTime: '{{ item.SubscriptionCreationTime }}'
      SourceType: '{{ item.SourceType }}'
      SourceIdsList: '{{ item.SourceIdsList }}'
      EventCategoriesList: '{{ item.EventCategoriesList }}'
      Enabled: '{{ item.Enabled }}'
- discovery_id: aws.dms.describeEvents
  calls:
  - action: describeEvents
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Events }}'
    item:
      SourceIdentifier: '{{ item.SourceIdentifier }}'
      SourceType: '{{ item.SourceType }}'
      Message: '{{ item.Message }}'
      EventCategories: '{{ item.EventCategories }}'
      Date: '{{ item.Date }}'
- discovery_id: aws.dms.describeFleetAdvisorCollectors
  calls:
  - action: describeFleetAdvisorCollectors
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Collectors }}'
    item:
