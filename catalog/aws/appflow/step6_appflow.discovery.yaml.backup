version: '1.0'
provider: aws
service: appflow
services:
  client: appflow
  module: boto3.client
discovery:
- discovery_id: aws.appflow.describeConnectorProfiles
  calls:
  - action: describeConnectorProfiles
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.connectorProfileDetails }}'
    item:
      connectorProfileArn: '{{ item.connectorProfileArn }}'
      connectorProfileName: '{{ item.connectorProfileName }}'
      connectorType: '{{ item.connectorType }}'
      connectorLabel: '{{ item.connectorLabel }}'
      connectionMode: '{{ item.connectionMode }}'
      credentialsArn: '{{ item.credentialsArn }}'
      connectorProfileProperties: '{{ item.connectorProfileProperties }}'
      createdAt: '{{ item.createdAt }}'
      lastUpdatedAt: '{{ item.lastUpdatedAt }}'
      privateConnectionProvisioningState: '{{ item.privateConnectionProvisioningState
        }}'
- discovery_id: aws.appflow.describeConnectors
  calls:
  - action: describeConnectors
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.connectors }}'
    item:
      connectorDescription: '{{ item.connectorDescription }}'
      connectorName: '{{ item.connectorName }}'
      connectorOwner: '{{ item.connectorOwner }}'
      connectorVersion: '{{ item.connectorVersion }}'
      applicationType: '{{ item.applicationType }}'
      connectorType: '{{ item.connectorType }}'
      connectorLabel: '{{ item.connectorLabel }}'
      registeredAt: '{{ item.registeredAt }}'
      registeredBy: '{{ item.registeredBy }}'
      connectorProvisioningType: '{{ item.connectorProvisioningType }}'
      connectorModes: '{{ item.connectorModes }}'
      supportedDataTransferTypes: '{{ item.supportedDataTransferTypes }}'
- discovery_id: aws.appflow.listConnectorEntities
  calls:
  - action: listConnectorEntities
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.connectorEntityMap }}'
- discovery_id: aws.appflow.listConnectors
  calls:
  - action: listConnectors
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.connectors }}'
    item:
      connectorDescription: '{{ item.connectorDescription }}'
      connectorName: '{{ item.connectorName }}'
      connectorOwner: '{{ item.connectorOwner }}'
      connectorVersion: '{{ item.connectorVersion }}'
      applicationType: '{{ item.applicationType }}'
      connectorType: '{{ item.connectorType }}'
      connectorLabel: '{{ item.connectorLabel }}'
      registeredAt: '{{ item.registeredAt }}'
      registeredBy: '{{ item.registeredBy }}'
      connectorProvisioningType: '{{ item.connectorProvisioningType }}'
      connectorModes: '{{ item.connectorModes }}'
      supportedDataTransferTypes: '{{ item.supportedDataTransferTypes }}'
- discovery_id: aws.appflow.listFlows
  calls:
  - action: listFlows
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.flows }}'
    item:
      flowArn: '{{ item.flowArn }}'
      description: '{{ item.description }}'
      flowName: '{{ item.flowName }}'
      flowStatus: '{{ item.flowStatus }}'
      sourceConnectorType: '{{ item.sourceConnectorType }}'
      sourceConnectorLabel: '{{ item.sourceConnectorLabel }}'
      destinationConnectorType: '{{ item.destinationConnectorType }}'
      destinationConnectorLabel: '{{ item.destinationConnectorLabel }}'
      triggerType: '{{ item.triggerType }}'
      createdAt: '{{ item.createdAt }}'
      lastUpdatedAt: '{{ item.lastUpdatedAt }}'
      createdBy: '{{ item.createdBy }}'
      lastUpdatedBy: '{{ item.lastUpdatedBy }}'
      tags: '{{ item.tags }}'
      lastRunExecutionDetails: '{{ item.lastRunExecutionDetails }}'
- discovery_id: aws.appflow.describeConnector
  calls:
  - action: describeConnector
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.connectorConfiguration }}'
    item:
      canUseAsSource: '{{ item.canUseAsSource }}'
      canUseAsDestination: '{{ item.canUseAsDestination }}'
      supportedDestinationConnectors: '{{ item.supportedDestinationConnectors }}'
      supportedSchedulingFrequencies: '{{ item.supportedSchedulingFrequencies }}'
      isPrivateLinkEnabled: '{{ item.isPrivateLinkEnabled }}'
      isPrivateLinkEndpointUrlRequired: '{{ item.isPrivateLinkEndpointUrlRequired
        }}'
      supportedTriggerTypes: '{{ item.supportedTriggerTypes }}'
      connectorMetadata: '{{ item.connectorMetadata }}'
      connectorType: '{{ item.connectorType }}'
      connectorLabel: '{{ item.connectorLabel }}'
      connectorDescription: '{{ item.connectorDescription }}'
      connectorOwner: '{{ item.connectorOwner }}'
      connectorName: '{{ item.connectorName }}'
      connectorVersion: '{{ item.connectorVersion }}'
      connectorArn: '{{ item.connectorArn }}'
      connectorModes: '{{ item.connectorModes }}'
      authenticationConfig: '{{ item.authenticationConfig }}'
      connectorRuntimeSettings: '{{ item.connectorRuntimeSettings }}'
      supportedApiVersions: '{{ item.supportedApiVersions }}'
      supportedOperators: '{{ item.supportedOperators }}'
      supportedWriteOperations: '{{ item.supportedWriteOperations }}'
      connectorProvisioningType: '{{ item.connectorProvisioningType }}'
      connectorProvisioningConfig: '{{ item.connectorProvisioningConfig }}'
      logoURL: '{{ item.logoURL }}'
      registeredAt: '{{ item.registeredAt }}'
      registeredBy: '{{ item.registeredBy }}'
      supportedDataTransferTypes: '{{ item.supportedDataTransferTypes }}'
      supportedDataTransferApis: '{{ item.supportedDataTransferApis }}'
- discovery_id: aws.appflow.describeConnectorEntity
  calls:
  - action: describeConnectorEntity
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.connectorEntityFields }}'
    item:
      identifier: '{{ item.identifier }}'
      parentIdentifier: '{{ item.parentIdentifier }}'
      label: '{{ item.label }}'
      isPrimaryKey: '{{ item.isPrimaryKey }}'
      defaultValue: '{{ item.defaultValue }}'
      isDeprecated: '{{ item.isDeprecated }}'
      supportedFieldTypeDetails: '{{ item.supportedFieldTypeDetails }}'
      description: '{{ item.description }}'
      sourceProperties: '{{ item.sourceProperties }}'
      destinationProperties: '{{ item.destinationProperties }}'
      customProperties: '{{ item.customProperties }}'
- discovery_id: aws.appflow.describeFlow
  calls:
  - action: describeFlow
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.destinationFlowConfigList }}'
    item:
      connectorType: '{{ item.connectorType }}'
      apiVersion: '{{ item.apiVersion }}'
      connectorProfileName: '{{ item.connectorProfileName }}'
      destinationConnectorProperties: '{{ item.destinationConnectorProperties }}'
- discovery_id: aws.appflow.describeFlowExecutionRecords
  calls:
  - action: describeFlowExecutionRecords
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.flowExecutions }}'
    item:
      executionId: '{{ item.executionId }}'
      executionStatus: '{{ item.executionStatus }}'
      executionResult: '{{ item.executionResult }}'
      startedAt: '{{ item.startedAt }}'
      lastUpdatedAt: '{{ item.lastUpdatedAt }}'
      dataPullStartTime: '{{ item.dataPullStartTime }}'
      dataPullEndTime: '{{ item.dataPullEndTime }}'
      metadataCatalogDetails: '{{ item.metadataCatalogDetails }}'
- discovery_id: aws.appflow.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tags }}'
checks: []
