version: '1.0'
provider: aws
service: forecastquery
services:
  client: forecastquery
  module: boto3.client
discovery:
- discovery_id: aws.forecastquery.queryForecast
  calls:
  - action: queryForecast
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Forecast }}'
    item:
      Predictions: '{{ item.Predictions }}'
- discovery_id: aws.forecastquery.queryWhatIfForecast
  calls:
  - action: queryWhatIfForecast
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Forecast }}'
    item:
      Predictions: '{{ item.Predictions }}'
checks: []
