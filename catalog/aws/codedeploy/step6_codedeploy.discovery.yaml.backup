version: '1.0'
provider: aws
service: codedeploy
services:
  client: codedeploy
  module: boto3.client
discovery:
- discovery_id: aws.codedeploy.listApplications
  calls:
  - action: listApplications
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.applications }}'
- discovery_id: aws.codedeploy.listDeploymentConfigs
  calls:
  - action: listDeploymentConfigs
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.deploymentConfigsList }}'
- discovery_id: aws.codedeploy.listDeployments
  calls:
  - action: listDeployments
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.deployments }}'
- discovery_id: aws.codedeploy.listGitHubAccountTokenNames
  calls:
  - action: listGitHubAccountTokenNames
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tokenNameList }}'
- discovery_id: aws.codedeploy.listOnPremisesInstances
  calls:
  - action: listOnPremisesInstances
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.instanceNames }}'
- discovery_id: aws.codedeploy.getApplication
  calls:
  - action: getApplication
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.application }}'
    item:
      applicationId: '{{ item.applicationId }}'
      applicationName: '{{ item.applicationName }}'
      createTime: '{{ item.createTime }}'
      linkedToGitHub: '{{ item.linkedToGitHub }}'
      gitHubAccountName: '{{ item.gitHubAccountName }}'
      computePlatform: '{{ item.computePlatform }}'
- discovery_id: aws.codedeploy.getApplicationRevision
  calls:
  - action: getApplicationRevision
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.revision }}'
    item:
      revisionType: '{{ item.revisionType }}'
      s3Location: '{{ item.s3Location }}'
      gitHubLocation: '{{ item.gitHubLocation }}'
      string: '{{ item.string }}'
      appSpecContent: '{{ item.appSpecContent }}'
- discovery_id: aws.codedeploy.getDeployment
  calls:
  - action: getDeployment
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.deploymentInfo }}'
    item:
      applicationName: '{{ item.applicationName }}'
      deploymentGroupName: '{{ item.deploymentGroupName }}'
      deploymentConfigName: '{{ item.deploymentConfigName }}'
      deploymentId: '{{ item.deploymentId }}'
      previousRevision: '{{ item.previousRevision }}'
      revision: '{{ item.revision }}'
      status: '{{ item.status }}'
      errorInformation: '{{ item.errorInformation }}'
      createTime: '{{ item.createTime }}'
      startTime: '{{ item.startTime }}'
      completeTime: '{{ item.completeTime }}'
      deploymentOverview: '{{ item.deploymentOverview }}'
      description: '{{ item.description }}'
      creator: '{{ item.creator }}'
      ignoreApplicationStopFailures: '{{ item.ignoreApplicationStopFailures }}'
      autoRollbackConfiguration: '{{ item.autoRollbackConfiguration }}'
      updateOutdatedInstancesOnly: '{{ item.updateOutdatedInstancesOnly }}'
      rollbackInfo: '{{ item.rollbackInfo }}'
      deploymentStyle: '{{ item.deploymentStyle }}'
      targetInstances: '{{ item.targetInstances }}'
      instanceTerminationWaitTimeStarted: '{{ item.instanceTerminationWaitTimeStarted
        }}'
      blueGreenDeploymentConfiguration: '{{ item.blueGreenDeploymentConfiguration
        }}'
      loadBalancerInfo: '{{ item.loadBalancerInfo }}'
      additionalDeploymentStatusInfo: '{{ item.additionalDeploymentStatusInfo }}'
      fileExistsBehavior: '{{ item.fileExistsBehavior }}'
      deploymentStatusMessages: '{{ item.deploymentStatusMessages }}'
      computePlatform: '{{ item.computePlatform }}'
      externalId: '{{ item.externalId }}'
      relatedDeployments: '{{ item.relatedDeployments }}'
      overrideAlarmConfiguration: '{{ item.overrideAlarmConfiguration }}'
- discovery_id: aws.codedeploy.getDeploymentConfig
  calls:
  - action: getDeploymentConfig
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.deploymentConfigInfo }}'
    item:
      deploymentConfigId: '{{ item.deploymentConfigId }}'
      deploymentConfigName: '{{ item.deploymentConfigName }}'
      minimumHealthyHosts: '{{ item.minimumHealthyHosts }}'
      createTime: '{{ item.createTime }}'
      computePlatform: '{{ item.computePlatform }}'
      trafficRoutingConfig: '{{ item.trafficRoutingConfig }}'
      zonalConfig: '{{ item.zonalConfig }}'
- discovery_id: aws.codedeploy.getDeploymentGroup
  calls:
  - action: getDeploymentGroup
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.deploymentGroupInfo }}'
    item:
      applicationName: '{{ item.applicationName }}'
      deploymentGroupId: '{{ item.deploymentGroupId }}'
      deploymentGroupName: '{{ item.deploymentGroupName }}'
      deploymentConfigName: '{{ item.deploymentConfigName }}'
      ec2TagFilters: '{{ item.ec2TagFilters }}'
      onPremisesInstanceTagFilters: '{{ item.onPremisesInstanceTagFilters }}'
      autoScalingGroups: '{{ item.autoScalingGroups }}'
      serviceRoleArn: '{{ item.serviceRoleArn }}'
      targetRevision: '{{ item.targetRevision }}'
      triggerConfigurations: '{{ item.triggerConfigurations }}'
      alarmConfiguration: '{{ item.alarmConfiguration }}'
      autoRollbackConfiguration: '{{ item.autoRollbackConfiguration }}'
      deploymentStyle: '{{ item.deploymentStyle }}'
      outdatedInstancesStrategy: '{{ item.outdatedInstancesStrategy }}'
      blueGreenDeploymentConfiguration: '{{ item.blueGreenDeploymentConfiguration
        }}'
      loadBalancerInfo: '{{ item.loadBalancerInfo }}'
      lastSuccessfulDeployment: '{{ item.lastSuccessfulDeployment }}'
      lastAttemptedDeployment: '{{ item.lastAttemptedDeployment }}'
      ec2TagSet: '{{ item.ec2TagSet }}'
      onPremisesTagSet: '{{ item.onPremisesTagSet }}'
      computePlatform: '{{ item.computePlatform }}'
      ecsServices: '{{ item.ecsServices }}'
      terminationHookEnabled: '{{ item.terminationHookEnabled }}'
- discovery_id: aws.codedeploy.getDeploymentInstance
  calls:
  - action: getDeploymentInstance
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.instanceSummary }}'
    item:
      deploymentId: '{{ item.deploymentId }}'
      instanceId: '{{ item.instanceId }}'
      status: '{{ item.status }}'
      lastUpdatedAt: '{{ item.lastUpdatedAt }}'
      lifecycleEvents: '{{ item.lifecycleEvents }}'
      instanceType: '{{ item.instanceType }}'
- discovery_id: aws.codedeploy.getDeploymentTarget
  calls:
  - action: getDeploymentTarget
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.deploymentTarget }}'
    item:
      deploymentTargetType: '{{ item.deploymentTargetType }}'
      instanceTarget: '{{ item.instanceTarget }}'
      lambdaTarget: '{{ item.lambdaTarget }}'
      ecsTarget: '{{ item.ecsTarget }}'
      cloudFormationTarget: '{{ item.cloudFormationTarget }}'
- discovery_id: aws.codedeploy.getOnPremisesInstance
  calls:
  - action: getOnPremisesInstance
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.instanceInfo }}'
    item:
      instanceName: '{{ item.instanceName }}'
      iamSessionArn: '{{ item.iamSessionArn }}'
      iamUserArn: '{{ item.iamUserArn }}'
      instanceArn: '{{ item.instanceArn }}'
      registerTime: '{{ item.registerTime }}'
      deregisterTime: '{{ item.deregisterTime }}'
      tags: '{{ item.tags }}'
- discovery_id: aws.codedeploy.listApplicationRevisions
  calls:
  - action: listApplicationRevisions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.revisions }}'
    item:
      revisionType: '{{ item.revisionType }}'
      s3Location: '{{ item.s3Location }}'
      gitHubLocation: '{{ item.gitHubLocation }}'
      string: '{{ item.string }}'
      appSpecContent: '{{ item.appSpecContent }}'
- discovery_id: aws.codedeploy.listDeploymentGroups
  calls:
  - action: listDeploymentGroups
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.deploymentGroups }}'
- discovery_id: aws.codedeploy.listDeploymentInstances
  calls:
  - action: listDeploymentInstances
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.instancesList }}'
- discovery_id: aws.codedeploy.listDeploymentTargets
  calls:
  - action: listDeploymentTargets
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.targetIds }}'
- discovery_id: aws.codedeploy.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Tags }}'
    item:
      Key: '{{ item.Key }}'
      Value: '{{ item.Value }}'
checks: []
