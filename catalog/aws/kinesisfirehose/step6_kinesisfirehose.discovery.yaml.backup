version: '1.0'
provider: aws
service: kinesisfirehose
services:
  client: kinesisfirehose
  module: boto3.client
discovery:
- discovery_id: aws.kinesisfirehose.listDeliveryStreams
  calls:
  - action: listDeliveryStreams
    save_as: response
    on_error: continue
    params:
      Limit: 1000
  emit:
    as: item
    items_for: '{{ response.DeliveryStreamNames }}'
- discovery_id: aws.kinesisfirehose.describeDeliveryStream
  calls:
  - action: describeDeliveryStream
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.DeliveryStreamDescription }}'
    item:
      DeliveryStreamName: '{{ item.DeliveryStreamName }}'
      DeliveryStreamARN: '{{ item.DeliveryStreamARN }}'
      DeliveryStreamStatus: '{{ item.DeliveryStreamStatus }}'
      FailureDescription: '{{ item.FailureDescription }}'
      DeliveryStreamEncryptionConfiguration: '{{ item.DeliveryStreamEncryptionConfiguration
        }}'
      DeliveryStreamType: '{{ item.DeliveryStreamType }}'
      VersionId: '{{ item.VersionId }}'
      CreateTimestamp: '{{ item.CreateTimestamp }}'
      LastUpdateTimestamp: '{{ item.LastUpdateTimestamp }}'
      Source: '{{ item.Source }}'
      Destinations: '{{ item.Destinations }}'
      HasMoreDestinations: '{{ item.HasMoreDestinations }}'
- discovery_id: aws.kinesisfirehose.listTagsForDeliveryStream
  calls:
  - action: listTagsForDeliveryStream
    save_as: response
    on_error: continue
    params:
      Limit: 1000
  emit:
    as: item
    items_for: '{{ response.Tags }}'
    item:
      Key: '{{ item.Key }}'
      Value: '{{ item.Value }}'
checks: []
