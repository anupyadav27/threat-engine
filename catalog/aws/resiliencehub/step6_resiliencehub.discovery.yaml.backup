version: '1.0'
provider: aws
service: resiliencehub
services:
  client: resiliencehub
  module: boto3.client
discovery:
- discovery_id: aws.resiliencehub.listAppAssessments
  calls:
  - action: listAppAssessments
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.assessmentSummaries }}'
    item:
      appArn: '{{ item.appArn }}'
      appVersion: '{{ item.appVersion }}'
      assessmentArn: '{{ item.assessmentArn }}'
      assessmentName: '{{ item.assessmentName }}'
      assessmentStatus: '{{ item.assessmentStatus }}'
      complianceStatus: '{{ item.complianceStatus }}'
      cost: '{{ item.cost }}'
      driftStatus: '{{ item.driftStatus }}'
      endTime: '{{ item.endTime }}'
      invoker: '{{ item.invoker }}'
      message: '{{ item.message }}'
      resiliencyScore: '{{ item.resiliencyScore }}'
      startTime: '{{ item.startTime }}'
      versionName: '{{ item.versionName }}'
- discovery_id: aws.resiliencehub.listApps
  calls:
  - action: listApps
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.appSummaries }}'
    item:
      appArn: '{{ item.appArn }}'
      assessmentSchedule: '{{ item.assessmentSchedule }}'
      awsApplicationArn: '{{ item.awsApplicationArn }}'
      complianceStatus: '{{ item.complianceStatus }}'
      creationTime: '{{ item.creationTime }}'
      description: '{{ item.description }}'
      driftStatus: '{{ item.driftStatus }}'
      lastAppComplianceEvaluationTime: '{{ item.lastAppComplianceEvaluationTime }}'
      name: '{{ item.name }}'
      resiliencyScore: '{{ item.resiliencyScore }}'
      rpoInSecs: '{{ item.rpoInSecs }}'
      rtoInSecs: '{{ item.rtoInSecs }}'
      status: '{{ item.status }}'
- discovery_id: aws.resiliencehub.listMetrics
  calls:
  - action: listMetrics
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.rows }}'
- discovery_id: aws.resiliencehub.listRecommendationTemplates
  calls:
  - action: listRecommendationTemplates
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.recommendationTemplates }}'
    item:
      appArn: '{{ item.appArn }}'
      assessmentArn: '{{ item.assessmentArn }}'
      endTime: '{{ item.endTime }}'
      format: '{{ item.format }}'
      message: '{{ item.message }}'
      name: '{{ item.name }}'
      needsReplacements: '{{ item.needsReplacements }}'
      recommendationIds: '{{ item.recommendationIds }}'
      recommendationTemplateArn: '{{ item.recommendationTemplateArn }}'
      recommendationTypes: '{{ item.recommendationTypes }}'
      startTime: '{{ item.startTime }}'
      status: '{{ item.status }}'
      tags: '{{ item.tags }}'
      templatesLocation: '{{ item.templatesLocation }}'
- discovery_id: aws.resiliencehub.listResiliencyPolicies
  calls:
  - action: listResiliencyPolicies
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.resiliencyPolicies }}'
    item:
      creationTime: '{{ item.creationTime }}'
      dataLocationConstraint: '{{ item.dataLocationConstraint }}'
      estimatedCostTier: '{{ item.estimatedCostTier }}'
      policy: '{{ item.policy }}'
      policyArn: '{{ item.policyArn }}'
      policyDescription: '{{ item.policyDescription }}'
      policyName: '{{ item.policyName }}'
      tags: '{{ item.tags }}'
      tier: '{{ item.tier }}'
- discovery_id: aws.resiliencehub.listResourceGroupingRecommendations
  calls:
  - action: listResourceGroupingRecommendations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.groupingRecommendations }}'
    item:
      confidenceLevel: '{{ item.confidenceLevel }}'
      creationTime: '{{ item.creationTime }}'
      groupingAppComponent: '{{ item.groupingAppComponent }}'
      groupingRecommendationId: '{{ item.groupingRecommendationId }}'
      recommendationReasons: '{{ item.recommendationReasons }}'
      rejectionReason: '{{ item.rejectionReason }}'
      resources: '{{ item.resources }}'
      score: '{{ item.score }}'
      status: '{{ item.status }}'
- discovery_id: aws.resiliencehub.listSuggestedResiliencyPolicies
  calls:
  - action: listSuggestedResiliencyPolicies
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.resiliencyPolicies }}'
    item:
      creationTime: '{{ item.creationTime }}'
      dataLocationConstraint: '{{ item.dataLocationConstraint }}'
      estimatedCostTier: '{{ item.estimatedCostTier }}'
      policy: '{{ item.policy }}'
      policyArn: '{{ item.policyArn }}'
      policyDescription: '{{ item.policyDescription }}'
      policyName: '{{ item.policyName }}'
      tags: '{{ item.tags }}'
      tier: '{{ item.tier }}'
- discovery_id: aws.resiliencehub.describeApp
  calls:
  - action: describeApp
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.app }}'
    item:
      appArn: '{{ item.appArn }}'
      assessmentSchedule: '{{ item.assessmentSchedule }}'
      awsApplicationArn: '{{ item.awsApplicationArn }}'
      complianceStatus: '{{ item.complianceStatus }}'
      creationTime: '{{ item.creationTime }}'
      description: '{{ item.description }}'
      driftStatus: '{{ item.driftStatus }}'
      eventSubscriptions: '{{ item.eventSubscriptions }}'
      lastAppComplianceEvaluationTime: '{{ item.lastAppComplianceEvaluationTime }}'
      lastDriftEvaluationTime: '{{ item.lastDriftEvaluationTime }}'
      lastResiliencyScoreEvaluationTime: '{{ item.lastResiliencyScoreEvaluationTime
        }}'
      name: '{{ item.name }}'
      permissionModel: '{{ item.permissionModel }}'
      policyArn: '{{ item.policyArn }}'
      resiliencyScore: '{{ item.resiliencyScore }}'
      rpoInSecs: '{{ item.rpoInSecs }}'
      rtoInSecs: '{{ item.rtoInSecs }}'
      status: '{{ item.status }}'
      tags: '{{ item.tags }}'
- discovery_id: aws.resiliencehub.describeAppAssessment
  calls:
  - action: describeAppAssessment
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.assessment }}'
    item:
      appArn: '{{ item.appArn }}'
      appVersion: '{{ item.appVersion }}'
      assessmentArn: '{{ item.assessmentArn }}'
      assessmentName: '{{ item.assessmentName }}'
      assessmentStatus: '{{ item.assessmentStatus }}'
      compliance: '{{ item.compliance }}'
      complianceStatus: '{{ item.complianceStatus }}'
      cost: '{{ item.cost }}'
      driftStatus: '{{ item.driftStatus }}'
      endTime: '{{ item.endTime }}'
      invoker: '{{ item.invoker }}'
      message: '{{ item.message }}'
      policy: '{{ item.policy }}'
      resiliencyScore: '{{ item.resiliencyScore }}'
      resourceErrorsDetails: '{{ item.resourceErrorsDetails }}'
      startTime: '{{ item.startTime }}'
      summary: '{{ item.summary }}'
      tags: '{{ item.tags }}'
      versionName: '{{ item.versionName }}'
- discovery_id: aws.resiliencehub.describeAppVersion
  calls:
  - action: describeAppVersion
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.additionalInfo }}'
- discovery_id: aws.resiliencehub.describeAppVersionAppComponent
  calls:
  - action: describeAppVersionAppComponent
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.appComponent }}'
    item:
      additionalInfo: '{{ item.additionalInfo }}'
      id: '{{ item.id }}'
      name: '{{ item.name }}'
      type: '{{ item.type }}'
- discovery_id: aws.resiliencehub.describeAppVersionResource
  calls:
  - action: describeAppVersionResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.physicalResource }}'
    item:
      additionalInfo: '{{ item.additionalInfo }}'
      appComponents: '{{ item.appComponents }}'
      excluded: '{{ item.excluded }}'
      logicalResourceId: '{{ item.logicalResourceId }}'
      parentResourceName: '{{ item.parentResourceName }}'
      physicalResourceId: '{{ item.physicalResourceId }}'
      resourceName: '{{ item.resourceName }}'
      resourceType: '{{ item.resourceType }}'
      sourceType: '{{ item.sourceType }}'
- discovery_id: aws.resiliencehub.describeAppVersionResourcesResolutionStatus
  calls:
  - action: describeAppVersionResourcesResolutionStatus
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.appArn }}'
- discovery_id: aws.resiliencehub.describeAppVersionTemplate
  calls:
  - action: describeAppVersionTemplate
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.appArn }}'
- discovery_id: aws.resiliencehub.describeDraftAppVersionResourcesImportStatus
  calls:
  - action: describeDraftAppVersionResourcesImportStatus
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.errorDetails }}'
    item:
      errorMessage: '{{ item.errorMessage }}'
- discovery_id: aws.resiliencehub.describeMetricsExport
  calls:
  - action: describeMetricsExport
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.exportLocation }}'
    item:
      bucket: '{{ item.bucket }}'
      prefix: '{{ item.prefix }}'
- discovery_id: aws.resiliencehub.describeResiliencyPolicy
  calls:
  - action: describeResiliencyPolicy
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.policy }}'
    item:
      creationTime: '{{ item.creationTime }}'
      dataLocationConstraint: '{{ item.dataLocationConstraint }}'
      estimatedCostTier: '{{ item.estimatedCostTier }}'
      policy: '{{ item.policy }}'
      policyArn: '{{ item.policyArn }}'
      policyDescription: '{{ item.policyDescription }}'
      policyName: '{{ item.policyName }}'
      tags: '{{ item.tags }}'
      tier: '{{ item.tier }}'
- discovery_id: aws.resiliencehub.describeResourceGroupingRecommendationTask
  calls:
  - action: describeResourceGroupingRecommendationTask
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.errorMessage }}'
- discovery_id: aws.resiliencehub.listAlarmRecommendations
  calls:
  - action: listAlarmRecommendations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.alarmRecommendations }}'
    item:
      appComponentName: '{{ item.appComponentName }}'
      appComponentNames: '{{ item.appComponentNames }}'
      description: '{{ item.description }}'
      items: '{{ item.items }}'
      name: '{{ item.name }}'
      prerequisite: '{{ item.prerequisite }}'
      recommendationId: '{{ item.recommendationId }}'
      recommendationStatus: '{{ item.recommendationStatus }}'
      referenceId: '{{ item.referenceId }}'
      type: '{{ item.type }}'
- discovery_id: aws.resiliencehub.listAppAssessmentComplianceDrifts
  calls:
  - action: listAppAssessmentComplianceDrifts
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.complianceDrifts }}'
    item:
      actualReferenceId: '{{ item.actualReferenceId }}'
      actualValue: '{{ item.actualValue }}'
      appId: '{{ item.appId }}'
      appVersion: '{{ item.appVersion }}'
      diffType: '{{ item.diffType }}'
      driftType: '{{ item.driftType }}'
      entityId: '{{ item.entityId }}'
      entityType: '{{ item.entityType }}'
      expectedReferenceId: '{{ item.expectedReferenceId }}'
      expectedValue: '{{ item.expectedValue }}'
- discovery_id: aws.resiliencehub.listAppAssessmentResourceDrifts
  calls:
  - action: listAppAssessmentResourceDrifts
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.resourceDrifts }}'
    item:
      appArn: '{{ item.appArn }}'
      appVersion: '{{ item.appVersion }}'
      diffType: '{{ item.diffType }}'
      referenceId: '{{ item.referenceId }}'
      resourceIdentifier: '{{ item.resourceIdentifier }}'
- discovery_id: aws.resiliencehub.listAppComponentCompliances
  calls:
  - action: listAppComponentCompliances
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.componentCompliances }}'
    item:
      appComponentName: '{{ item.appComponentName }}'
      compliance: '{{ item.compliance }}'
      cost: '{{ item.cost }}'
      message: '{{ item.message }}'
      resiliencyScore: '{{ item.resiliencyScore }}'
      status: '{{ item.status }}'
- discovery_id: aws.resiliencehub.listAppComponentRecommendations
  calls:
  - action: listAppComponentRecommendations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.componentRecommendations }}'
    item:
      appComponentName: '{{ item.appComponentName }}'
      configRecommendations: '{{ item.configRecommendations }}'
      recommendationStatus: '{{ item.recommendationStatus }}'
- discovery_id: aws.resiliencehub.listAppInputSources
  calls:
  - action: listAppInputSources
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.appInputSources }}'
    item:
      eksSourceClusterNamespace: '{{ item.eksSourceClusterNamespace }}'
      importType: '{{ item.importType }}'
      resourceCount: '{{ item.resourceCount }}'
      sourceArn: '{{ item.sourceArn }}'
      sourceName: '{{ item.sourceName }}'
      terraformSource: '{{ item.terraformSource }}'
- discovery_id: aws.resiliencehub.listAppVersionAppComponents
  calls:
  - action: listAppVersionAppComponents
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.appComponents }}'
    item:
      additionalInfo: '{{ item.additionalInfo }}'
      id: '{{ item.id }}'
      name: '{{ item.name }}'
      type: '{{ item.type }}'
- discovery_id: aws.resiliencehub.listAppVersionResourceMappings
  calls:
  - action: listAppVersionResourceMappings
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.resourceMappings }}'
    item:
      appRegistryAppName: '{{ item.appRegistryAppName }}'
      eksSourceName: '{{ item.eksSourceName }}'
      logicalStackName: '{{ item.logicalStackName }}'
      mappingType: '{{ item.mappingType }}'
      physicalResourceId: '{{ item.physicalResourceId }}'
      resourceGroupName: '{{ item.resourceGroupName }}'
      resourceName: '{{ item.resourceName }}'
      terraformSourceName: '{{ item.terraformSourceName }}'
- discovery_id: aws.resiliencehub.listAppVersionResources
  calls:
  - action: listAppVersionResources
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.physicalResources }}'
    item:
      additionalInfo: '{{ item.additionalInfo }}'
      appComponents: '{{ item.appComponents }}'
      excluded: '{{ item.excluded }}'
      logicalResourceId: '{{ item.logicalResourceId }}'
      parentResourceName: '{{ item.parentResourceName }}'
      physicalResourceId: '{{ item.physicalResourceId }}'
      resourceName: '{{ item.resourceName }}'
      resourceType: '{{ item.resourceType }}'
      sourceType: '{{ item.sourceType }}'
- discovery_id: aws.resiliencehub.listAppVersions
  calls:
  - action: listAppVersions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.appVersions }}'
    item:
      appVersion: '{{ item.appVersion }}'
      creationTime: '{{ item.creationTime }}'
      identifier: '{{ item.identifier }}'
      versionName: '{{ item.versionName }}'
- discovery_id: aws.resiliencehub.listSopRecommendations
  calls:
  - action: listSopRecommendations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.sopRecommendations }}'
    item:
      appComponentName: '{{ item.appComponentName }}'
      description: '{{ item.description }}'
      items: '{{ item.items }}'
      name: '{{ item.name }}'
      prerequisite: '{{ item.prerequisite }}'
      recommendationId: '{{ item.recommendationId }}'
      recommendationStatus: '{{ item.recommendationStatus }}'
      referenceId: '{{ item.referenceId }}'
      serviceType: '{{ item.serviceType }}'
- discovery_id: aws.resiliencehub.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tags }}'
- discovery_id: aws.resiliencehub.listTestRecommendations
  calls:
  - action: listTestRecommendations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.testRecommendations }}'
    item:
      appComponentId: '{{ item.appComponentId }}'
      appComponentName: '{{ item.appComponentName }}'
      dependsOnAlarms: '{{ item.dependsOnAlarms }}'
      description: '{{ item.description }}'
      intent: '{{ item.intent }}'
      items: '{{ item.items }}'
      name: '{{ item.name }}'
      prerequisite: '{{ item.prerequisite }}'
      recommendationId: '{{ item.recommendationId }}'
      recommendationStatus: '{{ item.recommendationStatus }}'
      referenceId: '{{ item.referenceId }}'
      risk: '{{ item.risk }}'
      type: '{{ item.type }}'
- discovery_id: aws.resiliencehub.listUnsupportedAppVersionResources
  calls:
  - action: listUnsupportedAppVersionResources
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.unsupportedResources }}'
    item:
      logicalResourceId: '{{ item.logicalResourceId }}'
      physicalResourceId: '{{ item.physicalResourceId }}'
      resourceType: '{{ item.resourceType }}'
      unsupportedResourceStatus: '{{ item.unsupportedResourceStatus }}'
checks: []
