version: '1.0'
provider: aws
service: connectcases
services:
  client: connectcases
  module: boto3.client
discovery:
- discovery_id: aws.connectcases.listDomains
  calls:
  - action: listDomains
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.domains }}'
    item:
      domainId: '{{ item.domainId }}'
      domainArn: '{{ item.domainArn }}'
      name: '{{ item.name }}'
- discovery_id: aws.connectcases.getCase
  calls:
  - action: getCase
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.fields }}'
    item:
      id: '{{ item.id }}'
      value: '{{ item.value }}'
- discovery_id: aws.connectcases.getCaseAuditEvents
  calls:
  - action: getCaseAuditEvents
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.auditEvents }}'
    item:
      eventId: '{{ item.eventId }}'
      type: '{{ item.type }}'
      relatedItemType: '{{ item.relatedItemType }}'
      performedTime: '{{ item.performedTime }}'
      fields: '{{ item.fields }}'
      performedBy: '{{ item.performedBy }}'
- discovery_id: aws.connectcases.getCaseEventConfiguration
  calls:
  - action: getCaseEventConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.eventBridge }}'
    item:
      enabled: '{{ item.enabled }}'
      includedData: '{{ item.includedData }}'
- discovery_id: aws.connectcases.getDomain
  calls:
  - action: getDomain
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.domainId }}'
- discovery_id: aws.connectcases.getLayout
  calls:
  - action: getLayout
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.content }}'
    item:
      basic: '{{ item.basic }}'
- discovery_id: aws.connectcases.getTemplate
  calls:
  - action: getTemplate
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.requiredFields }}'
    item:
      fieldId: '{{ item.fieldId }}'
- discovery_id: aws.connectcases.listCaseRules
  calls:
  - action: listCaseRules
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.caseRules }}'
    item:
      caseRuleId: '{{ item.caseRuleId }}'
      name: '{{ item.name }}'
      caseRuleArn: '{{ item.caseRuleArn }}'
      ruleType: '{{ item.ruleType }}'
      description: '{{ item.description }}'
- discovery_id: aws.connectcases.listCasesForContact
  calls:
  - action: listCasesForContact
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.cases }}'
    item:
      caseId: '{{ item.caseId }}'
      templateId: '{{ item.templateId }}'
- discovery_id: aws.connectcases.listFieldOptions
  calls:
  - action: listFieldOptions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.options }}'
    item:
      name: '{{ item.name }}'
      value: '{{ item.value }}'
      active: '{{ item.active }}'
- discovery_id: aws.connectcases.listFields
  calls:
  - action: listFields
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.fields }}'
    item:
      fieldId: '{{ item.fieldId }}'
      fieldArn: '{{ item.fieldArn }}'
      name: '{{ item.name }}'
      type: '{{ item.type }}'
      namespace: '{{ item.namespace }}'
- discovery_id: aws.connectcases.listLayouts
  calls:
  - action: listLayouts
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.layouts }}'
    item:
      layoutId: '{{ item.layoutId }}'
      layoutArn: '{{ item.layoutArn }}'
      name: '{{ item.name }}'
- discovery_id: aws.connectcases.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tags }}'
- discovery_id: aws.connectcases.listTemplates
  calls:
  - action: listTemplates
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.templates }}'
    item:
      templateId: '{{ item.templateId }}'
      templateArn: '{{ item.templateArn }}'
      name: '{{ item.name }}'
      status: '{{ item.status }}'
- discovery_id: aws.connectcases.searchAllRelatedItems
  calls:
  - action: searchAllRelatedItems
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.relatedItems }}'
    item:
      relatedItemId: '{{ item.relatedItemId }}'
      caseId: '{{ item.caseId }}'
      type: '{{ item.type }}'
      associationTime: '{{ item.associationTime }}'
      content: '{{ item.content }}'
      performedBy: '{{ item.performedBy }}'
      tags: '{{ item.tags }}'
- discovery_id: aws.connectcases.searchCases
  calls:
  - action: searchCases
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.cases }}'
    item:
      caseId: '{{ item.caseId }}'
      templateId: '{{ item.templateId }}'
      fields: '{{ item.fields }}'
      tags: '{{ item.tags }}'
- discovery_id: aws.connectcases.searchRelatedItems
  calls:
  - action: searchRelatedItems
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.relatedItems }}'
    item:
      relatedItemId: '{{ item.relatedItemId }}'
      type: '{{ item.type }}'
      associationTime: '{{ item.associationTime }}'
      content: '{{ item.content }}'
      tags: '{{ item.tags }}'
      performedBy: '{{ item.performedBy }}'
checks: []
