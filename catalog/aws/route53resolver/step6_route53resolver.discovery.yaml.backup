    items_for: '{{ response.FirewallRuleGroupAssociations }}'
    item:
      Id: '{{ item.Id }}'
      Arn: '{{ item.Arn }}'
      FirewallRuleGroupId: '{{ item.FirewallRuleGroupId }}'
      VpcId: '{{ item.VpcId }}'
      Name: '{{ item.Name }}'
      Priority: '{{ item.Priority }}'
      MutationProtection: '{{ item.MutationProtection }}'
      ManagedOwnerName: '{{ item.ManagedOwnerName }}'
      Status: '{{ item.Status }}'
      StatusMessage: '{{ item.StatusMessage }}'
      CreatorRequestId: '{{ item.CreatorRequestId }}'
      CreationTime: '{{ item.CreationTime }}'
      ModificationTime: '{{ item.ModificationTime }}'
- discovery_id: aws.route53resolver.listFirewallRuleGroups
  calls:
  - action: listFirewallRuleGroups
    save_as: response
    on_error: continue
    params:
