version: '1.0'
provider: aws
service: route53resolver
services:
  client: route53resolver
  module: boto3.client
discovery:
- discovery_id: aws.route53resolver.listFirewallConfigs
  calls:
  - action: listFirewallConfigs
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.FirewallConfigs }}'
    item:
      Id: '{{ item.Id }}'
      ResourceId: '{{ item.ResourceId }}'
      OwnerId: '{{ item.OwnerId }}'
      FirewallFailOpen: '{{ item.FirewallFailOpen }}'
- discovery_id: aws.route53resolver.listFirewallDomainLists
  calls:
  - action: listFirewallDomainLists
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.FirewallDomainLists }}'
    item:
      Id: '{{ item.Id }}'
      Arn: '{{ item.Arn }}'
      Name: '{{ item.Name }}'
      CreatorRequestId: '{{ item.CreatorRequestId }}'
      ManagedOwnerName: '{{ item.ManagedOwnerName }}'
- discovery_id: aws.route53resolver.listFirewallRuleGroupAssociations
  calls:
  - action: listFirewallRuleGroupAssociations
    save_as: response
    on_error: continue
    params:
