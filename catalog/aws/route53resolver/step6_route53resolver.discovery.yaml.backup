    item:
      Arn: '{{ item.Arn }}'
      CreationTime: '{{ item.CreationTime }}'
      ModificationTime: '{{ item.ModificationTime }}'
      CreatorRequestId: '{{ item.CreatorRequestId }}'
      Id: '{{ item.Id }}'
      InstanceCount: '{{ item.InstanceCount }}'
      PreferredInstanceType: '{{ item.PreferredInstanceType }}'
      Name: '{{ item.Name }}'
      Status: '{{ item.Status }}'
      StatusMessage: '{{ item.StatusMessage }}'
      OutpostArn: '{{ item.OutpostArn }}'
- discovery_id: aws.route53resolver.listResolverConfigs
  calls:
