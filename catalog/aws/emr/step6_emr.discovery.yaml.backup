version: '1.0'
provider: aws
service: emr
services:
  client: emr
  module: boto3.client
discovery:
- discovery_id: aws.emr.describeJobFlows
  calls:
  - action: describeJobFlows
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.JobFlows }}'
    item:
      JobFlowId: '{{ item.JobFlowId }}'
      Name: '{{ item.Name }}'
      LogUri: '{{ item.LogUri }}'
      LogEncryptionKmsKeyId: '{{ item.LogEncryptionKmsKeyId }}'
      AmiVersion: '{{ item.AmiVersion }}'
      ExecutionStatusDetail: '{{ item.ExecutionStatusDetail }}'
      Instances: '{{ item.Instances }}'
      Steps: '{{ item.Steps }}'
      BootstrapActions: '{{ item.BootstrapActions }}'
      SupportedProducts: '{{ item.SupportedProducts }}'
      VisibleToAllUsers: '{{ item.VisibleToAllUsers }}'
      JobFlowRole: '{{ item.JobFlowRole }}'
      ServiceRole: '{{ item.ServiceRole }}'
      AutoScalingRole: '{{ item.AutoScalingRole }}'
      ScaleDownBehavior: '{{ item.ScaleDownBehavior }}'
- discovery_id: aws.emr.describeReleaseLabel
  calls:
  - action: describeReleaseLabel
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Applications }}'
    item:
      Name: '{{ item.Name }}'
      Version: '{{ item.Version }}'
- discovery_id: aws.emr.getBlockPublicAccessConfiguration
  calls:
  - action: getBlockPublicAccessConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.BlockPublicAccessConfiguration }}'
    item:
      BlockPublicSecurityGroupRules: '{{ item.BlockPublicSecurityGroupRules }}'
      PermittedPublicSecurityGroupRuleRanges: '{{ item.PermittedPublicSecurityGroupRuleRanges
        }}'
- discovery_id: aws.emr.listClusters
  calls:
  - action: listClusters
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Clusters }}'
    item:
      Id: '{{ item.Id }}'
      Name: '{{ item.Name }}'
      Status: '{{ item.Status }}'
      NormalizedInstanceHours: '{{ item.NormalizedInstanceHours }}'
      ClusterArn: '{{ item.ClusterArn }}'
      OutpostArn: '{{ item.OutpostArn }}'
- discovery_id: aws.emr.listNotebookExecutions
  calls:
  - action: listNotebookExecutions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.NotebookExecutions }}'
    item:
      NotebookExecutionId: '{{ item.NotebookExecutionId }}'
      EditorId: '{{ item.EditorId }}'
      NotebookExecutionName: '{{ item.NotebookExecutionName }}'
      Status: '{{ item.Status }}'
      StartTime: '{{ item.StartTime }}'
      EndTime: '{{ item.EndTime }}'
      NotebookS3Location: '{{ item.NotebookS3Location }}'
      ExecutionEngineId: '{{ item.ExecutionEngineId }}'
- discovery_id: aws.emr.listReleaseLabels
  calls:
  - action: listReleaseLabels
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.ReleaseLabels }}'
- discovery_id: aws.emr.listSecurityConfigurations
  calls:
  - action: listSecurityConfigurations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.SecurityConfigurations }}'
    item:
      Name: '{{ item.Name }}'
      CreationDateTime: '{{ item.CreationDateTime }}'
- discovery_id: aws.emr.listStudioSessionMappings
  calls:
  - action: listStudioSessionMappings
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.SessionMappings }}'
    item:
      StudioId: '{{ item.StudioId }}'
      IdentityId: '{{ item.IdentityId }}'
      IdentityName: '{{ item.IdentityName }}'
      IdentityType: '{{ item.IdentityType }}'
      SessionPolicyArn: '{{ item.SessionPolicyArn }}'
      CreationTime: '{{ item.CreationTime }}'
- discovery_id: aws.emr.listStudios
  calls:
  - action: listStudios
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Studios }}'
    item:
      StudioId: '{{ item.StudioId }}'
      Name: '{{ item.Name }}'
      VpcId: '{{ item.VpcId }}'
      Description: '{{ item.Description }}'
      Url: '{{ item.Url }}'
      AuthMode: '{{ item.AuthMode }}'
      CreationTime: '{{ item.CreationTime }}'
- discovery_id: aws.emr.describeCluster
  calls:
  - action: describeCluster
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Cluster }}'
    item:
      Id: '{{ item.Id }}'
      Name: '{{ item.Name }}'
      Status: '{{ item.Status }}'
      Ec2InstanceAttributes: '{{ item.Ec2InstanceAttributes }}'
      InstanceCollectionType: '{{ item.InstanceCollectionType }}'
      LogUri: '{{ item.LogUri }}'
      LogEncryptionKmsKeyId: '{{ item.LogEncryptionKmsKeyId }}'
      RequestedAmiVersion: '{{ item.RequestedAmiVersion }}'
      RunningAmiVersion: '{{ item.RunningAmiVersion }}'
      ReleaseLabel: '{{ item.ReleaseLabel }}'
      AutoTerminate: '{{ item.AutoTerminate }}'
      TerminationProtected: '{{ item.TerminationProtected }}'
      UnhealthyNodeReplacement: '{{ item.UnhealthyNodeReplacement }}'
      VisibleToAllUsers: '{{ item.VisibleToAllUsers }}'
      Applications: '{{ item.Applications }}'
      Tags: '{{ item.Tags }}'
      ServiceRole: '{{ item.ServiceRole }}'
      NormalizedInstanceHours: '{{ item.NormalizedInstanceHours }}'
      MasterPublicDnsName: '{{ item.MasterPublicDnsName }}'
      Configurations: '{{ item.Configurations }}'
      SecurityConfiguration: '{{ item.SecurityConfiguration }}'
      AutoScalingRole: '{{ item.AutoScalingRole }}'
      ScaleDownBehavior: '{{ item.ScaleDownBehavior }}'
      CustomAmiId: '{{ item.CustomAmiId }}'
      EbsRootVolumeSize: '{{ item.EbsRootVolumeSize }}'
      RepoUpgradeOnBoot: '{{ item.RepoUpgradeOnBoot }}'
      KerberosAttributes: '{{ item.KerberosAttributes }}'
      ClusterArn: '{{ item.ClusterArn }}'
      OutpostArn: '{{ item.OutpostArn }}'
      StepConcurrencyLevel: '{{ item.StepConcurrencyLevel }}'
      PlacementGroups: '{{ item.PlacementGroups }}'
      OSReleaseLabel: '{{ item.OSReleaseLabel }}'
      EbsRootVolumeIops: '{{ item.EbsRootVolumeIops }}'
      EbsRootVolumeThroughput: '{{ item.EbsRootVolumeThroughput }}'
      ExtendedSupport: '{{ item.ExtendedSupport }}'
      MonitoringConfiguration: '{{ item.MonitoringConfiguration }}'
- discovery_id: aws.emr.describeNotebookExecution
  calls:
  - action: describeNotebookExecution
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.NotebookExecution }}'
    item:
      NotebookExecutionId: '{{ item.NotebookExecutionId }}'
      EditorId: '{{ item.EditorId }}'
      ExecutionEngine: '{{ item.ExecutionEngine }}'
      NotebookExecutionName: '{{ item.NotebookExecutionName }}'
      NotebookParams: '{{ item.NotebookParams }}'
      Status: '{{ item.Status }}'
      StartTime: '{{ item.StartTime }}'
      EndTime: '{{ item.EndTime }}'
      Arn: '{{ item.Arn }}'
      OutputNotebookURI: '{{ item.OutputNotebookURI }}'
      LastStateChangeReason: '{{ item.LastStateChangeReason }}'
      NotebookInstanceSecurityGroupId: '{{ item.NotebookInstanceSecurityGroupId }}'
      Tags: '{{ item.Tags }}'
      NotebookS3Location: '{{ item.NotebookS3Location }}'
      OutputNotebookS3Location: '{{ item.OutputNotebookS3Location }}'
      OutputNotebookFormat: '{{ item.OutputNotebookFormat }}'
      EnvironmentVariables: '{{ item.EnvironmentVariables }}'
- discovery_id: aws.emr.describePersistentAppUi
  calls:
  - action: describePersistentAppUi
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.PersistentAppUI }}'
    item:
      PersistentAppUIId: '{{ item.PersistentAppUIId }}'
      PersistentAppUITypeList: '{{ item.PersistentAppUITypeList }}'
      PersistentAppUIStatus: '{{ item.PersistentAppUIStatus }}'
      AuthorId: '{{ item.AuthorId }}'
      CreationTime: '{{ item.CreationTime }}'
      LastModifiedTime: '{{ item.LastModifiedTime }}'
      LastStateChangeReason: '{{ item.LastStateChangeReason }}'
      Tags: '{{ item.Tags }}'
- discovery_id: aws.emr.describeSecurityConfiguration
  calls:
  - action: describeSecurityConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Name }}'
- discovery_id: aws.emr.describeStep
  calls:
  - action: describeStep
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Step }}'
    item:
      Id: '{{ item.Id }}'
      Name: '{{ item.Name }}'
      Config: '{{ item.Config }}'
      ActionOnFailure: '{{ item.ActionOnFailure }}'
      Status: '{{ item.Status }}'
      ExecutionRoleArn: '{{ item.ExecutionRoleArn }}'
      LogUri: '{{ item.LogUri }}'
      EncryptionKeyArn: '{{ item.EncryptionKeyArn }}'
- discovery_id: aws.emr.describeStudio
  calls:
  - action: describeStudio
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Studio }}'
    item:
      StudioId: '{{ item.StudioId }}'
      StudioArn: '{{ item.StudioArn }}'
      Name: '{{ item.Name }}'
      Description: '{{ item.Description }}'
      AuthMode: '{{ item.AuthMode }}'
      VpcId: '{{ item.VpcId }}'
      SubnetIds: '{{ item.SubnetIds }}'
      ServiceRole: '{{ item.ServiceRole }}'
      UserRole: '{{ item.UserRole }}'
      WorkspaceSecurityGroupId: '{{ item.WorkspaceSecurityGroupId }}'
      EngineSecurityGroupId: '{{ item.EngineSecurityGroupId }}'
      Url: '{{ item.Url }}'
      CreationTime: '{{ item.CreationTime }}'
      DefaultS3Location: '{{ item.DefaultS3Location }}'
      IdpAuthUrl: '{{ item.IdpAuthUrl }}'
      IdpRelayStateParameterName: '{{ item.IdpRelayStateParameterName }}'
      Tags: '{{ item.Tags }}'
      IdcInstanceArn: '{{ item.IdcInstanceArn }}'
      TrustedIdentityPropagationEnabled: '{{ item.TrustedIdentityPropagationEnabled
        }}'
      IdcUserAssignment: '{{ item.IdcUserAssignment }}'
      EncryptionKeyArn: '{{ item.EncryptionKeyArn }}'
- discovery_id: aws.emr.getAutoTerminationPolicy
  calls:
  - action: getAutoTerminationPolicy
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AutoTerminationPolicy }}'
    item:
      IdleTimeout: '{{ item.IdleTimeout }}'
- discovery_id: aws.emr.getClusterSessionCredentials
  calls:
  - action: getClusterSessionCredentials
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Credentials }}'
    item:
      UsernamePassword: '{{ item.UsernamePassword }}'
- discovery_id: aws.emr.getManagedScalingPolicy
  calls:
  - action: getManagedScalingPolicy
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ManagedScalingPolicy }}'
    item:
      ComputeLimits: '{{ item.ComputeLimits }}'
      UtilizationPerformanceIndex: '{{ item.UtilizationPerformanceIndex }}'
      ScalingStrategy: '{{ item.ScalingStrategy }}'
- discovery_id: aws.emr.getOnClusterAppUiPresignedUrl
  calls:
  - action: getOnClusterAppUiPresignedUrl
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.PresignedURLReady }}'
- discovery_id: aws.emr.getPersistentAppUiPresignedUrl
  calls:
  - action: getPersistentAppUiPresignedUrl
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.PresignedURLReady }}'
- discovery_id: aws.emr.getStudioSessionMapping
  calls:
  - action: getStudioSessionMapping
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.SessionMapping }}'
    item:
      StudioId: '{{ item.StudioId }}'
      IdentityId: '{{ item.IdentityId }}'
      IdentityName: '{{ item.IdentityName }}'
      IdentityType: '{{ item.IdentityType }}'
      SessionPolicyArn: '{{ item.SessionPolicyArn }}'
      CreationTime: '{{ item.CreationTime }}'
      LastModifiedTime: '{{ item.LastModifiedTime }}'
- discovery_id: aws.emr.listBootstrapActions
  calls:
  - action: listBootstrapActions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.BootstrapActions }}'
    item:
      Name: '{{ item.Name }}'
      ScriptPath: '{{ item.ScriptPath }}'
      Args: '{{ item.Args }}'
- discovery_id: aws.emr.listInstanceFleets
  calls:
  - action: listInstanceFleets
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.InstanceFleets }}'
    item:
      Id: '{{ item.Id }}'
      Name: '{{ item.Name }}'
      Status: '{{ item.Status }}'
      InstanceFleetType: '{{ item.InstanceFleetType }}'
      TargetOnDemandCapacity: '{{ item.TargetOnDemandCapacity }}'
      TargetSpotCapacity: '{{ item.TargetSpotCapacity }}'
      ProvisionedOnDemandCapacity: '{{ item.ProvisionedOnDemandCapacity }}'
      ProvisionedSpotCapacity: '{{ item.ProvisionedSpotCapacity }}'
      InstanceTypeSpecifications: '{{ item.InstanceTypeSpecifications }}'
      LaunchSpecifications: '{{ item.LaunchSpecifications }}'
      ResizeSpecifications: '{{ item.ResizeSpecifications }}'
      Context: '{{ item.Context }}'
- discovery_id: aws.emr.listInstanceGroups
  calls:
  - action: listInstanceGroups
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.InstanceGroups }}'
    item:
      Id: '{{ item.Id }}'
      Name: '{{ item.Name }}'
      Market: '{{ item.Market }}'
      InstanceGroupType: '{{ item.InstanceGroupType }}'
      BidPrice: '{{ item.BidPrice }}'
      InstanceType: '{{ item.InstanceType }}'
      RequestedInstanceCount: '{{ item.RequestedInstanceCount }}'
      RunningInstanceCount: '{{ item.RunningInstanceCount }}'
      Status: '{{ item.Status }}'
      Configurations: '{{ item.Configurations }}'
      ConfigurationsVersion: '{{ item.ConfigurationsVersion }}'
      LastSuccessfullyAppliedConfigurations: '{{ item.LastSuccessfullyAppliedConfigurations
        }}'
      LastSuccessfullyAppliedConfigurationsVersion: '{{ item.LastSuccessfullyAppliedConfigurationsVersion
        }}'
      EbsBlockDevices: '{{ item.EbsBlockDevices }}'
      EbsOptimized: '{{ item.EbsOptimized }}'
      ShrinkPolicy: '{{ item.ShrinkPolicy }}'
      AutoScalingPolicy: '{{ item.AutoScalingPolicy }}'
      CustomAmiId: '{{ item.CustomAmiId }}'
- discovery_id: aws.emr.listInstances
  calls:
  - action: listInstances
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Instances }}'
    item:
      Id: '{{ item.Id }}'
      Ec2InstanceId: '{{ item.Ec2InstanceId }}'
      PublicDnsName: '{{ item.PublicDnsName }}'
      PublicIpAddress: '{{ item.PublicIpAddress }}'
      PrivateDnsName: '{{ item.PrivateDnsName }}'
      PrivateIpAddress: '{{ item.PrivateIpAddress }}'
      Status: '{{ item.Status }}'
      InstanceGroupId: '{{ item.InstanceGroupId }}'
      InstanceFleetId: '{{ item.InstanceFleetId }}'
      Market: '{{ item.Market }}'
      InstanceType: '{{ item.InstanceType }}'
      EbsVolumes: '{{ item.EbsVolumes }}'
- discovery_id: aws.emr.listSteps
  calls:
  - action: listSteps
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Steps }}'
    item:
      Id: '{{ item.Id }}'
      Name: '{{ item.Name }}'
      Config: '{{ item.Config }}'
      ActionOnFailure: '{{ item.ActionOnFailure }}'
      Status: '{{ item.Status }}'
      LogUri: '{{ item.LogUri }}'
      EncryptionKeyArn: '{{ item.EncryptionKeyArn }}'
- discovery_id: aws.emr.listSupportedInstanceTypes
  calls:
  - action: listSupportedInstanceTypes
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.SupportedInstanceTypes }}'
    item:
      Type: '{{ item.Type }}'
      MemoryGB: '{{ item.MemoryGB }}'
      StorageGB: '{{ item.StorageGB }}'
      VCPU: '{{ item.VCPU }}'
      Is64BitsOnly: '{{ item.Is64BitsOnly }}'
      InstanceFamilyId: '{{ item.InstanceFamilyId }}'
      EbsOptimizedAvailable: '{{ item.EbsOptimizedAvailable }}'
      EbsOptimizedByDefault: '{{ item.EbsOptimizedByDefault }}'
      NumberOfDisks: '{{ item.NumberOfDisks }}'
      EbsStorageOnly: '{{ item.EbsStorageOnly }}'
      Architecture: '{{ item.Architecture }}'
checks: []
