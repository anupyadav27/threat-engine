version: '1.0'
provider: aws
service: iotevents-data
services:
  client: iotevents-data
  module: boto3.client
discovery:
- discovery_id: aws.iotevents-data.describeAlarm
  calls:
  - action: describeAlarm
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.alarm }}'
    item:
      alarmModelName: '{{ item.alarmModelName }}'
      alarmModelVersion: '{{ item.alarmModelVersion }}'
      keyValue: '{{ item.keyValue }}'
      alarmState: '{{ item.alarmState }}'
      severity: '{{ item.severity }}'
      creationTime: '{{ item.creationTime }}'
      lastUpdateTime: '{{ item.lastUpdateTime }}'
- discovery_id: aws.iotevents-data.describeDetector
  calls:
  - action: describeDetector
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.detector }}'
    item:
      detectorModelName: '{{ item.detectorModelName }}'
      keyValue: '{{ item.keyValue }}'
      detectorModelVersion: '{{ item.detectorModelVersion }}'
      state: '{{ item.state }}'
      creationTime: '{{ item.creationTime }}'
      lastUpdateTime: '{{ item.lastUpdateTime }}'
- discovery_id: aws.iotevents-data.listAlarms
  calls:
  - action: listAlarms
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.alarmSummaries }}'
    item:
      alarmModelName: '{{ item.alarmModelName }}'
      alarmModelVersion: '{{ item.alarmModelVersion }}'
      keyValue: '{{ item.keyValue }}'
      stateName: '{{ item.stateName }}'
      creationTime: '{{ item.creationTime }}'
      lastUpdateTime: '{{ item.lastUpdateTime }}'
- discovery_id: aws.iotevents-data.listDetectors
  calls:
  - action: listDetectors
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.detectorSummaries }}'
    item:
      detectorModelName: '{{ item.detectorModelName }}'
      keyValue: '{{ item.keyValue }}'
      detectorModelVersion: '{{ item.detectorModelVersion }}'
      state: '{{ item.state }}'
      creationTime: '{{ item.creationTime }}'
      lastUpdateTime: '{{ item.lastUpdateTime }}'
checks: []
