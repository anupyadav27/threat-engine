version: '1.0'
provider: aws
service: ssm-contacts
services:
  client: ssm-contacts
  module: boto3.client
discovery:
- discovery_id: aws.ssm-contacts.listContacts
  calls:
  - action: listContacts
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Contacts }}'
    item:
      ContactArn: '{{ item.ContactArn }}'
      Alias: '{{ item.Alias }}'
      DisplayName: '{{ item.DisplayName }}'
      Type: '{{ item.Type }}'
- discovery_id: aws.ssm-contacts.listEngagements
  calls:
  - action: listEngagements
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Engagements }}'
    item:
      EngagementArn: '{{ item.EngagementArn }}'
      ContactArn: '{{ item.ContactArn }}'
      Sender: '{{ item.Sender }}'
      IncidentId: '{{ item.IncidentId }}'
      StartTime: '{{ item.StartTime }}'
      StopTime: '{{ item.StopTime }}'
- discovery_id: aws.ssm-contacts.listRotations
  calls:
  - action: listRotations
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Rotations }}'
    item:
      RotationArn: '{{ item.RotationArn }}'
      Name: '{{ item.Name }}'
      ContactIds: '{{ item.ContactIds }}'
      StartTime: '{{ item.StartTime }}'
      TimeZoneId: '{{ item.TimeZoneId }}'
      Recurrence: '{{ item.Recurrence }}'
- discovery_id: aws.ssm-contacts.describeEngagement
  calls:
  - action: describeEngagement
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ContactArn }}'
- discovery_id: aws.ssm-contacts.describePage
  calls:
  - action: describePage
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.PageArn }}'
- discovery_id: aws.ssm-contacts.getContact
  calls:
  - action: getContact
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Plan }}'
    item:
      Stages: '{{ item.Stages }}'
      RotationIds: '{{ item.RotationIds }}'
- discovery_id: aws.ssm-contacts.getContactChannel
  calls:
  - action: getContactChannel
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.DeliveryAddress }}'
    item:
      SimpleAddress: '{{ item.SimpleAddress }}'
- discovery_id: aws.ssm-contacts.getContactPolicy
  calls:
  - action: getContactPolicy
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ContactArn }}'
- discovery_id: aws.ssm-contacts.getRotation
  calls:
  - action: getRotation
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ContactIds }}'
- discovery_id: aws.ssm-contacts.getRotationOverride
  calls:
  - action: getRotationOverride
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.NewContactIds }}'
- discovery_id: aws.ssm-contacts.listContactChannels
  calls:
  - action: listContactChannels
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.ContactChannels }}'
    item:
      ContactChannelArn: '{{ item.ContactChannelArn }}'
      ContactArn: '{{ item.ContactArn }}'
      Name: '{{ item.Name }}'
      Type: '{{ item.Type }}'
      DeliveryAddress: '{{ item.DeliveryAddress }}'
      ActivationStatus: '{{ item.ActivationStatus }}'
- discovery_id: aws.ssm-contacts.listPageReceipts
  calls:
  - action: listPageReceipts
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Receipts }}'
    item:
      ContactChannelArn: '{{ item.ContactChannelArn }}'
      ReceiptType: '{{ item.ReceiptType }}'
      ReceiptInfo: '{{ item.ReceiptInfo }}'
      ReceiptTime: '{{ item.ReceiptTime }}'
- discovery_id: aws.ssm-contacts.listPageResolutions
  calls:
  - action: listPageResolutions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.PageResolutions }}'
    item:
      ContactArn: '{{ item.ContactArn }}'
      Type: '{{ item.Type }}'
      StageIndex: '{{ item.StageIndex }}'
- discovery_id: aws.ssm-contacts.listPagesByContact
  calls:
  - action: listPagesByContact
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Pages }}'
    item:
      PageArn: '{{ item.PageArn }}'
      EngagementArn: '{{ item.EngagementArn }}'
      ContactArn: '{{ item.ContactArn }}'
      Sender: '{{ item.Sender }}'
      IncidentId: '{{ item.IncidentId }}'
      SentTime: '{{ item.SentTime }}'
      DeliveryTime: '{{ item.DeliveryTime }}'
      ReadTime: '{{ item.ReadTime }}'
- discovery_id: aws.ssm-contacts.listPagesByEngagement
  calls:
  - action: listPagesByEngagement
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Pages }}'
    item:
      PageArn: '{{ item.PageArn }}'
      EngagementArn: '{{ item.EngagementArn }}'
      ContactArn: '{{ item.ContactArn }}'
      Sender: '{{ item.Sender }}'
      IncidentId: '{{ item.IncidentId }}'
      SentTime: '{{ item.SentTime }}'
      DeliveryTime: '{{ item.DeliveryTime }}'
      ReadTime: '{{ item.ReadTime }}'
- discovery_id: aws.ssm-contacts.listPreviewRotationShifts
  calls:
  - action: listPreviewRotationShifts
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.RotationShifts }}'
    item:
      ContactIds: '{{ item.ContactIds }}'
      StartTime: '{{ item.StartTime }}'
      EndTime: '{{ item.EndTime }}'
      Type: '{{ item.Type }}'
      ShiftDetails: '{{ item.ShiftDetails }}'
- discovery_id: aws.ssm-contacts.listRotationOverrides
  calls:
  - action: listRotationOverrides
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.RotationOverrides }}'
    item:
      RotationOverrideId: '{{ item.RotationOverrideId }}'
      NewContactIds: '{{ item.NewContactIds }}'
      StartTime: '{{ item.StartTime }}'
      EndTime: '{{ item.EndTime }}'
      CreateTime: '{{ item.CreateTime }}'
- discovery_id: aws.ssm-contacts.listRotationShifts
  calls:
  - action: listRotationShifts
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.RotationShifts }}'
    item:
      ContactIds: '{{ item.ContactIds }}'
      StartTime: '{{ item.StartTime }}'
      EndTime: '{{ item.EndTime }}'
      Type: '{{ item.Type }}'
      ShiftDetails: '{{ item.ShiftDetails }}'
- discovery_id: aws.ssm-contacts.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Tags }}'
    item:
      Key: '{{ item.Key }}'
      Value: '{{ item.Value }}'
checks: []
