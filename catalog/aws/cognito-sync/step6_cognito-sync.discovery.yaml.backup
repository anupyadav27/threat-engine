version: '1.0'
provider: aws
service: cognito-sync
services:
  client: cognito-sync
  module: boto3.client
discovery:
- discovery_id: aws.cognito-sync.listIdentityPoolUsage
  calls:
  - action: listIdentityPoolUsage
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.IdentityPoolUsages }}'
    item:
      IdentityPoolId: '{{ item.IdentityPoolId }}'
      SyncSessionsCount: '{{ item.SyncSessionsCount }}'
      DataStorage: '{{ item.DataStorage }}'
      LastModifiedDate: '{{ item.LastModifiedDate }}'
- discovery_id: aws.cognito-sync.describeDataset
  calls:
  - action: describeDataset
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Dataset }}'
    item:
      IdentityId: '{{ item.IdentityId }}'
      DatasetName: '{{ item.DatasetName }}'
      CreationDate: '{{ item.CreationDate }}'
      LastModifiedDate: '{{ item.LastModifiedDate }}'
      LastModifiedBy: '{{ item.LastModifiedBy }}'
      DataStorage: '{{ item.DataStorage }}'
      NumRecords: '{{ item.NumRecords }}'
- discovery_id: aws.cognito-sync.describeIdentityPoolUsage
  calls:
  - action: describeIdentityPoolUsage
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.IdentityPoolUsage }}'
    item:
      IdentityPoolId: '{{ item.IdentityPoolId }}'
      SyncSessionsCount: '{{ item.SyncSessionsCount }}'
      DataStorage: '{{ item.DataStorage }}'
      LastModifiedDate: '{{ item.LastModifiedDate }}'
- discovery_id: aws.cognito-sync.describeIdentityUsage
  calls:
  - action: describeIdentityUsage
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.IdentityUsage }}'
    item:
      IdentityId: '{{ item.IdentityId }}'
      IdentityPoolId: '{{ item.IdentityPoolId }}'
      LastModifiedDate: '{{ item.LastModifiedDate }}'
      DatasetCount: '{{ item.DatasetCount }}'
      DataStorage: '{{ item.DataStorage }}'
- discovery_id: aws.cognito-sync.getBulkPublishDetails
  calls:
  - action: getBulkPublishDetails
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.IdentityPoolId }}'
- discovery_id: aws.cognito-sync.getCognitoEvents
  calls:
  - action: getCognitoEvents
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Events }}'
- discovery_id: aws.cognito-sync.getIdentityPoolConfiguration
  calls:
  - action: getIdentityPoolConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.PushSync }}'
    item:
      ApplicationArns: '{{ item.ApplicationArns }}'
      RoleArn: '{{ item.RoleArn }}'
- discovery_id: aws.cognito-sync.listDatasets
  calls:
  - action: listDatasets
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Datasets }}'
    item:
      IdentityId: '{{ item.IdentityId }}'
      DatasetName: '{{ item.DatasetName }}'
      CreationDate: '{{ item.CreationDate }}'
      LastModifiedDate: '{{ item.LastModifiedDate }}'
      LastModifiedBy: '{{ item.LastModifiedBy }}'
      DataStorage: '{{ item.DataStorage }}'
      NumRecords: '{{ item.NumRecords }}'
- discovery_id: aws.cognito-sync.listRecords
  calls:
  - action: listRecords
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Records }}'
    item:
      Key: '{{ item.Key }}'
      Value: '{{ item.Value }}'
      SyncCount: '{{ item.SyncCount }}'
      LastModifiedDate: '{{ item.LastModifiedDate }}'
      LastModifiedBy: '{{ item.LastModifiedBy }}'
      DeviceLastModifiedDate: '{{ item.DeviceLastModifiedDate }}'
checks: []
