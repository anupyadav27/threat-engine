version: '1.0'
provider: aws
service: polly
services:
  client: polly
  module: boto3.client
discovery:
- discovery_id: aws.polly.describeVoices
  calls:
  - action: describeVoices
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Voices }}'
    item:
      Gender: '{{ item.Gender }}'
      Id: '{{ item.Id }}'
      LanguageCode: '{{ item.LanguageCode }}'
      LanguageName: '{{ item.LanguageName }}'
      Name: '{{ item.Name }}'
      AdditionalLanguageCodes: '{{ item.AdditionalLanguageCodes }}'
      SupportedEngines: '{{ item.SupportedEngines }}'
- discovery_id: aws.polly.listLexicons
  calls:
  - action: listLexicons
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Lexicons }}'
    item:
      Name: '{{ item.Name }}'
      Attributes: '{{ item.Attributes }}'
- discovery_id: aws.polly.listSpeechSynthesisTasks
  calls:
  - action: listSpeechSynthesisTasks
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.SynthesisTasks }}'
    item:
      Engine: '{{ item.Engine }}'
      TaskId: '{{ item.TaskId }}'
      TaskStatus: '{{ item.TaskStatus }}'
      TaskStatusReason: '{{ item.TaskStatusReason }}'
      OutputUri: '{{ item.OutputUri }}'
      CreationTime: '{{ item.CreationTime }}'
      RequestCharacters: '{{ item.RequestCharacters }}'
      SnsTopicArn: '{{ item.SnsTopicArn }}'
      LexiconNames: '{{ item.LexiconNames }}'
      OutputFormat: '{{ item.OutputFormat }}'
      SampleRate: '{{ item.SampleRate }}'
      SpeechMarkTypes: '{{ item.SpeechMarkTypes }}'
      TextType: '{{ item.TextType }}'
      VoiceId: '{{ item.VoiceId }}'
      LanguageCode: '{{ item.LanguageCode }}'
- discovery_id: aws.polly.getLexicon
  calls:
  - action: getLexicon
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Lexicon }}'
    item:
      Content: '{{ item.Content }}'
      Name: '{{ item.Name }}'
- discovery_id: aws.polly.getSpeechSynthesisTask
  calls:
  - action: getSpeechSynthesisTask
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.SynthesisTask }}'
    item:
      Engine: '{{ item.Engine }}'
      TaskId: '{{ item.TaskId }}'
      TaskStatus: '{{ item.TaskStatus }}'
      TaskStatusReason: '{{ item.TaskStatusReason }}'
      OutputUri: '{{ item.OutputUri }}'
      CreationTime: '{{ item.CreationTime }}'
      RequestCharacters: '{{ item.RequestCharacters }}'
      SnsTopicArn: '{{ item.SnsTopicArn }}'
      LexiconNames: '{{ item.LexiconNames }}'
      OutputFormat: '{{ item.OutputFormat }}'
      SampleRate: '{{ item.SampleRate }}'
      SpeechMarkTypes: '{{ item.SpeechMarkTypes }}'
      TextType: '{{ item.TextType }}'
      VoiceId: '{{ item.VoiceId }}'
      LanguageCode: '{{ item.LanguageCode }}'
checks: []
