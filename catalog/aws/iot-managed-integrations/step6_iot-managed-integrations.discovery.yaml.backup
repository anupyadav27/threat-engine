version: '1.0'
provider: aws
service: iot-managed-integrations
services:
  client: iot-managed-integrations
  module: boto3.client
discovery:
- discovery_id: aws.iot-managed-integrations.getCustomEndpoint
  calls:
  - action: getCustomEndpoint
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.EndpointAddress }}'
- discovery_id: aws.iot-managed-integrations.getDefaultEncryptionConfiguration
  calls:
  - action: getDefaultEncryptionConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.configurationStatus }}'
    item:
      error: '{{ item.error }}'
      state: '{{ item.state }}'
- discovery_id: aws.iot-managed-integrations.getHubConfiguration
  calls:
  - action: getHubConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.HubTokenTimerExpirySettingInSeconds }}'
- discovery_id: aws.iot-managed-integrations.listAccountAssociations
  calls:
  - action: listAccountAssociations
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Items }}'
    item:
      AccountAssociationId: '{{ item.AccountAssociationId }}'
      AssociationState: '{{ item.AssociationState }}'
      ErrorMessage: '{{ item.ErrorMessage }}'
      ConnectorDestinationId: '{{ item.ConnectorDestinationId }}'
      Name: '{{ item.Name }}'
      Description: '{{ item.Description }}'
      Arn: '{{ item.Arn }}'
- discovery_id: aws.iot-managed-integrations.listCloudConnectors
  calls:
  - action: listCloudConnectors
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Items }}'
    item:
      Name: '{{ item.Name }}'
      EndpointConfig: '{{ item.EndpointConfig }}'
      Description: '{{ item.Description }}'
      EndpointType: '{{ item.EndpointType }}'
      Id: '{{ item.Id }}'
      Type: '{{ item.Type }}'
- discovery_id: aws.iot-managed-integrations.listConnectorDestinations
  calls:
  - action: listConnectorDestinations
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.ConnectorDestinationList }}'
    item:
      Name: '{{ item.Name }}'
      Description: '{{ item.Description }}'
      CloudConnectorId: '{{ item.CloudConnectorId }}'
      Id: '{{ item.Id }}'
- discovery_id: aws.iot-managed-integrations.listCredentialLockers
  calls:
  - action: listCredentialLockers
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Items }}'
    item:
      Id: '{{ item.Id }}'
      Arn: '{{ item.Arn }}'
      Name: '{{ item.Name }}'
      CreatedAt: '{{ item.CreatedAt }}'
- discovery_id: aws.iot-managed-integrations.listDestinations
  calls:
  - action: listDestinations
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.DestinationList }}'
    item:
      Description: '{{ item.Description }}'
      DeliveryDestinationArn: '{{ item.DeliveryDestinationArn }}'
      DeliveryDestinationType: '{{ item.DeliveryDestinationType }}'
      Name: '{{ item.Name }}'
      RoleArn: '{{ item.RoleArn }}'
- discovery_id: aws.iot-managed-integrations.listDeviceDiscoveries
  calls:
  - action: listDeviceDiscoveries
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Items }}'
    item:
      Id: '{{ item.Id }}'
      DiscoveryType: '{{ item.DiscoveryType }}'
      Status: '{{ item.Status }}'
- discovery_id: aws.iot-managed-integrations.listEventLogConfigurations
  calls:
  - action: listEventLogConfigurations
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.EventLogConfigurationList }}'
    item:
      Id: '{{ item.Id }}'
      ResourceType: '{{ item.ResourceType }}'
      ResourceId: '{{ item.ResourceId }}'
      EventLogLevel: '{{ item.EventLogLevel }}'
- discovery_id: aws.iot-managed-integrations.listManagedThingAccountAssociations
  calls:
  - action: listManagedThingAccountAssociations
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Items }}'
    item:
      ManagedThingId: '{{ item.ManagedThingId }}'
      AccountAssociationId: '{{ item.AccountAssociationId }}'
- discovery_id: aws.iot-managed-integrations.listManagedThings
  calls:
  - action: listManagedThings
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Items }}'
    item:
      Id: '{{ item.Id }}'
      Arn: '{{ item.Arn }}'
      AdvertisedProductId: '{{ item.AdvertisedProductId }}'
      Brand: '{{ item.Brand }}'
      Classification: '{{ item.Classification }}'
      ConnectorDeviceId: '{{ item.ConnectorDeviceId }}'
      ConnectorPolicyId: '{{ item.ConnectorPolicyId }}'
      ConnectorDestinationId: '{{ item.ConnectorDestinationId }}'
      Model: '{{ item.Model }}'
      Name: '{{ item.Name }}'
      Owner: '{{ item.Owner }}'
      CredentialLockerId: '{{ item.CredentialLockerId }}'
      ParentControllerId: '{{ item.ParentControllerId }}'
      ProvisioningStatus: '{{ item.ProvisioningStatus }}'
      Role: '{{ item.Role }}'
      SerialNumber: '{{ item.SerialNumber }}'
      CreatedAt: '{{ item.CreatedAt }}'
      UpdatedAt: '{{ item.UpdatedAt }}'
      ActivatedAt: '{{ item.ActivatedAt }}'
- discovery_id: aws.iot-managed-integrations.listNotificationConfigurations
  calls:
  - action: listNotificationConfigurations
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.NotificationConfigurationList }}'
    item:
      EventType: '{{ item.EventType }}'
      DestinationName: '{{ item.DestinationName }}'
- discovery_id: aws.iot-managed-integrations.listOtaTaskConfigurations
  calls:
  - action: listOtaTaskConfigurations
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Items }}'
    item:
      TaskConfigurationId: '{{ item.TaskConfigurationId }}'
      Name: '{{ item.Name }}'
      CreatedAt: '{{ item.CreatedAt }}'
- discovery_id: aws.iot-managed-integrations.listOtaTasks
  calls:
  - action: listOtaTasks
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Tasks }}'
    item:
      TaskId: '{{ item.TaskId }}'
      TaskArn: '{{ item.TaskArn }}'
      CreatedAt: '{{ item.CreatedAt }}'
      LastUpdatedAt: '{{ item.LastUpdatedAt }}'
      TaskConfigurationId: '{{ item.TaskConfigurationId }}'
      Status: '{{ item.Status }}'
- discovery_id: aws.iot-managed-integrations.listProvisioningProfiles
  calls:
  - action: listProvisioningProfiles
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Items }}'
    item:
      Name: '{{ item.Name }}'
      Id: '{{ item.Id }}'
      Arn: '{{ item.Arn }}'
      ProvisioningType: '{{ item.ProvisioningType }}'
- discovery_id: aws.iot-managed-integrations.getAccountAssociation
  calls:
  - action: getAccountAssociation
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AccountAssociationId }}'
- discovery_id: aws.iot-managed-integrations.getCloudConnector
  calls:
  - action: getCloudConnector
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.EndpointConfig }}'
    item:
      lambda: '{{ item.lambda }}'
- discovery_id: aws.iot-managed-integrations.getConnectorDestination
  calls:
  - action: getConnectorDestination
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AuthConfig }}'
    item:
      oAuth: '{{ item.oAuth }}'
- discovery_id: aws.iot-managed-integrations.getCredentialLocker
  calls:
  - action: getCredentialLocker
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Id }}'
- discovery_id: aws.iot-managed-integrations.getDestination
  calls:
  - action: getDestination
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Description }}'
- discovery_id: aws.iot-managed-integrations.getDeviceDiscovery
  calls:
  - action: getDeviceDiscovery
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Id }}'
- discovery_id: aws.iot-managed-integrations.getEventLogConfiguration
  calls:
  - action: getEventLogConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Id }}'
- discovery_id: aws.iot-managed-integrations.getManagedThing
  calls:
  - action: getManagedThing
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Id }}'
- discovery_id: aws.iot-managed-integrations.getManagedThingCapabilities
  calls:
  - action: getManagedThingCapabilities
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.CapabilityReport }}'
    item:
      version: '{{ item.version }}'
      nodeId: '{{ item.nodeId }}'
      endpoints: '{{ item.endpoints }}'
- discovery_id: aws.iot-managed-integrations.getManagedThingCertificate
  calls:
  - action: getManagedThingCertificate
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ManagedThingId }}'
- discovery_id: aws.iot-managed-integrations.getManagedThingConnectivityData
  calls:
  - action: getManagedThingConnectivityData
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ManagedThingId }}'
- discovery_id: aws.iot-managed-integrations.getManagedThingMetaData
  calls:
  - action: getManagedThingMetaData
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ManagedThingId }}'
- discovery_id: aws.iot-managed-integrations.getManagedThingState
  calls:
  - action: getManagedThingState
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Endpoints }}'
    item:
      endpointId: '{{ item.endpointId }}'
      capabilities: '{{ item.capabilities }}'
- discovery_id: aws.iot-managed-integrations.getNotificationConfiguration
  calls:
  - action: getNotificationConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.EventType }}'
- discovery_id: aws.iot-managed-integrations.getOtaTask
  calls:
  - action: getOtaTask
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Target }}'
- discovery_id: aws.iot-managed-integrations.getOtaTaskConfiguration
  calls:
  - action: getOtaTaskConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.PushConfig }}'
    item:
      AbortConfig: '{{ item.AbortConfig }}'
      RolloutConfig: '{{ item.RolloutConfig }}'
      TimeoutConfig: '{{ item.TimeoutConfig }}'
- discovery_id: aws.iot-managed-integrations.getProvisioningProfile
  calls:
  - action: getProvisioningProfile
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Arn }}'
- discovery_id: aws.iot-managed-integrations.getRuntimeLogConfiguration
  calls:
  - action: getRuntimeLogConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.RuntimeLogConfigurations }}'
    item:
      LogLevel: '{{ item.LogLevel }}'
      LogFlushLevel: '{{ item.LogFlushLevel }}'
      LocalStoreLocation: '{{ item.LocalStoreLocation }}'
      LocalStoreFileRotationMaxFiles: '{{ item.LocalStoreFileRotationMaxFiles }}'
      LocalStoreFileRotationMaxBytes: '{{ item.LocalStoreFileRotationMaxBytes }}'
      UploadLog: '{{ item.UploadLog }}'
      UploadPeriodMinutes: '{{ item.UploadPeriodMinutes }}'
      DeleteLocalStoreAfterUpload: '{{ item.DeleteLocalStoreAfterUpload }}'
- discovery_id: aws.iot-managed-integrations.getSchemaVersion
  calls:
  - action: getSchemaVersion
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Schema }}'
- discovery_id: aws.iot-managed-integrations.listDiscoveredDevices
  calls:
  - action: listDiscoveredDevices
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Items }}'
    item:
      ConnectorDeviceId: '{{ item.ConnectorDeviceId }}'
      ConnectorDeviceName: '{{ item.ConnectorDeviceName }}'
      DeviceTypes: '{{ item.DeviceTypes }}'
      ManagedThingId: '{{ item.ManagedThingId }}'
      Modification: '{{ item.Modification }}'
      DiscoveredAt: '{{ item.DiscoveredAt }}'
      Brand: '{{ item.Brand }}'
      Model: '{{ item.Model }}'
      AuthenticationMaterial: '{{ item.AuthenticationMaterial }}'
- discovery_id: aws.iot-managed-integrations.listManagedThingSchemas
  calls:
  - action: listManagedThingSchemas
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Items }}'
    item:
      EndpointId: '{{ item.EndpointId }}'
      CapabilityId: '{{ item.CapabilityId }}'
      Schema: '{{ item.Schema }}'
- discovery_id: aws.iot-managed-integrations.listOtaTaskExecutions
  calls:
  - action: listOtaTaskExecutions
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.ExecutionSummaries }}'
    item:
      TaskExecutionSummary: '{{ item.TaskExecutionSummary }}'
      ManagedThingId: '{{ item.ManagedThingId }}'
- discovery_id: aws.iot-managed-integrations.listSchemaVersions
  calls:
  - action: listSchemaVersions
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Items }}'
    item:
      SchemaId: '{{ item.SchemaId }}'
      Type: '{{ item.Type }}'
      Description: '{{ item.Description }}'
      Namespace: '{{ item.Namespace }}'
      SemanticVersion: '{{ item.SemanticVersion }}'
      Visibility: '{{ item.Visibility }}'
- discovery_id: aws.iot-managed-integrations.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tags }}'
checks: []
