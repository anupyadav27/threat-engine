version: '1.0'
provider: aws
service: iotevents
services:
  client: iotevents
  module: boto3.client
discovery:
- discovery_id: aws.iotevents.describeLoggingOptions
  calls:
  - action: describeLoggingOptions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.loggingOptions }}'
    item:
      roleArn: '{{ item.roleArn }}'
      level: '{{ item.level }}'
      enabled: '{{ item.enabled }}'
      detectorDebugOptions: '{{ item.detectorDebugOptions }}'
- discovery_id: aws.iotevents.listAlarmModels
  calls:
  - action: listAlarmModels
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.alarmModelSummaries }}'
    item:
      creationTime: '{{ item.creationTime }}'
      alarmModelDescription: '{{ item.alarmModelDescription }}'
      alarmModelName: '{{ item.alarmModelName }}'
- discovery_id: aws.iotevents.listDetectorModels
  calls:
  - action: listDetectorModels
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.detectorModelSummaries }}'
    item:
      detectorModelName: '{{ item.detectorModelName }}'
      detectorModelDescription: '{{ item.detectorModelDescription }}'
      creationTime: '{{ item.creationTime }}'
- discovery_id: aws.iotevents.listInputs
  calls:
  - action: listInputs
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.inputSummaries }}'
    item:
      inputName: '{{ item.inputName }}'
      inputDescription: '{{ item.inputDescription }}'
      inputArn: '{{ item.inputArn }}'
      creationTime: '{{ item.creationTime }}'
      lastUpdateTime: '{{ item.lastUpdateTime }}'
      status: '{{ item.status }}'
- discovery_id: aws.iotevents.describeAlarmModel
  calls:
  - action: describeAlarmModel
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.alarmRule }}'
    item:
      simpleRule: '{{ item.simpleRule }}'
- discovery_id: aws.iotevents.describeDetectorModel
  calls:
  - action: describeDetectorModel
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.detectorModel }}'
    item:
      detectorModelDefinition: '{{ item.detectorModelDefinition }}'
      detectorModelConfiguration: '{{ item.detectorModelConfiguration }}'
- discovery_id: aws.iotevents.describeDetectorModelAnalysis
  calls:
  - action: describeDetectorModelAnalysis
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.status }}'
- discovery_id: aws.iotevents.describeInput
  calls:
  - action: describeInput
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.input }}'
    item:
      inputConfiguration: '{{ item.inputConfiguration }}'
      inputDefinition: '{{ item.inputDefinition }}'
- discovery_id: aws.iotevents.getDetectorModelAnalysisResults
  calls:
  - action: getDetectorModelAnalysisResults
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.analysisResults }}'
    item:
      type: '{{ item.type }}'
      level: '{{ item.level }}'
      message: '{{ item.message }}'
      locations: '{{ item.locations }}'
- discovery_id: aws.iotevents.listAlarmModelVersions
  calls:
  - action: listAlarmModelVersions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.alarmModelVersionSummaries }}'
    item:
      alarmModelName: '{{ item.alarmModelName }}'
      alarmModelArn: '{{ item.alarmModelArn }}'
      alarmModelVersion: '{{ item.alarmModelVersion }}'
      roleArn: '{{ item.roleArn }}'
      creationTime: '{{ item.creationTime }}'
      lastUpdateTime: '{{ item.lastUpdateTime }}'
      status: '{{ item.status }}'
      statusMessage: '{{ item.statusMessage }}'
- discovery_id: aws.iotevents.listDetectorModelVersions
  calls:
  - action: listDetectorModelVersions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.detectorModelVersionSummaries }}'
    item:
      detectorModelName: '{{ item.detectorModelName }}'
      detectorModelVersion: '{{ item.detectorModelVersion }}'
      detectorModelArn: '{{ item.detectorModelArn }}'
      roleArn: '{{ item.roleArn }}'
      creationTime: '{{ item.creationTime }}'
      lastUpdateTime: '{{ item.lastUpdateTime }}'
      status: '{{ item.status }}'
      evaluationMethod: '{{ item.evaluationMethod }}'
- discovery_id: aws.iotevents.listInputRoutings
  calls:
  - action: listInputRoutings
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.routedResources }}'
    item:
      name: '{{ item.name }}'
      arn: '{{ item.arn }}'
- discovery_id: aws.iotevents.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tags }}'
    item:
      key: '{{ item.key }}'
      value: '{{ item.value }}'
checks: []
