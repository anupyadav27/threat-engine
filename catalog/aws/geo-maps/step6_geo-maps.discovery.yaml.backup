version: '1.0'
provider: aws
service: geo-maps
services:
  client: geo-maps
  module: boto3.client
discovery:
- discovery_id: aws.geo-maps.getGlyphs
  calls:
  - action: getGlyphs
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Blob }}'
- discovery_id: aws.geo-maps.getSprites
  calls:
  - action: getSprites
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Blob }}'
- discovery_id: aws.geo-maps.getStaticMap
  calls:
  - action: getStaticMap
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Blob }}'
- discovery_id: aws.geo-maps.getStyleDescriptor
  calls:
  - action: getStyleDescriptor
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Blob }}'
- discovery_id: aws.geo-maps.getTile
  calls:
  - action: getTile
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Blob }}'
checks: []
