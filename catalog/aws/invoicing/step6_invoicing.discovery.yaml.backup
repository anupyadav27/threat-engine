version: '1.0'
provider: aws
service: invoicing
services:
  client: invoicing
  module: boto3.client
discovery:
- discovery_id: aws.invoicing.listInvoiceUnits
  calls:
  - action: listInvoiceUnits
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.InvoiceUnits }}'
    item:
      InvoiceUnitArn: '{{ item.InvoiceUnitArn }}'
      InvoiceReceiver: '{{ item.InvoiceReceiver }}'
      Name: '{{ item.Name }}'
      Description: '{{ item.Description }}'
      TaxInheritanceDisabled: '{{ item.TaxInheritanceDisabled }}'
      Rule: '{{ item.Rule }}'
      LastModified: '{{ item.LastModified }}'
- discovery_id: aws.invoicing.listProcurementPortalPreferences
  calls:
  - action: listProcurementPortalPreferences
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.ProcurementPortalPreferences }}'
    item:
      AwsAccountId: '{{ item.AwsAccountId }}'
      ProcurementPortalPreferenceArn: '{{ item.ProcurementPortalPreferenceArn }}'
      ProcurementPortalName: '{{ item.ProcurementPortalName }}'
      BuyerDomain: '{{ item.BuyerDomain }}'
      BuyerIdentifier: '{{ item.BuyerIdentifier }}'
      SupplierDomain: '{{ item.SupplierDomain }}'
      SupplierIdentifier: '{{ item.SupplierIdentifier }}'
      Selector: '{{ item.Selector }}'
      EinvoiceDeliveryEnabled: '{{ item.EinvoiceDeliveryEnabled }}'
      PurchaseOrderRetrievalEnabled: '{{ item.PurchaseOrderRetrievalEnabled }}'
      EinvoiceDeliveryPreferenceStatus: '{{ item.EinvoiceDeliveryPreferenceStatus
        }}'
      EinvoiceDeliveryPreferenceStatusReason: '{{ item.EinvoiceDeliveryPreferenceStatusReason
        }}'
      PurchaseOrderRetrievalPreferenceStatus: '{{ item.PurchaseOrderRetrievalPreferenceStatus
        }}'
      PurchaseOrderRetrievalPreferenceStatusReason: '{{ item.PurchaseOrderRetrievalPreferenceStatusReason
        }}'
      Version: '{{ item.Version }}'
      CreateDate: '{{ item.CreateDate }}'
      LastUpdateDate: '{{ item.LastUpdateDate }}'
- discovery_id: aws.invoicing.getInvoicePdf
  calls:
  - action: getInvoicePdf
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.InvoicePDF }}'
    item:
      InvoiceId: '{{ item.InvoiceId }}'
      DocumentUrl: '{{ item.DocumentUrl }}'
      DocumentUrlExpirationDate: '{{ item.DocumentUrlExpirationDate }}'
      SupplementalDocuments: '{{ item.SupplementalDocuments }}'
- discovery_id: aws.invoicing.getInvoiceUnit
  calls:
  - action: getInvoiceUnit
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Rule }}'
    item:
      LinkedAccounts: '{{ item.LinkedAccounts }}'
      BillSourceAccounts: '{{ item.BillSourceAccounts }}'
- discovery_id: aws.invoicing.getProcurementPortalPreference
  calls:
  - action: getProcurementPortalPreference
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ProcurementPortalPreference }}'
    item:
      AwsAccountId: '{{ item.AwsAccountId }}'
      ProcurementPortalPreferenceArn: '{{ item.ProcurementPortalPreferenceArn }}'
      ProcurementPortalName: '{{ item.ProcurementPortalName }}'
      BuyerDomain: '{{ item.BuyerDomain }}'
      BuyerIdentifier: '{{ item.BuyerIdentifier }}'
      SupplierDomain: '{{ item.SupplierDomain }}'
      SupplierIdentifier: '{{ item.SupplierIdentifier }}'
      Selector: '{{ item.Selector }}'
      ProcurementPortalSharedSecret: '{{ item.ProcurementPortalSharedSecret }}'
      ProcurementPortalInstanceEndpoint: '{{ item.ProcurementPortalInstanceEndpoint
        }}'
      PurchaseOrderRetrievalEndpoint: '{{ item.PurchaseOrderRetrievalEndpoint }}'
      TestEnvPreference: '{{ item.TestEnvPreference }}'
      EinvoiceDeliveryEnabled: '{{ item.EinvoiceDeliveryEnabled }}'
      EinvoiceDeliveryPreference: '{{ item.EinvoiceDeliveryPreference }}'
      PurchaseOrderRetrievalEnabled: '{{ item.PurchaseOrderRetrievalEnabled }}'
      Contacts: '{{ item.Contacts }}'
      EinvoiceDeliveryPreferenceStatus: '{{ item.EinvoiceDeliveryPreferenceStatus
        }}'
      EinvoiceDeliveryPreferenceStatusReason: '{{ item.EinvoiceDeliveryPreferenceStatusReason
        }}'
      PurchaseOrderRetrievalPreferenceStatus: '{{ item.PurchaseOrderRetrievalPreferenceStatus
        }}'
      PurchaseOrderRetrievalPreferenceStatusReason: '{{ item.PurchaseOrderRetrievalPreferenceStatusReason
        }}'
      Version: '{{ item.Version }}'
      CreateDate: '{{ item.CreateDate }}'
      LastUpdateDate: '{{ item.LastUpdateDate }}'
- discovery_id: aws.invoicing.listInvoiceSummaries
  calls:
  - action: listInvoiceSummaries
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.InvoiceSummaries }}'
    item:
      AccountId: '{{ item.AccountId }}'
      InvoiceId: '{{ item.InvoiceId }}'
      IssuedDate: '{{ item.IssuedDate }}'
      DueDate: '{{ item.DueDate }}'
      Entity: '{{ item.Entity }}'
      BillingPeriod: '{{ item.BillingPeriod }}'
      InvoiceType: '{{ item.InvoiceType }}'
      OriginalInvoiceId: '{{ item.OriginalInvoiceId }}'
      PurchaseOrderNumber: '{{ item.PurchaseOrderNumber }}'
      BaseCurrencyAmount: '{{ item.BaseCurrencyAmount }}'
      TaxCurrencyAmount: '{{ item.TaxCurrencyAmount }}'
      PaymentCurrencyAmount: '{{ item.PaymentCurrencyAmount }}'
- discovery_id: aws.invoicing.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ResourceTags }}'
    item:
      Key: '{{ item.Key }}'
      Value: '{{ item.Value }}'
checks: []
