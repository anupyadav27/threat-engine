      CapacityReservationIds: '{{ item.CapacityReservationIds }}'
      StartDate: '{{ item.StartDate }}'
      EndDate: '{{ item.EndDate }}'
      CreateDate: '{{ item.CreateDate }}'
      State: '{{ item.State }}'
      Tags: '{{ item.Tags }}'
- discovery_id: aws.vpc.describeCapacityManagerDataExports
  calls:
