version: '1.0'
provider: aws
service: vpc
services:
  client: vpc
  module: boto3.client
discovery:
- discovery_id: aws.vpc.describeAccountAttributes
  calls:
  - action: describeAccountAttributes
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AccountAttributes }}'
    item:
      AttributeName: '{{ item.AttributeName }}'
      AttributeValues: '{{ item.AttributeValues }}'
- discovery_id: aws.vpc.describeAddressTransfers
  calls:
  - action: describeAddressTransfers
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AddressTransfers }}'
    item:
      PublicIp: '{{ item.PublicIp }}'
      AllocationId: '{{ item.AllocationId }}'
      TransferAccountId: '{{ item.TransferAccountId }}'
      TransferOfferExpirationTimestamp: '{{ item.TransferOfferExpirationTimestamp
        }}'
      TransferOfferAcceptedTimestamp: '{{ item.TransferOfferAcceptedTimestamp }}'
      AddressTransferStatus: '{{ item.AddressTransferStatus }}'
- discovery_id: aws.vpc.describeAddresses
  calls:
  - action: describeAddresses
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Addresses }}'
    item:
      AllocationId: '{{ item.AllocationId }}'
      AssociationId: '{{ item.AssociationId }}'
      Domain: '{{ item.Domain }}'
      NetworkInterfaceId: '{{ item.NetworkInterfaceId }}'
      NetworkInterfaceOwnerId: '{{ item.NetworkInterfaceOwnerId }}'
      PrivateIpAddress: '{{ item.PrivateIpAddress }}'
      Tags: '{{ item.Tags }}'
      PublicIpv4Pool: '{{ item.PublicIpv4Pool }}'
      NetworkBorderGroup: '{{ item.NetworkBorderGroup }}'
      CustomerOwnedIp: '{{ item.CustomerOwnedIp }}'
      CustomerOwnedIpv4Pool: '{{ item.CustomerOwnedIpv4Pool }}'
      CarrierIp: '{{ item.CarrierIp }}'
      SubnetId: '{{ item.SubnetId }}'
      ServiceManaged: '{{ item.ServiceManaged }}'
      InstanceId: '{{ item.InstanceId }}'
      PublicIp: '{{ item.PublicIp }}'
- discovery_id: aws.vpc.describeAddressesAttribute
  calls:
  - action: describeAddressesAttribute
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Addresses }}'
    item:
      PublicIp: '{{ item.PublicIp }}'
      AllocationId: '{{ item.AllocationId }}'
      PtrRecord: '{{ item.PtrRecord }}'
      PtrRecordUpdate: '{{ item.PtrRecordUpdate }}'
- discovery_id: aws.vpc.describeAggregateIdFormat
  calls:
  - action: describeAggregateIdFormat
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Statuses }}'
    item:
      Deadline: '{{ item.Deadline }}'
      Resource: '{{ item.Resource }}'
      UseLongIds: '{{ item.UseLongIds }}'
- discovery_id: aws.vpc.describeAvailabilityZones
  calls:
  - action: describeAvailabilityZones
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AvailabilityZones }}'
    item:
      OptInStatus: '{{ item.OptInStatus }}'
      Messages: '{{ item.Messages }}'
      RegionName: '{{ item.RegionName }}'
      ZoneName: '{{ item.ZoneName }}'
      ZoneId: '{{ item.ZoneId }}'
      GroupName: '{{ item.GroupName }}'
      NetworkBorderGroup: '{{ item.NetworkBorderGroup }}'
      ZoneType: '{{ item.ZoneType }}'
      ParentZoneName: '{{ item.ParentZoneName }}'
      ParentZoneId: '{{ item.ParentZoneId }}'
      GroupLongName: '{{ item.GroupLongName }}'
      State: '{{ item.State }}'
- discovery_id: aws.vpc.describeAwsNetworkPerformanceMetricSubscriptions
  calls:
  - action: describeAwsNetworkPerformanceMetricSubscriptions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Subscriptions }}'
    item:
      Source: '{{ item.Source }}'
      Destination: '{{ item.Destination }}'
      Metric: '{{ item.Metric }}'
      Statistic: '{{ item.Statistic }}'
      Period: '{{ item.Period }}'
- discovery_id: aws.vpc.describeBundleTasks
  calls:
