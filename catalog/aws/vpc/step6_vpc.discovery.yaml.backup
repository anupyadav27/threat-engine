      CapacityBlockExtensionStartDate: '{{ item.CapacityBlockExtensionStartDate }}'
      CapacityBlockExtensionEndDate: '{{ item.CapacityBlockExtensionEndDate }}'
      UpfrontFee: '{{ item.UpfrontFee }}'
      CurrencyCode: '{{ item.CurrencyCode }}'
- discovery_id: aws.vpc.describeCapacityBlockStatus
  calls:
