    on_error: continue
  emit:
    as: item
    items_for: '{{ response.BundleTasks }}'
    item:
      InstanceId: '{{ item.InstanceId }}'
      BundleId: '{{ item.BundleId }}'
      State: '{{ item.State }}'
      StartTime: '{{ item.StartTime }}'
      UpdateTime: '{{ item.UpdateTime }}'
      Storage: '{{ item.Storage }}'
      Progress: '{{ item.Progress }}'
      BundleTaskError: '{{ item.BundleTaskError }}'
- discovery_id: aws.vpc.describeCapacityBlockExtensionHistory
  calls:
