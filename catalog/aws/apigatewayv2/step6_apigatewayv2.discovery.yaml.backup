version: '1.0'
provider: aws
service: apigatewayv2
services:
  client: apigatewayv2
  module: boto3.client
discovery:
- discovery_id: aws.apigatewayv2.getApis
  calls:
  - action: getApis
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Items }}'
    item:
      ApiEndpoint: '{{ item.ApiEndpoint }}'
      ApiGatewayManaged: '{{ item.ApiGatewayManaged }}'
      ApiId: '{{ item.ApiId }}'
      ApiKeySelectionExpression: '{{ item.ApiKeySelectionExpression }}'
      CorsConfiguration: '{{ item.CorsConfiguration }}'
      CreatedDate: '{{ item.CreatedDate }}'
      Description: '{{ item.Description }}'
      DisableSchemaValidation: '{{ item.DisableSchemaValidation }}'
      DisableExecuteApiEndpoint: '{{ item.DisableExecuteApiEndpoint }}'
      ImportInfo: '{{ item.ImportInfo }}'
      IpAddressType: '{{ item.IpAddressType }}'
      Name: '{{ item.Name }}'
      ProtocolType: '{{ item.ProtocolType }}'
      RouteSelectionExpression: '{{ item.RouteSelectionExpression }}'
      Tags: '{{ item.Tags }}'
      Version: '{{ item.Version }}'
      Warnings: '{{ item.Warnings }}'
- discovery_id: aws.apigatewayv2.getDomainNames
  calls:
  - action: getDomainNames
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Items }}'
    item:
      ApiMappingSelectionExpression: '{{ item.ApiMappingSelectionExpression }}'
      DomainName: '{{ item.DomainName }}'
      DomainNameArn: '{{ item.DomainNameArn }}'
      DomainNameConfigurations: '{{ item.DomainNameConfigurations }}'
      MutualTlsAuthentication: '{{ item.MutualTlsAuthentication }}'
      RoutingMode: '{{ item.RoutingMode }}'
      Tags: '{{ item.Tags }}'
- discovery_id: aws.apigatewayv2.getVpcLinks
  calls:
  - action: getVpcLinks
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Items }}'
    item:
      CreatedDate: '{{ item.CreatedDate }}'
      Name: '{{ item.Name }}'
      SecurityGroupIds: '{{ item.SecurityGroupIds }}'
      SubnetIds: '{{ item.SubnetIds }}'
      Tags: '{{ item.Tags }}'
      VpcLinkId: '{{ item.VpcLinkId }}'
      VpcLinkStatus: '{{ item.VpcLinkStatus }}'
      VpcLinkStatusMessage: '{{ item.VpcLinkStatusMessage }}'
      VpcLinkVersion: '{{ item.VpcLinkVersion }}'
- discovery_id: aws.apigatewayv2.listPortalProducts
  calls:
  - action: listPortalProducts
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Items }}'
    item:
      Description: '{{ item.Description }}'
      DisplayName: '{{ item.DisplayName }}'
      LastModified: '{{ item.LastModified }}'
      PortalProductArn: '{{ item.PortalProductArn }}'
      PortalProductId: '{{ item.PortalProductId }}'
      Tags: '{{ item.Tags }}'
- discovery_id: aws.apigatewayv2.listPortals
  calls:
  - action: listPortals
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Items }}'
    item:
      Authorization: '{{ item.Authorization }}'
      EndpointConfiguration: '{{ item.EndpointConfiguration }}'
      IncludedPortalProductArns: '{{ item.IncludedPortalProductArns }}'
      LastModified: '{{ item.LastModified }}'
      LastPublished: '{{ item.LastPublished }}'
      LastPublishedDescription: '{{ item.LastPublishedDescription }}'
      PortalArn: '{{ item.PortalArn }}'
      PortalContent: '{{ item.PortalContent }}'
      PortalId: '{{ item.PortalId }}'
      Preview: '{{ item.Preview }}'
      PublishStatus: '{{ item.PublishStatus }}'
      RumAppMonitorName: '{{ item.RumAppMonitorName }}'
      StatusException: '{{ item.StatusException }}'
      Tags: '{{ item.Tags }}'
- discovery_id: aws.apigatewayv2.getApi
  calls:
  - action: getApi
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ImportInfo }}'
- discovery_id: aws.apigatewayv2.getApiMapping
  calls:
  - action: getApiMapping
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ApiId }}'
- discovery_id: aws.apigatewayv2.getApiMappings
  calls:
  - action: getApiMappings
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Items }}'
    item:
      ApiId: '{{ item.ApiId }}'
      ApiMappingId: '{{ item.ApiMappingId }}'
      ApiMappingKey: '{{ item.ApiMappingKey }}'
      Stage: '{{ item.Stage }}'
- discovery_id: aws.apigatewayv2.getAuthorizer
  calls:
  - action: getAuthorizer
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.IdentitySource }}'
- discovery_id: aws.apigatewayv2.getAuthorizers
  calls:
  - action: getAuthorizers
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Items }}'
    item:
      AuthorizerCredentialsArn: '{{ item.AuthorizerCredentialsArn }}'
      AuthorizerId: '{{ item.AuthorizerId }}'
      AuthorizerPayloadFormatVersion: '{{ item.AuthorizerPayloadFormatVersion }}'
      AuthorizerResultTtlInSeconds: '{{ item.AuthorizerResultTtlInSeconds }}'
      AuthorizerType: '{{ item.AuthorizerType }}'
      AuthorizerUri: '{{ item.AuthorizerUri }}'
      EnableSimpleResponses: '{{ item.EnableSimpleResponses }}'
      IdentitySource: '{{ item.IdentitySource }}'
      IdentityValidationExpression: '{{ item.IdentityValidationExpression }}'
      JwtConfiguration: '{{ item.JwtConfiguration }}'
      Name: '{{ item.Name }}'
- discovery_id: aws.apigatewayv2.getDeployment
  calls:
  - action: getDeployment
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AutoDeployed }}'
- discovery_id: aws.apigatewayv2.getDeployments
  calls:
  - action: getDeployments
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Items }}'
    item:
      AutoDeployed: '{{ item.AutoDeployed }}'
      CreatedDate: '{{ item.CreatedDate }}'
      DeploymentId: '{{ item.DeploymentId }}'
      DeploymentStatus: '{{ item.DeploymentStatus }}'
      DeploymentStatusMessage: '{{ item.DeploymentStatusMessage }}'
      Description: '{{ item.Description }}'
- discovery_id: aws.apigatewayv2.getDomainName
  calls:
  - action: getDomainName
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.DomainNameConfigurations }}'
    item:
      ApiGatewayDomainName: '{{ item.ApiGatewayDomainName }}'
      CertificateArn: '{{ item.CertificateArn }}'
      CertificateName: '{{ item.CertificateName }}'
      CertificateUploadDate: '{{ item.CertificateUploadDate }}'
      DomainNameStatus: '{{ item.DomainNameStatus }}'
      DomainNameStatusMessage: '{{ item.DomainNameStatusMessage }}'
      EndpointType: '{{ item.EndpointType }}'
      HostedZoneId: '{{ item.HostedZoneId }}'
      IpAddressType: '{{ item.IpAddressType }}'
      SecurityPolicy: '{{ item.SecurityPolicy }}'
      OwnershipVerificationCertificateArn: '{{ item.OwnershipVerificationCertificateArn
        }}'
- discovery_id: aws.apigatewayv2.getIntegration
  calls:
  - action: getIntegration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.TlsConfig }}'
    item:
      ServerNameToVerify: '{{ item.ServerNameToVerify }}'
- discovery_id: aws.apigatewayv2.getIntegrationResponse
  calls:
  - action: getIntegrationResponse
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ContentHandlingStrategy }}'
- discovery_id: aws.apigatewayv2.getIntegrationResponses
  calls:
  - action: getIntegrationResponses
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Items }}'
    item:
      ContentHandlingStrategy: '{{ item.ContentHandlingStrategy }}'
      IntegrationResponseId: '{{ item.IntegrationResponseId }}'
      IntegrationResponseKey: '{{ item.IntegrationResponseKey }}'
      ResponseParameters: '{{ item.ResponseParameters }}'
      ResponseTemplates: '{{ item.ResponseTemplates }}'
      TemplateSelectionExpression: '{{ item.TemplateSelectionExpression }}'
- discovery_id: aws.apigatewayv2.getIntegrations
  calls:
  - action: getIntegrations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Items }}'
    item:
      ApiGatewayManaged: '{{ item.ApiGatewayManaged }}'
      ConnectionId: '{{ item.ConnectionId }}'
      ConnectionType: '{{ item.ConnectionType }}'
      ContentHandlingStrategy: '{{ item.ContentHandlingStrategy }}'
      CredentialsArn: '{{ item.CredentialsArn }}'
      Description: '{{ item.Description }}'
      IntegrationId: '{{ item.IntegrationId }}'
      IntegrationMethod: '{{ item.IntegrationMethod }}'
      IntegrationResponseSelectionExpression: '{{ item.IntegrationResponseSelectionExpression
        }}'
      IntegrationSubtype: '{{ item.IntegrationSubtype }}'
      IntegrationType: '{{ item.IntegrationType }}'
      IntegrationUri: '{{ item.IntegrationUri }}'
      PassthroughBehavior: '{{ item.PassthroughBehavior }}'
      PayloadFormatVersion: '{{ item.PayloadFormatVersion }}'
      RequestParameters: '{{ item.RequestParameters }}'
      RequestTemplates: '{{ item.RequestTemplates }}'
      ResponseParameters: '{{ item.ResponseParameters }}'
      TemplateSelectionExpression: '{{ item.TemplateSelectionExpression }}'
      TimeoutInMillis: '{{ item.TimeoutInMillis }}'
      TlsConfig: '{{ item.TlsConfig }}'
- discovery_id: aws.apigatewayv2.getModel
  calls:
  - action: getModel
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ContentType }}'
- discovery_id: aws.apigatewayv2.getModelTemplate
  calls:
  - action: getModelTemplate
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Value }}'
- discovery_id: aws.apigatewayv2.getModels
  calls:
  - action: getModels
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Items }}'
    item:
      ContentType: '{{ item.ContentType }}'
      Description: '{{ item.Description }}'
      ModelId: '{{ item.ModelId }}'
      Name: '{{ item.Name }}'
      Schema: '{{ item.Schema }}'
- discovery_id: aws.apigatewayv2.getPortal
  calls:
  - action: getPortal
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.IncludedPortalProductArns }}'
- discovery_id: aws.apigatewayv2.getPortalProduct
  calls:
  - action: getPortalProduct
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.DisplayOrder }}'
    item:
      Contents: '{{ item.Contents }}'
      OverviewPageArn: '{{ item.OverviewPageArn }}'
      ProductPageArns: '{{ item.ProductPageArns }}'
- discovery_id: aws.apigatewayv2.getPortalProductSharingPolicy
  calls:
  - action: getPortalProductSharingPolicy
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.PolicyDocument }}'
- discovery_id: aws.apigatewayv2.getProductPage
  calls:
  - action: getProductPage
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.DisplayContent }}'
    item:
      Body: '{{ item.Body }}'
      Title: '{{ item.Title }}'
- discovery_id: aws.apigatewayv2.getProductRestEndpointPage
  calls:
  - action: getProductRestEndpointPage
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.DisplayContent }}'
    item:
      Body: '{{ item.Body }}'
      Endpoint: '{{ item.Endpoint }}'
      OperationName: '{{ item.OperationName }}'
- discovery_id: aws.apigatewayv2.getRoute
  calls:
  - action: getRoute
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AuthorizationScopes }}'
- discovery_id: aws.apigatewayv2.getRouteResponse
  calls:
  - action: getRouteResponse
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ModelSelectionExpression }}'
- discovery_id: aws.apigatewayv2.getRouteResponses
  calls:
  - action: getRouteResponses
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Items }}'
    item:
      ModelSelectionExpression: '{{ item.ModelSelectionExpression }}'
      ResponseModels: '{{ item.ResponseModels }}'
      ResponseParameters: '{{ item.ResponseParameters }}'
      RouteResponseId: '{{ item.RouteResponseId }}'
      RouteResponseKey: '{{ item.RouteResponseKey }}'
- discovery_id: aws.apigatewayv2.getRoutes
  calls:
  - action: getRoutes
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Items }}'
    item:
      ApiGatewayManaged: '{{ item.ApiGatewayManaged }}'
      ApiKeyRequired: '{{ item.ApiKeyRequired }}'
      AuthorizationScopes: '{{ item.AuthorizationScopes }}'
      AuthorizationType: '{{ item.AuthorizationType }}'
      AuthorizerId: '{{ item.AuthorizerId }}'
      ModelSelectionExpression: '{{ item.ModelSelectionExpression }}'
      OperationName: '{{ item.OperationName }}'
      RequestModels: '{{ item.RequestModels }}'
      RequestParameters: '{{ item.RequestParameters }}'
      RouteId: '{{ item.RouteId }}'
      RouteKey: '{{ item.RouteKey }}'
      RouteResponseSelectionExpression: '{{ item.RouteResponseSelectionExpression
        }}'
      Target: '{{ item.Target }}'
- discovery_id: aws.apigatewayv2.getRoutingRule
  calls:
  - action: getRoutingRule
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Actions }}'
    item:
      InvokeApi: '{{ item.InvokeApi }}'
- discovery_id: aws.apigatewayv2.listRoutingRules
  calls:
  - action: listRoutingRules
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.RoutingRules }}'
    item:
      Actions: '{{ item.Actions }}'
      Conditions: '{{ item.Conditions }}'
      Priority: '{{ item.Priority }}'
      RoutingRuleArn: '{{ item.RoutingRuleArn }}'
      RoutingRuleId: '{{ item.RoutingRuleId }}'
- discovery_id: aws.apigatewayv2.getStage
  calls:
  - action: getStage
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AccessLogSettings }}'
    item:
      DestinationArn: '{{ item.DestinationArn }}'
      Format: '{{ item.Format }}'
- discovery_id: aws.apigatewayv2.getStages
  calls:
  - action: getStages
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Items }}'
    item:
      AccessLogSettings: '{{ item.AccessLogSettings }}'
      ApiGatewayManaged: '{{ item.ApiGatewayManaged }}'
      AutoDeploy: '{{ item.AutoDeploy }}'
      ClientCertificateId: '{{ item.ClientCertificateId }}'
      CreatedDate: '{{ item.CreatedDate }}'
      DefaultRouteSettings: '{{ item.DefaultRouteSettings }}'
      DeploymentId: '{{ item.DeploymentId }}'
      Description: '{{ item.Description }}'
      LastDeploymentStatusMessage: '{{ item.LastDeploymentStatusMessage }}'
      LastUpdatedDate: '{{ item.LastUpdatedDate }}'
      RouteSettings: '{{ item.RouteSettings }}'
      StageName: '{{ item.StageName }}'
      StageVariables: '{{ item.StageVariables }}'
      Tags: '{{ item.Tags }}'
- discovery_id: aws.apigatewayv2.getTags
  calls:
  - action: getTags
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Tags }}'
- discovery_id: aws.apigatewayv2.getVpcLink
  calls:
  - action: getVpcLink
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.SecurityGroupIds }}'
- discovery_id: aws.apigatewayv2.listProductPages
  calls:
  - action: listProductPages
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Items }}'
    item:
      LastModified: '{{ item.LastModified }}'
      PageTitle: '{{ item.PageTitle }}'
      ProductPageArn: '{{ item.ProductPageArn }}'
      ProductPageId: '{{ item.ProductPageId }}'
- discovery_id: aws.apigatewayv2.listProductRestEndpointPages
  calls:
  - action: listProductRestEndpointPages
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Items }}'
    item:
      Endpoint: '{{ item.Endpoint }}'
      LastModified: '{{ item.LastModified }}'
      OperationName: '{{ item.OperationName }}'
      ProductRestEndpointPageArn: '{{ item.ProductRestEndpointPageArn }}'
      ProductRestEndpointPageId: '{{ item.ProductRestEndpointPageId }}'
      RestEndpointIdentifier: '{{ item.RestEndpointIdentifier }}'
      Status: '{{ item.Status }}'
      StatusException: '{{ item.StatusException }}'
      TryItState: '{{ item.TryItState }}'
checks: []
