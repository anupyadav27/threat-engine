version: '1.0'
provider: aws
service: application-insights
services:
  client: application-insights
  module: boto3.client
discovery:
- discovery_id: aws.application-insights.listApplications
  calls:
  - action: listApplications
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.ApplicationInfoList }}'
    item:
      AccountId: '{{ item.AccountId }}'
      ResourceGroupName: '{{ item.ResourceGroupName }}'
      LifeCycle: '{{ item.LifeCycle }}'
      OpsItemSNSTopicArn: '{{ item.OpsItemSNSTopicArn }}'
      SNSNotificationArn: '{{ item.SNSNotificationArn }}'
      OpsCenterEnabled: '{{ item.OpsCenterEnabled }}'
      CWEMonitorEnabled: '{{ item.CWEMonitorEnabled }}'
      Remarks: '{{ item.Remarks }}'
      AutoConfigEnabled: '{{ item.AutoConfigEnabled }}'
      DiscoveryType: '{{ item.DiscoveryType }}'
      AttachMissingPermission: '{{ item.AttachMissingPermission }}'
- discovery_id: aws.application-insights.listConfigurationHistory
  calls:
  - action: listConfigurationHistory
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.EventList }}'
    item:
      ResourceGroupName: '{{ item.ResourceGroupName }}'
      AccountId: '{{ item.AccountId }}'
      MonitoredResourceARN: '{{ item.MonitoredResourceARN }}'
      EventStatus: '{{ item.EventStatus }}'
      EventResourceType: '{{ item.EventResourceType }}'
      EventTime: '{{ item.EventTime }}'
      EventDetail: '{{ item.EventDetail }}'
      EventResourceName: '{{ item.EventResourceName }}'
- discovery_id: aws.application-insights.listProblems
  calls:
  - action: listProblems
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.ProblemList }}'
    item:
      Id: '{{ item.Id }}'
      Title: '{{ item.Title }}'
      ShortName: '{{ item.ShortName }}'
      Insights: '{{ item.Insights }}'
      Status: '{{ item.Status }}'
      AffectedResource: '{{ item.AffectedResource }}'
      StartTime: '{{ item.StartTime }}'
      EndTime: '{{ item.EndTime }}'
      SeverityLevel: '{{ item.SeverityLevel }}'
      AccountId: '{{ item.AccountId }}'
      ResourceGroupName: '{{ item.ResourceGroupName }}'
      Feedback: '{{ item.Feedback }}'
      RecurringCount: '{{ item.RecurringCount }}'
      LastRecurrenceTime: '{{ item.LastRecurrenceTime }}'
      Visibility: '{{ item.Visibility }}'
      ResolutionMethod: '{{ item.ResolutionMethod }}'
- discovery_id: aws.application-insights.describeApplication
  calls:
  - action: describeApplication
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ApplicationInfo }}'
    item:
      AccountId: '{{ item.AccountId }}'
      ResourceGroupName: '{{ item.ResourceGroupName }}'
      LifeCycle: '{{ item.LifeCycle }}'
      OpsItemSNSTopicArn: '{{ item.OpsItemSNSTopicArn }}'
      SNSNotificationArn: '{{ item.SNSNotificationArn }}'
      OpsCenterEnabled: '{{ item.OpsCenterEnabled }}'
      CWEMonitorEnabled: '{{ item.CWEMonitorEnabled }}'
      Remarks: '{{ item.Remarks }}'
      AutoConfigEnabled: '{{ item.AutoConfigEnabled }}'
      DiscoveryType: '{{ item.DiscoveryType }}'
      AttachMissingPermission: '{{ item.AttachMissingPermission }}'
- discovery_id: aws.application-insights.describeComponent
  calls:
  - action: describeComponent
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ResourceList }}'
- discovery_id: aws.application-insights.describeComponentConfiguration
  calls:
  - action: describeComponentConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Monitor }}'
- discovery_id: aws.application-insights.describeComponentConfigurationRecommendation
  calls:
  - action: describeComponentConfigurationRecommendation
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ComponentConfiguration }}'
- discovery_id: aws.application-insights.describeLogPattern
  calls:
  - action: describeLogPattern
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.LogPattern }}'
    item:
      PatternSetName: '{{ item.PatternSetName }}'
      PatternName: '{{ item.PatternName }}'
      Pattern: '{{ item.Pattern }}'
      Rank: '{{ item.Rank }}'
- discovery_id: aws.application-insights.describeObservation
  calls:
  - action: describeObservation
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Observation }}'
    item:
      Id: '{{ item.Id }}'
      StartTime: '{{ item.StartTime }}'
      EndTime: '{{ item.EndTime }}'
      SourceType: '{{ item.SourceType }}'
      SourceARN: '{{ item.SourceARN }}'
      LogGroup: '{{ item.LogGroup }}'
      LineTime: '{{ item.LineTime }}'
      LogText: '{{ item.LogText }}'
      LogFilter: '{{ item.LogFilter }}'
      MetricNamespace: '{{ item.MetricNamespace }}'
      MetricName: '{{ item.MetricName }}'
      Unit: '{{ item.Unit }}'
      Value: '{{ item.Value }}'
      CloudWatchEventId: '{{ item.CloudWatchEventId }}'
      CloudWatchEventSource: '{{ item.CloudWatchEventSource }}'
      CloudWatchEventDetailType: '{{ item.CloudWatchEventDetailType }}'
      HealthEventArn: '{{ item.HealthEventArn }}'
      HealthService: '{{ item.HealthService }}'
      HealthEventTypeCode: '{{ item.HealthEventTypeCode }}'
      HealthEventTypeCategory: '{{ item.HealthEventTypeCategory }}'
      HealthEventDescription: '{{ item.HealthEventDescription }}'
      CodeDeployDeploymentId: '{{ item.CodeDeployDeploymentId }}'
      CodeDeployDeploymentGroup: '{{ item.CodeDeployDeploymentGroup }}'
      CodeDeployState: '{{ item.CodeDeployState }}'
      CodeDeployApplication: '{{ item.CodeDeployApplication }}'
      CodeDeployInstanceGroupId: '{{ item.CodeDeployInstanceGroupId }}'
      Ec2State: '{{ item.Ec2State }}'
      RdsEventCategories: '{{ item.RdsEventCategories }}'
      RdsEventMessage: '{{ item.RdsEventMessage }}'
      S3EventName: '{{ item.S3EventName }}'
      StatesExecutionArn: '{{ item.StatesExecutionArn }}'
      StatesArn: '{{ item.StatesArn }}'
      StatesStatus: '{{ item.StatesStatus }}'
      StatesInput: '{{ item.StatesInput }}'
      EbsEvent: '{{ item.EbsEvent }}'
      EbsResult: '{{ item.EbsResult }}'
      EbsCause: '{{ item.EbsCause }}'
      EbsRequestId: '{{ item.EbsRequestId }}'
      XRayFaultPercent: '{{ item.XRayFaultPercent }}'
      XRayThrottlePercent: '{{ item.XRayThrottlePercent }}'
      XRayErrorPercent: '{{ item.XRayErrorPercent }}'
      XRayRequestCount: '{{ item.XRayRequestCount }}'
      XRayRequestAverageLatency: '{{ item.XRayRequestAverageLatency }}'
      XRayNodeName: '{{ item.XRayNodeName }}'
      XRayNodeType: '{{ item.XRayNodeType }}'
- discovery_id: aws.application-insights.describeProblem
  calls:
  - action: describeProblem
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Problem }}'
    item:
      Id: '{{ item.Id }}'
      Title: '{{ item.Title }}'
      ShortName: '{{ item.ShortName }}'
      Insights: '{{ item.Insights }}'
      Status: '{{ item.Status }}'
      AffectedResource: '{{ item.AffectedResource }}'
      StartTime: '{{ item.StartTime }}'
      EndTime: '{{ item.EndTime }}'
      SeverityLevel: '{{ item.SeverityLevel }}'
      AccountId: '{{ item.AccountId }}'
      ResourceGroupName: '{{ item.ResourceGroupName }}'
      Feedback: '{{ item.Feedback }}'
      RecurringCount: '{{ item.RecurringCount }}'
      LastRecurrenceTime: '{{ item.LastRecurrenceTime }}'
      Visibility: '{{ item.Visibility }}'
      ResolutionMethod: '{{ item.ResolutionMethod }}'
- discovery_id: aws.application-insights.describeProblemObservations
  calls:
  - action: describeProblemObservations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.RelatedObservations }}'
    item:
      ObservationList: '{{ item.ObservationList }}'
- discovery_id: aws.application-insights.describeWorkload
  calls:
  - action: describeWorkload
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.WorkloadConfiguration }}'
    item:
      WorkloadName: '{{ item.WorkloadName }}'
      Tier: '{{ item.Tier }}'
      Configuration: '{{ item.Configuration }}'
- discovery_id: aws.application-insights.listComponents
  calls:
  - action: listComponents
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.ApplicationComponentList }}'
    item:
      ComponentName: '{{ item.ComponentName }}'
      ComponentRemarks: '{{ item.ComponentRemarks }}'
      ResourceType: '{{ item.ResourceType }}'
      OsType: '{{ item.OsType }}'
      Tier: '{{ item.Tier }}'
      Monitor: '{{ item.Monitor }}'
      DetectedWorkload: '{{ item.DetectedWorkload }}'
- discovery_id: aws.application-insights.listLogPatternSets
  calls:
  - action: listLogPatternSets
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.LogPatternSets }}'
- discovery_id: aws.application-insights.listLogPatterns
  calls:
  - action: listLogPatterns
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.LogPatterns }}'
    item:
      PatternSetName: '{{ item.PatternSetName }}'
      PatternName: '{{ item.PatternName }}'
      Pattern: '{{ item.Pattern }}'
      Rank: '{{ item.Rank }}'
- discovery_id: aws.application-insights.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Tags }}'
    item:
      Key: '{{ item.Key }}'
      Value: '{{ item.Value }}'
- discovery_id: aws.application-insights.listWorkloads
  calls:
  - action: listWorkloads
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.WorkloadList }}'
    item:
      WorkloadId: '{{ item.WorkloadId }}'
      ComponentName: '{{ item.ComponentName }}'
      WorkloadName: '{{ item.WorkloadName }}'
      Tier: '{{ item.Tier }}'
      WorkloadRemarks: '{{ item.WorkloadRemarks }}'
      MissingWorkloadConfig: '{{ item.MissingWorkloadConfig }}'
checks: []
