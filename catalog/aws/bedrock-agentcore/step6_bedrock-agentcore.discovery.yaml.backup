version: '1.0'
provider: aws
service: bedrock-agentcore
services:
  client: bedrock-agentcore
  module: boto3.client
discovery:
- discovery_id: aws.bedrock-agentcore.getAgentCard
  calls:
  - action: getAgentCard
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.agentCard }}'
- discovery_id: aws.bedrock-agentcore.getBrowserSession
  calls:
  - action: getBrowserSession
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.viewPort }}'
    item:
      width: '{{ item.width }}'
      height: '{{ item.height }}'
- discovery_id: aws.bedrock-agentcore.getCodeInterpreterSession
  calls:
  - action: getCodeInterpreterSession
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.codeInterpreterIdentifier }}'
- discovery_id: aws.bedrock-agentcore.getEvent
  calls:
  - action: getEvent
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.event }}'
    item:
      memoryId: '{{ item.memoryId }}'
      actorId: '{{ item.actorId }}'
      sessionId: '{{ item.sessionId }}'
      eventId: '{{ item.eventId }}'
      eventTimestamp: '{{ item.eventTimestamp }}'
      payload: '{{ item.payload }}'
      branch: '{{ item.branch }}'
      metadata: '{{ item.metadata }}'
- discovery_id: aws.bedrock-agentcore.getMemoryRecord
  calls:
  - action: getMemoryRecord
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.memoryRecord }}'
    item:
      memoryRecordId: '{{ item.memoryRecordId }}'
      content: '{{ item.content }}'
      memoryStrategyId: '{{ item.memoryStrategyId }}'
      namespaces: '{{ item.namespaces }}'
      createdAt: '{{ item.createdAt }}'
- discovery_id: aws.bedrock-agentcore.getResourceApiKey
  calls:
  - action: getResourceApiKey
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.apiKey }}'
- discovery_id: aws.bedrock-agentcore.getResourceOauth2Token
  calls:
  - action: getResourceOauth2Token
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.authorizationUrl }}'
- discovery_id: aws.bedrock-agentcore.getWorkloadAccessToken
  calls:
  - action: getWorkloadAccessToken
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.workloadAccessToken }}'
- discovery_id: aws.bedrock-agentcore.getWorkloadAccessTokenForJwt
  calls:
  - action: getWorkloadAccessTokenForJwt
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.workloadAccessToken }}'
- discovery_id: aws.bedrock-agentcore.getWorkloadAccessTokenForUserId
  calls:
  - action: getWorkloadAccessTokenForUserId
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.workloadAccessToken }}'
- discovery_id: aws.bedrock-agentcore.listActors
  calls:
  - action: listActors
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.actorSummaries }}'
    item:
      actorId: '{{ item.actorId }}'
- discovery_id: aws.bedrock-agentcore.listBrowserSessions
  calls:
  - action: listBrowserSessions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
    item:
      browserIdentifier: '{{ item.browserIdentifier }}'
      sessionId: '{{ item.sessionId }}'
      name: '{{ item.name }}'
      status: '{{ item.status }}'
      createdAt: '{{ item.createdAt }}'
      lastUpdatedAt: '{{ item.lastUpdatedAt }}'
- discovery_id: aws.bedrock-agentcore.listCodeInterpreterSessions
  calls:
  - action: listCodeInterpreterSessions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
    item:
      codeInterpreterIdentifier: '{{ item.codeInterpreterIdentifier }}'
      sessionId: '{{ item.sessionId }}'
      name: '{{ item.name }}'
      status: '{{ item.status }}'
      createdAt: '{{ item.createdAt }}'
      lastUpdatedAt: '{{ item.lastUpdatedAt }}'
- discovery_id: aws.bedrock-agentcore.listEvents
  calls:
  - action: listEvents
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.events }}'
    item:
      memoryId: '{{ item.memoryId }}'
      actorId: '{{ item.actorId }}'
      sessionId: '{{ item.sessionId }}'
      eventId: '{{ item.eventId }}'
      eventTimestamp: '{{ item.eventTimestamp }}'
      payload: '{{ item.payload }}'
      branch: '{{ item.branch }}'
      metadata: '{{ item.metadata }}'
- discovery_id: aws.bedrock-agentcore.listMemoryExtractionJobs
  calls:
  - action: listMemoryExtractionJobs
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.jobs }}'
    item:
      jobID: '{{ item.jobID }}'
      messages: '{{ item.messages }}'
      status: '{{ item.status }}'
      failureReason: '{{ item.failureReason }}'
      strategyId: '{{ item.strategyId }}'
      sessionId: '{{ item.sessionId }}'
      actorId: '{{ item.actorId }}'
- discovery_id: aws.bedrock-agentcore.listMemoryRecords
  calls:
  - action: listMemoryRecords
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.memoryRecordSummaries }}'
    item:
      memoryRecordId: '{{ item.memoryRecordId }}'
      content: '{{ item.content }}'
      memoryStrategyId: '{{ item.memoryStrategyId }}'
      namespaces: '{{ item.namespaces }}'
      createdAt: '{{ item.createdAt }}'
      score: '{{ item.score }}'
- discovery_id: aws.bedrock-agentcore.listSessions
  calls:
  - action: listSessions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.sessionSummaries }}'
    item:
      sessionId: '{{ item.sessionId }}'
      actorId: '{{ item.actorId }}'
      createdAt: '{{ item.createdAt }}'
- discovery_id: aws.bedrock-agentcore.retrieveMemoryRecords
  calls:
  - action: retrieveMemoryRecords
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.memoryRecordSummaries }}'
    item:
      memoryRecordId: '{{ item.memoryRecordId }}'
      content: '{{ item.content }}'
      memoryStrategyId: '{{ item.memoryStrategyId }}'
      namespaces: '{{ item.namespaces }}'
      createdAt: '{{ item.createdAt }}'
      score: '{{ item.score }}'
checks: []
