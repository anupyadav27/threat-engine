version: '1.0'
provider: aws
service: efs
services:
  client: efs
  module: boto3.client
discovery:
- discovery_id: aws.efs.describeAccessPoints
  calls:
  - action: describeAccessPoints
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AccessPoints }}'
    item:
      ClientToken: '{{ item.ClientToken }}'
      Name: '{{ item.Name }}'
      Tags: '{{ item.Tags }}'
      AccessPointId: '{{ item.AccessPointId }}'
      AccessPointArn: '{{ item.AccessPointArn }}'
      FileSystemId: '{{ item.FileSystemId }}'
      PosixUser: '{{ item.PosixUser }}'
      RootDirectory: '{{ item.RootDirectory }}'
      OwnerId: '{{ item.OwnerId }}'
      LifeCycleState: '{{ item.LifeCycleState }}'
- discovery_id: aws.efs.describeAccountPreferences
  calls:
  - action: describeAccountPreferences
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ResourceIdPreference }}'
    item:
      ResourceIdType: '{{ item.ResourceIdType }}'
      Resources: '{{ item.Resources }}'
- discovery_id: aws.efs.describeFileSystems
  calls:
  - action: describeFileSystems
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.FileSystems }}'
    item:
      OwnerId: '{{ item.OwnerId }}'
      CreationToken: '{{ item.CreationToken }}'
      FileSystemId: '{{ item.FileSystemId }}'
      FileSystemArn: '{{ item.FileSystemArn }}'
      CreationTime: '{{ item.CreationTime }}'
      LifeCycleState: '{{ item.LifeCycleState }}'
      Name: '{{ item.Name }}'
      NumberOfMountTargets: '{{ item.NumberOfMountTargets }}'
      SizeInBytes: '{{ item.SizeInBytes }}'
      PerformanceMode: '{{ item.PerformanceMode }}'
      Encrypted: '{{ item.Encrypted }}'
      KmsKeyId: '{{ item.KmsKeyId }}'
      ThroughputMode: '{{ item.ThroughputMode }}'
      ProvisionedThroughputInMibps: '{{ item.ProvisionedThroughputInMibps }}'
      AvailabilityZoneName: '{{ item.AvailabilityZoneName }}'
      AvailabilityZoneId: '{{ item.AvailabilityZoneId }}'
      Tags: '{{ item.Tags }}'
      FileSystemProtection: '{{ item.FileSystemProtection }}'
- discovery_id: aws.efs.describeMountTargets
  calls:
  - action: describeMountTargets
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.MountTargets }}'
    item:
      OwnerId: '{{ item.OwnerId }}'
      MountTargetId: '{{ item.MountTargetId }}'
      FileSystemId: '{{ item.FileSystemId }}'
      SubnetId: '{{ item.SubnetId }}'
      LifeCycleState: '{{ item.LifeCycleState }}'
      IpAddress: '{{ item.IpAddress }}'
      Ipv6Address: '{{ item.Ipv6Address }}'
      NetworkInterfaceId: '{{ item.NetworkInterfaceId }}'
      AvailabilityZoneId: '{{ item.AvailabilityZoneId }}'
      AvailabilityZoneName: '{{ item.AvailabilityZoneName }}'
      VpcId: '{{ item.VpcId }}'
- discovery_id: aws.efs.describeReplicationConfigurations
  calls:
  - action: describeReplicationConfigurations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Replications }}'
    item:
      SourceFileSystemId: '{{ item.SourceFileSystemId }}'
      SourceFileSystemRegion: '{{ item.SourceFileSystemRegion }}'
      SourceFileSystemArn: '{{ item.SourceFileSystemArn }}'
      OriginalSourceFileSystemArn: '{{ item.OriginalSourceFileSystemArn }}'
      CreationTime: '{{ item.CreationTime }}'
      Destinations: '{{ item.Destinations }}'
      SourceFileSystemOwnerId: '{{ item.SourceFileSystemOwnerId }}'
- discovery_id: aws.efs.describeBackupPolicy
  calls:
  - action: describeBackupPolicy
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.BackupPolicy }}'
    item:
      Status: '{{ item.Status }}'
- discovery_id: aws.efs.describeFileSystemPolicy
  calls:
  - action: describeFileSystemPolicy
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.FileSystemId }}'
- discovery_id: aws.efs.describeLifecycleConfiguration
  calls:
  - action: describeLifecycleConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.LifecyclePolicies }}'
    item:
      TransitionToIA: '{{ item.TransitionToIA }}'
      TransitionToPrimaryStorageClass: '{{ item.TransitionToPrimaryStorageClass }}'
      TransitionToArchive: '{{ item.TransitionToArchive }}'
- discovery_id: aws.efs.describeMountTargetSecurityGroups
  calls:
  - action: describeMountTargetSecurityGroups
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.SecurityGroups }}'
- discovery_id: aws.efs.describeTags
  calls:
  - action: describeTags
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Tags }}'
    item:
      Key: '{{ item.Key }}'
      Value: '{{ item.Value }}'
- discovery_id: aws.efs.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Tags }}'
    item:
      Key: '{{ item.Key }}'
      Value: '{{ item.Value }}'
checks: []
