version: '1.0'
provider: aws
service: batch
services:
  client: batch
  module: boto3.client
discovery:
- discovery_id: aws.batch.describeComputeEnvironments
  calls:
  - action: describeComputeEnvironments
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.computeEnvironments }}'
    item:
      computeEnvironmentName: '{{ item.computeEnvironmentName }}'
      computeEnvironmentArn: '{{ item.computeEnvironmentArn }}'
      unmanagedvCpus: '{{ item.unmanagedvCpus }}'
      ecsClusterArn: '{{ item.ecsClusterArn }}'
      tags: '{{ item.tags }}'
      type: '{{ item.type }}'
      state: '{{ item.state }}'
      status: '{{ item.status }}'
      statusReason: '{{ item.statusReason }}'
      computeResources: '{{ item.computeResources }}'
      serviceRole: '{{ item.serviceRole }}'
      updatePolicy: '{{ item.updatePolicy }}'
      eksConfiguration: '{{ item.eksConfiguration }}'
      containerOrchestrationType: '{{ item.containerOrchestrationType }}'
      uuid: '{{ item.uuid }}'
      context: '{{ item.context }}'
- discovery_id: aws.batch.describeJobDefinitions
  calls:
  - action: describeJobDefinitions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.jobDefinitions }}'
    item:
      jobDefinitionName: '{{ item.jobDefinitionName }}'
      jobDefinitionArn: '{{ item.jobDefinitionArn }}'
      revision: '{{ item.revision }}'
      status: '{{ item.status }}'
      type: '{{ item.type }}'
      schedulingPriority: '{{ item.schedulingPriority }}'
      parameters: '{{ item.parameters }}'
      retryStrategy: '{{ item.retryStrategy }}'
      containerProperties: '{{ item.containerProperties }}'
      timeout: '{{ item.timeout }}'
      nodeProperties: '{{ item.nodeProperties }}'
      tags: '{{ item.tags }}'
      propagateTags: '{{ item.propagateTags }}'
      platformCapabilities: '{{ item.platformCapabilities }}'
      ecsProperties: '{{ item.ecsProperties }}'
      eksProperties: '{{ item.eksProperties }}'
      containerOrchestrationType: '{{ item.containerOrchestrationType }}'
      consumableResourceProperties: '{{ item.consumableResourceProperties }}'
- discovery_id: aws.batch.describeJobQueues
  calls:
  - action: describeJobQueues
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.jobQueues }}'
    item:
      jobQueueName: '{{ item.jobQueueName }}'
      jobQueueArn: '{{ item.jobQueueArn }}'
      state: '{{ item.state }}'
      schedulingPolicyArn: '{{ item.schedulingPolicyArn }}'
      status: '{{ item.status }}'
      statusReason: '{{ item.statusReason }}'
      priority: '{{ item.priority }}'
      computeEnvironmentOrder: '{{ item.computeEnvironmentOrder }}'
      serviceEnvironmentOrder: '{{ item.serviceEnvironmentOrder }}'
      jobQueueType: '{{ item.jobQueueType }}'
      tags: '{{ item.tags }}'
      jobStateTimeLimitActions: '{{ item.jobStateTimeLimitActions }}'
- discovery_id: aws.batch.describeServiceEnvironments
  calls:
  - action: describeServiceEnvironments
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.serviceEnvironments }}'
    item:
      serviceEnvironmentName: '{{ item.serviceEnvironmentName }}'
      serviceEnvironmentArn: '{{ item.serviceEnvironmentArn }}'
      serviceEnvironmentType: '{{ item.serviceEnvironmentType }}'
      state: '{{ item.state }}'
      status: '{{ item.status }}'
      capacityLimits: '{{ item.capacityLimits }}'
      tags: '{{ item.tags }}'
- discovery_id: aws.batch.listConsumableResources
  calls:
  - action: listConsumableResources
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.consumableResources }}'
    item:
      consumableResourceArn: '{{ item.consumableResourceArn }}'
      consumableResourceName: '{{ item.consumableResourceName }}'
      totalQuantity: '{{ item.totalQuantity }}'
      inUseQuantity: '{{ item.inUseQuantity }}'
      resourceType: '{{ item.resourceType }}'
- discovery_id: aws.batch.listJobs
  calls:
  - action: listJobs
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.jobSummaryList }}'
    item:
      jobArn: '{{ item.jobArn }}'
      jobId: '{{ item.jobId }}'
      jobName: '{{ item.jobName }}'
      createdAt: '{{ item.createdAt }}'
      status: '{{ item.status }}'
      statusReason: '{{ item.statusReason }}'
      startedAt: '{{ item.startedAt }}'
      stoppedAt: '{{ item.stoppedAt }}'
      container: '{{ item.container }}'
      arrayProperties: '{{ item.arrayProperties }}'
      nodeProperties: '{{ item.nodeProperties }}'
      jobDefinition: '{{ item.jobDefinition }}'
- discovery_id: aws.batch.listSchedulingPolicies
  calls:
  - action: listSchedulingPolicies
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.schedulingPolicies }}'
    item:
      arn: '{{ item.arn }}'
- discovery_id: aws.batch.listServiceJobs
  calls:
  - action: listServiceJobs
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.jobSummaryList }}'
    item:
      latestAttempt: '{{ item.latestAttempt }}'
      createdAt: '{{ item.createdAt }}'
      jobArn: '{{ item.jobArn }}'
      jobId: '{{ item.jobId }}'
      jobName: '{{ item.jobName }}'
      serviceJobType: '{{ item.serviceJobType }}'
      shareIdentifier: '{{ item.shareIdentifier }}'
      status: '{{ item.status }}'
      statusReason: '{{ item.statusReason }}'
      startedAt: '{{ item.startedAt }}'
      stoppedAt: '{{ item.stoppedAt }}'
- discovery_id: aws.batch.describeConsumableResource
  calls:
  - action: describeConsumableResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.consumableResourceName }}'
- discovery_id: aws.batch.describeJobs
  calls:
  - action: describeJobs
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.jobs }}'
    item:
      jobArn: '{{ item.jobArn }}'
      jobName: '{{ item.jobName }}'
      jobId: '{{ item.jobId }}'
      jobQueue: '{{ item.jobQueue }}'
      status: '{{ item.status }}'
      shareIdentifier: '{{ item.shareIdentifier }}'
      schedulingPriority: '{{ item.schedulingPriority }}'
      attempts: '{{ item.attempts }}'
      statusReason: '{{ item.statusReason }}'
      createdAt: '{{ item.createdAt }}'
      retryStrategy: '{{ item.retryStrategy }}'
      startedAt: '{{ item.startedAt }}'
      stoppedAt: '{{ item.stoppedAt }}'
      dependsOn: '{{ item.dependsOn }}'
      jobDefinition: '{{ item.jobDefinition }}'
      parameters: '{{ item.parameters }}'
      container: '{{ item.container }}'
      nodeDetails: '{{ item.nodeDetails }}'
      nodeProperties: '{{ item.nodeProperties }}'
      arrayProperties: '{{ item.arrayProperties }}'
      timeout: '{{ item.timeout }}'
      tags: '{{ item.tags }}'
      propagateTags: '{{ item.propagateTags }}'
      platformCapabilities: '{{ item.platformCapabilities }}'
      eksProperties: '{{ item.eksProperties }}'
      eksAttempts: '{{ item.eksAttempts }}'
      ecsProperties: '{{ item.ecsProperties }}'
      isCancelled: '{{ item.isCancelled }}'
      isTerminated: '{{ item.isTerminated }}'
      consumableResourceProperties: '{{ item.consumableResourceProperties }}'
- discovery_id: aws.batch.describeSchedulingPolicies
  calls:
  - action: describeSchedulingPolicies
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.schedulingPolicies }}'
    item:
      name: '{{ item.name }}'
      arn: '{{ item.arn }}'
      fairsharePolicy: '{{ item.fairsharePolicy }}'
      tags: '{{ item.tags }}'
- discovery_id: aws.batch.describeServiceJob
  calls:
  - action: describeServiceJob
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.attempts }}'
    item:
      serviceResourceId: '{{ item.serviceResourceId }}'
      startedAt: '{{ item.startedAt }}'
      stoppedAt: '{{ item.stoppedAt }}'
      statusReason: '{{ item.statusReason }}'
- discovery_id: aws.batch.getJobQueueSnapshot
  calls:
  - action: getJobQueueSnapshot
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.frontOfQueue }}'
    item:
      jobs: '{{ item.jobs }}'
      lastUpdatedAt: '{{ item.lastUpdatedAt }}'
- discovery_id: aws.batch.listJobsByConsumableResource
  calls:
  - action: listJobsByConsumableResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.jobs }}'
    item:
      jobArn: '{{ item.jobArn }}'
      jobQueueArn: '{{ item.jobQueueArn }}'
      jobName: '{{ item.jobName }}'
      jobDefinitionArn: '{{ item.jobDefinitionArn }}'
      shareIdentifier: '{{ item.shareIdentifier }}'
      jobStatus: '{{ item.jobStatus }}'
      quantity: '{{ item.quantity }}'
      statusReason: '{{ item.statusReason }}'
      startedAt: '{{ item.startedAt }}'
      createdAt: '{{ item.createdAt }}'
      consumableResourceProperties: '{{ item.consumableResourceProperties }}'
- discovery_id: aws.batch.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tags }}'
checks: []
