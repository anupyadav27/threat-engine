version: '1.0'
provider: aws
service: opensearch
services:
  client: opensearch
  module: boto3.client
discovery:
- discovery_id: aws.opensearch.describeInboundConnections
  calls:
  - action: describeInboundConnections
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Connections }}'
    item:
      LocalDomainInfo: '{{ item.LocalDomainInfo }}'
      RemoteDomainInfo: '{{ item.RemoteDomainInfo }}'
      ConnectionId: '{{ item.ConnectionId }}'
      ConnectionStatus: '{{ item.ConnectionStatus }}'
      ConnectionMode: '{{ item.ConnectionMode }}'
- discovery_id: aws.opensearch.describeOutboundConnections
  calls:
  - action: describeOutboundConnections
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Connections }}'
    item:
      LocalDomainInfo: '{{ item.LocalDomainInfo }}'
      RemoteDomainInfo: '{{ item.RemoteDomainInfo }}'
      ConnectionId: '{{ item.ConnectionId }}'
      ConnectionAlias: '{{ item.ConnectionAlias }}'
      ConnectionStatus: '{{ item.ConnectionStatus }}'
      ConnectionMode: '{{ item.ConnectionMode }}'
      ConnectionProperties: '{{ item.ConnectionProperties }}'
- discovery_id: aws.opensearch.describePackages
  calls:
  - action: describePackages
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.PackageDetailsList }}'
    item:
      PackageID: '{{ item.PackageID }}'
      PackageName: '{{ item.PackageName }}'
      PackageType: '{{ item.PackageType }}'
      PackageDescription: '{{ item.PackageDescription }}'
      PackageStatus: '{{ item.PackageStatus }}'
      CreatedAt: '{{ item.CreatedAt }}'
      LastUpdatedAt: '{{ item.LastUpdatedAt }}'
      AvailablePackageVersion: '{{ item.AvailablePackageVersion }}'
      ErrorDetails: '{{ item.ErrorDetails }}'
      EngineVersion: '{{ item.EngineVersion }}'
      AvailablePluginProperties: '{{ item.AvailablePluginProperties }}'
      AvailablePackageConfiguration: '{{ item.AvailablePackageConfiguration }}'
      AllowListedUserList: '{{ item.AllowListedUserList }}'
      PackageOwner: '{{ item.PackageOwner }}'
      PackageVendingOptions: '{{ item.PackageVendingOptions }}'
      PackageEncryptionOptions: '{{ item.PackageEncryptionOptions }}'
- discovery_id: aws.opensearch.describeReservedInstanceOfferings
  calls:
  - action: describeReservedInstanceOfferings
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ReservedInstanceOfferings }}'
    item:
      ReservedInstanceOfferingId: '{{ item.ReservedInstanceOfferingId }}'
      InstanceType: '{{ item.InstanceType }}'
      Duration: '{{ item.Duration }}'
      FixedPrice: '{{ item.FixedPrice }}'
      UsagePrice: '{{ item.UsagePrice }}'
      CurrencyCode: '{{ item.CurrencyCode }}'
      PaymentOption: '{{ item.PaymentOption }}'
      RecurringCharges: '{{ item.RecurringCharges }}'
- discovery_id: aws.opensearch.describeReservedInstances
  calls:
  - action: describeReservedInstances
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ReservedInstances }}'
    item:
      ReservationName: '{{ item.ReservationName }}'
      ReservedInstanceId: '{{ item.ReservedInstanceId }}'
      BillingSubscriptionId: '{{ item.BillingSubscriptionId }}'
      ReservedInstanceOfferingId: '{{ item.ReservedInstanceOfferingId }}'
      InstanceType: '{{ item.InstanceType }}'
      StartTime: '{{ item.StartTime }}'
      Duration: '{{ item.Duration }}'
      FixedPrice: '{{ item.FixedPrice }}'
      UsagePrice: '{{ item.UsagePrice }}'
      CurrencyCode: '{{ item.CurrencyCode }}'
      InstanceCount: '{{ item.InstanceCount }}'
      State: '{{ item.State }}'
      PaymentOption: '{{ item.PaymentOption }}'
      RecurringCharges: '{{ item.RecurringCharges }}'
- discovery_id: aws.opensearch.getCompatibleVersions
  calls:
  - action: getCompatibleVersions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.CompatibleVersions }}'
    item:
      SourceVersion: '{{ item.SourceVersion }}'
      TargetVersions: '{{ item.TargetVersions }}'
- discovery_id: aws.opensearch.getDefaultApplicationSetting
  calls:
  - action: getDefaultApplicationSetting
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.applicationArn }}'
- discovery_id: aws.opensearch.listApplications
  calls:
  - action: listApplications
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ApplicationSummaries }}'
    item:
      id: '{{ item.id }}'
      arn: '{{ item.arn }}'
      name: '{{ item.name }}'
      endpoint: '{{ item.endpoint }}'
      status: '{{ item.status }}'
      createdAt: '{{ item.createdAt }}'
      lastUpdatedAt: '{{ item.lastUpdatedAt }}'
- discovery_id: aws.opensearch.listDirectQueryDataSources
  calls:
  - action: listDirectQueryDataSources
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.DirectQueryDataSources }}'
    item:
      DataSourceName: '{{ item.DataSourceName }}'
      DataSourceType: '{{ item.DataSourceType }}'
      Description: '{{ item.Description }}'
      OpenSearchArns: '{{ item.OpenSearchArns }}'
      DataSourceArn: '{{ item.DataSourceArn }}'
      TagList: '{{ item.TagList }}'
- discovery_id: aws.opensearch.listDomainNames
  calls:
  - action: listDomainNames
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.DomainNames }}'
    item:
      DomainName: '{{ item.DomainName }}'
      EngineType: '{{ item.EngineType }}'
- discovery_id: aws.opensearch.listVersions
  calls:
  - action: listVersions
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Versions }}'
- discovery_id: aws.opensearch.listVpcEndpoints
  calls:
  - action: listVpcEndpoints
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.VpcEndpointSummaryList }}'
    item:
      VpcEndpointId: '{{ item.VpcEndpointId }}'
      VpcEndpointOwner: '{{ item.VpcEndpointOwner }}'
      DomainArn: '{{ item.DomainArn }}'
      Status: '{{ item.Status }}'
- discovery_id: aws.opensearch.describeDomain
  calls:
  - action: describeDomain
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.DomainStatus }}'
    item:
      DomainId: '{{ item.DomainId }}'
      DomainName: '{{ item.DomainName }}'
      ARN: '{{ item.ARN }}'
      Created: '{{ item.Created }}'
      Deleted: '{{ item.Deleted }}'
      Endpoint: '{{ item.Endpoint }}'
      EndpointV2: '{{ item.EndpointV2 }}'
      Endpoints: '{{ item.Endpoints }}'
      DomainEndpointV2HostedZoneId: '{{ item.DomainEndpointV2HostedZoneId }}'
      Processing: '{{ item.Processing }}'
      UpgradeProcessing: '{{ item.UpgradeProcessing }}'
      EngineVersion: '{{ item.EngineVersion }}'
      ClusterConfig: '{{ item.ClusterConfig }}'
      EBSOptions: '{{ item.EBSOptions }}'
      AccessPolicies: '{{ item.AccessPolicies }}'
      IPAddressType: '{{ item.IPAddressType }}'
      SnapshotOptions: '{{ item.SnapshotOptions }}'
      VPCOptions: '{{ item.VPCOptions }}'
      CognitoOptions: '{{ item.CognitoOptions }}'
      EncryptionAtRestOptions: '{{ item.EncryptionAtRestOptions }}'
      NodeToNodeEncryptionOptions: '{{ item.NodeToNodeEncryptionOptions }}'
      AdvancedOptions: '{{ item.AdvancedOptions }}'
      LogPublishingOptions: '{{ item.LogPublishingOptions }}'
      ServiceSoftwareOptions: '{{ item.ServiceSoftwareOptions }}'
      DomainEndpointOptions: '{{ item.DomainEndpointOptions }}'
      AdvancedSecurityOptions: '{{ item.AdvancedSecurityOptions }}'
      IdentityCenterOptions: '{{ item.IdentityCenterOptions }}'
      AutoTuneOptions: '{{ item.AutoTuneOptions }}'
      ChangeProgressDetails: '{{ item.ChangeProgressDetails }}'
      OffPeakWindowOptions: '{{ item.OffPeakWindowOptions }}'
      SoftwareUpdateOptions: '{{ item.SoftwareUpdateOptions }}'
      DomainProcessingStatus: '{{ item.DomainProcessingStatus }}'
      ModifyingProperties: '{{ item.ModifyingProperties }}'
      AIMLOptions: '{{ item.AIMLOptions }}'
- discovery_id: aws.opensearch.describeDomainAutoTunes
  calls:
  - action: describeDomainAutoTunes
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AutoTunes }}'
    item:
      AutoTuneType: '{{ item.AutoTuneType }}'
      AutoTuneDetails: '{{ item.AutoTuneDetails }}'
- discovery_id: aws.opensearch.describeDomainChangeProgress
  calls:
  - action: describeDomainChangeProgress
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ChangeProgressStatus }}'
    item:
      ChangeId: '{{ item.ChangeId }}'
      StartTime: '{{ item.StartTime }}'
      Status: '{{ item.Status }}'
      PendingProperties: '{{ item.PendingProperties }}'
      CompletedProperties: '{{ item.CompletedProperties }}'
      TotalNumberOfStages: '{{ item.TotalNumberOfStages }}'
      ChangeProgressStages: '{{ item.ChangeProgressStages }}'
      LastUpdatedTime: '{{ item.LastUpdatedTime }}'
      ConfigChangeStatus: '{{ item.ConfigChangeStatus }}'
      InitiatedBy: '{{ item.InitiatedBy }}'
- discovery_id: aws.opensearch.describeDomainConfig
  calls:
  - action: describeDomainConfig
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.DomainConfig }}'
    item:
      EngineVersion: '{{ item.EngineVersion }}'
      ClusterConfig: '{{ item.ClusterConfig }}'
      EBSOptions: '{{ item.EBSOptions }}'
      AccessPolicies: '{{ item.AccessPolicies }}'
      IPAddressType: '{{ item.IPAddressType }}'
      SnapshotOptions: '{{ item.SnapshotOptions }}'
      VPCOptions: '{{ item.VPCOptions }}'
      CognitoOptions: '{{ item.CognitoOptions }}'
      EncryptionAtRestOptions: '{{ item.EncryptionAtRestOptions }}'
      NodeToNodeEncryptionOptions: '{{ item.NodeToNodeEncryptionOptions }}'
      AdvancedOptions: '{{ item.AdvancedOptions }}'
      LogPublishingOptions: '{{ item.LogPublishingOptions }}'
      DomainEndpointOptions: '{{ item.DomainEndpointOptions }}'
      AdvancedSecurityOptions: '{{ item.AdvancedSecurityOptions }}'
      IdentityCenterOptions: '{{ item.IdentityCenterOptions }}'
      AutoTuneOptions: '{{ item.AutoTuneOptions }}'
      ChangeProgressDetails: '{{ item.ChangeProgressDetails }}'
      OffPeakWindowOptions: '{{ item.OffPeakWindowOptions }}'
      SoftwareUpdateOptions: '{{ item.SoftwareUpdateOptions }}'
      ModifyingProperties: '{{ item.ModifyingProperties }}'
      AIMLOptions: '{{ item.AIMLOptions }}'
- discovery_id: aws.opensearch.describeDomainHealth
  calls:
  - action: describeDomainHealth
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.EnvironmentInformation }}'
    item:
      AvailabilityZoneInformation: '{{ item.AvailabilityZoneInformation }}'
- discovery_id: aws.opensearch.describeDomainNodes
  calls:
  - action: describeDomainNodes
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.DomainNodesStatusList }}'
    item:
      NodeId: '{{ item.NodeId }}'
      NodeType: '{{ item.NodeType }}'
      AvailabilityZone: '{{ item.AvailabilityZone }}'
      InstanceType: '{{ item.InstanceType }}'
      NodeStatus: '{{ item.NodeStatus }}'
      StorageType: '{{ item.StorageType }}'
      StorageVolumeType: '{{ item.StorageVolumeType }}'
      StorageSize: '{{ item.StorageSize }}'
- discovery_id: aws.opensearch.describeDomains
  calls:
  - action: describeDomains
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.DomainStatusList }}'
    item:
      DomainId: '{{ item.DomainId }}'
      DomainName: '{{ item.DomainName }}'
      ARN: '{{ item.ARN }}'
      Created: '{{ item.Created }}'
      Deleted: '{{ item.Deleted }}'
      Endpoint: '{{ item.Endpoint }}'
      EndpointV2: '{{ item.EndpointV2 }}'
      Endpoints: '{{ item.Endpoints }}'
      DomainEndpointV2HostedZoneId: '{{ item.DomainEndpointV2HostedZoneId }}'
      Processing: '{{ item.Processing }}'
      UpgradeProcessing: '{{ item.UpgradeProcessing }}'
      EngineVersion: '{{ item.EngineVersion }}'
      ClusterConfig: '{{ item.ClusterConfig }}'
      EBSOptions: '{{ item.EBSOptions }}'
      AccessPolicies: '{{ item.AccessPolicies }}'
      IPAddressType: '{{ item.IPAddressType }}'
      SnapshotOptions: '{{ item.SnapshotOptions }}'
      VPCOptions: '{{ item.VPCOptions }}'
      CognitoOptions: '{{ item.CognitoOptions }}'
      EncryptionAtRestOptions: '{{ item.EncryptionAtRestOptions }}'
      NodeToNodeEncryptionOptions: '{{ item.NodeToNodeEncryptionOptions }}'
      AdvancedOptions: '{{ item.AdvancedOptions }}'
      LogPublishingOptions: '{{ item.LogPublishingOptions }}'
      ServiceSoftwareOptions: '{{ item.ServiceSoftwareOptions }}'
      DomainEndpointOptions: '{{ item.DomainEndpointOptions }}'
      AdvancedSecurityOptions: '{{ item.AdvancedSecurityOptions }}'
      IdentityCenterOptions: '{{ item.IdentityCenterOptions }}'
      AutoTuneOptions: '{{ item.AutoTuneOptions }}'
      ChangeProgressDetails: '{{ item.ChangeProgressDetails }}'
      OffPeakWindowOptions: '{{ item.OffPeakWindowOptions }}'
      SoftwareUpdateOptions: '{{ item.SoftwareUpdateOptions }}'
      DomainProcessingStatus: '{{ item.DomainProcessingStatus }}'
      ModifyingProperties: '{{ item.ModifyingProperties }}'
      AIMLOptions: '{{ item.AIMLOptions }}'
- discovery_id: aws.opensearch.describeDryRunProgress
  calls:
  - action: describeDryRunProgress
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.DryRunProgressStatus }}'
    item:
      DryRunId: '{{ item.DryRunId }}'
      DryRunStatus: '{{ item.DryRunStatus }}'
      CreationDate: '{{ item.CreationDate }}'
      UpdateDate: '{{ item.UpdateDate }}'
      ValidationFailures: '{{ item.ValidationFailures }}'
- discovery_id: aws.opensearch.describeInstanceTypeLimits
  calls:
  - action: describeInstanceTypeLimits
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.LimitsByRole }}'
- discovery_id: aws.opensearch.describeVpcEndpoints
  calls:
  - action: describeVpcEndpoints
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.VpcEndpoints }}'
    item:
      VpcEndpointId: '{{ item.VpcEndpointId }}'
      VpcEndpointOwner: '{{ item.VpcEndpointOwner }}'
      DomainArn: '{{ item.DomainArn }}'
      VpcOptions: '{{ item.VpcOptions }}'
      Status: '{{ item.Status }}'
      Endpoint: '{{ item.Endpoint }}'
- discovery_id: aws.opensearch.getApplication
  calls:
  - action: getApplication
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.dataSources }}'
    item:
      dataSourceArn: '{{ item.dataSourceArn }}'
      dataSourceDescription: '{{ item.dataSourceDescription }}'
- discovery_id: aws.opensearch.getDataSource
  calls:
  - action: getDataSource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.DataSourceType }}'
    item:
      S3GlueDataCatalog: '{{ item.S3GlueDataCatalog }}'
- discovery_id: aws.opensearch.getDirectQueryDataSource
  calls:
  - action: getDirectQueryDataSource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.OpenSearchArns }}'
- discovery_id: aws.opensearch.getDomainMaintenanceStatus
  calls:
  - action: getDomainMaintenanceStatus
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Status }}'
- discovery_id: aws.opensearch.getIndex
  calls:
  - action: getIndex
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.IndexSchema }}'
- discovery_id: aws.opensearch.getPackageVersionHistory
  calls:
  - action: getPackageVersionHistory
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.PackageVersionHistoryList }}'
    item:
      PackageVersion: '{{ item.PackageVersion }}'
      CommitMessage: '{{ item.CommitMessage }}'
      CreatedAt: '{{ item.CreatedAt }}'
      PluginProperties: '{{ item.PluginProperties }}'
      PackageConfiguration: '{{ item.PackageConfiguration }}'
- discovery_id: aws.opensearch.getUpgradeHistory
  calls:
  - action: getUpgradeHistory
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.UpgradeHistories }}'
    item:
      UpgradeName: '{{ item.UpgradeName }}'
      StartTimestamp: '{{ item.StartTimestamp }}'
      UpgradeStatus: '{{ item.UpgradeStatus }}'
      StepsList: '{{ item.StepsList }}'
- discovery_id: aws.opensearch.getUpgradeStatus
  calls:
  - action: getUpgradeStatus
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.UpgradeStep }}'
- discovery_id: aws.opensearch.listDataSources
  calls:
  - action: listDataSources
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.DataSources }}'
    item:
      DataSourceType: '{{ item.DataSourceType }}'
      Name: '{{ item.Name }}'
      Description: '{{ item.Description }}'
      Status: '{{ item.Status }}'
- discovery_id: aws.opensearch.listDomainMaintenances
  calls:
  - action: listDomainMaintenances
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.DomainMaintenances }}'
    item:
      MaintenanceId: '{{ item.MaintenanceId }}'
      DomainName: '{{ item.DomainName }}'
      Action: '{{ item.Action }}'
      NodeId: '{{ item.NodeId }}'
      Status: '{{ item.Status }}'
      StatusMessage: '{{ item.StatusMessage }}'
      CreatedAt: '{{ item.CreatedAt }}'
      UpdatedAt: '{{ item.UpdatedAt }}'
- discovery_id: aws.opensearch.listDomainsForPackage
  calls:
  - action: listDomainsForPackage
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.DomainPackageDetailsList }}'
    item:
      PackageID: '{{ item.PackageID }}'
      PackageName: '{{ item.PackageName }}'
      PackageType: '{{ item.PackageType }}'
      LastUpdated: '{{ item.LastUpdated }}'
      DomainName: '{{ item.DomainName }}'
      DomainPackageStatus: '{{ item.DomainPackageStatus }}'
      PackageVersion: '{{ item.PackageVersion }}'
      PrerequisitePackageIDList: '{{ item.PrerequisitePackageIDList }}'
      ReferencePath: '{{ item.ReferencePath }}'
      ErrorDetails: '{{ item.ErrorDetails }}'
      AssociationConfiguration: '{{ item.AssociationConfiguration }}'
- discovery_id: aws.opensearch.listInstanceTypeDetails
  calls:
  - action: listInstanceTypeDetails
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.InstanceTypeDetails }}'
    item:
      InstanceType: '{{ item.InstanceType }}'
      EncryptionEnabled: '{{ item.EncryptionEnabled }}'
      CognitoEnabled: '{{ item.CognitoEnabled }}'
      AppLogsEnabled: '{{ item.AppLogsEnabled }}'
      AdvancedSecurityEnabled: '{{ item.AdvancedSecurityEnabled }}'
      WarmEnabled: '{{ item.WarmEnabled }}'
      InstanceRole: '{{ item.InstanceRole }}'
      AvailabilityZones: '{{ item.AvailabilityZones }}'
- discovery_id: aws.opensearch.listPackagesForDomain
  calls:
  - action: listPackagesForDomain
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.DomainPackageDetailsList }}'
    item:
      PackageID: '{{ item.PackageID }}'
      PackageName: '{{ item.PackageName }}'
      PackageType: '{{ item.PackageType }}'
      LastUpdated: '{{ item.LastUpdated }}'
      DomainName: '{{ item.DomainName }}'
      DomainPackageStatus: '{{ item.DomainPackageStatus }}'
      PackageVersion: '{{ item.PackageVersion }}'
      PrerequisitePackageIDList: '{{ item.PrerequisitePackageIDList }}'
      ReferencePath: '{{ item.ReferencePath }}'
      ErrorDetails: '{{ item.ErrorDetails }}'
      AssociationConfiguration: '{{ item.AssociationConfiguration }}'
- discovery_id: aws.opensearch.listScheduledActions
  calls:
  - action: listScheduledActions
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.ScheduledActions }}'
    item:
      Id: '{{ item.Id }}'
      Type: '{{ item.Type }}'
      Severity: '{{ item.Severity }}'
      ScheduledTime: '{{ item.ScheduledTime }}'
      Description: '{{ item.Description }}'
      ScheduledBy: '{{ item.ScheduledBy }}'
      Status: '{{ item.Status }}'
      Mandatory: '{{ item.Mandatory }}'
      Cancellable: '{{ item.Cancellable }}'
- discovery_id: aws.opensearch.listTags
  calls:
  - action: listTags
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.TagList }}'
    item:
      Key: '{{ item.Key }}'
      Value: '{{ item.Value }}'
- discovery_id: aws.opensearch.listVpcEndpointAccess
  calls:
  - action: listVpcEndpointAccess
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AuthorizedPrincipalList }}'
    item:
      PrincipalType: '{{ item.PrincipalType }}'
      Principal: '{{ item.Principal }}'
- discovery_id: aws.opensearch.listVpcEndpointsForDomain
  calls:
  - action: listVpcEndpointsForDomain
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.VpcEndpointSummaryList }}'
    item:
      VpcEndpointId: '{{ item.VpcEndpointId }}'
      VpcEndpointOwner: '{{ item.VpcEndpointOwner }}'
      DomainArn: '{{ item.DomainArn }}'
      Status: '{{ item.Status }}'
checks: []
