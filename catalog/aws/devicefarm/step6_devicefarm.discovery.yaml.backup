      type: '{{ item.type }}'
      url: '{{ item.url }}'
- discovery_id: aws.devicefarm.listTestGridSessions
  calls:
  - action: listTestGridSessions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.testGridSessions }}'
    item:
      arn: '{{ item.arn }}'
      status: '{{ item.status }}'
      created: '{{ item.created }}'
      ended: '{{ item.ended }}'
      billingMinutes: '{{ item.billingMinutes }}'
      seleniumProperties: '{{ item.seleniumProperties }}'
- discovery_id: aws.devicefarm.listTests
  calls:
  - action: listTests
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tests }}'
    item:
      arn: '{{ item.arn }}'
      name: '{{ item.name }}'
      type: '{{ item.type }}'
      created: '{{ item.created }}'
      status: '{{ item.status }}'
      result: '{{ item.result }}'
      started: '{{ item.started }}'
      stopped: '{{ item.stopped }}'
      counters: '{{ item.counters }}'
      message: '{{ item.message }}'
      deviceMinutes: '{{ item.deviceMinutes }}'
- discovery_id: aws.devicefarm.listUniqueProblems
  calls:
  - action: listUniqueProblems
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.uniqueProblems }}'
- discovery_id: aws.devicefarm.listUploads
  calls:
  - action: listUploads
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.uploads }}'
    item:
      arn: '{{ item.arn }}'
      name: '{{ item.name }}'
      created: '{{ item.created }}'
      type: '{{ item.type }}'
      status: '{{ item.status }}'
      url: '{{ item.url }}'
      metadata: '{{ item.metadata }}'
      contentType: '{{ item.contentType }}'
      message: '{{ item.message }}'
      category: '{{ item.category }}'
checks: []
