version: '1.0'
provider: aws
service: devicefarm
services:
  client: devicefarm
  module: boto3.client
discovery:
- discovery_id: aws.devicefarm.getAccountSettings
  calls:
  - action: getAccountSettings
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.accountSettings }}'
    item:
      awsAccountNumber: '{{ item.awsAccountNumber }}'
      unmeteredDevices: '{{ item.unmeteredDevices }}'
      unmeteredRemoteAccessDevices: '{{ item.unmeteredRemoteAccessDevices }}'
      maxJobTimeoutMinutes: '{{ item.maxJobTimeoutMinutes }}'
      trialMinutes: '{{ item.trialMinutes }}'
      maxSlots: '{{ item.maxSlots }}'
      defaultJobTimeoutMinutes: '{{ item.defaultJobTimeoutMinutes }}'
      skipAppResign: '{{ item.skipAppResign }}'
- discovery_id: aws.devicefarm.getOfferingStatus
  calls:
  - action: getOfferingStatus
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.current }}'
- discovery_id: aws.devicefarm.getTestGridSession
  calls:
  - action: getTestGridSession
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.testGridSession }}'
    item:
      arn: '{{ item.arn }}'
      status: '{{ item.status }}'
      created: '{{ item.created }}'
      ended: '{{ item.ended }}'
      billingMinutes: '{{ item.billingMinutes }}'
      seleniumProperties: '{{ item.seleniumProperties }}'
- discovery_id: aws.devicefarm.listDeviceInstances
  calls:
  - action: listDeviceInstances
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.deviceInstances }}'
    item:
      arn: '{{ item.arn }}'
      deviceArn: '{{ item.deviceArn }}'
      labels: '{{ item.labels }}'
      status: '{{ item.status }}'
      udid: '{{ item.udid }}'
      instanceProfile: '{{ item.instanceProfile }}'
- discovery_id: aws.devicefarm.listDevices
  calls:
  - action: listDevices
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.devices }}'
    item:
      arn: '{{ item.arn }}'
      name: '{{ item.name }}'
      manufacturer: '{{ item.manufacturer }}'
      model: '{{ item.model }}'
      modelId: '{{ item.modelId }}'
      formFactor: '{{ item.formFactor }}'
      platform: '{{ item.platform }}'
      os: '{{ item.os }}'
      cpu: '{{ item.cpu }}'
      resolution: '{{ item.resolution }}'
      heapSize: '{{ item.heapSize }}'
      memory: '{{ item.memory }}'
      image: '{{ item.image }}'
      carrier: '{{ item.carrier }}'
      radio: '{{ item.radio }}'
      remoteAccessEnabled: '{{ item.remoteAccessEnabled }}'
      remoteDebugEnabled: '{{ item.remoteDebugEnabled }}'
      fleetType: '{{ item.fleetType }}'
      fleetName: '{{ item.fleetName }}'
      instances: '{{ item.instances }}'
      availability: '{{ item.availability }}'
- discovery_id: aws.devicefarm.listInstanceProfiles
  calls:
  - action: listInstanceProfiles
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.instanceProfiles }}'
    item:
      arn: '{{ item.arn }}'
      packageCleanup: '{{ item.packageCleanup }}'
      excludeAppPackagesFromCleanup: '{{ item.excludeAppPackagesFromCleanup }}'
      rebootAfterUse: '{{ item.rebootAfterUse }}'
      name: '{{ item.name }}'
      description: '{{ item.description }}'
- discovery_id: aws.devicefarm.listOfferingPromotions
  calls:
  - action: listOfferingPromotions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.offeringPromotions }}'
    item:
      id: '{{ item.id }}'
      description: '{{ item.description }}'
- discovery_id: aws.devicefarm.listOfferingTransactions
  calls:
  - action: listOfferingTransactions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.offeringTransactions }}'
    item:
      offeringStatus: '{{ item.offeringStatus }}'
      transactionId: '{{ item.transactionId }}'
      offeringPromotionId: '{{ item.offeringPromotionId }}'
      createdOn: '{{ item.createdOn }}'
      cost: '{{ item.cost }}'
- discovery_id: aws.devicefarm.listOfferings
  calls:
  - action: listOfferings
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.offerings }}'
    item:
      id: '{{ item.id }}'
      description: '{{ item.description }}'
      type: '{{ item.type }}'
      platform: '{{ item.platform }}'
      recurringCharges: '{{ item.recurringCharges }}'
- discovery_id: aws.devicefarm.listProjects
  calls:
  - action: listProjects
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.projects }}'
    item:
      arn: '{{ item.arn }}'
      name: '{{ item.name }}'
      defaultJobTimeoutMinutes: '{{ item.defaultJobTimeoutMinutes }}'
      created: '{{ item.created }}'
      vpcConfig: '{{ item.vpcConfig }}'
      environmentVariables: '{{ item.environmentVariables }}'
      executionRoleArn: '{{ item.executionRoleArn }}'
- discovery_id: aws.devicefarm.listTestGridProjects
  calls:
  - action: listTestGridProjects
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.testGridProjects }}'
    item:
      arn: '{{ item.arn }}'
      name: '{{ item.name }}'
      description: '{{ item.description }}'
      vpcConfig: '{{ item.vpcConfig }}'
      created: '{{ item.created }}'
- discovery_id: aws.devicefarm.listVpceConfigurations
  calls:
  - action: listVpceConfigurations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.vpceConfigurations }}'
    item:
      arn: '{{ item.arn }}'
      vpceConfigurationName: '{{ item.vpceConfigurationName }}'
      vpceServiceName: '{{ item.vpceServiceName }}'
      serviceDnsName: '{{ item.serviceDnsName }}'
      vpceConfigurationDescription: '{{ item.vpceConfigurationDescription }}'
- discovery_id: aws.devicefarm.getDevice
  calls:
  - action: getDevice
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.device }}'
    item:
      arn: '{{ item.arn }}'
      name: '{{ item.name }}'
      manufacturer: '{{ item.manufacturer }}'
      model: '{{ item.model }}'
      modelId: '{{ item.modelId }}'
      formFactor: '{{ item.formFactor }}'
      platform: '{{ item.platform }}'
      os: '{{ item.os }}'
      cpu: '{{ item.cpu }}'
      resolution: '{{ item.resolution }}'
      heapSize: '{{ item.heapSize }}'
      memory: '{{ item.memory }}'
      image: '{{ item.image }}'
      carrier: '{{ item.carrier }}'
      radio: '{{ item.radio }}'
      remoteAccessEnabled: '{{ item.remoteAccessEnabled }}'
      remoteDebugEnabled: '{{ item.remoteDebugEnabled }}'
      fleetType: '{{ item.fleetType }}'
      fleetName: '{{ item.fleetName }}'
      instances: '{{ item.instances }}'
      availability: '{{ item.availability }}'
- discovery_id: aws.devicefarm.getDeviceInstance
  calls:
  - action: getDeviceInstance
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.deviceInstance }}'
    item:
      arn: '{{ item.arn }}'
      deviceArn: '{{ item.deviceArn }}'
      labels: '{{ item.labels }}'
      status: '{{ item.status }}'
      udid: '{{ item.udid }}'
      instanceProfile: '{{ item.instanceProfile }}'
- discovery_id: aws.devicefarm.getDevicePool
  calls:
  - action: getDevicePool
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.devicePool }}'
    item:
