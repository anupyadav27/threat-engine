version: '1.0'
provider: aws
service: translate
services:
  client: translate
  module: boto3.client
discovery:
- discovery_id: aws.translate.listLanguages
  calls:
  - action: listLanguages
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Languages }}'
    item:
      LanguageName: '{{ item.LanguageName }}'
      LanguageCode: '{{ item.LanguageCode }}'
- discovery_id: aws.translate.listParallelData
  calls:
  - action: listParallelData
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.ParallelDataPropertiesList }}'
    item:
      Name: '{{ item.Name }}'
      Arn: '{{ item.Arn }}'
      Description: '{{ item.Description }}'
      Status: '{{ item.Status }}'
      SourceLanguageCode: '{{ item.SourceLanguageCode }}'
      TargetLanguageCodes: '{{ item.TargetLanguageCodes }}'
      ParallelDataConfig: '{{ item.ParallelDataConfig }}'
      Message: '{{ item.Message }}'
      ImportedDataSize: '{{ item.ImportedDataSize }}'
      ImportedRecordCount: '{{ item.ImportedRecordCount }}'
      FailedRecordCount: '{{ item.FailedRecordCount }}'
      SkippedRecordCount: '{{ item.SkippedRecordCount }}'
      EncryptionKey: '{{ item.EncryptionKey }}'
      CreatedAt: '{{ item.CreatedAt }}'
      LastUpdatedAt: '{{ item.LastUpdatedAt }}'
      LatestUpdateAttemptStatus: '{{ item.LatestUpdateAttemptStatus }}'
      LatestUpdateAttemptAt: '{{ item.LatestUpdateAttemptAt }}'
- discovery_id: aws.translate.listTerminologies
  calls:
  - action: listTerminologies
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.TerminologyPropertiesList }}'
    item:
      Name: '{{ item.Name }}'
      Description: '{{ item.Description }}'
      Arn: '{{ item.Arn }}'
      SourceLanguageCode: '{{ item.SourceLanguageCode }}'
      TargetLanguageCodes: '{{ item.TargetLanguageCodes }}'
      EncryptionKey: '{{ item.EncryptionKey }}'
      SizeBytes: '{{ item.SizeBytes }}'
      TermCount: '{{ item.TermCount }}'
      CreatedAt: '{{ item.CreatedAt }}'
      LastUpdatedAt: '{{ item.LastUpdatedAt }}'
      Directionality: '{{ item.Directionality }}'
      Message: '{{ item.Message }}'
      SkippedTermCount: '{{ item.SkippedTermCount }}'
      Format: '{{ item.Format }}'
- discovery_id: aws.translate.listTextTranslationJobs
  calls:
  - action: listTextTranslationJobs
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.TextTranslationJobPropertiesList }}'
    item:
      JobId: '{{ item.JobId }}'
      JobName: '{{ item.JobName }}'
      JobStatus: '{{ item.JobStatus }}'
      JobDetails: '{{ item.JobDetails }}'
      SourceLanguageCode: '{{ item.SourceLanguageCode }}'
      TargetLanguageCodes: '{{ item.TargetLanguageCodes }}'
      TerminologyNames: '{{ item.TerminologyNames }}'
      ParallelDataNames: '{{ item.ParallelDataNames }}'
      Message: '{{ item.Message }}'
      SubmittedTime: '{{ item.SubmittedTime }}'
      EndTime: '{{ item.EndTime }}'
      InputDataConfig: '{{ item.InputDataConfig }}'
      OutputDataConfig: '{{ item.OutputDataConfig }}'
      DataAccessRoleArn: '{{ item.DataAccessRoleArn }}'
      Settings: '{{ item.Settings }}'
- discovery_id: aws.translate.describeTextTranslationJob
  calls:
  - action: describeTextTranslationJob
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.TextTranslationJobProperties }}'
    item:
      JobId: '{{ item.JobId }}'
      JobName: '{{ item.JobName }}'
      JobStatus: '{{ item.JobStatus }}'
      JobDetails: '{{ item.JobDetails }}'
      SourceLanguageCode: '{{ item.SourceLanguageCode }}'
      TargetLanguageCodes: '{{ item.TargetLanguageCodes }}'
      TerminologyNames: '{{ item.TerminologyNames }}'
      ParallelDataNames: '{{ item.ParallelDataNames }}'
      Message: '{{ item.Message }}'
      SubmittedTime: '{{ item.SubmittedTime }}'
      EndTime: '{{ item.EndTime }}'
      InputDataConfig: '{{ item.InputDataConfig }}'
      OutputDataConfig: '{{ item.OutputDataConfig }}'
      DataAccessRoleArn: '{{ item.DataAccessRoleArn }}'
      Settings: '{{ item.Settings }}'
- discovery_id: aws.translate.getParallelData
  calls:
  - action: getParallelData
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ParallelDataProperties }}'
    item:
      Name: '{{ item.Name }}'
      Arn: '{{ item.Arn }}'
      Description: '{{ item.Description }}'
      Status: '{{ item.Status }}'
      SourceLanguageCode: '{{ item.SourceLanguageCode }}'
      TargetLanguageCodes: '{{ item.TargetLanguageCodes }}'
      ParallelDataConfig: '{{ item.ParallelDataConfig }}'
      Message: '{{ item.Message }}'
      ImportedDataSize: '{{ item.ImportedDataSize }}'
      ImportedRecordCount: '{{ item.ImportedRecordCount }}'
      FailedRecordCount: '{{ item.FailedRecordCount }}'
      SkippedRecordCount: '{{ item.SkippedRecordCount }}'
      EncryptionKey: '{{ item.EncryptionKey }}'
      CreatedAt: '{{ item.CreatedAt }}'
      LastUpdatedAt: '{{ item.LastUpdatedAt }}'
      LatestUpdateAttemptStatus: '{{ item.LatestUpdateAttemptStatus }}'
      LatestUpdateAttemptAt: '{{ item.LatestUpdateAttemptAt }}'
- discovery_id: aws.translate.getTerminology
  calls:
  - action: getTerminology
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.TerminologyProperties }}'
    item:
      Name: '{{ item.Name }}'
      Description: '{{ item.Description }}'
      Arn: '{{ item.Arn }}'
      SourceLanguageCode: '{{ item.SourceLanguageCode }}'
      TargetLanguageCodes: '{{ item.TargetLanguageCodes }}'
      EncryptionKey: '{{ item.EncryptionKey }}'
      SizeBytes: '{{ item.SizeBytes }}'
      TermCount: '{{ item.TermCount }}'
      CreatedAt: '{{ item.CreatedAt }}'
      LastUpdatedAt: '{{ item.LastUpdatedAt }}'
      Directionality: '{{ item.Directionality }}'
      Message: '{{ item.Message }}'
      SkippedTermCount: '{{ item.SkippedTermCount }}'
      Format: '{{ item.Format }}'
- discovery_id: aws.translate.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Tags }}'
    item:
      Key: '{{ item.Key }}'
      Value: '{{ item.Value }}'
checks: []
