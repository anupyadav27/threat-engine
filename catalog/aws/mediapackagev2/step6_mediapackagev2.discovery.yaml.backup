version: '1.0'
provider: aws
service: mediapackagev2
services:
  client: mediapackagev2
  module: boto3.client
discovery:
- discovery_id: aws.mediapackagev2.listChannelGroups
  calls:
  - action: listChannelGroups
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Items }}'
    item:
      ChannelGroupName: '{{ item.ChannelGroupName }}'
      Arn: '{{ item.Arn }}'
      CreatedAt: '{{ item.CreatedAt }}'
      ModifiedAt: '{{ item.ModifiedAt }}'
      Description: '{{ item.Description }}'
- discovery_id: aws.mediapackagev2.getChannel
  calls:
  - action: getChannel
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.IngestEndpoints }}'
    item:
      Id: '{{ item.Id }}'
      Url: '{{ item.Url }}'
- discovery_id: aws.mediapackagev2.getChannelGroup
  calls:
  - action: getChannelGroup
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ChannelGroupName }}'
- discovery_id: aws.mediapackagev2.getChannelPolicy
  calls:
  - action: getChannelPolicy
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ChannelGroupName }}'
- discovery_id: aws.mediapackagev2.getHarvestJob
  calls:
  - action: getHarvestJob
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Destination }}'
    item:
      S3Destination: '{{ item.S3Destination }}'
- discovery_id: aws.mediapackagev2.getOriginEndpoint
  calls:
  - action: getOriginEndpoint
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.HlsManifests }}'
    item:
      ManifestName: '{{ item.ManifestName }}'
      Url: '{{ item.Url }}'
      ChildManifestName: '{{ item.ChildManifestName }}'
      ManifestWindowSeconds: '{{ item.ManifestWindowSeconds }}'
      ProgramDateTimeIntervalSeconds: '{{ item.ProgramDateTimeIntervalSeconds }}'
      ScteHls: '{{ item.ScteHls }}'
      FilterConfiguration: '{{ item.FilterConfiguration }}'
      StartTag: '{{ item.StartTag }}'
      UrlEncodeChildManifest: '{{ item.UrlEncodeChildManifest }}'
- discovery_id: aws.mediapackagev2.getOriginEndpointPolicy
  calls:
  - action: getOriginEndpointPolicy
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.CdnAuthConfiguration }}'
    item:
      CdnIdentifierSecretArns: '{{ item.CdnIdentifierSecretArns }}'
      SecretsRoleArn: '{{ item.SecretsRoleArn }}'
- discovery_id: aws.mediapackagev2.listChannels
  calls:
  - action: listChannels
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Items }}'
    item:
      Arn: '{{ item.Arn }}'
      ChannelName: '{{ item.ChannelName }}'
      ChannelGroupName: '{{ item.ChannelGroupName }}'
      CreatedAt: '{{ item.CreatedAt }}'
      ModifiedAt: '{{ item.ModifiedAt }}'
      Description: '{{ item.Description }}'
      InputType: '{{ item.InputType }}'
- discovery_id: aws.mediapackagev2.listHarvestJobs
  calls:
  - action: listHarvestJobs
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Items }}'
    item:
      ChannelGroupName: '{{ item.ChannelGroupName }}'
      ChannelName: '{{ item.ChannelName }}'
      OriginEndpointName: '{{ item.OriginEndpointName }}'
      Destination: '{{ item.Destination }}'
      HarvestJobName: '{{ item.HarvestJobName }}'
      HarvestedManifests: '{{ item.HarvestedManifests }}'
      Description: '{{ item.Description }}'
      ScheduleConfiguration: '{{ item.ScheduleConfiguration }}'
      Arn: '{{ item.Arn }}'
      CreatedAt: '{{ item.CreatedAt }}'
      ModifiedAt: '{{ item.ModifiedAt }}'
      Status: '{{ item.Status }}'
      ErrorMessage: '{{ item.ErrorMessage }}'
      ETag: '{{ item.ETag }}'
- discovery_id: aws.mediapackagev2.listOriginEndpoints
  calls:
  - action: listOriginEndpoints
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Items }}'
    item:
      Arn: '{{ item.Arn }}'
      ChannelGroupName: '{{ item.ChannelGroupName }}'
      ChannelName: '{{ item.ChannelName }}'
      OriginEndpointName: '{{ item.OriginEndpointName }}'
      ContainerType: '{{ item.ContainerType }}'
      Description: '{{ item.Description }}'
      CreatedAt: '{{ item.CreatedAt }}'
      ModifiedAt: '{{ item.ModifiedAt }}'
      HlsManifests: '{{ item.HlsManifests }}'
      LowLatencyHlsManifests: '{{ item.LowLatencyHlsManifests }}'
      DashManifests: '{{ item.DashManifests }}'
      MssManifests: '{{ item.MssManifests }}'
      ForceEndpointErrorConfiguration: '{{ item.ForceEndpointErrorConfiguration }}'
- discovery_id: aws.mediapackagev2.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Tags }}'
checks: []
