version: '1.0'
provider: aws
service: mediaconvert
services:
  client: mediaconvert
  module: boto3.client
discovery:
- discovery_id: aws.mediaconvert.describeEndpoints
  calls:
  - action: describeEndpoints
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Endpoints }}'
    item:
      Url: '{{ item.Url }}'
- discovery_id: aws.mediaconvert.getPolicy
  calls:
  - action: getPolicy
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Policy }}'
    item:
      HttpInputs: '{{ item.HttpInputs }}'
      HttpsInputs: '{{ item.HttpsInputs }}'
      S3Inputs: '{{ item.S3Inputs }}'
- discovery_id: aws.mediaconvert.listJobTemplates
  calls:
  - action: listJobTemplates
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.JobTemplates }}'
    item:
      AccelerationSettings: '{{ item.AccelerationSettings }}'
      Arn: '{{ item.Arn }}'
      Category: '{{ item.Category }}'
      CreatedAt: '{{ item.CreatedAt }}'
      Description: '{{ item.Description }}'
      HopDestinations: '{{ item.HopDestinations }}'
      LastUpdated: '{{ item.LastUpdated }}'
      Name: '{{ item.Name }}'
      Priority: '{{ item.Priority }}'
      Queue: '{{ item.Queue }}'
      Settings: '{{ item.Settings }}'
      StatusUpdateInterval: '{{ item.StatusUpdateInterval }}'
      Type: '{{ item.Type }}'
- discovery_id: aws.mediaconvert.listJobs
  calls:
  - action: listJobs
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Jobs }}'
    item:
      AccelerationSettings: '{{ item.AccelerationSettings }}'
      AccelerationStatus: '{{ item.AccelerationStatus }}'
      Arn: '{{ item.Arn }}'
      BillingTagsSource: '{{ item.BillingTagsSource }}'
      ClientRequestToken: '{{ item.ClientRequestToken }}'
      CreatedAt: '{{ item.CreatedAt }}'
      CurrentPhase: '{{ item.CurrentPhase }}'
      ErrorCode: '{{ item.ErrorCode }}'
      ErrorMessage: '{{ item.ErrorMessage }}'
      HopDestinations: '{{ item.HopDestinations }}'
      Id: '{{ item.Id }}'
      JobEngineVersionRequested: '{{ item.JobEngineVersionRequested }}'
      JobEngineVersionUsed: '{{ item.JobEngineVersionUsed }}'
      JobPercentComplete: '{{ item.JobPercentComplete }}'
      JobTemplate: '{{ item.JobTemplate }}'
      LastShareDetails: '{{ item.LastShareDetails }}'
      Messages: '{{ item.Messages }}'
      OutputGroupDetails: '{{ item.OutputGroupDetails }}'
      Priority: '{{ item.Priority }}'
      Queue: '{{ item.Queue }}'
      QueueTransitions: '{{ item.QueueTransitions }}'
      RetryCount: '{{ item.RetryCount }}'
      Role: '{{ item.Role }}'
      Settings: '{{ item.Settings }}'
      ShareStatus: '{{ item.ShareStatus }}'
      SimulateReservedQueue: '{{ item.SimulateReservedQueue }}'
      Status: '{{ item.Status }}'
      StatusUpdateInterval: '{{ item.StatusUpdateInterval }}'
      Timing: '{{ item.Timing }}'
      UserMetadata: '{{ item.UserMetadata }}'
      Warnings: '{{ item.Warnings }}'
- discovery_id: aws.mediaconvert.listPresets
  calls:
  - action: listPresets
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Presets }}'
    item:
      Arn: '{{ item.Arn }}'
      Category: '{{ item.Category }}'
      CreatedAt: '{{ item.CreatedAt }}'
      Description: '{{ item.Description }}'
      LastUpdated: '{{ item.LastUpdated }}'
      Name: '{{ item.Name }}'
      Settings: '{{ item.Settings }}'
      Type: '{{ item.Type }}'
- discovery_id: aws.mediaconvert.listQueues
  calls:
  - action: listQueues
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Queues }}'
    item:
      Arn: '{{ item.Arn }}'
      ConcurrentJobs: '{{ item.ConcurrentJobs }}'
      CreatedAt: '{{ item.CreatedAt }}'
      Description: '{{ item.Description }}'
      LastUpdated: '{{ item.LastUpdated }}'
      Name: '{{ item.Name }}'
      PricingPlan: '{{ item.PricingPlan }}'
      ProgressingJobsCount: '{{ item.ProgressingJobsCount }}'
      ReservationPlan: '{{ item.ReservationPlan }}'
      ServiceOverrides: '{{ item.ServiceOverrides }}'
      Status: '{{ item.Status }}'
      SubmittedJobsCount: '{{ item.SubmittedJobsCount }}'
      Type: '{{ item.Type }}'
- discovery_id: aws.mediaconvert.listVersions
  calls:
  - action: listVersions
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Versions }}'
    item:
      ExpirationDate: '{{ item.ExpirationDate }}'
      Version: '{{ item.Version }}'
- discovery_id: aws.mediaconvert.searchJobs
  calls:
  - action: searchJobs
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Jobs }}'
    item:
      AccelerationSettings: '{{ item.AccelerationSettings }}'
      AccelerationStatus: '{{ item.AccelerationStatus }}'
      Arn: '{{ item.Arn }}'
      BillingTagsSource: '{{ item.BillingTagsSource }}'
      ClientRequestToken: '{{ item.ClientRequestToken }}'
      CreatedAt: '{{ item.CreatedAt }}'
      CurrentPhase: '{{ item.CurrentPhase }}'
      ErrorCode: '{{ item.ErrorCode }}'
      ErrorMessage: '{{ item.ErrorMessage }}'
      HopDestinations: '{{ item.HopDestinations }}'
      Id: '{{ item.Id }}'
      JobEngineVersionRequested: '{{ item.JobEngineVersionRequested }}'
      JobEngineVersionUsed: '{{ item.JobEngineVersionUsed }}'
      JobPercentComplete: '{{ item.JobPercentComplete }}'
      JobTemplate: '{{ item.JobTemplate }}'
      LastShareDetails: '{{ item.LastShareDetails }}'
      Messages: '{{ item.Messages }}'
      OutputGroupDetails: '{{ item.OutputGroupDetails }}'
      Priority: '{{ item.Priority }}'
      Queue: '{{ item.Queue }}'
      QueueTransitions: '{{ item.QueueTransitions }}'
      RetryCount: '{{ item.RetryCount }}'
      Role: '{{ item.Role }}'
      Settings: '{{ item.Settings }}'
      ShareStatus: '{{ item.ShareStatus }}'
      SimulateReservedQueue: '{{ item.SimulateReservedQueue }}'
      Status: '{{ item.Status }}'
      StatusUpdateInterval: '{{ item.StatusUpdateInterval }}'
      Timing: '{{ item.Timing }}'
      UserMetadata: '{{ item.UserMetadata }}'
      Warnings: '{{ item.Warnings }}'
- discovery_id: aws.mediaconvert.getJob
  calls:
  - action: getJob
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Job }}'
    item:
      AccelerationSettings: '{{ item.AccelerationSettings }}'
      AccelerationStatus: '{{ item.AccelerationStatus }}'
      Arn: '{{ item.Arn }}'
      BillingTagsSource: '{{ item.BillingTagsSource }}'
      ClientRequestToken: '{{ item.ClientRequestToken }}'
      CreatedAt: '{{ item.CreatedAt }}'
      CurrentPhase: '{{ item.CurrentPhase }}'
      ErrorCode: '{{ item.ErrorCode }}'
      ErrorMessage: '{{ item.ErrorMessage }}'
      HopDestinations: '{{ item.HopDestinations }}'
      Id: '{{ item.Id }}'
      JobEngineVersionRequested: '{{ item.JobEngineVersionRequested }}'
      JobEngineVersionUsed: '{{ item.JobEngineVersionUsed }}'
      JobPercentComplete: '{{ item.JobPercentComplete }}'
      JobTemplate: '{{ item.JobTemplate }}'
      LastShareDetails: '{{ item.LastShareDetails }}'
      Messages: '{{ item.Messages }}'
      OutputGroupDetails: '{{ item.OutputGroupDetails }}'
      Priority: '{{ item.Priority }}'
      Queue: '{{ item.Queue }}'
      QueueTransitions: '{{ item.QueueTransitions }}'
      RetryCount: '{{ item.RetryCount }}'
      Role: '{{ item.Role }}'
      Settings: '{{ item.Settings }}'
      ShareStatus: '{{ item.ShareStatus }}'
      SimulateReservedQueue: '{{ item.SimulateReservedQueue }}'
      Status: '{{ item.Status }}'
      StatusUpdateInterval: '{{ item.StatusUpdateInterval }}'
      Timing: '{{ item.Timing }}'
      UserMetadata: '{{ item.UserMetadata }}'
      Warnings: '{{ item.Warnings }}'
- discovery_id: aws.mediaconvert.getJobTemplate
  calls:
  - action: getJobTemplate
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.JobTemplate }}'
    item:
      AccelerationSettings: '{{ item.AccelerationSettings }}'
      Arn: '{{ item.Arn }}'
      Category: '{{ item.Category }}'
      CreatedAt: '{{ item.CreatedAt }}'
      Description: '{{ item.Description }}'
      HopDestinations: '{{ item.HopDestinations }}'
      LastUpdated: '{{ item.LastUpdated }}'
      Name: '{{ item.Name }}'
      Priority: '{{ item.Priority }}'
      Queue: '{{ item.Queue }}'
      Settings: '{{ item.Settings }}'
      StatusUpdateInterval: '{{ item.StatusUpdateInterval }}'
      Type: '{{ item.Type }}'
- discovery_id: aws.mediaconvert.getJobsQueryResults
  calls:
  - action: getJobsQueryResults
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Jobs }}'
    item:
      AccelerationSettings: '{{ item.AccelerationSettings }}'
      AccelerationStatus: '{{ item.AccelerationStatus }}'
      Arn: '{{ item.Arn }}'
      BillingTagsSource: '{{ item.BillingTagsSource }}'
      ClientRequestToken: '{{ item.ClientRequestToken }}'
      CreatedAt: '{{ item.CreatedAt }}'
      CurrentPhase: '{{ item.CurrentPhase }}'
      ErrorCode: '{{ item.ErrorCode }}'
      ErrorMessage: '{{ item.ErrorMessage }}'
      HopDestinations: '{{ item.HopDestinations }}'
      Id: '{{ item.Id }}'
      JobEngineVersionRequested: '{{ item.JobEngineVersionRequested }}'
      JobEngineVersionUsed: '{{ item.JobEngineVersionUsed }}'
      JobPercentComplete: '{{ item.JobPercentComplete }}'
      JobTemplate: '{{ item.JobTemplate }}'
      LastShareDetails: '{{ item.LastShareDetails }}'
      Messages: '{{ item.Messages }}'
      OutputGroupDetails: '{{ item.OutputGroupDetails }}'
      Priority: '{{ item.Priority }}'
      Queue: '{{ item.Queue }}'
      QueueTransitions: '{{ item.QueueTransitions }}'
      RetryCount: '{{ item.RetryCount }}'
      Role: '{{ item.Role }}'
      Settings: '{{ item.Settings }}'
      ShareStatus: '{{ item.ShareStatus }}'
      SimulateReservedQueue: '{{ item.SimulateReservedQueue }}'
      Status: '{{ item.Status }}'
      StatusUpdateInterval: '{{ item.StatusUpdateInterval }}'
      Timing: '{{ item.Timing }}'
      UserMetadata: '{{ item.UserMetadata }}'
      Warnings: '{{ item.Warnings }}'
- discovery_id: aws.mediaconvert.getPreset
  calls:
  - action: getPreset
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Preset }}'
    item:
      Arn: '{{ item.Arn }}'
      Category: '{{ item.Category }}'
      CreatedAt: '{{ item.CreatedAt }}'
      Description: '{{ item.Description }}'
      LastUpdated: '{{ item.LastUpdated }}'
      Name: '{{ item.Name }}'
      Settings: '{{ item.Settings }}'
      Type: '{{ item.Type }}'
- discovery_id: aws.mediaconvert.getQueue
  calls:
  - action: getQueue
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Queue }}'
    item:
      Arn: '{{ item.Arn }}'
      ConcurrentJobs: '{{ item.ConcurrentJobs }}'
      CreatedAt: '{{ item.CreatedAt }}'
      Description: '{{ item.Description }}'
      LastUpdated: '{{ item.LastUpdated }}'
      Name: '{{ item.Name }}'
      PricingPlan: '{{ item.PricingPlan }}'
      ProgressingJobsCount: '{{ item.ProgressingJobsCount }}'
      ReservationPlan: '{{ item.ReservationPlan }}'
      ServiceOverrides: '{{ item.ServiceOverrides }}'
      Status: '{{ item.Status }}'
      SubmittedJobsCount: '{{ item.SubmittedJobsCount }}'
      Type: '{{ item.Type }}'
- discovery_id: aws.mediaconvert.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ResourceTags }}'
    item:
      Arn: '{{ item.Arn }}'
      Tags: '{{ item.Tags }}'
checks: []
