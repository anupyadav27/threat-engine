version: '1.0'
provider: aws
service: mturk
services:
  client: mturk
  module: boto3.client
discovery:
- discovery_id: aws.mturk.getAccountBalance
  calls:
  - action: getAccountBalance
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AvailableBalance }}'
- discovery_id: aws.mturk.listBonusPayments
  calls:
  - action: listBonusPayments
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.BonusPayments }}'
    item:
      WorkerId: '{{ item.WorkerId }}'
      BonusAmount: '{{ item.BonusAmount }}'
      AssignmentId: '{{ item.AssignmentId }}'
      Reason: '{{ item.Reason }}'
      GrantTime: '{{ item.GrantTime }}'
- discovery_id: aws.mturk.listHiTs
  calls:
  - action: listHiTs
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.HITs }}'
    item:
      HITId: '{{ item.HITId }}'
      HITTypeId: '{{ item.HITTypeId }}'
      HITGroupId: '{{ item.HITGroupId }}'
      HITLayoutId: '{{ item.HITLayoutId }}'
      CreationTime: '{{ item.CreationTime }}'
      Title: '{{ item.Title }}'
      Description: '{{ item.Description }}'
      Question: '{{ item.Question }}'
      Keywords: '{{ item.Keywords }}'
      HITStatus: '{{ item.HITStatus }}'
      MaxAssignments: '{{ item.MaxAssignments }}'
      Reward: '{{ item.Reward }}'
      AutoApprovalDelayInSeconds: '{{ item.AutoApprovalDelayInSeconds }}'
      Expiration: '{{ item.Expiration }}'
      AssignmentDurationInSeconds: '{{ item.AssignmentDurationInSeconds }}'
      RequesterAnnotation: '{{ item.RequesterAnnotation }}'
      QualificationRequirements: '{{ item.QualificationRequirements }}'
      HITReviewStatus: '{{ item.HITReviewStatus }}'
      NumberOfAssignmentsPending: '{{ item.NumberOfAssignmentsPending }}'
      NumberOfAssignmentsAvailable: '{{ item.NumberOfAssignmentsAvailable }}'
      NumberOfAssignmentsCompleted: '{{ item.NumberOfAssignmentsCompleted }}'
- discovery_id: aws.mturk.listQualificationRequests
  calls:
  - action: listQualificationRequests
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.QualificationRequests }}'
    item:
      QualificationRequestId: '{{ item.QualificationRequestId }}'
      QualificationTypeId: '{{ item.QualificationTypeId }}'
      WorkerId: '{{ item.WorkerId }}'
      Test: '{{ item.Test }}'
      Answer: '{{ item.Answer }}'
      SubmitTime: '{{ item.SubmitTime }}'
- discovery_id: aws.mturk.listReviewableHiTs
  calls:
  - action: listReviewableHiTs
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.HITs }}'
    item:
      HITId: '{{ item.HITId }}'
      HITTypeId: '{{ item.HITTypeId }}'
      HITGroupId: '{{ item.HITGroupId }}'
      HITLayoutId: '{{ item.HITLayoutId }}'
      CreationTime: '{{ item.CreationTime }}'
      Title: '{{ item.Title }}'
      Description: '{{ item.Description }}'
      Question: '{{ item.Question }}'
      Keywords: '{{ item.Keywords }}'
      HITStatus: '{{ item.HITStatus }}'
      MaxAssignments: '{{ item.MaxAssignments }}'
      Reward: '{{ item.Reward }}'
      AutoApprovalDelayInSeconds: '{{ item.AutoApprovalDelayInSeconds }}'
      Expiration: '{{ item.Expiration }}'
      AssignmentDurationInSeconds: '{{ item.AssignmentDurationInSeconds }}'
      RequesterAnnotation: '{{ item.RequesterAnnotation }}'
      QualificationRequirements: '{{ item.QualificationRequirements }}'
      HITReviewStatus: '{{ item.HITReviewStatus }}'
      NumberOfAssignmentsPending: '{{ item.NumberOfAssignmentsPending }}'
      NumberOfAssignmentsAvailable: '{{ item.NumberOfAssignmentsAvailable }}'
      NumberOfAssignmentsCompleted: '{{ item.NumberOfAssignmentsCompleted }}'
- discovery_id: aws.mturk.listWorkerBlocks
  calls:
  - action: listWorkerBlocks
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.WorkerBlocks }}'
    item:
      WorkerId: '{{ item.WorkerId }}'
      Reason: '{{ item.Reason }}'
- discovery_id: aws.mturk.getAssignment
  calls:
  - action: getAssignment
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Assignment }}'
    item:
      AssignmentId: '{{ item.AssignmentId }}'
      WorkerId: '{{ item.WorkerId }}'
      HITId: '{{ item.HITId }}'
      AssignmentStatus: '{{ item.AssignmentStatus }}'
      AutoApprovalTime: '{{ item.AutoApprovalTime }}'
      AcceptTime: '{{ item.AcceptTime }}'
      SubmitTime: '{{ item.SubmitTime }}'
      ApprovalTime: '{{ item.ApprovalTime }}'
      RejectionTime: '{{ item.RejectionTime }}'
      Deadline: '{{ item.Deadline }}'
      Answer: '{{ item.Answer }}'
      RequesterFeedback: '{{ item.RequesterFeedback }}'
- discovery_id: aws.mturk.getFileUploadUrl
  calls:
  - action: getFileUploadUrl
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.FileUploadURL }}'
- discovery_id: aws.mturk.getHit
  calls:
  - action: getHit
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.HIT }}'
    item:
      HITId: '{{ item.HITId }}'
      HITTypeId: '{{ item.HITTypeId }}'
      HITGroupId: '{{ item.HITGroupId }}'
      HITLayoutId: '{{ item.HITLayoutId }}'
      CreationTime: '{{ item.CreationTime }}'
      Title: '{{ item.Title }}'
      Description: '{{ item.Description }}'
      Question: '{{ item.Question }}'
      Keywords: '{{ item.Keywords }}'
      HITStatus: '{{ item.HITStatus }}'
      MaxAssignments: '{{ item.MaxAssignments }}'
      Reward: '{{ item.Reward }}'
      AutoApprovalDelayInSeconds: '{{ item.AutoApprovalDelayInSeconds }}'
      Expiration: '{{ item.Expiration }}'
      AssignmentDurationInSeconds: '{{ item.AssignmentDurationInSeconds }}'
      RequesterAnnotation: '{{ item.RequesterAnnotation }}'
      QualificationRequirements: '{{ item.QualificationRequirements }}'
      HITReviewStatus: '{{ item.HITReviewStatus }}'
      NumberOfAssignmentsPending: '{{ item.NumberOfAssignmentsPending }}'
      NumberOfAssignmentsAvailable: '{{ item.NumberOfAssignmentsAvailable }}'
      NumberOfAssignmentsCompleted: '{{ item.NumberOfAssignmentsCompleted }}'
- discovery_id: aws.mturk.getQualificationScore
  calls:
  - action: getQualificationScore
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Qualification }}'
    item:
      QualificationTypeId: '{{ item.QualificationTypeId }}'
      WorkerId: '{{ item.WorkerId }}'
      GrantTime: '{{ item.GrantTime }}'
      IntegerValue: '{{ item.IntegerValue }}'
      LocaleValue: '{{ item.LocaleValue }}'
      Status: '{{ item.Status }}'
- discovery_id: aws.mturk.getQualificationType
  calls:
  - action: getQualificationType
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.QualificationType }}'
    item:
      QualificationTypeId: '{{ item.QualificationTypeId }}'
      CreationTime: '{{ item.CreationTime }}'
      Name: '{{ item.Name }}'
      Description: '{{ item.Description }}'
      Keywords: '{{ item.Keywords }}'
      QualificationTypeStatus: '{{ item.QualificationTypeStatus }}'
      Test: '{{ item.Test }}'
      TestDurationInSeconds: '{{ item.TestDurationInSeconds }}'
      AnswerKey: '{{ item.AnswerKey }}'
      RetryDelayInSeconds: '{{ item.RetryDelayInSeconds }}'
      IsRequestable: '{{ item.IsRequestable }}'
      AutoGranted: '{{ item.AutoGranted }}'
      AutoGrantedValue: '{{ item.AutoGrantedValue }}'
- discovery_id: aws.mturk.listAssignmentsForHit
  calls:
  - action: listAssignmentsForHit
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Assignments }}'
    item:
      AssignmentId: '{{ item.AssignmentId }}'
      WorkerId: '{{ item.WorkerId }}'
      HITId: '{{ item.HITId }}'
      AssignmentStatus: '{{ item.AssignmentStatus }}'
      AutoApprovalTime: '{{ item.AutoApprovalTime }}'
      AcceptTime: '{{ item.AcceptTime }}'
      SubmitTime: '{{ item.SubmitTime }}'
      ApprovalTime: '{{ item.ApprovalTime }}'
      RejectionTime: '{{ item.RejectionTime }}'
      Deadline: '{{ item.Deadline }}'
      Answer: '{{ item.Answer }}'
      RequesterFeedback: '{{ item.RequesterFeedback }}'
- discovery_id: aws.mturk.listHiTsForQualificationType
  calls:
  - action: listHiTsForQualificationType
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.HITs }}'
    item:
      HITId: '{{ item.HITId }}'
      HITTypeId: '{{ item.HITTypeId }}'
      HITGroupId: '{{ item.HITGroupId }}'
      HITLayoutId: '{{ item.HITLayoutId }}'
      CreationTime: '{{ item.CreationTime }}'
      Title: '{{ item.Title }}'
      Description: '{{ item.Description }}'
      Question: '{{ item.Question }}'
      Keywords: '{{ item.Keywords }}'
      HITStatus: '{{ item.HITStatus }}'
      MaxAssignments: '{{ item.MaxAssignments }}'
      Reward: '{{ item.Reward }}'
      AutoApprovalDelayInSeconds: '{{ item.AutoApprovalDelayInSeconds }}'
      Expiration: '{{ item.Expiration }}'
      AssignmentDurationInSeconds: '{{ item.AssignmentDurationInSeconds }}'
      RequesterAnnotation: '{{ item.RequesterAnnotation }}'
      QualificationRequirements: '{{ item.QualificationRequirements }}'
      HITReviewStatus: '{{ item.HITReviewStatus }}'
      NumberOfAssignmentsPending: '{{ item.NumberOfAssignmentsPending }}'
      NumberOfAssignmentsAvailable: '{{ item.NumberOfAssignmentsAvailable }}'
      NumberOfAssignmentsCompleted: '{{ item.NumberOfAssignmentsCompleted }}'
- discovery_id: aws.mturk.listQualificationTypes
  calls:
  - action: listQualificationTypes
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.QualificationTypes }}'
    item:
      QualificationTypeId: '{{ item.QualificationTypeId }}'
      CreationTime: '{{ item.CreationTime }}'
      Name: '{{ item.Name }}'
      Description: '{{ item.Description }}'
      Keywords: '{{ item.Keywords }}'
      QualificationTypeStatus: '{{ item.QualificationTypeStatus }}'
      Test: '{{ item.Test }}'
      TestDurationInSeconds: '{{ item.TestDurationInSeconds }}'
      AnswerKey: '{{ item.AnswerKey }}'
      RetryDelayInSeconds: '{{ item.RetryDelayInSeconds }}'
      IsRequestable: '{{ item.IsRequestable }}'
      AutoGranted: '{{ item.AutoGranted }}'
      AutoGrantedValue: '{{ item.AutoGrantedValue }}'
- discovery_id: aws.mturk.listReviewPolicyResultsForHit
  calls:
  - action: listReviewPolicyResultsForHit
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.AssignmentReviewPolicy }}'
    item:
      PolicyName: '{{ item.PolicyName }}'
      Parameters: '{{ item.Parameters }}'
- discovery_id: aws.mturk.listWorkersWithQualificationType
  calls:
  - action: listWorkersWithQualificationType
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Qualifications }}'
    item:
      QualificationTypeId: '{{ item.QualificationTypeId }}'
      WorkerId: '{{ item.WorkerId }}'
      GrantTime: '{{ item.GrantTime }}'
      IntegerValue: '{{ item.IntegerValue }}'
      LocaleValue: '{{ item.LocaleValue }}'
      Status: '{{ item.Status }}'
checks: []
