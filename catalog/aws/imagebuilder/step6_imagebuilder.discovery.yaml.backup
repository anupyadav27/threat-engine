version: '1.0'
provider: aws
service: imagebuilder
services:
  client: imagebuilder
  module: boto3.client
discovery:
- discovery_id: aws.imagebuilder.listComponentBuildVersions
  calls:
  - action: listComponentBuildVersions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.componentSummaryList }}'
    item:
      arn: '{{ item.arn }}'
      name: '{{ item.name }}'
      version: '{{ item.version }}'
      platform: '{{ item.platform }}'
      supportedOsVersions: '{{ item.supportedOsVersions }}'
      state: '{{ item.state }}'
      type: '{{ item.type }}'
      owner: '{{ item.owner }}'
      description: '{{ item.description }}'
      changeDescription: '{{ item.changeDescription }}'
      dateCreated: '{{ item.dateCreated }}'
      tags: '{{ item.tags }}'
      publisher: '{{ item.publisher }}'
      obfuscate: '{{ item.obfuscate }}'
- discovery_id: aws.imagebuilder.listComponents
  calls:
  - action: listComponents
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.componentVersionList }}'
    item:
      arn: '{{ item.arn }}'
      name: '{{ item.name }}'
      version: '{{ item.version }}'
      description: '{{ item.description }}'
      platform: '{{ item.platform }}'
      supportedOsVersions: '{{ item.supportedOsVersions }}'
      type: '{{ item.type }}'
      owner: '{{ item.owner }}'
      dateCreated: '{{ item.dateCreated }}'
      status: '{{ item.status }}'
      productCodes: '{{ item.productCodes }}'
- discovery_id: aws.imagebuilder.listContainerRecipes
  calls:
  - action: listContainerRecipes
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.containerRecipeSummaryList }}'
    item:
      arn: '{{ item.arn }}'
      containerType: '{{ item.containerType }}'
      name: '{{ item.name }}'
      platform: '{{ item.platform }}'
      owner: '{{ item.owner }}'
      parentImage: '{{ item.parentImage }}'
      dateCreated: '{{ item.dateCreated }}'
      instanceImage: '{{ item.instanceImage }}'
      tags: '{{ item.tags }}'
- discovery_id: aws.imagebuilder.listDistributionConfigurations
  calls:
  - action: listDistributionConfigurations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.distributionConfigurationSummaryList }}'
    item:
      arn: '{{ item.arn }}'
      name: '{{ item.name }}'
      description: '{{ item.description }}'
      dateCreated: '{{ item.dateCreated }}'
      dateUpdated: '{{ item.dateUpdated }}'
      tags: '{{ item.tags }}'
      regions: '{{ item.regions }}'
- discovery_id: aws.imagebuilder.listImageBuildVersions
  calls:
  - action: listImageBuildVersions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.imageSummaryList }}'
    item:
      arn: '{{ item.arn }}'
      name: '{{ item.name }}'
      type: '{{ item.type }}'
      version: '{{ item.version }}'
      platform: '{{ item.platform }}'
      osVersion: '{{ item.osVersion }}'
      state: '{{ item.state }}'
      owner: '{{ item.owner }}'
      dateCreated: '{{ item.dateCreated }}'
      outputResources: '{{ item.outputResources }}'
      tags: '{{ item.tags }}'
      buildType: '{{ item.buildType }}'
      imageSource: '{{ item.imageSource }}'
      deprecationTime: '{{ item.deprecationTime }}'
      lifecycleExecutionId: '{{ item.lifecycleExecutionId }}'
      loggingConfiguration: '{{ item.loggingConfiguration }}'
- discovery_id: aws.imagebuilder.listImagePipelines
  calls:
  - action: listImagePipelines
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.imagePipelineList }}'
    item:
      arn: '{{ item.arn }}'
      name: '{{ item.name }}'
      description: '{{ item.description }}'
      platform: '{{ item.platform }}'
      enhancedImageMetadataEnabled: '{{ item.enhancedImageMetadataEnabled }}'
      imageRecipeArn: '{{ item.imageRecipeArn }}'
      containerRecipeArn: '{{ item.containerRecipeArn }}'
      infrastructureConfigurationArn: '{{ item.infrastructureConfigurationArn }}'
      distributionConfigurationArn: '{{ item.distributionConfigurationArn }}'
      imageTestsConfiguration: '{{ item.imageTestsConfiguration }}'
      schedule: '{{ item.schedule }}'
      status: '{{ item.status }}'
      dateCreated: '{{ item.dateCreated }}'
      dateUpdated: '{{ item.dateUpdated }}'
      dateLastRun: '{{ item.dateLastRun }}'
      lastRunStatus: '{{ item.lastRunStatus }}'
      dateNextRun: '{{ item.dateNextRun }}'
      tags: '{{ item.tags }}'
      imageScanningConfiguration: '{{ item.imageScanningConfiguration }}'
      executionRole: '{{ item.executionRole }}'
      workflows: '{{ item.workflows }}'
      loggingConfiguration: '{{ item.loggingConfiguration }}'
      consecutiveFailures: '{{ item.consecutiveFailures }}'
- discovery_id: aws.imagebuilder.listImageRecipes
  calls:
  - action: listImageRecipes
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.imageRecipeSummaryList }}'
    item:
      arn: '{{ item.arn }}'
      name: '{{ item.name }}'
      platform: '{{ item.platform }}'
      owner: '{{ item.owner }}'
      parentImage: '{{ item.parentImage }}'
      dateCreated: '{{ item.dateCreated }}'
      tags: '{{ item.tags }}'
- discovery_id: aws.imagebuilder.listImageScanFindingAggregations
  calls:
  - action: listImageScanFindingAggregations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.responses }}'
    item:
      accountAggregation: '{{ item.accountAggregation }}'
      imageAggregation: '{{ item.imageAggregation }}'
      imagePipelineAggregation: '{{ item.imagePipelineAggregation }}'
      vulnerabilityIdAggregation: '{{ item.vulnerabilityIdAggregation }}'
- discovery_id: aws.imagebuilder.listImageScanFindings
  calls:
  - action: listImageScanFindings
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.findings }}'
    item:
      awsAccountId: '{{ item.awsAccountId }}'
      imageBuildVersionArn: '{{ item.imageBuildVersionArn }}'
      imagePipelineArn: '{{ item.imagePipelineArn }}'
      type: '{{ item.type }}'
      description: '{{ item.description }}'
      title: '{{ item.title }}'
      remediation: '{{ item.remediation }}'
      severity: '{{ item.severity }}'
      firstObservedAt: '{{ item.firstObservedAt }}'
      updatedAt: '{{ item.updatedAt }}'
      inspectorScore: '{{ item.inspectorScore }}'
      inspectorScoreDetails: '{{ item.inspectorScoreDetails }}'
      packageVulnerabilityDetails: '{{ item.packageVulnerabilityDetails }}'
      fixAvailable: '{{ item.fixAvailable }}'
- discovery_id: aws.imagebuilder.listImages
  calls:
  - action: listImages
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.imageVersionList }}'
    item:
      arn: '{{ item.arn }}'
      name: '{{ item.name }}'
      type: '{{ item.type }}'
      version: '{{ item.version }}'
