    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.infrastructureConfigurationSummaryList }}'
    item:
      arn: '{{ item.arn }}'
      name: '{{ item.name }}'
      description: '{{ item.description }}'
      dateCreated: '{{ item.dateCreated }}'
      dateUpdated: '{{ item.dateUpdated }}'
      resourceTags: '{{ item.resourceTags }}'
      tags: '{{ item.tags }}'
      instanceTypes: '{{ item.instanceTypes }}'
      instanceProfileName: '{{ item.instanceProfileName }}'
