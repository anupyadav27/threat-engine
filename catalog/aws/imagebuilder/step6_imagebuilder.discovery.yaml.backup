  - action: listWorkflowStepExecutions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.steps }}'
    item:
      stepExecutionId: '{{ item.stepExecutionId }}'
      name: '{{ item.name }}'
      description: '{{ item.description }}'
      action: '{{ item.action }}'
      status: '{{ item.status }}'
      rollbackStatus: '{{ item.rollbackStatus }}'
      message: '{{ item.message }}'
      inputs: '{{ item.inputs }}'
      outputs: '{{ item.outputs }}'
      startTime: '{{ item.startTime }}'
      endTime: '{{ item.endTime }}'
checks: []
