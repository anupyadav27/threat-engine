- discovery_id: aws.redshift.describeHsmConfigurations
  calls:
  - action: describeHsmConfigurations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.HsmConfigurations }}'
    item:
      HsmConfigurationIdentifier: '{{ item.HsmConfigurationIdentifier }}'
      Description: '{{ item.Description }}'
      HsmIpAddress: '{{ item.HsmIpAddress }}'
      HsmPartitionName: '{{ item.HsmPartitionName }}'
      Tags: '{{ item.Tags }}'
- discovery_id: aws.redshift.describeInboundIntegrations
  calls:
  - action: describeInboundIntegrations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.InboundIntegrations }}'
    item:
      IntegrationArn: '{{ item.IntegrationArn }}'
      SourceArn: '{{ item.SourceArn }}'
      TargetArn: '{{ item.TargetArn }}'
      Status: '{{ item.Status }}'
      Errors: '{{ item.Errors }}'
      CreateTime: '{{ item.CreateTime }}'
- discovery_id: aws.redshift.describeIntegrations
  calls:
  - action: describeIntegrations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Integrations }}'
    item:
      IntegrationArn: '{{ item.IntegrationArn }}'
      IntegrationName: '{{ item.IntegrationName }}'
      SourceArn: '{{ item.SourceArn }}'
      TargetArn: '{{ item.TargetArn }}'
      Status: '{{ item.Status }}'
      Errors: '{{ item.Errors }}'
      CreateTime: '{{ item.CreateTime }}'
      Description: '{{ item.Description }}'
      KMSKeyId: '{{ item.KMSKeyId }}'
      AdditionalEncryptionContext: '{{ item.AdditionalEncryptionContext }}'
      Tags: '{{ item.Tags }}'
