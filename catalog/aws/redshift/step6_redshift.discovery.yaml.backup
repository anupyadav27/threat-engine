      ApplicationType: '{{ item.ApplicationType }}'
      Tags: '{{ item.Tags }}'
      SsoTagKeys: '{{ item.SsoTagKeys }}'
- discovery_id: aws.redshift.describeReservedNodeExchangeStatus
  calls:
