    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ReservedNodeExchangeStatusDetails }}'
    item:
      ReservedNodeExchangeRequestId: '{{ item.ReservedNodeExchangeRequestId }}'
      Status: '{{ item.Status }}'
      RequestTime: '{{ item.RequestTime }}'
      SourceReservedNodeId: '{{ item.SourceReservedNodeId }}'
      SourceReservedNodeType: '{{ item.SourceReservedNodeType }}'
      SourceReservedNodeCount: '{{ item.SourceReservedNodeCount }}'
      TargetReservedNodeOfferingId: '{{ item.TargetReservedNodeOfferingId }}'
