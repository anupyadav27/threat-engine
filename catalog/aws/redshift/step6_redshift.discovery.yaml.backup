    items_for: '{{ response.Recommendations }}'
    item:
      Id: '{{ item.Id }}'
      ClusterIdentifier: '{{ item.ClusterIdentifier }}'
      NamespaceArn: '{{ item.NamespaceArn }}'
      CreatedAt: '{{ item.CreatedAt }}'
      RecommendationType: '{{ item.RecommendationType }}'
      Title: '{{ item.Title }}'
      Description: '{{ item.Description }}'
      Observation: '{{ item.Observation }}'
      ImpactRanking: '{{ item.ImpactRanking }}'
      RecommendationText: '{{ item.RecommendationText }}'
      RecommendedActions: '{{ item.RecommendedActions }}'
      ReferenceLinks: '{{ item.ReferenceLinks }}'
- discovery_id: aws.redshift.describeClusterParameters
  calls:
  - action: describeClusterParameters
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Parameters }}'
    item:
      ParameterName: '{{ item.ParameterName }}'
      ParameterValue: '{{ item.ParameterValue }}'
      Description: '{{ item.Description }}'
      Source: '{{ item.Source }}'
      DataType: '{{ item.DataType }}'
      AllowedValues: '{{ item.AllowedValues }}'
      ApplyType: '{{ item.ApplyType }}'
      IsModifiable: '{{ item.IsModifiable }}'
      MinimumEngineVersion: '{{ item.MinimumEngineVersion }}'
- discovery_id: aws.redshift.describeDefaultClusterParameters
  calls:
  - action: describeDefaultClusterParameters
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.DefaultClusterParameters }}'
    item:
      ParameterGroupFamily: '{{ item.ParameterGroupFamily }}'
      Marker: '{{ item.Marker }}'
      Parameters: '{{ item.Parameters }}'
- discovery_id: aws.redshift.describeLoggingStatus
  calls:
  - action: describeLoggingStatus
    save_as: response
    on_error: continue
    params:
      ClusterIdentifier: '{{ item.ClusterIdentifier }}'
  emit:
    as: item
    items_for: '{{ response.LogExports }}'
  for_each: aws.redshift.describeClusters
- discovery_id: aws.redshift.describeNodeConfigurationOptions
  calls:
  - action: describeNodeConfigurationOptions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.NodeConfigurationOptionList }}'
    item:
      NodeType: '{{ item.NodeType }}'
      NumberOfNodes: '{{ item.NumberOfNodes }}'
      EstimatedDiskUtilizationPercent: '{{ item.EstimatedDiskUtilizationPercent }}'
      Mode: '{{ item.Mode }}'
- discovery_id: aws.redshift.describePartners
  calls:
  - action: describePartners
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.PartnerIntegrationInfoList }}'
    item:
      DatabaseName: '{{ item.DatabaseName }}'
      PartnerName: '{{ item.PartnerName }}'
      Status: '{{ item.Status }}'
      StatusMessage: '{{ item.StatusMessage }}'
      CreatedAt: '{{ item.CreatedAt }}'
      UpdatedAt: '{{ item.UpdatedAt }}'
- discovery_id: aws.redshift.describeResize
  calls:
  - action: describeResize
    save_as: response
    on_error: continue
    params:
      ClusterIdentifier: '{{ item.ClusterIdentifier }}'
  emit:
    as: item
    items_for: '{{ response.ImportTablesCompleted }}'
  for_each: aws.redshift.describeClusters
- discovery_id: aws.redshift.getClusterCredentials
  calls:
  - action: getClusterCredentials
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.DbUser }}'
- discovery_id: aws.redshift.getIdentityCenterAuthToken
  calls:
  - action: getIdentityCenterAuthToken
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Token }}'
- discovery_id: aws.redshift.getReservedNodeExchangeConfigurationOptions
  calls:
  - action: getReservedNodeExchangeConfigurationOptions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ReservedNodeConfigurationOptionList }}'
    item:
      SourceReservedNode: '{{ item.SourceReservedNode }}'
      TargetReservedNodeCount: '{{ item.TargetReservedNodeCount }}'
      TargetReservedNodeOffering: '{{ item.TargetReservedNodeOffering }}'
- discovery_id: aws.redshift.getReservedNodeExchangeOfferings
  calls:
  - action: getReservedNodeExchangeOfferings
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ReservedNodeOfferings }}'
    item:
      ReservedNodeOfferingId: '{{ item.ReservedNodeOfferingId }}'
      NodeType: '{{ item.NodeType }}'
      Duration: '{{ item.Duration }}'
      FixedPrice: '{{ item.FixedPrice }}'
      UsagePrice: '{{ item.UsagePrice }}'
      CurrencyCode: '{{ item.CurrencyCode }}'
      OfferingType: '{{ item.OfferingType }}'
      RecurringCharges: '{{ item.RecurringCharges }}'
      ReservedNodeOfferingType: '{{ item.ReservedNodeOfferingType }}'
- discovery_id: aws.redshift.getResourcePolicy
  calls:
  - action: getResourcePolicy
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ResourcePolicy }}'
    item:
      ResourceArn: '{{ item.ResourceArn }}'
      Policy: '{{ item.Policy }}'
checks: []
