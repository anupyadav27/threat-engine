version: '1.0'
provider: aws
service: redshift
services:
  client: redshift
  module: boto3.client
discovery:
- discovery_id: aws.redshift.describeAccountAttributes
  calls:
  - action: describeAccountAttributes
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AccountAttributes }}'
    item:
      AttributeName: '{{ item.AttributeName }}'
      AttributeValues: '{{ item.AttributeValues }}'
- discovery_id: aws.redshift.describeAuthenticationProfiles
  calls:
  - action: describeAuthenticationProfiles
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AuthenticationProfiles }}'
    item:
      AuthenticationProfileName: '{{ item.AuthenticationProfileName }}'
      AuthenticationProfileContent: '{{ item.AuthenticationProfileContent }}'
- discovery_id: aws.redshift.describeClusterDbRevisions
  calls:
  - action: describeClusterDbRevisions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ClusterDbRevisions }}'
    item:
      ClusterIdentifier: '{{ item.ClusterIdentifier }}'
      CurrentDatabaseRevision: '{{ item.CurrentDatabaseRevision }}'
      DatabaseRevisionReleaseDate: '{{ item.DatabaseRevisionReleaseDate }}'
      RevisionTargets: '{{ item.RevisionTargets }}'
- discovery_id: aws.redshift.describeClusterParameterGroups
  calls:
  - action: describeClusterParameterGroups
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ParameterGroups }}'
    item:
      ParameterGroupName: '{{ item.ParameterGroupName }}'
      ParameterGroupFamily: '{{ item.ParameterGroupFamily }}'
      Description: '{{ item.Description }}'
      Tags: '{{ item.Tags }}'
- discovery_id: aws.redshift.describeClusterSecurityGroups
  calls:
  - action: describeClusterSecurityGroups
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ClusterSecurityGroups }}'
    item:
      ClusterSecurityGroupName: '{{ item.ClusterSecurityGroupName }}'
      Description: '{{ item.Description }}'
      EC2SecurityGroups: '{{ item.EC2SecurityGroups }}'
      IPRanges: '{{ item.IPRanges }}'
      Tags: '{{ item.Tags }}'
- discovery_id: aws.redshift.describeClusterSnapshots
  calls:
  - action: describeClusterSnapshots
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Snapshots }}'
    item:
      SnapshotIdentifier: '{{ item.SnapshotIdentifier }}'
      ClusterIdentifier: '{{ item.ClusterIdentifier }}'
      SnapshotCreateTime: '{{ item.SnapshotCreateTime }}'
      Status: '{{ item.Status }}'
      Port: '{{ item.Port }}'
      AvailabilityZone: '{{ item.AvailabilityZone }}'
      ClusterCreateTime: '{{ item.ClusterCreateTime }}'
      MasterUsername: '{{ item.MasterUsername }}'
      ClusterVersion: '{{ item.ClusterVersion }}'
      EngineFullVersion: '{{ item.EngineFullVersion }}'
      SnapshotType: '{{ item.SnapshotType }}'
      NodeType: '{{ item.NodeType }}'
      NumberOfNodes: '{{ item.NumberOfNodes }}'
      DBName: '{{ item.DBName }}'
      VpcId: '{{ item.VpcId }}'
      Encrypted: '{{ item.Encrypted }}'
      KmsKeyId: '{{ item.KmsKeyId }}'
      EncryptedWithHSM: '{{ item.EncryptedWithHSM }}'
      AccountsWithRestoreAccess: '{{ item.AccountsWithRestoreAccess }}'
      OwnerAccount: '{{ item.OwnerAccount }}'
      TotalBackupSizeInMegaBytes: '{{ item.TotalBackupSizeInMegaBytes }}'
      ActualIncrementalBackupSizeInMegaBytes: '{{ item.ActualIncrementalBackupSizeInMegaBytes
        }}'
      BackupProgressInMegaBytes: '{{ item.BackupProgressInMegaBytes }}'
      CurrentBackupRateInMegaBytesPerSecond: '{{ item.CurrentBackupRateInMegaBytesPerSecond
        }}'
      EstimatedSecondsToCompletion: '{{ item.EstimatedSecondsToCompletion }}'
      ElapsedTimeInSeconds: '{{ item.ElapsedTimeInSeconds }}'
      SourceRegion: '{{ item.SourceRegion }}'
      Tags: '{{ item.Tags }}'
      RestorableNodeTypes: '{{ item.RestorableNodeTypes }}'
      EnhancedVpcRouting: '{{ item.EnhancedVpcRouting }}'
      MaintenanceTrackName: '{{ item.MaintenanceTrackName }}'
      ManualSnapshotRetentionPeriod: '{{ item.ManualSnapshotRetentionPeriod }}'
      ManualSnapshotRemainingDays: '{{ item.ManualSnapshotRemainingDays }}'
      SnapshotRetentionStartTime: '{{ item.SnapshotRetentionStartTime }}'
      MasterPasswordSecretArn: '{{ item.MasterPasswordSecretArn }}'
      MasterPasswordSecretKmsKeyId: '{{ item.MasterPasswordSecretKmsKeyId }}'
      SnapshotArn: '{{ item.SnapshotArn }}'
- discovery_id: aws.redshift.describeClusterSubnetGroups
  calls:
  - action: describeClusterSubnetGroups
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ClusterSubnetGroups }}'
    item:
      ClusterSubnetGroupName: '{{ item.ClusterSubnetGroupName }}'
      Description: '{{ item.Description }}'
      VpcId: '{{ item.VpcId }}'
      SubnetGroupStatus: '{{ item.SubnetGroupStatus }}'
      Subnets: '{{ item.Subnets }}'
      Tags: '{{ item.Tags }}'
      SupportedClusterIpAddressTypes: '{{ item.SupportedClusterIpAddressTypes }}'
- discovery_id: aws.redshift.describeClusterTracks
  calls:
  - action: describeClusterTracks
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.MaintenanceTracks }}'
    item:
      MaintenanceTrackName: '{{ item.MaintenanceTrackName }}'
      DatabaseVersion: '{{ item.DatabaseVersion }}'
      UpdateTargets: '{{ item.UpdateTargets }}'
- discovery_id: aws.redshift.describeClusterVersions
  calls:
  - action: describeClusterVersions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ClusterVersions }}'
    item:
      ClusterVersion: '{{ item.ClusterVersion }}'
      ClusterParameterGroupFamily: '{{ item.ClusterParameterGroupFamily }}'
      Description: '{{ item.Description }}'
- discovery_id: aws.redshift.describeClusters
  calls:
  - action: describeClusters
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Clusters }}'
    item:
      ClusterIdentifier: '{{ item.ClusterIdentifier }}'
      NodeType: '{{ item.NodeType }}'
      ClusterStatus: '{{ item.ClusterStatus }}'
      ClusterAvailabilityStatus: '{{ item.ClusterAvailabilityStatus }}'
      ModifyStatus: '{{ item.ModifyStatus }}'
      MasterUsername: '{{ item.MasterUsername }}'
      DBName: '{{ item.DBName }}'
      Endpoint: '{{ item.Endpoint }}'
      ClusterCreateTime: '{{ item.ClusterCreateTime }}'
      AutomatedSnapshotRetentionPeriod: '{{ item.AutomatedSnapshotRetentionPeriod
        }}'
      ManualSnapshotRetentionPeriod: '{{ item.ManualSnapshotRetentionPeriod }}'
      ClusterSecurityGroups: '{{ item.ClusterSecurityGroups }}'
      VpcSecurityGroups: '{{ item.VpcSecurityGroups }}'
      ClusterParameterGroups: '{{ item.ClusterParameterGroups }}'
      ClusterSubnetGroupName: '{{ item.ClusterSubnetGroupName }}'
      VpcId: '{{ item.VpcId }}'
      AvailabilityZone: '{{ item.AvailabilityZone }}'
      PreferredMaintenanceWindow: '{{ item.PreferredMaintenanceWindow }}'
      PendingModifiedValues: '{{ item.PendingModifiedValues }}'
      ClusterVersion: '{{ item.ClusterVersion }}'
      AllowVersionUpgrade: '{{ item.AllowVersionUpgrade }}'
      NumberOfNodes: '{{ item.NumberOfNodes }}'
      PubliclyAccessible: '{{ item.PubliclyAccessible }}'
      Encrypted: '{{ item.Encrypted }}'
      RestoreStatus: '{{ item.RestoreStatus }}'
      DataTransferProgress: '{{ item.DataTransferProgress }}'
      HsmStatus: '{{ item.HsmStatus }}'
      ClusterSnapshotCopyStatus: '{{ item.ClusterSnapshotCopyStatus }}'
      ClusterPublicKey: '{{ item.ClusterPublicKey }}'
      ClusterNodes: '{{ item.ClusterNodes }}'
      ElasticIpStatus: '{{ item.ElasticIpStatus }}'
      ClusterRevisionNumber: '{{ item.ClusterRevisionNumber }}'
      Tags: '{{ item.Tags }}'
      KmsKeyId: '{{ item.KmsKeyId }}'
      EnhancedVpcRouting: '{{ item.EnhancedVpcRouting }}'
      IamRoles: '{{ item.IamRoles }}'
      PendingActions: '{{ item.PendingActions }}'
      MaintenanceTrackName: '{{ item.MaintenanceTrackName }}'
      ElasticResizeNumberOfNodeOptions: '{{ item.ElasticResizeNumberOfNodeOptions
        }}'
      DeferredMaintenanceWindows: '{{ item.DeferredMaintenanceWindows }}'
      SnapshotScheduleIdentifier: '{{ item.SnapshotScheduleIdentifier }}'
      SnapshotScheduleState: '{{ item.SnapshotScheduleState }}'
      ExpectedNextSnapshotScheduleTime: '{{ item.ExpectedNextSnapshotScheduleTime
        }}'
      ExpectedNextSnapshotScheduleTimeStatus: '{{ item.ExpectedNextSnapshotScheduleTimeStatus
        }}'
      NextMaintenanceWindowStartTime: '{{ item.NextMaintenanceWindowStartTime }}'
      ResizeInfo: '{{ item.ResizeInfo }}'
      AvailabilityZoneRelocationStatus: '{{ item.AvailabilityZoneRelocationStatus
        }}'
      ClusterNamespaceArn: '{{ item.ClusterNamespaceArn }}'
      TotalStorageCapacityInMegaBytes: '{{ item.TotalStorageCapacityInMegaBytes }}'
      AquaConfiguration: '{{ item.AquaConfiguration }}'
      DefaultIamRoleArn: '{{ item.DefaultIamRoleArn }}'
      ReservedNodeExchangeStatus: '{{ item.ReservedNodeExchangeStatus }}'
      CustomDomainName: '{{ item.CustomDomainName }}'
      CustomDomainCertificateArn: '{{ item.CustomDomainCertificateArn }}'
      CustomDomainCertificateExpiryDate: '{{ item.CustomDomainCertificateExpiryDate
        }}'
      MasterPasswordSecretArn: '{{ item.MasterPasswordSecretArn }}'
      MasterPasswordSecretKmsKeyId: '{{ item.MasterPasswordSecretKmsKeyId }}'
      IpAddressType: '{{ item.IpAddressType }}'
      MultiAZ: '{{ item.MultiAZ }}'
      MultiAZSecondary: '{{ item.MultiAZSecondary }}'
      LakehouseRegistrationStatus: '{{ item.LakehouseRegistrationStatus }}'
      CatalogArn: '{{ item.CatalogArn }}'
- discovery_id: aws.redshift.describeCustomDomainAssociations
  calls:
  - action: describeCustomDomainAssociations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Associations }}'
    item:
      CustomDomainCertificateArn: '{{ item.CustomDomainCertificateArn }}'
      CustomDomainCertificateExpiryDate: '{{ item.CustomDomainCertificateExpiryDate
        }}'
      CertificateAssociations: '{{ item.CertificateAssociations }}'
- discovery_id: aws.redshift.describeDataShares
  calls:
  - action: describeDataShares
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.DataShares }}'
    item:
      DataShareArn: '{{ item.DataShareArn }}'
      ProducerArn: '{{ item.ProducerArn }}'
      AllowPubliclyAccessibleConsumers: '{{ item.AllowPubliclyAccessibleConsumers
        }}'
      DataShareAssociations: '{{ item.DataShareAssociations }}'
      ManagedBy: '{{ item.ManagedBy }}'
      DataShareType: '{{ item.DataShareType }}'
- discovery_id: aws.redshift.describeDataSharesForConsumer
  calls:
  - action: describeDataSharesForConsumer
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.DataShares }}'
    item:
      DataShareArn: '{{ item.DataShareArn }}'
      ProducerArn: '{{ item.ProducerArn }}'
      AllowPubliclyAccessibleConsumers: '{{ item.AllowPubliclyAccessibleConsumers
        }}'
      DataShareAssociations: '{{ item.DataShareAssociations }}'
      ManagedBy: '{{ item.ManagedBy }}'
      DataShareType: '{{ item.DataShareType }}'
- discovery_id: aws.redshift.describeDataSharesForProducer
  calls:
  - action: describeDataSharesForProducer
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.DataShares }}'
    item:
      DataShareArn: '{{ item.DataShareArn }}'
      ProducerArn: '{{ item.ProducerArn }}'
      AllowPubliclyAccessibleConsumers: '{{ item.AllowPubliclyAccessibleConsumers
        }}'
      DataShareAssociations: '{{ item.DataShareAssociations }}'
      ManagedBy: '{{ item.ManagedBy }}'
      DataShareType: '{{ item.DataShareType }}'
- discovery_id: aws.redshift.describeEndpointAccess
  calls:
  - action: describeEndpointAccess
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.EndpointAccessList }}'
    item:
      ClusterIdentifier: '{{ item.ClusterIdentifier }}'
      ResourceOwner: '{{ item.ResourceOwner }}'
      SubnetGroupName: '{{ item.SubnetGroupName }}'
      EndpointStatus: '{{ item.EndpointStatus }}'
      EndpointName: '{{ item.EndpointName }}'
      EndpointCreateTime: '{{ item.EndpointCreateTime }}'
      Port: '{{ item.Port }}'
      Address: '{{ item.Address }}'
      VpcSecurityGroups: '{{ item.VpcSecurityGroups }}'
      VpcEndpoint: '{{ item.VpcEndpoint }}'
- discovery_id: aws.redshift.describeEndpointAuthorization
  calls:
  - action: describeEndpointAuthorization
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.EndpointAuthorizationList }}'
    item:
      Grantor: '{{ item.Grantor }}'
      Grantee: '{{ item.Grantee }}'
      ClusterIdentifier: '{{ item.ClusterIdentifier }}'
      AuthorizeTime: '{{ item.AuthorizeTime }}'
      ClusterStatus: '{{ item.ClusterStatus }}'
      Status: '{{ item.Status }}'
      AllowedAllVPCs: '{{ item.AllowedAllVPCs }}'
      AllowedVPCs: '{{ item.AllowedVPCs }}'
      EndpointCount: '{{ item.EndpointCount }}'
- discovery_id: aws.redshift.describeEventCategories
  calls:
  - action: describeEventCategories
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.EventCategoriesMapList }}'
    item:
      SourceType: '{{ item.SourceType }}'
      Events: '{{ item.Events }}'
- discovery_id: aws.redshift.describeEventSubscriptions
  calls:
  - action: describeEventSubscriptions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.EventSubscriptionsList }}'
    item:
      CustomerAwsId: '{{ item.CustomerAwsId }}'
      CustSubscriptionId: '{{ item.CustSubscriptionId }}'
      SnsTopicArn: '{{ item.SnsTopicArn }}'
      Status: '{{ item.Status }}'
      SubscriptionCreationTime: '{{ item.SubscriptionCreationTime }}'
      SourceType: '{{ item.SourceType }}'
      SourceIdsList: '{{ item.SourceIdsList }}'
      EventCategoriesList: '{{ item.EventCategoriesList }}'
      Severity: '{{ item.Severity }}'
      Enabled: '{{ item.Enabled }}'
      Tags: '{{ item.Tags }}'
- discovery_id: aws.redshift.describeEvents
  calls:
  - action: describeEvents
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Events }}'
    item:
      SourceIdentifier: '{{ item.SourceIdentifier }}'
      SourceType: '{{ item.SourceType }}'
      Message: '{{ item.Message }}'
      EventCategories: '{{ item.EventCategories }}'
      Severity: '{{ item.Severity }}'
      Date: '{{ item.Date }}'
      EventId: '{{ item.EventId }}'
- discovery_id: aws.redshift.describeHsmClientCertificates
  calls:
  - action: describeHsmClientCertificates
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.HsmClientCertificates }}'
    item:
      HsmClientCertificateIdentifier: '{{ item.HsmClientCertificateIdentifier }}'
      HsmClientCertificatePublicKey: '{{ item.HsmClientCertificatePublicKey }}'
