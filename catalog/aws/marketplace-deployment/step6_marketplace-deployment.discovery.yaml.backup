version: '1.0'
provider: aws
service: marketplace-deployment
services:
  client: marketplace-deployment
  module: boto3.client
discovery:
- discovery_id: aws.marketplace-deployment.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tags }}'
checks: []
