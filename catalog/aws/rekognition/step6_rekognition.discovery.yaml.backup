version: '1.0'
provider: aws
service: rekognition
services:
  client: rekognition
  module: boto3.client
discovery:
- discovery_id: aws.rekognition.describeProjects
  calls:
  - action: describeProjects
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ProjectDescriptions }}'
    item:
      ProjectArn: '{{ item.ProjectArn }}'
      CreationTimestamp: '{{ item.CreationTimestamp }}'
      Status: '{{ item.Status }}'
      Datasets: '{{ item.Datasets }}'
      Feature: '{{ item.Feature }}'
      AutoUpdate: '{{ item.AutoUpdate }}'
- discovery_id: aws.rekognition.listCollections
  calls:
  - action: listCollections
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.CollectionIds }}'
- discovery_id: aws.rekognition.listMediaAnalysisJobs
  calls:
  - action: listMediaAnalysisJobs
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.MediaAnalysisJobs }}'
    item:
      JobId: '{{ item.JobId }}'
      JobName: '{{ item.JobName }}'
      OperationsConfig: '{{ item.OperationsConfig }}'
      Status: '{{ item.Status }}'
      FailureDetails: '{{ item.FailureDetails }}'
      CreationTimestamp: '{{ item.CreationTimestamp }}'
      CompletionTimestamp: '{{ item.CompletionTimestamp }}'
      Input: '{{ item.Input }}'
      OutputConfig: '{{ item.OutputConfig }}'
      KmsKeyId: '{{ item.KmsKeyId }}'
      Results: '{{ item.Results }}'
      ManifestSummary: '{{ item.ManifestSummary }}'
- discovery_id: aws.rekognition.listStreamProcessors
  calls:
  - action: listStreamProcessors
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.StreamProcessors }}'
    item:
      Name: '{{ item.Name }}'
      Status: '{{ item.Status }}'
- discovery_id: aws.rekognition.describeCollection
  calls:
  - action: describeCollection
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.FaceCount }}'
- discovery_id: aws.rekognition.describeDataset
  calls:
  - action: describeDataset
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.DatasetDescription }}'
    item:
      CreationTimestamp: '{{ item.CreationTimestamp }}'
      LastUpdatedTimestamp: '{{ item.LastUpdatedTimestamp }}'
      Status: '{{ item.Status }}'
      StatusMessage: '{{ item.StatusMessage }}'
      StatusMessageCode: '{{ item.StatusMessageCode }}'
      DatasetStats: '{{ item.DatasetStats }}'
- discovery_id: aws.rekognition.describeProjectVersions
  calls:
  - action: describeProjectVersions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ProjectVersionDescriptions }}'
    item:
      ProjectVersionArn: '{{ item.ProjectVersionArn }}'
      CreationTimestamp: '{{ item.CreationTimestamp }}'
      MinInferenceUnits: '{{ item.MinInferenceUnits }}'
      Status: '{{ item.Status }}'
      StatusMessage: '{{ item.StatusMessage }}'
      BillableTrainingTimeInSeconds: '{{ item.BillableTrainingTimeInSeconds }}'
      TrainingEndTimestamp: '{{ item.TrainingEndTimestamp }}'
      OutputConfig: '{{ item.OutputConfig }}'
      TrainingDataResult: '{{ item.TrainingDataResult }}'
      TestingDataResult: '{{ item.TestingDataResult }}'
      EvaluationResult: '{{ item.EvaluationResult }}'
      ManifestSummary: '{{ item.ManifestSummary }}'
      KmsKeyId: '{{ item.KmsKeyId }}'
      MaxInferenceUnits: '{{ item.MaxInferenceUnits }}'
      SourceProjectVersionArn: '{{ item.SourceProjectVersionArn }}'
      VersionDescription: '{{ item.VersionDescription }}'
      Feature: '{{ item.Feature }}'
      BaseModelVersion: '{{ item.BaseModelVersion }}'
      FeatureConfig: '{{ item.FeatureConfig }}'
- discovery_id: aws.rekognition.describeStreamProcessor
  calls:
  - action: describeStreamProcessor
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.RegionsOfInterest }}'
    item:
      BoundingBox: '{{ item.BoundingBox }}'
      Polygon: '{{ item.Polygon }}'
- discovery_id: aws.rekognition.getCelebrityInfo
  calls:
  - action: getCelebrityInfo
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Urls }}'
- discovery_id: aws.rekognition.getCelebrityRecognition
  calls:
  - action: getCelebrityRecognition
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Celebrities }}'
    item:
      Timestamp: '{{ item.Timestamp }}'
      Celebrity: '{{ item.Celebrity }}'
- discovery_id: aws.rekognition.getContentModeration
  calls:
  - action: getContentModeration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ModerationLabels }}'
    item:
      Timestamp: '{{ item.Timestamp }}'
      ModerationLabel: '{{ item.ModerationLabel }}'
      StartTimestampMillis: '{{ item.StartTimestampMillis }}'
      EndTimestampMillis: '{{ item.EndTimestampMillis }}'
      DurationMillis: '{{ item.DurationMillis }}'
      ContentTypes: '{{ item.ContentTypes }}'
- discovery_id: aws.rekognition.getFaceDetection
  calls:
  - action: getFaceDetection
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Faces }}'
    item:
      Timestamp: '{{ item.Timestamp }}'
      Face: '{{ item.Face }}'
- discovery_id: aws.rekognition.getFaceLivenessSessionResults
  calls:
  - action: getFaceLivenessSessionResults
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AuditImages }}'
    item:
      Bytes: '{{ item.Bytes }}'
      S3Object: '{{ item.S3Object }}'
      BoundingBox: '{{ item.BoundingBox }}'
- discovery_id: aws.rekognition.getFaceSearch
  calls:
  - action: getFaceSearch
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Persons }}'
    item:
      Timestamp: '{{ item.Timestamp }}'
      Person: '{{ item.Person }}'
      FaceMatches: '{{ item.FaceMatches }}'
- discovery_id: aws.rekognition.getLabelDetection
  calls:
  - action: getLabelDetection
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Labels }}'
    item:
      Timestamp: '{{ item.Timestamp }}'
      Label: '{{ item.Label }}'
      StartTimestampMillis: '{{ item.StartTimestampMillis }}'
      EndTimestampMillis: '{{ item.EndTimestampMillis }}'
      DurationMillis: '{{ item.DurationMillis }}'
- discovery_id: aws.rekognition.getMediaAnalysisJob
  calls:
  - action: getMediaAnalysisJob
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.OperationsConfig }}'
    item:
      DetectModerationLabels: '{{ item.DetectModerationLabels }}'
- discovery_id: aws.rekognition.getPersonTracking
  calls:
  - action: getPersonTracking
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Persons }}'
    item:
      Timestamp: '{{ item.Timestamp }}'
      Person: '{{ item.Person }}'
- discovery_id: aws.rekognition.getSegmentDetection
  calls:
  - action: getSegmentDetection
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.VideoMetadata }}'
    item:
      Codec: '{{ item.Codec }}'
      DurationMillis: '{{ item.DurationMillis }}'
      Format: '{{ item.Format }}'
      FrameRate: '{{ item.FrameRate }}'
      FrameHeight: '{{ item.FrameHeight }}'
      FrameWidth: '{{ item.FrameWidth }}'
      ColorRange: '{{ item.ColorRange }}'
- discovery_id: aws.rekognition.getTextDetection
  calls:
  - action: getTextDetection
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.TextDetections }}'
    item:
      Timestamp: '{{ item.Timestamp }}'
      TextDetection: '{{ item.TextDetection }}'
- discovery_id: aws.rekognition.listDatasetEntries
  calls:
  - action: listDatasetEntries
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.DatasetEntries }}'
- discovery_id: aws.rekognition.listDatasetLabels
  calls:
  - action: listDatasetLabels
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.DatasetLabelDescriptions }}'
    item:
      LabelName: '{{ item.LabelName }}'
      LabelStats: '{{ item.LabelStats }}'
- discovery_id: aws.rekognition.listFaces
  calls:
  - action: listFaces
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Faces }}'
    item:
      FaceId: '{{ item.FaceId }}'
      BoundingBox: '{{ item.BoundingBox }}'
      ImageId: '{{ item.ImageId }}'
      ExternalImageId: '{{ item.ExternalImageId }}'
      Confidence: '{{ item.Confidence }}'
      IndexFacesModelVersion: '{{ item.IndexFacesModelVersion }}'
      UserId: '{{ item.UserId }}'
- discovery_id: aws.rekognition.listProjectPolicies
  calls:
  - action: listProjectPolicies
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.ProjectPolicies }}'
    item:
      ProjectArn: '{{ item.ProjectArn }}'
      PolicyName: '{{ item.PolicyName }}'
      PolicyRevisionId: '{{ item.PolicyRevisionId }}'
      PolicyDocument: '{{ item.PolicyDocument }}'
      CreationTimestamp: '{{ item.CreationTimestamp }}'
      LastUpdatedTimestamp: '{{ item.LastUpdatedTimestamp }}'
- discovery_id: aws.rekognition.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Tags }}'
- discovery_id: aws.rekognition.listUsers
  calls:
  - action: listUsers
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Users }}'
    item:
      UserId: '{{ item.UserId }}'
      UserStatus: '{{ item.UserStatus }}'
- discovery_id: aws.rekognition.searchFaces
  calls:
  - action: searchFaces
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.FaceMatches }}'
    item:
      Similarity: '{{ item.Similarity }}'
      Face: '{{ item.Face }}'
- discovery_id: aws.rekognition.searchFacesByImage
  calls:
  - action: searchFacesByImage
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.FaceMatches }}'
    item:
      Similarity: '{{ item.Similarity }}'
      Face: '{{ item.Face }}'
- discovery_id: aws.rekognition.searchUsers
  calls:
  - action: searchUsers
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.UserMatches }}'
    item:
      Similarity: '{{ item.Similarity }}'
      User: '{{ item.User }}'
- discovery_id: aws.rekognition.searchUsersByImage
  calls:
  - action: searchUsersByImage
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.UserMatches }}'
    item:
      Similarity: '{{ item.Similarity }}'
      User: '{{ item.User }}'
checks: []
