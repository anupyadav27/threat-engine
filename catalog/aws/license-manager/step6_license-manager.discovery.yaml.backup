      TokenType: '{{ item.TokenType }}'
      LicenseArn: '{{ item.LicenseArn }}'
      ExpirationTime: '{{ item.ExpirationTime }}'
      TokenProperties: '{{ item.TokenProperties }}'
      RoleArns: '{{ item.RoleArns }}'
      Status: '{{ item.Status }}'
- discovery_id: aws.license-manager.getAccessToken
  calls:
