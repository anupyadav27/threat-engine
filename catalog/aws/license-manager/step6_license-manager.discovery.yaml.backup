      GrantArn: '{{ item.GrantArn }}'
      GrantName: '{{ item.GrantName }}'
      ParentArn: '{{ item.ParentArn }}'
      LicenseArn: '{{ item.LicenseArn }}'
      GranteePrincipalArn: '{{ item.GranteePrincipalArn }}'
      HomeRegion: '{{ item.HomeRegion }}'
      GrantStatus: '{{ item.GrantStatus }}'
      StatusReason: '{{ item.StatusReason }}'
      Version: '{{ item.Version }}'
      GrantedOperations: '{{ item.GrantedOperations }}'
      Options: '{{ item.Options }}'
- discovery_id: aws.license-manager.listReceivedLicenses
  calls:
  - action: listReceivedLicenses
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Licenses }}'
    item:
      LicenseArn: '{{ item.LicenseArn }}'
      LicenseName: '{{ item.LicenseName }}'
      ProductName: '{{ item.ProductName }}'
      ProductSKU: '{{ item.ProductSKU }}'
      Issuer: '{{ item.Issuer }}'
      HomeRegion: '{{ item.HomeRegion }}'
      Status: '{{ item.Status }}'
      Validity: '{{ item.Validity }}'
      Beneficiary: '{{ item.Beneficiary }}'
      Entitlements: '{{ item.Entitlements }}'
      ConsumptionConfiguration: '{{ item.ConsumptionConfiguration }}'
      LicenseMetadata: '{{ item.LicenseMetadata }}'
      CreateTime: '{{ item.CreateTime }}'
      Version: '{{ item.Version }}'
      ReceivedMetadata: '{{ item.ReceivedMetadata }}'
- discovery_id: aws.license-manager.listReceivedLicensesForOrganization
  calls:
  - action: listReceivedLicensesForOrganization
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Licenses }}'
    item:
      LicenseArn: '{{ item.LicenseArn }}'
      LicenseName: '{{ item.LicenseName }}'
      ProductName: '{{ item.ProductName }}'
      ProductSKU: '{{ item.ProductSKU }}'
      Issuer: '{{ item.Issuer }}'
      HomeRegion: '{{ item.HomeRegion }}'
      Status: '{{ item.Status }}'
      Validity: '{{ item.Validity }}'
      Beneficiary: '{{ item.Beneficiary }}'
      Entitlements: '{{ item.Entitlements }}'
      ConsumptionConfiguration: '{{ item.ConsumptionConfiguration }}'
      LicenseMetadata: '{{ item.LicenseMetadata }}'
      CreateTime: '{{ item.CreateTime }}'
      Version: '{{ item.Version }}'
      ReceivedMetadata: '{{ item.ReceivedMetadata }}'
- discovery_id: aws.license-manager.listResourceInventory
  calls:
  - action: listResourceInventory
    save_as: response
