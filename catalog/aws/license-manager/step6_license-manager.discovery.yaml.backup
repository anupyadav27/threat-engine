version: '1.0'
provider: aws
service: license-manager
services:
  client: license-manager
  module: boto3.client
discovery:
- discovery_id: aws.license-manager.getServiceSettings
  calls:
  - action: getServiceSettings
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.CrossRegionDiscoverySourceRegions }}'
- discovery_id: aws.license-manager.listDistributedGrants
  calls:
  - action: listDistributedGrants
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Grants }}'
    item:
      GrantArn: '{{ item.GrantArn }}'
      GrantName: '{{ item.GrantName }}'
      ParentArn: '{{ item.ParentArn }}'
      LicenseArn: '{{ item.LicenseArn }}'
      GranteePrincipalArn: '{{ item.GranteePrincipalArn }}'
      HomeRegion: '{{ item.HomeRegion }}'
      GrantStatus: '{{ item.GrantStatus }}'
      StatusReason: '{{ item.StatusReason }}'
      Version: '{{ item.Version }}'
      GrantedOperations: '{{ item.GrantedOperations }}'
      Options: '{{ item.Options }}'
- discovery_id: aws.license-manager.listLicenseAssetGroups
  calls:
  - action: listLicenseAssetGroups
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.LicenseAssetGroups }}'
    item:
      Name: '{{ item.Name }}'
      Description: '{{ item.Description }}'
      LicenseAssetGroupConfigurations: '{{ item.LicenseAssetGroupConfigurations }}'
      AssociatedLicenseAssetRulesetARNs: '{{ item.AssociatedLicenseAssetRulesetARNs
        }}'
      Properties: '{{ item.Properties }}'
      LicenseAssetGroupArn: '{{ item.LicenseAssetGroupArn }}'
      Status: '{{ item.Status }}'
      StatusMessage: '{{ item.StatusMessage }}'
      LatestUsageAnalysisTime: '{{ item.LatestUsageAnalysisTime }}'
      LatestResourceDiscoveryTime: '{{ item.LatestResourceDiscoveryTime }}'
- discovery_id: aws.license-manager.listLicenseAssetRulesets
  calls:
  - action: listLicenseAssetRulesets
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.LicenseAssetRulesets }}'
    item:
      Name: '{{ item.Name }}'
      Description: '{{ item.Description }}'
      Rules: '{{ item.Rules }}'
      LicenseAssetRulesetArn: '{{ item.LicenseAssetRulesetArn }}'
- discovery_id: aws.license-manager.listLicenseConfigurations
  calls:
  - action: listLicenseConfigurations
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.LicenseConfigurations }}'
    item:
      LicenseConfigurationId: '{{ item.LicenseConfigurationId }}'
      LicenseConfigurationArn: '{{ item.LicenseConfigurationArn }}'
      Name: '{{ item.Name }}'
      Description: '{{ item.Description }}'
      LicenseCountingType: '{{ item.LicenseCountingType }}'
      LicenseRules: '{{ item.LicenseRules }}'
      LicenseCount: '{{ item.LicenseCount }}'
      LicenseCountHardLimit: '{{ item.LicenseCountHardLimit }}'
      DisassociateWhenNotFound: '{{ item.DisassociateWhenNotFound }}'
      ConsumedLicenses: '{{ item.ConsumedLicenses }}'
      Status: '{{ item.Status }}'
      OwnerAccountId: '{{ item.OwnerAccountId }}'
      ConsumedLicenseSummaryList: '{{ item.ConsumedLicenseSummaryList }}'
      ManagedResourceSummaryList: '{{ item.ManagedResourceSummaryList }}'
      ProductInformationList: '{{ item.ProductInformationList }}'
      AutomatedDiscoveryInformation: '{{ item.AutomatedDiscoveryInformation }}'
      LicenseExpiry: '{{ item.LicenseExpiry }}'
- discovery_id: aws.license-manager.listLicenseConfigurationsForOrganization
  calls:
  - action: listLicenseConfigurationsForOrganization
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.LicenseConfigurations }}'
    item:
      LicenseConfigurationId: '{{ item.LicenseConfigurationId }}'
      LicenseConfigurationArn: '{{ item.LicenseConfigurationArn }}'
      Name: '{{ item.Name }}'
      Description: '{{ item.Description }}'
      LicenseCountingType: '{{ item.LicenseCountingType }}'
      LicenseRules: '{{ item.LicenseRules }}'
      LicenseCount: '{{ item.LicenseCount }}'
      LicenseCountHardLimit: '{{ item.LicenseCountHardLimit }}'
      DisassociateWhenNotFound: '{{ item.DisassociateWhenNotFound }}'
      ConsumedLicenses: '{{ item.ConsumedLicenses }}'
      Status: '{{ item.Status }}'
      OwnerAccountId: '{{ item.OwnerAccountId }}'
      ConsumedLicenseSummaryList: '{{ item.ConsumedLicenseSummaryList }}'
      ManagedResourceSummaryList: '{{ item.ManagedResourceSummaryList }}'
      ProductInformationList: '{{ item.ProductInformationList }}'
      AutomatedDiscoveryInformation: '{{ item.AutomatedDiscoveryInformation }}'
      LicenseExpiry: '{{ item.LicenseExpiry }}'
- discovery_id: aws.license-manager.listLicenseConversionTasks
  calls:
  - action: listLicenseConversionTasks
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.LicenseConversionTasks }}'
    item:
      LicenseConversionTaskId: '{{ item.LicenseConversionTaskId }}'
      ResourceArn: '{{ item.ResourceArn }}'
      SourceLicenseContext: '{{ item.SourceLicenseContext }}'
      DestinationLicenseContext: '{{ item.DestinationLicenseContext }}'
      Status: '{{ item.Status }}'
      StatusMessage: '{{ item.StatusMessage }}'
      StartTime: '{{ item.StartTime }}'
      LicenseConversionTime: '{{ item.LicenseConversionTime }}'
      EndTime: '{{ item.EndTime }}'
- discovery_id: aws.license-manager.listLicenseManagerReportGenerators
  calls:
  - action: listLicenseManagerReportGenerators
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.ReportGenerators }}'
    item:
      ReportGeneratorName: '{{ item.ReportGeneratorName }}'
      ReportType: '{{ item.ReportType }}'
      ReportContext: '{{ item.ReportContext }}'
      ReportFrequency: '{{ item.ReportFrequency }}'
      LicenseManagerReportGeneratorArn: '{{ item.LicenseManagerReportGeneratorArn
        }}'
      LastRunStatus: '{{ item.LastRunStatus }}'
      LastRunFailureReason: '{{ item.LastRunFailureReason }}'
      LastReportGenerationTime: '{{ item.LastReportGenerationTime }}'
      ReportCreatorAccount: '{{ item.ReportCreatorAccount }}'
      Description: '{{ item.Description }}'
      S3Location: '{{ item.S3Location }}'
      CreateTime: '{{ item.CreateTime }}'
      Tags: '{{ item.Tags }}'
- discovery_id: aws.license-manager.listLicenses
  calls:
  - action: listLicenses
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Licenses }}'
    item:
      LicenseArn: '{{ item.LicenseArn }}'
      LicenseName: '{{ item.LicenseName }}'
      ProductName: '{{ item.ProductName }}'
      ProductSKU: '{{ item.ProductSKU }}'
      Issuer: '{{ item.Issuer }}'
      HomeRegion: '{{ item.HomeRegion }}'
      Status: '{{ item.Status }}'
      Validity: '{{ item.Validity }}'
      Beneficiary: '{{ item.Beneficiary }}'
      Entitlements: '{{ item.Entitlements }}'
      ConsumptionConfiguration: '{{ item.ConsumptionConfiguration }}'
      LicenseMetadata: '{{ item.LicenseMetadata }}'
      CreateTime: '{{ item.CreateTime }}'
      Version: '{{ item.Version }}'
- discovery_id: aws.license-manager.listReceivedGrants
  calls:
  - action: listReceivedGrants
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
