  calls:
  - action: getLicenseUsage
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.LicenseUsage }}'
    item:
      EntitlementUsages: '{{ item.EntitlementUsages }}'
- discovery_id: aws.license-manager.listAssetsForLicenseAssetGroup
  calls:
  - action: listAssetsForLicenseAssetGroup
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Assets }}'
    item:
      AssetArn: '{{ item.AssetArn }}'
      LatestAssetDiscoveryTime: '{{ item.LatestAssetDiscoveryTime }}'
