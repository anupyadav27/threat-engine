version: '1.0'
provider: aws
service: appconfigdata
services:
  client: appconfigdata
  module: boto3.client
discovery:
- discovery_id: aws.appconfigdata.getLatestConfiguration
  calls:
  - action: getLatestConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.NextPollConfigurationToken }}'
checks: []
