version: '1.0'
provider: aws
service: greengrassv2
services:
  client: greengrassv2
  module: boto3.client
discovery:
- discovery_id: aws.greengrassv2.getServiceRoleForAccount
  calls:
  - action: getServiceRoleForAccount
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.associatedAt }}'
- discovery_id: aws.greengrassv2.listComponents
  calls:
  - action: listComponents
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.components }}'
    item:
      arn: '{{ item.arn }}'
      componentName: '{{ item.componentName }}'
      latestVersion: '{{ item.latestVersion }}'
- discovery_id: aws.greengrassv2.listCoreDevices
  calls:
  - action: listCoreDevices
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.coreDevices }}'
    item:
      coreDeviceThingName: '{{ item.coreDeviceThingName }}'
      status: '{{ item.status }}'
      lastStatusUpdateTimestamp: '{{ item.lastStatusUpdateTimestamp }}'
      platform: '{{ item.platform }}'
      architecture: '{{ item.architecture }}'
      runtime: '{{ item.runtime }}'
- discovery_id: aws.greengrassv2.listDeployments
  calls:
  - action: listDeployments
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.deployments }}'
    item:
      targetArn: '{{ item.targetArn }}'
      revisionId: '{{ item.revisionId }}'
      deploymentId: '{{ item.deploymentId }}'
      deploymentName: '{{ item.deploymentName }}'
      creationTimestamp: '{{ item.creationTimestamp }}'
      deploymentStatus: '{{ item.deploymentStatus }}'
      isLatestForTarget: '{{ item.isLatestForTarget }}'
      parentTargetArn: '{{ item.parentTargetArn }}'
- discovery_id: aws.greengrassv2.describeComponent
  calls:
  - action: describeComponent
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.platforms }}'
    item:
      name: '{{ item.name }}'
      attributes: '{{ item.attributes }}'
- discovery_id: aws.greengrassv2.getComponent
  calls:
  - action: getComponent
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.recipeOutputFormat }}'
- discovery_id: aws.greengrassv2.getComponentVersionArtifact
  calls:
  - action: getComponentVersionArtifact
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.preSignedUrl }}'
- discovery_id: aws.greengrassv2.getConnectivityInfo
  calls:
  - action: getConnectivityInfo
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.connectivityInfo }}'
    item:
      id: '{{ item.id }}'
      hostAddress: '{{ item.hostAddress }}'
      portNumber: '{{ item.portNumber }}'
      metadata: '{{ item.metadata }}'
- discovery_id: aws.greengrassv2.getCoreDevice
  calls:
  - action: getCoreDevice
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.coreDeviceThingName }}'
- discovery_id: aws.greengrassv2.getDeployment
  calls:
  - action: getDeployment
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.deploymentPolicies }}'
    item:
      failureHandlingPolicy: '{{ item.failureHandlingPolicy }}'
      componentUpdatePolicy: '{{ item.componentUpdatePolicy }}'
      configurationValidationPolicy: '{{ item.configurationValidationPolicy }}'
- discovery_id: aws.greengrassv2.listClientDevicesAssociatedWithCoreDevice
  calls:
  - action: listClientDevicesAssociatedWithCoreDevice
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.associatedClientDevices }}'
    item:
      thingName: '{{ item.thingName }}'
      associationTimestamp: '{{ item.associationTimestamp }}'
- discovery_id: aws.greengrassv2.listComponentVersions
  calls:
  - action: listComponentVersions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.componentVersions }}'
    item:
      componentName: '{{ item.componentName }}'
      componentVersion: '{{ item.componentVersion }}'
      arn: '{{ item.arn }}'
- discovery_id: aws.greengrassv2.listEffectiveDeployments
  calls:
  - action: listEffectiveDeployments
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.effectiveDeployments }}'
    item:
      deploymentId: '{{ item.deploymentId }}'
      deploymentName: '{{ item.deploymentName }}'
      iotJobId: '{{ item.iotJobId }}'
      iotJobArn: '{{ item.iotJobArn }}'
      description: '{{ item.description }}'
      targetArn: '{{ item.targetArn }}'
      coreDeviceExecutionStatus: '{{ item.coreDeviceExecutionStatus }}'
      reason: '{{ item.reason }}'
      creationTimestamp: '{{ item.creationTimestamp }}'
      modifiedTimestamp: '{{ item.modifiedTimestamp }}'
      statusDetails: '{{ item.statusDetails }}'
- discovery_id: aws.greengrassv2.listInstalledComponents
  calls:
  - action: listInstalledComponents
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.installedComponents }}'
    item:
      componentName: '{{ item.componentName }}'
      componentVersion: '{{ item.componentVersion }}'
      lifecycleState: '{{ item.lifecycleState }}'
      lifecycleStateDetails: '{{ item.lifecycleStateDetails }}'
      isRoot: '{{ item.isRoot }}'
      lastStatusChangeTimestamp: '{{ item.lastStatusChangeTimestamp }}'
      lastReportedTimestamp: '{{ item.lastReportedTimestamp }}'
      lastInstallationSource: '{{ item.lastInstallationSource }}'
      lifecycleStatusCodes: '{{ item.lifecycleStatusCodes }}'
- discovery_id: aws.greengrassv2.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tags }}'
checks: []
