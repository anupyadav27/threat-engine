version: '1.0'
provider: aws
service: snow-device-management
services:
  client: snow-device-management
  module: boto3.client
discovery:
- discovery_id: aws.snow-device-management.listDevices
  calls:
  - action: listDevices
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.devices }}'
    item:
      associatedWithJob: '{{ item.associatedWithJob }}'
      managedDeviceArn: '{{ item.managedDeviceArn }}'
      managedDeviceId: '{{ item.managedDeviceId }}'
      tags: '{{ item.tags }}'
- discovery_id: aws.snow-device-management.listTasks
  calls:
  - action: listTasks
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tasks }}'
    item:
      state: '{{ item.state }}'
      tags: '{{ item.tags }}'
      taskArn: '{{ item.taskArn }}'
      taskId: '{{ item.taskId }}'
- discovery_id: aws.snow-device-management.describeDevice
  calls:
  - action: describeDevice
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.deviceCapacities }}'
    item:
      available: '{{ item.available }}'
      name: '{{ item.name }}'
      total: '{{ item.total }}'
      unit: '{{ item.unit }}'
      used: '{{ item.used }}'
- discovery_id: aws.snow-device-management.describeDeviceEc2Instances
  calls:
  - action: describeDeviceEc2Instances
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.instances }}'
    item:
      instance: '{{ item.instance }}'
      lastUpdatedAt: '{{ item.lastUpdatedAt }}'
- discovery_id: aws.snow-device-management.describeExecution
  calls:
  - action: describeExecution
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.executionId }}'
- discovery_id: aws.snow-device-management.describeTask
  calls:
  - action: describeTask
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.targets }}'
- discovery_id: aws.snow-device-management.listDeviceResources
  calls:
  - action: listDeviceResources
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.resources }}'
    item:
      arn: '{{ item.arn }}'
      id: '{{ item.id }}'
      resourceType: '{{ item.resourceType }}'
- discovery_id: aws.snow-device-management.listExecutions
  calls:
  - action: listExecutions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.executions }}'
    item:
      executionId: '{{ item.executionId }}'
      managedDeviceId: '{{ item.managedDeviceId }}'
      state: '{{ item.state }}'
      taskId: '{{ item.taskId }}'
- discovery_id: aws.snow-device-management.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tags }}'
checks: []
