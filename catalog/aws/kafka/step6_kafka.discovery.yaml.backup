version: '1.0'
provider: aws
service: kafka
services:
  client: kafka
  module: boto3.client
discovery:
- discovery_id: aws.kafka.getCompatibleKafkaVersions
  calls:
  - action: getCompatibleKafkaVersions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.CompatibleKafkaVersions }}'
    item:
      SourceVersion: '{{ item.SourceVersion }}'
      TargetVersions: '{{ item.TargetVersions }}'
- discovery_id: aws.kafka.listClusters
  calls:
  - action: listClusters
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.ClusterInfoList }}'
    item:
      ActiveOperationArn: '{{ item.ActiveOperationArn }}'
      BrokerNodeGroupInfo: '{{ item.BrokerNodeGroupInfo }}'
      Rebalancing: '{{ item.Rebalancing }}'
      ClientAuthentication: '{{ item.ClientAuthentication }}'
      ClusterArn: '{{ item.ClusterArn }}'
      ClusterName: '{{ item.ClusterName }}'
      CreationTime: '{{ item.CreationTime }}'
      CurrentBrokerSoftwareInfo: '{{ item.CurrentBrokerSoftwareInfo }}'
      CurrentVersion: '{{ item.CurrentVersion }}'
      EncryptionInfo: '{{ item.EncryptionInfo }}'
      EnhancedMonitoring: '{{ item.EnhancedMonitoring }}'
      OpenMonitoring: '{{ item.OpenMonitoring }}'
      LoggingInfo: '{{ item.LoggingInfo }}'
      NumberOfBrokerNodes: '{{ item.NumberOfBrokerNodes }}'
      State: '{{ item.State }}'
      StateInfo: '{{ item.StateInfo }}'
      Tags: '{{ item.Tags }}'
      ZookeeperConnectString: '{{ item.ZookeeperConnectString }}'
      ZookeeperConnectStringTls: '{{ item.ZookeeperConnectStringTls }}'
      StorageMode: '{{ item.StorageMode }}'
      CustomerActionStatus: '{{ item.CustomerActionStatus }}'
- discovery_id: aws.kafka.listClustersV2
  calls:
  - action: listClustersV2
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.ClusterInfoList }}'
    item:
      ActiveOperationArn: '{{ item.ActiveOperationArn }}'
      ClusterType: '{{ item.ClusterType }}'
      ClusterArn: '{{ item.ClusterArn }}'
      ClusterName: '{{ item.ClusterName }}'
      CreationTime: '{{ item.CreationTime }}'
      CurrentVersion: '{{ item.CurrentVersion }}'
      State: '{{ item.State }}'
      StateInfo: '{{ item.StateInfo }}'
      Tags: '{{ item.Tags }}'
      Provisioned: '{{ item.Provisioned }}'
      Serverless: '{{ item.Serverless }}'
- discovery_id: aws.kafka.listConfigurations
  calls:
  - action: listConfigurations
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Configurations }}'
    item:
      Arn: '{{ item.Arn }}'
      CreationTime: '{{ item.CreationTime }}'
      Description: '{{ item.Description }}'
      KafkaVersions: '{{ item.KafkaVersions }}'
      LatestRevision: '{{ item.LatestRevision }}'
      Name: '{{ item.Name }}'
      State: '{{ item.State }}'
- discovery_id: aws.kafka.listKafkaVersions
  calls:
  - action: listKafkaVersions
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.KafkaVersions }}'
    item:
      Version: '{{ item.Version }}'
      Status: '{{ item.Status }}'
- discovery_id: aws.kafka.listReplicators
  calls:
  - action: listReplicators
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Replicators }}'
    item:
      CreationTime: '{{ item.CreationTime }}'
      CurrentVersion: '{{ item.CurrentVersion }}'
      IsReplicatorReference: '{{ item.IsReplicatorReference }}'
      KafkaClustersSummary: '{{ item.KafkaClustersSummary }}'
      ReplicationInfoSummaryList: '{{ item.ReplicationInfoSummaryList }}'
      ReplicatorArn: '{{ item.ReplicatorArn }}'
      ReplicatorName: '{{ item.ReplicatorName }}'
      ReplicatorResourceArn: '{{ item.ReplicatorResourceArn }}'
      ReplicatorState: '{{ item.ReplicatorState }}'
- discovery_id: aws.kafka.listVpcConnections
  calls:
  - action: listVpcConnections
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.VpcConnections }}'
    item:
      VpcConnectionArn: '{{ item.VpcConnectionArn }}'
      TargetClusterArn: '{{ item.TargetClusterArn }}'
      CreationTime: '{{ item.CreationTime }}'
      Authentication: '{{ item.Authentication }}'
      VpcId: '{{ item.VpcId }}'
      State: '{{ item.State }}'
- discovery_id: aws.kafka.describeCluster
  calls:
  - action: describeCluster
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ClusterInfo }}'
    item:
      ActiveOperationArn: '{{ item.ActiveOperationArn }}'
      BrokerNodeGroupInfo: '{{ item.BrokerNodeGroupInfo }}'
      Rebalancing: '{{ item.Rebalancing }}'
      ClientAuthentication: '{{ item.ClientAuthentication }}'
      ClusterArn: '{{ item.ClusterArn }}'
      ClusterName: '{{ item.ClusterName }}'
      CreationTime: '{{ item.CreationTime }}'
      CurrentBrokerSoftwareInfo: '{{ item.CurrentBrokerSoftwareInfo }}'
      CurrentVersion: '{{ item.CurrentVersion }}'
      EncryptionInfo: '{{ item.EncryptionInfo }}'
      EnhancedMonitoring: '{{ item.EnhancedMonitoring }}'
      OpenMonitoring: '{{ item.OpenMonitoring }}'
      LoggingInfo: '{{ item.LoggingInfo }}'
      NumberOfBrokerNodes: '{{ item.NumberOfBrokerNodes }}'
      State: '{{ item.State }}'
      StateInfo: '{{ item.StateInfo }}'
      Tags: '{{ item.Tags }}'
      ZookeeperConnectString: '{{ item.ZookeeperConnectString }}'
      ZookeeperConnectStringTls: '{{ item.ZookeeperConnectStringTls }}'
      StorageMode: '{{ item.StorageMode }}'
      CustomerActionStatus: '{{ item.CustomerActionStatus }}'
- discovery_id: aws.kafka.describeClusterV2
  calls:
  - action: describeClusterV2
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ClusterInfo }}'
    item:
      ActiveOperationArn: '{{ item.ActiveOperationArn }}'
      ClusterType: '{{ item.ClusterType }}'
      ClusterArn: '{{ item.ClusterArn }}'
      ClusterName: '{{ item.ClusterName }}'
      CreationTime: '{{ item.CreationTime }}'
      CurrentVersion: '{{ item.CurrentVersion }}'
      State: '{{ item.State }}'
      StateInfo: '{{ item.StateInfo }}'
      Tags: '{{ item.Tags }}'
      Provisioned: '{{ item.Provisioned }}'
      Serverless: '{{ item.Serverless }}'
- discovery_id: aws.kafka.describeClusterOperation
  calls:
  - action: describeClusterOperation
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ClusterOperationInfo }}'
    item:
      ClientRequestId: '{{ item.ClientRequestId }}'
      ClusterArn: '{{ item.ClusterArn }}'
      CreationTime: '{{ item.CreationTime }}'
      EndTime: '{{ item.EndTime }}'
      ErrorInfo: '{{ item.ErrorInfo }}'
      OperationArn: '{{ item.OperationArn }}'
      OperationState: '{{ item.OperationState }}'
      OperationSteps: '{{ item.OperationSteps }}'
      OperationType: '{{ item.OperationType }}'
      SourceClusterInfo: '{{ item.SourceClusterInfo }}'
      TargetClusterInfo: '{{ item.TargetClusterInfo }}'
      VpcConnectionInfo: '{{ item.VpcConnectionInfo }}'
- discovery_id: aws.kafka.describeClusterOperationV2
  calls:
  - action: describeClusterOperationV2
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ClusterOperationInfo }}'
    item:
      ClusterArn: '{{ item.ClusterArn }}'
      ClusterType: '{{ item.ClusterType }}'
      StartTime: '{{ item.StartTime }}'
      EndTime: '{{ item.EndTime }}'
      ErrorInfo: '{{ item.ErrorInfo }}'
      OperationArn: '{{ item.OperationArn }}'
      OperationState: '{{ item.OperationState }}'
      OperationType: '{{ item.OperationType }}'
      Provisioned: '{{ item.Provisioned }}'
      Serverless: '{{ item.Serverless }}'
- discovery_id: aws.kafka.describeConfiguration
  calls:
  - action: describeConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.KafkaVersions }}'
- discovery_id: aws.kafka.describeConfigurationRevision
  calls:
  - action: describeConfigurationRevision
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Arn }}'
- discovery_id: aws.kafka.describeReplicator
  calls:
  - action: describeReplicator
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ReplicationInfoList }}'
    item:
      ConsumerGroupReplication: '{{ item.ConsumerGroupReplication }}'
      SourceKafkaClusterAlias: '{{ item.SourceKafkaClusterAlias }}'
      TargetCompressionType: '{{ item.TargetCompressionType }}'
      TargetKafkaClusterAlias: '{{ item.TargetKafkaClusterAlias }}'
      TopicReplication: '{{ item.TopicReplication }}'
- discovery_id: aws.kafka.describeTopic
  calls:
  - action: describeTopic
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.TopicArn }}'
- discovery_id: aws.kafka.describeTopicPartitions
  calls:
  - action: describeTopicPartitions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Partitions }}'
    item:
      Partition: '{{ item.Partition }}'
      Leader: '{{ item.Leader }}'
      Replicas: '{{ item.Replicas }}'
      Isr: '{{ item.Isr }}'
- discovery_id: aws.kafka.describeVpcConnection
  calls:
  - action: describeVpcConnection
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.SecurityGroups }}'
- discovery_id: aws.kafka.getBootstrapBrokers
  calls:
  - action: getBootstrapBrokers
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.BootstrapBrokerString }}'
- discovery_id: aws.kafka.getClusterPolicy
  calls:
  - action: getClusterPolicy
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.CurrentVersion }}'
- discovery_id: aws.kafka.listClusterOperations
  calls:
  - action: listClusterOperations
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.ClusterOperationInfoList }}'
    item:
      ClientRequestId: '{{ item.ClientRequestId }}'
      ClusterArn: '{{ item.ClusterArn }}'
      CreationTime: '{{ item.CreationTime }}'
      EndTime: '{{ item.EndTime }}'
      ErrorInfo: '{{ item.ErrorInfo }}'
      OperationArn: '{{ item.OperationArn }}'
      OperationState: '{{ item.OperationState }}'
      OperationSteps: '{{ item.OperationSteps }}'
      OperationType: '{{ item.OperationType }}'
      SourceClusterInfo: '{{ item.SourceClusterInfo }}'
      TargetClusterInfo: '{{ item.TargetClusterInfo }}'
      VpcConnectionInfo: '{{ item.VpcConnectionInfo }}'
- discovery_id: aws.kafka.listClusterOperationsV2
  calls:
  - action: listClusterOperationsV2
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.ClusterOperationInfoList }}'
    item:
      ClusterArn: '{{ item.ClusterArn }}'
      ClusterType: '{{ item.ClusterType }}'
      StartTime: '{{ item.StartTime }}'
      EndTime: '{{ item.EndTime }}'
      OperationArn: '{{ item.OperationArn }}'
      OperationState: '{{ item.OperationState }}'
      OperationType: '{{ item.OperationType }}'
- discovery_id: aws.kafka.listConfigurationRevisions
  calls:
  - action: listConfigurationRevisions
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Revisions }}'
    item:
      CreationTime: '{{ item.CreationTime }}'
      Description: '{{ item.Description }}'
      Revision: '{{ item.Revision }}'
- discovery_id: aws.kafka.listNodes
  calls:
  - action: listNodes
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.NodeInfoList }}'
    item:
      AddedToClusterTime: '{{ item.AddedToClusterTime }}'
      BrokerNodeInfo: '{{ item.BrokerNodeInfo }}'
      ControllerNodeInfo: '{{ item.ControllerNodeInfo }}'
      InstanceType: '{{ item.InstanceType }}'
      NodeARN: '{{ item.NodeARN }}'
      NodeType: '{{ item.NodeType }}'
      ZookeeperNodeInfo: '{{ item.ZookeeperNodeInfo }}'
- discovery_id: aws.kafka.listScramSecrets
  calls:
  - action: listScramSecrets
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.SecretArnList }}'
- discovery_id: aws.kafka.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Tags }}'
- discovery_id: aws.kafka.listClientVpcConnections
  calls:
  - action: listClientVpcConnections
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.ClientVpcConnections }}'
    item:
      Authentication: '{{ item.Authentication }}'
      CreationTime: '{{ item.CreationTime }}'
      State: '{{ item.State }}'
      VpcConnectionArn: '{{ item.VpcConnectionArn }}'
      Owner: '{{ item.Owner }}'
- discovery_id: aws.kafka.listTopics
  calls:
  - action: listTopics
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Topics }}'
    item:
      TopicArn: '{{ item.TopicArn }}'
      TopicName: '{{ item.TopicName }}'
      ReplicationFactor: '{{ item.ReplicationFactor }}'
      PartitionCount: '{{ item.PartitionCount }}'
      OutOfSyncReplicaCount: '{{ item.OutOfSyncReplicaCount }}'
checks: []
