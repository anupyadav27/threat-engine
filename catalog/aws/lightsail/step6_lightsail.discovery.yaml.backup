version: '1.0'
provider: aws
service: lightsail
services:
  client: lightsail
  module: boto3.client
discovery:
- discovery_id: aws.lightsail.getActiveNames
  calls:
  - action: getActiveNames
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.activeNames }}'
- discovery_id: aws.lightsail.getAlarms
  calls:
  - action: getAlarms
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.alarms }}'
    item:
      name: '{{ item.name }}'
      arn: '{{ item.arn }}'
      createdAt: '{{ item.createdAt }}'
      location: '{{ item.location }}'
      resourceType: '{{ item.resourceType }}'
      supportCode: '{{ item.supportCode }}'
      monitoredResourceInfo: '{{ item.monitoredResourceInfo }}'
      comparisonOperator: '{{ item.comparisonOperator }}'
      evaluationPeriods: '{{ item.evaluationPeriods }}'
      period: '{{ item.period }}'
      threshold: '{{ item.threshold }}'
      datapointsToAlarm: '{{ item.datapointsToAlarm }}'
      treatMissingData: '{{ item.treatMissingData }}'
      statistic: '{{ item.statistic }}'
      metricName: '{{ item.metricName }}'
      state: '{{ item.state }}'
      unit: '{{ item.unit }}'
      contactProtocols: '{{ item.contactProtocols }}'
      notificationTriggers: '{{ item.notificationTriggers }}'
      notificationEnabled: '{{ item.notificationEnabled }}'
- discovery_id: aws.lightsail.getBlueprints
  calls:
  - action: getBlueprints
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.blueprints }}'
    item:
      blueprintId: '{{ item.blueprintId }}'
      name: '{{ item.name }}'
      group: '{{ item.group }}'
      type: '{{ item.type }}'
      description: '{{ item.description }}'
      isActive: '{{ item.isActive }}'
      minPower: '{{ item.minPower }}'
      version: '{{ item.version }}'
      versionCode: '{{ item.versionCode }}'
      productUrl: '{{ item.productUrl }}'
      licenseUrl: '{{ item.licenseUrl }}'
      platform: '{{ item.platform }}'
      appCategory: '{{ item.appCategory }}'
- discovery_id: aws.lightsail.getBucketBundles
  calls:
  - action: getBucketBundles
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.bundles }}'
    item:
      bundleId: '{{ item.bundleId }}'
      name: '{{ item.name }}'
      price: '{{ item.price }}'
      storagePerMonthInGb: '{{ item.storagePerMonthInGb }}'
      transferPerMonthInGb: '{{ item.transferPerMonthInGb }}'
      isActive: '{{ item.isActive }}'
- discovery_id: aws.lightsail.getBuckets
  calls:
  - action: getBuckets
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.buckets }}'
    item:
      resourceType: '{{ item.resourceType }}'
      accessRules: '{{ item.accessRules }}'
      arn: '{{ item.arn }}'
      bundleId: '{{ item.bundleId }}'
      createdAt: '{{ item.createdAt }}'
      url: '{{ item.url }}'
      location: '{{ item.location }}'
      name: '{{ item.name }}'
      supportCode: '{{ item.supportCode }}'
      tags: '{{ item.tags }}'
      objectVersioning: '{{ item.objectVersioning }}'
      ableToUpdateBundle: '{{ item.ableToUpdateBundle }}'
      readonlyAccessAccounts: '{{ item.readonlyAccessAccounts }}'
      resourcesReceivingAccess: '{{ item.resourcesReceivingAccess }}'
      state: '{{ item.state }}'
      accessLogConfig: '{{ item.accessLogConfig }}'
      cors: '{{ item.cors }}'
- discovery_id: aws.lightsail.getBundles
  calls:
  - action: getBundles
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.bundles }}'
    item:
      price: '{{ item.price }}'
      cpuCount: '{{ item.cpuCount }}'
      diskSizeInGb: '{{ item.diskSizeInGb }}'
      bundleId: '{{ item.bundleId }}'
      instanceType: '{{ item.instanceType }}'
      isActive: '{{ item.isActive }}'
      name: '{{ item.name }}'
      power: '{{ item.power }}'
      ramSizeInGb: '{{ item.ramSizeInGb }}'
      transferPerMonthInGb: '{{ item.transferPerMonthInGb }}'
      supportedPlatforms: '{{ item.supportedPlatforms }}'
      supportedAppCategories: '{{ item.supportedAppCategories }}'
      publicIpv4AddressCount: '{{ item.publicIpv4AddressCount }}'
- discovery_id: aws.lightsail.getCertificates
  calls:
  - action: getCertificates
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.certificates }}'
    item:
      certificateArn: '{{ item.certificateArn }}'
      certificateName: '{{ item.certificateName }}'
      domainName: '{{ item.domainName }}'
      certificateDetail: '{{ item.certificateDetail }}'
      tags: '{{ item.tags }}'
- discovery_id: aws.lightsail.getCloudFormationStackRecords
  calls:
  - action: getCloudFormationStackRecords
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.cloudFormationStackRecords }}'
    item:
      name: '{{ item.name }}'
      arn: '{{ item.arn }}'
      createdAt: '{{ item.createdAt }}'
      location: '{{ item.location }}'
      resourceType: '{{ item.resourceType }}'
      state: '{{ item.state }}'
      sourceInfo: '{{ item.sourceInfo }}'
      destinationInfo: '{{ item.destinationInfo }}'
- discovery_id: aws.lightsail.getContactMethods
  calls:
  - action: getContactMethods
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.contactMethods }}'
    item:
      contactEndpoint: '{{ item.contactEndpoint }}'
      status: '{{ item.status }}'
      protocol: '{{ item.protocol }}'
      name: '{{ item.name }}'
      arn: '{{ item.arn }}'
      createdAt: '{{ item.createdAt }}'
      location: '{{ item.location }}'
      resourceType: '{{ item.resourceType }}'
      supportCode: '{{ item.supportCode }}'
- discovery_id: aws.lightsail.getContainerApiMetadata
  calls:
  - action: getContainerApiMetadata
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.metadata }}'
- discovery_id: aws.lightsail.getContainerServicePowers
  calls:
  - action: getContainerServicePowers
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.powers }}'
    item:
      powerId: '{{ item.powerId }}'
      price: '{{ item.price }}'
      cpuCount: '{{ item.cpuCount }}'
      ramSizeInGb: '{{ item.ramSizeInGb }}'
      name: '{{ item.name }}'
      isActive: '{{ item.isActive }}'
- discovery_id: aws.lightsail.getContainerServices
  calls:
  - action: getContainerServices
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.containerServices }}'
    item:
      containerServiceName: '{{ item.containerServiceName }}'
      arn: '{{ item.arn }}'
      createdAt: '{{ item.createdAt }}'
      location: '{{ item.location }}'
      resourceType: '{{ item.resourceType }}'
      tags: '{{ item.tags }}'
      power: '{{ item.power }}'
      powerId: '{{ item.powerId }}'
      state: '{{ item.state }}'
      stateDetail: '{{ item.stateDetail }}'
      scale: '{{ item.scale }}'
      currentDeployment: '{{ item.currentDeployment }}'
      nextDeployment: '{{ item.nextDeployment }}'
      isDisabled: '{{ item.isDisabled }}'
      principalArn: '{{ item.principalArn }}'
      privateDomainName: '{{ item.privateDomainName }}'
      publicDomainNames: '{{ item.publicDomainNames }}'
      url: '{{ item.url }}'
      privateRegistryAccess: '{{ item.privateRegistryAccess }}'
- discovery_id: aws.lightsail.getDiskSnapshots
  calls:
  - action: getDiskSnapshots
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.diskSnapshots }}'
