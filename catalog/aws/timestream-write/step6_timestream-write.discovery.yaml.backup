version: '1.0'
provider: aws
service: timestream-write
services:
  client: timestream-write
  module: boto3.client
discovery:
- discovery_id: aws.timestream-write.describeEndpoints
  calls:
  - action: describeEndpoints
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Endpoints }}'
    item:
      Address: '{{ item.Address }}'
      CachePeriodInMinutes: '{{ item.CachePeriodInMinutes }}'
- discovery_id: aws.timestream-write.listBatchLoadTasks
  calls:
  - action: listBatchLoadTasks
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.BatchLoadTasks }}'
    item:
      TaskId: '{{ item.TaskId }}'
      TaskStatus: '{{ item.TaskStatus }}'
      DatabaseName: '{{ item.DatabaseName }}'
      TableName: '{{ item.TableName }}'
      CreationTime: '{{ item.CreationTime }}'
      LastUpdatedTime: '{{ item.LastUpdatedTime }}'
      ResumableUntil: '{{ item.ResumableUntil }}'
- discovery_id: aws.timestream-write.listDatabases
  calls:
  - action: listDatabases
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Databases }}'
    item:
      Arn: '{{ item.Arn }}'
      DatabaseName: '{{ item.DatabaseName }}'
      TableCount: '{{ item.TableCount }}'
      KmsKeyId: '{{ item.KmsKeyId }}'
      CreationTime: '{{ item.CreationTime }}'
      LastUpdatedTime: '{{ item.LastUpdatedTime }}'
- discovery_id: aws.timestream-write.listTables
  calls:
  - action: listTables
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Tables }}'
    item:
      Arn: '{{ item.Arn }}'
      TableName: '{{ item.TableName }}'
      DatabaseName: '{{ item.DatabaseName }}'
      TableStatus: '{{ item.TableStatus }}'
      RetentionProperties: '{{ item.RetentionProperties }}'
      CreationTime: '{{ item.CreationTime }}'
      LastUpdatedTime: '{{ item.LastUpdatedTime }}'
      MagneticStoreWriteProperties: '{{ item.MagneticStoreWriteProperties }}'
      Schema: '{{ item.Schema }}'
- discovery_id: aws.timestream-write.describeBatchLoadTask
  calls:
  - action: describeBatchLoadTask
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.BatchLoadTaskDescription }}'
    item:
      TaskId: '{{ item.TaskId }}'
      ErrorMessage: '{{ item.ErrorMessage }}'
      DataSourceConfiguration: '{{ item.DataSourceConfiguration }}'
      ProgressReport: '{{ item.ProgressReport }}'
      ReportConfiguration: '{{ item.ReportConfiguration }}'
      DataModelConfiguration: '{{ item.DataModelConfiguration }}'
      TargetDatabaseName: '{{ item.TargetDatabaseName }}'
      TargetTableName: '{{ item.TargetTableName }}'
      TaskStatus: '{{ item.TaskStatus }}'
      RecordVersion: '{{ item.RecordVersion }}'
      CreationTime: '{{ item.CreationTime }}'
      LastUpdatedTime: '{{ item.LastUpdatedTime }}'
      ResumableUntil: '{{ item.ResumableUntil }}'
- discovery_id: aws.timestream-write.describeDatabase
  calls:
  - action: describeDatabase
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Database }}'
    item:
      Arn: '{{ item.Arn }}'
      DatabaseName: '{{ item.DatabaseName }}'
      TableCount: '{{ item.TableCount }}'
      KmsKeyId: '{{ item.KmsKeyId }}'
      CreationTime: '{{ item.CreationTime }}'
      LastUpdatedTime: '{{ item.LastUpdatedTime }}'
- discovery_id: aws.timestream-write.describeTable
  calls:
  - action: describeTable
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Table }}'
    item:
      Arn: '{{ item.Arn }}'
      TableName: '{{ item.TableName }}'
      DatabaseName: '{{ item.DatabaseName }}'
      TableStatus: '{{ item.TableStatus }}'
      RetentionProperties: '{{ item.RetentionProperties }}'
      CreationTime: '{{ item.CreationTime }}'
      LastUpdatedTime: '{{ item.LastUpdatedTime }}'
      MagneticStoreWriteProperties: '{{ item.MagneticStoreWriteProperties }}'
      Schema: '{{ item.Schema }}'
- discovery_id: aws.timestream-write.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Tags }}'
    item:
      Key: '{{ item.Key }}'
      Value: '{{ item.Value }}'
checks: []
