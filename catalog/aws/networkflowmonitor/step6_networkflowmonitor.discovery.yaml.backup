version: '1.0'
provider: aws
service: networkflowmonitor
services:
  client: networkflowmonitor
  module: boto3.client
discovery:
- discovery_id: aws.networkflowmonitor.listMonitors
  calls:
  - action: listMonitors
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.monitors }}'
    item:
      monitorArn: '{{ item.monitorArn }}'
      monitorName: '{{ item.monitorName }}'
      monitorStatus: '{{ item.monitorStatus }}'
- discovery_id: aws.networkflowmonitor.listScopes
  calls:
  - action: listScopes
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.scopes }}'
    item:
      scopeId: '{{ item.scopeId }}'
      status: '{{ item.status }}'
      scopeArn: '{{ item.scopeArn }}'
- discovery_id: aws.networkflowmonitor.getMonitor
  calls:
  - action: getMonitor
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.localResources }}'
    item:
      type: '{{ item.type }}'
      identifier: '{{ item.identifier }}'
- discovery_id: aws.networkflowmonitor.getQueryResultsMonitorTopContributors
  calls:
  - action: getQueryResultsMonitorTopContributors
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.topContributors }}'
    item:
      localIp: '{{ item.localIp }}'
      snatIp: '{{ item.snatIp }}'
      localInstanceId: '{{ item.localInstanceId }}'
      localVpcId: '{{ item.localVpcId }}'
      localRegion: '{{ item.localRegion }}'
      localAz: '{{ item.localAz }}'
      localSubnetId: '{{ item.localSubnetId }}'
      targetPort: '{{ item.targetPort }}'
      destinationCategory: '{{ item.destinationCategory }}'
      remoteVpcId: '{{ item.remoteVpcId }}'
      remoteRegion: '{{ item.remoteRegion }}'
      remoteAz: '{{ item.remoteAz }}'
      remoteSubnetId: '{{ item.remoteSubnetId }}'
      remoteInstanceId: '{{ item.remoteInstanceId }}'
      remoteIp: '{{ item.remoteIp }}'
      dnatIp: '{{ item.dnatIp }}'
      value: '{{ item.value }}'
      traversedConstructs: '{{ item.traversedConstructs }}'
      kubernetesMetadata: '{{ item.kubernetesMetadata }}'
      localInstanceArn: '{{ item.localInstanceArn }}'
      localSubnetArn: '{{ item.localSubnetArn }}'
      localVpcArn: '{{ item.localVpcArn }}'
      remoteInstanceArn: '{{ item.remoteInstanceArn }}'
      remoteSubnetArn: '{{ item.remoteSubnetArn }}'
      remoteVpcArn: '{{ item.remoteVpcArn }}'
- discovery_id: aws.networkflowmonitor.getQueryResultsWorkloadInsightsTopContributors
  calls:
  - action: getQueryResultsWorkloadInsightsTopContributors
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.topContributors }}'
    item:
      accountId: '{{ item.accountId }}'
      localSubnetId: '{{ item.localSubnetId }}'
      localAz: '{{ item.localAz }}'
      localVpcId: '{{ item.localVpcId }}'
      localRegion: '{{ item.localRegion }}'
      remoteIdentifier: '{{ item.remoteIdentifier }}'
      value: '{{ item.value }}'
      localSubnetArn: '{{ item.localSubnetArn }}'
      localVpcArn: '{{ item.localVpcArn }}'
- discovery_id: aws.networkflowmonitor.getQueryResultsWorkloadInsightsTopContributorsData
  calls:
  - action: getQueryResultsWorkloadInsightsTopContributorsData
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.datapoints }}'
    item:
      timestamps: '{{ item.timestamps }}'
      values: '{{ item.values }}'
      label: '{{ item.label }}'
- discovery_id: aws.networkflowmonitor.getQueryStatusMonitorTopContributors
  calls:
  - action: getQueryStatusMonitorTopContributors
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.status }}'
- discovery_id: aws.networkflowmonitor.getQueryStatusWorkloadInsightsTopContributors
  calls:
  - action: getQueryStatusWorkloadInsightsTopContributors
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.status }}'
- discovery_id: aws.networkflowmonitor.getQueryStatusWorkloadInsightsTopContributorsData
  calls:
  - action: getQueryStatusWorkloadInsightsTopContributorsData
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.status }}'
- discovery_id: aws.networkflowmonitor.getScope
  calls:
  - action: getScope
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.targets }}'
    item:
      targetIdentifier: '{{ item.targetIdentifier }}'
      region: '{{ item.region }}'
- discovery_id: aws.networkflowmonitor.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tags }}'
checks: []
