version: '1.0'
provider: aws
service: s3vectors
services:
  client: s3vectors
  module: boto3.client
discovery:
- discovery_id: aws.s3vectors.getIndex
  calls:
  - action: getIndex
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.index }}'
    item:
      vectorBucketName: '{{ item.vectorBucketName }}'
      indexName: '{{ item.indexName }}'
      indexArn: '{{ item.indexArn }}'
      creationTime: '{{ item.creationTime }}'
      dataType: '{{ item.dataType }}'
      dimension: '{{ item.dimension }}'
      distanceMetric: '{{ item.distanceMetric }}'
      metadataConfiguration: '{{ item.metadataConfiguration }}'
- discovery_id: aws.s3vectors.getVectorBucket
  calls:
  - action: getVectorBucket
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.vectorBucket }}'
    item:
      vectorBucketName: '{{ item.vectorBucketName }}'
      vectorBucketArn: '{{ item.vectorBucketArn }}'
      creationTime: '{{ item.creationTime }}'
      encryptionConfiguration: '{{ item.encryptionConfiguration }}'
- discovery_id: aws.s3vectors.getVectorBucketPolicy
  calls:
  - action: getVectorBucketPolicy
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.policy }}'
- discovery_id: aws.s3vectors.listIndexes
  calls:
  - action: listIndexes
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.indexes }}'
    item:
      vectorBucketName: '{{ item.vectorBucketName }}'
      indexName: '{{ item.indexName }}'
      indexArn: '{{ item.indexArn }}'
      creationTime: '{{ item.creationTime }}'
- discovery_id: aws.s3vectors.listVectorBuckets
  calls:
  - action: listVectorBuckets
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.vectorBuckets }}'
    item:
      vectorBucketName: '{{ item.vectorBucketName }}'
      vectorBucketArn: '{{ item.vectorBucketArn }}'
      creationTime: '{{ item.creationTime }}'
- discovery_id: aws.s3vectors.listVectors
  calls:
  - action: listVectors
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.vectors }}'
    item:
      key: '{{ item.key }}'
      data: '{{ item.data }}'
      metadata: '{{ item.metadata }}'
- discovery_id: aws.s3vectors.getVectors
  calls:
  - action: getVectors
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.vectors }}'
    item:
      key: '{{ item.key }}'
      data: '{{ item.data }}'
      metadata: '{{ item.metadata }}'
- discovery_id: aws.s3vectors.queryVectors
  calls:
  - action: queryVectors
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.vectors }}'
    item:
      key: '{{ item.key }}'
      data: '{{ item.data }}'
      metadata: '{{ item.metadata }}'
      distance: '{{ item.distance }}'
checks: []
