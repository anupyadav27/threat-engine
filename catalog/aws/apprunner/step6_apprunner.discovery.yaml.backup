version: '1.0'
provider: aws
service: apprunner
services:
  client: apprunner
  module: boto3.client
discovery:
- discovery_id: aws.apprunner.listAutoScalingConfigurations
  calls:
  - action: listAutoScalingConfigurations
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.AutoScalingConfigurationSummaryList }}'
    item:
      AutoScalingConfigurationArn: '{{ item.AutoScalingConfigurationArn }}'
      AutoScalingConfigurationName: '{{ item.AutoScalingConfigurationName }}'
      AutoScalingConfigurationRevision: '{{ item.AutoScalingConfigurationRevision
        }}'
      Status: '{{ item.Status }}'
      CreatedAt: '{{ item.CreatedAt }}'
      HasAssociatedService: '{{ item.HasAssociatedService }}'
      IsDefault: '{{ item.IsDefault }}'
- discovery_id: aws.apprunner.listConnections
  calls:
  - action: listConnections
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.ConnectionSummaryList }}'
    item:
      ConnectionName: '{{ item.ConnectionName }}'
      ConnectionArn: '{{ item.ConnectionArn }}'
      ProviderType: '{{ item.ProviderType }}'
      Status: '{{ item.Status }}'
      CreatedAt: '{{ item.CreatedAt }}'
- discovery_id: aws.apprunner.listObservabilityConfigurations
  calls:
  - action: listObservabilityConfigurations
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.ObservabilityConfigurationSummaryList }}'
    item:
      ObservabilityConfigurationArn: '{{ item.ObservabilityConfigurationArn }}'
      ObservabilityConfigurationName: '{{ item.ObservabilityConfigurationName }}'
      ObservabilityConfigurationRevision: '{{ item.ObservabilityConfigurationRevision
        }}'
- discovery_id: aws.apprunner.listServices
  calls:
  - action: listServices
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.ServiceSummaryList }}'
    item:
      ServiceName: '{{ item.ServiceName }}'
      ServiceId: '{{ item.ServiceId }}'
      ServiceArn: '{{ item.ServiceArn }}'
      ServiceUrl: '{{ item.ServiceUrl }}'
      CreatedAt: '{{ item.CreatedAt }}'
      UpdatedAt: '{{ item.UpdatedAt }}'
      Status: '{{ item.Status }}'
- discovery_id: aws.apprunner.listVpcConnectors
  calls:
  - action: listVpcConnectors
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.VpcConnectors }}'
    item:
      VpcConnectorName: '{{ item.VpcConnectorName }}'
      VpcConnectorArn: '{{ item.VpcConnectorArn }}'
      VpcConnectorRevision: '{{ item.VpcConnectorRevision }}'
      Subnets: '{{ item.Subnets }}'
      SecurityGroups: '{{ item.SecurityGroups }}'
      Status: '{{ item.Status }}'
      CreatedAt: '{{ item.CreatedAt }}'
      DeletedAt: '{{ item.DeletedAt }}'
- discovery_id: aws.apprunner.listVpcIngressConnections
  calls:
  - action: listVpcIngressConnections
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.VpcIngressConnectionSummaryList }}'
    item:
      VpcIngressConnectionArn: '{{ item.VpcIngressConnectionArn }}'
      ServiceArn: '{{ item.ServiceArn }}'
- discovery_id: aws.apprunner.describeAutoScalingConfiguration
  calls:
  - action: describeAutoScalingConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AutoScalingConfiguration }}'
    item:
      AutoScalingConfigurationArn: '{{ item.AutoScalingConfigurationArn }}'
      AutoScalingConfigurationName: '{{ item.AutoScalingConfigurationName }}'
      AutoScalingConfigurationRevision: '{{ item.AutoScalingConfigurationRevision
        }}'
      Latest: '{{ item.Latest }}'
      Status: '{{ item.Status }}'
      MaxConcurrency: '{{ item.MaxConcurrency }}'
      MinSize: '{{ item.MinSize }}'
      MaxSize: '{{ item.MaxSize }}'
      CreatedAt: '{{ item.CreatedAt }}'
      DeletedAt: '{{ item.DeletedAt }}'
      HasAssociatedService: '{{ item.HasAssociatedService }}'
      IsDefault: '{{ item.IsDefault }}'
- discovery_id: aws.apprunner.describeCustomDomains
  calls:
  - action: describeCustomDomains
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.CustomDomains }}'
    item:
      DomainName: '{{ item.DomainName }}'
      EnableWWWSubdomain: '{{ item.EnableWWWSubdomain }}'
      CertificateValidationRecords: '{{ item.CertificateValidationRecords }}'
      Status: '{{ item.Status }}'
- discovery_id: aws.apprunner.describeObservabilityConfiguration
  calls:
  - action: describeObservabilityConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ObservabilityConfiguration }}'
    item:
      ObservabilityConfigurationArn: '{{ item.ObservabilityConfigurationArn }}'
      ObservabilityConfigurationName: '{{ item.ObservabilityConfigurationName }}'
      TraceConfiguration: '{{ item.TraceConfiguration }}'
      ObservabilityConfigurationRevision: '{{ item.ObservabilityConfigurationRevision
        }}'
      Latest: '{{ item.Latest }}'
      Status: '{{ item.Status }}'
      CreatedAt: '{{ item.CreatedAt }}'
      DeletedAt: '{{ item.DeletedAt }}'
- discovery_id: aws.apprunner.describeService
  calls:
  - action: describeService
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Service }}'
    item:
      ServiceName: '{{ item.ServiceName }}'
      ServiceId: '{{ item.ServiceId }}'
      ServiceArn: '{{ item.ServiceArn }}'
      ServiceUrl: '{{ item.ServiceUrl }}'
      CreatedAt: '{{ item.CreatedAt }}'
      UpdatedAt: '{{ item.UpdatedAt }}'
      DeletedAt: '{{ item.DeletedAt }}'
      Status: '{{ item.Status }}'
      SourceConfiguration: '{{ item.SourceConfiguration }}'
      InstanceConfiguration: '{{ item.InstanceConfiguration }}'
      EncryptionConfiguration: '{{ item.EncryptionConfiguration }}'
      HealthCheckConfiguration: '{{ item.HealthCheckConfiguration }}'
      AutoScalingConfigurationSummary: '{{ item.AutoScalingConfigurationSummary }}'
      NetworkConfiguration: '{{ item.NetworkConfiguration }}'
      ObservabilityConfiguration: '{{ item.ObservabilityConfiguration }}'
- discovery_id: aws.apprunner.describeVpcConnector
  calls:
  - action: describeVpcConnector
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.VpcConnector }}'
    item:
      VpcConnectorName: '{{ item.VpcConnectorName }}'
      VpcConnectorArn: '{{ item.VpcConnectorArn }}'
      VpcConnectorRevision: '{{ item.VpcConnectorRevision }}'
      Subnets: '{{ item.Subnets }}'
      SecurityGroups: '{{ item.SecurityGroups }}'
      Status: '{{ item.Status }}'
      CreatedAt: '{{ item.CreatedAt }}'
      DeletedAt: '{{ item.DeletedAt }}'
- discovery_id: aws.apprunner.describeVpcIngressConnection
  calls:
  - action: describeVpcIngressConnection
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.VpcIngressConnection }}'
    item:
      VpcIngressConnectionArn: '{{ item.VpcIngressConnectionArn }}'
      VpcIngressConnectionName: '{{ item.VpcIngressConnectionName }}'
      ServiceArn: '{{ item.ServiceArn }}'
      Status: '{{ item.Status }}'
      AccountId: '{{ item.AccountId }}'
      DomainName: '{{ item.DomainName }}'
      IngressVpcConfiguration: '{{ item.IngressVpcConfiguration }}'
      CreatedAt: '{{ item.CreatedAt }}'
      DeletedAt: '{{ item.DeletedAt }}'
- discovery_id: aws.apprunner.listOperations
  calls:
  - action: listOperations
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.OperationSummaryList }}'
    item:
      Id: '{{ item.Id }}'
      Type: '{{ item.Type }}'
      Status: '{{ item.Status }}'
      TargetArn: '{{ item.TargetArn }}'
      StartedAt: '{{ item.StartedAt }}'
      EndedAt: '{{ item.EndedAt }}'
      UpdatedAt: '{{ item.UpdatedAt }}'
- discovery_id: aws.apprunner.listServicesForAutoScalingConfiguration
  calls:
  - action: listServicesForAutoScalingConfiguration
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.ServiceArnList }}'
- discovery_id: aws.apprunner.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Tags }}'
    item:
      Key: '{{ item.Key }}'
      Value: '{{ item.Value }}'
checks: []
