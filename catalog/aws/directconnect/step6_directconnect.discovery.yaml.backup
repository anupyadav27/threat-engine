version: '1.0'
provider: aws
service: directconnect
services:
  client: directconnect
  module: boto3.client
discovery:
- discovery_id: aws.directconnect.describeConnections
  calls:
  - action: describeConnections
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.connections }}'
    item:
      ownerAccount: '{{ item.ownerAccount }}'
      connectionId: '{{ item.connectionId }}'
      connectionName: '{{ item.connectionName }}'
      connectionState: '{{ item.connectionState }}'
      region: '{{ item.region }}'
      location: '{{ item.location }}'
      bandwidth: '{{ item.bandwidth }}'
      vlan: '{{ item.vlan }}'
      partnerName: '{{ item.partnerName }}'
      loaIssueTime: '{{ item.loaIssueTime }}'
      lagId: '{{ item.lagId }}'
      awsDevice: '{{ item.awsDevice }}'
      jumboFrameCapable: '{{ item.jumboFrameCapable }}'
      awsDeviceV2: '{{ item.awsDeviceV2 }}'
      awsLogicalDeviceId: '{{ item.awsLogicalDeviceId }}'
      hasLogicalRedundancy: '{{ item.hasLogicalRedundancy }}'
      tags: '{{ item.tags }}'
      providerName: '{{ item.providerName }}'
      macSecCapable: '{{ item.macSecCapable }}'
      portEncryptionStatus: '{{ item.portEncryptionStatus }}'
      encryptionMode: '{{ item.encryptionMode }}'
      macSecKeys: '{{ item.macSecKeys }}'
      partnerInterconnectMacSecCapable: '{{ item.partnerInterconnectMacSecCapable
        }}'
- discovery_id: aws.directconnect.describeCustomerMetadata
  calls:
  - action: describeCustomerMetadata
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.agreements }}'
    item:
      agreementName: '{{ item.agreementName }}'
      status: '{{ item.status }}'
- discovery_id: aws.directconnect.describeDirectConnectGatewayAssociationProposals
  calls:
  - action: describeDirectConnectGatewayAssociationProposals
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.directConnectGatewayAssociationProposals }}'
    item:
      proposalId: '{{ item.proposalId }}'
      directConnectGatewayId: '{{ item.directConnectGatewayId }}'
      directConnectGatewayOwnerAccount: '{{ item.directConnectGatewayOwnerAccount
        }}'
      proposalState: '{{ item.proposalState }}'
      associatedGateway: '{{ item.associatedGateway }}'
      existingAllowedPrefixesToDirectConnectGateway: '{{ item.existingAllowedPrefixesToDirectConnectGateway
        }}'
      requestedAllowedPrefixesToDirectConnectGateway: '{{ item.requestedAllowedPrefixesToDirectConnectGateway
        }}'
- discovery_id: aws.directconnect.describeDirectConnectGatewayAssociations
  calls:
  - action: describeDirectConnectGatewayAssociations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.directConnectGatewayAssociations }}'
    item:
      directConnectGatewayId: '{{ item.directConnectGatewayId }}'
      directConnectGatewayOwnerAccount: '{{ item.directConnectGatewayOwnerAccount
        }}'
      associationState: '{{ item.associationState }}'
      stateChangeError: '{{ item.stateChangeError }}'
      associatedGateway: '{{ item.associatedGateway }}'
      associationId: '{{ item.associationId }}'
      allowedPrefixesToDirectConnectGateway: '{{ item.allowedPrefixesToDirectConnectGateway
        }}'
      associatedCoreNetwork: '{{ item.associatedCoreNetwork }}'
      virtualGatewayId: '{{ item.virtualGatewayId }}'
      virtualGatewayRegion: '{{ item.virtualGatewayRegion }}'
      virtualGatewayOwnerAccount: '{{ item.virtualGatewayOwnerAccount }}'
- discovery_id: aws.directconnect.describeDirectConnectGatewayAttachments
  calls:
  - action: describeDirectConnectGatewayAttachments
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.directConnectGatewayAttachments }}'
    item:
      directConnectGatewayId: '{{ item.directConnectGatewayId }}'
      virtualInterfaceId: '{{ item.virtualInterfaceId }}'
      virtualInterfaceRegion: '{{ item.virtualInterfaceRegion }}'
      virtualInterfaceOwnerAccount: '{{ item.virtualInterfaceOwnerAccount }}'
      attachmentState: '{{ item.attachmentState }}'
      attachmentType: '{{ item.attachmentType }}'
      stateChangeError: '{{ item.stateChangeError }}'
- discovery_id: aws.directconnect.describeDirectConnectGateways
  calls:
  - action: describeDirectConnectGateways
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.directConnectGateways }}'
    item:
      directConnectGatewayId: '{{ item.directConnectGatewayId }}'
      directConnectGatewayName: '{{ item.directConnectGatewayName }}'
      amazonSideAsn: '{{ item.amazonSideAsn }}'
      ownerAccount: '{{ item.ownerAccount }}'
      directConnectGatewayState: '{{ item.directConnectGatewayState }}'
      stateChangeError: '{{ item.stateChangeError }}'
      tags: '{{ item.tags }}'
- discovery_id: aws.directconnect.describeInterconnects
  calls:
  - action: describeInterconnects
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.interconnects }}'
    item:
      interconnectId: '{{ item.interconnectId }}'
      interconnectName: '{{ item.interconnectName }}'
      interconnectState: '{{ item.interconnectState }}'
      region: '{{ item.region }}'
      location: '{{ item.location }}'
      bandwidth: '{{ item.bandwidth }}'
      loaIssueTime: '{{ item.loaIssueTime }}'
      lagId: '{{ item.lagId }}'
      awsDevice: '{{ item.awsDevice }}'
      jumboFrameCapable: '{{ item.jumboFrameCapable }}'
      awsDeviceV2: '{{ item.awsDeviceV2 }}'
      awsLogicalDeviceId: '{{ item.awsLogicalDeviceId }}'
      hasLogicalRedundancy: '{{ item.hasLogicalRedundancy }}'
      tags: '{{ item.tags }}'
      providerName: '{{ item.providerName }}'
      macSecCapable: '{{ item.macSecCapable }}'
      portEncryptionStatus: '{{ item.portEncryptionStatus }}'
      encryptionMode: '{{ item.encryptionMode }}'
      macSecKeys: '{{ item.macSecKeys }}'
- discovery_id: aws.directconnect.describeLags
  calls:
  - action: describeLags
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.lags }}'
    item:
      connectionsBandwidth: '{{ item.connectionsBandwidth }}'
      numberOfConnections: '{{ item.numberOfConnections }}'
      lagId: '{{ item.lagId }}'
      ownerAccount: '{{ item.ownerAccount }}'
      lagName: '{{ item.lagName }}'
      lagState: '{{ item.lagState }}'
      location: '{{ item.location }}'
      region: '{{ item.region }}'
      minimumLinks: '{{ item.minimumLinks }}'
      awsDevice: '{{ item.awsDevice }}'
      awsDeviceV2: '{{ item.awsDeviceV2 }}'
      awsLogicalDeviceId: '{{ item.awsLogicalDeviceId }}'
      connections: '{{ item.connections }}'
      allowsHostedConnections: '{{ item.allowsHostedConnections }}'
      jumboFrameCapable: '{{ item.jumboFrameCapable }}'
      hasLogicalRedundancy: '{{ item.hasLogicalRedundancy }}'
      tags: '{{ item.tags }}'
      providerName: '{{ item.providerName }}'
      macSecCapable: '{{ item.macSecCapable }}'
      encryptionMode: '{{ item.encryptionMode }}'
      macSecKeys: '{{ item.macSecKeys }}'
- discovery_id: aws.directconnect.describeLocations
  calls:
  - action: describeLocations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.locations }}'
    item:
      locationCode: '{{ item.locationCode }}'
      locationName: '{{ item.locationName }}'
      region: '{{ item.region }}'
      availablePortSpeeds: '{{ item.availablePortSpeeds }}'
      availableProviders: '{{ item.availableProviders }}'
      availableMacSecPortSpeeds: '{{ item.availableMacSecPortSpeeds }}'
- discovery_id: aws.directconnect.describeVirtualGateways
  calls:
  - action: describeVirtualGateways
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.virtualGateways }}'
    item:
      virtualGatewayId: '{{ item.virtualGatewayId }}'
      virtualGatewayState: '{{ item.virtualGatewayState }}'
- discovery_id: aws.directconnect.describeVirtualInterfaces
  calls:
  - action: describeVirtualInterfaces
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.virtualInterfaces }}'
    item:
      ownerAccount: '{{ item.ownerAccount }}'
      virtualInterfaceId: '{{ item.virtualInterfaceId }}'
      location: '{{ item.location }}'
      connectionId: '{{ item.connectionId }}'
      virtualInterfaceType: '{{ item.virtualInterfaceType }}'
      virtualInterfaceName: '{{ item.virtualInterfaceName }}'
      vlan: '{{ item.vlan }}'
      asn: '{{ item.asn }}'
      asnLong: '{{ item.asnLong }}'
      amazonSideAsn: '{{ item.amazonSideAsn }}'
      authKey: '{{ item.authKey }}'
      amazonAddress: '{{ item.amazonAddress }}'
      customerAddress: '{{ item.customerAddress }}'
      addressFamily: '{{ item.addressFamily }}'
      virtualInterfaceState: '{{ item.virtualInterfaceState }}'
      customerRouterConfig: '{{ item.customerRouterConfig }}'
      mtu: '{{ item.mtu }}'
      jumboFrameCapable: '{{ item.jumboFrameCapable }}'
      virtualGatewayId: '{{ item.virtualGatewayId }}'
      directConnectGatewayId: '{{ item.directConnectGatewayId }}'
      routeFilterPrefixes: '{{ item.routeFilterPrefixes }}'
      bgpPeers: '{{ item.bgpPeers }}'
      region: '{{ item.region }}'
      awsDeviceV2: '{{ item.awsDeviceV2 }}'
      awsLogicalDeviceId: '{{ item.awsLogicalDeviceId }}'
      tags: '{{ item.tags }}'
      siteLinkEnabled: '{{ item.siteLinkEnabled }}'
- discovery_id: aws.directconnect.listVirtualInterfaceTestHistory
  calls:
  - action: listVirtualInterfaceTestHistory
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.virtualInterfaceTestHistory }}'
    item:
      testId: '{{ item.testId }}'
      virtualInterfaceId: '{{ item.virtualInterfaceId }}'
      bgpPeers: '{{ item.bgpPeers }}'
      status: '{{ item.status }}'
      ownerAccount: '{{ item.ownerAccount }}'
      testDurationInMinutes: '{{ item.testDurationInMinutes }}'
      startTime: '{{ item.startTime }}'
      endTime: '{{ item.endTime }}'
- discovery_id: aws.directconnect.describeConnectionLoa
  calls:
  - action: describeConnectionLoa
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.loa }}'
    item:
      loaContent: '{{ item.loaContent }}'
      loaContentType: '{{ item.loaContentType }}'
- discovery_id: aws.directconnect.describeConnectionsOnInterconnect
  calls:
  - action: describeConnectionsOnInterconnect
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.connections }}'
    item:
      ownerAccount: '{{ item.ownerAccount }}'
      connectionId: '{{ item.connectionId }}'
      connectionName: '{{ item.connectionName }}'
      connectionState: '{{ item.connectionState }}'
      region: '{{ item.region }}'
      location: '{{ item.location }}'
      bandwidth: '{{ item.bandwidth }}'
      vlan: '{{ item.vlan }}'
      partnerName: '{{ item.partnerName }}'
      loaIssueTime: '{{ item.loaIssueTime }}'
      lagId: '{{ item.lagId }}'
      awsDevice: '{{ item.awsDevice }}'
      jumboFrameCapable: '{{ item.jumboFrameCapable }}'
      awsDeviceV2: '{{ item.awsDeviceV2 }}'
      awsLogicalDeviceId: '{{ item.awsLogicalDeviceId }}'
      hasLogicalRedundancy: '{{ item.hasLogicalRedundancy }}'
      tags: '{{ item.tags }}'
      providerName: '{{ item.providerName }}'
      macSecCapable: '{{ item.macSecCapable }}'
      portEncryptionStatus: '{{ item.portEncryptionStatus }}'
      encryptionMode: '{{ item.encryptionMode }}'
      macSecKeys: '{{ item.macSecKeys }}'
      partnerInterconnectMacSecCapable: '{{ item.partnerInterconnectMacSecCapable
        }}'
- discovery_id: aws.directconnect.describeHostedConnections
  calls:
  - action: describeHostedConnections
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.connections }}'
    item:
      ownerAccount: '{{ item.ownerAccount }}'
      connectionId: '{{ item.connectionId }}'
      connectionName: '{{ item.connectionName }}'
      connectionState: '{{ item.connectionState }}'
      region: '{{ item.region }}'
      location: '{{ item.location }}'
      bandwidth: '{{ item.bandwidth }}'
      vlan: '{{ item.vlan }}'
      partnerName: '{{ item.partnerName }}'
      loaIssueTime: '{{ item.loaIssueTime }}'
      lagId: '{{ item.lagId }}'
      awsDevice: '{{ item.awsDevice }}'
      jumboFrameCapable: '{{ item.jumboFrameCapable }}'
      awsDeviceV2: '{{ item.awsDeviceV2 }}'
      awsLogicalDeviceId: '{{ item.awsLogicalDeviceId }}'
      hasLogicalRedundancy: '{{ item.hasLogicalRedundancy }}'
      tags: '{{ item.tags }}'
      providerName: '{{ item.providerName }}'
      macSecCapable: '{{ item.macSecCapable }}'
      portEncryptionStatus: '{{ item.portEncryptionStatus }}'
      encryptionMode: '{{ item.encryptionMode }}'
      macSecKeys: '{{ item.macSecKeys }}'
      partnerInterconnectMacSecCapable: '{{ item.partnerInterconnectMacSecCapable
        }}'
- discovery_id: aws.directconnect.describeInterconnectLoa
  calls:
  - action: describeInterconnectLoa
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.loa }}'
    item:
      loaContent: '{{ item.loaContent }}'
      loaContentType: '{{ item.loaContentType }}'
- discovery_id: aws.directconnect.describeLoa
  calls:
  - action: describeLoa
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.loaContent }}'
- discovery_id: aws.directconnect.describeRouterConfiguration
  calls:
  - action: describeRouterConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.router }}'
    item:
      vendor: '{{ item.vendor }}'
      platform: '{{ item.platform }}'
      software: '{{ item.software }}'
      xsltTemplateName: '{{ item.xsltTemplateName }}'
      xsltTemplateNameForMacSec: '{{ item.xsltTemplateNameForMacSec }}'
      routerTypeIdentifier: '{{ item.routerTypeIdentifier }}'
- discovery_id: aws.directconnect.describeTags
  calls:
  - action: describeTags
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.resourceTags }}'
    item:
      resourceArn: '{{ item.resourceArn }}'
      tags: '{{ item.tags }}'
checks: []
