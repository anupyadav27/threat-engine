version: '1.0'
provider: alicloud
service: arms
services:
  client: arms
  module: aliyunsdkarms
discovery:
- discovery_id: alicloud.arms.DescribeContactGroups
  calls:
  - action: DescribeContactGroups
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response }}'
- discovery_id: alicloud.arms.DescribeContacts
  calls:
  - action: DescribeContacts
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response }}'
- discovery_id: alicloud.arms.DescribeAddonRelease
  calls:
  - action: DescribeAddonRelease
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response }}'
- discovery_id: alicloud.arms.DescribeDispatchRule
  calls:
  - action: DescribeDispatchRule
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response }}'
checks: []
