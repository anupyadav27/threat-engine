{
  "apiserver": {
    "resource": "apiserver",
    "api_version": "v1",
    "kind": "Apiserver",
    "description": "apiserver security view \u2014 aggregated from k8s API",
    "independent": [
      {
        "operation": "list_component_status",
        "http_method": "GET",
        "description": "List apiserver resources via list_component_status",
        "item_fields": {
          "metadata.name": {
            "type": "string",
            "description": "Component name",
            "compliance_category": "identity",
            "security_impact": null,
            "enum": false,
            "possible_values": null
          },
          "conditions": {
            "type": "array",
            "description": "Component health conditions",
            "compliance_category": "security",
            "security_impact": "Unhealthy components indicate cluster control-plane degradation",
            "enum": false,
            "possible_values": null
          },
          "conditions[].type": {
            "type": "string",
            "description": "Condition type",
            "compliance_category": "security",
            "security_impact": null,
            "enum": true,
            "possible_values": [
              "Healthy"
            ]
          },
          "conditions[].status": {
            "type": "string",
            "description": "Condition status",
            "compliance_category": "security",
            "security_impact": null,
            "enum": true,
            "possible_values": [
              "True",
              "False",
              "Unknown"
            ]
          },
          "conditions[].message": {
            "type": "string",
            "description": "Condition message",
            "compliance_category": "general",
            "security_impact": null,
            "enum": false,
            "possible_values": null
          }
        }
      },
      {
        "operation": "list_api_service",
        "http_method": "GET",
        "description": "List apiserver resources via list_api_service",
        "item_fields": {
          "metadata.name": {
            "type": "string",
            "description": "APIService name",
            "compliance_category": "identity",
            "security_impact": null,
            "enum": false,
            "possible_values": null
          },
          "spec.service": {
            "type": "object",
            "description": "Service reference",
            "compliance_category": "network",
            "security_impact": null,
            "enum": false,
            "possible_values": null
          },
          "spec.insecureSkipTLSVerify": {
            "type": "boolean",
            "description": "Skip TLS verification",
            "compliance_category": "security",
            "security_impact": "Skipping TLS verification allows MITM attacks on API aggregation",
            "enum": false,
            "possible_values": null
          },
          "spec.groupPriorityMinimum": {
            "type": "integer",
            "description": "Group priority minimum",
            "compliance_category": "general",
            "security_impact": null,
            "enum": false,
            "possible_values": null
          },
          "spec.versionPriority": {
            "type": "integer",
            "description": "Version priority",
            "compliance_category": "general",
            "security_impact": null,
            "enum": false,
            "possible_values": null
          },
          "status.conditions": {
            "type": "array",
            "description": "APIService availability conditions",
            "compliance_category": "security",
            "security_impact": null,
            "enum": false,
            "possible_values": null
          }
        }
      }
    ],
    "dependent": []
  }
}