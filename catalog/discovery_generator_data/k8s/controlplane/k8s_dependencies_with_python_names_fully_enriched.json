{
  "controlplane": {
    "resource": "controlplane",
    "api_version": "v1",
    "kind": "Controlplane",
    "description": "controlplane security view \u2014 aggregated from k8s API",
    "independent": [
      {
        "operation": "list_component_status",
        "http_method": "GET",
        "description": "List controlplane resources via list_component_status",
        "item_fields": {
          "metadata.name": {
            "type": "string",
            "description": "Component name",
            "compliance_category": "identity",
            "security_impact": null,
            "enum": false,
            "possible_values": null
          },
          "conditions": {
            "type": "array",
            "description": "Component health conditions",
            "compliance_category": "security",
            "security_impact": "Unhealthy components indicate cluster control-plane degradation",
            "enum": false,
            "possible_values": null
          },
          "conditions[].type": {
            "type": "string",
            "description": "Condition type",
            "compliance_category": "security",
            "security_impact": null,
            "enum": true,
            "possible_values": [
              "Healthy"
            ]
          },
          "conditions[].status": {
            "type": "string",
            "description": "Condition status",
            "compliance_category": "security",
            "security_impact": null,
            "enum": true,
            "possible_values": [
              "True",
              "False",
              "Unknown"
            ]
          },
          "conditions[].message": {
            "type": "string",
            "description": "Condition message",
            "compliance_category": "general",
            "security_impact": null,
            "enum": false,
            "possible_values": null
          }
        }
      }
    ],
    "dependent": []
  }
}