{
  "job": {
    "resource": "job",
    "api_version": "batch/v1",
    "kind": "Job",
    "description": "Job resource \u2014 runs a batch task to completion",
    "independent": [
      {
        "operation": "list",
        "http_method": "GET",
        "description": "List all Jobs across all namespaces",
        "item_fields": {
          "metadata.name": {
            "type": "string",
            "description": "Job name",
            "compliance_category": "identity",
            "security_impact": null,
            "enum": false,
            "possible_values": null
          },
          "metadata.namespace": {
            "type": "string",
            "description": "Namespace",
            "compliance_category": "identity",
            "security_impact": null,
            "enum": false,
            "possible_values": null
          },
          "spec.template.spec.securityContext.runAsNonRoot": {
            "type": "boolean",
            "description": "Force non-root execution",
            "compliance_category": "security",
            "security_impact": "Root jobs can write to host volumes and modify system files",
            "enum": false,
            "possible_values": null
          },
          "spec.template.spec.securityContext.runAsUser": {
            "type": "integer",
            "description": "UID to run as",
            "compliance_category": "security",
            "security_impact": null,
            "enum": false,
            "possible_values": null
          },
          "spec.template.spec.hostNetwork": {
            "type": "boolean",
            "description": "Use host network namespace",
            "compliance_category": "security",
            "security_impact": "Host network exposes node traffic",
            "enum": false,
            "possible_values": null
          },
          "spec.template.spec.hostPID": {
            "type": "boolean",
            "description": "Share host PID namespace",
            "compliance_category": "security",
            "security_impact": "Host PID allows node process inspection",
            "enum": false,
            "possible_values": null
          },
          "spec.template.spec.hostIPC": {
            "type": "boolean",
            "description": "Share host IPC namespace",
            "compliance_category": "security",
            "security_impact": null,
            "enum": false,
            "possible_values": null
          },
          "spec.template.spec.containers": {
            "type": "array",
            "description": "Container list",
            "compliance_category": "security",
            "security_impact": "Each container should have security context defined",
            "enum": false,
            "possible_values": null
          },
          "spec.template.spec.resources.limits": {
            "type": "object",
            "description": "CPU/memory limits",
            "compliance_category": "security",
            "security_impact": "Unbounded jobs can exhaust node resources",
            "enum": false,
            "possible_values": null
          }
        }
      }
    ],
    "dependent": []
  }
}