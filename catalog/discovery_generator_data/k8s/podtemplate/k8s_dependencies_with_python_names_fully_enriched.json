{
  "podtemplate": {
    "resource": "podtemplate",
    "api_version": "v1",
    "kind": "PodTemplate",
    "description": "PodTemplate resource \u2014 reusable pod spec template",
    "independent": [
      {
        "operation": "list",
        "http_method": "GET",
        "description": "List all PodTemplates across all namespaces",
        "item_fields": {
          "metadata.name": {
            "type": "string",
            "description": "PodTemplate name",
            "compliance_category": "identity",
            "security_impact": null,
            "enum": false,
            "possible_values": null
          },
          "metadata.namespace": {
            "type": "string",
            "description": "Namespace",
            "compliance_category": "identity",
            "security_impact": null,
            "enum": false,
            "possible_values": null
          },
          "template.spec.securityContext.runAsNonRoot": {
            "type": "boolean",
            "description": "Force non-root for all pods from this template",
            "compliance_category": "security",
            "security_impact": "Security defaults in templates propagate to all instantiated pods",
            "enum": false,
            "possible_values": null
          },
          "template.spec.securityContext.runAsUser": {
            "type": "integer",
            "description": "UID to run as",
            "compliance_category": "security",
            "security_impact": null,
            "enum": false,
            "possible_values": null
          },
          "template.spec.hostNetwork": {
            "type": "boolean",
            "description": "Use host network namespace",
            "compliance_category": "security",
            "security_impact": "Host network in template affects every pod created from it",
            "enum": false,
            "possible_values": null
          },
          "template.spec.hostPID": {
            "type": "boolean",
            "description": "Share host PID namespace",
            "compliance_category": "security",
            "security_impact": null,
            "enum": false,
            "possible_values": null
          },
          "template.spec.hostIPC": {
            "type": "boolean",
            "description": "Share host IPC namespace",
            "compliance_category": "security",
            "security_impact": null,
            "enum": false,
            "possible_values": null
          },
          "template.spec.containers": {
            "type": "array",
            "description": "Container list",
            "compliance_category": "security",
            "security_impact": "Template containers should have full security context",
            "enum": false,
            "possible_values": null
          },
          "template.spec.resources.limits": {
            "type": "object",
            "description": "CPU/memory limits",
            "compliance_category": "security",
            "security_impact": "Resource limits in template enforce bounds on all pods",
            "enum": false,
            "possible_values": null
          }
        }
      }
    ],
    "dependent": []
  }
}