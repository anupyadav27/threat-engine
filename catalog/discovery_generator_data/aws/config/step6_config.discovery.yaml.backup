version: '1.0'
provider: aws
service: config
services:
  client: config
  module: boto3.client
discovery:
- discovery_id: aws.config.describeAggregationAuthorizations
  calls:
  - action: describeAggregationAuthorizations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AggregationAuthorizations }}'
    item:
      AggregationAuthorizationArn: '{{ item.AggregationAuthorizationArn }}'
      AuthorizedAccountId: '{{ item.AuthorizedAccountId }}'
      AuthorizedAwsRegion: '{{ item.AuthorizedAwsRegion }}'
      CreationTime: '{{ item.CreationTime }}'
- discovery_id: aws.config.describeComplianceByConfigRule
  calls:
  - action: describeComplianceByConfigRule
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ComplianceByConfigRules }}'
    item:
      ConfigRuleName: '{{ item.ConfigRuleName }}'
      Compliance: '{{ item.Compliance }}'
- discovery_id: aws.config.describeComplianceByResource
  calls:
  - action: describeComplianceByResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ComplianceByResources }}'
    item:
      ResourceType: '{{ item.ResourceType }}'
      ResourceId: '{{ item.ResourceId }}'
      Compliance: '{{ item.Compliance }}'
- discovery_id: aws.config.describeConfigRuleEvaluationStatus
  calls:
  - action: describeConfigRuleEvaluationStatus
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ConfigRulesEvaluationStatus }}'
    item:
      ConfigRuleName: '{{ item.ConfigRuleName }}'
      ConfigRuleArn: '{{ item.ConfigRuleArn }}'
      ConfigRuleId: '{{ item.ConfigRuleId }}'
      LastSuccessfulInvocationTime: '{{ item.LastSuccessfulInvocationTime }}'
      LastFailedInvocationTime: '{{ item.LastFailedInvocationTime }}'
      LastSuccessfulEvaluationTime: '{{ item.LastSuccessfulEvaluationTime }}'
      LastFailedEvaluationTime: '{{ item.LastFailedEvaluationTime }}'
      FirstActivatedTime: '{{ item.FirstActivatedTime }}'
      LastDeactivatedTime: '{{ item.LastDeactivatedTime }}'
      LastErrorCode: '{{ item.LastErrorCode }}'
      LastErrorMessage: '{{ item.LastErrorMessage }}'
      FirstEvaluationStarted: '{{ item.FirstEvaluationStarted }}'
      LastDebugLogDeliveryStatus: '{{ item.LastDebugLogDeliveryStatus }}'
      LastDebugLogDeliveryStatusReason: '{{ item.LastDebugLogDeliveryStatusReason
        }}'
      LastDebugLogDeliveryTime: '{{ item.LastDebugLogDeliveryTime }}'
- discovery_id: aws.config.describeConfigRules
  calls:
  - action: describeConfigRules
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ConfigRules }}'
    item:
      ConfigRuleName: '{{ item.ConfigRuleName }}'
      ConfigRuleArn: '{{ item.ConfigRuleArn }}'
      ConfigRuleId: '{{ item.ConfigRuleId }}'
      Description: '{{ item.Description }}'
      Scope: '{{ item.Scope }}'
      Source: '{{ item.Source }}'
      InputParameters: '{{ item.InputParameters }}'
      MaximumExecutionFrequency: '{{ item.MaximumExecutionFrequency }}'
      ConfigRuleState: '{{ item.ConfigRuleState }}'
      CreatedBy: '{{ item.CreatedBy }}'
      EvaluationModes: '{{ item.EvaluationModes }}'
- discovery_id: aws.config.describeConfigurationAggregators
  calls:
  - action: describeConfigurationAggregators
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ConfigurationAggregators }}'
    item:
      ConfigurationAggregatorName: '{{ item.ConfigurationAggregatorName }}'
      ConfigurationAggregatorArn: '{{ item.ConfigurationAggregatorArn }}'
      AccountAggregationSources: '{{ item.AccountAggregationSources }}'
      OrganizationAggregationSource: '{{ item.OrganizationAggregationSource }}'
      CreationTime: '{{ item.CreationTime }}'
      LastUpdatedTime: '{{ item.LastUpdatedTime }}'
      CreatedBy: '{{ item.CreatedBy }}'
      AggregatorFilters: '{{ item.AggregatorFilters }}'
- discovery_id: aws.config.describeConfigurationRecorderStatus
  calls:
  - action: describeConfigurationRecorderStatus
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ConfigurationRecordersStatus }}'
    item:
      arn: '{{ item.arn }}'
      name: '{{ item.name }}'
      lastStartTime: '{{ item.lastStartTime }}'
      lastStopTime: '{{ item.lastStopTime }}'
      recording: '{{ item.recording }}'
      lastStatus: '{{ item.lastStatus }}'
      lastErrorCode: '{{ item.lastErrorCode }}'
      lastErrorMessage: '{{ item.lastErrorMessage }}'
      lastStatusChangeTime: '{{ item.lastStatusChangeTime }}'
      servicePrincipal: '{{ item.servicePrincipal }}'
- discovery_id: aws.config.describeConfigurationRecorders
  calls:
  - action: describeConfigurationRecorders
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ConfigurationRecorders }}'
    item:
      arn: '{{ item.arn }}'
      name: '{{ item.name }}'
      roleARN: '{{ item.roleARN }}'
      recordingGroup: '{{ item.recordingGroup }}'
      recordingMode: '{{ item.recordingMode }}'
      recordingScope: '{{ item.recordingScope }}'
      servicePrincipal: '{{ item.servicePrincipal }}'
- discovery_id: aws.config.describeConformancePackStatus
  calls:
  - action: describeConformancePackStatus
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ConformancePackStatusDetails }}'
    item:
      ConformancePackName: '{{ item.ConformancePackName }}'
      ConformancePackId: '{{ item.ConformancePackId }}'
      ConformancePackArn: '{{ item.ConformancePackArn }}'
      ConformancePackState: '{{ item.ConformancePackState }}'
      StackArn: '{{ item.StackArn }}'
      ConformancePackStatusReason: '{{ item.ConformancePackStatusReason }}'
      LastUpdateRequestedTime: '{{ item.LastUpdateRequestedTime }}'
      LastUpdateCompletedTime: '{{ item.LastUpdateCompletedTime }}'
- discovery_id: aws.config.describeConformancePacks
  calls:
  - action: describeConformancePacks
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ConformancePackDetails }}'
    item:
      ConformancePackName: '{{ item.ConformancePackName }}'
      ConformancePackArn: '{{ item.ConformancePackArn }}'
      ConformancePackId: '{{ item.ConformancePackId }}'
      DeliveryS3Bucket: '{{ item.DeliveryS3Bucket }}'
      DeliveryS3KeyPrefix: '{{ item.DeliveryS3KeyPrefix }}'
      ConformancePackInputParameters: '{{ item.ConformancePackInputParameters }}'
      LastUpdateRequestedTime: '{{ item.LastUpdateRequestedTime }}'
      CreatedBy: '{{ item.CreatedBy }}'
      TemplateSSMDocumentDetails: '{{ item.TemplateSSMDocumentDetails }}'
- discovery_id: aws.config.describeDeliveryChannelStatus
  calls:
  - action: describeDeliveryChannelStatus
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.DeliveryChannelsStatus }}'
    item:
      name: '{{ item.name }}'
      configSnapshotDeliveryInfo: '{{ item.configSnapshotDeliveryInfo }}'
      configHistoryDeliveryInfo: '{{ item.configHistoryDeliveryInfo }}'
      configStreamDeliveryInfo: '{{ item.configStreamDeliveryInfo }}'
- discovery_id: aws.config.describeDeliveryChannels
  calls:
  - action: describeDeliveryChannels
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.DeliveryChannels }}'
    item:
      name: '{{ item.name }}'
      s3BucketName: '{{ item.s3BucketName }}'
      s3KeyPrefix: '{{ item.s3KeyPrefix }}'
      s3KmsKeyArn: '{{ item.s3KmsKeyArn }}'
      snsTopicARN: '{{ item.snsTopicARN }}'
      configSnapshotDeliveryProperties: '{{ item.configSnapshotDeliveryProperties
        }}'
- discovery_id: aws.config.describeOrganizationConfigRuleStatuses
  calls:
  - action: describeOrganizationConfigRuleStatuses
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.OrganizationConfigRuleStatuses }}'
    item:
      OrganizationConfigRuleName: '{{ item.OrganizationConfigRuleName }}'
      OrganizationRuleStatus: '{{ item.OrganizationRuleStatus }}'
      ErrorCode: '{{ item.ErrorCode }}'
      ErrorMessage: '{{ item.ErrorMessage }}'
      LastUpdateTime: '{{ item.LastUpdateTime }}'
- discovery_id: aws.config.describeOrganizationConfigRules
  calls:
  - action: describeOrganizationConfigRules
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.OrganizationConfigRules }}'
    item:
      OrganizationConfigRuleName: '{{ item.OrganizationConfigRuleName }}'
      OrganizationConfigRuleArn: '{{ item.OrganizationConfigRuleArn }}'
      OrganizationManagedRuleMetadata: '{{ item.OrganizationManagedRuleMetadata }}'
      OrganizationCustomRuleMetadata: '{{ item.OrganizationCustomRuleMetadata }}'
      ExcludedAccounts: '{{ item.ExcludedAccounts }}'
      LastUpdateTime: '{{ item.LastUpdateTime }}'
      OrganizationCustomPolicyRuleMetadata: '{{ item.OrganizationCustomPolicyRuleMetadata
        }}'
- discovery_id: aws.config.describeOrganizationConformancePackStatuses
  calls:
  - action: describeOrganizationConformancePackStatuses
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.OrganizationConformancePackStatuses }}'
    item:
      OrganizationConformancePackName: '{{ item.OrganizationConformancePackName }}'
      Status: '{{ item.Status }}'
      ErrorCode: '{{ item.ErrorCode }}'
      ErrorMessage: '{{ item.ErrorMessage }}'
      LastUpdateTime: '{{ item.LastUpdateTime }}'
- discovery_id: aws.config.describeOrganizationConformancePacks
  calls:
  - action: describeOrganizationConformancePacks
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.OrganizationConformancePacks }}'
    item:
      OrganizationConformancePackName: '{{ item.OrganizationConformancePackName }}'
      OrganizationConformancePackArn: '{{ item.OrganizationConformancePackArn }}'
      DeliveryS3Bucket: '{{ item.DeliveryS3Bucket }}'
      DeliveryS3KeyPrefix: '{{ item.DeliveryS3KeyPrefix }}'
      ConformancePackInputParameters: '{{ item.ConformancePackInputParameters }}'
      ExcludedAccounts: '{{ item.ExcludedAccounts }}'
      LastUpdateTime: '{{ item.LastUpdateTime }}'
- discovery_id: aws.config.describePendingAggregationRequests
  calls:
  - action: describePendingAggregationRequests
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.PendingAggregationRequests }}'
    item:
      RequesterAccountId: '{{ item.RequesterAccountId }}'
      RequesterAwsRegion: '{{ item.RequesterAwsRegion }}'
- discovery_id: aws.config.describeRetentionConfigurations
  calls:
  - action: describeRetentionConfigurations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.RetentionConfigurations }}'
    item:
      Name: '{{ item.Name }}'
      RetentionPeriodInDays: '{{ item.RetentionPeriodInDays }}'
- discovery_id: aws.config.getComplianceDetailsByResource
  calls:
  - action: getComplianceDetailsByResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.EvaluationResults }}'
    item:
      EvaluationResultIdentifier: '{{ item.EvaluationResultIdentifier }}'
      ComplianceType: '{{ item.ComplianceType }}'
      ResultRecordedTime: '{{ item.ResultRecordedTime }}'
      ConfigRuleInvokedTime: '{{ item.ConfigRuleInvokedTime }}'
      Annotation: '{{ item.Annotation }}'
      ResultToken: '{{ item.ResultToken }}'
- discovery_id: aws.config.getComplianceSummaryByConfigRule
  calls:
  - action: getComplianceSummaryByConfigRule
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ComplianceSummary }}'
    item:
      CompliantResourceCount: '{{ item.CompliantResourceCount }}'
      NonCompliantResourceCount: '{{ item.NonCompliantResourceCount }}'
      ComplianceSummaryTimestamp: '{{ item.ComplianceSummaryTimestamp }}'
- discovery_id: aws.config.getComplianceSummaryByResourceType
  calls:
  - action: getComplianceSummaryByResourceType
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ComplianceSummariesByResourceType }}'
    item:
      ResourceType: '{{ item.ResourceType }}'
      ComplianceSummary: '{{ item.ComplianceSummary }}'
- discovery_id: aws.config.getCustomRulePolicy
  calls:
  - action: getCustomRulePolicy
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.PolicyText }}'
- discovery_id: aws.config.getDiscoveredResourceCounts
  calls:
  - action: getDiscoveredResourceCounts
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.resourceCounts }}'
    item:
      resourceType: '{{ item.resourceType }}'
      count: '{{ item.count }}'
- discovery_id: aws.config.listConfigurationRecorders
  calls:
  - action: listConfigurationRecorders
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.ConfigurationRecorderSummaries }}'
    item:
      arn: '{{ item.arn }}'
      name: '{{ item.name }}'
      servicePrincipal: '{{ item.servicePrincipal }}'
      recordingScope: '{{ item.recordingScope }}'
- discovery_id: aws.config.listConformancePackComplianceScores
  calls:
  - action: listConformancePackComplianceScores
    save_as: response
    on_error: continue
    params:
      Limit: 1000
  emit:
    as: item
    items_for: '{{ response.ConformancePackComplianceScores }}'
    item:
      Score: '{{ item.Score }}'
      ConformancePackName: '{{ item.ConformancePackName }}'
      LastUpdatedTime: '{{ item.LastUpdatedTime }}'
- discovery_id: aws.config.listResourceEvaluations
  calls:
  - action: listResourceEvaluations
    save_as: response
    on_error: continue
    params:
      Limit: 1000
  emit:
    as: item
    items_for: '{{ response.ResourceEvaluations }}'
    item:
      ResourceEvaluationId: '{{ item.ResourceEvaluationId }}'
      EvaluationMode: '{{ item.EvaluationMode }}'
      EvaluationStartTimestamp: '{{ item.EvaluationStartTimestamp }}'
- discovery_id: aws.config.listStoredQueries
  calls:
  - action: listStoredQueries
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.StoredQueryMetadata }}'
    item:
      QueryId: '{{ item.QueryId }}'
      QueryArn: '{{ item.QueryArn }}'
      QueryName: '{{ item.QueryName }}'
      Description: '{{ item.Description }}'
- discovery_id: aws.config.describeAggregateComplianceByConfigRules
  calls:
  - action: describeAggregateComplianceByConfigRules
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AggregateComplianceByConfigRules }}'
    item:
      ConfigRuleName: '{{ item.ConfigRuleName }}'
      Compliance: '{{ item.Compliance }}'
      AccountId: '{{ item.AccountId }}'
      AwsRegion: '{{ item.AwsRegion }}'
- discovery_id: aws.config.describeAggregateComplianceByConformancePacks
  calls:
  - action: describeAggregateComplianceByConformancePacks
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AggregateComplianceByConformancePacks }}'
