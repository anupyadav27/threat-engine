      resourceType: '{{ item.resourceType }}'
      resourceId: '{{ item.resourceId }}'
      resourceName: '{{ item.resourceName }}'
      awsRegion: '{{ item.awsRegion }}'
      availabilityZone: '{{ item.availabilityZone }}'
      resourceCreationTime: '{{ item.resourceCreationTime }}'
      tags: '{{ item.tags }}'
      relatedEvents: '{{ item.relatedEvents }}'
      relationships: '{{ item.relationships }}'
      configuration: '{{ item.configuration }}'
      supplementaryConfiguration: '{{ item.supplementaryConfiguration }}'
      recordingFrequency: '{{ item.recordingFrequency }}'
      configurationItemDeliveryTime: '{{ item.configurationItemDeliveryTime }}'
- discovery_id: aws.config.getComplianceDetailsByConfigRule
  calls:
  - action: getComplianceDetailsByConfigRule
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.EvaluationResults }}'
    item:
