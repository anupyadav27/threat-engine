    items_for: '{{ response.configurationItems }}'
    item:
      version: '{{ item.version }}'
      accountId: '{{ item.accountId }}'
      configurationItemCaptureTime: '{{ item.configurationItemCaptureTime }}'
      configurationItemStatus: '{{ item.configurationItemStatus }}'
      configurationStateId: '{{ item.configurationStateId }}'
      configurationItemMD5Hash: '{{ item.configurationItemMD5Hash }}'
      arn: '{{ item.arn }}'
      resourceType: '{{ item.resourceType }}'
      resourceId: '{{ item.resourceId }}'
      resourceName: '{{ item.resourceName }}'
      awsRegion: '{{ item.awsRegion }}'
      availabilityZone: '{{ item.availabilityZone }}'
      resourceCreationTime: '{{ item.resourceCreationTime }}'
      tags: '{{ item.tags }}'
      relatedEvents: '{{ item.relatedEvents }}'
      relationships: '{{ item.relationships }}'
      configuration: '{{ item.configuration }}'
      supplementaryConfiguration: '{{ item.supplementaryConfiguration }}'
      recordingFrequency: '{{ item.recordingFrequency }}'
      configurationItemDeliveryTime: '{{ item.configurationItemDeliveryTime }}'
- discovery_id: aws.config.getResourceEvaluationSummary
  calls:
  - action: getResourceEvaluationSummary
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.EvaluationStatus }}'
    item:
      Status: '{{ item.Status }}'
      FailureReason: '{{ item.FailureReason }}'
- discovery_id: aws.config.getStoredQuery
  calls:
  - action: getStoredQuery
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.StoredQuery }}'
    item:
      QueryId: '{{ item.QueryId }}'
      QueryArn: '{{ item.QueryArn }}'
      QueryName: '{{ item.QueryName }}'
      Description: '{{ item.Description }}'
      Expression: '{{ item.Expression }}'
- discovery_id: aws.config.listAggregateDiscoveredResources
  calls:
  - action: listAggregateDiscoveredResources
    save_as: response
    on_error: continue
    params:
      Limit: 1000
  emit:
    as: item
    items_for: '{{ response.ResourceIdentifiers }}'
    item:
      SourceAccountId: '{{ item.SourceAccountId }}'
      SourceRegion: '{{ item.SourceRegion }}'
      ResourceId: '{{ item.ResourceId }}'
      ResourceType: '{{ item.ResourceType }}'
      ResourceName: '{{ item.ResourceName }}'
- discovery_id: aws.config.listDiscoveredResources
  calls:
  - action: listDiscoveredResources
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.resourceIdentifiers }}'
    item:
      resourceType: '{{ item.resourceType }}'
      resourceId: '{{ item.resourceId }}'
      resourceName: '{{ item.resourceName }}'
      resourceDeletionTime: '{{ item.resourceDeletionTime }}'
- discovery_id: aws.config.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
    params:
      Limit: 1000
  emit:
    as: item
    items_for: '{{ response.Tags }}'
    item:
      Key: '{{ item.Key }}'
      Value: '{{ item.Value }}'
checks: []
