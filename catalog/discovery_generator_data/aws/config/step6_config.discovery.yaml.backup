- discovery_id: aws.config.getConformancePackComplianceSummary
  calls:
  - action: getConformancePackComplianceSummary
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ConformancePackComplianceSummaryList }}'
