    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.OrganizationConfigRuleDetailedStatus }}'
    item:
      AccountId: '{{ item.AccountId }}'
      ConfigRuleName: '{{ item.ConfigRuleName }}'
      MemberAccountRuleStatus: '{{ item.MemberAccountRuleStatus }}'
      ErrorCode: '{{ item.ErrorCode }}'
      ErrorMessage: '{{ item.ErrorMessage }}'
      LastUpdateTime: '{{ item.LastUpdateTime }}'
- discovery_id: aws.config.getOrganizationConformancePackDetailedStatus
  calls:
  - action: getOrganizationConformancePackDetailedStatus
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.OrganizationConformancePackDetailedStatuses }}'
    item:
      AccountId: '{{ item.AccountId }}'
      ConformancePackName: '{{ item.ConformancePackName }}'
      Status: '{{ item.Status }}'
      ErrorCode: '{{ item.ErrorCode }}'
