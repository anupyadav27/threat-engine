    items_for: '{{ response.AggregatedSourceStatusList }}'
    item:
      SourceId: '{{ item.SourceId }}'
      SourceType: '{{ item.SourceType }}'
      AwsRegion: '{{ item.AwsRegion }}'
      LastUpdateStatus: '{{ item.LastUpdateStatus }}'
      LastUpdateTime: '{{ item.LastUpdateTime }}'
      LastErrorCode: '{{ item.LastErrorCode }}'
      LastErrorMessage: '{{ item.LastErrorMessage }}'
- discovery_id: aws.config.describeConformancePackCompliance
  calls:
  - action: describeConformancePackCompliance
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ConformancePackRuleComplianceList }}'
    item:
      ConfigRuleName: '{{ item.ConfigRuleName }}'
      ComplianceType: '{{ item.ComplianceType }}'
      Controls: '{{ item.Controls }}'
- discovery_id: aws.config.describeRemediationConfigurations
  calls:
  - action: describeRemediationConfigurations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.RemediationConfigurations }}'
    item:
      ConfigRuleName: '{{ item.ConfigRuleName }}'
      TargetType: '{{ item.TargetType }}'
      TargetId: '{{ item.TargetId }}'
      TargetVersion: '{{ item.TargetVersion }}'
      Parameters: '{{ item.Parameters }}'
      ResourceType: '{{ item.ResourceType }}'
      Automatic: '{{ item.Automatic }}'
      ExecutionControls: '{{ item.ExecutionControls }}'
      MaximumAutomaticAttempts: '{{ item.MaximumAutomaticAttempts }}'
      RetryAttemptSeconds: '{{ item.RetryAttemptSeconds }}'
      Arn: '{{ item.Arn }}'
      CreatedByService: '{{ item.CreatedByService }}'
- discovery_id: aws.config.describeRemediationExceptions
  calls:
  - action: describeRemediationExceptions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.RemediationExceptions }}'
    item:
