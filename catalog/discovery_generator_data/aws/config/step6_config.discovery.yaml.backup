      LastUpdatedTime: '{{ item.LastUpdatedTime }}'
- discovery_id: aws.config.getAggregateComplianceDetailsByConfigRule
  calls:
  - action: getAggregateComplianceDetailsByConfigRule
    save_as: response
    on_error: continue
  emit:
