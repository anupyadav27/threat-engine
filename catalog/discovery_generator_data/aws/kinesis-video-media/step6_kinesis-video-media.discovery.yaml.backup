version: '1.0'
provider: aws
service: kinesis-video-media
services:
  client: kinesis-video-media
  module: boto3.client
discovery:
- discovery_id: aws.kinesis-video-media.getMedia
  calls:
  - action: getMedia
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ContentType }}'
checks: []
