version: '1.0'
provider: aws
service: securitylake
services:
  client: securitylake
  module: boto3.client
discovery:
- discovery_id: aws.securitylake.getDataLakeExceptionSubscription
  calls:
  - action: getDataLakeExceptionSubscription
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.exceptionTimeToLive }}'
- discovery_id: aws.securitylake.getDataLakeOrganizationConfiguration
  calls:
  - action: getDataLakeOrganizationConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.autoEnableNewAccount }}'
    item:
      region: '{{ item.region }}'
      sources: '{{ item.sources }}'
- discovery_id: aws.securitylake.getDataLakeSources
  calls:
  - action: getDataLakeSources
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.dataLakeSources }}'
    item:
      account: '{{ item.account }}'
      eventClasses: '{{ item.eventClasses }}'
      sourceName: '{{ item.sourceName }}'
      sourceStatuses: '{{ item.sourceStatuses }}'
- discovery_id: aws.securitylake.listDataLakeExceptions
  calls:
  - action: listDataLakeExceptions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.exceptions }}'
    item:
      exception: '{{ item.exception }}'
      region: '{{ item.region }}'
      remediation: '{{ item.remediation }}'
      timestamp: '{{ item.timestamp }}'
- discovery_id: aws.securitylake.listDataLakes
  calls:
  - action: listDataLakes
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.dataLakes }}'
    item:
      createStatus: '{{ item.createStatus }}'
      dataLakeArn: '{{ item.dataLakeArn }}'
      encryptionConfiguration: '{{ item.encryptionConfiguration }}'
      lifecycleConfiguration: '{{ item.lifecycleConfiguration }}'
      region: '{{ item.region }}'
      replicationConfiguration: '{{ item.replicationConfiguration }}'
      s3BucketArn: '{{ item.s3BucketArn }}'
      updateStatus: '{{ item.updateStatus }}'
- discovery_id: aws.securitylake.listLogSources
  calls:
  - action: listLogSources
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.sources }}'
    item:
      account: '{{ item.account }}'
      region: '{{ item.region }}'
      sources: '{{ item.sources }}'
- discovery_id: aws.securitylake.listSubscribers
  calls:
  - action: listSubscribers
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.subscribers }}'
    item:
      accessTypes: '{{ item.accessTypes }}'
      createdAt: '{{ item.createdAt }}'
      resourceShareArn: '{{ item.resourceShareArn }}'
      resourceShareName: '{{ item.resourceShareName }}'
      roleArn: '{{ item.roleArn }}'
      s3BucketArn: '{{ item.s3BucketArn }}'
      sources: '{{ item.sources }}'
      subscriberArn: '{{ item.subscriberArn }}'
      subscriberDescription: '{{ item.subscriberDescription }}'
      subscriberEndpoint: '{{ item.subscriberEndpoint }}'
      subscriberId: '{{ item.subscriberId }}'
      subscriberIdentity: '{{ item.subscriberIdentity }}'
      subscriberName: '{{ item.subscriberName }}'
      subscriberStatus: '{{ item.subscriberStatus }}'
      updatedAt: '{{ item.updatedAt }}'
- discovery_id: aws.securitylake.getSubscriber
  calls:
  - action: getSubscriber
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.subscriber }}'
    item:
      accessTypes: '{{ item.accessTypes }}'
      createdAt: '{{ item.createdAt }}'
      resourceShareArn: '{{ item.resourceShareArn }}'
      resourceShareName: '{{ item.resourceShareName }}'
      roleArn: '{{ item.roleArn }}'
      s3BucketArn: '{{ item.s3BucketArn }}'
      sources: '{{ item.sources }}'
      subscriberArn: '{{ item.subscriberArn }}'
      subscriberDescription: '{{ item.subscriberDescription }}'
      subscriberEndpoint: '{{ item.subscriberEndpoint }}'
      subscriberId: '{{ item.subscriberId }}'
      subscriberIdentity: '{{ item.subscriberIdentity }}'
      subscriberName: '{{ item.subscriberName }}'
      subscriberStatus: '{{ item.subscriberStatus }}'
      updatedAt: '{{ item.updatedAt }}'
- discovery_id: aws.securitylake.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tags }}'
    item:
      key: '{{ item.key }}'
      value: '{{ item.value }}'
checks: []
