version: '1.0'
provider: aws
service: route53-recovery-control-config
services:
  client: route53-recovery-control-config
  module: boto3.client
discovery:
- discovery_id: aws.route53-recovery-control-config.listClusters
  calls:
  - action: listClusters
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Clusters }}'
    item:
      ClusterArn: '{{ item.ClusterArn }}'
      ClusterEndpoints: '{{ item.ClusterEndpoints }}'
      Name: '{{ item.Name }}'
      Status: '{{ item.Status }}'
      Owner: '{{ item.Owner }}'
      NetworkType: '{{ item.NetworkType }}'
- discovery_id: aws.route53-recovery-control-config.listControlPanels
  calls:
  - action: listControlPanels
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.ControlPanels }}'
    item:
      ClusterArn: '{{ item.ClusterArn }}'
      ControlPanelArn: '{{ item.ControlPanelArn }}'
      DefaultControlPanel: '{{ item.DefaultControlPanel }}'
      Name: '{{ item.Name }}'
      RoutingControlCount: '{{ item.RoutingControlCount }}'
      Status: '{{ item.Status }}'
      Owner: '{{ item.Owner }}'
- discovery_id: aws.route53-recovery-control-config.describeCluster
  calls:
  - action: describeCluster
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Cluster }}'
    item:
      ClusterArn: '{{ item.ClusterArn }}'
      ClusterEndpoints: '{{ item.ClusterEndpoints }}'
      Name: '{{ item.Name }}'
      Status: '{{ item.Status }}'
      Owner: '{{ item.Owner }}'
      NetworkType: '{{ item.NetworkType }}'
- discovery_id: aws.route53-recovery-control-config.describeControlPanel
  calls:
  - action: describeControlPanel
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ControlPanel }}'
    item:
      ClusterArn: '{{ item.ClusterArn }}'
      ControlPanelArn: '{{ item.ControlPanelArn }}'
      DefaultControlPanel: '{{ item.DefaultControlPanel }}'
      Name: '{{ item.Name }}'
      RoutingControlCount: '{{ item.RoutingControlCount }}'
      Status: '{{ item.Status }}'
      Owner: '{{ item.Owner }}'
- discovery_id: aws.route53-recovery-control-config.describeRoutingControl
  calls:
  - action: describeRoutingControl
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.RoutingControl }}'
    item:
      ControlPanelArn: '{{ item.ControlPanelArn }}'
      Name: '{{ item.Name }}'
      RoutingControlArn: '{{ item.RoutingControlArn }}'
      Status: '{{ item.Status }}'
      Owner: '{{ item.Owner }}'
- discovery_id: aws.route53-recovery-control-config.describeSafetyRule
  calls:
  - action: describeSafetyRule
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AssertionRule }}'
    item:
      AssertedControls: '{{ item.AssertedControls }}'
      ControlPanelArn: '{{ item.ControlPanelArn }}'
      Name: '{{ item.Name }}'
      RuleConfig: '{{ item.RuleConfig }}'
      SafetyRuleArn: '{{ item.SafetyRuleArn }}'
      Status: '{{ item.Status }}'
      WaitPeriodMs: '{{ item.WaitPeriodMs }}'
      Owner: '{{ item.Owner }}'
- discovery_id: aws.route53-recovery-control-config.getResourcePolicy
  calls:
  - action: getResourcePolicy
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Policy }}'
- discovery_id: aws.route53-recovery-control-config.listAssociatedRoute53HealthChecks
  calls:
  - action: listAssociatedRoute53HealthChecks
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.HealthCheckIds }}'
- discovery_id: aws.route53-recovery-control-config.listRoutingControls
  calls:
  - action: listRoutingControls
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.RoutingControls }}'
    item:
      ControlPanelArn: '{{ item.ControlPanelArn }}'
      Name: '{{ item.Name }}'
      RoutingControlArn: '{{ item.RoutingControlArn }}'
      Status: '{{ item.Status }}'
      Owner: '{{ item.Owner }}'
- discovery_id: aws.route53-recovery-control-config.listSafetyRules
  calls:
  - action: listSafetyRules
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.SafetyRules }}'
    item:
      ASSERTION: '{{ item.ASSERTION }}'
      GATING: '{{ item.GATING }}'
- discovery_id: aws.route53-recovery-control-config.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Tags }}'
checks: []
