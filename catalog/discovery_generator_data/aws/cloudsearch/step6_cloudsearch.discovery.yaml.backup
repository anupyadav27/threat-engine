version: '1.0'
provider: aws
service: cloudsearch
services:
  client: cloudsearch
  module: boto3.client
discovery:
- discovery_id: aws.cloudsearch.describeDomains
  calls:
  - action: describeDomains
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.DomainStatusList }}'
    item:
      DomainId: '{{ item.DomainId }}'
      DomainName: '{{ item.DomainName }}'
      ARN: '{{ item.ARN }}'
      Created: '{{ item.Created }}'
      Deleted: '{{ item.Deleted }}'
      DocService: '{{ item.DocService }}'
      SearchService: '{{ item.SearchService }}'
      RequiresIndexDocuments: '{{ item.RequiresIndexDocuments }}'
      Processing: '{{ item.Processing }}'
      SearchInstanceType: '{{ item.SearchInstanceType }}'
      SearchPartitionCount: '{{ item.SearchPartitionCount }}'
      SearchInstanceCount: '{{ item.SearchInstanceCount }}'
      Limits: '{{ item.Limits }}'
- discovery_id: aws.cloudsearch.listDomainNames
  calls:
  - action: listDomainNames
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.DomainNames }}'
- discovery_id: aws.cloudsearch.describeAnalysisSchemes
  calls:
  - action: describeAnalysisSchemes
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AnalysisSchemes }}'
    item:
      Options: '{{ item.Options }}'
      Status: '{{ item.Status }}'
- discovery_id: aws.cloudsearch.describeAvailabilityOptions
  calls:
  - action: describeAvailabilityOptions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AvailabilityOptions }}'
    item:
      Options: '{{ item.Options }}'
      Status: '{{ item.Status }}'
- discovery_id: aws.cloudsearch.describeDomainEndpointOptions
  calls:
  - action: describeDomainEndpointOptions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.DomainEndpointOptions }}'
    item:
      Options: '{{ item.Options }}'
      Status: '{{ item.Status }}'
- discovery_id: aws.cloudsearch.describeExpressions
  calls:
  - action: describeExpressions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Expressions }}'
    item:
      Options: '{{ item.Options }}'
      Status: '{{ item.Status }}'
- discovery_id: aws.cloudsearch.describeIndexFields
  calls:
  - action: describeIndexFields
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.IndexFields }}'
    item:
      Options: '{{ item.Options }}'
      Status: '{{ item.Status }}'
- discovery_id: aws.cloudsearch.describeScalingParameters
  calls:
  - action: describeScalingParameters
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ScalingParameters }}'
    item:
      Options: '{{ item.Options }}'
      Status: '{{ item.Status }}'
- discovery_id: aws.cloudsearch.describeServiceAccessPolicies
  calls:
  - action: describeServiceAccessPolicies
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AccessPolicies }}'
    item:
      Options: '{{ item.Options }}'
      Status: '{{ item.Status }}'
- discovery_id: aws.cloudsearch.describeSuggesters
  calls:
  - action: describeSuggesters
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Suggesters }}'
    item:
      Options: '{{ item.Options }}'
      Status: '{{ item.Status }}'
checks: []
