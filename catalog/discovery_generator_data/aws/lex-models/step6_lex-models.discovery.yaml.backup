version: '1.0'
provider: aws
service: lex-models
services:
  client: lex-models
  module: boto3.client
discovery:
- discovery_id: aws.lex-models.getBots
  calls:
  - action: getBots
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.bots }}'
    item:
      name: '{{ item.name }}'
      description: '{{ item.description }}'
      status: '{{ item.status }}'
      lastUpdatedDate: '{{ item.lastUpdatedDate }}'
      createdDate: '{{ item.createdDate }}'
      version: '{{ item.version }}'
- discovery_id: aws.lex-models.getBuiltinIntents
  calls:
  - action: getBuiltinIntents
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.intents }}'
    item:
      signature: '{{ item.signature }}'
      supportedLocales: '{{ item.supportedLocales }}'
- discovery_id: aws.lex-models.getBuiltinSlotTypes
  calls:
  - action: getBuiltinSlotTypes
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.slotTypes }}'
    item:
      signature: '{{ item.signature }}'
      supportedLocales: '{{ item.supportedLocales }}'
- discovery_id: aws.lex-models.getIntents
  calls:
  - action: getIntents
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.intents }}'
    item:
      name: '{{ item.name }}'
      description: '{{ item.description }}'
      lastUpdatedDate: '{{ item.lastUpdatedDate }}'
      createdDate: '{{ item.createdDate }}'
      version: '{{ item.version }}'
- discovery_id: aws.lex-models.getMigrations
  calls:
  - action: getMigrations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.migrationSummaries }}'
    item:
      migrationId: '{{ item.migrationId }}'
      v1BotName: '{{ item.v1BotName }}'
      v1BotVersion: '{{ item.v1BotVersion }}'
      v1BotLocale: '{{ item.v1BotLocale }}'
      v2BotId: '{{ item.v2BotId }}'
      v2BotRole: '{{ item.v2BotRole }}'
      migrationStatus: '{{ item.migrationStatus }}'
      migrationStrategy: '{{ item.migrationStrategy }}'
      migrationTimestamp: '{{ item.migrationTimestamp }}'
- discovery_id: aws.lex-models.getSlotTypes
  calls:
  - action: getSlotTypes
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.slotTypes }}'
    item:
      name: '{{ item.name }}'
      description: '{{ item.description }}'
      lastUpdatedDate: '{{ item.lastUpdatedDate }}'
      createdDate: '{{ item.createdDate }}'
      version: '{{ item.version }}'
- discovery_id: aws.lex-models.getBot
  calls:
  - action: getBot
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.intents }}'
    item:
      intentName: '{{ item.intentName }}'
      intentVersion: '{{ item.intentVersion }}'
- discovery_id: aws.lex-models.getBotAlias
  calls:
  - action: getBotAlias
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.conversationLogs }}'
    item:
      logSettings: '{{ item.logSettings }}'
      iamRoleArn: '{{ item.iamRoleArn }}'
- discovery_id: aws.lex-models.getBotAliases
  calls:
  - action: getBotAliases
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.BotAliases }}'
    item:
      name: '{{ item.name }}'
      description: '{{ item.description }}'
      botVersion: '{{ item.botVersion }}'
      botName: '{{ item.botName }}'
      lastUpdatedDate: '{{ item.lastUpdatedDate }}'
      createdDate: '{{ item.createdDate }}'
      checksum: '{{ item.checksum }}'
      conversationLogs: '{{ item.conversationLogs }}'
- discovery_id: aws.lex-models.getBotChannelAssociation
  calls:
  - action: getBotChannelAssociation
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.name }}'
- discovery_id: aws.lex-models.getBotChannelAssociations
  calls:
  - action: getBotChannelAssociations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.botChannelAssociations }}'
    item:
      name: '{{ item.name }}'
      description: '{{ item.description }}'
      botAlias: '{{ item.botAlias }}'
      botName: '{{ item.botName }}'
      createdDate: '{{ item.createdDate }}'
      type: '{{ item.type }}'
      botConfiguration: '{{ item.botConfiguration }}'
      status: '{{ item.status }}'
      failureReason: '{{ item.failureReason }}'
- discovery_id: aws.lex-models.getBotVersions
  calls:
  - action: getBotVersions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.bots }}'
    item:
      name: '{{ item.name }}'
      description: '{{ item.description }}'
      status: '{{ item.status }}'
      lastUpdatedDate: '{{ item.lastUpdatedDate }}'
      createdDate: '{{ item.createdDate }}'
      version: '{{ item.version }}'
- discovery_id: aws.lex-models.getBuiltinIntent
  calls:
  - action: getBuiltinIntent
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.supportedLocales }}'
- discovery_id: aws.lex-models.getExport
  calls:
  - action: getExport
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.name }}'
- discovery_id: aws.lex-models.getImport
  calls:
  - action: getImport
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.failureReason }}'
- discovery_id: aws.lex-models.getIntent
  calls:
  - action: getIntent
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.slots }}'
    item:
      name: '{{ item.name }}'
      description: '{{ item.description }}'
      slotConstraint: '{{ item.slotConstraint }}'
      slotType: '{{ item.slotType }}'
      slotTypeVersion: '{{ item.slotTypeVersion }}'
      valueElicitationPrompt: '{{ item.valueElicitationPrompt }}'
      priority: '{{ item.priority }}'
      sampleUtterances: '{{ item.sampleUtterances }}'
      responseCard: '{{ item.responseCard }}'
      obfuscationSetting: '{{ item.obfuscationSetting }}'
      defaultValueSpec: '{{ item.defaultValueSpec }}'
- discovery_id: aws.lex-models.getIntentVersions
  calls:
  - action: getIntentVersions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.intents }}'
    item:
      name: '{{ item.name }}'
      description: '{{ item.description }}'
      lastUpdatedDate: '{{ item.lastUpdatedDate }}'
      createdDate: '{{ item.createdDate }}'
      version: '{{ item.version }}'
- discovery_id: aws.lex-models.getMigration
  calls:
  - action: getMigration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.alerts }}'
    item:
      type: '{{ item.type }}'
      message: '{{ item.message }}'
      details: '{{ item.details }}'
      referenceURLs: '{{ item.referenceURLs }}'
- discovery_id: aws.lex-models.getSlotType
  calls:
  - action: getSlotType
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.enumerationValues }}'
    item:
      value: '{{ item.value }}'
      synonyms: '{{ item.synonyms }}'
- discovery_id: aws.lex-models.getSlotTypeVersions
  calls:
  - action: getSlotTypeVersions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.slotTypes }}'
    item:
      name: '{{ item.name }}'
      description: '{{ item.description }}'
      lastUpdatedDate: '{{ item.lastUpdatedDate }}'
      createdDate: '{{ item.createdDate }}'
      version: '{{ item.version }}'
- discovery_id: aws.lex-models.getUtterancesView
  calls:
  - action: getUtterancesView
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.utterances }}'
    item:
      botVersion: '{{ item.botVersion }}'
      utterances: '{{ item.utterances }}'
- discovery_id: aws.lex-models.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tags }}'
    item:
      key: '{{ item.key }}'
      value: '{{ item.value }}'
checks: []
