version: '1.0'
provider: aws
service: s3control
services:
  client: s3control
  module: boto3.client
discovery:
- discovery_id: aws.s3control.describeJob
  calls:
  - action: describeJob
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Job }}'
    item:
      JobId: '{{ item.JobId }}'
      ConfirmationRequired: '{{ item.ConfirmationRequired }}'
      Description: '{{ item.Description }}'
      JobArn: '{{ item.JobArn }}'
      Status: '{{ item.Status }}'
      Manifest: '{{ item.Manifest }}'
      Operation: '{{ item.Operation }}'
      Priority: '{{ item.Priority }}'
      ProgressSummary: '{{ item.ProgressSummary }}'
      StatusUpdateReason: '{{ item.StatusUpdateReason }}'
      FailureReasons: '{{ item.FailureReasons }}'
      Report: '{{ item.Report }}'
      CreationTime: '{{ item.CreationTime }}'
      TerminationDate: '{{ item.TerminationDate }}'
      RoleArn: '{{ item.RoleArn }}'
      SuspendedDate: '{{ item.SuspendedDate }}'
      SuspendedCause: '{{ item.SuspendedCause }}'
      ManifestGenerator: '{{ item.ManifestGenerator }}'
      GeneratedManifestDescriptor: '{{ item.GeneratedManifestDescriptor }}'
- discovery_id: aws.s3control.describeMultiRegionAccessPointOperation
  calls:
  - action: describeMultiRegionAccessPointOperation
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AsyncOperation }}'
    item:
      CreationTime: '{{ item.CreationTime }}'
      Operation: '{{ item.Operation }}'
      RequestTokenARN: '{{ item.RequestTokenARN }}'
      RequestParameters: '{{ item.RequestParameters }}'
      RequestStatus: '{{ item.RequestStatus }}'
      ResponseDetails: '{{ item.ResponseDetails }}'
- discovery_id: aws.s3control.getAccessGrant
  calls:
  - action: getAccessGrant
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Grantee }}'
    item:
      GranteeType: '{{ item.GranteeType }}'
      GranteeIdentifier: '{{ item.GranteeIdentifier }}'
- discovery_id: aws.s3control.getAccessGrantsInstance
  calls:
  - action: getAccessGrantsInstance
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AccessGrantsInstanceArn }}'
- discovery_id: aws.s3control.getAccessGrantsInstanceForPrefix
  calls:
  - action: getAccessGrantsInstanceForPrefix
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AccessGrantsInstanceArn }}'
- discovery_id: aws.s3control.getAccessGrantsInstanceResourcePolicy
  calls:
  - action: getAccessGrantsInstanceResourcePolicy
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Policy }}'
- discovery_id: aws.s3control.getAccessGrantsLocation
  calls:
  - action: getAccessGrantsLocation
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.CreatedAt }}'
- discovery_id: aws.s3control.getAccessPoint
  calls:
  - action: getAccessPoint
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.VpcConfiguration }}'
    item:
      VpcId: '{{ item.VpcId }}'
- discovery_id: aws.s3control.getAccessPointConfigurationForObjectLambda
  calls:
  - action: getAccessPointConfigurationForObjectLambda
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Configuration }}'
    item:
      SupportingAccessPoint: '{{ item.SupportingAccessPoint }}'
      CloudWatchMetricsEnabled: '{{ item.CloudWatchMetricsEnabled }}'
      AllowedFeatures: '{{ item.AllowedFeatures }}'
      TransformationConfigurations: '{{ item.TransformationConfigurations }}'
- discovery_id: aws.s3control.getAccessPointForObjectLambda
  calls:
  - action: getAccessPointForObjectLambda
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.PublicAccessBlockConfiguration }}'
    item:
      BlockPublicAcls: '{{ item.BlockPublicAcls }}'
      IgnorePublicAcls: '{{ item.IgnorePublicAcls }}'
      BlockPublicPolicy: '{{ item.BlockPublicPolicy }}'
      RestrictPublicBuckets: '{{ item.RestrictPublicBuckets }}'
- discovery_id: aws.s3control.getAccessPointPolicy
  calls:
  - action: getAccessPointPolicy
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Policy }}'
- discovery_id: aws.s3control.getAccessPointPolicyForObjectLambda
  calls:
  - action: getAccessPointPolicyForObjectLambda
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Policy }}'
- discovery_id: aws.s3control.getAccessPointPolicyStatus
  calls:
  - action: getAccessPointPolicyStatus
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.PolicyStatus }}'
    item:
      IsPublic: '{{ item.IsPublic }}'
- discovery_id: aws.s3control.getAccessPointPolicyStatusForObjectLambda
  calls:
  - action: getAccessPointPolicyStatusForObjectLambda
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.PolicyStatus }}'
    item:
      IsPublic: '{{ item.IsPublic }}'
- discovery_id: aws.s3control.getAccessPointScope
  calls:
  - action: getAccessPointScope
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Scope }}'
    item:
      Prefixes: '{{ item.Prefixes }}'
      Permissions: '{{ item.Permissions }}'
- discovery_id: aws.s3control.getBucket
  calls:
  - action: getBucket
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Bucket }}'
- discovery_id: aws.s3control.getBucketLifecycleConfiguration
  calls:
  - action: getBucketLifecycleConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Rules }}'
    item:
      Expiration: '{{ item.Expiration }}'
      ID: '{{ item.ID }}'
      Filter: '{{ item.Filter }}'
      Status: '{{ item.Status }}'
      Transitions: '{{ item.Transitions }}'
      NoncurrentVersionTransitions: '{{ item.NoncurrentVersionTransitions }}'
      NoncurrentVersionExpiration: '{{ item.NoncurrentVersionExpiration }}'
      AbortIncompleteMultipartUpload: '{{ item.AbortIncompleteMultipartUpload }}'
- discovery_id: aws.s3control.getBucketPolicy
  calls:
  - action: getBucketPolicy
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Policy }}'
- discovery_id: aws.s3control.getBucketReplication
  calls:
  - action: getBucketReplication
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ReplicationConfiguration }}'
    item:
      Role: '{{ item.Role }}'
      Rules: '{{ item.Rules }}'
- discovery_id: aws.s3control.getBucketTagging
  calls:
  - action: getBucketTagging
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.TagSet }}'
    item:
      Key: '{{ item.Key }}'
      Value: '{{ item.Value }}'
- discovery_id: aws.s3control.getBucketVersioning
  calls:
  - action: getBucketVersioning
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Status }}'
- discovery_id: aws.s3control.getDataAccess
  calls:
  - action: getDataAccess
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Credentials }}'
    item:
      AccessKeyId: '{{ item.AccessKeyId }}'
      SecretAccessKey: '{{ item.SecretAccessKey }}'
      SessionToken: '{{ item.SessionToken }}'
      Expiration: '{{ item.Expiration }}'
- discovery_id: aws.s3control.getJobTagging
  calls:
  - action: getJobTagging
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Tags }}'
    item:
      Key: '{{ item.Key }}'
      Value: '{{ item.Value }}'
- discovery_id: aws.s3control.getMultiRegionAccessPoint
  calls:
  - action: getMultiRegionAccessPoint
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AccessPoint }}'
    item:
      Name: '{{ item.Name }}'
      Alias: '{{ item.Alias }}'
      CreatedAt: '{{ item.CreatedAt }}'
      PublicAccessBlock: '{{ item.PublicAccessBlock }}'
      Status: '{{ item.Status }}'
      Regions: '{{ item.Regions }}'
- discovery_id: aws.s3control.getMultiRegionAccessPointPolicy
  calls:
  - action: getMultiRegionAccessPointPolicy
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Policy }}'
    item:
      Established: '{{ item.Established }}'
      Proposed: '{{ item.Proposed }}'
- discovery_id: aws.s3control.getMultiRegionAccessPointPolicyStatus
  calls:
  - action: getMultiRegionAccessPointPolicyStatus
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Established }}'
    item:
      IsPublic: '{{ item.IsPublic }}'
- discovery_id: aws.s3control.getMultiRegionAccessPointRoutes
  calls:
  - action: getMultiRegionAccessPointRoutes
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Routes }}'
    item:
      Bucket: '{{ item.Bucket }}'
      Region: '{{ item.Region }}'
      TrafficDialPercentage: '{{ item.TrafficDialPercentage }}'
- discovery_id: aws.s3control.getPublicAccessBlock
  calls:
  - action: getPublicAccessBlock
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.PublicAccessBlockConfiguration }}'
    item:
      BlockPublicAcls: '{{ item.BlockPublicAcls }}'
      IgnorePublicAcls: '{{ item.IgnorePublicAcls }}'
      BlockPublicPolicy: '{{ item.BlockPublicPolicy }}'
      RestrictPublicBuckets: '{{ item.RestrictPublicBuckets }}'
- discovery_id: aws.s3control.getStorageLensConfiguration
  calls:
  - action: getStorageLensConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.StorageLensConfiguration }}'
    item:
      Id: '{{ item.Id }}'
      AccountLevel: '{{ item.AccountLevel }}'
      Include: '{{ item.Include }}'
      Exclude: '{{ item.Exclude }}'
      DataExport: '{{ item.DataExport }}'
      IsEnabled: '{{ item.IsEnabled }}'
      AwsOrg: '{{ item.AwsOrg }}'
      StorageLensArn: '{{ item.StorageLensArn }}'
- discovery_id: aws.s3control.getStorageLensConfigurationTagging
  calls:
  - action: getStorageLensConfigurationTagging
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Tags }}'
    item:
      Key: '{{ item.Key }}'
      Value: '{{ item.Value }}'
- discovery_id: aws.s3control.getStorageLensGroup
  calls:
  - action: getStorageLensGroup
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.StorageLensGroup }}'
    item:
      Name: '{{ item.Name }}'
      Filter: '{{ item.Filter }}'
      StorageLensGroupArn: '{{ item.StorageLensGroupArn }}'
- discovery_id: aws.s3control.listAccessGrants
  calls:
  - action: listAccessGrants
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.AccessGrantsList }}'
    item:
      CreatedAt: '{{ item.CreatedAt }}'
      AccessGrantId: '{{ item.AccessGrantId }}'
      AccessGrantArn: '{{ item.AccessGrantArn }}'
      Grantee: '{{ item.Grantee }}'
      Permission: '{{ item.Permission }}'
      AccessGrantsLocationId: '{{ item.AccessGrantsLocationId }}'
      AccessGrantsLocationConfiguration: '{{ item.AccessGrantsLocationConfiguration
        }}'
      GrantScope: '{{ item.GrantScope }}'
      ApplicationArn: '{{ item.ApplicationArn }}'
- discovery_id: aws.s3control.listAccessGrantsInstances
  calls:
  - action: listAccessGrantsInstances
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.AccessGrantsInstancesList }}'
    item:
      AccessGrantsInstanceId: '{{ item.AccessGrantsInstanceId }}'
      AccessGrantsInstanceArn: '{{ item.AccessGrantsInstanceArn }}'
      CreatedAt: '{{ item.CreatedAt }}'
      IdentityCenterArn: '{{ item.IdentityCenterArn }}'
      IdentityCenterInstanceArn: '{{ item.IdentityCenterInstanceArn }}'
      IdentityCenterApplicationArn: '{{ item.IdentityCenterApplicationArn }}'
- discovery_id: aws.s3control.listAccessGrantsLocations
  calls:
  - action: listAccessGrantsLocations
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.AccessGrantsLocationsList }}'
    item:
      CreatedAt: '{{ item.CreatedAt }}'
      AccessGrantsLocationId: '{{ item.AccessGrantsLocationId }}'
      AccessGrantsLocationArn: '{{ item.AccessGrantsLocationArn }}'
      LocationScope: '{{ item.LocationScope }}'
      IAMRoleArn: '{{ item.IAMRoleArn }}'
- discovery_id: aws.s3control.listAccessPoints
  calls:
  - action: listAccessPoints
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.AccessPointList }}'
    item:
      Name: '{{ item.Name }}'
      NetworkOrigin: '{{ item.NetworkOrigin }}'
      VpcConfiguration: '{{ item.VpcConfiguration }}'
      Bucket: '{{ item.Bucket }}'
      AccessPointArn: '{{ item.AccessPointArn }}'
      Alias: '{{ item.Alias }}'
      BucketAccountId: '{{ item.BucketAccountId }}'
      DataSourceId: '{{ item.DataSourceId }}'
      DataSourceType: '{{ item.DataSourceType }}'
- discovery_id: aws.s3control.listAccessPointsForDirectoryBuckets
  calls:
  - action: listAccessPointsForDirectoryBuckets
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.AccessPointList }}'
    item:
      Name: '{{ item.Name }}'
      NetworkOrigin: '{{ item.NetworkOrigin }}'
      VpcConfiguration: '{{ item.VpcConfiguration }}'
      Bucket: '{{ item.Bucket }}'
      AccessPointArn: '{{ item.AccessPointArn }}'
      Alias: '{{ item.Alias }}'
      BucketAccountId: '{{ item.BucketAccountId }}'
      DataSourceId: '{{ item.DataSourceId }}'
      DataSourceType: '{{ item.DataSourceType }}'
- discovery_id: aws.s3control.listAccessPointsForObjectLambda
  calls:
  - action: listAccessPointsForObjectLambda
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.ObjectLambdaAccessPointList }}'
    item:
      Name: '{{ item.Name }}'
      ObjectLambdaAccessPointArn: '{{ item.ObjectLambdaAccessPointArn }}'
      Alias: '{{ item.Alias }}'
- discovery_id: aws.s3control.listCallerAccessGrants
  calls:
  - action: listCallerAccessGrants
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.CallerAccessGrantsList }}'
    item:
      Permission: '{{ item.Permission }}'
      GrantScope: '{{ item.GrantScope }}'
      ApplicationArn: '{{ item.ApplicationArn }}'
- discovery_id: aws.s3control.listJobs
  calls:
  - action: listJobs
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Jobs }}'
    item:
      JobId: '{{ item.JobId }}'
      Description: '{{ item.Description }}'
      Operation: '{{ item.Operation }}'
      Priority: '{{ item.Priority }}'
      Status: '{{ item.Status }}'
      CreationTime: '{{ item.CreationTime }}'
      TerminationDate: '{{ item.TerminationDate }}'
      ProgressSummary: '{{ item.ProgressSummary }}'
- discovery_id: aws.s3control.listMultiRegionAccessPoints
  calls:
  - action: listMultiRegionAccessPoints
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.AccessPoints }}'
    item:
      Name: '{{ item.Name }}'
      Alias: '{{ item.Alias }}'
      CreatedAt: '{{ item.CreatedAt }}'
      PublicAccessBlock: '{{ item.PublicAccessBlock }}'
      Status: '{{ item.Status }}'
      Regions: '{{ item.Regions }}'
- discovery_id: aws.s3control.listRegionalBuckets
  calls:
  - action: listRegionalBuckets
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.RegionalBucketList }}'
    item:
      Bucket: '{{ item.Bucket }}'
      BucketArn: '{{ item.BucketArn }}'
      PublicAccessBlockEnabled: '{{ item.PublicAccessBlockEnabled }}'
      CreationDate: '{{ item.CreationDate }}'
      OutpostId: '{{ item.OutpostId }}'
- discovery_id: aws.s3control.listStorageLensConfigurations
  calls:
  - action: listStorageLensConfigurations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.StorageLensConfigurationList }}'
    item:
      Id: '{{ item.Id }}'
      StorageLensArn: '{{ item.StorageLensArn }}'
      HomeRegion: '{{ item.HomeRegion }}'
      IsEnabled: '{{ item.IsEnabled }}'
- discovery_id: aws.s3control.listStorageLensGroups
  calls:
  - action: listStorageLensGroups
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.StorageLensGroupList }}'
    item:
      Name: '{{ item.Name }}'
      StorageLensGroupArn: '{{ item.StorageLensGroupArn }}'
      HomeRegion: '{{ item.HomeRegion }}'
- discovery_id: aws.s3control.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Tags }}'
    item:
      Key: '{{ item.Key }}'
      Value: '{{ item.Value }}'
checks: []
