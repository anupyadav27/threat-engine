version: '1.0'
provider: aws
service: codebuild
services:
  client: codebuild
  module: boto3.client
discovery:
- discovery_id: aws.codebuild.listBuildBatches
  calls:
  - action: listBuildBatches
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ids }}'
- discovery_id: aws.codebuild.listBuildBatchesForProject
  calls:
  - action: listBuildBatchesForProject
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ids }}'
- discovery_id: aws.codebuild.listBuilds
  calls:
  - action: listBuilds
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ids }}'
- discovery_id: aws.codebuild.listCuratedEnvironmentImages
  calls:
  - action: listCuratedEnvironmentImages
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.platforms }}'
    item:
      platform: '{{ item.platform }}'
      languages: '{{ item.languages }}'
- discovery_id: aws.codebuild.listFleets
  calls:
  - action: listFleets
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.fleets }}'
- discovery_id: aws.codebuild.listProjects
  calls:
  - action: listProjects
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.projects }}'
- discovery_id: aws.codebuild.listReportGroups
  calls:
  - action: listReportGroups
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.reportGroups }}'
- discovery_id: aws.codebuild.listReports
  calls:
  - action: listReports
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.reports }}'
- discovery_id: aws.codebuild.listSandboxes
  calls:
  - action: listSandboxes
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ids }}'
- discovery_id: aws.codebuild.listSharedProjects
  calls:
  - action: listSharedProjects
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.projects }}'
- discovery_id: aws.codebuild.listSharedReportGroups
  calls:
  - action: listSharedReportGroups
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.reportGroups }}'
- discovery_id: aws.codebuild.listSourceCredentials
  calls:
  - action: listSourceCredentials
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.sourceCredentialsInfos }}'
    item:
      arn: '{{ item.arn }}'
      serverType: '{{ item.serverType }}'
      authType: '{{ item.authType }}'
      resource: '{{ item.resource }}'
- discovery_id: aws.codebuild.describeCodeCoverages
  calls:
  - action: describeCodeCoverages
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.codeCoverages }}'
    item:
      id: '{{ item.id }}'
      reportARN: '{{ item.reportARN }}'
      filePath: '{{ item.filePath }}'
      lineCoveragePercentage: '{{ item.lineCoveragePercentage }}'
      linesCovered: '{{ item.linesCovered }}'
      linesMissed: '{{ item.linesMissed }}'
      branchCoveragePercentage: '{{ item.branchCoveragePercentage }}'
      branchesCovered: '{{ item.branchesCovered }}'
      branchesMissed: '{{ item.branchesMissed }}'
      expired: '{{ item.expired }}'
- discovery_id: aws.codebuild.describeTestCases
  calls:
  - action: describeTestCases
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.testCases }}'
    item:
      reportArn: '{{ item.reportArn }}'
      testRawDataPath: '{{ item.testRawDataPath }}'
      prefix: '{{ item.prefix }}'
      name: '{{ item.name }}'
      status: '{{ item.status }}'
      durationInNanoSeconds: '{{ item.durationInNanoSeconds }}'
      message: '{{ item.message }}'
      expired: '{{ item.expired }}'
      testSuiteName: '{{ item.testSuiteName }}'
- discovery_id: aws.codebuild.getReportGroupTrend
  calls:
  - action: getReportGroupTrend
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.rawData }}'
    item:
      reportArn: '{{ item.reportArn }}'
      data: '{{ item.data }}'
- discovery_id: aws.codebuild.getResourcePolicy
  calls:
  - action: getResourcePolicy
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.policy }}'
- discovery_id: aws.codebuild.listBuildsForProject
  calls:
  - action: listBuildsForProject
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ids }}'
- discovery_id: aws.codebuild.listCommandExecutionsForSandbox
  calls:
  - action: listCommandExecutionsForSandbox
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.commandExecutions }}'
    item:
      id: '{{ item.id }}'
      sandboxId: '{{ item.sandboxId }}'
      submitTime: '{{ item.submitTime }}'
      startTime: '{{ item.startTime }}'
      endTime: '{{ item.endTime }}'
      status: '{{ item.status }}'
      command: '{{ item.command }}'
      type: '{{ item.type }}'
      exitCode: '{{ item.exitCode }}'
      standardOutputContent: '{{ item.standardOutputContent }}'
      standardErrContent: '{{ item.standardErrContent }}'
      logs: '{{ item.logs }}'
      sandboxArn: '{{ item.sandboxArn }}'
- discovery_id: aws.codebuild.listReportsForReportGroup
  calls:
  - action: listReportsForReportGroup
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.reports }}'
- discovery_id: aws.codebuild.listSandboxesForProject
  calls:
  - action: listSandboxesForProject
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ids }}'
checks: []
