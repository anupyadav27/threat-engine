        Replicas: '{{ response.TableAutoScalingDescription.Replicas }}'
        TableName: '{{ response.TableAutoScalingDescription.TableName }}'
        TableStatus: '{{ response.TableAutoScalingDescription.TableStatus }}'
    for_each: aws.dynamodb.list_backups
  - calls:
    - action: describe_global_table
