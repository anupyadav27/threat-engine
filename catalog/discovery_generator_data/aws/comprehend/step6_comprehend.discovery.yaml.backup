version: '1.0'
provider: aws
service: comprehend
services:
  client: comprehend
  module: boto3.client
discovery:
- discovery_id: aws.comprehend.listDatasets
  calls:
  - action: listDatasets
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.DatasetPropertiesList }}'
    item:
      DatasetArn: '{{ item.DatasetArn }}'
      DatasetName: '{{ item.DatasetName }}'
      DatasetType: '{{ item.DatasetType }}'
      DatasetS3Uri: '{{ item.DatasetS3Uri }}'
      Description: '{{ item.Description }}'
      Status: '{{ item.Status }}'
      Message: '{{ item.Message }}'
      NumberOfDocuments: '{{ item.NumberOfDocuments }}'
      CreationTime: '{{ item.CreationTime }}'
      EndTime: '{{ item.EndTime }}'
- discovery_id: aws.comprehend.listDocumentClassificationJobs
  calls:
  - action: listDocumentClassificationJobs
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.DocumentClassificationJobPropertiesList }}'
    item:
      JobId: '{{ item.JobId }}'
      JobArn: '{{ item.JobArn }}'
      JobName: '{{ item.JobName }}'
      JobStatus: '{{ item.JobStatus }}'
      Message: '{{ item.Message }}'
      SubmitTime: '{{ item.SubmitTime }}'
      EndTime: '{{ item.EndTime }}'
      DocumentClassifierArn: '{{ item.DocumentClassifierArn }}'
      InputDataConfig: '{{ item.InputDataConfig }}'
      OutputDataConfig: '{{ item.OutputDataConfig }}'
      DataAccessRoleArn: '{{ item.DataAccessRoleArn }}'
      VolumeKmsKeyId: '{{ item.VolumeKmsKeyId }}'
      VpcConfig: '{{ item.VpcConfig }}'
      FlywheelArn: '{{ item.FlywheelArn }}'
- discovery_id: aws.comprehend.listDocumentClassifierSummaries
  calls:
  - action: listDocumentClassifierSummaries
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.DocumentClassifierSummariesList }}'
    item:
      DocumentClassifierName: '{{ item.DocumentClassifierName }}'
      NumberOfVersions: '{{ item.NumberOfVersions }}'
      LatestVersionCreatedAt: '{{ item.LatestVersionCreatedAt }}'
      LatestVersionName: '{{ item.LatestVersionName }}'
      LatestVersionStatus: '{{ item.LatestVersionStatus }}'
- discovery_id: aws.comprehend.listDocumentClassifiers
  calls:
  - action: listDocumentClassifiers
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.DocumentClassifierPropertiesList }}'
    item:
      DocumentClassifierArn: '{{ item.DocumentClassifierArn }}'
      LanguageCode: '{{ item.LanguageCode }}'
      Status: '{{ item.Status }}'
      Message: '{{ item.Message }}'
      SubmitTime: '{{ item.SubmitTime }}'
      EndTime: '{{ item.EndTime }}'
      TrainingStartTime: '{{ item.TrainingStartTime }}'
      TrainingEndTime: '{{ item.TrainingEndTime }}'
      InputDataConfig: '{{ item.InputDataConfig }}'
      OutputDataConfig: '{{ item.OutputDataConfig }}'
      ClassifierMetadata: '{{ item.ClassifierMetadata }}'
      DataAccessRoleArn: '{{ item.DataAccessRoleArn }}'
      VolumeKmsKeyId: '{{ item.VolumeKmsKeyId }}'
      VpcConfig: '{{ item.VpcConfig }}'
      Mode: '{{ item.Mode }}'
      ModelKmsKeyId: '{{ item.ModelKmsKeyId }}'
      VersionName: '{{ item.VersionName }}'
      SourceModelArn: '{{ item.SourceModelArn }}'
      FlywheelArn: '{{ item.FlywheelArn }}'
