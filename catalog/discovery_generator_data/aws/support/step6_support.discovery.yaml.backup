version: '1.0'
provider: aws
service: support
services:
  client: support
  module: boto3.client
discovery:
- discovery_id: aws.support.describeCases
  calls:
  - action: describeCases
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.cases }}'
    item:
      caseId: '{{ item.caseId }}'
      displayId: '{{ item.displayId }}'
      subject: '{{ item.subject }}'
      status: '{{ item.status }}'
      serviceCode: '{{ item.serviceCode }}'
      categoryCode: '{{ item.categoryCode }}'
      severityCode: '{{ item.severityCode }}'
      submittedBy: '{{ item.submittedBy }}'
      timeCreated: '{{ item.timeCreated }}'
      recentCommunications: '{{ item.recentCommunications }}'
      ccEmailAddresses: '{{ item.ccEmailAddresses }}'
      language: '{{ item.language }}'
- discovery_id: aws.support.describeServices
  calls:
  - action: describeServices
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.services }}'
    item:
      code: '{{ item.code }}'
      name: '{{ item.name }}'
      categories: '{{ item.categories }}'
- discovery_id: aws.support.describeSeverityLevels
  calls:
  - action: describeSeverityLevels
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.severityLevels }}'
    item:
      code: '{{ item.code }}'
      name: '{{ item.name }}'
- discovery_id: aws.support.describeAttachment
  calls:
  - action: describeAttachment
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.attachment }}'
    item:
      fileName: '{{ item.fileName }}'
      data: '{{ item.data }}'
- discovery_id: aws.support.describeCommunications
  calls:
  - action: describeCommunications
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.communications }}'
    item:
      caseId: '{{ item.caseId }}'
      body: '{{ item.body }}'
      submittedBy: '{{ item.submittedBy }}'
      timeCreated: '{{ item.timeCreated }}'
      attachmentSet: '{{ item.attachmentSet }}'
- discovery_id: aws.support.describeCreateCaseOptions
  calls:
  - action: describeCreateCaseOptions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.communicationTypes }}'
    item:
      type: '{{ item.type }}'
      supportedHours: '{{ item.supportedHours }}'
      datesWithoutSupport: '{{ item.datesWithoutSupport }}'
- discovery_id: aws.support.describeSupportedLanguages
  calls:
  - action: describeSupportedLanguages
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.supportedLanguages }}'
    item:
      code: '{{ item.code }}'
      language: '{{ item.language }}'
      display: '{{ item.display }}'
- discovery_id: aws.support.describeTrustedAdvisorCheckRefreshStatuses
  calls:
  - action: describeTrustedAdvisorCheckRefreshStatuses
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.statuses }}'
    item:
      checkId: '{{ item.checkId }}'
      status: '{{ item.status }}'
      millisUntilNextRefreshable: '{{ item.millisUntilNextRefreshable }}'
- discovery_id: aws.support.describeTrustedAdvisorCheckResult
  calls:
  - action: describeTrustedAdvisorCheckResult
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.result }}'
    item:
      checkId: '{{ item.checkId }}'
      timestamp: '{{ item.timestamp }}'
      status: '{{ item.status }}'
      resourcesSummary: '{{ item.resourcesSummary }}'
      categorySpecificSummary: '{{ item.categorySpecificSummary }}'
      flaggedResources: '{{ item.flaggedResources }}'
- discovery_id: aws.support.describeTrustedAdvisorCheckSummaries
  calls:
  - action: describeTrustedAdvisorCheckSummaries
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.summaries }}'
    item:
      checkId: '{{ item.checkId }}'
      timestamp: '{{ item.timestamp }}'
      status: '{{ item.status }}'
      hasFlaggedResources: '{{ item.hasFlaggedResources }}'
      resourcesSummary: '{{ item.resourcesSummary }}'
      categorySpecificSummary: '{{ item.categorySpecificSummary }}'
- discovery_id: aws.support.describeTrustedAdvisorChecks
  calls:
  - action: describeTrustedAdvisorChecks
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.checks }}'
    item:
      id: '{{ item.id }}'
      name: '{{ item.name }}'
      description: '{{ item.description }}'
      category: '{{ item.category }}'
      metadata: '{{ item.metadata }}'
checks: []
