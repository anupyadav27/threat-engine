version: '1.0'
provider: aws
service: s3outposts
services:
  client: s3outposts
  module: boto3.client
discovery:
- discovery_id: aws.s3outposts.listEndpoints
  calls:
  - action: listEndpoints
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Endpoints }}'
    item:
      EndpointArn: '{{ item.EndpointArn }}'
      OutpostsId: '{{ item.OutpostsId }}'
      CidrBlock: '{{ item.CidrBlock }}'
      Status: '{{ item.Status }}'
      CreationTime: '{{ item.CreationTime }}'
      NetworkInterfaces: '{{ item.NetworkInterfaces }}'
      VpcId: '{{ item.VpcId }}'
      SubnetId: '{{ item.SubnetId }}'
      SecurityGroupId: '{{ item.SecurityGroupId }}'
      AccessType: '{{ item.AccessType }}'
      CustomerOwnedIpv4Pool: '{{ item.CustomerOwnedIpv4Pool }}'
      FailedReason: '{{ item.FailedReason }}'
- discovery_id: aws.s3outposts.listOutpostsWithS3
  calls:
  - action: listOutpostsWithS3
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Outposts }}'
    item:
      OutpostArn: '{{ item.OutpostArn }}'
      S3OutpostArn: '{{ item.S3OutpostArn }}'
      OutpostId: '{{ item.OutpostId }}'
      OwnerId: '{{ item.OwnerId }}'
      CapacityInBytes: '{{ item.CapacityInBytes }}'
- discovery_id: aws.s3outposts.listSharedEndpoints
  calls:
  - action: listSharedEndpoints
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Endpoints }}'
    item:
      EndpointArn: '{{ item.EndpointArn }}'
      OutpostsId: '{{ item.OutpostsId }}'
      CidrBlock: '{{ item.CidrBlock }}'
      Status: '{{ item.Status }}'
      CreationTime: '{{ item.CreationTime }}'
      NetworkInterfaces: '{{ item.NetworkInterfaces }}'
      VpcId: '{{ item.VpcId }}'
      SubnetId: '{{ item.SubnetId }}'
      SecurityGroupId: '{{ item.SecurityGroupId }}'
      AccessType: '{{ item.AccessType }}'
      CustomerOwnedIpv4Pool: '{{ item.CustomerOwnedIpv4Pool }}'
      FailedReason: '{{ item.FailedReason }}'
checks: []
