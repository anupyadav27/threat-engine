      completedAt: '{{ item.completedAt }}'
      componentName: '{{ item.componentName }}'
      createdAt: '{{ item.createdAt }}'
      deploymentStatus: '{{ item.deploymentStatus }}'
      deploymentStatusMessage: '{{ item.deploymentStatusMessage }}'
      environmentName: '{{ item.environmentName }}'
      id: '{{ item.id }}'
      initialState: '{{ item.initialState }}'
      lastAttemptedDeploymentId: '{{ item.lastAttemptedDeploymentId }}'
      lastModifiedAt: '{{ item.lastModifiedAt }}'
      lastSucceededDeploymentId: '{{ item.lastSucceededDeploymentId }}'
      serviceInstanceName: '{{ item.serviceInstanceName }}'
      serviceName: '{{ item.serviceName }}'
      targetArn: '{{ item.targetArn }}'
      targetResourceCreatedAt: '{{ item.targetResourceCreatedAt }}'
      targetResourceType: '{{ item.targetResourceType }}'
      targetState: '{{ item.targetState }}'
- discovery_id: aws.proton.getEnvironment
  calls:
