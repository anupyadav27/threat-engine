version: '1.0'
provider: aws
service: proton
services:
  client: proton
  module: boto3.client
discovery:
- discovery_id: aws.proton.getAccountSettings
  calls:
  - action: getAccountSettings
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.accountSettings }}'
    item:
      pipelineCodebuildRoleArn: '{{ item.pipelineCodebuildRoleArn }}'
      pipelineProvisioningRepository: '{{ item.pipelineProvisioningRepository }}'
      pipelineServiceRoleArn: '{{ item.pipelineServiceRoleArn }}'
- discovery_id: aws.proton.getResourcesSummary
  calls:
  - action: getResourcesSummary
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.counts }}'
    item:
      components: '{{ item.components }}'
      environmentTemplates: '{{ item.environmentTemplates }}'
      environments: '{{ item.environments }}'
      pipelines: '{{ item.pipelines }}'
      serviceInstances: '{{ item.serviceInstances }}'
      serviceTemplates: '{{ item.serviceTemplates }}'
      services: '{{ item.services }}'
- discovery_id: aws.proton.listComponents
  calls:
  - action: listComponents
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.components }}'
    item:
      arn: '{{ item.arn }}'
      createdAt: '{{ item.createdAt }}'
      deploymentStatus: '{{ item.deploymentStatus }}'
      deploymentStatusMessage: '{{ item.deploymentStatusMessage }}'
      environmentName: '{{ item.environmentName }}'
      lastAttemptedDeploymentId: '{{ item.lastAttemptedDeploymentId }}'
      lastDeploymentAttemptedAt: '{{ item.lastDeploymentAttemptedAt }}'
      lastDeploymentSucceededAt: '{{ item.lastDeploymentSucceededAt }}'
      lastModifiedAt: '{{ item.lastModifiedAt }}'
      lastSucceededDeploymentId: '{{ item.lastSucceededDeploymentId }}'
      name: '{{ item.name }}'
      serviceInstanceName: '{{ item.serviceInstanceName }}'
      serviceName: '{{ item.serviceName }}'
- discovery_id: aws.proton.listDeployments
  calls:
  - action: listDeployments
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.deployments }}'
    item:
      arn: '{{ item.arn }}'
      completedAt: '{{ item.completedAt }}'
      componentName: '{{ item.componentName }}'
      createdAt: '{{ item.createdAt }}'
      deploymentStatus: '{{ item.deploymentStatus }}'
      environmentName: '{{ item.environmentName }}'
      id: '{{ item.id }}'
      lastAttemptedDeploymentId: '{{ item.lastAttemptedDeploymentId }}'
      lastModifiedAt: '{{ item.lastModifiedAt }}'
      lastSucceededDeploymentId: '{{ item.lastSucceededDeploymentId }}'
      serviceInstanceName: '{{ item.serviceInstanceName }}'
      serviceName: '{{ item.serviceName }}'
      targetArn: '{{ item.targetArn }}'
      targetResourceCreatedAt: '{{ item.targetResourceCreatedAt }}'
      targetResourceType: '{{ item.targetResourceType }}'
- discovery_id: aws.proton.listEnvironmentTemplates
  calls:
  - action: listEnvironmentTemplates
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.templates }}'
    item:
      arn: '{{ item.arn }}'
      createdAt: '{{ item.createdAt }}'
      description: '{{ item.description }}'
      displayName: '{{ item.displayName }}'
      lastModifiedAt: '{{ item.lastModifiedAt }}'
      name: '{{ item.name }}'
      provisioning: '{{ item.provisioning }}'
      recommendedVersion: '{{ item.recommendedVersion }}'
- discovery_id: aws.proton.listEnvironments
  calls:
  - action: listEnvironments
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.environments }}'
    item:
      arn: '{{ item.arn }}'
      componentRoleArn: '{{ item.componentRoleArn }}'
      createdAt: '{{ item.createdAt }}'
      deploymentStatus: '{{ item.deploymentStatus }}'
      deploymentStatusMessage: '{{ item.deploymentStatusMessage }}'
      description: '{{ item.description }}'
      environmentAccountConnectionId: '{{ item.environmentAccountConnectionId }}'
      environmentAccountId: '{{ item.environmentAccountId }}'
      lastAttemptedDeploymentId: '{{ item.lastAttemptedDeploymentId }}'
      lastDeploymentAttemptedAt: '{{ item.lastDeploymentAttemptedAt }}'
      lastDeploymentSucceededAt: '{{ item.lastDeploymentSucceededAt }}'
      lastSucceededDeploymentId: '{{ item.lastSucceededDeploymentId }}'
      name: '{{ item.name }}'
      protonServiceRoleArn: '{{ item.protonServiceRoleArn }}'
      provisioning: '{{ item.provisioning }}'
      templateMajorVersion: '{{ item.templateMajorVersion }}'
      templateMinorVersion: '{{ item.templateMinorVersion }}'
      templateName: '{{ item.templateName }}'
- discovery_id: aws.proton.listRepositories
  calls:
  - action: listRepositories
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.repositories }}'
    item:
      arn: '{{ item.arn }}'
      connectionArn: '{{ item.connectionArn }}'
      name: '{{ item.name }}'
      provider: '{{ item.provider }}'
- discovery_id: aws.proton.listServiceInstances
  calls:
  - action: listServiceInstances
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.serviceInstances }}'
    item:
      arn: '{{ item.arn }}'
      createdAt: '{{ item.createdAt }}'
      deploymentStatus: '{{ item.deploymentStatus }}'
      deploymentStatusMessage: '{{ item.deploymentStatusMessage }}'
      environmentName: '{{ item.environmentName }}'
      lastAttemptedDeploymentId: '{{ item.lastAttemptedDeploymentId }}'
      lastDeploymentAttemptedAt: '{{ item.lastDeploymentAttemptedAt }}'
      lastDeploymentSucceededAt: '{{ item.lastDeploymentSucceededAt }}'
      lastSucceededDeploymentId: '{{ item.lastSucceededDeploymentId }}'
      name: '{{ item.name }}'
      serviceName: '{{ item.serviceName }}'
      templateMajorVersion: '{{ item.templateMajorVersion }}'
      templateMinorVersion: '{{ item.templateMinorVersion }}'
      templateName: '{{ item.templateName }}'
- discovery_id: aws.proton.listServiceTemplates
  calls:
  - action: listServiceTemplates
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.templates }}'
    item:
      arn: '{{ item.arn }}'
      createdAt: '{{ item.createdAt }}'
      description: '{{ item.description }}'
      displayName: '{{ item.displayName }}'
      lastModifiedAt: '{{ item.lastModifiedAt }}'
      name: '{{ item.name }}'
      pipelineProvisioning: '{{ item.pipelineProvisioning }}'
      recommendedVersion: '{{ item.recommendedVersion }}'
- discovery_id: aws.proton.listServices
  calls:
  - action: listServices
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.services }}'
    item:
      arn: '{{ item.arn }}'
      createdAt: '{{ item.createdAt }}'
      description: '{{ item.description }}'
      lastModifiedAt: '{{ item.lastModifiedAt }}'
      name: '{{ item.name }}'
      status: '{{ item.status }}'
      statusMessage: '{{ item.statusMessage }}'
      templateName: '{{ item.templateName }}'
- discovery_id: aws.proton.getComponent
  calls:
  - action: getComponent
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.component }}'
    item:
      arn: '{{ item.arn }}'
      createdAt: '{{ item.createdAt }}'
      deploymentStatus: '{{ item.deploymentStatus }}'
      deploymentStatusMessage: '{{ item.deploymentStatusMessage }}'
      description: '{{ item.description }}'
      environmentName: '{{ item.environmentName }}'
      lastAttemptedDeploymentId: '{{ item.lastAttemptedDeploymentId }}'
      lastClientRequestToken: '{{ item.lastClientRequestToken }}'
      lastDeploymentAttemptedAt: '{{ item.lastDeploymentAttemptedAt }}'
      lastDeploymentSucceededAt: '{{ item.lastDeploymentSucceededAt }}'
      lastModifiedAt: '{{ item.lastModifiedAt }}'
      lastSucceededDeploymentId: '{{ item.lastSucceededDeploymentId }}'
      name: '{{ item.name }}'
      serviceInstanceName: '{{ item.serviceInstanceName }}'
      serviceName: '{{ item.serviceName }}'
      serviceSpec: '{{ item.serviceSpec }}'
- discovery_id: aws.proton.getDeployment
  calls:
  - action: getDeployment
    save_as: response
    on_error: continue
  emit:
