version: '1.0'
provider: aws
service: taxsettings
services:
  client: taxsettings
  module: boto3.client
discovery:
- discovery_id: aws.taxsettings.getTaxExemptionTypes
  calls:
  - action: getTaxExemptionTypes
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.taxExemptionTypes }}'
    item:
      applicableJurisdictions: '{{ item.applicableJurisdictions }}'
      description: '{{ item.description }}'
      displayName: '{{ item.displayName }}'
- discovery_id: aws.taxsettings.getTaxInheritance
  calls:
  - action: getTaxInheritance
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.heritageStatus }}'
- discovery_id: aws.taxsettings.getTaxRegistration
  calls:
  - action: getTaxRegistration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.taxRegistration }}'
    item:
      additionalTaxInformation: '{{ item.additionalTaxInformation }}'
      certifiedEmailId: '{{ item.certifiedEmailId }}'
      legalAddress: '{{ item.legalAddress }}'
      legalName: '{{ item.legalName }}'
      registrationId: '{{ item.registrationId }}'
      registrationType: '{{ item.registrationType }}'
      sector: '{{ item.sector }}'
      status: '{{ item.status }}'
      taxDocumentMetadatas: '{{ item.taxDocumentMetadatas }}'
- discovery_id: aws.taxsettings.listSupplementalTaxRegistrations
  calls:
  - action: listSupplementalTaxRegistrations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.taxRegistrations }}'
    item:
      address: '{{ item.address }}'
      authorityId: '{{ item.authorityId }}'
      legalName: '{{ item.legalName }}'
      registrationId: '{{ item.registrationId }}'
      registrationType: '{{ item.registrationType }}'
      status: '{{ item.status }}'
- discovery_id: aws.taxsettings.listTaxExemptions
  calls:
  - action: listTaxExemptions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.nextToken }}'
- discovery_id: aws.taxsettings.listTaxRegistrations
  calls:
  - action: listTaxRegistrations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.accountDetails }}'
    item:
      accountId: '{{ item.accountId }}'
      accountMetaData: '{{ item.accountMetaData }}'
      taxInheritanceDetails: '{{ item.taxInheritanceDetails }}'
      taxRegistration: '{{ item.taxRegistration }}'
- discovery_id: aws.taxsettings.getTaxRegistrationDocument
  calls:
  - action: getTaxRegistrationDocument
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.destinationFilePath }}'
checks: []
