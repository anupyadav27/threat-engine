version: '1.0'
provider: aws
service: kinesisanalytics
services:
  client: kinesisanalytics
  module: boto3.client
discovery:
- discovery_id: aws.kinesisanalytics.listApplications
  calls:
  - action: listApplications
    save_as: response
    on_error: continue
    params:
      Limit: 1000
  emit:
    as: item
    items_for: '{{ response.ApplicationSummaries }}'
    item:
      ApplicationName: '{{ item.ApplicationName }}'
      ApplicationARN: '{{ item.ApplicationARN }}'
      ApplicationStatus: '{{ item.ApplicationStatus }}'
- discovery_id: aws.kinesisanalytics.describeApplication
  calls:
  - action: describeApplication
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ApplicationDetail }}'
    item:
      ApplicationName: '{{ item.ApplicationName }}'
      ApplicationDescription: '{{ item.ApplicationDescription }}'
      ApplicationARN: '{{ item.ApplicationARN }}'
      ApplicationStatus: '{{ item.ApplicationStatus }}'
      CreateTimestamp: '{{ item.CreateTimestamp }}'
      LastUpdateTimestamp: '{{ item.LastUpdateTimestamp }}'
      InputDescriptions: '{{ item.InputDescriptions }}'
      OutputDescriptions: '{{ item.OutputDescriptions }}'
      ReferenceDataSourceDescriptions: '{{ item.ReferenceDataSourceDescriptions }}'
      CloudWatchLoggingOptionDescriptions: '{{ item.CloudWatchLoggingOptionDescriptions
        }}'
      ApplicationCode: '{{ item.ApplicationCode }}'
      ApplicationVersionId: '{{ item.ApplicationVersionId }}'
- discovery_id: aws.kinesisanalytics.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Tags }}'
    item:
      Key: '{{ item.Key }}'
      Value: '{{ item.Value }}'
checks: []
