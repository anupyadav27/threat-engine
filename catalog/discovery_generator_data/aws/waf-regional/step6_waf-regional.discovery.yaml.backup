    item:
      Request: '{{ item.Request }}'
      Weight: '{{ item.Weight }}'
      Timestamp: '{{ item.Timestamp }}'
      Action: '{{ item.Action }}'
      RuleWithinRuleGroup: '{{ item.RuleWithinRuleGroup }}'
