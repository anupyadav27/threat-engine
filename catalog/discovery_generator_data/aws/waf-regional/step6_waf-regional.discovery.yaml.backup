    items_for: '{{ response.WebACL }}'
    item:
      WebACLId: '{{ item.WebACLId }}'
      Name: '{{ item.Name }}'
      MetricName: '{{ item.MetricName }}'
      DefaultAction: '{{ item.DefaultAction }}'
      Rules: '{{ item.Rules }}'
      WebACLArn: '{{ item.WebACLArn }}'
- discovery_id: aws.waf-regional.getWebAclForResource
  calls:
  - action: getWebAclForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.WebACLSummary }}'
    item:
      WebACLId: '{{ item.WebACLId }}'
      Name: '{{ item.Name }}'
- discovery_id: aws.waf-regional.getXssMatchSet
  calls:
  - action: getXssMatchSet
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.XssMatchSet }}'
    item:
      XssMatchSetId: '{{ item.XssMatchSetId }}'
      Name: '{{ item.Name }}'
      XssMatchTuples: '{{ item.XssMatchTuples }}'
- discovery_id: aws.waf-regional.listResourcesForWebAcl
  calls:
  - action: listResourcesForWebAcl
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ResourceArns }}'
- discovery_id: aws.waf-regional.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
    params:
      Limit: 1000
  emit:
    as: item
    items_for: '{{ response.TagInfoForResource }}'
    item:
      ResourceARN: '{{ item.ResourceARN }}'
      TagList: '{{ item.TagList }}'
checks: []
