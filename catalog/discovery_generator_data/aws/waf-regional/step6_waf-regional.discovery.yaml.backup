  calls:
  - action: listSubscribedRuleGroups
    save_as: response
    on_error: continue
    params:
      Limit: 1000
  emit:
    as: item
    items_for: '{{ response.RuleGroups }}'
    item:
      RuleGroupId: '{{ item.RuleGroupId }}'
      Name: '{{ item.Name }}'
      MetricName: '{{ item.MetricName }}'
- discovery_id: aws.waf-regional.listWebAcLs
  calls:
  - action: listWebAcLs
    save_as: response
    on_error: continue
    params:
      Limit: 1000
  emit:
    as: item
    items_for: '{{ response.WebACLs }}'
    item:
      WebACLId: '{{ item.WebACLId }}'
      Name: '{{ item.Name }}'
- discovery_id: aws.waf-regional.listXssMatchSets
  calls:
  - action: listXssMatchSets
    save_as: response
    on_error: continue
    params:
