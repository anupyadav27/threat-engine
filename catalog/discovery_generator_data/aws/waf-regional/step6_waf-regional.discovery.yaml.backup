  calls:
  - action: getByteMatchSet
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ByteMatchSet }}'
    item:
      ByteMatchSetId: '{{ item.ByteMatchSetId }}'
      Name: '{{ item.Name }}'
      ByteMatchTuples: '{{ item.ByteMatchTuples }}'
- discovery_id: aws.waf-regional.getChangeTokenStatus
  calls:
  - action: getChangeTokenStatus
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ChangeTokenStatus }}'
- discovery_id: aws.waf-regional.getGeoMatchSet
  calls:
  - action: getGeoMatchSet
    save_as: response
