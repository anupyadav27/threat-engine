version: '1.0'
provider: aws
service: waf-regional
services:
  client: waf-regional
  module: boto3.client
discovery:
- discovery_id: aws.waf-regional.getChangeToken
  calls:
  - action: getChangeToken
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ChangeToken }}'
- discovery_id: aws.waf-regional.listActivatedRulesInRuleGroup
  calls:
  - action: listActivatedRulesInRuleGroup
    save_as: response
    on_error: continue
    params:
      Limit: 1000
  emit:
    as: item
    items_for: '{{ response.ActivatedRules }}'
    item:
      Priority: '{{ item.Priority }}'
      RuleId: '{{ item.RuleId }}'
      Action: '{{ item.Action }}'
      OverrideAction: '{{ item.OverrideAction }}'
      Type: '{{ item.Type }}'
      ExcludedRules: '{{ item.ExcludedRules }}'
- discovery_id: aws.waf-regional.listByteMatchSets
  calls:
  - action: listByteMatchSets
    save_as: response
    on_error: continue
    params:
      Limit: 1000
  emit:
    as: item
    items_for: '{{ response.ByteMatchSets }}'
    item:
      ByteMatchSetId: '{{ item.ByteMatchSetId }}'
      Name: '{{ item.Name }}'
- discovery_id: aws.waf-regional.listGeoMatchSets
  calls:
  - action: listGeoMatchSets
    save_as: response
    on_error: continue
    params:
      Limit: 1000
  emit:
    as: item
    items_for: '{{ response.GeoMatchSets }}'
    item:
      GeoMatchSetId: '{{ item.GeoMatchSetId }}'
      Name: '{{ item.Name }}'
- discovery_id: aws.waf-regional.listIpSets
  calls:
  - action: listIpSets
    save_as: response
    on_error: continue
    params:
      Limit: 1000
  emit:
    as: item
    items_for: '{{ response.IPSets }}'
    item:
      IPSetId: '{{ item.IPSetId }}'
      Name: '{{ item.Name }}'
- discovery_id: aws.waf-regional.listLoggingConfigurations
  calls:
  - action: listLoggingConfigurations
    save_as: response
    on_error: continue
    params:
      Limit: 1000
  emit:
    as: item
    items_for: '{{ response.LoggingConfigurations }}'
    item:
      ResourceArn: '{{ item.ResourceArn }}'
      LogDestinationConfigs: '{{ item.LogDestinationConfigs }}'
      RedactedFields: '{{ item.RedactedFields }}'
- discovery_id: aws.waf-regional.listRateBasedRules
  calls:
  - action: listRateBasedRules
    save_as: response
    on_error: continue
    params:
      Limit: 1000
  emit:
    as: item
    items_for: '{{ response.Rules }}'
    item:
      RuleId: '{{ item.RuleId }}'
      Name: '{{ item.Name }}'
- discovery_id: aws.waf-regional.listRegexMatchSets
  calls:
  - action: listRegexMatchSets
    save_as: response
    on_error: continue
    params:
      Limit: 1000
  emit:
    as: item
    items_for: '{{ response.RegexMatchSets }}'
    item:
      RegexMatchSetId: '{{ item.RegexMatchSetId }}'
      Name: '{{ item.Name }}'
- discovery_id: aws.waf-regional.listRegexPatternSets
  calls:
  - action: listRegexPatternSets
    save_as: response
    on_error: continue
    params:
      Limit: 1000
  emit:
    as: item
    items_for: '{{ response.RegexPatternSets }}'
    item:
      RegexPatternSetId: '{{ item.RegexPatternSetId }}'
      Name: '{{ item.Name }}'
- discovery_id: aws.waf-regional.listRuleGroups
  calls:
  - action: listRuleGroups
    save_as: response
    on_error: continue
    params:
