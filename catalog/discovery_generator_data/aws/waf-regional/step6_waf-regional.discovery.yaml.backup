  emit:
    as: item
    items_for: '{{ response.Rule }}'
    item:
      RuleId: '{{ item.RuleId }}'
      Name: '{{ item.Name }}'
      MetricName: '{{ item.MetricName }}'
      MatchPredicates: '{{ item.MatchPredicates }}'
      RateKey: '{{ item.RateKey }}'
      RateLimit: '{{ item.RateLimit }}'
- discovery_id: aws.waf-regional.getRateBasedRuleManagedKeys
  calls:
  - action: getRateBasedRuleManagedKeys
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ManagedKeys }}'
- discovery_id: aws.waf-regional.getRegexMatchSet
  calls:
  - action: getRegexMatchSet
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.RegexMatchSet }}'
    item:
      RegexMatchSetId: '{{ item.RegexMatchSetId }}'
      Name: '{{ item.Name }}'
      RegexMatchTuples: '{{ item.RegexMatchTuples }}'
- discovery_id: aws.waf-regional.getRegexPatternSet
  calls:
  - action: getRegexPatternSet
    save_as: response
