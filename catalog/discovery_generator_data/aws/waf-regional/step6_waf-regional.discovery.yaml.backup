    items_for: '{{ response.Rules }}'
    item:
      RuleId: '{{ item.RuleId }}'
      Name: '{{ item.Name }}'
- discovery_id: aws.waf-regional.listSizeConstraintSets
  calls:
  - action: listSizeConstraintSets
    save_as: response
    on_error: continue
    params:
      Limit: 1000
  emit:
    as: item
    items_for: '{{ response.SizeConstraintSets }}'
    item:
      SizeConstraintSetId: '{{ item.SizeConstraintSetId }}'
      Name: '{{ item.Name }}'
- discovery_id: aws.waf-regional.listSqlInjectionMatchSets
  calls:
  - action: listSqlInjectionMatchSets
    save_as: response
    on_error: continue
    params:
      Limit: 1000
  emit:
    as: item
    items_for: '{{ response.SqlInjectionMatchSets }}'
