version: '1.0'
provider: aws
service: codeguruprofiler
services:
  client: codeguruprofiler
  module: boto3.client
discovery:
- discovery_id: aws.codeguruprofiler.getFindingsReportAccountSummary
  calls:
  - action: getFindingsReportAccountSummary
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.reportSummaries }}'
    item:
      id: '{{ item.id }}'
      profileEndTime: '{{ item.profileEndTime }}'
      profileStartTime: '{{ item.profileStartTime }}'
      profilingGroupName: '{{ item.profilingGroupName }}'
      totalNumberOfFindings: '{{ item.totalNumberOfFindings }}'
- discovery_id: aws.codeguruprofiler.listProfilingGroups
  calls:
  - action: listProfilingGroups
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.profilingGroups }}'
    item:
      agentOrchestrationConfig: '{{ item.agentOrchestrationConfig }}'
      arn: '{{ item.arn }}'
      computePlatform: '{{ item.computePlatform }}'
      createdAt: '{{ item.createdAt }}'
      name: '{{ item.name }}'
      profilingStatus: '{{ item.profilingStatus }}'
      tags: '{{ item.tags }}'
      updatedAt: '{{ item.updatedAt }}'
- discovery_id: aws.codeguruprofiler.describeProfilingGroup
  calls:
  - action: describeProfilingGroup
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.profilingGroup }}'
    item:
      agentOrchestrationConfig: '{{ item.agentOrchestrationConfig }}'
      arn: '{{ item.arn }}'
      computePlatform: '{{ item.computePlatform }}'
      createdAt: '{{ item.createdAt }}'
      name: '{{ item.name }}'
      profilingStatus: '{{ item.profilingStatus }}'
      tags: '{{ item.tags }}'
      updatedAt: '{{ item.updatedAt }}'
- discovery_id: aws.codeguruprofiler.getNotificationConfiguration
  calls:
  - action: getNotificationConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.notificationConfiguration }}'
    item:
      channels: '{{ item.channels }}'
- discovery_id: aws.codeguruprofiler.getPolicy
  calls:
  - action: getPolicy
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.policy }}'
- discovery_id: aws.codeguruprofiler.getProfile
  calls:
  - action: getProfile
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.contentEncoding }}'
- discovery_id: aws.codeguruprofiler.getRecommendations
  calls:
  - action: getRecommendations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.anomalies }}'
    item:
      instances: '{{ item.instances }}'
      metric: '{{ item.metric }}'
      reason: '{{ item.reason }}'
- discovery_id: aws.codeguruprofiler.listFindingsReports
  calls:
  - action: listFindingsReports
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.findingsReportSummaries }}'
    item:
      id: '{{ item.id }}'
      profileEndTime: '{{ item.profileEndTime }}'
      profileStartTime: '{{ item.profileStartTime }}'
      profilingGroupName: '{{ item.profilingGroupName }}'
      totalNumberOfFindings: '{{ item.totalNumberOfFindings }}'
- discovery_id: aws.codeguruprofiler.listProfileTimes
  calls:
  - action: listProfileTimes
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.profileTimes }}'
    item:
      start: '{{ item.start }}'
- discovery_id: aws.codeguruprofiler.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tags }}'
checks: []
