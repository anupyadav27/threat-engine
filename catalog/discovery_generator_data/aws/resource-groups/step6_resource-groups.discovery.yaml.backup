version: '1.0'
provider: aws
service: resource-groups
services:
  client: resource-groups
  module: boto3.client
discovery:
- discovery_id: aws.resource-groups.getAccountSettings
  calls:
  - action: getAccountSettings
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AccountSettings }}'
    item:
      GroupLifecycleEventsDesiredStatus: '{{ item.GroupLifecycleEventsDesiredStatus
        }}'
      GroupLifecycleEventsStatus: '{{ item.GroupLifecycleEventsStatus }}'
      GroupLifecycleEventsStatusMessage: '{{ item.GroupLifecycleEventsStatusMessage
        }}'
- discovery_id: aws.resource-groups.getGroup
  calls:
  - action: getGroup
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Group }}'
    item:
      GroupArn: '{{ item.GroupArn }}'
      Name: '{{ item.Name }}'
      Description: '{{ item.Description }}'
      Criticality: '{{ item.Criticality }}'
      Owner: '{{ item.Owner }}'
      DisplayName: '{{ item.DisplayName }}'
      ApplicationTag: '{{ item.ApplicationTag }}'
- discovery_id: aws.resource-groups.getGroupConfiguration
  calls:
  - action: getGroupConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.GroupConfiguration }}'
    item:
      Configuration: '{{ item.Configuration }}'
      ProposedConfiguration: '{{ item.ProposedConfiguration }}'
      Status: '{{ item.Status }}'
      FailureReason: '{{ item.FailureReason }}'
- discovery_id: aws.resource-groups.getGroupQuery
  calls:
  - action: getGroupQuery
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.GroupQuery }}'
    item:
      GroupName: '{{ item.GroupName }}'
      ResourceQuery: '{{ item.ResourceQuery }}'
- discovery_id: aws.resource-groups.listGroupResources
  calls:
  - action: listGroupResources
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Resources }}'
    item:
      Identifier: '{{ item.Identifier }}'
      Status: '{{ item.Status }}'
- discovery_id: aws.resource-groups.listGroups
  calls:
  - action: listGroups
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Groups }}'
    item:
      GroupArn: '{{ item.GroupArn }}'
      Name: '{{ item.Name }}'
      Description: '{{ item.Description }}'
      Criticality: '{{ item.Criticality }}'
      Owner: '{{ item.Owner }}'
      DisplayName: '{{ item.DisplayName }}'
      ApplicationTag: '{{ item.ApplicationTag }}'
- discovery_id: aws.resource-groups.listTagSyncTasks
  calls:
  - action: listTagSyncTasks
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.TagSyncTasks }}'
    item:
      GroupArn: '{{ item.GroupArn }}'
      GroupName: '{{ item.GroupName }}'
      TaskArn: '{{ item.TaskArn }}'
      TagKey: '{{ item.TagKey }}'
      TagValue: '{{ item.TagValue }}'
      ResourceQuery: '{{ item.ResourceQuery }}'
      RoleArn: '{{ item.RoleArn }}'
      Status: '{{ item.Status }}'
      ErrorMessage: '{{ item.ErrorMessage }}'
      CreatedAt: '{{ item.CreatedAt }}'
- discovery_id: aws.resource-groups.getTagSyncTask
  calls:
  - action: getTagSyncTask
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ResourceQuery }}'
    item:
      Type: '{{ item.Type }}'
      Query: '{{ item.Query }}'
- discovery_id: aws.resource-groups.getTags
  calls:
  - action: getTags
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Arn }}'
- discovery_id: aws.resource-groups.listGroupingStatuses
  calls:
  - action: listGroupingStatuses
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.GroupingStatuses }}'
    item:
      ResourceArn: '{{ item.ResourceArn }}'
      Action: '{{ item.Action }}'
      Status: '{{ item.Status }}'
      ErrorMessage: '{{ item.ErrorMessage }}'
      ErrorCode: '{{ item.ErrorCode }}'
      UpdatedAt: '{{ item.UpdatedAt }}'
- discovery_id: aws.resource-groups.searchResources
  calls:
  - action: searchResources
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ResourceIdentifiers }}'
    item:
      ResourceArn: '{{ item.ResourceArn }}'
      ResourceType: '{{ item.ResourceType }}'
checks: []
