version: '1.0'
provider: aws
service: ssm-guiconnect
services:
  client: ssm-guiconnect
  module: boto3.client
discovery:
- discovery_id: aws.ssm-guiconnect.getConnectionRecordingPreferences
  calls:
  - action: getConnectionRecordingPreferences
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ConnectionRecordingPreferences }}'
    item:
      KMSKeyArn: '{{ item.KMSKeyArn }}'
      RecordingDestinations: '{{ item.RecordingDestinations }}'
checks: []
