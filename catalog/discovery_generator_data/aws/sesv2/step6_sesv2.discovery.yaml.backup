version: '1.0'
provider: aws
service: sesv2
services:
  client: sesv2
  module: boto3.client
discovery:
- discovery_id: aws.sesv2.getAccount
  calls:
  - action: getAccount
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.SendQuota }}'
    item:
      Max24HourSend: '{{ item.Max24HourSend }}'
      MaxSendRate: '{{ item.MaxSendRate }}'
      SentLast24Hours: '{{ item.SentLast24Hours }}'
- discovery_id: aws.sesv2.getDedicatedIps
  calls:
  - action: getDedicatedIps
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.DedicatedIps }}'
    item:
      Ip: '{{ item.Ip }}'
      WarmupStatus: '{{ item.WarmupStatus }}'
      WarmupPercentage: '{{ item.WarmupPercentage }}'
      PoolName: '{{ item.PoolName }}'
- discovery_id: aws.sesv2.getDeliverabilityDashboardOptions
  calls:
  - action: getDeliverabilityDashboardOptions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ActiveSubscribedDomains }}'
    item:
      Domain: '{{ item.Domain }}'
      SubscriptionStartDate: '{{ item.SubscriptionStartDate }}'
      InboxPlacementTrackingOption: '{{ item.InboxPlacementTrackingOption }}'
- discovery_id: aws.sesv2.listConfigurationSets
  calls:
  - action: listConfigurationSets
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ConfigurationSets }}'
- discovery_id: aws.sesv2.listContactLists
  calls:
  - action: listContactLists
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ContactLists }}'
    item:
      ContactListName: '{{ item.ContactListName }}'
      LastUpdatedTimestamp: '{{ item.LastUpdatedTimestamp }}'
- discovery_id: aws.sesv2.listCustomVerificationEmailTemplates
  calls:
  - action: listCustomVerificationEmailTemplates
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.CustomVerificationEmailTemplates }}'
    item:
      TemplateName: '{{ item.TemplateName }}'
      FromEmailAddress: '{{ item.FromEmailAddress }}'
      TemplateSubject: '{{ item.TemplateSubject }}'
      SuccessRedirectionURL: '{{ item.SuccessRedirectionURL }}'
      FailureRedirectionURL: '{{ item.FailureRedirectionURL }}'
- discovery_id: aws.sesv2.listDedicatedIpPools
  calls:
  - action: listDedicatedIpPools
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.DedicatedIpPools }}'
- discovery_id: aws.sesv2.listDeliverabilityTestReports
  calls:
  - action: listDeliverabilityTestReports
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.DeliverabilityTestReports }}'
    item:
      ReportId: '{{ item.ReportId }}'
      ReportName: '{{ item.ReportName }}'
      Subject: '{{ item.Subject }}'
      FromEmailAddress: '{{ item.FromEmailAddress }}'
      CreateDate: '{{ item.CreateDate }}'
      DeliverabilityTestStatus: '{{ item.DeliverabilityTestStatus }}'
- discovery_id: aws.sesv2.listEmailIdentities
  calls:
  - action: listEmailIdentities
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.EmailIdentities }}'
    item:
      IdentityType: '{{ item.IdentityType }}'
      IdentityName: '{{ item.IdentityName }}'
      SendingEnabled: '{{ item.SendingEnabled }}'
      VerificationStatus: '{{ item.VerificationStatus }}'
- discovery_id: aws.sesv2.listEmailTemplates
  calls:
  - action: listEmailTemplates
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.TemplatesMetadata }}'
    item:
      TemplateName: '{{ item.TemplateName }}'
      CreatedTimestamp: '{{ item.CreatedTimestamp }}'
- discovery_id: aws.sesv2.listExportJobs
  calls:
  - action: listExportJobs
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ExportJobs }}'
    item:
      JobId: '{{ item.JobId }}'
      ExportSourceType: '{{ item.ExportSourceType }}'
      JobStatus: '{{ item.JobStatus }}'
      CreatedTimestamp: '{{ item.CreatedTimestamp }}'
      CompletedTimestamp: '{{ item.CompletedTimestamp }}'
- discovery_id: aws.sesv2.listImportJobs
  calls:
  - action: listImportJobs
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ImportJobs }}'
    item:
      JobId: '{{ item.JobId }}'
      ImportDestination: '{{ item.ImportDestination }}'
      JobStatus: '{{ item.JobStatus }}'
      CreatedTimestamp: '{{ item.CreatedTimestamp }}'
      ProcessedRecordsCount: '{{ item.ProcessedRecordsCount }}'
      FailedRecordsCount: '{{ item.FailedRecordsCount }}'
- discovery_id: aws.sesv2.listMultiRegionEndpoints
  calls:
  - action: listMultiRegionEndpoints
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.MultiRegionEndpoints }}'
    item:
      EndpointName: '{{ item.EndpointName }}'
      Status: '{{ item.Status }}'
      EndpointId: '{{ item.EndpointId }}'
      Regions: '{{ item.Regions }}'
      CreatedTimestamp: '{{ item.CreatedTimestamp }}'
      LastUpdatedTimestamp: '{{ item.LastUpdatedTimestamp }}'
- discovery_id: aws.sesv2.listRecommendations
  calls:
  - action: listRecommendations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Recommendations }}'
    item:
      ResourceArn: '{{ item.ResourceArn }}'
      Type: '{{ item.Type }}'
      Description: '{{ item.Description }}'
      Status: '{{ item.Status }}'
      CreatedTimestamp: '{{ item.CreatedTimestamp }}'
      LastUpdatedTimestamp: '{{ item.LastUpdatedTimestamp }}'
      Impact: '{{ item.Impact }}'
- discovery_id: aws.sesv2.listReputationEntities
  calls:
  - action: listReputationEntities
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ReputationEntities }}'
    item:
      ReputationEntityReference: '{{ item.ReputationEntityReference }}'
      ReputationEntityType: '{{ item.ReputationEntityType }}'
      ReputationManagementPolicy: '{{ item.ReputationManagementPolicy }}'
      CustomerManagedStatus: '{{ item.CustomerManagedStatus }}'
      AwsSesManagedStatus: '{{ item.AwsSesManagedStatus }}'
      SendingStatusAggregate: '{{ item.SendingStatusAggregate }}'
      ReputationImpact: '{{ item.ReputationImpact }}'
- discovery_id: aws.sesv2.listSuppressedDestinations
  calls:
  - action: listSuppressedDestinations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.SuppressedDestinationSummaries }}'
    item:
      EmailAddress: '{{ item.EmailAddress }}'
      Reason: '{{ item.Reason }}'
      LastUpdateTime: '{{ item.LastUpdateTime }}'
- discovery_id: aws.sesv2.listTenants
  calls:
  - action: listTenants
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Tenants }}'
    item:
      TenantName: '{{ item.TenantName }}'
      TenantId: '{{ item.TenantId }}'
      TenantArn: '{{ item.TenantArn }}'
      CreatedTimestamp: '{{ item.CreatedTimestamp }}'
- discovery_id: aws.sesv2.getBlacklistReports
  calls:
  - action: getBlacklistReports
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.BlacklistReport }}'
- discovery_id: aws.sesv2.getConfigurationSet
  calls:
  - action: getConfigurationSet
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Tags }}'
    item:
      Key: '{{ item.Key }}'
      Value: '{{ item.Value }}'
- discovery_id: aws.sesv2.getConfigurationSetEventDestinations
  calls:
  - action: getConfigurationSetEventDestinations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.EventDestinations }}'
    item:
      Name: '{{ item.Name }}'
      Enabled: '{{ item.Enabled }}'
      MatchingEventTypes: '{{ item.MatchingEventTypes }}'
      KinesisFirehoseDestination: '{{ item.KinesisFirehoseDestination }}'
      CloudWatchDestination: '{{ item.CloudWatchDestination }}'
      SnsDestination: '{{ item.SnsDestination }}'
      EventBridgeDestination: '{{ item.EventBridgeDestination }}'
      PinpointDestination: '{{ item.PinpointDestination }}'
- discovery_id: aws.sesv2.getContact
  calls:
  - action: getContact
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.TopicPreferences }}'
    item:
      TopicName: '{{ item.TopicName }}'
      SubscriptionStatus: '{{ item.SubscriptionStatus }}'
- discovery_id: aws.sesv2.getContactList
  calls:
  - action: getContactList
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Topics }}'
    item:
      TopicName: '{{ item.TopicName }}'
      DisplayName: '{{ item.DisplayName }}'
      Description: '{{ item.Description }}'
      DefaultSubscriptionStatus: '{{ item.DefaultSubscriptionStatus }}'
- discovery_id: aws.sesv2.getCustomVerificationEmailTemplate
  calls:
  - action: getCustomVerificationEmailTemplate
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.TemplateName }}'
- discovery_id: aws.sesv2.getDedicatedIp
  calls:
  - action: getDedicatedIp
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.DedicatedIp }}'
    item:
      Ip: '{{ item.Ip }}'
      WarmupStatus: '{{ item.WarmupStatus }}'
      WarmupPercentage: '{{ item.WarmupPercentage }}'
      PoolName: '{{ item.PoolName }}'
- discovery_id: aws.sesv2.getDedicatedIpPool
  calls:
  - action: getDedicatedIpPool
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.DedicatedIpPool }}'
    item:
      PoolName: '{{ item.PoolName }}'
      ScalingMode: '{{ item.ScalingMode }}'
- discovery_id: aws.sesv2.getDeliverabilityTestReport
  calls:
  - action: getDeliverabilityTestReport
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.IspPlacements }}'
    item:
      IspName: '{{ item.IspName }}'
      PlacementStatistics: '{{ item.PlacementStatistics }}'
- discovery_id: aws.sesv2.getDomainDeliverabilityCampaign
  calls:
  - action: getDomainDeliverabilityCampaign
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.DomainDeliverabilityCampaign }}'
    item:
      CampaignId: '{{ item.CampaignId }}'
      ImageUrl: '{{ item.ImageUrl }}'
      Subject: '{{ item.Subject }}'
      FromAddress: '{{ item.FromAddress }}'
      SendingIps: '{{ item.SendingIps }}'
      FirstSeenDateTime: '{{ item.FirstSeenDateTime }}'
      LastSeenDateTime: '{{ item.LastSeenDateTime }}'
      InboxCount: '{{ item.InboxCount }}'
      SpamCount: '{{ item.SpamCount }}'
      ReadRate: '{{ item.ReadRate }}'
      DeleteRate: '{{ item.DeleteRate }}'
      ReadDeleteRate: '{{ item.ReadDeleteRate }}'
      ProjectedVolume: '{{ item.ProjectedVolume }}'
      Esps: '{{ item.Esps }}'
- discovery_id: aws.sesv2.getDomainStatisticsReport
  calls:
  - action: getDomainStatisticsReport
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.DailyVolumes }}'
    item:
      StartDate: '{{ item.StartDate }}'
      VolumeStatistics: '{{ item.VolumeStatistics }}'
      DomainIspPlacements: '{{ item.DomainIspPlacements }}'
- discovery_id: aws.sesv2.getEmailIdentity
  calls:
  - action: getEmailIdentity
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Tags }}'
    item:
      Key: '{{ item.Key }}'
      Value: '{{ item.Value }}'
- discovery_id: aws.sesv2.getEmailIdentityPolicies
  calls:
  - action: getEmailIdentityPolicies
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Policies }}'
- discovery_id: aws.sesv2.getEmailTemplate
  calls:
  - action: getEmailTemplate
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.TemplateContent }}'
    item:
      Subject: '{{ item.Subject }}'
      Text: '{{ item.Text }}'
      Html: '{{ item.Html }}'
- discovery_id: aws.sesv2.getExportJob
  calls:
  - action: getExportJob
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ExportDestination }}'
    item:
      DataFormat: '{{ item.DataFormat }}'
      S3Url: '{{ item.S3Url }}'
- discovery_id: aws.sesv2.getImportJob
  calls:
  - action: getImportJob
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ImportDestination }}'
    item:
      SuppressionListDestination: '{{ item.SuppressionListDestination }}'
      ContactListDestination: '{{ item.ContactListDestination }}'
- discovery_id: aws.sesv2.getMessageInsights
  calls:
  - action: getMessageInsights
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.EmailTags }}'
    item:
      Name: '{{ item.Name }}'
      Value: '{{ item.Value }}'
- discovery_id: aws.sesv2.getMultiRegionEndpoint
  calls:
  - action: getMultiRegionEndpoint
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Routes }}'
    item:
      Region: '{{ item.Region }}'
- discovery_id: aws.sesv2.getReputationEntity
  calls:
  - action: getReputationEntity
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ReputationEntity }}'
    item:
      ReputationEntityReference: '{{ item.ReputationEntityReference }}'
      ReputationEntityType: '{{ item.ReputationEntityType }}'
      ReputationManagementPolicy: '{{ item.ReputationManagementPolicy }}'
      CustomerManagedStatus: '{{ item.CustomerManagedStatus }}'
      AwsSesManagedStatus: '{{ item.AwsSesManagedStatus }}'
      SendingStatusAggregate: '{{ item.SendingStatusAggregate }}'
      ReputationImpact: '{{ item.ReputationImpact }}'
- discovery_id: aws.sesv2.getSuppressedDestination
  calls:
  - action: getSuppressedDestination
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.SuppressedDestination }}'
    item:
      EmailAddress: '{{ item.EmailAddress }}'
      Reason: '{{ item.Reason }}'
      LastUpdateTime: '{{ item.LastUpdateTime }}'
      Attributes: '{{ item.Attributes }}'
- discovery_id: aws.sesv2.getTenant
  calls:
  - action: getTenant
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Tenant }}'
    item:
      TenantName: '{{ item.TenantName }}'
      TenantId: '{{ item.TenantId }}'
      TenantArn: '{{ item.TenantArn }}'
      CreatedTimestamp: '{{ item.CreatedTimestamp }}'
      Tags: '{{ item.Tags }}'
      SendingStatus: '{{ item.SendingStatus }}'
- discovery_id: aws.sesv2.listContacts
  calls:
  - action: listContacts
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Contacts }}'
    item:
      EmailAddress: '{{ item.EmailAddress }}'
      TopicPreferences: '{{ item.TopicPreferences }}'
      TopicDefaultPreferences: '{{ item.TopicDefaultPreferences }}'
      UnsubscribeAll: '{{ item.UnsubscribeAll }}'
      LastUpdatedTimestamp: '{{ item.LastUpdatedTimestamp }}'
- discovery_id: aws.sesv2.listDomainDeliverabilityCampaigns
  calls:
  - action: listDomainDeliverabilityCampaigns
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.DomainDeliverabilityCampaigns }}'
    item:
      CampaignId: '{{ item.CampaignId }}'
      ImageUrl: '{{ item.ImageUrl }}'
      Subject: '{{ item.Subject }}'
      FromAddress: '{{ item.FromAddress }}'
      SendingIps: '{{ item.SendingIps }}'
      FirstSeenDateTime: '{{ item.FirstSeenDateTime }}'
      LastSeenDateTime: '{{ item.LastSeenDateTime }}'
      InboxCount: '{{ item.InboxCount }}'
      SpamCount: '{{ item.SpamCount }}'
      ReadRate: '{{ item.ReadRate }}'
      DeleteRate: '{{ item.DeleteRate }}'
      ReadDeleteRate: '{{ item.ReadDeleteRate }}'
      ProjectedVolume: '{{ item.ProjectedVolume }}'
      Esps: '{{ item.Esps }}'
- discovery_id: aws.sesv2.listResourceTenants
  calls:
  - action: listResourceTenants
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ResourceTenants }}'
    item:
      TenantName: '{{ item.TenantName }}'
      TenantId: '{{ item.TenantId }}'
      ResourceArn: '{{ item.ResourceArn }}'
      AssociatedTimestamp: '{{ item.AssociatedTimestamp }}'
- discovery_id: aws.sesv2.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Tags }}'
    item:
      Key: '{{ item.Key }}'
      Value: '{{ item.Value }}'
- discovery_id: aws.sesv2.listTenantResources
  calls:
  - action: listTenantResources
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.TenantResources }}'
    item:
      ResourceType: '{{ item.ResourceType }}'
      ResourceArn: '{{ item.ResourceArn }}'
checks: []
