version: '1.0'
provider: aws
service: emr-serverless
services:
  client: emr-serverless
  module: boto3.client
discovery:
- discovery_id: aws.emr-serverless.listApplications
  calls:
  - action: listApplications
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.applications }}'
    item:
      id: '{{ item.id }}'
      name: '{{ item.name }}'
      arn: '{{ item.arn }}'
      releaseLabel: '{{ item.releaseLabel }}'
      type: '{{ item.type }}'
      state: '{{ item.state }}'
      stateDetails: '{{ item.stateDetails }}'
      createdAt: '{{ item.createdAt }}'
      updatedAt: '{{ item.updatedAt }}'
      architecture: '{{ item.architecture }}'
- discovery_id: aws.emr-serverless.getApplication
  calls:
  - action: getApplication
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.application }}'
    item:
      applicationId: '{{ item.applicationId }}'
      name: '{{ item.name }}'
      arn: '{{ item.arn }}'
      releaseLabel: '{{ item.releaseLabel }}'
      type: '{{ item.type }}'
      state: '{{ item.state }}'
      stateDetails: '{{ item.stateDetails }}'
      initialCapacity: '{{ item.initialCapacity }}'
      maximumCapacity: '{{ item.maximumCapacity }}'
      createdAt: '{{ item.createdAt }}'
      updatedAt: '{{ item.updatedAt }}'
      tags: '{{ item.tags }}'
      autoStartConfiguration: '{{ item.autoStartConfiguration }}'
      autoStopConfiguration: '{{ item.autoStopConfiguration }}'
      networkConfiguration: '{{ item.networkConfiguration }}'
      architecture: '{{ item.architecture }}'
      imageConfiguration: '{{ item.imageConfiguration }}'
      workerTypeSpecifications: '{{ item.workerTypeSpecifications }}'
      runtimeConfiguration: '{{ item.runtimeConfiguration }}'
      monitoringConfiguration: '{{ item.monitoringConfiguration }}'
      interactiveConfiguration: '{{ item.interactiveConfiguration }}'
      schedulerConfiguration: '{{ item.schedulerConfiguration }}'
      identityCenterConfiguration: '{{ item.identityCenterConfiguration }}'
- discovery_id: aws.emr-serverless.getDashboardForJobRun
  calls:
  - action: getDashboardForJobRun
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.url }}'
- discovery_id: aws.emr-serverless.getJobRun
  calls:
  - action: getJobRun
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.jobRun }}'
    item:
      applicationId: '{{ item.applicationId }}'
      jobRunId: '{{ item.jobRunId }}'
      name: '{{ item.name }}'
      arn: '{{ item.arn }}'
      createdBy: '{{ item.createdBy }}'
      createdAt: '{{ item.createdAt }}'
      updatedAt: '{{ item.updatedAt }}'
      executionRole: '{{ item.executionRole }}'
      executionIamPolicy: '{{ item.executionIamPolicy }}'
      state: '{{ item.state }}'
      stateDetails: '{{ item.stateDetails }}'
      releaseLabel: '{{ item.releaseLabel }}'
      configurationOverrides: '{{ item.configurationOverrides }}'
      jobDriver: '{{ item.jobDriver }}'
      tags: '{{ item.tags }}'
      totalResourceUtilization: '{{ item.totalResourceUtilization }}'
      networkConfiguration: '{{ item.networkConfiguration }}'
      totalExecutionDurationSeconds: '{{ item.totalExecutionDurationSeconds }}'
      executionTimeoutMinutes: '{{ item.executionTimeoutMinutes }}'
      billedResourceUtilization: '{{ item.billedResourceUtilization }}'
      mode: '{{ item.mode }}'
      retryPolicy: '{{ item.retryPolicy }}'
      attempt: '{{ item.attempt }}'
      attemptCreatedAt: '{{ item.attemptCreatedAt }}'
      attemptUpdatedAt: '{{ item.attemptUpdatedAt }}'
      startedAt: '{{ item.startedAt }}'
      endedAt: '{{ item.endedAt }}'
      queuedDurationMilliseconds: '{{ item.queuedDurationMilliseconds }}'
- discovery_id: aws.emr-serverless.listJobRunAttempts
  calls:
  - action: listJobRunAttempts
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.jobRunAttempts }}'
    item:
      applicationId: '{{ item.applicationId }}'
      id: '{{ item.id }}'
      name: '{{ item.name }}'
      mode: '{{ item.mode }}'
      arn: '{{ item.arn }}'
      createdBy: '{{ item.createdBy }}'
      jobCreatedAt: '{{ item.jobCreatedAt }}'
      createdAt: '{{ item.createdAt }}'
      updatedAt: '{{ item.updatedAt }}'
      executionRole: '{{ item.executionRole }}'
      state: '{{ item.state }}'
      stateDetails: '{{ item.stateDetails }}'
      releaseLabel: '{{ item.releaseLabel }}'
      type: '{{ item.type }}'
      attempt: '{{ item.attempt }}'
- discovery_id: aws.emr-serverless.listJobRuns
  calls:
  - action: listJobRuns
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.jobRuns }}'
    item:
      applicationId: '{{ item.applicationId }}'
      id: '{{ item.id }}'
      name: '{{ item.name }}'
      mode: '{{ item.mode }}'
      arn: '{{ item.arn }}'
      createdBy: '{{ item.createdBy }}'
      createdAt: '{{ item.createdAt }}'
      updatedAt: '{{ item.updatedAt }}'
      executionRole: '{{ item.executionRole }}'
      state: '{{ item.state }}'
      stateDetails: '{{ item.stateDetails }}'
      releaseLabel: '{{ item.releaseLabel }}'
      type: '{{ item.type }}'
      attempt: '{{ item.attempt }}'
      attemptCreatedAt: '{{ item.attemptCreatedAt }}'
      attemptUpdatedAt: '{{ item.attemptUpdatedAt }}'
- discovery_id: aws.emr-serverless.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tags }}'
checks: []
