version: '1.0'
provider: aws
service: kendra-ranking
services:
  client: kendra-ranking
  module: boto3.client
discovery:
- discovery_id: aws.kendra-ranking.listRescoreExecutionPlans
  calls:
  - action: listRescoreExecutionPlans
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.SummaryItems }}'
    item:
      Name: '{{ item.Name }}'
      Id: '{{ item.Id }}'
      CreatedAt: '{{ item.CreatedAt }}'
      UpdatedAt: '{{ item.UpdatedAt }}'
      Status: '{{ item.Status }}'
- discovery_id: aws.kendra-ranking.describeRescoreExecutionPlan
  calls:
  - action: describeRescoreExecutionPlan
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.CapacityUnits }}'
    item:
      RescoreCapacityUnits: '{{ item.RescoreCapacityUnits }}'
- discovery_id: aws.kendra-ranking.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Tags }}'
    item:
      Key: '{{ item.Key }}'
      Value: '{{ item.Value }}'
checks: []
