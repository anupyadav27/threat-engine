version: '1.0'
provider: aws
service: socialmessaging
services:
  client: socialmessaging
  module: boto3.client
discovery:
- discovery_id: aws.socialmessaging.listLinkedWhatsAppBusinessAccounts
  calls:
  - action: listLinkedWhatsAppBusinessAccounts
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.linkedAccounts }}'
    item:
      arn: '{{ item.arn }}'
      id: '{{ item.id }}'
      wabaId: '{{ item.wabaId }}'
      registrationStatus: '{{ item.registrationStatus }}'
      linkDate: '{{ item.linkDate }}'
      wabaName: '{{ item.wabaName }}'
      eventDestinations: '{{ item.eventDestinations }}'
- discovery_id: aws.socialmessaging.getLinkedWhatsAppBusinessAccount
  calls:
  - action: getLinkedWhatsAppBusinessAccount
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.account }}'
    item:
      arn: '{{ item.arn }}'
      id: '{{ item.id }}'
      wabaId: '{{ item.wabaId }}'
      registrationStatus: '{{ item.registrationStatus }}'
      linkDate: '{{ item.linkDate }}'
      wabaName: '{{ item.wabaName }}'
      eventDestinations: '{{ item.eventDestinations }}'
      phoneNumbers: '{{ item.phoneNumbers }}'
- discovery_id: aws.socialmessaging.getLinkedWhatsAppBusinessAccountPhoneNumber
  calls:
  - action: getLinkedWhatsAppBusinessAccountPhoneNumber
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.phoneNumber }}'
    item:
      arn: '{{ item.arn }}'
      phoneNumber: '{{ item.phoneNumber }}'
      phoneNumberId: '{{ item.phoneNumberId }}'
      metaPhoneNumberId: '{{ item.metaPhoneNumberId }}'
      displayPhoneNumberName: '{{ item.displayPhoneNumberName }}'
      displayPhoneNumber: '{{ item.displayPhoneNumber }}'
      qualityRating: '{{ item.qualityRating }}'
      dataLocalizationRegion: '{{ item.dataLocalizationRegion }}'
- discovery_id: aws.socialmessaging.getWhatsAppMessageMedia
  calls:
  - action: getWhatsAppMessageMedia
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.mimeType }}'
- discovery_id: aws.socialmessaging.getWhatsAppMessageTemplate
  calls:
  - action: getWhatsAppMessageTemplate
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.template }}'
- discovery_id: aws.socialmessaging.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tags }}'
    item:
      key: '{{ item.key }}'
      value: '{{ item.value }}'
- discovery_id: aws.socialmessaging.listWhatsAppMessageTemplates
  calls:
  - action: listWhatsAppMessageTemplates
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.templates }}'
    item:
      templateName: '{{ item.templateName }}'
      metaTemplateId: '{{ item.metaTemplateId }}'
      templateStatus: '{{ item.templateStatus }}'
      templateQualityScore: '{{ item.templateQualityScore }}'
      templateLanguage: '{{ item.templateLanguage }}'
      templateCategory: '{{ item.templateCategory }}'
- discovery_id: aws.socialmessaging.listWhatsAppTemplateLibrary
  calls:
  - action: listWhatsAppTemplateLibrary
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.metaLibraryTemplates }}'
    item:
      templateName: '{{ item.templateName }}'
      templateLanguage: '{{ item.templateLanguage }}'
      templateCategory: '{{ item.templateCategory }}'
      templateTopic: '{{ item.templateTopic }}'
      templateUseCase: '{{ item.templateUseCase }}'
      templateIndustry: '{{ item.templateIndustry }}'
      templateHeader: '{{ item.templateHeader }}'
      templateBody: '{{ item.templateBody }}'
      templateButtons: '{{ item.templateButtons }}'
      templateId: '{{ item.templateId }}'
checks: []
