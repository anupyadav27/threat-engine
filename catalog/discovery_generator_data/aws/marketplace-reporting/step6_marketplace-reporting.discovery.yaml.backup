version: '1.0'
provider: aws
service: marketplace-reporting
services:
  client: marketplace-reporting
  module: boto3.client
discovery:
- discovery_id: aws.marketplace-reporting.getBuyerDashboard
  calls:
  - action: getBuyerDashboard
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.embeddingDomains }}'
checks: []
