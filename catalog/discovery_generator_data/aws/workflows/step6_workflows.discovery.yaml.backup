version: '1.0'
provider: aws
service: workflows
services:
  client: workflows
  module: boto3.client
discovery:
- discovery_id: aws.workflows.listActivities
  calls:
  - action: listActivities
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.activities }}'
    item:
      activityArn: '{{ item.activityArn }}'
      name: '{{ item.name }}'
      creationDate: '{{ item.creationDate }}'
- discovery_id: aws.workflows.listExecutions
  calls:
  - action: listExecutions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.executions }}'
    item:
      executionArn: '{{ item.executionArn }}'
      stateMachineArn: '{{ item.stateMachineArn }}'
      name: '{{ item.name }}'
      status: '{{ item.status }}'
      startDate: '{{ item.startDate }}'
      stopDate: '{{ item.stopDate }}'
      mapRunArn: '{{ item.mapRunArn }}'
      itemCount: '{{ item.itemCount }}'
      stateMachineVersionArn: '{{ item.stateMachineVersionArn }}'
      stateMachineAliasArn: '{{ item.stateMachineAliasArn }}'
      redriveCount: '{{ item.redriveCount }}'
      redriveDate: '{{ item.redriveDate }}'
- discovery_id: aws.workflows.listStateMachines
  calls:
  - action: listStateMachines
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.stateMachines }}'
    item:
      stateMachineArn: '{{ item.stateMachineArn }}'
      name: '{{ item.name }}'
      type: '{{ item.type }}'
      creationDate: '{{ item.creationDate }}'
- discovery_id: aws.workflows.describeActivity
  calls:
  - action: describeActivity
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.encryptionConfiguration }}'
    item:
      kmsKeyId: '{{ item.kmsKeyId }}'
      kmsDataKeyReusePeriodSeconds: '{{ item.kmsDataKeyReusePeriodSeconds }}'
      type: '{{ item.type }}'
- discovery_id: aws.workflows.describeExecution
  calls:
  - action: describeExecution
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.inputDetails }}'
    item:
      included: '{{ item.included }}'
- discovery_id: aws.workflows.describeMapRun
  calls:
  - action: describeMapRun
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.itemCounts }}'
    item:
      pending: '{{ item.pending }}'
      running: '{{ item.running }}'
      succeeded: '{{ item.succeeded }}'
      failed: '{{ item.failed }}'
      timedOut: '{{ item.timedOut }}'
      aborted: '{{ item.aborted }}'
      total: '{{ item.total }}'
      resultsWritten: '{{ item.resultsWritten }}'
      failuresNotRedrivable: '{{ item.failuresNotRedrivable }}'
      pendingRedrive: '{{ item.pendingRedrive }}'
- discovery_id: aws.workflows.describeStateMachine
  calls:
  - action: describeStateMachine
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.loggingConfiguration }}'
    item:
      level: '{{ item.level }}'
      includeExecutionData: '{{ item.includeExecutionData }}'
      destinations: '{{ item.destinations }}'
- discovery_id: aws.workflows.describeStateMachineAlias
  calls:
  - action: describeStateMachineAlias
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.routingConfiguration }}'
    item:
      stateMachineVersionArn: '{{ item.stateMachineVersionArn }}'
      weight: '{{ item.weight }}'
- discovery_id: aws.workflows.describeStateMachineForExecution
  calls:
  - action: describeStateMachineForExecution
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.loggingConfiguration }}'
    item:
      level: '{{ item.level }}'
      includeExecutionData: '{{ item.includeExecutionData }}'
      destinations: '{{ item.destinations }}'
- discovery_id: aws.workflows.getActivityTask
  calls:
  - action: getActivityTask
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.taskToken }}'
- discovery_id: aws.workflows.getExecutionHistory
  calls:
  - action: getExecutionHistory
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.events }}'
    item:
      timestamp: '{{ item.timestamp }}'
      type: '{{ item.type }}'
      id: '{{ item.id }}'
      previousEventId: '{{ item.previousEventId }}'
      activityFailedEventDetails: '{{ item.activityFailedEventDetails }}'
      activityScheduleFailedEventDetails: '{{ item.activityScheduleFailedEventDetails
        }}'
      activityScheduledEventDetails: '{{ item.activityScheduledEventDetails }}'
      activityStartedEventDetails: '{{ item.activityStartedEventDetails }}'
      activitySucceededEventDetails: '{{ item.activitySucceededEventDetails }}'
      activityTimedOutEventDetails: '{{ item.activityTimedOutEventDetails }}'
      taskFailedEventDetails: '{{ item.taskFailedEventDetails }}'
      taskScheduledEventDetails: '{{ item.taskScheduledEventDetails }}'
      taskStartFailedEventDetails: '{{ item.taskStartFailedEventDetails }}'
      taskStartedEventDetails: '{{ item.taskStartedEventDetails }}'
      taskSubmitFailedEventDetails: '{{ item.taskSubmitFailedEventDetails }}'
      taskSubmittedEventDetails: '{{ item.taskSubmittedEventDetails }}'
      taskSucceededEventDetails: '{{ item.taskSucceededEventDetails }}'
      taskTimedOutEventDetails: '{{ item.taskTimedOutEventDetails }}'
      executionFailedEventDetails: '{{ item.executionFailedEventDetails }}'
      executionStartedEventDetails: '{{ item.executionStartedEventDetails }}'
      executionSucceededEventDetails: '{{ item.executionSucceededEventDetails }}'
      executionAbortedEventDetails: '{{ item.executionAbortedEventDetails }}'
      executionTimedOutEventDetails: '{{ item.executionTimedOutEventDetails }}'
      executionRedrivenEventDetails: '{{ item.executionRedrivenEventDetails }}'
      mapStateStartedEventDetails: '{{ item.mapStateStartedEventDetails }}'
      mapIterationStartedEventDetails: '{{ item.mapIterationStartedEventDetails }}'
      mapIterationSucceededEventDetails: '{{ item.mapIterationSucceededEventDetails
        }}'
      mapIterationFailedEventDetails: '{{ item.mapIterationFailedEventDetails }}'
      mapIterationAbortedEventDetails: '{{ item.mapIterationAbortedEventDetails }}'
      lambdaFunctionFailedEventDetails: '{{ item.lambdaFunctionFailedEventDetails
        }}'
      lambdaFunctionScheduleFailedEventDetails: '{{ item.lambdaFunctionScheduleFailedEventDetails
        }}'
      lambdaFunctionScheduledEventDetails: '{{ item.lambdaFunctionScheduledEventDetails
        }}'
      lambdaFunctionStartFailedEventDetails: '{{ item.lambdaFunctionStartFailedEventDetails
        }}'
      lambdaFunctionSucceededEventDetails: '{{ item.lambdaFunctionSucceededEventDetails
        }}'
      lambdaFunctionTimedOutEventDetails: '{{ item.lambdaFunctionTimedOutEventDetails
        }}'
      stateEnteredEventDetails: '{{ item.stateEnteredEventDetails }}'
      stateExitedEventDetails: '{{ item.stateExitedEventDetails }}'
      mapRunStartedEventDetails: '{{ item.mapRunStartedEventDetails }}'
      mapRunFailedEventDetails: '{{ item.mapRunFailedEventDetails }}'
      mapRunRedrivenEventDetails: '{{ item.mapRunRedrivenEventDetails }}'
      evaluationFailedEventDetails: '{{ item.evaluationFailedEventDetails }}'
- discovery_id: aws.workflows.listMapRuns
  calls:
  - action: listMapRuns
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.mapRuns }}'
    item:
      executionArn: '{{ item.executionArn }}'
      mapRunArn: '{{ item.mapRunArn }}'
      stateMachineArn: '{{ item.stateMachineArn }}'
      startDate: '{{ item.startDate }}'
      stopDate: '{{ item.stopDate }}'
- discovery_id: aws.workflows.listStateMachineAliases
  calls:
  - action: listStateMachineAliases
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.stateMachineAliases }}'
    item:
      stateMachineAliasArn: '{{ item.stateMachineAliasArn }}'
      creationDate: '{{ item.creationDate }}'
- discovery_id: aws.workflows.listStateMachineVersions
  calls:
  - action: listStateMachineVersions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.stateMachineVersions }}'
    item:
      stateMachineVersionArn: '{{ item.stateMachineVersionArn }}'
      creationDate: '{{ item.creationDate }}'
- discovery_id: aws.workflows.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tags }}'
    item:
      key: '{{ item.key }}'
      value: '{{ item.value }}'
checks: []
