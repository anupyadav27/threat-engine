version: '1.0'
provider: aws
service: synthetics
services:
  client: synthetics
  module: boto3.client
discovery:
- discovery_id: aws.synthetics.describeCanaries
  calls:
  - action: describeCanaries
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Canaries }}'
    item:
      Id: '{{ item.Id }}'
      Name: '{{ item.Name }}'
      Code: '{{ item.Code }}'
      ExecutionRoleArn: '{{ item.ExecutionRoleArn }}'
      Schedule: '{{ item.Schedule }}'
      RunConfig: '{{ item.RunConfig }}'
      SuccessRetentionPeriodInDays: '{{ item.SuccessRetentionPeriodInDays }}'
      FailureRetentionPeriodInDays: '{{ item.FailureRetentionPeriodInDays }}'
      Status: '{{ item.Status }}'
      Timeline: '{{ item.Timeline }}'
      ArtifactS3Location: '{{ item.ArtifactS3Location }}'
      EngineArn: '{{ item.EngineArn }}'
      RuntimeVersion: '{{ item.RuntimeVersion }}'
      VpcConfig: '{{ item.VpcConfig }}'
      VisualReference: '{{ item.VisualReference }}'
      ProvisionedResourceCleanup: '{{ item.ProvisionedResourceCleanup }}'
      BrowserConfigs: '{{ item.BrowserConfigs }}'
      EngineConfigs: '{{ item.EngineConfigs }}'
      VisualReferences: '{{ item.VisualReferences }}'
      Tags: '{{ item.Tags }}'
      ArtifactConfig: '{{ item.ArtifactConfig }}'
      DryRunConfig: '{{ item.DryRunConfig }}'
- discovery_id: aws.synthetics.describeCanariesLastRun
  calls:
  - action: describeCanariesLastRun
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.CanariesLastRun }}'
    item:
      CanaryName: '{{ item.CanaryName }}'
      LastRun: '{{ item.LastRun }}'
- discovery_id: aws.synthetics.describeRuntimeVersions
  calls:
  - action: describeRuntimeVersions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.RuntimeVersions }}'
    item:
      VersionName: '{{ item.VersionName }}'
      Description: '{{ item.Description }}'
      ReleaseDate: '{{ item.ReleaseDate }}'
      DeprecationDate: '{{ item.DeprecationDate }}'
- discovery_id: aws.synthetics.listGroups
  calls:
  - action: listGroups
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Groups }}'
    item:
      Id: '{{ item.Id }}'
      Name: '{{ item.Name }}'
      Arn: '{{ item.Arn }}'
- discovery_id: aws.synthetics.getCanary
  calls:
  - action: getCanary
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Canary }}'
    item:
      Id: '{{ item.Id }}'
      Name: '{{ item.Name }}'
      Code: '{{ item.Code }}'
      ExecutionRoleArn: '{{ item.ExecutionRoleArn }}'
      Schedule: '{{ item.Schedule }}'
      RunConfig: '{{ item.RunConfig }}'
      SuccessRetentionPeriodInDays: '{{ item.SuccessRetentionPeriodInDays }}'
      FailureRetentionPeriodInDays: '{{ item.FailureRetentionPeriodInDays }}'
      Status: '{{ item.Status }}'
      Timeline: '{{ item.Timeline }}'
      ArtifactS3Location: '{{ item.ArtifactS3Location }}'
      EngineArn: '{{ item.EngineArn }}'
      RuntimeVersion: '{{ item.RuntimeVersion }}'
      VpcConfig: '{{ item.VpcConfig }}'
      VisualReference: '{{ item.VisualReference }}'
      ProvisionedResourceCleanup: '{{ item.ProvisionedResourceCleanup }}'
      BrowserConfigs: '{{ item.BrowserConfigs }}'
      EngineConfigs: '{{ item.EngineConfigs }}'
      VisualReferences: '{{ item.VisualReferences }}'
      Tags: '{{ item.Tags }}'
      ArtifactConfig: '{{ item.ArtifactConfig }}'
      DryRunConfig: '{{ item.DryRunConfig }}'
- discovery_id: aws.synthetics.getCanaryRuns
  calls:
  - action: getCanaryRuns
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.CanaryRuns }}'
    item:
      Id: '{{ item.Id }}'
      ScheduledRunId: '{{ item.ScheduledRunId }}'
      RetryAttempt: '{{ item.RetryAttempt }}'
      Name: '{{ item.Name }}'
      Status: '{{ item.Status }}'
      Timeline: '{{ item.Timeline }}'
      ArtifactS3Location: '{{ item.ArtifactS3Location }}'
      DryRunConfig: '{{ item.DryRunConfig }}'
      BrowserType: '{{ item.BrowserType }}'
- discovery_id: aws.synthetics.getGroup
  calls:
  - action: getGroup
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Group }}'
    item:
      Id: '{{ item.Id }}'
      Name: '{{ item.Name }}'
      Arn: '{{ item.Arn }}'
      Tags: '{{ item.Tags }}'
      CreatedTime: '{{ item.CreatedTime }}'
      LastModifiedTime: '{{ item.LastModifiedTime }}'
- discovery_id: aws.synthetics.listAssociatedGroups
  calls:
  - action: listAssociatedGroups
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Groups }}'
    item:
      Id: '{{ item.Id }}'
      Name: '{{ item.Name }}'
      Arn: '{{ item.Arn }}'
- discovery_id: aws.synthetics.listGroupResources
  calls:
  - action: listGroupResources
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Resources }}'
- discovery_id: aws.synthetics.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Tags }}'
checks: []
