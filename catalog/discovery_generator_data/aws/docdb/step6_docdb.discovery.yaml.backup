version: '1.0'
provider: aws
service: docdb
services:
  client: docdb
  module: boto3.client
discovery:
- discovery_id: aws.docdb.describeCertificates
  calls:
  - action: describeCertificates
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Certificates }}'
    item:
      CertificateIdentifier: '{{ item.CertificateIdentifier }}'
      CertificateType: '{{ item.CertificateType }}'
      Thumbprint: '{{ item.Thumbprint }}'
      ValidFrom: '{{ item.ValidFrom }}'
      ValidTill: '{{ item.ValidTill }}'
      CertificateArn: '{{ item.CertificateArn }}'
- discovery_id: aws.docdb.describeDbClusterParameterGroups
  calls:
  - action: describeDbClusterParameterGroups
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.DBClusterParameterGroups }}'
    item:
      DBClusterParameterGroupName: '{{ item.DBClusterParameterGroupName }}'
      DBParameterGroupFamily: '{{ item.DBParameterGroupFamily }}'
      Description: '{{ item.Description }}'
      DBClusterParameterGroupArn: '{{ item.DBClusterParameterGroupArn }}'
- discovery_id: aws.docdb.describeDbClusterSnapshots
  calls:
  - action: describeDbClusterSnapshots
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.DBClusterSnapshots }}'
    item:
      AvailabilityZones: '{{ item.AvailabilityZones }}'
      DBClusterSnapshotIdentifier: '{{ item.DBClusterSnapshotIdentifier }}'
      DBClusterIdentifier: '{{ item.DBClusterIdentifier }}'
      SnapshotCreateTime: '{{ item.SnapshotCreateTime }}'
      Engine: '{{ item.Engine }}'
      Status: '{{ item.Status }}'
      Port: '{{ item.Port }}'
      VpcId: '{{ item.VpcId }}'
      ClusterCreateTime: '{{ item.ClusterCreateTime }}'
      MasterUsername: '{{ item.MasterUsername }}'
      EngineVersion: '{{ item.EngineVersion }}'
      SnapshotType: '{{ item.SnapshotType }}'
      PercentProgress: '{{ item.PercentProgress }}'
      StorageEncrypted: '{{ item.StorageEncrypted }}'
      KmsKeyId: '{{ item.KmsKeyId }}'
      DBClusterSnapshotArn: '{{ item.DBClusterSnapshotArn }}'
      SourceDBClusterSnapshotArn: '{{ item.SourceDBClusterSnapshotArn }}'
      StorageType: '{{ item.StorageType }}'
- discovery_id: aws.docdb.describeDbClusters
  calls:
  - action: describeDbClusters
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.DBClusters }}'
    item:
      AvailabilityZones: '{{ item.AvailabilityZones }}'
      BackupRetentionPeriod: '{{ item.BackupRetentionPeriod }}'
      DBClusterIdentifier: '{{ item.DBClusterIdentifier }}'
      DBClusterParameterGroup: '{{ item.DBClusterParameterGroup }}'
      DBSubnetGroup: '{{ item.DBSubnetGroup }}'
      Status: '{{ item.Status }}'
      PercentProgress: '{{ item.PercentProgress }}'
      EarliestRestorableTime: '{{ item.EarliestRestorableTime }}'
      Endpoint: '{{ item.Endpoint }}'
      ReaderEndpoint: '{{ item.ReaderEndpoint }}'
      MultiAZ: '{{ item.MultiAZ }}'
      Engine: '{{ item.Engine }}'
      EngineVersion: '{{ item.EngineVersion }}'
      LatestRestorableTime: '{{ item.LatestRestorableTime }}'
      Port: '{{ item.Port }}'
      MasterUsername: '{{ item.MasterUsername }}'
      PreferredBackupWindow: '{{ item.PreferredBackupWindow }}'
      PreferredMaintenanceWindow: '{{ item.PreferredMaintenanceWindow }}'
      ReplicationSourceIdentifier: '{{ item.ReplicationSourceIdentifier }}'
      ReadReplicaIdentifiers: '{{ item.ReadReplicaIdentifiers }}'
      DBClusterMembers: '{{ item.DBClusterMembers }}'
      VpcSecurityGroups: '{{ item.VpcSecurityGroups }}'
      HostedZoneId: '{{ item.HostedZoneId }}'
      StorageEncrypted: '{{ item.StorageEncrypted }}'
      KmsKeyId: '{{ item.KmsKeyId }}'
      DbClusterResourceId: '{{ item.DbClusterResourceId }}'
      DBClusterArn: '{{ item.DBClusterArn }}'
      AssociatedRoles: '{{ item.AssociatedRoles }}'
      CloneGroupId: '{{ item.CloneGroupId }}'
      ClusterCreateTime: '{{ item.ClusterCreateTime }}'
      EnabledCloudwatchLogsExports: '{{ item.EnabledCloudwatchLogsExports }}'
      DeletionProtection: '{{ item.DeletionProtection }}'
      IOOptimizedNextAllowedModificationTime: '{{ item.IOOptimizedNextAllowedModificationTime
        }}'
      StorageType: '{{ item.StorageType }}'
      ServerlessV2ScalingConfiguration: '{{ item.ServerlessV2ScalingConfiguration
        }}'
      MasterUserSecret: '{{ item.MasterUserSecret }}'
      NetworkType: '{{ item.NetworkType }}'
- discovery_id: aws.docdb.describeDbEngineVersions
  calls:
  - action: describeDbEngineVersions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.DBEngineVersions }}'
    item:
      Engine: '{{ item.Engine }}'
      EngineVersion: '{{ item.EngineVersion }}'
      DBParameterGroupFamily: '{{ item.DBParameterGroupFamily }}'
      DBEngineDescription: '{{ item.DBEngineDescription }}'
      DBEngineVersionDescription: '{{ item.DBEngineVersionDescription }}'
      ValidUpgradeTarget: '{{ item.ValidUpgradeTarget }}'
      ExportableLogTypes: '{{ item.ExportableLogTypes }}'
      SupportsLogExportsToCloudwatchLogs: '{{ item.SupportsLogExportsToCloudwatchLogs
        }}'
      SupportedCACertificateIdentifiers: '{{ item.SupportedCACertificateIdentifiers
        }}'
      SupportsCertificateRotationWithoutRestart: '{{ item.SupportsCertificateRotationWithoutRestart
        }}'
      ServerlessV2FeaturesSupport: '{{ item.ServerlessV2FeaturesSupport }}'
- discovery_id: aws.docdb.describeDbInstances
  calls:
  - action: describeDbInstances
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.DBInstances }}'
    item:
      DBInstanceIdentifier: '{{ item.DBInstanceIdentifier }}'
      DBInstanceClass: '{{ item.DBInstanceClass }}'
      Engine: '{{ item.Engine }}'
      DBInstanceStatus: '{{ item.DBInstanceStatus }}'
      Endpoint: '{{ item.Endpoint }}'
      InstanceCreateTime: '{{ item.InstanceCreateTime }}'
      PreferredBackupWindow: '{{ item.PreferredBackupWindow }}'
      BackupRetentionPeriod: '{{ item.BackupRetentionPeriod }}'
      VpcSecurityGroups: '{{ item.VpcSecurityGroups }}'
      AvailabilityZone: '{{ item.AvailabilityZone }}'
      DBSubnetGroup: '{{ item.DBSubnetGroup }}'
      PreferredMaintenanceWindow: '{{ item.PreferredMaintenanceWindow }}'
      PendingModifiedValues: '{{ item.PendingModifiedValues }}'
      LatestRestorableTime: '{{ item.LatestRestorableTime }}'
      EngineVersion: '{{ item.EngineVersion }}'
      AutoMinorVersionUpgrade: '{{ item.AutoMinorVersionUpgrade }}'
      PubliclyAccessible: '{{ item.PubliclyAccessible }}'
      StatusInfos: '{{ item.StatusInfos }}'
      DBClusterIdentifier: '{{ item.DBClusterIdentifier }}'
      StorageEncrypted: '{{ item.StorageEncrypted }}'
      KmsKeyId: '{{ item.KmsKeyId }}'
      DbiResourceId: '{{ item.DbiResourceId }}'
      CACertificateIdentifier: '{{ item.CACertificateIdentifier }}'
      CopyTagsToSnapshot: '{{ item.CopyTagsToSnapshot }}'
      PromotionTier: '{{ item.PromotionTier }}'
      DBInstanceArn: '{{ item.DBInstanceArn }}'
      EnabledCloudwatchLogsExports: '{{ item.EnabledCloudwatchLogsExports }}'
      CertificateDetails: '{{ item.CertificateDetails }}'
      PerformanceInsightsEnabled: '{{ item.PerformanceInsightsEnabled }}'
      PerformanceInsightsKMSKeyId: '{{ item.PerformanceInsightsKMSKeyId }}'
- discovery_id: aws.docdb.describeDbSubnetGroups
  calls:
  - action: describeDbSubnetGroups
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.DBSubnetGroups }}'
    item:
      DBSubnetGroupName: '{{ item.DBSubnetGroupName }}'
      DBSubnetGroupDescription: '{{ item.DBSubnetGroupDescription }}'
      VpcId: '{{ item.VpcId }}'
      SubnetGroupStatus: '{{ item.SubnetGroupStatus }}'
      Subnets: '{{ item.Subnets }}'
      DBSubnetGroupArn: '{{ item.DBSubnetGroupArn }}'
      SupportedNetworkTypes: '{{ item.SupportedNetworkTypes }}'
- discovery_id: aws.docdb.describeEventCategories
  calls:
  - action: describeEventCategories
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.EventCategoriesMapList }}'
    item:
      SourceType: '{{ item.SourceType }}'
      EventCategories: '{{ item.EventCategories }}'
- discovery_id: aws.docdb.describeEventSubscriptions
  calls:
  - action: describeEventSubscriptions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.EventSubscriptionsList }}'
    item:
      CustomerAwsId: '{{ item.CustomerAwsId }}'
      CustSubscriptionId: '{{ item.CustSubscriptionId }}'
      SnsTopicArn: '{{ item.SnsTopicArn }}'
      Status: '{{ item.Status }}'
      SubscriptionCreationTime: '{{ item.SubscriptionCreationTime }}'
      SourceType: '{{ item.SourceType }}'
      SourceIdsList: '{{ item.SourceIdsList }}'
      EventCategoriesList: '{{ item.EventCategoriesList }}'
      Enabled: '{{ item.Enabled }}'
      EventSubscriptionArn: '{{ item.EventSubscriptionArn }}'
- discovery_id: aws.docdb.describeEvents
  calls:
  - action: describeEvents
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Events }}'
    item:
      SourceIdentifier: '{{ item.SourceIdentifier }}'
      SourceType: '{{ item.SourceType }}'
      Message: '{{ item.Message }}'
      EventCategories: '{{ item.EventCategories }}'
      Date: '{{ item.Date }}'
      SourceArn: '{{ item.SourceArn }}'
- discovery_id: aws.docdb.describeGlobalClusters
  calls:
  - action: describeGlobalClusters
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.GlobalClusters }}'
    item:
      GlobalClusterIdentifier: '{{ item.GlobalClusterIdentifier }}'
      GlobalClusterResourceId: '{{ item.GlobalClusterResourceId }}'
      GlobalClusterArn: '{{ item.GlobalClusterArn }}'
      Status: '{{ item.Status }}'
      Engine: '{{ item.Engine }}'
      EngineVersion: '{{ item.EngineVersion }}'
      DatabaseName: '{{ item.DatabaseName }}'
      StorageEncrypted: '{{ item.StorageEncrypted }}'
      DeletionProtection: '{{ item.DeletionProtection }}'
      GlobalClusterMembers: '{{ item.GlobalClusterMembers }}'
      FailoverState: '{{ item.FailoverState }}'
      TagList: '{{ item.TagList }}'
- discovery_id: aws.docdb.describePendingMaintenanceActions
  calls:
  - action: describePendingMaintenanceActions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.PendingMaintenanceActions }}'
    item:
      ResourceIdentifier: '{{ item.ResourceIdentifier }}'
      PendingMaintenanceActionDetails: '{{ item.PendingMaintenanceActionDetails }}'
- discovery_id: aws.docdb.describeDbClusterParameters
  calls:
  - action: describeDbClusterParameters
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Parameters }}'
    item:
      ParameterName: '{{ item.ParameterName }}'
      ParameterValue: '{{ item.ParameterValue }}'
      Description: '{{ item.Description }}'
      Source: '{{ item.Source }}'
      ApplyType: '{{ item.ApplyType }}'
      DataType: '{{ item.DataType }}'
      AllowedValues: '{{ item.AllowedValues }}'
      IsModifiable: '{{ item.IsModifiable }}'
      MinimumEngineVersion: '{{ item.MinimumEngineVersion }}'
      ApplyMethod: '{{ item.ApplyMethod }}'
- discovery_id: aws.docdb.describeDbClusterSnapshotAttributes
  calls:
  - action: describeDbClusterSnapshotAttributes
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.DBClusterSnapshotAttributesResult }}'
    item:
      DBClusterSnapshotIdentifier: '{{ item.DBClusterSnapshotIdentifier }}'
      DBClusterSnapshotAttributes: '{{ item.DBClusterSnapshotAttributes }}'
- discovery_id: aws.docdb.describeEngineDefaultClusterParameters
  calls:
  - action: describeEngineDefaultClusterParameters
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.EngineDefaults }}'
    item:
      DBParameterGroupFamily: '{{ item.DBParameterGroupFamily }}'
      Marker: '{{ item.Marker }}'
      Parameters: '{{ item.Parameters }}'
- discovery_id: aws.docdb.describeOrderableDbInstanceOptions
  calls:
  - action: describeOrderableDbInstanceOptions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.OrderableDBInstanceOptions }}'
    item:
      Engine: '{{ item.Engine }}'
      EngineVersion: '{{ item.EngineVersion }}'
      DBInstanceClass: '{{ item.DBInstanceClass }}'
      LicenseModel: '{{ item.LicenseModel }}'
      AvailabilityZones: '{{ item.AvailabilityZones }}'
      Vpc: '{{ item.Vpc }}'
      StorageType: '{{ item.StorageType }}'
- discovery_id: aws.docdb.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.TagList }}'
    item:
      Key: '{{ item.Key }}'
      Value: '{{ item.Value }}'
checks: []
