version: '1.0'
provider: aws
service: managedblockchain-query
services:
  client: managedblockchain-query
  module: boto3.client
discovery:
- discovery_id: aws.managedblockchain-query.getAssetContract
  calls:
  - action: getAssetContract
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.contractIdentifier }}'
    item:
      network: '{{ item.network }}'
      contractAddress: '{{ item.contractAddress }}'
- discovery_id: aws.managedblockchain-query.getTokenBalance
  calls:
  - action: getTokenBalance
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ownerIdentifier }}'
    item:
      address: '{{ item.address }}'
- discovery_id: aws.managedblockchain-query.getTransaction
  calls:
  - action: getTransaction
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.transaction }}'
    item:
      network: '{{ item.network }}'
      blockHash: '{{ item.blockHash }}'
      transactionHash: '{{ item.transactionHash }}'
      blockNumber: '{{ item.blockNumber }}'
      transactionTimestamp: '{{ item.transactionTimestamp }}'
      transactionIndex: '{{ item.transactionIndex }}'
      numberOfTransactions: '{{ item.numberOfTransactions }}'
      to: '{{ item.to }}'
      from: '{{ item.from }}'
      contractAddress: '{{ item.contractAddress }}'
      gasUsed: '{{ item.gasUsed }}'
      cumulativeGasUsed: '{{ item.cumulativeGasUsed }}'
      effectiveGasPrice: '{{ item.effectiveGasPrice }}'
      signatureV: '{{ item.signatureV }}'
      signatureR: '{{ item.signatureR }}'
      signatureS: '{{ item.signatureS }}'
      transactionFee: '{{ item.transactionFee }}'
      transactionId: '{{ item.transactionId }}'
      confirmationStatus: '{{ item.confirmationStatus }}'
      executionStatus: '{{ item.executionStatus }}'
- discovery_id: aws.managedblockchain-query.listAssetContracts
  calls:
  - action: listAssetContracts
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.contracts }}'
    item:
      contractIdentifier: '{{ item.contractIdentifier }}'
      tokenStandard: '{{ item.tokenStandard }}'
      deployerAddress: '{{ item.deployerAddress }}'
- discovery_id: aws.managedblockchain-query.listFilteredTransactionEvents
  calls:
  - action: listFilteredTransactionEvents
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.events }}'
    item:
      network: '{{ item.network }}'
      transactionHash: '{{ item.transactionHash }}'
      eventType: '{{ item.eventType }}'
      from: '{{ item.from }}'
      to: '{{ item.to }}'
      value: '{{ item.value }}'
      contractAddress: '{{ item.contractAddress }}'
      tokenId: '{{ item.tokenId }}'
      transactionId: '{{ item.transactionId }}'
      voutIndex: '{{ item.voutIndex }}'
      voutSpent: '{{ item.voutSpent }}'
      spentVoutTransactionId: '{{ item.spentVoutTransactionId }}'
      spentVoutTransactionHash: '{{ item.spentVoutTransactionHash }}'
      spentVoutIndex: '{{ item.spentVoutIndex }}'
      blockchainInstant: '{{ item.blockchainInstant }}'
      confirmationStatus: '{{ item.confirmationStatus }}'
- discovery_id: aws.managedblockchain-query.listTokenBalances
  calls:
  - action: listTokenBalances
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tokenBalances }}'
    item:
      ownerIdentifier: '{{ item.ownerIdentifier }}'
      tokenIdentifier: '{{ item.tokenIdentifier }}'
      balance: '{{ item.balance }}'
      atBlockchainInstant: '{{ item.atBlockchainInstant }}'
      lastUpdatedTime: '{{ item.lastUpdatedTime }}'
- discovery_id: aws.managedblockchain-query.listTransactionEvents
  calls:
  - action: listTransactionEvents
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.events }}'
    item:
      network: '{{ item.network }}'
      transactionHash: '{{ item.transactionHash }}'
      eventType: '{{ item.eventType }}'
      from: '{{ item.from }}'
      to: '{{ item.to }}'
      value: '{{ item.value }}'
      contractAddress: '{{ item.contractAddress }}'
      tokenId: '{{ item.tokenId }}'
      transactionId: '{{ item.transactionId }}'
      voutIndex: '{{ item.voutIndex }}'
      voutSpent: '{{ item.voutSpent }}'
      spentVoutTransactionId: '{{ item.spentVoutTransactionId }}'
      spentVoutTransactionHash: '{{ item.spentVoutTransactionHash }}'
      spentVoutIndex: '{{ item.spentVoutIndex }}'
      blockchainInstant: '{{ item.blockchainInstant }}'
      confirmationStatus: '{{ item.confirmationStatus }}'
- discovery_id: aws.managedblockchain-query.listTransactions
  calls:
  - action: listTransactions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.transactions }}'
    item:
      transactionHash: '{{ item.transactionHash }}'
      transactionId: '{{ item.transactionId }}'
      network: '{{ item.network }}'
      transactionTimestamp: '{{ item.transactionTimestamp }}'
      confirmationStatus: '{{ item.confirmationStatus }}'
checks: []
