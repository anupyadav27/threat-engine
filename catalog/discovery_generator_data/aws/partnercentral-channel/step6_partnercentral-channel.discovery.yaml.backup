version: '1.0'
provider: aws
service: partnercentral-channel
services:
  client: partnercentral-channel
  module: boto3.client
discovery:
- discovery_id: aws.partnercentral-channel.getRelationship
  calls:
  - action: getRelationship
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.relationshipDetail }}'
    item:
      arn: '{{ item.arn }}'
      id: '{{ item.id }}'
      revision: '{{ item.revision }}'
      catalog: '{{ item.catalog }}'
      associationType: '{{ item.associationType }}'
      programManagementAccountId: '{{ item.programManagementAccountId }}'
      associatedAccountId: '{{ item.associatedAccountId }}'
      displayName: '{{ item.displayName }}'
      resaleAccountModel: '{{ item.resaleAccountModel }}'
      sector: '{{ item.sector }}'
      createdAt: '{{ item.createdAt }}'
      updatedAt: '{{ item.updatedAt }}'
      startDate: '{{ item.startDate }}'
- discovery_id: aws.partnercentral-channel.listChannelHandshakes
  calls:
  - action: listChannelHandshakes
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
    item:
      id: '{{ item.id }}'
      arn: '{{ item.arn }}'
      catalog: '{{ item.catalog }}'
      handshakeType: '{{ item.handshakeType }}'
      ownerAccountId: '{{ item.ownerAccountId }}'
      senderAccountId: '{{ item.senderAccountId }}'
      senderDisplayName: '{{ item.senderDisplayName }}'
      receiverAccountId: '{{ item.receiverAccountId }}'
      associatedResourceId: '{{ item.associatedResourceId }}'
      detail: '{{ item.detail }}'
      createdAt: '{{ item.createdAt }}'
      updatedAt: '{{ item.updatedAt }}'
      status: '{{ item.status }}'
- discovery_id: aws.partnercentral-channel.listProgramManagementAccounts
  calls:
  - action: listProgramManagementAccounts
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
    item:
      id: '{{ item.id }}'
      revision: '{{ item.revision }}'
      catalog: '{{ item.catalog }}'
      program: '{{ item.program }}'
      displayName: '{{ item.displayName }}'
      accountId: '{{ item.accountId }}'
      arn: '{{ item.arn }}'
      createdAt: '{{ item.createdAt }}'
      updatedAt: '{{ item.updatedAt }}'
      startDate: '{{ item.startDate }}'
      status: '{{ item.status }}'
- discovery_id: aws.partnercentral-channel.listRelationships
  calls:
  - action: listRelationships
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
    item:
      arn: '{{ item.arn }}'
      id: '{{ item.id }}'
      revision: '{{ item.revision }}'
      catalog: '{{ item.catalog }}'
      associationType: '{{ item.associationType }}'
      programManagementAccountId: '{{ item.programManagementAccountId }}'
      associatedAccountId: '{{ item.associatedAccountId }}'
      displayName: '{{ item.displayName }}'
      sector: '{{ item.sector }}'
      createdAt: '{{ item.createdAt }}'
      updatedAt: '{{ item.updatedAt }}'
      startDate: '{{ item.startDate }}'
- discovery_id: aws.partnercentral-channel.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tags }}'
    item:
      key: '{{ item.key }}'
      value: '{{ item.value }}'
checks: []
