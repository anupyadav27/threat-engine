version: '1.0'
provider: aws
service: lexv2-models
services:
  client: lexv2-models
  module: boto3.client
discovery:
- discovery_id: aws.lexv2-models.listBots
  calls:
  - action: listBots
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.botSummaries }}'
    item:
      botId: '{{ item.botId }}'
      botName: '{{ item.botName }}'
      description: '{{ item.description }}'
      botStatus: '{{ item.botStatus }}'
      latestBotVersion: '{{ item.latestBotVersion }}'
      lastUpdatedDateTime: '{{ item.lastUpdatedDateTime }}'
      botType: '{{ item.botType }}'
- discovery_id: aws.lexv2-models.listExports
  calls:
  - action: listExports
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.exportSummaries }}'
    item:
      exportId: '{{ item.exportId }}'
      resourceSpecification: '{{ item.resourceSpecification }}'
      fileFormat: '{{ item.fileFormat }}'
      exportStatus: '{{ item.exportStatus }}'
      creationDateTime: '{{ item.creationDateTime }}'
      lastUpdatedDateTime: '{{ item.lastUpdatedDateTime }}'
- discovery_id: aws.lexv2-models.listImports
  calls:
  - action: listImports
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.importSummaries }}'
    item:
      importId: '{{ item.importId }}'
      importedResourceId: '{{ item.importedResourceId }}'
      importedResourceName: '{{ item.importedResourceName }}'
      importStatus: '{{ item.importStatus }}'
      mergeStrategy: '{{ item.mergeStrategy }}'
      creationDateTime: '{{ item.creationDateTime }}'
      lastUpdatedDateTime: '{{ item.lastUpdatedDateTime }}'
      importedResourceType: '{{ item.importedResourceType }}'
- discovery_id: aws.lexv2-models.listTestExecutions
  calls:
  - action: listTestExecutions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.testExecutions }}'
    item:
      testExecutionId: '{{ item.testExecutionId }}'
      creationDateTime: '{{ item.creationDateTime }}'
      lastUpdatedDateTime: '{{ item.lastUpdatedDateTime }}'
      testExecutionStatus: '{{ item.testExecutionStatus }}'
      testSetId: '{{ item.testSetId }}'
      testSetName: '{{ item.testSetName }}'
      target: '{{ item.target }}'
      apiMode: '{{ item.apiMode }}'
      testExecutionModality: '{{ item.testExecutionModality }}'
- discovery_id: aws.lexv2-models.listTestSets
  calls:
  - action: listTestSets
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.testSets }}'
    item:
      testSetId: '{{ item.testSetId }}'
      testSetName: '{{ item.testSetName }}'
      description: '{{ item.description }}'
      modality: '{{ item.modality }}'
      status: '{{ item.status }}'
      roleArn: '{{ item.roleArn }}'
      numTurns: '{{ item.numTurns }}'
      storageLocation: '{{ item.storageLocation }}'
      creationDateTime: '{{ item.creationDateTime }}'
      lastUpdatedDateTime: '{{ item.lastUpdatedDateTime }}'
- discovery_id: aws.lexv2-models.describeBot
  calls:
  - action: describeBot
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.botMembers }}'
    item:
      botMemberId: '{{ item.botMemberId }}'
      botMemberName: '{{ item.botMemberName }}'
      botMemberAliasId: '{{ item.botMemberAliasId }}'
      botMemberAliasName: '{{ item.botMemberAliasName }}'
      botMemberVersion: '{{ item.botMemberVersion }}'
- discovery_id: aws.lexv2-models.describeBotAlias
  calls:
  - action: describeBotAlias
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.botAliasHistoryEvents }}'
    item:
      botVersion: '{{ item.botVersion }}'
      startDate: '{{ item.startDate }}'
      endDate: '{{ item.endDate }}'
- discovery_id: aws.lexv2-models.describeBotLocale
  calls:
  - action: describeBotLocale
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.failureReasons }}'
- discovery_id: aws.lexv2-models.describeBotRecommendation
  calls:
  - action: describeBotRecommendation
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.failureReasons }}'
- discovery_id: aws.lexv2-models.describeBotReplica
  calls:
  - action: describeBotReplica
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.failureReasons }}'
- discovery_id: aws.lexv2-models.describeBotResourceGeneration
  calls:
  - action: describeBotResourceGeneration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.failureReasons }}'
- discovery_id: aws.lexv2-models.describeBotVersion
  calls:
  - action: describeBotVersion
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.failureReasons }}'
- discovery_id: aws.lexv2-models.describeCustomVocabularyMetadata
  calls:
  - action: describeCustomVocabularyMetadata
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.botId }}'
- discovery_id: aws.lexv2-models.describeExport
  calls:
  - action: describeExport
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.failureReasons }}'
- discovery_id: aws.lexv2-models.describeImport
  calls:
  - action: describeImport
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.failureReasons }}'
- discovery_id: aws.lexv2-models.describeIntent
  calls:
  - action: describeIntent
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.sampleUtterances }}'
    item:
      utterance: '{{ item.utterance }}'
- discovery_id: aws.lexv2-models.describeResourcePolicy
  calls:
  - action: describeResourcePolicy
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.resourceArn }}'
- discovery_id: aws.lexv2-models.describeSlot
  calls:
  - action: describeSlot
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.valueElicitationSetting }}'
    item:
      defaultValueSpecification: '{{ item.defaultValueSpecification }}'
      slotConstraint: '{{ item.slotConstraint }}'
      promptSpecification: '{{ item.promptSpecification }}'
      sampleUtterances: '{{ item.sampleUtterances }}'
      waitAndContinueSpecification: '{{ item.waitAndContinueSpecification }}'
      slotCaptureSetting: '{{ item.slotCaptureSetting }}'
      slotResolutionSetting: '{{ item.slotResolutionSetting }}'
- discovery_id: aws.lexv2-models.describeSlotType
  calls:
  - action: describeSlotType
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.slotTypeValues }}'
    item:
      sampleValue: '{{ item.sampleValue }}'
      synonyms: '{{ item.synonyms }}'
- discovery_id: aws.lexv2-models.describeTestExecution
  calls:
  - action: describeTestExecution
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.failureReasons }}'
- discovery_id: aws.lexv2-models.describeTestSet
  calls:
  - action: describeTestSet
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.storageLocation }}'
    item:
      s3BucketName: '{{ item.s3BucketName }}'
      s3Path: '{{ item.s3Path }}'
      kmsKeyArn: '{{ item.kmsKeyArn }}'
- discovery_id: aws.lexv2-models.describeTestSetDiscrepancyReport
  calls:
  - action: describeTestSetDiscrepancyReport
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.failureReasons }}'
- discovery_id: aws.lexv2-models.describeTestSetGeneration
  calls:
  - action: describeTestSetGeneration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.failureReasons }}'
- discovery_id: aws.lexv2-models.getTestExecutionArtifactsUrl
  calls:
  - action: getTestExecutionArtifactsUrl
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.testExecutionId }}'
- discovery_id: aws.lexv2-models.listAggregatedUtterances
  calls:
  - action: listAggregatedUtterances
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.aggregatedUtterancesSummaries }}'
    item:
      utterance: '{{ item.utterance }}'
      hitCount: '{{ item.hitCount }}'
      missedCount: '{{ item.missedCount }}'
      utteranceFirstRecordedInAggregationDuration: '{{ item.utteranceFirstRecordedInAggregationDuration
        }}'
      utteranceLastRecordedInAggregationDuration: '{{ item.utteranceLastRecordedInAggregationDuration
        }}'
      containsDataFromDeletedResources: '{{ item.containsDataFromDeletedResources
        }}'
- discovery_id: aws.lexv2-models.listBotAliasReplicas
  calls:
