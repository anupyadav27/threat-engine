version: '1.0'
provider: aws
service: migrationhubstrategy
services:
  client: migrationhubstrategy
  module: boto3.client
discovery:
- discovery_id: aws.migrationhubstrategy.getLatestAssessmentId
  calls:
  - action: getLatestAssessmentId
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.id }}'
- discovery_id: aws.migrationhubstrategy.getPortfolioPreferences
  calls:
  - action: getPortfolioPreferences
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.applicationPreferences }}'
    item:
      managementPreference: '{{ item.managementPreference }}'
- discovery_id: aws.migrationhubstrategy.getPortfolioSummary
  calls:
  - action: getPortfolioSummary
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.assessmentSummary }}'
    item:
      antipatternReportS3Object: '{{ item.antipatternReportS3Object }}'
      antipatternReportStatus: '{{ item.antipatternReportStatus }}'
      antipatternReportStatusMessage: '{{ item.antipatternReportStatusMessage }}'
      lastAnalyzedTimestamp: '{{ item.lastAnalyzedTimestamp }}'
      listAntipatternSeveritySummary: '{{ item.listAntipatternSeveritySummary }}'
      listApplicationComponentStatusSummary: '{{ item.listApplicationComponentStatusSummary
        }}'
      listApplicationComponentStrategySummary: '{{ item.listApplicationComponentStrategySummary
        }}'
      listApplicationComponentSummary: '{{ item.listApplicationComponentSummary }}'
      listServerStatusSummary: '{{ item.listServerStatusSummary }}'
      listServerStrategySummary: '{{ item.listServerStrategySummary }}'
      listServerSummary: '{{ item.listServerSummary }}'
- discovery_id: aws.migrationhubstrategy.listAnalyzableServers
  calls:
  - action: listAnalyzableServers
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.analyzableServers }}'
    item:
      hostname: '{{ item.hostname }}'
      ipAddress: '{{ item.ipAddress }}'
      source: '{{ item.source }}'
      vmId: '{{ item.vmId }}'
- discovery_id: aws.migrationhubstrategy.listApplicationComponents
  calls:
  - action: listApplicationComponents
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.applicationComponentInfos }}'
    item:
      analysisStatus: '{{ item.analysisStatus }}'
      antipatternReportS3Object: '{{ item.antipatternReportS3Object }}'
      antipatternReportStatus: '{{ item.antipatternReportStatus }}'
      antipatternReportStatusMessage: '{{ item.antipatternReportStatusMessage }}'
      appType: '{{ item.appType }}'
      appUnitError: '{{ item.appUnitError }}'
      associatedServerId: '{{ item.associatedServerId }}'
      databaseConfigDetail: '{{ item.databaseConfigDetail }}'
      id: '{{ item.id }}'
      inclusionStatus: '{{ item.inclusionStatus }}'
      lastAnalyzedTimestamp: '{{ item.lastAnalyzedTimestamp }}'
      listAntipatternSeveritySummary: '{{ item.listAntipatternSeveritySummary }}'
      moreServerAssociationExists: '{{ item.moreServerAssociationExists }}'
      name: '{{ item.name }}'
      osDriver: '{{ item.osDriver }}'
      osVersion: '{{ item.osVersion }}'
      recommendationSet: '{{ item.recommendationSet }}'
      resourceSubType: '{{ item.resourceSubType }}'
      resultList: '{{ item.resultList }}'
      runtimeStatus: '{{ item.runtimeStatus }}'
      runtimeStatusMessage: '{{ item.runtimeStatusMessage }}'
      sourceCodeRepositories: '{{ item.sourceCodeRepositories }}'
      statusMessage: '{{ item.statusMessage }}'
- discovery_id: aws.migrationhubstrategy.listCollectors
  calls:
  - action: listCollectors
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Collectors }}'
    item:
      collectorHealth: '{{ item.collectorHealth }}'
      collectorId: '{{ item.collectorId }}'
      collectorVersion: '{{ item.collectorVersion }}'
      configurationSummary: '{{ item.configurationSummary }}'
      hostName: '{{ item.hostName }}'
      ipAddress: '{{ item.ipAddress }}'
      lastActivityTimeStamp: '{{ item.lastActivityTimeStamp }}'
      registeredTimeStamp: '{{ item.registeredTimeStamp }}'
- discovery_id: aws.migrationhubstrategy.listImportFileTask
  calls:
  - action: listImportFileTask
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.taskInfos }}'
    item:
      completionTime: '{{ item.completionTime }}'
      id: '{{ item.id }}'
      importName: '{{ item.importName }}'
      inputS3Bucket: '{{ item.inputS3Bucket }}'
      inputS3Key: '{{ item.inputS3Key }}'
      numberOfRecordsFailed: '{{ item.numberOfRecordsFailed }}'
      numberOfRecordsSuccess: '{{ item.numberOfRecordsSuccess }}'
      startTime: '{{ item.startTime }}'
      status: '{{ item.status }}'
      statusReportS3Bucket: '{{ item.statusReportS3Bucket }}'
      statusReportS3Key: '{{ item.statusReportS3Key }}'
- discovery_id: aws.migrationhubstrategy.listServers
  calls:
  - action: listServers
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.serverInfos }}'
    item:
      antipatternReportS3Object: '{{ item.antipatternReportS3Object }}'
      antipatternReportStatus: '{{ item.antipatternReportStatus }}'
      antipatternReportStatusMessage: '{{ item.antipatternReportStatusMessage }}'
      applicationComponentStrategySummary: '{{ item.applicationComponentStrategySummary
        }}'
      dataCollectionStatus: '{{ item.dataCollectionStatus }}'
      id: '{{ item.id }}'
      lastAnalyzedTimestamp: '{{ item.lastAnalyzedTimestamp }}'
      listAntipatternSeveritySummary: '{{ item.listAntipatternSeveritySummary }}'
      name: '{{ item.name }}'
      recommendationSet: '{{ item.recommendationSet }}'
      serverError: '{{ item.serverError }}'
      serverType: '{{ item.serverType }}'
      statusMessage: '{{ item.statusMessage }}'
      systemInfo: '{{ item.systemInfo }}'
- discovery_id: aws.migrationhubstrategy.getApplicationComponentDetails
  calls:
  - action: getApplicationComponentDetails
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.associatedApplications }}'
    item:
      id: '{{ item.id }}'
      name: '{{ item.name }}'
- discovery_id: aws.migrationhubstrategy.getApplicationComponentStrategies
  calls:
  - action: getApplicationComponentStrategies
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.applicationComponentStrategies }}'
    item:
      isPreferred: '{{ item.isPreferred }}'
      recommendation: '{{ item.recommendation }}'
      status: '{{ item.status }}'
- discovery_id: aws.migrationhubstrategy.getAssessment
  calls:
  - action: getAssessment
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.assessmentTargets }}'
    item:
      condition: '{{ item.condition }}'
      name: '{{ item.name }}'
      values: '{{ item.values }}'
- discovery_id: aws.migrationhubstrategy.getImportFileTask
  calls:
  - action: getImportFileTask
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.completionTime }}'
- discovery_id: aws.migrationhubstrategy.getRecommendationReportDetails
  calls:
  - action: getRecommendationReportDetails
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.recommendationReportDetails }}'
    item:
      completionTime: '{{ item.completionTime }}'
      s3Bucket: '{{ item.s3Bucket }}'
      s3Keys: '{{ item.s3Keys }}'
      startTime: '{{ item.startTime }}'
      status: '{{ item.status }}'
      statusMessage: '{{ item.statusMessage }}'
- discovery_id: aws.migrationhubstrategy.getServerDetails
  calls:
  - action: getServerDetails
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.associatedApplications }}'
    item:
      id: '{{ item.id }}'
      name: '{{ item.name }}'
- discovery_id: aws.migrationhubstrategy.getServerStrategies
  calls:
  - action: getServerStrategies
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.serverStrategies }}'
    item:
      isPreferred: '{{ item.isPreferred }}'
      numberOfApplicationComponents: '{{ item.numberOfApplicationComponents }}'
      recommendation: '{{ item.recommendation }}'
      status: '{{ item.status }}'
checks: []
