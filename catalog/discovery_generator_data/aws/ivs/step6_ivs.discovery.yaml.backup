version: '1.0'
provider: aws
service: ivs
services:
  client: ivs
  module: boto3.client
discovery:
- discovery_id: aws.ivs.listChannels
  calls:
  - action: listChannels
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.channels }}'
    item:
      arn: '{{ item.arn }}'
      authorized: '{{ item.authorized }}'
      insecureIngest: '{{ item.insecureIngest }}'
      latencyMode: '{{ item.latencyMode }}'
      name: '{{ item.name }}'
      playbackRestrictionPolicyArn: '{{ item.playbackRestrictionPolicyArn }}'
      preset: '{{ item.preset }}'
      recordingConfigurationArn: '{{ item.recordingConfigurationArn }}'
      tags: '{{ item.tags }}'
      type: '{{ item.type }}'
- discovery_id: aws.ivs.listPlaybackKeyPairs
  calls:
  - action: listPlaybackKeyPairs
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.keyPairs }}'
    item:
      arn: '{{ item.arn }}'
      name: '{{ item.name }}'
      tags: '{{ item.tags }}'
- discovery_id: aws.ivs.listPlaybackRestrictionPolicies
  calls:
  - action: listPlaybackRestrictionPolicies
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.playbackRestrictionPolicies }}'
    item:
      allowedCountries: '{{ item.allowedCountries }}'
      allowedOrigins: '{{ item.allowedOrigins }}'
      arn: '{{ item.arn }}'
      enableStrictOriginEnforcement: '{{ item.enableStrictOriginEnforcement }}'
      name: '{{ item.name }}'
      tags: '{{ item.tags }}'
- discovery_id: aws.ivs.listRecordingConfigurations
  calls:
  - action: listRecordingConfigurations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.recordingConfigurations }}'
    item:
      arn: '{{ item.arn }}'
      destinationConfiguration: '{{ item.destinationConfiguration }}'
      name: '{{ item.name }}'
      state: '{{ item.state }}'
      tags: '{{ item.tags }}'
- discovery_id: aws.ivs.listStreams
  calls:
  - action: listStreams
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.streams }}'
    item:
      channelArn: '{{ item.channelArn }}'
      health: '{{ item.health }}'
      startTime: '{{ item.startTime }}'
      state: '{{ item.state }}'
      streamId: '{{ item.streamId }}'
      viewerCount: '{{ item.viewerCount }}'
- discovery_id: aws.ivs.getChannel
  calls:
  - action: getChannel
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.channel }}'
    item:
      arn: '{{ item.arn }}'
      authorized: '{{ item.authorized }}'
      containerFormat: '{{ item.containerFormat }}'
      ingestEndpoint: '{{ item.ingestEndpoint }}'
      insecureIngest: '{{ item.insecureIngest }}'
      latencyMode: '{{ item.latencyMode }}'
      multitrackInputConfiguration: '{{ item.multitrackInputConfiguration }}'
      name: '{{ item.name }}'
      playbackRestrictionPolicyArn: '{{ item.playbackRestrictionPolicyArn }}'
      playbackUrl: '{{ item.playbackUrl }}'
      preset: '{{ item.preset }}'
      recordingConfigurationArn: '{{ item.recordingConfigurationArn }}'
      srt: '{{ item.srt }}'
      tags: '{{ item.tags }}'
      type: '{{ item.type }}'
- discovery_id: aws.ivs.getPlaybackKeyPair
  calls:
  - action: getPlaybackKeyPair
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.keyPair }}'
    item:
      arn: '{{ item.arn }}'
      fingerprint: '{{ item.fingerprint }}'
      name: '{{ item.name }}'
      tags: '{{ item.tags }}'
- discovery_id: aws.ivs.getPlaybackRestrictionPolicy
  calls:
  - action: getPlaybackRestrictionPolicy
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.playbackRestrictionPolicy }}'
    item:
      allowedCountries: '{{ item.allowedCountries }}'
      allowedOrigins: '{{ item.allowedOrigins }}'
      arn: '{{ item.arn }}'
      enableStrictOriginEnforcement: '{{ item.enableStrictOriginEnforcement }}'
      name: '{{ item.name }}'
      tags: '{{ item.tags }}'
- discovery_id: aws.ivs.getRecordingConfiguration
  calls:
  - action: getRecordingConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.recordingConfiguration }}'
    item:
      arn: '{{ item.arn }}'
      destinationConfiguration: '{{ item.destinationConfiguration }}'
      name: '{{ item.name }}'
      recordingReconnectWindowSeconds: '{{ item.recordingReconnectWindowSeconds }}'
      renditionConfiguration: '{{ item.renditionConfiguration }}'
      state: '{{ item.state }}'
      tags: '{{ item.tags }}'
      thumbnailConfiguration: '{{ item.thumbnailConfiguration }}'
- discovery_id: aws.ivs.getStream
  calls:
  - action: getStream
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.stream }}'
    item:
      channelArn: '{{ item.channelArn }}'
      health: '{{ item.health }}'
      playbackUrl: '{{ item.playbackUrl }}'
      startTime: '{{ item.startTime }}'
      state: '{{ item.state }}'
      streamId: '{{ item.streamId }}'
      viewerCount: '{{ item.viewerCount }}'
- discovery_id: aws.ivs.getStreamKey
  calls:
  - action: getStreamKey
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.streamKey }}'
    item:
      arn: '{{ item.arn }}'
      channelArn: '{{ item.channelArn }}'
      tags: '{{ item.tags }}'
      value: '{{ item.value }}'
- discovery_id: aws.ivs.getStreamSession
  calls:
  - action: getStreamSession
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.streamSession }}'
    item:
      channel: '{{ item.channel }}'
      endTime: '{{ item.endTime }}'
      ingestConfiguration: '{{ item.ingestConfiguration }}'
      ingestConfigurations: '{{ item.ingestConfigurations }}'
      recordingConfiguration: '{{ item.recordingConfiguration }}'
      startTime: '{{ item.startTime }}'
      streamId: '{{ item.streamId }}'
      truncatedEvents: '{{ item.truncatedEvents }}'
- discovery_id: aws.ivs.listStreamKeys
  calls:
  - action: listStreamKeys
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.streamKeys }}'
    item:
      arn: '{{ item.arn }}'
      channelArn: '{{ item.channelArn }}'
      tags: '{{ item.tags }}'
- discovery_id: aws.ivs.listStreamSessions
  calls:
  - action: listStreamSessions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.streamSessions }}'
    item:
      endTime: '{{ item.endTime }}'
      hasErrorEvent: '{{ item.hasErrorEvent }}'
      startTime: '{{ item.startTime }}'
      streamId: '{{ item.streamId }}'
- discovery_id: aws.ivs.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tags }}'
checks: []
