version: '1.0'
provider: aws
service: dataexchange
services:
  client: dataexchange
  module: boto3.client
discovery:
- discovery_id: aws.dataexchange.listDataGrants
  calls:
  - action: listDataGrants
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.DataGrantSummaries }}'
    item:
      Name: '{{ item.Name }}'
      SenderPrincipal: '{{ item.SenderPrincipal }}'
      ReceiverPrincipal: '{{ item.ReceiverPrincipal }}'
      AcceptanceState: '{{ item.AcceptanceState }}'
      AcceptedAt: '{{ item.AcceptedAt }}'
      EndsAt: '{{ item.EndsAt }}'
      DataSetId: '{{ item.DataSetId }}'
      SourceDataSetId: '{{ item.SourceDataSetId }}'
      Id: '{{ item.Id }}'
      Arn: '{{ item.Arn }}'
      CreatedAt: '{{ item.CreatedAt }}'
      UpdatedAt: '{{ item.UpdatedAt }}'
- discovery_id: aws.dataexchange.listDataSets
  calls:
  - action: listDataSets
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.DataSets }}'
    item:
      Arn: '{{ item.Arn }}'
      AssetType: '{{ item.AssetType }}'
      CreatedAt: '{{ item.CreatedAt }}'
      Description: '{{ item.Description }}'
      Id: '{{ item.Id }}'
      Name: '{{ item.Name }}'
      Origin: '{{ item.Origin }}'
      OriginDetails: '{{ item.OriginDetails }}'
      SourceId: '{{ item.SourceId }}'
      UpdatedAt: '{{ item.UpdatedAt }}'
- discovery_id: aws.dataexchange.listEventActions
  calls:
  - action: listEventActions
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.EventActions }}'
    item:
      Action: '{{ item.Action }}'
      Arn: '{{ item.Arn }}'
      CreatedAt: '{{ item.CreatedAt }}'
      Event: '{{ item.Event }}'
      Id: '{{ item.Id }}'
      UpdatedAt: '{{ item.UpdatedAt }}'
- discovery_id: aws.dataexchange.listJobs
  calls:
  - action: listJobs
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Jobs }}'
    item:
      Arn: '{{ item.Arn }}'
      CreatedAt: '{{ item.CreatedAt }}'
      Details: '{{ item.Details }}'
      Errors: '{{ item.Errors }}'
      Id: '{{ item.Id }}'
      State: '{{ item.State }}'
      Type: '{{ item.Type }}'
      UpdatedAt: '{{ item.UpdatedAt }}'
- discovery_id: aws.dataexchange.listReceivedDataGrants
  calls:
  - action: listReceivedDataGrants
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.DataGrantSummaries }}'
    item:
      Name: '{{ item.Name }}'
      SenderPrincipal: '{{ item.SenderPrincipal }}'
      ReceiverPrincipal: '{{ item.ReceiverPrincipal }}'
      AcceptanceState: '{{ item.AcceptanceState }}'
      AcceptedAt: '{{ item.AcceptedAt }}'
      EndsAt: '{{ item.EndsAt }}'
      DataSetId: '{{ item.DataSetId }}'
      Id: '{{ item.Id }}'
      Arn: '{{ item.Arn }}'
      CreatedAt: '{{ item.CreatedAt }}'
      UpdatedAt: '{{ item.UpdatedAt }}'
- discovery_id: aws.dataexchange.getAsset
  calls:
  - action: getAsset
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AssetDetails }}'
    item:
      S3SnapshotAsset: '{{ item.S3SnapshotAsset }}'
      RedshiftDataShareAsset: '{{ item.RedshiftDataShareAsset }}'
      ApiGatewayApiAsset: '{{ item.ApiGatewayApiAsset }}'
      S3DataAccessAsset: '{{ item.S3DataAccessAsset }}'
      LakeFormationDataPermissionAsset: '{{ item.LakeFormationDataPermissionAsset
        }}'
- discovery_id: aws.dataexchange.getDataGrant
  calls:
  - action: getDataGrant
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Name }}'
- discovery_id: aws.dataexchange.getDataSet
  calls:
  - action: getDataSet
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.OriginDetails }}'
    item:
      ProductId: '{{ item.ProductId }}'
      DataGrantId: '{{ item.DataGrantId }}'
- discovery_id: aws.dataexchange.getEventAction
  calls:
  - action: getEventAction
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Action }}'
    item:
      ExportRevisionToS3: '{{ item.ExportRevisionToS3 }}'
- discovery_id: aws.dataexchange.getJob
  calls:
  - action: getJob
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Errors }}'
    item:
      Code: '{{ item.Code }}'
      Details: '{{ item.Details }}'
      LimitName: '{{ item.LimitName }}'
      LimitValue: '{{ item.LimitValue }}'
      Message: '{{ item.Message }}'
      ResourceId: '{{ item.ResourceId }}'
      ResourceType: '{{ item.ResourceType }}'
- discovery_id: aws.dataexchange.getReceivedDataGrant
  calls:
  - action: getReceivedDataGrant
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Name }}'
- discovery_id: aws.dataexchange.getRevision
  calls:
  - action: getRevision
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Arn }}'
- discovery_id: aws.dataexchange.listDataSetRevisions
  calls:
  - action: listDataSetRevisions
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Revisions }}'
    item:
      Arn: '{{ item.Arn }}'
      Comment: '{{ item.Comment }}'
      CreatedAt: '{{ item.CreatedAt }}'
      DataSetId: '{{ item.DataSetId }}'
      Finalized: '{{ item.Finalized }}'
      Id: '{{ item.Id }}'
      SourceId: '{{ item.SourceId }}'
      UpdatedAt: '{{ item.UpdatedAt }}'
      RevocationComment: '{{ item.RevocationComment }}'
      Revoked: '{{ item.Revoked }}'
      RevokedAt: '{{ item.RevokedAt }}'
- discovery_id: aws.dataexchange.listRevisionAssets
  calls:
  - action: listRevisionAssets
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Assets }}'
    item:
      Arn: '{{ item.Arn }}'
      AssetDetails: '{{ item.AssetDetails }}'
      AssetType: '{{ item.AssetType }}'
      CreatedAt: '{{ item.CreatedAt }}'
      DataSetId: '{{ item.DataSetId }}'
      Id: '{{ item.Id }}'
      Name: '{{ item.Name }}'
      RevisionId: '{{ item.RevisionId }}'
      SourceId: '{{ item.SourceId }}'
      UpdatedAt: '{{ item.UpdatedAt }}'
- discovery_id: aws.dataexchange.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Tags }}'
checks: []
