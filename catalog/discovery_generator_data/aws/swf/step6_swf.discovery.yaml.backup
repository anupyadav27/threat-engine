version: '1.0'
provider: aws
service: swf
services:
  client: swf
  module: boto3.client
discovery:
- discovery_id: aws.swf.describeActivityType
  calls:
  - action: describeActivityType
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.typeInfo }}'
    item:
      activityType: '{{ item.activityType }}'
      status: '{{ item.status }}'
      description: '{{ item.description }}'
      creationDate: '{{ item.creationDate }}'
      deprecationDate: '{{ item.deprecationDate }}'
- discovery_id: aws.swf.describeDomain
  calls:
  - action: describeDomain
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.domainInfo }}'
    item:
      name: '{{ item.name }}'
      status: '{{ item.status }}'
      description: '{{ item.description }}'
      arn: '{{ item.arn }}'
- discovery_id: aws.swf.describeWorkflowExecution
  calls:
  - action: describeWorkflowExecution
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.executionInfo }}'
    item:
      execution: '{{ item.execution }}'
      workflowType: '{{ item.workflowType }}'
      startTimestamp: '{{ item.startTimestamp }}'
      closeTimestamp: '{{ item.closeTimestamp }}'
      executionStatus: '{{ item.executionStatus }}'
      closeStatus: '{{ item.closeStatus }}'
      parent: '{{ item.parent }}'
      tagList: '{{ item.tagList }}'
      cancelRequested: '{{ item.cancelRequested }}'
- discovery_id: aws.swf.describeWorkflowType
  calls:
  - action: describeWorkflowType
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.typeInfo }}'
    item:
      workflowType: '{{ item.workflowType }}'
      status: '{{ item.status }}'
      description: '{{ item.description }}'
      creationDate: '{{ item.creationDate }}'
      deprecationDate: '{{ item.deprecationDate }}'
- discovery_id: aws.swf.getWorkflowExecutionHistory
  calls:
  - action: getWorkflowExecutionHistory
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.events }}'
    item:
      eventTimestamp: '{{ item.eventTimestamp }}'
      eventType: '{{ item.eventType }}'
      eventId: '{{ item.eventId }}'
      workflowExecutionStartedEventAttributes: '{{ item.workflowExecutionStartedEventAttributes
        }}'
      workflowExecutionCompletedEventAttributes: '{{ item.workflowExecutionCompletedEventAttributes
        }}'
      completeWorkflowExecutionFailedEventAttributes: '{{ item.completeWorkflowExecutionFailedEventAttributes
        }}'
      workflowExecutionFailedEventAttributes: '{{ item.workflowExecutionFailedEventAttributes
        }}'
      failWorkflowExecutionFailedEventAttributes: '{{ item.failWorkflowExecutionFailedEventAttributes
        }}'
      workflowExecutionTimedOutEventAttributes: '{{ item.workflowExecutionTimedOutEventAttributes
        }}'
      workflowExecutionCanceledEventAttributes: '{{ item.workflowExecutionCanceledEventAttributes
        }}'
      cancelWorkflowExecutionFailedEventAttributes: '{{ item.cancelWorkflowExecutionFailedEventAttributes
        }}'
      workflowExecutionContinuedAsNewEventAttributes: '{{ item.workflowExecutionContinuedAsNewEventAttributes
        }}'
      continueAsNewWorkflowExecutionFailedEventAttributes: '{{ item.continueAsNewWorkflowExecutionFailedEventAttributes
        }}'
      workflowExecutionTerminatedEventAttributes: '{{ item.workflowExecutionTerminatedEventAttributes
        }}'
      workflowExecutionCancelRequestedEventAttributes: '{{ item.workflowExecutionCancelRequestedEventAttributes
        }}'
      decisionTaskScheduledEventAttributes: '{{ item.decisionTaskScheduledEventAttributes
        }}'
      decisionTaskStartedEventAttributes: '{{ item.decisionTaskStartedEventAttributes
        }}'
      decisionTaskCompletedEventAttributes: '{{ item.decisionTaskCompletedEventAttributes
        }}'
      decisionTaskTimedOutEventAttributes: '{{ item.decisionTaskTimedOutEventAttributes
        }}'
      activityTaskScheduledEventAttributes: '{{ item.activityTaskScheduledEventAttributes
        }}'
      activityTaskStartedEventAttributes: '{{ item.activityTaskStartedEventAttributes
        }}'
      activityTaskCompletedEventAttributes: '{{ item.activityTaskCompletedEventAttributes
        }}'
      activityTaskFailedEventAttributes: '{{ item.activityTaskFailedEventAttributes
        }}'
      activityTaskTimedOutEventAttributes: '{{ item.activityTaskTimedOutEventAttributes
        }}'
      activityTaskCanceledEventAttributes: '{{ item.activityTaskCanceledEventAttributes
        }}'
      activityTaskCancelRequestedEventAttributes: '{{ item.activityTaskCancelRequestedEventAttributes
        }}'
      workflowExecutionSignaledEventAttributes: '{{ item.workflowExecutionSignaledEventAttributes
        }}'
      markerRecordedEventAttributes: '{{ item.markerRecordedEventAttributes }}'
      recordMarkerFailedEventAttributes: '{{ item.recordMarkerFailedEventAttributes
        }}'
      timerStartedEventAttributes: '{{ item.timerStartedEventAttributes }}'
      timerFiredEventAttributes: '{{ item.timerFiredEventAttributes }}'
      timerCanceledEventAttributes: '{{ item.timerCanceledEventAttributes }}'
      startChildWorkflowExecutionInitiatedEventAttributes: '{{ item.startChildWorkflowExecutionInitiatedEventAttributes
        }}'
      childWorkflowExecutionStartedEventAttributes: '{{ item.childWorkflowExecutionStartedEventAttributes
        }}'
      childWorkflowExecutionCompletedEventAttributes: '{{ item.childWorkflowExecutionCompletedEventAttributes
        }}'
      childWorkflowExecutionFailedEventAttributes: '{{ item.childWorkflowExecutionFailedEventAttributes
        }}'
      childWorkflowExecutionTimedOutEventAttributes: '{{ item.childWorkflowExecutionTimedOutEventAttributes
        }}'
      childWorkflowExecutionCanceledEventAttributes: '{{ item.childWorkflowExecutionCanceledEventAttributes
        }}'
      childWorkflowExecutionTerminatedEventAttributes: '{{ item.childWorkflowExecutionTerminatedEventAttributes
        }}'
      signalExternalWorkflowExecutionInitiatedEventAttributes: '{{ item.signalExternalWorkflowExecutionInitiatedEventAttributes
        }}'
      externalWorkflowExecutionSignaledEventAttributes: '{{ item.externalWorkflowExecutionSignaledEventAttributes
        }}'
      signalExternalWorkflowExecutionFailedEventAttributes: '{{ item.signalExternalWorkflowExecutionFailedEventAttributes
        }}'
      externalWorkflowExecutionCancelRequestedEventAttributes: '{{ item.externalWorkflowExecutionCancelRequestedEventAttributes
        }}'
      requestCancelExternalWorkflowExecutionInitiatedEventAttributes: '{{ item.requestCancelExternalWorkflowExecutionInitiatedEventAttributes
        }}'
      requestCancelExternalWorkflowExecutionFailedEventAttributes: '{{ item.requestCancelExternalWorkflowExecutionFailedEventAttributes
        }}'
      scheduleActivityTaskFailedEventAttributes: '{{ item.scheduleActivityTaskFailedEventAttributes
        }}'
      requestCancelActivityTaskFailedEventAttributes: '{{ item.requestCancelActivityTaskFailedEventAttributes
        }}'
      startTimerFailedEventAttributes: '{{ item.startTimerFailedEventAttributes }}'
      cancelTimerFailedEventAttributes: '{{ item.cancelTimerFailedEventAttributes
        }}'
      startChildWorkflowExecutionFailedEventAttributes: '{{ item.startChildWorkflowExecutionFailedEventAttributes
        }}'
      lambdaFunctionScheduledEventAttributes: '{{ item.lambdaFunctionScheduledEventAttributes
        }}'
      lambdaFunctionStartedEventAttributes: '{{ item.lambdaFunctionStartedEventAttributes
        }}'
      lambdaFunctionCompletedEventAttributes: '{{ item.lambdaFunctionCompletedEventAttributes
        }}'
      lambdaFunctionFailedEventAttributes: '{{ item.lambdaFunctionFailedEventAttributes
        }}'
      lambdaFunctionTimedOutEventAttributes: '{{ item.lambdaFunctionTimedOutEventAttributes
        }}'
      scheduleLambdaFunctionFailedEventAttributes: '{{ item.scheduleLambdaFunctionFailedEventAttributes
        }}'
      startLambdaFunctionFailedEventAttributes: '{{ item.startLambdaFunctionFailedEventAttributes
        }}'
- discovery_id: aws.swf.listActivityTypes
  calls:
  - action: listActivityTypes
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.typeInfos }}'
    item:
      activityType: '{{ item.activityType }}'
      status: '{{ item.status }}'
      description: '{{ item.description }}'
      creationDate: '{{ item.creationDate }}'
      deprecationDate: '{{ item.deprecationDate }}'
- discovery_id: aws.swf.listClosedWorkflowExecutions
  calls:
  - action: listClosedWorkflowExecutions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.executionInfos }}'
    item:
      execution: '{{ item.execution }}'
      workflowType: '{{ item.workflowType }}'
      startTimestamp: '{{ item.startTimestamp }}'
      closeTimestamp: '{{ item.closeTimestamp }}'
      executionStatus: '{{ item.executionStatus }}'
      closeStatus: '{{ item.closeStatus }}'
      parent: '{{ item.parent }}'
      tagList: '{{ item.tagList }}'
      cancelRequested: '{{ item.cancelRequested }}'
- discovery_id: aws.swf.listDomains
  calls:
  - action: listDomains
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.domainInfos }}'
    item:
      name: '{{ item.name }}'
      status: '{{ item.status }}'
      description: '{{ item.description }}'
      arn: '{{ item.arn }}'
- discovery_id: aws.swf.listOpenWorkflowExecutions
  calls:
  - action: listOpenWorkflowExecutions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.executionInfos }}'
    item:
      execution: '{{ item.execution }}'
      workflowType: '{{ item.workflowType }}'
      startTimestamp: '{{ item.startTimestamp }}'
      closeTimestamp: '{{ item.closeTimestamp }}'
      executionStatus: '{{ item.executionStatus }}'
      closeStatus: '{{ item.closeStatus }}'
      parent: '{{ item.parent }}'
      tagList: '{{ item.tagList }}'
      cancelRequested: '{{ item.cancelRequested }}'
- discovery_id: aws.swf.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tags }}'
    item:
      key: '{{ item.key }}'
      value: '{{ item.value }}'
- discovery_id: aws.swf.listWorkflowTypes
  calls:
  - action: listWorkflowTypes
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.typeInfos }}'
    item:
      workflowType: '{{ item.workflowType }}'
      status: '{{ item.status }}'
      description: '{{ item.description }}'
      creationDate: '{{ item.creationDate }}'
      deprecationDate: '{{ item.deprecationDate }}'
checks: []
