      ModelVersion: '{{ response.ComprehendMedicalAsyncJobProperties.ModelVersion
        }}'
      OutputDataConfig: '{{ response.ComprehendMedicalAsyncJobProperties.OutputDataConfig
        }}'
      SubmitTime: '{{ response.ComprehendMedicalAsyncJobProperties.SubmitTime }}'
