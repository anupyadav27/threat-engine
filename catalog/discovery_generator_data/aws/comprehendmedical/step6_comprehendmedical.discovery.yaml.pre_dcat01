version: '1.0'
provider: aws
service: comprehendmedical
services:
  client: comprehendmedical
  module: boto3.client
discovery:
- discovery_id: aws.comprehendmedical.list_entities_detection_v2_jobs
  calls:
  - action: list_entities_detection_v2_jobs
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ComprehendMedicalAsyncJobPropertiesList }}'
    item:
      ComprehendMedicalAsyncJobProperties: '{{ item.ComprehendMedicalAsyncJobProperties
        }}'
      DataAccessRoleArn: '{{ item.DataAccessRoleArn }}'
      EndTime: '{{ item.EndTime }}'
      ExpirationTime: '{{ item.ExpirationTime }}'
      InputDataConfig: '{{ item.InputDataConfig }}'
      JobId: '{{ item.JobId }}'
      JobName: '{{ item.JobName }}'
      JobStatus: '{{ item.JobStatus }}'
      KMSKey: '{{ item.KMSKey }}'
      LanguageCode: '{{ item.LanguageCode }}'
      ManifestFilePath: '{{ item.ManifestFilePath }}'
      Message: '{{ item.Message }}'
      ModelVersion: '{{ item.ModelVersion }}'
      OutputDataConfig: '{{ item.OutputDataConfig }}'
      SubmitTime: '{{ item.SubmitTime }}'
- discovery_id: aws.comprehendmedical.list_icd10_cm_inference_jobs
  calls:
  - action: list_icd10_cm_inference_jobs
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ComprehendMedicalAsyncJobPropertiesList }}'
    item:
      DataAccessRoleArn: '{{ item.DataAccessRoleArn }}'
      EndTime: '{{ item.EndTime }}'
      ExpirationTime: '{{ item.ExpirationTime }}'
      InputDataConfig: '{{ item.InputDataConfig }}'
      JobId: '{{ item.JobId }}'
      JobName: '{{ item.JobName }}'
      JobStatus: '{{ item.JobStatus }}'
      KMSKey: '{{ item.KMSKey }}'
      LanguageCode: '{{ item.LanguageCode }}'
      ManifestFilePath: '{{ item.ManifestFilePath }}'
      Message: '{{ item.Message }}'
      ModelVersion: '{{ item.ModelVersion }}'
      OutputDataConfig: '{{ item.OutputDataConfig }}'
      SubmitTime: '{{ item.SubmitTime }}'
- discovery_id: aws.comprehendmedical.list_phi_detection_jobs
  calls:
  - action: list_phi_detection_jobs
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ComprehendMedicalAsyncJobPropertiesList }}'
    item:
      DataAccessRoleArn: '{{ item.DataAccessRoleArn }}'
      EndTime: '{{ item.EndTime }}'
      ExpirationTime: '{{ item.ExpirationTime }}'
      InputDataConfig: '{{ item.InputDataConfig }}'
      JobId: '{{ item.JobId }}'
      JobName: '{{ item.JobName }}'
      JobStatus: '{{ item.JobStatus }}'
      KMSKey: '{{ item.KMSKey }}'
      LanguageCode: '{{ item.LanguageCode }}'
      ManifestFilePath: '{{ item.ManifestFilePath }}'
      Message: '{{ item.Message }}'
      ModelVersion: '{{ item.ModelVersion }}'
      OutputDataConfig: '{{ item.OutputDataConfig }}'
      SubmitTime: '{{ item.SubmitTime }}'
- discovery_id: aws.comprehendmedical.list_rx_norm_inference_jobs
  calls:
  - action: list_rx_norm_inference_jobs
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ComprehendMedicalAsyncJobPropertiesList }}'
    item:
      DataAccessRoleArn: '{{ item.DataAccessRoleArn }}'
      EndTime: '{{ item.EndTime }}'
      ExpirationTime: '{{ item.ExpirationTime }}'
      InputDataConfig: '{{ item.InputDataConfig }}'
      JobId: '{{ item.JobId }}'
      JobName: '{{ item.JobName }}'
      JobStatus: '{{ item.JobStatus }}'
      KMSKey: '{{ item.KMSKey }}'
      LanguageCode: '{{ item.LanguageCode }}'
      ManifestFilePath: '{{ item.ManifestFilePath }}'
