      ModelVersion: '{{ item.ModelVersion }}'
      OutputDataConfig: '{{ item.OutputDataConfig }}'
      SubmitTime: '{{ item.SubmitTime }}'
- discovery_id: aws.comprehendmedical.list_snomedct_inference_jobs
  calls:
  - action: list_snomedct_inference_jobs
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ComprehendMedicalAsyncJobPropertiesList }}'
    item:
      DataAccessRoleArn: '{{ item.DataAccessRoleArn }}'
      EndTime: '{{ item.EndTime }}'
      ExpirationTime: '{{ item.ExpirationTime }}'
      InputDataConfig: '{{ item.InputDataConfig }}'
      JobId: '{{ item.JobId }}'
      JobName: '{{ item.JobName }}'
      JobStatus: '{{ item.JobStatus }}'
      KMSKey: '{{ item.KMSKey }}'
      LanguageCode: '{{ item.LanguageCode }}'
      ManifestFilePath: '{{ item.ManifestFilePath }}'
      Message: '{{ item.Message }}'
      ModelVersion: '{{ item.ModelVersion }}'
      OutputDataConfig: '{{ item.OutputDataConfig }}'
      SubmitTime: '{{ item.SubmitTime }}'
- discovery_id: aws.comprehendmedical.describe_entities_detection_v2_job
  for_each: aws.comprehendmedical.list_entities_detection_v2_jobs
  calls:
  - action: describe_entities_detection_v2_job
    params:
      JobId: '{{ item.JobId }}'
    save_as: response
    on_error: continue
  emit:
    as: item
    item:
      ComprehendMedicalAsyncJobProperties: '{{ response.ComprehendMedicalAsyncJobProperties.ComprehendMedicalAsyncJobProperties
        }}'
      DataAccessRoleArn: '{{ response.ComprehendMedicalAsyncJobProperties.DataAccessRoleArn
        }}'
      EndTime: '{{ response.ComprehendMedicalAsyncJobProperties.EndTime }}'
      ExpirationTime: '{{ response.ComprehendMedicalAsyncJobProperties.ExpirationTime
        }}'
      InputDataConfig: '{{ response.ComprehendMedicalAsyncJobProperties.InputDataConfig
        }}'
      JobId: '{{ response.ComprehendMedicalAsyncJobProperties.JobId }}'
      JobName: '{{ response.ComprehendMedicalAsyncJobProperties.JobName }}'
      JobStatus: '{{ response.ComprehendMedicalAsyncJobProperties.JobStatus }}'
      KMSKey: '{{ response.ComprehendMedicalAsyncJobProperties.KMSKey }}'
      LanguageCode: '{{ response.ComprehendMedicalAsyncJobProperties.LanguageCode
        }}'
