version: '1.0'
provider: aws
service: comprehendmedical
services:
  client: comprehendmedical
  module: boto3.client
discovery:
- discovery_id: aws.comprehendmedical.listEntitiesDetectionV2Jobs
  calls:
  - action: listEntitiesDetectionV2Jobs
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.ComprehendMedicalAsyncJobPropertiesList }}'
    item:
      JobId: '{{ item.JobId }}'
      JobName: '{{ item.JobName }}'
      JobStatus: '{{ item.JobStatus }}'
      Message: '{{ item.Message }}'
      SubmitTime: '{{ item.SubmitTime }}'
      EndTime: '{{ item.EndTime }}'
      ExpirationTime: '{{ item.ExpirationTime }}'
      InputDataConfig: '{{ item.InputDataConfig }}'
      OutputDataConfig: '{{ item.OutputDataConfig }}'
      LanguageCode: '{{ item.LanguageCode }}'
      DataAccessRoleArn: '{{ item.DataAccessRoleArn }}'
      ManifestFilePath: '{{ item.ManifestFilePath }}'
      KMSKey: '{{ item.KMSKey }}'
      ModelVersion: '{{ item.ModelVersion }}'
- discovery_id: aws.comprehendmedical.listIcd10CmInferenceJobs
