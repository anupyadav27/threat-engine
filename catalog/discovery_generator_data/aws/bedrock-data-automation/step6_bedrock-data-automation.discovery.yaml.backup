version: '1.0'
provider: aws
service: bedrock-data-automation
services:
  client: bedrock-data-automation
  module: boto3.client
discovery:
- discovery_id: aws.bedrock-data-automation.listBlueprints
  calls:
  - action: listBlueprints
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.blueprints }}'
    item:
      blueprintArn: '{{ item.blueprintArn }}'
      blueprintVersion: '{{ item.blueprintVersion }}'
      blueprintStage: '{{ item.blueprintStage }}'
      blueprintName: '{{ item.blueprintName }}'
      creationTime: '{{ item.creationTime }}'
      lastModifiedTime: '{{ item.lastModifiedTime }}'
- discovery_id: aws.bedrock-data-automation.listDataAutomationProjects
  calls:
  - action: listDataAutomationProjects
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.projects }}'
    item:
      projectArn: '{{ item.projectArn }}'
      projectStage: '{{ item.projectStage }}'
      projectType: '{{ item.projectType }}'
      projectName: '{{ item.projectName }}'
      creationTime: '{{ item.creationTime }}'
- discovery_id: aws.bedrock-data-automation.getBlueprint
  calls:
  - action: getBlueprint
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.blueprint }}'
    item:
      blueprintArn: '{{ item.blueprintArn }}'
      schema: '{{ item.schema }}'
      type: '{{ item.type }}'
      creationTime: '{{ item.creationTime }}'
      lastModifiedTime: '{{ item.lastModifiedTime }}'
      blueprintName: '{{ item.blueprintName }}'
      blueprintVersion: '{{ item.blueprintVersion }}'
      blueprintStage: '{{ item.blueprintStage }}'
      kmsKeyId: '{{ item.kmsKeyId }}'
      kmsEncryptionContext: '{{ item.kmsEncryptionContext }}'
- discovery_id: aws.bedrock-data-automation.getDataAutomationProject
  calls:
  - action: getDataAutomationProject
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.project }}'
    item:
      projectArn: '{{ item.projectArn }}'
      creationTime: '{{ item.creationTime }}'
      lastModifiedTime: '{{ item.lastModifiedTime }}'
      projectName: '{{ item.projectName }}'
      projectStage: '{{ item.projectStage }}'
      projectType: '{{ item.projectType }}'
      projectDescription: '{{ item.projectDescription }}'
      standardOutputConfiguration: '{{ item.standardOutputConfiguration }}'
      customOutputConfiguration: '{{ item.customOutputConfiguration }}'
      overrideConfiguration: '{{ item.overrideConfiguration }}'
      status: '{{ item.status }}'
      kmsKeyId: '{{ item.kmsKeyId }}'
      kmsEncryptionContext: '{{ item.kmsEncryptionContext }}'
- discovery_id: aws.bedrock-data-automation.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tags }}'
    item:
      key: '{{ item.key }}'
      value: '{{ item.value }}'
checks: []
