version: '1.0'
provider: aws
service: amplify
services:
  client: amplify
  module: boto3.client
discovery:
- discovery_id: aws.amplify.listApps
  calls:
  - action: listApps
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.apps }}'
    item:
      appId: '{{ item.appId }}'
      appArn: '{{ item.appArn }}'
      name: '{{ item.name }}'
      tags: '{{ item.tags }}'
      description: '{{ item.description }}'
      repository: '{{ item.repository }}'
      platform: '{{ item.platform }}'
      createTime: '{{ item.createTime }}'
      updateTime: '{{ item.updateTime }}'
      computeRoleArn: '{{ item.computeRoleArn }}'
      iamServiceRoleArn: '{{ item.iamServiceRoleArn }}'
      environmentVariables: '{{ item.environmentVariables }}'
      defaultDomain: '{{ item.defaultDomain }}'
      enableBranchAutoBuild: '{{ item.enableBranchAutoBuild }}'
      enableBranchAutoDeletion: '{{ item.enableBranchAutoDeletion }}'
      enableBasicAuth: '{{ item.enableBasicAuth }}'
      basicAuthCredentials: '{{ item.basicAuthCredentials }}'
      customRules: '{{ item.customRules }}'
      productionBranch: '{{ item.productionBranch }}'
      buildSpec: '{{ item.buildSpec }}'
      customHeaders: '{{ item.customHeaders }}'
      enableAutoBranchCreation: '{{ item.enableAutoBranchCreation }}'
      autoBranchCreationPatterns: '{{ item.autoBranchCreationPatterns }}'
      autoBranchCreationConfig: '{{ item.autoBranchCreationConfig }}'
      repositoryCloneMethod: '{{ item.repositoryCloneMethod }}'
      cacheConfig: '{{ item.cacheConfig }}'
      webhookCreateTime: '{{ item.webhookCreateTime }}'
      wafConfiguration: '{{ item.wafConfiguration }}'
      jobConfig: '{{ item.jobConfig }}'
- discovery_id: aws.amplify.getApp
  calls:
  - action: getApp
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.app }}'
    item:
      appId: '{{ item.appId }}'
      appArn: '{{ item.appArn }}'
      name: '{{ item.name }}'
      tags: '{{ item.tags }}'
      description: '{{ item.description }}'
      repository: '{{ item.repository }}'
      platform: '{{ item.platform }}'
      createTime: '{{ item.createTime }}'
      updateTime: '{{ item.updateTime }}'
      computeRoleArn: '{{ item.computeRoleArn }}'
      iamServiceRoleArn: '{{ item.iamServiceRoleArn }}'
      environmentVariables: '{{ item.environmentVariables }}'
      defaultDomain: '{{ item.defaultDomain }}'
      enableBranchAutoBuild: '{{ item.enableBranchAutoBuild }}'
      enableBranchAutoDeletion: '{{ item.enableBranchAutoDeletion }}'
      enableBasicAuth: '{{ item.enableBasicAuth }}'
      basicAuthCredentials: '{{ item.basicAuthCredentials }}'
      customRules: '{{ item.customRules }}'
      productionBranch: '{{ item.productionBranch }}'
      buildSpec: '{{ item.buildSpec }}'
      customHeaders: '{{ item.customHeaders }}'
      enableAutoBranchCreation: '{{ item.enableAutoBranchCreation }}'
      autoBranchCreationPatterns: '{{ item.autoBranchCreationPatterns }}'
      autoBranchCreationConfig: '{{ item.autoBranchCreationConfig }}'
      repositoryCloneMethod: '{{ item.repositoryCloneMethod }}'
      cacheConfig: '{{ item.cacheConfig }}'
      webhookCreateTime: '{{ item.webhookCreateTime }}'
      wafConfiguration: '{{ item.wafConfiguration }}'
      jobConfig: '{{ item.jobConfig }}'
- discovery_id: aws.amplify.getArtifactUrl
  calls:
  - action: getArtifactUrl
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.artifactId }}'
- discovery_id: aws.amplify.getBackendEnvironment
  calls:
  - action: getBackendEnvironment
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.backendEnvironment }}'
    item:
      backendEnvironmentArn: '{{ item.backendEnvironmentArn }}'
      environmentName: '{{ item.environmentName }}'
      stackName: '{{ item.stackName }}'
      deploymentArtifacts: '{{ item.deploymentArtifacts }}'
      createTime: '{{ item.createTime }}'
      updateTime: '{{ item.updateTime }}'
- discovery_id: aws.amplify.getBranch
  calls:
  - action: getBranch
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.branch }}'
    item:
      branchArn: '{{ item.branchArn }}'
      branchName: '{{ item.branchName }}'
      description: '{{ item.description }}'
      tags: '{{ item.tags }}'
      stage: '{{ item.stage }}'
      displayName: '{{ item.displayName }}'
      enableNotification: '{{ item.enableNotification }}'
      createTime: '{{ item.createTime }}'
      updateTime: '{{ item.updateTime }}'
      environmentVariables: '{{ item.environmentVariables }}'
      enableAutoBuild: '{{ item.enableAutoBuild }}'
      enableSkewProtection: '{{ item.enableSkewProtection }}'
      customDomains: '{{ item.customDomains }}'
      framework: '{{ item.framework }}'
      activeJobId: '{{ item.activeJobId }}'
      totalNumberOfJobs: '{{ item.totalNumberOfJobs }}'
      enableBasicAuth: '{{ item.enableBasicAuth }}'
      enablePerformanceMode: '{{ item.enablePerformanceMode }}'
      thumbnailUrl: '{{ item.thumbnailUrl }}'
      basicAuthCredentials: '{{ item.basicAuthCredentials }}'
      buildSpec: '{{ item.buildSpec }}'
      ttl: '{{ item.ttl }}'
      associatedResources: '{{ item.associatedResources }}'
      enablePullRequestPreview: '{{ item.enablePullRequestPreview }}'
      pullRequestEnvironmentName: '{{ item.pullRequestEnvironmentName }}'
      destinationBranch: '{{ item.destinationBranch }}'
      sourceBranch: '{{ item.sourceBranch }}'
      backendEnvironmentArn: '{{ item.backendEnvironmentArn }}'
      backend: '{{ item.backend }}'
      computeRoleArn: '{{ item.computeRoleArn }}'
- discovery_id: aws.amplify.getDomainAssociation
  calls:
  - action: getDomainAssociation
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.domainAssociation }}'
    item:
      domainAssociationArn: '{{ item.domainAssociationArn }}'
      domainName: '{{ item.domainName }}'
      enableAutoSubDomain: '{{ item.enableAutoSubDomain }}'
      autoSubDomainCreationPatterns: '{{ item.autoSubDomainCreationPatterns }}'
      autoSubDomainIAMRole: '{{ item.autoSubDomainIAMRole }}'
      domainStatus: '{{ item.domainStatus }}'
      updateStatus: '{{ item.updateStatus }}'
      statusReason: '{{ item.statusReason }}'
      certificateVerificationDNSRecord: '{{ item.certificateVerificationDNSRecord
        }}'
      subDomains: '{{ item.subDomains }}'
      certificate: '{{ item.certificate }}'
- discovery_id: aws.amplify.getJob
  calls:
  - action: getJob
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.job }}'
    item:
      summary: '{{ item.summary }}'
      steps: '{{ item.steps }}'
- discovery_id: aws.amplify.getWebhook
  calls:
  - action: getWebhook
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.webhook }}'
    item:
      webhookArn: '{{ item.webhookArn }}'
      webhookId: '{{ item.webhookId }}'
      webhookUrl: '{{ item.webhookUrl }}'
      appId: '{{ item.appId }}'
      branchName: '{{ item.branchName }}'
      description: '{{ item.description }}'
      createTime: '{{ item.createTime }}'
      updateTime: '{{ item.updateTime }}'
- discovery_id: aws.amplify.listArtifacts
  calls:
  - action: listArtifacts
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.artifacts }}'
    item:
      artifactFileName: '{{ item.artifactFileName }}'
      artifactId: '{{ item.artifactId }}'
- discovery_id: aws.amplify.listBackendEnvironments
  calls:
  - action: listBackendEnvironments
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.backendEnvironments }}'
    item:
      backendEnvironmentArn: '{{ item.backendEnvironmentArn }}'
      environmentName: '{{ item.environmentName }}'
      stackName: '{{ item.stackName }}'
      deploymentArtifacts: '{{ item.deploymentArtifacts }}'
      createTime: '{{ item.createTime }}'
      updateTime: '{{ item.updateTime }}'
- discovery_id: aws.amplify.listBranches
  calls:
  - action: listBranches
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.branches }}'
    item:
      branchArn: '{{ item.branchArn }}'
      branchName: '{{ item.branchName }}'
      description: '{{ item.description }}'
      tags: '{{ item.tags }}'
      stage: '{{ item.stage }}'
      displayName: '{{ item.displayName }}'
      enableNotification: '{{ item.enableNotification }}'
      createTime: '{{ item.createTime }}'
      updateTime: '{{ item.updateTime }}'
      environmentVariables: '{{ item.environmentVariables }}'
      enableAutoBuild: '{{ item.enableAutoBuild }}'
      enableSkewProtection: '{{ item.enableSkewProtection }}'
      customDomains: '{{ item.customDomains }}'
      framework: '{{ item.framework }}'
      activeJobId: '{{ item.activeJobId }}'
      totalNumberOfJobs: '{{ item.totalNumberOfJobs }}'
      enableBasicAuth: '{{ item.enableBasicAuth }}'
      enablePerformanceMode: '{{ item.enablePerformanceMode }}'
      thumbnailUrl: '{{ item.thumbnailUrl }}'
      basicAuthCredentials: '{{ item.basicAuthCredentials }}'
      buildSpec: '{{ item.buildSpec }}'
      ttl: '{{ item.ttl }}'
      associatedResources: '{{ item.associatedResources }}'
      enablePullRequestPreview: '{{ item.enablePullRequestPreview }}'
      pullRequestEnvironmentName: '{{ item.pullRequestEnvironmentName }}'
      destinationBranch: '{{ item.destinationBranch }}'
      sourceBranch: '{{ item.sourceBranch }}'
      backendEnvironmentArn: '{{ item.backendEnvironmentArn }}'
      backend: '{{ item.backend }}'
      computeRoleArn: '{{ item.computeRoleArn }}'
- discovery_id: aws.amplify.listDomainAssociations
  calls:
  - action: listDomainAssociations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.domainAssociations }}'
    item:
      domainAssociationArn: '{{ item.domainAssociationArn }}'
      domainName: '{{ item.domainName }}'
      enableAutoSubDomain: '{{ item.enableAutoSubDomain }}'
      autoSubDomainCreationPatterns: '{{ item.autoSubDomainCreationPatterns }}'
      autoSubDomainIAMRole: '{{ item.autoSubDomainIAMRole }}'
      domainStatus: '{{ item.domainStatus }}'
      updateStatus: '{{ item.updateStatus }}'
      statusReason: '{{ item.statusReason }}'
      certificateVerificationDNSRecord: '{{ item.certificateVerificationDNSRecord
        }}'
      subDomains: '{{ item.subDomains }}'
      certificate: '{{ item.certificate }}'
- discovery_id: aws.amplify.listJobs
  calls:
  - action: listJobs
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.jobSummaries }}'
    item:
      jobArn: '{{ item.jobArn }}'
      jobId: '{{ item.jobId }}'
      commitId: '{{ item.commitId }}'
      commitMessage: '{{ item.commitMessage }}'
      commitTime: '{{ item.commitTime }}'
      startTime: '{{ item.startTime }}'
      status: '{{ item.status }}'
      endTime: '{{ item.endTime }}'
      jobType: '{{ item.jobType }}'
      sourceUrl: '{{ item.sourceUrl }}'
      sourceUrlType: '{{ item.sourceUrlType }}'
- discovery_id: aws.amplify.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tags }}'
- discovery_id: aws.amplify.listWebhooks
  calls:
  - action: listWebhooks
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.webhooks }}'
    item:
      webhookArn: '{{ item.webhookArn }}'
      webhookId: '{{ item.webhookId }}'
      webhookUrl: '{{ item.webhookUrl }}'
      appId: '{{ item.appId }}'
      branchName: '{{ item.branchName }}'
      description: '{{ item.description }}'
      createTime: '{{ item.createTime }}'
      updateTime: '{{ item.updateTime }}'
checks: []
