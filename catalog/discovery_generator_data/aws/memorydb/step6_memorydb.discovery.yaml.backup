version: '1.0'
provider: aws
service: memorydb
services:
  client: memorydb
  module: boto3.client
discovery:
- discovery_id: aws.memorydb.describeAcLs
  calls:
  - action: describeAcLs
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ACLs }}'
    item:
      Name: '{{ item.Name }}'
      Status: '{{ item.Status }}'
      UserNames: '{{ item.UserNames }}'
      MinimumEngineVersion: '{{ item.MinimumEngineVersion }}'
      PendingChanges: '{{ item.PendingChanges }}'
      Clusters: '{{ item.Clusters }}'
      ARN: '{{ item.ARN }}'
- discovery_id: aws.memorydb.describeClusters
  calls:
  - action: describeClusters
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Clusters }}'
    item:
      Name: '{{ item.Name }}'
      Description: '{{ item.Description }}'
      Status: '{{ item.Status }}'
      PendingUpdates: '{{ item.PendingUpdates }}'
      MultiRegionClusterName: '{{ item.MultiRegionClusterName }}'
      NumberOfShards: '{{ item.NumberOfShards }}'
      Shards: '{{ item.Shards }}'
      AvailabilityMode: '{{ item.AvailabilityMode }}'
      ClusterEndpoint: '{{ item.ClusterEndpoint }}'
      NodeType: '{{ item.NodeType }}'
      Engine: '{{ item.Engine }}'
      EngineVersion: '{{ item.EngineVersion }}'
      EnginePatchVersion: '{{ item.EnginePatchVersion }}'
      ParameterGroupName: '{{ item.ParameterGroupName }}'
      ParameterGroupStatus: '{{ item.ParameterGroupStatus }}'
      SecurityGroups: '{{ item.SecurityGroups }}'
      SubnetGroupName: '{{ item.SubnetGroupName }}'
      TLSEnabled: '{{ item.TLSEnabled }}'
      KmsKeyId: '{{ item.KmsKeyId }}'
      ARN: '{{ item.ARN }}'
      SnsTopicArn: '{{ item.SnsTopicArn }}'
      SnsTopicStatus: '{{ item.SnsTopicStatus }}'
      SnapshotRetentionLimit: '{{ item.SnapshotRetentionLimit }}'
      MaintenanceWindow: '{{ item.MaintenanceWindow }}'
      SnapshotWindow: '{{ item.SnapshotWindow }}'
      ACLName: '{{ item.ACLName }}'
      AutoMinorVersionUpgrade: '{{ item.AutoMinorVersionUpgrade }}'
      DataTiering: '{{ item.DataTiering }}'
      NetworkType: '{{ item.NetworkType }}'
      IpDiscovery: '{{ item.IpDiscovery }}'
- discovery_id: aws.memorydb.describeEngineVersions
  calls:
  - action: describeEngineVersions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.EngineVersions }}'
    item:
      Engine: '{{ item.Engine }}'
      EngineVersion: '{{ item.EngineVersion }}'
      EnginePatchVersion: '{{ item.EnginePatchVersion }}'
      ParameterGroupFamily: '{{ item.ParameterGroupFamily }}'
- discovery_id: aws.memorydb.describeEvents
  calls:
  - action: describeEvents
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Events }}'
    item:
      SourceName: '{{ item.SourceName }}'
      SourceType: '{{ item.SourceType }}'
      Message: '{{ item.Message }}'
      Date: '{{ item.Date }}'
- discovery_id: aws.memorydb.describeMultiRegionClusters
  calls:
  - action: describeMultiRegionClusters
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.MultiRegionClusters }}'
    item:
      MultiRegionClusterName: '{{ item.MultiRegionClusterName }}'
      Description: '{{ item.Description }}'
      Status: '{{ item.Status }}'
      NodeType: '{{ item.NodeType }}'
      Engine: '{{ item.Engine }}'
      EngineVersion: '{{ item.EngineVersion }}'
      NumberOfShards: '{{ item.NumberOfShards }}'
      Clusters: '{{ item.Clusters }}'
      MultiRegionParameterGroupName: '{{ item.MultiRegionParameterGroupName }}'
      TLSEnabled: '{{ item.TLSEnabled }}'
      ARN: '{{ item.ARN }}'
- discovery_id: aws.memorydb.describeMultiRegionParameterGroups
  calls:
  - action: describeMultiRegionParameterGroups
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.MultiRegionParameterGroups }}'
    item:
      Name: '{{ item.Name }}'
      Family: '{{ item.Family }}'
      Description: '{{ item.Description }}'
      ARN: '{{ item.ARN }}'
- discovery_id: aws.memorydb.describeParameterGroups
  calls:
  - action: describeParameterGroups
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ParameterGroups }}'
    item:
      Name: '{{ item.Name }}'
      Family: '{{ item.Family }}'
      Description: '{{ item.Description }}'
      ARN: '{{ item.ARN }}'
- discovery_id: aws.memorydb.describeReservedNodes
  calls:
  - action: describeReservedNodes
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ReservedNodes }}'
    item:
      ReservationId: '{{ item.ReservationId }}'
      ReservedNodesOfferingId: '{{ item.ReservedNodesOfferingId }}'
      NodeType: '{{ item.NodeType }}'
      StartTime: '{{ item.StartTime }}'
      Duration: '{{ item.Duration }}'
      FixedPrice: '{{ item.FixedPrice }}'
      NodeCount: '{{ item.NodeCount }}'
      OfferingType: '{{ item.OfferingType }}'
      State: '{{ item.State }}'
      RecurringCharges: '{{ item.RecurringCharges }}'
      ARN: '{{ item.ARN }}'
- discovery_id: aws.memorydb.describeReservedNodesOfferings
  calls:
  - action: describeReservedNodesOfferings
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ReservedNodesOfferings }}'
    item:
      ReservedNodesOfferingId: '{{ item.ReservedNodesOfferingId }}'
      NodeType: '{{ item.NodeType }}'
      Duration: '{{ item.Duration }}'
      FixedPrice: '{{ item.FixedPrice }}'
      OfferingType: '{{ item.OfferingType }}'
      RecurringCharges: '{{ item.RecurringCharges }}'
- discovery_id: aws.memorydb.describeServiceUpdates
  calls:
  - action: describeServiceUpdates
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ServiceUpdates }}'
    item:
      ClusterName: '{{ item.ClusterName }}'
      ServiceUpdateName: '{{ item.ServiceUpdateName }}'
      ReleaseDate: '{{ item.ReleaseDate }}'
      Description: '{{ item.Description }}'
      Status: '{{ item.Status }}'
      Type: '{{ item.Type }}'
      Engine: '{{ item.Engine }}'
      NodesUpdated: '{{ item.NodesUpdated }}'
      AutoUpdateStartDate: '{{ item.AutoUpdateStartDate }}'
- discovery_id: aws.memorydb.describeSnapshots
  calls:
  - action: describeSnapshots
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Snapshots }}'
    item:
      Name: '{{ item.Name }}'
      Status: '{{ item.Status }}'
      Source: '{{ item.Source }}'
      KmsKeyId: '{{ item.KmsKeyId }}'
      ARN: '{{ item.ARN }}'
      ClusterConfiguration: '{{ item.ClusterConfiguration }}'
      DataTiering: '{{ item.DataTiering }}'
- discovery_id: aws.memorydb.describeSubnetGroups
  calls:
  - action: describeSubnetGroups
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.SubnetGroups }}'
    item:
      Name: '{{ item.Name }}'
      Description: '{{ item.Description }}'
      VpcId: '{{ item.VpcId }}'
      Subnets: '{{ item.Subnets }}'
      ARN: '{{ item.ARN }}'
      SupportedNetworkTypes: '{{ item.SupportedNetworkTypes }}'
- discovery_id: aws.memorydb.describeUsers
  calls:
  - action: describeUsers
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Users }}'
    item:
      Name: '{{ item.Name }}'
      Status: '{{ item.Status }}'
      AccessString: '{{ item.AccessString }}'
      ACLNames: '{{ item.ACLNames }}'
      MinimumEngineVersion: '{{ item.MinimumEngineVersion }}'
      Authentication: '{{ item.Authentication }}'
      ARN: '{{ item.ARN }}'
- discovery_id: aws.memorydb.describeMultiRegionParameters
  calls:
  - action: describeMultiRegionParameters
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.MultiRegionParameters }}'
    item:
      Name: '{{ item.Name }}'
      Value: '{{ item.Value }}'
      Description: '{{ item.Description }}'
      Source: '{{ item.Source }}'
      DataType: '{{ item.DataType }}'
      AllowedValues: '{{ item.AllowedValues }}'
      MinimumEngineVersion: '{{ item.MinimumEngineVersion }}'
- discovery_id: aws.memorydb.describeParameters
  calls:
  - action: describeParameters
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Parameters }}'
    item:
      Name: '{{ item.Name }}'
      Value: '{{ item.Value }}'
      Description: '{{ item.Description }}'
      DataType: '{{ item.DataType }}'
      AllowedValues: '{{ item.AllowedValues }}'
      MinimumEngineVersion: '{{ item.MinimumEngineVersion }}'
- discovery_id: aws.memorydb.listAllowedMultiRegionClusterUpdates
  calls:
  - action: listAllowedMultiRegionClusterUpdates
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ScaleUpNodeTypes }}'
- discovery_id: aws.memorydb.listAllowedNodeTypeUpdates
  calls:
  - action: listAllowedNodeTypeUpdates
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ScaleUpNodeTypes }}'
- discovery_id: aws.memorydb.listTags
  calls:
  - action: listTags
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.TagList }}'
    item:
      Key: '{{ item.Key }}'
      Value: '{{ item.Value }}'
checks: []
