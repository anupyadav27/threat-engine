      CandidateSteps: '{{ item.CandidateSteps }}'
      CandidateStatus: '{{ item.CandidateStatus }}'
      InferenceContainers: '{{ item.InferenceContainers }}'
      CreationTime: '{{ item.CreationTime }}'
