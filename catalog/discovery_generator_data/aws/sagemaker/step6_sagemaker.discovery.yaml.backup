version: '1.0'
provider: aws
service: sagemaker
services:
  client: sagemaker
  module: boto3.client
discovery:
- discovery_id: aws.sagemaker.getSagemakerServicecatalogPortfolioStatus
  calls:
  - action: getSagemakerServicecatalogPortfolioStatus
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Status }}'
- discovery_id: aws.sagemaker.listActions
  calls:
  - action: listActions
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.ActionSummaries }}'
    item:
      ActionArn: '{{ item.ActionArn }}'
      ActionName: '{{ item.ActionName }}'
      Source: '{{ item.Source }}'
      ActionType: '{{ item.ActionType }}'
      Status: '{{ item.Status }}'
      CreationTime: '{{ item.CreationTime }}'
      LastModifiedTime: '{{ item.LastModifiedTime }}'
- discovery_id: aws.sagemaker.listAlgorithms
  calls:
  - action: listAlgorithms
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.AlgorithmSummaryList }}'
    item:
      AlgorithmName: '{{ item.AlgorithmName }}'
      AlgorithmArn: '{{ item.AlgorithmArn }}'
      AlgorithmDescription: '{{ item.AlgorithmDescription }}'
      CreationTime: '{{ item.CreationTime }}'
      AlgorithmStatus: '{{ item.AlgorithmStatus }}'
- discovery_id: aws.sagemaker.listAppImageConfigs
  calls:
  - action: listAppImageConfigs
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.AppImageConfigs }}'
    item:
      AppImageConfigArn: '{{ item.AppImageConfigArn }}'
      AppImageConfigName: '{{ item.AppImageConfigName }}'
      CreationTime: '{{ item.CreationTime }}'
      LastModifiedTime: '{{ item.LastModifiedTime }}'
      KernelGatewayImageConfig: '{{ item.KernelGatewayImageConfig }}'
      JupyterLabAppImageConfig: '{{ item.JupyterLabAppImageConfig }}'
      CodeEditorAppImageConfig: '{{ item.CodeEditorAppImageConfig }}'
- discovery_id: aws.sagemaker.listApps
  calls:
  - action: listApps
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Apps }}'
    item:
      DomainId: '{{ item.DomainId }}'
      UserProfileName: '{{ item.UserProfileName }}'
      SpaceName: '{{ item.SpaceName }}'
      AppType: '{{ item.AppType }}'
      AppName: '{{ item.AppName }}'
      Status: '{{ item.Status }}'
      CreationTime: '{{ item.CreationTime }}'
      ResourceSpec: '{{ item.ResourceSpec }}'
- discovery_id: aws.sagemaker.listArtifacts
  calls:
  - action: listArtifacts
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.ArtifactSummaries }}'
    item:
      ArtifactArn: '{{ item.ArtifactArn }}'
      ArtifactName: '{{ item.ArtifactName }}'
      Source: '{{ item.Source }}'
      ArtifactType: '{{ item.ArtifactType }}'
      CreationTime: '{{ item.CreationTime }}'
      LastModifiedTime: '{{ item.LastModifiedTime }}'
- discovery_id: aws.sagemaker.listAssociations
  calls:
  - action: listAssociations
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.AssociationSummaries }}'
    item:
      SourceArn: '{{ item.SourceArn }}'
      DestinationArn: '{{ item.DestinationArn }}'
