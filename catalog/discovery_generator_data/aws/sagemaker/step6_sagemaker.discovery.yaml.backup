      DestinationType: '{{ item.DestinationType }}'
      AssociationType: '{{ item.AssociationType }}'
      SourceName: '{{ item.SourceName }}'
      DestinationName: '{{ item.DestinationName }}'
      CreationTime: '{{ item.CreationTime }}'
      CreatedBy: '{{ item.CreatedBy }}'
