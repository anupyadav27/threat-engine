  - action: describeWorkteam
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Workteam }}'
    item:
      WorkteamName: '{{ item.WorkteamName }}'
      MemberDefinitions: '{{ item.MemberDefinitions }}'
      WorkteamArn: '{{ item.WorkteamArn }}'
      WorkforceArn: '{{ item.WorkforceArn }}'
      ProductListingIds: '{{ item.ProductListingIds }}'
      Description: '{{ item.Description }}'
      SubDomain: '{{ item.SubDomain }}'
      CreateDate: '{{ item.CreateDate }}'
      LastUpdatedDate: '{{ item.LastUpdatedDate }}'
      NotificationConfiguration: '{{ item.NotificationConfiguration }}'
      WorkerAccessConfiguration: '{{ item.WorkerAccessConfiguration }}'
- discovery_id: aws.sagemaker.getDeviceFleetReport
  calls:
  - action: getDeviceFleetReport
    save_as: response
    on_error: continue
  emit:
