version: '1.0'
provider: aws
service: amplifyuibuilder
services:
  client: amplifyuibuilder
  module: boto3.client
discovery:
- discovery_id: aws.amplifyuibuilder.getCodegenJob
  calls:
  - action: getCodegenJob
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.job }}'
    item:
      id: '{{ item.id }}'
      appId: '{{ item.appId }}'
      environmentName: '{{ item.environmentName }}'
      renderConfig: '{{ item.renderConfig }}'
      genericDataSchema: '{{ item.genericDataSchema }}'
      autoGenerateForms: '{{ item.autoGenerateForms }}'
      features: '{{ item.features }}'
      status: '{{ item.status }}'
      statusMessage: '{{ item.statusMessage }}'
      asset: '{{ item.asset }}'
      tags: '{{ item.tags }}'
      createdAt: '{{ item.createdAt }}'
      modifiedAt: '{{ item.modifiedAt }}'
      dependencies: '{{ item.dependencies }}'
- discovery_id: aws.amplifyuibuilder.getComponent
  calls:
  - action: getComponent
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.component }}'
    item:
      appId: '{{ item.appId }}'
      environmentName: '{{ item.environmentName }}'
      sourceId: '{{ item.sourceId }}'
      id: '{{ item.id }}'
      name: '{{ item.name }}'
      componentType: '{{ item.componentType }}'
      properties: '{{ item.properties }}'
      children: '{{ item.children }}'
      variants: '{{ item.variants }}'
      overrides: '{{ item.overrides }}'
      bindingProperties: '{{ item.bindingProperties }}'
      collectionProperties: '{{ item.collectionProperties }}'
      createdAt: '{{ item.createdAt }}'
      modifiedAt: '{{ item.modifiedAt }}'
      tags: '{{ item.tags }}'
      events: '{{ item.events }}'
      schemaVersion: '{{ item.schemaVersion }}'
- discovery_id: aws.amplifyuibuilder.getForm
  calls:
  - action: getForm
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.form }}'
    item:
      appId: '{{ item.appId }}'
      environmentName: '{{ item.environmentName }}'
      id: '{{ item.id }}'
      name: '{{ item.name }}'
      formActionType: '{{ item.formActionType }}'
      style: '{{ item.style }}'
      dataType: '{{ item.dataType }}'
      fields: '{{ item.fields }}'
      sectionalElements: '{{ item.sectionalElements }}'
      schemaVersion: '{{ item.schemaVersion }}'
      tags: '{{ item.tags }}'
      cta: '{{ item.cta }}'
      labelDecorator: '{{ item.labelDecorator }}'
- discovery_id: aws.amplifyuibuilder.getMetadata
  calls:
  - action: getMetadata
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.features }}'
- discovery_id: aws.amplifyuibuilder.getTheme
  calls:
  - action: getTheme
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.theme }}'
    item:
      appId: '{{ item.appId }}'
      environmentName: '{{ item.environmentName }}'
      id: '{{ item.id }}'
      name: '{{ item.name }}'
      createdAt: '{{ item.createdAt }}'
      modifiedAt: '{{ item.modifiedAt }}'
      values: '{{ item.values }}'
      overrides: '{{ item.overrides }}'
      tags: '{{ item.tags }}'
- discovery_id: aws.amplifyuibuilder.listCodegenJobs
  calls:
  - action: listCodegenJobs
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.entities }}'
    item:
      appId: '{{ item.appId }}'
      environmentName: '{{ item.environmentName }}'
      id: '{{ item.id }}'
      createdAt: '{{ item.createdAt }}'
      modifiedAt: '{{ item.modifiedAt }}'
- discovery_id: aws.amplifyuibuilder.listComponents
  calls:
  - action: listComponents
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.entities }}'
    item:
      appId: '{{ item.appId }}'
      environmentName: '{{ item.environmentName }}'
      id: '{{ item.id }}'
      name: '{{ item.name }}'
      componentType: '{{ item.componentType }}'
- discovery_id: aws.amplifyuibuilder.listForms
  calls:
  - action: listForms
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.entities }}'
    item:
      appId: '{{ item.appId }}'
      dataType: '{{ item.dataType }}'
      environmentName: '{{ item.environmentName }}'
      formActionType: '{{ item.formActionType }}'
      id: '{{ item.id }}'
      name: '{{ item.name }}'
- discovery_id: aws.amplifyuibuilder.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tags }}'
- discovery_id: aws.amplifyuibuilder.listThemes
  calls:
  - action: listThemes
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.entities }}'
    item:
      appId: '{{ item.appId }}'
      environmentName: '{{ item.environmentName }}'
      id: '{{ item.id }}'
      name: '{{ item.name }}'
checks: []
