version: '1.0'
provider: aws
service: kendra
services:
  client: kendra
  module: boto3.client
discovery:
- discovery_id: aws.kendra.listIndices
  calls:
  - action: listIndices
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.IndexConfigurationSummaryItems }}'
    item:
      Name: '{{ item.Name }}'
      Id: '{{ item.Id }}'
      Edition: '{{ item.Edition }}'
      CreatedAt: '{{ item.CreatedAt }}'
      UpdatedAt: '{{ item.UpdatedAt }}'
      Status: '{{ item.Status }}'
- discovery_id: aws.kendra.describeAccessControlConfiguration
  calls:
  - action: describeAccessControlConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AccessControlList }}'
    item:
      Name: '{{ item.Name }}'
      Type: '{{ item.Type }}'
      Access: '{{ item.Access }}'
      DataSourceId: '{{ item.DataSourceId }}'
- discovery_id: aws.kendra.describeDataSource
  calls:
  - action: describeDataSource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Configuration }}'
    item:
      S3Configuration: '{{ item.S3Configuration }}'
      SharePointConfiguration: '{{ item.SharePointConfiguration }}'
      DatabaseConfiguration: '{{ item.DatabaseConfiguration }}'
      SalesforceConfiguration: '{{ item.SalesforceConfiguration }}'
      OneDriveConfiguration: '{{ item.OneDriveConfiguration }}'
      ServiceNowConfiguration: '{{ item.ServiceNowConfiguration }}'
      ConfluenceConfiguration: '{{ item.ConfluenceConfiguration }}'
      GoogleDriveConfiguration: '{{ item.GoogleDriveConfiguration }}'
      WebCrawlerConfiguration: '{{ item.WebCrawlerConfiguration }}'
      WorkDocsConfiguration: '{{ item.WorkDocsConfiguration }}'
      FsxConfiguration: '{{ item.FsxConfiguration }}'
      SlackConfiguration: '{{ item.SlackConfiguration }}'
      BoxConfiguration: '{{ item.BoxConfiguration }}'
      QuipConfiguration: '{{ item.QuipConfiguration }}'
      JiraConfiguration: '{{ item.JiraConfiguration }}'
      GitHubConfiguration: '{{ item.GitHubConfiguration }}'
      AlfrescoConfiguration: '{{ item.AlfrescoConfiguration }}'
      TemplateConfiguration: '{{ item.TemplateConfiguration }}'
- discovery_id: aws.kendra.describeExperience
  calls:
  - action: describeExperience
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Endpoints }}'
    item:
      EndpointType: '{{ item.EndpointType }}'
      Endpoint: '{{ item.Endpoint }}'
- discovery_id: aws.kendra.describeFaq
  calls:
  - action: describeFaq
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.S3Path }}'
    item:
      Bucket: '{{ item.Bucket }}'
      Key: '{{ item.Key }}'
- discovery_id: aws.kendra.describeFeaturedResultsSet
  calls:
  - action: describeFeaturedResultsSet
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.QueryTexts }}'
- discovery_id: aws.kendra.describeIndex
  calls:
  - action: describeIndex
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.DocumentMetadataConfigurations }}'
    item:
      Name: '{{ item.Name }}'
      Type: '{{ item.Type }}'
      Relevance: '{{ item.Relevance }}'
      Search: '{{ item.Search }}'
- discovery_id: aws.kendra.describePrincipalMapping
  calls:
  - action: describePrincipalMapping
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.GroupOrderingIdSummaries }}'
    item:
      Status: '{{ item.Status }}'
      LastUpdatedAt: '{{ item.LastUpdatedAt }}'
      ReceivedAt: '{{ item.ReceivedAt }}'
      OrderingId: '{{ item.OrderingId }}'
      FailureReason: '{{ item.FailureReason }}'
- discovery_id: aws.kendra.describeQuerySuggestionsBlockList
  calls:
  - action: describeQuerySuggestionsBlockList
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.SourceS3Path }}'
    item:
      Bucket: '{{ item.Bucket }}'
      Key: '{{ item.Key }}'
- discovery_id: aws.kendra.describeQuerySuggestionsConfig
  calls:
  - action: describeQuerySuggestionsConfig
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AttributeSuggestionsConfig }}'
    item:
      SuggestableConfigList: '{{ item.SuggestableConfigList }}'
      AttributeSuggestionsMode: '{{ item.AttributeSuggestionsMode }}'
- discovery_id: aws.kendra.describeThesaurus
  calls:
  - action: describeThesaurus
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.SourceS3Path }}'
    item:
      Bucket: '{{ item.Bucket }}'
      Key: '{{ item.Key }}'
- discovery_id: aws.kendra.getQuerySuggestions
  calls:
  - action: getQuerySuggestions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Suggestions }}'
    item:
      Id: '{{ item.Id }}'
      Value: '{{ item.Value }}'
      SourceDocuments: '{{ item.SourceDocuments }}'
- discovery_id: aws.kendra.getSnapshots
  calls:
  - action: getSnapshots
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.SnapshotsDataHeader }}'
- discovery_id: aws.kendra.listAccessControlConfigurations
  calls:
  - action: listAccessControlConfigurations
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.AccessControlConfigurations }}'
    item:
      Id: '{{ item.Id }}'
- discovery_id: aws.kendra.listDataSourceSyncJobs
  calls:
  - action: listDataSourceSyncJobs
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.History }}'
    item:
      ExecutionId: '{{ item.ExecutionId }}'
      StartTime: '{{ item.StartTime }}'
      EndTime: '{{ item.EndTime }}'
      Status: '{{ item.Status }}'
      ErrorMessage: '{{ item.ErrorMessage }}'
      ErrorCode: '{{ item.ErrorCode }}'
      DataSourceErrorCode: '{{ item.DataSourceErrorCode }}'
      Metrics: '{{ item.Metrics }}'
- discovery_id: aws.kendra.listDataSources
  calls:
  - action: listDataSources
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.SummaryItems }}'
    item:
      Name: '{{ item.Name }}'
      Id: '{{ item.Id }}'
      Type: '{{ item.Type }}'
      CreatedAt: '{{ item.CreatedAt }}'
      UpdatedAt: '{{ item.UpdatedAt }}'
      Status: '{{ item.Status }}'
      LanguageCode: '{{ item.LanguageCode }}'
- discovery_id: aws.kendra.listEntityPersonas
  calls:
  - action: listEntityPersonas
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.SummaryItems }}'
    item:
      EntityId: '{{ item.EntityId }}'
      Persona: '{{ item.Persona }}'
      CreatedAt: '{{ item.CreatedAt }}'
      UpdatedAt: '{{ item.UpdatedAt }}'
- discovery_id: aws.kendra.listExperienceEntities
  calls:
  - action: listExperienceEntities
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.SummaryItems }}'
    item:
      EntityId: '{{ item.EntityId }}'
      EntityType: '{{ item.EntityType }}'
      DisplayData: '{{ item.DisplayData }}'
- discovery_id: aws.kendra.listExperiences
  calls:
  - action: listExperiences
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.SummaryItems }}'
    item:
      Name: '{{ item.Name }}'
      Id: '{{ item.Id }}'
      CreatedAt: '{{ item.CreatedAt }}'
      Status: '{{ item.Status }}'
      Endpoints: '{{ item.Endpoints }}'
- discovery_id: aws.kendra.listFaqs
  calls:
  - action: listFaqs
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.FaqSummaryItems }}'
    item:
      Id: '{{ item.Id }}'
      Name: '{{ item.Name }}'
      Status: '{{ item.Status }}'
      CreatedAt: '{{ item.CreatedAt }}'
      UpdatedAt: '{{ item.UpdatedAt }}'
      FileFormat: '{{ item.FileFormat }}'
      LanguageCode: '{{ item.LanguageCode }}'
- discovery_id: aws.kendra.listFeaturedResultsSets
  calls:
  - action: listFeaturedResultsSets
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.FeaturedResultsSetSummaryItems }}'
    item:
      FeaturedResultsSetId: '{{ item.FeaturedResultsSetId }}'
      FeaturedResultsSetName: '{{ item.FeaturedResultsSetName }}'
      Status: '{{ item.Status }}'
      LastUpdatedTimestamp: '{{ item.LastUpdatedTimestamp }}'
      CreationTimestamp: '{{ item.CreationTimestamp }}'
- discovery_id: aws.kendra.listGroupsOlderThanOrderingId
  calls:
  - action: listGroupsOlderThanOrderingId
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.GroupsSummaries }}'
    item:
      GroupId: '{{ item.GroupId }}'
      OrderingId: '{{ item.OrderingId }}'
- discovery_id: aws.kendra.listQuerySuggestionsBlockLists
  calls:
  - action: listQuerySuggestionsBlockLists
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.BlockListSummaryItems }}'
    item:
      Id: '{{ item.Id }}'
      Name: '{{ item.Name }}'
      Status: '{{ item.Status }}'
      CreatedAt: '{{ item.CreatedAt }}'
      UpdatedAt: '{{ item.UpdatedAt }}'
      ItemCount: '{{ item.ItemCount }}'
- discovery_id: aws.kendra.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Tags }}'
    item:
      Key: '{{ item.Key }}'
      Value: '{{ item.Value }}'
- discovery_id: aws.kendra.listThesauri
  calls:
  - action: listThesauri
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.ThesaurusSummaryItems }}'
    item:
      Id: '{{ item.Id }}'
      Name: '{{ item.Name }}'
      Status: '{{ item.Status }}'
      CreatedAt: '{{ item.CreatedAt }}'
      UpdatedAt: '{{ item.UpdatedAt }}'
- discovery_id: aws.kendra.query
  calls:
  - action: query
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ResultItems }}'
    item:
      Id: '{{ item.Id }}'
      Type: '{{ item.Type }}'
      Format: '{{ item.Format }}'
      AdditionalAttributes: '{{ item.AdditionalAttributes }}'
      DocumentId: '{{ item.DocumentId }}'
      DocumentTitle: '{{ item.DocumentTitle }}'
      DocumentExcerpt: '{{ item.DocumentExcerpt }}'
      DocumentURI: '{{ item.DocumentURI }}'
      DocumentAttributes: '{{ item.DocumentAttributes }}'
      ScoreAttributes: '{{ item.ScoreAttributes }}'
      FeedbackToken: '{{ item.FeedbackToken }}'
      TableExcerpt: '{{ item.TableExcerpt }}'
      CollapsedResultDetail: '{{ item.CollapsedResultDetail }}'
- discovery_id: aws.kendra.retrieve
  calls:
  - action: retrieve
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ResultItems }}'
    item:
      Id: '{{ item.Id }}'
      DocumentId: '{{ item.DocumentId }}'
      DocumentTitle: '{{ item.DocumentTitle }}'
      Content: '{{ item.Content }}'
      DocumentURI: '{{ item.DocumentURI }}'
      DocumentAttributes: '{{ item.DocumentAttributes }}'
      ScoreAttributes: '{{ item.ScoreAttributes }}'
checks: []
