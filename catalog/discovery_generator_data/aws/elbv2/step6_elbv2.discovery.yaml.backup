version: '1.0'
provider: aws
service: elbv2
services:
  client: elbv2
  module: boto3.client
discovery:
- discovery_id: aws.elbv2.describeAccountLimits
  calls:
  - action: describeAccountLimits
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Limits }}'
    item:
      Name: '{{ item.Name }}'
      Max: '{{ item.Max }}'
- discovery_id: aws.elbv2.describeListeners
  calls:
  - action: describeListeners
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Listeners }}'
    item:
      ListenerArn: '{{ item.ListenerArn }}'
      LoadBalancerArn: '{{ item.LoadBalancerArn }}'
      Port: '{{ item.Port }}'
      Protocol: '{{ item.Protocol }}'
      Certificates: '{{ item.Certificates }}'
      SslPolicy: '{{ item.SslPolicy }}'
      DefaultActions: '{{ item.DefaultActions }}'
      AlpnPolicy: '{{ item.AlpnPolicy }}'
      MutualAuthentication: '{{ item.MutualAuthentication }}'
- discovery_id: aws.elbv2.describeLoadBalancers
  calls:
  - action: describeLoadBalancers
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.LoadBalancers }}'
    item:
      LoadBalancerArn: '{{ item.LoadBalancerArn }}'
      DNSName: '{{ item.DNSName }}'
      CanonicalHostedZoneId: '{{ item.CanonicalHostedZoneId }}'
      CreatedTime: '{{ item.CreatedTime }}'
      LoadBalancerName: '{{ item.LoadBalancerName }}'
      Scheme: '{{ item.Scheme }}'
      VpcId: '{{ item.VpcId }}'
      State: '{{ item.State }}'
      Type: '{{ item.Type }}'
      AvailabilityZones: '{{ item.AvailabilityZones }}'
      SecurityGroups: '{{ item.SecurityGroups }}'
      IpAddressType: '{{ item.IpAddressType }}'
      CustomerOwnedIpv4Pool: '{{ item.CustomerOwnedIpv4Pool }}'
      EnforceSecurityGroupInboundRulesOnPrivateLinkTraffic: '{{ item.EnforceSecurityGroupInboundRulesOnPrivateLinkTraffic
        }}'
      EnablePrefixForIpv6SourceNat: '{{ item.EnablePrefixForIpv6SourceNat }}'
      IpamPools: '{{ item.IpamPools }}'
- discovery_id: aws.elbv2.describeRules
  calls:
  - action: describeRules
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Rules }}'
    item:
      RuleArn: '{{ item.RuleArn }}'
      Priority: '{{ item.Priority }}'
      Conditions: '{{ item.Conditions }}'
      Actions: '{{ item.Actions }}'
      IsDefault: '{{ item.IsDefault }}'
      Transforms: '{{ item.Transforms }}'
- discovery_id: aws.elbv2.describeSslPolicies
  calls:
  - action: describeSslPolicies
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.SslPolicies }}'
    item:
      SslProtocols: '{{ item.SslProtocols }}'
      Ciphers: '{{ item.Ciphers }}'
      Name: '{{ item.Name }}'
      SupportedLoadBalancerTypes: '{{ item.SupportedLoadBalancerTypes }}'
- discovery_id: aws.elbv2.describeTargetGroups
  calls:
  - action: describeTargetGroups
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.TargetGroups }}'
    item:
      TargetGroupArn: '{{ item.TargetGroupArn }}'
      TargetGroupName: '{{ item.TargetGroupName }}'
      Protocol: '{{ item.Protocol }}'
      Port: '{{ item.Port }}'
      VpcId: '{{ item.VpcId }}'
      HealthCheckProtocol: '{{ item.HealthCheckProtocol }}'
      HealthCheckPort: '{{ item.HealthCheckPort }}'
      HealthCheckEnabled: '{{ item.HealthCheckEnabled }}'
      HealthCheckIntervalSeconds: '{{ item.HealthCheckIntervalSeconds }}'
      HealthCheckTimeoutSeconds: '{{ item.HealthCheckTimeoutSeconds }}'
      HealthyThresholdCount: '{{ item.HealthyThresholdCount }}'
      UnhealthyThresholdCount: '{{ item.UnhealthyThresholdCount }}'
      HealthCheckPath: '{{ item.HealthCheckPath }}'
      Matcher: '{{ item.Matcher }}'
      LoadBalancerArns: '{{ item.LoadBalancerArns }}'
      TargetType: '{{ item.TargetType }}'
      ProtocolVersion: '{{ item.ProtocolVersion }}'
      IpAddressType: '{{ item.IpAddressType }}'
      TargetControlPort: '{{ item.TargetControlPort }}'
- discovery_id: aws.elbv2.describeTrustStores
  calls:
  - action: describeTrustStores
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.TrustStores }}'
    item:
      Name: '{{ item.Name }}'
      TrustStoreArn: '{{ item.TrustStoreArn }}'
      Status: '{{ item.Status }}'
      NumberOfCaCertificates: '{{ item.NumberOfCaCertificates }}'
      TotalRevokedEntries: '{{ item.TotalRevokedEntries }}'
- discovery_id: aws.elbv2.describeCapacityReservation
  calls:
  - action: describeCapacityReservation
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.CapacityReservationState }}'
    item:
      State: '{{ item.State }}'
      AvailabilityZone: '{{ item.AvailabilityZone }}'
      EffectiveCapacityUnits: '{{ item.EffectiveCapacityUnits }}'
- discovery_id: aws.elbv2.describeListenerAttributes
  calls:
  - action: describeListenerAttributes
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Attributes }}'
    item:
      Key: '{{ item.Key }}'
      Value: '{{ item.Value }}'
- discovery_id: aws.elbv2.describeListenerCertificates
  calls:
  - action: describeListenerCertificates
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Certificates }}'
    item:
      CertificateArn: '{{ item.CertificateArn }}'
      IsDefault: '{{ item.IsDefault }}'
- discovery_id: aws.elbv2.describeLoadBalancerAttributes
  calls:
  - action: describeLoadBalancerAttributes
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Attributes }}'
    item:
      Key: '{{ item.Key }}'
      Value: '{{ item.Value }}'
- discovery_id: aws.elbv2.describeTags
  calls:
  - action: describeTags
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.TagDescriptions }}'
    item:
      ResourceArn: '{{ item.ResourceArn }}'
      Tags: '{{ item.Tags }}'
- discovery_id: aws.elbv2.describeTargetGroupAttributes
  calls:
  - action: describeTargetGroupAttributes
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Attributes }}'
    item:
      Key: '{{ item.Key }}'
      Value: '{{ item.Value }}'
- discovery_id: aws.elbv2.describeTargetHealth
  calls:
  - action: describeTargetHealth
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.TargetHealthDescriptions }}'
    item:
      Target: '{{ item.Target }}'
      HealthCheckPort: '{{ item.HealthCheckPort }}'
      TargetHealth: '{{ item.TargetHealth }}'
      AnomalyDetection: '{{ item.AnomalyDetection }}'
      AdministrativeOverride: '{{ item.AdministrativeOverride }}'
- discovery_id: aws.elbv2.describeTrustStoreAssociations
  calls:
  - action: describeTrustStoreAssociations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.TrustStoreAssociations }}'
    item:
      ResourceArn: '{{ item.ResourceArn }}'
- discovery_id: aws.elbv2.describeTrustStoreRevocations
  calls:
  - action: describeTrustStoreRevocations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.TrustStoreRevocations }}'
    item:
      TrustStoreArn: '{{ item.TrustStoreArn }}'
      RevocationId: '{{ item.RevocationId }}'
      RevocationType: '{{ item.RevocationType }}'
      NumberOfRevokedEntries: '{{ item.NumberOfRevokedEntries }}'
- discovery_id: aws.elbv2.getResourcePolicy
  calls:
  - action: getResourcePolicy
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Policy }}'
- discovery_id: aws.elbv2.getTrustStoreCaCertificatesBundle
  calls:
  - action: getTrustStoreCaCertificatesBundle
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Location }}'
- discovery_id: aws.elbv2.getTrustStoreRevocationContent
  calls:
  - action: getTrustStoreRevocationContent
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Location }}'
checks: []
