version: '1.0'
provider: aws
service: mgn
services:
  client: mgn
  module: boto3.client
discovery:
- discovery_id: aws.mgn.describeJobs
  calls:
  - action: describeJobs
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
    item:
      arn: '{{ item.arn }}'
      creationDateTime: '{{ item.creationDateTime }}'
      endDateTime: '{{ item.endDateTime }}'
      initiatedBy: '{{ item.initiatedBy }}'
      jobID: '{{ item.jobID }}'
      participatingServers: '{{ item.participatingServers }}'
      status: '{{ item.status }}'
      tags: '{{ item.tags }}'
      type: '{{ item.type }}'
- discovery_id: aws.mgn.describeLaunchConfigurationTemplates
  calls:
  - action: describeLaunchConfigurationTemplates
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
    item:
      arn: '{{ item.arn }}'
      associatePublicIpAddress: '{{ item.associatePublicIpAddress }}'
      bootMode: '{{ item.bootMode }}'
      copyPrivateIp: '{{ item.copyPrivateIp }}'
      copyTags: '{{ item.copyTags }}'
      ec2LaunchTemplateID: '{{ item.ec2LaunchTemplateID }}'
      enableMapAutoTagging: '{{ item.enableMapAutoTagging }}'
      largeVolumeConf: '{{ item.largeVolumeConf }}'
      launchConfigurationTemplateID: '{{ item.launchConfigurationTemplateID }}'
      launchDisposition: '{{ item.launchDisposition }}'
      licensing: '{{ item.licensing }}'
      mapAutoTaggingMpeID: '{{ item.mapAutoTaggingMpeID }}'
      postLaunchActions: '{{ item.postLaunchActions }}'
      smallVolumeConf: '{{ item.smallVolumeConf }}'
      smallVolumeMaxSize: '{{ item.smallVolumeMaxSize }}'
      tags: '{{ item.tags }}'
      targetInstanceTypeRightSizingMethod: '{{ item.targetInstanceTypeRightSizingMethod
        }}'
- discovery_id: aws.mgn.describeReplicationConfigurationTemplates
  calls:
  - action: describeReplicationConfigurationTemplates
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
    item:
      arn: '{{ item.arn }}'
      associateDefaultSecurityGroup: '{{ item.associateDefaultSecurityGroup }}'
      bandwidthThrottling: '{{ item.bandwidthThrottling }}'
      createPublicIP: '{{ item.createPublicIP }}'
      dataPlaneRouting: '{{ item.dataPlaneRouting }}'
      defaultLargeStagingDiskType: '{{ item.defaultLargeStagingDiskType }}'
      ebsEncryption: '{{ item.ebsEncryption }}'
      ebsEncryptionKeyArn: '{{ item.ebsEncryptionKeyArn }}'
      replicationConfigurationTemplateID: '{{ item.replicationConfigurationTemplateID
        }}'
      replicationServerInstanceType: '{{ item.replicationServerInstanceType }}'
      replicationServersSecurityGroupsIDs: '{{ item.replicationServersSecurityGroupsIDs
        }}'
      stagingAreaSubnetId: '{{ item.stagingAreaSubnetId }}'
      stagingAreaTags: '{{ item.stagingAreaTags }}'
      tags: '{{ item.tags }}'
      useDedicatedReplicationServer: '{{ item.useDedicatedReplicationServer }}'
      useFipsEndpoint: '{{ item.useFipsEndpoint }}'
- discovery_id: aws.mgn.describeSourceServers
  calls:
  - action: describeSourceServers
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
    item:
      applicationID: '{{ item.applicationID }}'
      arn: '{{ item.arn }}'
      connectorAction: '{{ item.connectorAction }}'
      dataReplicationInfo: '{{ item.dataReplicationInfo }}'
      fqdnForActionFramework: '{{ item.fqdnForActionFramework }}'
      isArchived: '{{ item.isArchived }}'
      launchedInstance: '{{ item.launchedInstance }}'
      lifeCycle: '{{ item.lifeCycle }}'
      replicationType: '{{ item.replicationType }}'
      sourceProperties: '{{ item.sourceProperties }}'
      sourceServerID: '{{ item.sourceServerID }}'
      tags: '{{ item.tags }}'
      userProvidedID: '{{ item.userProvidedID }}'
      vcenterClientID: '{{ item.vcenterClientID }}'
- discovery_id: aws.mgn.describeVcenterClients
  calls:
  - action: describeVcenterClients
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
    item:
      arn: '{{ item.arn }}'
      datacenterName: '{{ item.datacenterName }}'
      hostname: '{{ item.hostname }}'
      lastSeenDatetime: '{{ item.lastSeenDatetime }}'
      sourceServerTags: '{{ item.sourceServerTags }}'
      tags: '{{ item.tags }}'
      vcenterClientID: '{{ item.vcenterClientID }}'
      vcenterUUID: '{{ item.vcenterUUID }}'
- discovery_id: aws.mgn.listApplications
  calls:
  - action: listApplications
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
    item:
      applicationAggregatedStatus: '{{ item.applicationAggregatedStatus }}'
      applicationID: '{{ item.applicationID }}'
      arn: '{{ item.arn }}'
      creationDateTime: '{{ item.creationDateTime }}'
      description: '{{ item.description }}'
      isArchived: '{{ item.isArchived }}'
      lastModifiedDateTime: '{{ item.lastModifiedDateTime }}'
      name: '{{ item.name }}'
      tags: '{{ item.tags }}'
      waveID: '{{ item.waveID }}'
- discovery_id: aws.mgn.listConnectors
  calls:
  - action: listConnectors
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
    item:
      arn: '{{ item.arn }}'
      connectorID: '{{ item.connectorID }}'
      name: '{{ item.name }}'
      ssmCommandConfig: '{{ item.ssmCommandConfig }}'
      ssmInstanceID: '{{ item.ssmInstanceID }}'
      tags: '{{ item.tags }}'
- discovery_id: aws.mgn.listExports
  calls:
  - action: listExports
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
    item:
      creationDateTime: '{{ item.creationDateTime }}'
      endDateTime: '{{ item.endDateTime }}'
      exportID: '{{ item.exportID }}'
      progressPercentage: '{{ item.progressPercentage }}'
      s3Bucket: '{{ item.s3Bucket }}'
      s3BucketOwner: '{{ item.s3BucketOwner }}'
      s3Key: '{{ item.s3Key }}'
      status: '{{ item.status }}'
      summary: '{{ item.summary }}'
- discovery_id: aws.mgn.listImports
  calls:
  - action: listImports
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
    item:
      creationDateTime: '{{ item.creationDateTime }}'
      endDateTime: '{{ item.endDateTime }}'
      importID: '{{ item.importID }}'
      progressPercentage: '{{ item.progressPercentage }}'
      s3BucketSource: '{{ item.s3BucketSource }}'
      status: '{{ item.status }}'
      summary: '{{ item.summary }}'
- discovery_id: aws.mgn.listManagedAccounts
  calls:
  - action: listManagedAccounts
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
    item:
      accountId: '{{ item.accountId }}'
- discovery_id: aws.mgn.listWaves
  calls:
  - action: listWaves
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
    item:
      arn: '{{ item.arn }}'
      creationDateTime: '{{ item.creationDateTime }}'
      description: '{{ item.description }}'
      isArchived: '{{ item.isArchived }}'
      lastModifiedDateTime: '{{ item.lastModifiedDateTime }}'
      name: '{{ item.name }}'
      tags: '{{ item.tags }}'
      waveAggregatedStatus: '{{ item.waveAggregatedStatus }}'
      waveID: '{{ item.waveID }}'
- discovery_id: aws.mgn.describeJobLogItems
  calls:
  - action: describeJobLogItems
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
    item:
      event: '{{ item.event }}'
      eventData: '{{ item.eventData }}'
      logDateTime: '{{ item.logDateTime }}'
- discovery_id: aws.mgn.getLaunchConfiguration
  calls:
  - action: getLaunchConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.licensing }}'
    item:
      osByol: '{{ item.osByol }}'
- discovery_id: aws.mgn.getReplicationConfiguration
  calls:
  - action: getReplicationConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.replicationServersSecurityGroupsIDs }}'
- discovery_id: aws.mgn.listExportErrors
  calls:
  - action: listExportErrors
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
    item:
      errorData: '{{ item.errorData }}'
      errorDateTime: '{{ item.errorDateTime }}'
- discovery_id: aws.mgn.listImportErrors
  calls:
  - action: listImportErrors
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
    item:
      errorData: '{{ item.errorData }}'
      errorDateTime: '{{ item.errorDateTime }}'
      errorType: '{{ item.errorType }}'
- discovery_id: aws.mgn.listSourceServerActions
  calls:
  - action: listSourceServerActions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
    item:
      actionID: '{{ item.actionID }}'
      actionName: '{{ item.actionName }}'
      active: '{{ item.active }}'
      category: '{{ item.category }}'
      description: '{{ item.description }}'
      documentIdentifier: '{{ item.documentIdentifier }}'
      documentVersion: '{{ item.documentVersion }}'
      externalParameters: '{{ item.externalParameters }}'
      mustSucceedForCutover: '{{ item.mustSucceedForCutover }}'
      order: '{{ item.order }}'
      parameters: '{{ item.parameters }}'
      timeoutSeconds: '{{ item.timeoutSeconds }}'
- discovery_id: aws.mgn.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tags }}'
- discovery_id: aws.mgn.listTemplateActions
  calls:
  - action: listTemplateActions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
    item:
      actionID: '{{ item.actionID }}'
      actionName: '{{ item.actionName }}'
      active: '{{ item.active }}'
      category: '{{ item.category }}'
      description: '{{ item.description }}'
      documentIdentifier: '{{ item.documentIdentifier }}'
      documentVersion: '{{ item.documentVersion }}'
      externalParameters: '{{ item.externalParameters }}'
      mustSucceedForCutover: '{{ item.mustSucceedForCutover }}'
      operatingSystem: '{{ item.operatingSystem }}'
      order: '{{ item.order }}'
      parameters: '{{ item.parameters }}'
      timeoutSeconds: '{{ item.timeoutSeconds }}'
checks: []
