version: '1.0'
provider: aws
service: kinesisanalyticsv2
services:
  client: kinesisanalyticsv2
  module: boto3.client
discovery:
- discovery_id: aws.kinesisanalyticsv2.listApplications
  calls:
  - action: listApplications
    save_as: response
    on_error: continue
    params:
      Limit: 1000
  emit:
    as: item
    items_for: '{{ response.ApplicationSummaries }}'
    item:
      ApplicationName: '{{ item.ApplicationName }}'
      ApplicationARN: '{{ item.ApplicationARN }}'
      ApplicationStatus: '{{ item.ApplicationStatus }}'
      ApplicationVersionId: '{{ item.ApplicationVersionId }}'
      RuntimeEnvironment: '{{ item.RuntimeEnvironment }}'
      ApplicationMode: '{{ item.ApplicationMode }}'
- discovery_id: aws.kinesisanalyticsv2.describeApplication
  calls:
  - action: describeApplication
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ApplicationDetail }}'
    item:
      ApplicationARN: '{{ item.ApplicationARN }}'
      ApplicationDescription: '{{ item.ApplicationDescription }}'
      ApplicationName: '{{ item.ApplicationName }}'
      RuntimeEnvironment: '{{ item.RuntimeEnvironment }}'
      ServiceExecutionRole: '{{ item.ServiceExecutionRole }}'
      ApplicationStatus: '{{ item.ApplicationStatus }}'
      ApplicationVersionId: '{{ item.ApplicationVersionId }}'
      CreateTimestamp: '{{ item.CreateTimestamp }}'
      LastUpdateTimestamp: '{{ item.LastUpdateTimestamp }}'
      ApplicationConfigurationDescription: '{{ item.ApplicationConfigurationDescription
        }}'
      CloudWatchLoggingOptionDescriptions: '{{ item.CloudWatchLoggingOptionDescriptions
        }}'
      ApplicationMaintenanceConfigurationDescription: '{{ item.ApplicationMaintenanceConfigurationDescription
        }}'
      ApplicationVersionUpdatedFrom: '{{ item.ApplicationVersionUpdatedFrom }}'
      ApplicationVersionRolledBackFrom: '{{ item.ApplicationVersionRolledBackFrom
        }}'
      ApplicationVersionCreateTimestamp: '{{ item.ApplicationVersionCreateTimestamp
        }}'
      ConditionalToken: '{{ item.ConditionalToken }}'
      ApplicationVersionRolledBackTo: '{{ item.ApplicationVersionRolledBackTo }}'
      ApplicationMode: '{{ item.ApplicationMode }}'
- discovery_id: aws.kinesisanalyticsv2.describeApplicationOperation
  calls:
  - action: describeApplicationOperation
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ApplicationOperationInfoDetails }}'
    item:
      Operation: '{{ item.Operation }}'
      StartTime: '{{ item.StartTime }}'
      EndTime: '{{ item.EndTime }}'
      OperationStatus: '{{ item.OperationStatus }}'
      ApplicationVersionChangeDetails: '{{ item.ApplicationVersionChangeDetails }}'
      OperationFailureDetails: '{{ item.OperationFailureDetails }}'
- discovery_id: aws.kinesisanalyticsv2.describeApplicationSnapshot
  calls:
  - action: describeApplicationSnapshot
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.SnapshotDetails }}'
    item:
      SnapshotName: '{{ item.SnapshotName }}'
      SnapshotStatus: '{{ item.SnapshotStatus }}'
      ApplicationVersionId: '{{ item.ApplicationVersionId }}'
      SnapshotCreationTimestamp: '{{ item.SnapshotCreationTimestamp }}'
      RuntimeEnvironment: '{{ item.RuntimeEnvironment }}'
      ApplicationEncryptionConfigurationDescription: '{{ item.ApplicationEncryptionConfigurationDescription
        }}'
- discovery_id: aws.kinesisanalyticsv2.describeApplicationVersion
  calls:
  - action: describeApplicationVersion
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ApplicationVersionDetail }}'
    item:
      ApplicationARN: '{{ item.ApplicationARN }}'
      ApplicationDescription: '{{ item.ApplicationDescription }}'
      ApplicationName: '{{ item.ApplicationName }}'
      RuntimeEnvironment: '{{ item.RuntimeEnvironment }}'
      ServiceExecutionRole: '{{ item.ServiceExecutionRole }}'
      ApplicationStatus: '{{ item.ApplicationStatus }}'
      ApplicationVersionId: '{{ item.ApplicationVersionId }}'
      CreateTimestamp: '{{ item.CreateTimestamp }}'
      LastUpdateTimestamp: '{{ item.LastUpdateTimestamp }}'
      ApplicationConfigurationDescription: '{{ item.ApplicationConfigurationDescription
        }}'
      CloudWatchLoggingOptionDescriptions: '{{ item.CloudWatchLoggingOptionDescriptions
        }}'
      ApplicationMaintenanceConfigurationDescription: '{{ item.ApplicationMaintenanceConfigurationDescription
        }}'
      ApplicationVersionUpdatedFrom: '{{ item.ApplicationVersionUpdatedFrom }}'
      ApplicationVersionRolledBackFrom: '{{ item.ApplicationVersionRolledBackFrom
        }}'
      ApplicationVersionCreateTimestamp: '{{ item.ApplicationVersionCreateTimestamp
        }}'
      ConditionalToken: '{{ item.ConditionalToken }}'
      ApplicationVersionRolledBackTo: '{{ item.ApplicationVersionRolledBackTo }}'
      ApplicationMode: '{{ item.ApplicationMode }}'
- discovery_id: aws.kinesisanalyticsv2.listApplicationOperations
  calls:
  - action: listApplicationOperations
    save_as: response
    on_error: continue
    params:
      Limit: 1000
  emit:
    as: item
    items_for: '{{ response.ApplicationOperationInfoList }}'
    item:
      Operation: '{{ item.Operation }}'
      OperationId: '{{ item.OperationId }}'
      StartTime: '{{ item.StartTime }}'
      EndTime: '{{ item.EndTime }}'
      OperationStatus: '{{ item.OperationStatus }}'
- discovery_id: aws.kinesisanalyticsv2.listApplicationSnapshots
  calls:
  - action: listApplicationSnapshots
    save_as: response
    on_error: continue
    params:
      Limit: 1000
  emit:
    as: item
    items_for: '{{ response.SnapshotSummaries }}'
    item:
      SnapshotName: '{{ item.SnapshotName }}'
      SnapshotStatus: '{{ item.SnapshotStatus }}'
      ApplicationVersionId: '{{ item.ApplicationVersionId }}'
      SnapshotCreationTimestamp: '{{ item.SnapshotCreationTimestamp }}'
      RuntimeEnvironment: '{{ item.RuntimeEnvironment }}'
      ApplicationEncryptionConfigurationDescription: '{{ item.ApplicationEncryptionConfigurationDescription
        }}'
- discovery_id: aws.kinesisanalyticsv2.listApplicationVersions
  calls:
  - action: listApplicationVersions
    save_as: response
    on_error: continue
    params:
      Limit: 1000
  emit:
    as: item
    items_for: '{{ response.ApplicationVersionSummaries }}'
    item:
      ApplicationVersionId: '{{ item.ApplicationVersionId }}'
      ApplicationStatus: '{{ item.ApplicationStatus }}'
- discovery_id: aws.kinesisanalyticsv2.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Tags }}'
    item:
      Key: '{{ item.Key }}'
      Value: '{{ item.Value }}'
checks: []
