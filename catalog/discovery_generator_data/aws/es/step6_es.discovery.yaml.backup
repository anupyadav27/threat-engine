version: '1.0'
provider: aws
service: es
services:
  client: es
  module: boto3.client
discovery:
- discovery_id: aws.es.describeInboundCrossClusterSearchConnections
  calls:
  - action: describeInboundCrossClusterSearchConnections
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.CrossClusterSearchConnections }}'
    item:
      SourceDomainInfo: '{{ item.SourceDomainInfo }}'
      DestinationDomainInfo: '{{ item.DestinationDomainInfo }}'
      CrossClusterSearchConnectionId: '{{ item.CrossClusterSearchConnectionId }}'
      ConnectionStatus: '{{ item.ConnectionStatus }}'
- discovery_id: aws.es.describeOutboundCrossClusterSearchConnections
  calls:
  - action: describeOutboundCrossClusterSearchConnections
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.CrossClusterSearchConnections }}'
    item:
      SourceDomainInfo: '{{ item.SourceDomainInfo }}'
      DestinationDomainInfo: '{{ item.DestinationDomainInfo }}'
      CrossClusterSearchConnectionId: '{{ item.CrossClusterSearchConnectionId }}'
      ConnectionAlias: '{{ item.ConnectionAlias }}'
      ConnectionStatus: '{{ item.ConnectionStatus }}'
- discovery_id: aws.es.describePackages
  calls:
  - action: describePackages
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.PackageDetailsList }}'
    item:
      PackageID: '{{ item.PackageID }}'
      PackageName: '{{ item.PackageName }}'
      PackageType: '{{ item.PackageType }}'
      PackageDescription: '{{ item.PackageDescription }}'
      PackageStatus: '{{ item.PackageStatus }}'
      CreatedAt: '{{ item.CreatedAt }}'
      LastUpdatedAt: '{{ item.LastUpdatedAt }}'
      AvailablePackageVersion: '{{ item.AvailablePackageVersion }}'
      ErrorDetails: '{{ item.ErrorDetails }}'
- discovery_id: aws.es.describeReservedElasticsearchInstanceOfferings
  calls:
  - action: describeReservedElasticsearchInstanceOfferings
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ReservedElasticsearchInstanceOfferings }}'
    item:
      ReservedElasticsearchInstanceOfferingId: '{{ item.ReservedElasticsearchInstanceOfferingId
        }}'
      ElasticsearchInstanceType: '{{ item.ElasticsearchInstanceType }}'
      Duration: '{{ item.Duration }}'
      FixedPrice: '{{ item.FixedPrice }}'
      UsagePrice: '{{ item.UsagePrice }}'
      CurrencyCode: '{{ item.CurrencyCode }}'
      PaymentOption: '{{ item.PaymentOption }}'
      RecurringCharges: '{{ item.RecurringCharges }}'
- discovery_id: aws.es.describeReservedElasticsearchInstances
  calls:
  - action: describeReservedElasticsearchInstances
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ReservedElasticsearchInstances }}'
    item:
      ReservationName: '{{ item.ReservationName }}'
      ReservedElasticsearchInstanceId: '{{ item.ReservedElasticsearchInstanceId }}'
      ReservedElasticsearchInstanceOfferingId: '{{ item.ReservedElasticsearchInstanceOfferingId
        }}'
      ElasticsearchInstanceType: '{{ item.ElasticsearchInstanceType }}'
      StartTime: '{{ item.StartTime }}'
      Duration: '{{ item.Duration }}'
      FixedPrice: '{{ item.FixedPrice }}'
      UsagePrice: '{{ item.UsagePrice }}'
      CurrencyCode: '{{ item.CurrencyCode }}'
      ElasticsearchInstanceCount: '{{ item.ElasticsearchInstanceCount }}'
      State: '{{ item.State }}'
      PaymentOption: '{{ item.PaymentOption }}'
      RecurringCharges: '{{ item.RecurringCharges }}'
- discovery_id: aws.es.getCompatibleElasticsearchVersions
  calls:
  - action: getCompatibleElasticsearchVersions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.CompatibleElasticsearchVersions }}'
    item:
      SourceVersion: '{{ item.SourceVersion }}'
      TargetVersions: '{{ item.TargetVersions }}'
- discovery_id: aws.es.listDomainNames
  calls:
  - action: listDomainNames
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.DomainNames }}'
    item:
      DomainName: '{{ item.DomainName }}'
      EngineType: '{{ item.EngineType }}'
- discovery_id: aws.es.listElasticsearchVersions
  calls:
  - action: listElasticsearchVersions
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.ElasticsearchVersions }}'
- discovery_id: aws.es.listVpcEndpoints
  calls:
  - action: listVpcEndpoints
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.VpcEndpointSummaryList }}'
    item:
      VpcEndpointId: '{{ item.VpcEndpointId }}'
      VpcEndpointOwner: '{{ item.VpcEndpointOwner }}'
      DomainArn: '{{ item.DomainArn }}'
      Status: '{{ item.Status }}'
- discovery_id: aws.es.describeDomainAutoTunes
  calls:
  - action: describeDomainAutoTunes
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AutoTunes }}'
    item:
      AutoTuneType: '{{ item.AutoTuneType }}'
      AutoTuneDetails: '{{ item.AutoTuneDetails }}'
- discovery_id: aws.es.describeDomainChangeProgress
  calls:
  - action: describeDomainChangeProgress
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ChangeProgressStatus }}'
    item:
      ChangeId: '{{ item.ChangeId }}'
      StartTime: '{{ item.StartTime }}'
      Status: '{{ item.Status }}'
      PendingProperties: '{{ item.PendingProperties }}'
      CompletedProperties: '{{ item.CompletedProperties }}'
      TotalNumberOfStages: '{{ item.TotalNumberOfStages }}'
      ChangeProgressStages: '{{ item.ChangeProgressStages }}'
      ConfigChangeStatus: '{{ item.ConfigChangeStatus }}'
      LastUpdatedTime: '{{ item.LastUpdatedTime }}'
      InitiatedBy: '{{ item.InitiatedBy }}'
- discovery_id: aws.es.describeElasticsearchDomain
  calls:
  - action: describeElasticsearchDomain
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.DomainStatus }}'
    item:
      DomainId: '{{ item.DomainId }}'
      DomainName: '{{ item.DomainName }}'
      ARN: '{{ item.ARN }}'
      Created: '{{ item.Created }}'
      Deleted: '{{ item.Deleted }}'
      Endpoint: '{{ item.Endpoint }}'
      Endpoints: '{{ item.Endpoints }}'
      Processing: '{{ item.Processing }}'
      UpgradeProcessing: '{{ item.UpgradeProcessing }}'
      ElasticsearchVersion: '{{ item.ElasticsearchVersion }}'
      ElasticsearchClusterConfig: '{{ item.ElasticsearchClusterConfig }}'
      EBSOptions: '{{ item.EBSOptions }}'
      AccessPolicies: '{{ item.AccessPolicies }}'
      SnapshotOptions: '{{ item.SnapshotOptions }}'
      VPCOptions: '{{ item.VPCOptions }}'
      CognitoOptions: '{{ item.CognitoOptions }}'
      EncryptionAtRestOptions: '{{ item.EncryptionAtRestOptions }}'
      NodeToNodeEncryptionOptions: '{{ item.NodeToNodeEncryptionOptions }}'
      AdvancedOptions: '{{ item.AdvancedOptions }}'
      LogPublishingOptions: '{{ item.LogPublishingOptions }}'
      ServiceSoftwareOptions: '{{ item.ServiceSoftwareOptions }}'
      DomainEndpointOptions: '{{ item.DomainEndpointOptions }}'
      AdvancedSecurityOptions: '{{ item.AdvancedSecurityOptions }}'
      AutoTuneOptions: '{{ item.AutoTuneOptions }}'
      ChangeProgressDetails: '{{ item.ChangeProgressDetails }}'
      DomainProcessingStatus: '{{ item.DomainProcessingStatus }}'
      ModifyingProperties: '{{ item.ModifyingProperties }}'
- discovery_id: aws.es.describeElasticsearchDomainConfig
  calls:
  - action: describeElasticsearchDomainConfig
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.DomainConfig }}'
    item:
      ElasticsearchVersion: '{{ item.ElasticsearchVersion }}'
      ElasticsearchClusterConfig: '{{ item.ElasticsearchClusterConfig }}'
      EBSOptions: '{{ item.EBSOptions }}'
      AccessPolicies: '{{ item.AccessPolicies }}'
      SnapshotOptions: '{{ item.SnapshotOptions }}'
      VPCOptions: '{{ item.VPCOptions }}'
      CognitoOptions: '{{ item.CognitoOptions }}'
      EncryptionAtRestOptions: '{{ item.EncryptionAtRestOptions }}'
      NodeToNodeEncryptionOptions: '{{ item.NodeToNodeEncryptionOptions }}'
      AdvancedOptions: '{{ item.AdvancedOptions }}'
      LogPublishingOptions: '{{ item.LogPublishingOptions }}'
      DomainEndpointOptions: '{{ item.DomainEndpointOptions }}'
      AdvancedSecurityOptions: '{{ item.AdvancedSecurityOptions }}'
      AutoTuneOptions: '{{ item.AutoTuneOptions }}'
      ChangeProgressDetails: '{{ item.ChangeProgressDetails }}'
      ModifyingProperties: '{{ item.ModifyingProperties }}'
- discovery_id: aws.es.describeElasticsearchDomains
  calls:
  - action: describeElasticsearchDomains
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.DomainStatusList }}'
    item:
      DomainId: '{{ item.DomainId }}'
      DomainName: '{{ item.DomainName }}'
      ARN: '{{ item.ARN }}'
      Created: '{{ item.Created }}'
      Deleted: '{{ item.Deleted }}'
      Endpoint: '{{ item.Endpoint }}'
      Endpoints: '{{ item.Endpoints }}'
      Processing: '{{ item.Processing }}'
      UpgradeProcessing: '{{ item.UpgradeProcessing }}'
      ElasticsearchVersion: '{{ item.ElasticsearchVersion }}'
      ElasticsearchClusterConfig: '{{ item.ElasticsearchClusterConfig }}'
      EBSOptions: '{{ item.EBSOptions }}'
      AccessPolicies: '{{ item.AccessPolicies }}'
      SnapshotOptions: '{{ item.SnapshotOptions }}'
      VPCOptions: '{{ item.VPCOptions }}'
      CognitoOptions: '{{ item.CognitoOptions }}'
      EncryptionAtRestOptions: '{{ item.EncryptionAtRestOptions }}'
      NodeToNodeEncryptionOptions: '{{ item.NodeToNodeEncryptionOptions }}'
      AdvancedOptions: '{{ item.AdvancedOptions }}'
      LogPublishingOptions: '{{ item.LogPublishingOptions }}'
      ServiceSoftwareOptions: '{{ item.ServiceSoftwareOptions }}'
      DomainEndpointOptions: '{{ item.DomainEndpointOptions }}'
      AdvancedSecurityOptions: '{{ item.AdvancedSecurityOptions }}'
      AutoTuneOptions: '{{ item.AutoTuneOptions }}'
      ChangeProgressDetails: '{{ item.ChangeProgressDetails }}'
      DomainProcessingStatus: '{{ item.DomainProcessingStatus }}'
      ModifyingProperties: '{{ item.ModifyingProperties }}'
- discovery_id: aws.es.describeElasticsearchInstanceTypeLimits
  calls:
  - action: describeElasticsearchInstanceTypeLimits
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.LimitsByRole }}'
- discovery_id: aws.es.describeVpcEndpoints
  calls:
  - action: describeVpcEndpoints
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.VpcEndpoints }}'
    item:
      VpcEndpointId: '{{ item.VpcEndpointId }}'
      VpcEndpointOwner: '{{ item.VpcEndpointOwner }}'
      DomainArn: '{{ item.DomainArn }}'
      VpcOptions: '{{ item.VpcOptions }}'
      Status: '{{ item.Status }}'
      Endpoint: '{{ item.Endpoint }}'
- discovery_id: aws.es.getPackageVersionHistory
  calls:
  - action: getPackageVersionHistory
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.PackageVersionHistoryList }}'
    item:
      PackageVersion: '{{ item.PackageVersion }}'
      CommitMessage: '{{ item.CommitMessage }}'
      CreatedAt: '{{ item.CreatedAt }}'
- discovery_id: aws.es.getUpgradeHistory
  calls:
  - action: getUpgradeHistory
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.UpgradeHistories }}'
    item:
      UpgradeName: '{{ item.UpgradeName }}'
      StartTimestamp: '{{ item.StartTimestamp }}'
      UpgradeStatus: '{{ item.UpgradeStatus }}'
      StepsList: '{{ item.StepsList }}'
- discovery_id: aws.es.getUpgradeStatus
  calls:
  - action: getUpgradeStatus
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.UpgradeStep }}'
- discovery_id: aws.es.listDomainsForPackage
  calls:
  - action: listDomainsForPackage
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.DomainPackageDetailsList }}'
    item:
      PackageID: '{{ item.PackageID }}'
      PackageName: '{{ item.PackageName }}'
      PackageType: '{{ item.PackageType }}'
      LastUpdated: '{{ item.LastUpdated }}'
      DomainName: '{{ item.DomainName }}'
      DomainPackageStatus: '{{ item.DomainPackageStatus }}'
      PackageVersion: '{{ item.PackageVersion }}'
      ReferencePath: '{{ item.ReferencePath }}'
      ErrorDetails: '{{ item.ErrorDetails }}'
- discovery_id: aws.es.listElasticsearchInstanceTypes
  calls:
  - action: listElasticsearchInstanceTypes
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.ElasticsearchInstanceTypes }}'
- discovery_id: aws.es.listPackagesForDomain
  calls:
  - action: listPackagesForDomain
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.DomainPackageDetailsList }}'
    item:
      PackageID: '{{ item.PackageID }}'
      PackageName: '{{ item.PackageName }}'
      PackageType: '{{ item.PackageType }}'
      LastUpdated: '{{ item.LastUpdated }}'
      DomainName: '{{ item.DomainName }}'
      DomainPackageStatus: '{{ item.DomainPackageStatus }}'
      PackageVersion: '{{ item.PackageVersion }}'
      ReferencePath: '{{ item.ReferencePath }}'
      ErrorDetails: '{{ item.ErrorDetails }}'
- discovery_id: aws.es.listTags
  calls:
  - action: listTags
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.TagList }}'
    item:
      Key: '{{ item.Key }}'
      Value: '{{ item.Value }}'
- discovery_id: aws.es.listVpcEndpointAccess
  calls:
  - action: listVpcEndpointAccess
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AuthorizedPrincipalList }}'
    item:
      PrincipalType: '{{ item.PrincipalType }}'
      Principal: '{{ item.Principal }}'
- discovery_id: aws.es.listVpcEndpointsForDomain
  calls:
  - action: listVpcEndpointsForDomain
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.VpcEndpointSummaryList }}'
    item:
      VpcEndpointId: '{{ item.VpcEndpointId }}'
      VpcEndpointOwner: '{{ item.VpcEndpointOwner }}'
      DomainArn: '{{ item.DomainArn }}'
      Status: '{{ item.Status }}'
checks: []
