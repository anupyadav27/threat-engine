version: '1.0'
provider: aws
service: rolesanywhere
services:
  client: rolesanywhere
  module: boto3.client
discovery:
- discovery_id: aws.rolesanywhere.listCrls
  calls:
  - action: listCrls
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.crls }}'
    item:
      createdAt: '{{ item.createdAt }}'
      crlArn: '{{ item.crlArn }}'
      crlData: '{{ item.crlData }}'
      crlId: '{{ item.crlId }}'
      enabled: '{{ item.enabled }}'
      name: '{{ item.name }}'
      trustAnchorArn: '{{ item.trustAnchorArn }}'
      updatedAt: '{{ item.updatedAt }}'
- discovery_id: aws.rolesanywhere.listProfiles
  calls:
  - action: listProfiles
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.profiles }}'
    item:
      acceptRoleSessionName: '{{ item.acceptRoleSessionName }}'
      attributeMappings: '{{ item.attributeMappings }}'
      createdAt: '{{ item.createdAt }}'
      createdBy: '{{ item.createdBy }}'
      durationSeconds: '{{ item.durationSeconds }}'
      enabled: '{{ item.enabled }}'
      managedPolicyArns: '{{ item.managedPolicyArns }}'
      name: '{{ item.name }}'
      profileArn: '{{ item.profileArn }}'
      profileId: '{{ item.profileId }}'
      requireInstanceProperties: '{{ item.requireInstanceProperties }}'
      roleArns: '{{ item.roleArns }}'
      sessionPolicy: '{{ item.sessionPolicy }}'
      updatedAt: '{{ item.updatedAt }}'
- discovery_id: aws.rolesanywhere.listSubjects
  calls:
  - action: listSubjects
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.subjects }}'
    item:
      createdAt: '{{ item.createdAt }}'
      enabled: '{{ item.enabled }}'
      lastSeenAt: '{{ item.lastSeenAt }}'
      subjectArn: '{{ item.subjectArn }}'
      subjectId: '{{ item.subjectId }}'
      updatedAt: '{{ item.updatedAt }}'
      x509Subject: '{{ item.x509Subject }}'
- discovery_id: aws.rolesanywhere.listTrustAnchors
  calls:
  - action: listTrustAnchors
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.trustAnchors }}'
    item:
      createdAt: '{{ item.createdAt }}'
      enabled: '{{ item.enabled }}'
      name: '{{ item.name }}'
      notificationSettings: '{{ item.notificationSettings }}'
      source: '{{ item.source }}'
      trustAnchorArn: '{{ item.trustAnchorArn }}'
      trustAnchorId: '{{ item.trustAnchorId }}'
      updatedAt: '{{ item.updatedAt }}'
- discovery_id: aws.rolesanywhere.getCrl
  calls:
  - action: getCrl
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.crl }}'
    item:
      createdAt: '{{ item.createdAt }}'
      crlArn: '{{ item.crlArn }}'
      crlData: '{{ item.crlData }}'
      crlId: '{{ item.crlId }}'
      enabled: '{{ item.enabled }}'
      name: '{{ item.name }}'
      trustAnchorArn: '{{ item.trustAnchorArn }}'
      updatedAt: '{{ item.updatedAt }}'
- discovery_id: aws.rolesanywhere.getProfile
  calls:
  - action: getProfile
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.profile }}'
    item:
      acceptRoleSessionName: '{{ item.acceptRoleSessionName }}'
      attributeMappings: '{{ item.attributeMappings }}'
      createdAt: '{{ item.createdAt }}'
      createdBy: '{{ item.createdBy }}'
      durationSeconds: '{{ item.durationSeconds }}'
      enabled: '{{ item.enabled }}'
      managedPolicyArns: '{{ item.managedPolicyArns }}'
      name: '{{ item.name }}'
      profileArn: '{{ item.profileArn }}'
      profileId: '{{ item.profileId }}'
      requireInstanceProperties: '{{ item.requireInstanceProperties }}'
      roleArns: '{{ item.roleArns }}'
      sessionPolicy: '{{ item.sessionPolicy }}'
      updatedAt: '{{ item.updatedAt }}'
- discovery_id: aws.rolesanywhere.getSubject
  calls:
  - action: getSubject
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.subject }}'
    item:
      createdAt: '{{ item.createdAt }}'
      credentials: '{{ item.credentials }}'
      enabled: '{{ item.enabled }}'
      instanceProperties: '{{ item.instanceProperties }}'
      lastSeenAt: '{{ item.lastSeenAt }}'
      subjectArn: '{{ item.subjectArn }}'
      subjectId: '{{ item.subjectId }}'
      updatedAt: '{{ item.updatedAt }}'
      x509Subject: '{{ item.x509Subject }}'
- discovery_id: aws.rolesanywhere.getTrustAnchor
  calls:
  - action: getTrustAnchor
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.trustAnchor }}'
    item:
      createdAt: '{{ item.createdAt }}'
      enabled: '{{ item.enabled }}'
      name: '{{ item.name }}'
      notificationSettings: '{{ item.notificationSettings }}'
      source: '{{ item.source }}'
      trustAnchorArn: '{{ item.trustAnchorArn }}'
      trustAnchorId: '{{ item.trustAnchorId }}'
      updatedAt: '{{ item.updatedAt }}'
- discovery_id: aws.rolesanywhere.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tags }}'
    item:
      key: '{{ item.key }}'
      value: '{{ item.value }}'
checks: []
