version: '1.0'
provider: aws
service: ecr
services:
  client: ecr
  module: boto3.client
discovery:
- discovery_id: aws.ecr.describePullThroughCacheRules
  calls:
  - action: describePullThroughCacheRules
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.pullThroughCacheRules }}'
    item:
      ecrRepositoryPrefix: '{{ item.ecrRepositoryPrefix }}'
      upstreamRegistryUrl: '{{ item.upstreamRegistryUrl }}'
      createdAt: '{{ item.createdAt }}'
      registryId: '{{ item.registryId }}'
      credentialArn: '{{ item.credentialArn }}'
      customRoleArn: '{{ item.customRoleArn }}'
      upstreamRepositoryPrefix: '{{ item.upstreamRepositoryPrefix }}'
      upstreamRegistry: '{{ item.upstreamRegistry }}'
      updatedAt: '{{ item.updatedAt }}'
- discovery_id: aws.ecr.describeRegistry
  calls:
  - action: describeRegistry
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.replicationConfiguration }}'
    item:
      rules: '{{ item.rules }}'
- discovery_id: aws.ecr.describeRepositories
  calls:
  - action: describeRepositories
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.repositories }}'
    item:
      repositoryArn: '{{ item.repositoryArn }}'
      registryId: '{{ item.registryId }}'
      repositoryName: '{{ item.repositoryName }}'
      repositoryUri: '{{ item.repositoryUri }}'
      createdAt: '{{ item.createdAt }}'
      imageTagMutability: '{{ item.imageTagMutability }}'
      imageTagMutabilityExclusionFilters: '{{ item.imageTagMutabilityExclusionFilters
        }}'
      imageScanningConfiguration: '{{ item.imageScanningConfiguration }}'
      encryptionConfiguration: '{{ item.encryptionConfiguration }}'
- discovery_id: aws.ecr.describeRepositoryCreationTemplates
  calls:
  - action: describeRepositoryCreationTemplates
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.repositoryCreationTemplates }}'
    item:
      prefix: '{{ item.prefix }}'
      description: '{{ item.description }}'
      encryptionConfiguration: '{{ item.encryptionConfiguration }}'
      resourceTags: '{{ item.resourceTags }}'
      imageTagMutability: '{{ item.imageTagMutability }}'
      imageTagMutabilityExclusionFilters: '{{ item.imageTagMutabilityExclusionFilters
        }}'
      repositoryPolicy: '{{ item.repositoryPolicy }}'
      lifecyclePolicy: '{{ item.lifecyclePolicy }}'
      appliedFor: '{{ item.appliedFor }}'
      customRoleArn: '{{ item.customRoleArn }}'
      createdAt: '{{ item.createdAt }}'
      updatedAt: '{{ item.updatedAt }}'
- discovery_id: aws.ecr.getAuthorizationToken
  calls:
  - action: getAuthorizationToken
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.authorizationData }}'
    item:
      authorizationToken: '{{ item.authorizationToken }}'
      expiresAt: '{{ item.expiresAt }}'
      proxyEndpoint: '{{ item.proxyEndpoint }}'
- discovery_id: aws.ecr.getRegistryPolicy
  calls:
  - action: getRegistryPolicy
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.registryId }}'
- discovery_id: aws.ecr.getRegistryScanningConfiguration
  calls:
  - action: getRegistryScanningConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.scanningConfiguration }}'
    item:
      scanType: '{{ item.scanType }}'
      rules: '{{ item.rules }}'
- discovery_id: aws.ecr.getSigningConfiguration
  calls:
  - action: getSigningConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.signingConfiguration }}'
    item:
      rules: '{{ item.rules }}'
- discovery_id: aws.ecr.listPullTimeUpdateExclusions
  calls:
  - action: listPullTimeUpdateExclusions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.pullTimeUpdateExclusions }}'
- discovery_id: aws.ecr.describeImageReplicationStatus
  calls:
  - action: describeImageReplicationStatus
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.replicationStatuses }}'
    item:
      region: '{{ item.region }}'
      registryId: '{{ item.registryId }}'
      status: '{{ item.status }}'
      failureCode: '{{ item.failureCode }}'
- discovery_id: aws.ecr.describeImageScanFindings
  calls:
  - action: describeImageScanFindings
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.imageId }}'
    item:
      imageDigest: '{{ item.imageDigest }}'
      imageTag: '{{ item.imageTag }}'
- discovery_id: aws.ecr.describeImageSigningStatus
  calls:
  - action: describeImageSigningStatus
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.signingStatuses }}'
    item:
      signingProfileArn: '{{ item.signingProfileArn }}'
      failureCode: '{{ item.failureCode }}'
      failureReason: '{{ item.failureReason }}'
      status: '{{ item.status }}'
- discovery_id: aws.ecr.describeImages
  calls:
  - action: describeImages
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.imageDetails }}'
    item:
      registryId: '{{ item.registryId }}'
      repositoryName: '{{ item.repositoryName }}'
      imageDigest: '{{ item.imageDigest }}'
      imageTags: '{{ item.imageTags }}'
      imageSizeInBytes: '{{ item.imageSizeInBytes }}'
      imagePushedAt: '{{ item.imagePushedAt }}'
      imageScanStatus: '{{ item.imageScanStatus }}'
      imageScanFindingsSummary: '{{ item.imageScanFindingsSummary }}'
      imageManifestMediaType: '{{ item.imageManifestMediaType }}'
      artifactMediaType: '{{ item.artifactMediaType }}'
      lastRecordedPullTime: '{{ item.lastRecordedPullTime }}'
      subjectManifestDigest: '{{ item.subjectManifestDigest }}'
      imageStatus: '{{ item.imageStatus }}'
      lastArchivedAt: '{{ item.lastArchivedAt }}'
      lastActivatedAt: '{{ item.lastActivatedAt }}'
- discovery_id: aws.ecr.getAccountSetting
  calls:
  - action: getAccountSetting
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.name }}'
- discovery_id: aws.ecr.getDownloadUrlForLayer
  calls:
  - action: getDownloadUrlForLayer
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.downloadUrl }}'
- discovery_id: aws.ecr.getLifecyclePolicy
  calls:
  - action: getLifecyclePolicy
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.registryId }}'
- discovery_id: aws.ecr.getLifecyclePolicyPreview
  calls:
  - action: getLifecyclePolicyPreview
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.previewResults }}'
    item:
      imageTags: '{{ item.imageTags }}'
      imageDigest: '{{ item.imageDigest }}'
      imagePushedAt: '{{ item.imagePushedAt }}'
      action: '{{ item.action }}'
      appliedRulePriority: '{{ item.appliedRulePriority }}'
      storageClass: '{{ item.storageClass }}'
- discovery_id: aws.ecr.getRepositoryPolicy
  calls:
  - action: getRepositoryPolicy
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.registryId }}'
- discovery_id: aws.ecr.listImageReferrers
  calls:
  - action: listImageReferrers
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.referrers }}'
    item:
      digest: '{{ item.digest }}'
      mediaType: '{{ item.mediaType }}'
      artifactType: '{{ item.artifactType }}'
      size: '{{ item.size }}'
      annotations: '{{ item.annotations }}'
      artifactStatus: '{{ item.artifactStatus }}'
- discovery_id: aws.ecr.listImages
  calls:
  - action: listImages
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.imageIds }}'
    item:
      imageDigest: '{{ item.imageDigest }}'
      imageTag: '{{ item.imageTag }}'
- discovery_id: aws.ecr.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tags }}'
    item:
      Key: '{{ item.Key }}'
      Value: '{{ item.Value }}'
checks: []
