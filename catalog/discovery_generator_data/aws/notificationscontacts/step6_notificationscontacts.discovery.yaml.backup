version: '1.0'
provider: aws
service: notificationscontacts
services:
  client: notificationscontacts
  module: boto3.client
discovery:
- discovery_id: aws.notificationscontacts.listEmailContacts
  calls:
  - action: listEmailContacts
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.emailContacts }}'
    item:
      arn: '{{ item.arn }}'
      name: '{{ item.name }}'
      address: '{{ item.address }}'
      status: '{{ item.status }}'
      creationTime: '{{ item.creationTime }}'
      updateTime: '{{ item.updateTime }}'
- discovery_id: aws.notificationscontacts.getEmailContact
  calls:
  - action: getEmailContact
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.emailContact }}'
    item:
      arn: '{{ item.arn }}'
      name: '{{ item.name }}'
      address: '{{ item.address }}'
      status: '{{ item.status }}'
      creationTime: '{{ item.creationTime }}'
      updateTime: '{{ item.updateTime }}'
- discovery_id: aws.notificationscontacts.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tags }}'
checks: []
