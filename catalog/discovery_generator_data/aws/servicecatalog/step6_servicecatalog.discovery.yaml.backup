version: '1.0'
provider: aws
service: servicecatalog
services:
  client: servicecatalog
  module: boto3.client
discovery:
- discovery_id: aws.servicecatalog.describeProduct
  calls:
  - action: describeProduct
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ProvisioningArtifacts }}'
    item:
      Id: '{{ item.Id }}'
      Name: '{{ item.Name }}'
      Description: '{{ item.Description }}'
      CreatedTime: '{{ item.CreatedTime }}'
      Guidance: '{{ item.Guidance }}'
- discovery_id: aws.servicecatalog.describeProductAsAdmin
  calls:
  - action: describeProductAsAdmin
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ProvisioningArtifactSummaries }}'
    item:
      Id: '{{ item.Id }}'
      Name: '{{ item.Name }}'
      Description: '{{ item.Description }}'
      CreatedTime: '{{ item.CreatedTime }}'
      ProvisioningArtifactMetadata: '{{ item.ProvisioningArtifactMetadata }}'
- discovery_id: aws.servicecatalog.describeProvisionedProduct
  calls:
  - action: describeProvisionedProduct
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.CloudWatchDashboards }}'
    item:
      Name: '{{ item.Name }}'
- discovery_id: aws.servicecatalog.describeProvisioningArtifact
  calls:
  - action: describeProvisioningArtifact
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ProvisioningArtifactParameters }}'
    item:
      ParameterKey: '{{ item.ParameterKey }}'
      DefaultValue: '{{ item.DefaultValue }}'
      ParameterType: '{{ item.ParameterType }}'
      IsNoEcho: '{{ item.IsNoEcho }}'
      Description: '{{ item.Description }}'
      ParameterConstraints: '{{ item.ParameterConstraints }}'
- discovery_id: aws.servicecatalog.describeProvisioningParameters
  calls:
  - action: describeProvisioningParameters
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ProvisioningArtifactOutputKeys }}'
    item:
      Key: '{{ item.Key }}'
      Description: '{{ item.Description }}'
- discovery_id: aws.servicecatalog.getAwsOrganizationsAccessStatus
  calls:
  - action: getAwsOrganizationsAccessStatus
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AccessStatus }}'
- discovery_id: aws.servicecatalog.getProvisionedProductOutputs
  calls:
  - action: getProvisionedProductOutputs
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Outputs }}'
    item:
      OutputKey: '{{ item.OutputKey }}'
      OutputValue: '{{ item.OutputValue }}'
      Description: '{{ item.Description }}'
- discovery_id: aws.servicecatalog.listAcceptedPortfolioShares
  calls:
  - action: listAcceptedPortfolioShares
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.PortfolioDetails }}'
    item:
      Id: '{{ item.Id }}'
      ARN: '{{ item.ARN }}'
      DisplayName: '{{ item.DisplayName }}'
      Description: '{{ item.Description }}'
      CreatedTime: '{{ item.CreatedTime }}'
      ProviderName: '{{ item.ProviderName }}'
- discovery_id: aws.servicecatalog.listPortfolios
  calls:
  - action: listPortfolios
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.PortfolioDetails }}'
    item:
      Id: '{{ item.Id }}'
      ARN: '{{ item.ARN }}'
      DisplayName: '{{ item.DisplayName }}'
      Description: '{{ item.Description }}'
      CreatedTime: '{{ item.CreatedTime }}'
      ProviderName: '{{ item.ProviderName }}'
- discovery_id: aws.servicecatalog.listProvisionedProductPlans
  calls:
  - action: listProvisionedProductPlans
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ProvisionedProductPlans }}'
    item:
      PlanName: '{{ item.PlanName }}'
      PlanId: '{{ item.PlanId }}'
      ProvisionProductId: '{{ item.ProvisionProductId }}'
      ProvisionProductName: '{{ item.ProvisionProductName }}'
      PlanType: '{{ item.PlanType }}'
      ProvisioningArtifactId: '{{ item.ProvisioningArtifactId }}'
- discovery_id: aws.servicecatalog.listRecordHistory
  calls:
  - action: listRecordHistory
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.RecordDetails }}'
    item:
      RecordId: '{{ item.RecordId }}'
      ProvisionedProductName: '{{ item.ProvisionedProductName }}'
      Status: '{{ item.Status }}'
      CreatedTime: '{{ item.CreatedTime }}'
      UpdatedTime: '{{ item.UpdatedTime }}'
      ProvisionedProductType: '{{ item.ProvisionedProductType }}'
      RecordType: '{{ item.RecordType }}'
      ProvisionedProductId: '{{ item.ProvisionedProductId }}'
      ProductId: '{{ item.ProductId }}'
      ProvisioningArtifactId: '{{ item.ProvisioningArtifactId }}'
      PathId: '{{ item.PathId }}'
      RecordErrors: '{{ item.RecordErrors }}'
      RecordTags: '{{ item.RecordTags }}'
      LaunchRoleArn: '{{ item.LaunchRoleArn }}'
- discovery_id: aws.servicecatalog.listServiceActions
  calls:
  - action: listServiceActions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ServiceActionSummaries }}'
    item:
      Id: '{{ item.Id }}'
      Name: '{{ item.Name }}'
      Description: '{{ item.Description }}'
      DefinitionType: '{{ item.DefinitionType }}'
- discovery_id: aws.servicecatalog.listTagOptions
  calls:
  - action: listTagOptions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.TagOptionDetails }}'
    item:
      Key: '{{ item.Key }}'
      Value: '{{ item.Value }}'
      Active: '{{ item.Active }}'
      Id: '{{ item.Id }}'
      Owner: '{{ item.Owner }}'
- discovery_id: aws.servicecatalog.searchProducts
  calls:
  - action: searchProducts
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ProductViewSummaries }}'
    item:
      Id: '{{ item.Id }}'
      ProductId: '{{ item.ProductId }}'
      Name: '{{ item.Name }}'
      Owner: '{{ item.Owner }}'
      ShortDescription: '{{ item.ShortDescription }}'
      Type: '{{ item.Type }}'
      Distributor: '{{ item.Distributor }}'
      HasDefaultPath: '{{ item.HasDefaultPath }}'
      SupportEmail: '{{ item.SupportEmail }}'
      SupportDescription: '{{ item.SupportDescription }}'
      SupportUrl: '{{ item.SupportUrl }}'
- discovery_id: aws.servicecatalog.searchProductsAsAdmin
  calls:
  - action: searchProductsAsAdmin
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ProductViewDetails }}'
    item:
      ProductViewSummary: '{{ item.ProductViewSummary }}'
      Status: '{{ item.Status }}'
      ProductARN: '{{ item.ProductARN }}'
      CreatedTime: '{{ item.CreatedTime }}'
      SourceConnection: '{{ item.SourceConnection }}'
- discovery_id: aws.servicecatalog.searchProvisionedProducts
  calls:
  - action: searchProvisionedProducts
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ProvisionedProducts }}'
    item:
      Name: '{{ item.Name }}'
      Arn: '{{ item.Arn }}'
      Type: '{{ item.Type }}'
      Id: '{{ item.Id }}'
      Status: '{{ item.Status }}'
      StatusMessage: '{{ item.StatusMessage }}'
      CreatedTime: '{{ item.CreatedTime }}'
      IdempotencyToken: '{{ item.IdempotencyToken }}'
      LastRecordId: '{{ item.LastRecordId }}'
      LastProvisioningRecordId: '{{ item.LastProvisioningRecordId }}'
      LastSuccessfulProvisioningRecordId: '{{ item.LastSuccessfulProvisioningRecordId
        }}'
      Tags: '{{ item.Tags }}'
      PhysicalId: '{{ item.PhysicalId }}'
      ProductId: '{{ item.ProductId }}'
      ProductName: '{{ item.ProductName }}'
      ProvisioningArtifactId: '{{ item.ProvisioningArtifactId }}'
      ProvisioningArtifactName: '{{ item.ProvisioningArtifactName }}'
      UserArn: '{{ item.UserArn }}'
      UserArnSession: '{{ item.UserArnSession }}'
- discovery_id: aws.servicecatalog.describeConstraint
  calls:
  - action: describeConstraint
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ConstraintDetail }}'
    item:
      ConstraintId: '{{ item.ConstraintId }}'
      Type: '{{ item.Type }}'
      Description: '{{ item.Description }}'
      Owner: '{{ item.Owner }}'
      ProductId: '{{ item.ProductId }}'
      PortfolioId: '{{ item.PortfolioId }}'
- discovery_id: aws.servicecatalog.describeCopyProductStatus
  calls:
  - action: describeCopyProductStatus
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.CopyProductStatus }}'
- discovery_id: aws.servicecatalog.describePortfolio
  calls:
  - action: describePortfolio
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Tags }}'
    item:
      Key: '{{ item.Key }}'
      Value: '{{ item.Value }}'
- discovery_id: aws.servicecatalog.describePortfolioShareStatus
  calls:
  - action: describePortfolioShareStatus
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ShareDetails }}'
    item:
      SuccessfulShares: '{{ item.SuccessfulShares }}'
      ShareErrors: '{{ item.ShareErrors }}'
- discovery_id: aws.servicecatalog.describePortfolioShares
  calls:
  - action: describePortfolioShares
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.PortfolioShareDetails }}'
    item:
      PrincipalId: '{{ item.PrincipalId }}'
      Type: '{{ item.Type }}'
      Accepted: '{{ item.Accepted }}'
      ShareTagOptions: '{{ item.ShareTagOptions }}'
      SharePrincipals: '{{ item.SharePrincipals }}'
- discovery_id: aws.servicecatalog.describeProductView
  calls:
  - action: describeProductView
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ProvisioningArtifacts }}'
    item:
      Id: '{{ item.Id }}'
      Name: '{{ item.Name }}'
      Description: '{{ item.Description }}'
      CreatedTime: '{{ item.CreatedTime }}'
      Guidance: '{{ item.Guidance }}'
- discovery_id: aws.servicecatalog.describeProvisionedProductPlan
  calls:
  - action: describeProvisionedProductPlan
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ResourceChanges }}'
    item:
      Action: '{{ item.Action }}'
      LogicalResourceId: '{{ item.LogicalResourceId }}'
      PhysicalResourceId: '{{ item.PhysicalResourceId }}'
      ResourceType: '{{ item.ResourceType }}'
      Replacement: '{{ item.Replacement }}'
      Scope: '{{ item.Scope }}'
      Details: '{{ item.Details }}'
- discovery_id: aws.servicecatalog.describeRecord
  calls:
  - action: describeRecord
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.RecordOutputs }}'
    item:
      OutputKey: '{{ item.OutputKey }}'
      OutputValue: '{{ item.OutputValue }}'
      Description: '{{ item.Description }}'
- discovery_id: aws.servicecatalog.describeServiceAction
  calls:
  - action: describeServiceAction
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ServiceActionDetail }}'
    item:
      ServiceActionSummary: '{{ item.ServiceActionSummary }}'
      Definition: '{{ item.Definition }}'
- discovery_id: aws.servicecatalog.describeServiceActionExecutionParameters
  calls:
  - action: describeServiceActionExecutionParameters
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ServiceActionParameters }}'
    item:
      Name: '{{ item.Name }}'
      Type: '{{ item.Type }}'
      DefaultValues: '{{ item.DefaultValues }}'
- discovery_id: aws.servicecatalog.describeTagOption
  calls:
  - action: describeTagOption
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.TagOptionDetail }}'
    item:
      Key: '{{ item.Key }}'
      Value: '{{ item.Value }}'
      Active: '{{ item.Active }}'
      Id: '{{ item.Id }}'
      Owner: '{{ item.Owner }}'
- discovery_id: aws.servicecatalog.listBudgetsForResource
  calls:
  - action: listBudgetsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Budgets }}'
    item:
      BudgetName: '{{ item.BudgetName }}'
- discovery_id: aws.servicecatalog.listConstraintsForPortfolio
  calls:
  - action: listConstraintsForPortfolio
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ConstraintDetails }}'
    item:
      ConstraintId: '{{ item.ConstraintId }}'
      Type: '{{ item.Type }}'
      Description: '{{ item.Description }}'
      Owner: '{{ item.Owner }}'
      ProductId: '{{ item.ProductId }}'
      PortfolioId: '{{ item.PortfolioId }}'
- discovery_id: aws.servicecatalog.listLaunchPaths
  calls:
  - action: listLaunchPaths
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.LaunchPathSummaries }}'
    item:
      Id: '{{ item.Id }}'
      ConstraintSummaries: '{{ item.ConstraintSummaries }}'
      Tags: '{{ item.Tags }}'
      Name: '{{ item.Name }}'
- discovery_id: aws.servicecatalog.listOrganizationPortfolioAccess
  calls:
  - action: listOrganizationPortfolioAccess
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.OrganizationNodes }}'
    item:
      Type: '{{ item.Type }}'
      Value: '{{ item.Value }}'
- discovery_id: aws.servicecatalog.listPortfolioAccess
  calls:
  - action: listPortfolioAccess
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AccountIds }}'
- discovery_id: aws.servicecatalog.listPortfoliosForProduct
  calls:
  - action: listPortfoliosForProduct
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.PortfolioDetails }}'
    item:
      Id: '{{ item.Id }}'
      ARN: '{{ item.ARN }}'
      DisplayName: '{{ item.DisplayName }}'
      Description: '{{ item.Description }}'
      CreatedTime: '{{ item.CreatedTime }}'
      ProviderName: '{{ item.ProviderName }}'
- discovery_id: aws.servicecatalog.listPrincipalsForPortfolio
  calls:
  - action: listPrincipalsForPortfolio
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Principals }}'
    item:
      PrincipalARN: '{{ item.PrincipalARN }}'
      PrincipalType: '{{ item.PrincipalType }}'
- discovery_id: aws.servicecatalog.listProvisioningArtifacts
  calls:
  - action: listProvisioningArtifacts
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ProvisioningArtifactDetails }}'
    item:
      Id: '{{ item.Id }}'
      Name: '{{ item.Name }}'
      Description: '{{ item.Description }}'
      Type: '{{ item.Type }}'
      CreatedTime: '{{ item.CreatedTime }}'
      Active: '{{ item.Active }}'
      Guidance: '{{ item.Guidance }}'
      SourceRevision: '{{ item.SourceRevision }}'
- discovery_id: aws.servicecatalog.listProvisioningArtifactsForServiceAction
  calls:
  - action: listProvisioningArtifactsForServiceAction
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ProvisioningArtifactViews }}'
    item:
      ProductViewSummary: '{{ item.ProductViewSummary }}'
      ProvisioningArtifact: '{{ item.ProvisioningArtifact }}'
- discovery_id: aws.servicecatalog.listResourcesForTagOption
  calls:
  - action: listResourcesForTagOption
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ResourceDetails }}'
    item:
      Id: '{{ item.Id }}'
      ARN: '{{ item.ARN }}'
      Name: '{{ item.Name }}'
      Description: '{{ item.Description }}'
      CreatedTime: '{{ item.CreatedTime }}'
- discovery_id: aws.servicecatalog.listServiceActionsForProvisioningArtifact
  calls:
  - action: listServiceActionsForProvisioningArtifact
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ServiceActionSummaries }}'
    item:
      Id: '{{ item.Id }}'
      Name: '{{ item.Name }}'
      Description: '{{ item.Description }}'
      DefinitionType: '{{ item.DefinitionType }}'
- discovery_id: aws.servicecatalog.listStackInstancesForProvisionedProduct
  calls:
  - action: listStackInstancesForProvisionedProduct
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.StackInstances }}'
    item:
      Account: '{{ item.Account }}'
      Region: '{{ item.Region }}'
      StackInstanceStatus: '{{ item.StackInstanceStatus }}'
checks: []
