version: '1.0'
provider: aws
service: compute-optimizer-automation
services:
  client: compute-optimizer-automation
  module: boto3.client
discovery:
- discovery_id: aws.compute-optimizer-automation.getEnrollmentConfiguration
  calls:
  - action: getEnrollmentConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.status }}'
- discovery_id: aws.compute-optimizer-automation.listAccounts
  calls:
  - action: listAccounts
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.accounts }}'
    item:
      accountId: '{{ item.accountId }}'
      status: '{{ item.status }}'
      organizationRuleMode: '{{ item.organizationRuleMode }}'
      statusReason: '{{ item.statusReason }}'
      lastUpdatedTimestamp: '{{ item.lastUpdatedTimestamp }}'
- discovery_id: aws.compute-optimizer-automation.listAutomationEventSummaries
  calls:
  - action: listAutomationEventSummaries
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.automationEventSummaries }}'
    item:
      key: '{{ item.key }}'
      dimensions: '{{ item.dimensions }}'
      timePeriod: '{{ item.timePeriod }}'
      total: '{{ item.total }}'
- discovery_id: aws.compute-optimizer-automation.listAutomationEvents
  calls:
  - action: listAutomationEvents
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.automationEvents }}'
    item:
      eventId: '{{ item.eventId }}'
      eventDescription: '{{ item.eventDescription }}'
      eventType: '{{ item.eventType }}'
      eventStatus: '{{ item.eventStatus }}'
      eventStatusReason: '{{ item.eventStatusReason }}'
      resourceArn: '{{ item.resourceArn }}'
      resourceId: '{{ item.resourceId }}'
      recommendedActionId: '{{ item.recommendedActionId }}'
      accountId: '{{ item.accountId }}'
      region: '{{ item.region }}'
      ruleId: '{{ item.ruleId }}'
      resourceType: '{{ item.resourceType }}'
      createdTimestamp: '{{ item.createdTimestamp }}'
      completedTimestamp: '{{ item.completedTimestamp }}'
      estimatedMonthlySavings: '{{ item.estimatedMonthlySavings }}'
- discovery_id: aws.compute-optimizer-automation.listAutomationRules
  calls:
  - action: listAutomationRules
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.automationRules }}'
    item:
      ruleArn: '{{ item.ruleArn }}'
      ruleId: '{{ item.ruleId }}'
      name: '{{ item.name }}'
      description: '{{ item.description }}'
      ruleType: '{{ item.ruleType }}'
      ruleRevision: '{{ item.ruleRevision }}'
      accountId: '{{ item.accountId }}'
      organizationConfiguration: '{{ item.organizationConfiguration }}'
      priority: '{{ item.priority }}'
      recommendedActionTypes: '{{ item.recommendedActionTypes }}'
      schedule: '{{ item.schedule }}'
      status: '{{ item.status }}'
      createdTimestamp: '{{ item.createdTimestamp }}'
      lastUpdatedTimestamp: '{{ item.lastUpdatedTimestamp }}'
- discovery_id: aws.compute-optimizer-automation.listRecommendedActionSummaries
  calls:
  - action: listRecommendedActionSummaries
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.recommendedActionSummaries }}'
    item:
      key: '{{ item.key }}'
      total: '{{ item.total }}'
- discovery_id: aws.compute-optimizer-automation.listRecommendedActions
  calls:
  - action: listRecommendedActions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.recommendedActions }}'
    item:
      recommendedActionId: '{{ item.recommendedActionId }}'
      resourceArn: '{{ item.resourceArn }}'
      resourceId: '{{ item.resourceId }}'
      accountId: '{{ item.accountId }}'
      region: '{{ item.region }}'
      resourceType: '{{ item.resourceType }}'
      lookBackPeriodInDays: '{{ item.lookBackPeriodInDays }}'
      recommendedActionType: '{{ item.recommendedActionType }}'
      currentResourceSummary: '{{ item.currentResourceSummary }}'
      currentResourceDetails: '{{ item.currentResourceDetails }}'
      recommendedResourceSummary: '{{ item.recommendedResourceSummary }}'
      recommendedResourceDetails: '{{ item.recommendedResourceDetails }}'
      restartNeeded: '{{ item.restartNeeded }}'
      estimatedMonthlySavings: '{{ item.estimatedMonthlySavings }}'
      resourceTags: '{{ item.resourceTags }}'
- discovery_id: aws.compute-optimizer-automation.getAutomationEvent
  calls:
  - action: getAutomationEvent
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.estimatedMonthlySavings }}'
    item:
      currency: '{{ item.currency }}'
      beforeDiscountSavings: '{{ item.beforeDiscountSavings }}'
      afterDiscountSavings: '{{ item.afterDiscountSavings }}'
      savingsEstimationMode: '{{ item.savingsEstimationMode }}'
- discovery_id: aws.compute-optimizer-automation.getAutomationRule
  calls:
  - action: getAutomationRule
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.recommendedActionTypes }}'
- discovery_id: aws.compute-optimizer-automation.listAutomationEventSteps
  calls:
  - action: listAutomationEventSteps
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.automationEventSteps }}'
    item:
      eventId: '{{ item.eventId }}'
      stepId: '{{ item.stepId }}'
      stepType: '{{ item.stepType }}'
      stepStatus: '{{ item.stepStatus }}'
      resourceId: '{{ item.resourceId }}'
      startTimestamp: '{{ item.startTimestamp }}'
      completedTimestamp: '{{ item.completedTimestamp }}'
      estimatedMonthlySavings: '{{ item.estimatedMonthlySavings }}'
- discovery_id: aws.compute-optimizer-automation.listAutomationRulePreview
  calls:
  - action: listAutomationRulePreview
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.previewResults }}'
    item:
      recommendedActionId: '{{ item.recommendedActionId }}'
      resourceArn: '{{ item.resourceArn }}'
      resourceId: '{{ item.resourceId }}'
      accountId: '{{ item.accountId }}'
      region: '{{ item.region }}'
      resourceType: '{{ item.resourceType }}'
      lookBackPeriodInDays: '{{ item.lookBackPeriodInDays }}'
      recommendedActionType: '{{ item.recommendedActionType }}'
      currentResourceSummary: '{{ item.currentResourceSummary }}'
      currentResourceDetails: '{{ item.currentResourceDetails }}'
      recommendedResourceSummary: '{{ item.recommendedResourceSummary }}'
      recommendedResourceDetails: '{{ item.recommendedResourceDetails }}'
      restartNeeded: '{{ item.restartNeeded }}'
      estimatedMonthlySavings: '{{ item.estimatedMonthlySavings }}'
      resourceTags: '{{ item.resourceTags }}'
- discovery_id: aws.compute-optimizer-automation.listAutomationRulePreviewSummaries
  calls:
  - action: listAutomationRulePreviewSummaries
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.previewResultSummaries }}'
    item:
      key: '{{ item.key }}'
      total: '{{ item.total }}'
- discovery_id: aws.compute-optimizer-automation.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tags }}'
    item:
      key: '{{ item.key }}'
      value: '{{ item.value }}'
checks: []
