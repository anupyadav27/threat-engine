version: '1.0'
provider: aws
service: lambda
services:
  client: lambda
  module: boto3.client
discovery:
- discovery_id: aws.lambda.getAccountSettings
  calls:
  - action: getAccountSettings
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AccountLimit }}'
    item:
      TotalCodeSize: '{{ item.TotalCodeSize }}'
      CodeSizeUnzipped: '{{ item.CodeSizeUnzipped }}'
      CodeSizeZipped: '{{ item.CodeSizeZipped }}'
      ConcurrentExecutions: '{{ item.ConcurrentExecutions }}'
      UnreservedConcurrentExecutions: '{{ item.UnreservedConcurrentExecutions }}'
- discovery_id: aws.lambda.listCodeSigningConfigs
  calls:
  - action: listCodeSigningConfigs
    save_as: response
    on_error: continue
    params:
      MaxItems: 1000
  emit:
    as: item
    items_for: '{{ response.CodeSigningConfigs }}'
    item:
      CodeSigningConfigId: '{{ item.CodeSigningConfigId }}'
      CodeSigningConfigArn: '{{ item.CodeSigningConfigArn }}'
      Description: '{{ item.Description }}'
      AllowedPublishers: '{{ item.AllowedPublishers }}'
      CodeSigningPolicies: '{{ item.CodeSigningPolicies }}'
      LastModified: '{{ item.LastModified }}'
- discovery_id: aws.lambda.listEventSourceMappings
  calls:
  - action: listEventSourceMappings
    save_as: response
    on_error: continue
    params:
      MaxItems: 1000
  emit:
    as: item
    items_for: '{{ response.EventSourceMappings }}'
    item:
      UUID: '{{ item.UUID }}'
      StartingPosition: '{{ item.StartingPosition }}'
      StartingPositionTimestamp: '{{ item.StartingPositionTimestamp }}'
      BatchSize: '{{ item.BatchSize }}'
      MaximumBatchingWindowInSeconds: '{{ item.MaximumBatchingWindowInSeconds }}'
      ParallelizationFactor: '{{ item.ParallelizationFactor }}'
      EventSourceArn: '{{ item.EventSourceArn }}'
      FilterCriteria: '{{ item.FilterCriteria }}'
      FunctionArn: '{{ item.FunctionArn }}'
      LastModified: '{{ item.LastModified }}'
      LastProcessingResult: '{{ item.LastProcessingResult }}'
      State: '{{ item.State }}'
      StateTransitionReason: '{{ item.StateTransitionReason }}'
      DestinationConfig: '{{ item.DestinationConfig }}'
      Topics: '{{ item.Topics }}'
      Queues: '{{ item.Queues }}'
      SourceAccessConfigurations: '{{ item.SourceAccessConfigurations }}'
      SelfManagedEventSource: '{{ item.SelfManagedEventSource }}'
      MaximumRecordAgeInSeconds: '{{ item.MaximumRecordAgeInSeconds }}'
      BisectBatchOnFunctionError: '{{ item.BisectBatchOnFunctionError }}'
      MaximumRetryAttempts: '{{ item.MaximumRetryAttempts }}'
      TumblingWindowInSeconds: '{{ item.TumblingWindowInSeconds }}'
      FunctionResponseTypes: '{{ item.FunctionResponseTypes }}'
      AmazonManagedKafkaEventSourceConfig: '{{ item.AmazonManagedKafkaEventSourceConfig
        }}'
      SelfManagedKafkaEventSourceConfig: '{{ item.SelfManagedKafkaEventSourceConfig
        }}'
      ScalingConfig: '{{ item.ScalingConfig }}'
      DocumentDBEventSourceConfig: '{{ item.DocumentDBEventSourceConfig }}'
      KMSKeyArn: '{{ item.KMSKeyArn }}'
      FilterCriteriaError: '{{ item.FilterCriteriaError }}'
      EventSourceMappingArn: '{{ item.EventSourceMappingArn }}'
      MetricsConfig: '{{ item.MetricsConfig }}'
      ProvisionedPollerConfig: '{{ item.ProvisionedPollerConfig }}'
- discovery_id: aws.lambda.listFunctions
  calls:
  - action: listFunctions
    save_as: response
    on_error: continue
    params:
      MaxItems: 1000
  emit:
    as: item
    items_for: '{{ response.Functions }}'
    item:
      FunctionName: '{{ item.FunctionName }}'
      FunctionArn: '{{ item.FunctionArn }}'
      Runtime: '{{ item.Runtime }}'
      Role: '{{ item.Role }}'
      Handler: '{{ item.Handler }}'
      CodeSize: '{{ item.CodeSize }}'
      Description: '{{ item.Description }}'
      Timeout: '{{ item.Timeout }}'
      MemorySize: '{{ item.MemorySize }}'
      LastModified: '{{ item.LastModified }}'
      CodeSha256: '{{ item.CodeSha256 }}'
      Version: '{{ item.Version }}'
      VpcConfig: '{{ item.VpcConfig }}'
      DeadLetterConfig: '{{ item.DeadLetterConfig }}'
      Environment: '{{ item.Environment }}'
      KMSKeyArn: '{{ item.KMSKeyArn }}'
      TracingConfig: '{{ item.TracingConfig }}'
      MasterArn: '{{ item.MasterArn }}'
      RevisionId: '{{ item.RevisionId }}'
      Layers: '{{ item.Layers }}'
      State: '{{ item.State }}'
      StateReason: '{{ item.StateReason }}'
      StateReasonCode: '{{ item.StateReasonCode }}'
      LastUpdateStatus: '{{ item.LastUpdateStatus }}'
      LastUpdateStatusReason: '{{ item.LastUpdateStatusReason }}'
      LastUpdateStatusReasonCode: '{{ item.LastUpdateStatusReasonCode }}'
      FileSystemConfigs: '{{ item.FileSystemConfigs }}'
      PackageType: '{{ item.PackageType }}'
      ImageConfigResponse: '{{ item.ImageConfigResponse }}'
      SigningProfileVersionArn: '{{ item.SigningProfileVersionArn }}'
      SigningJobArn: '{{ item.SigningJobArn }}'
      Architectures: '{{ item.Architectures }}'
      EphemeralStorage: '{{ item.EphemeralStorage }}'
      SnapStart: '{{ item.SnapStart }}'
      RuntimeVersionConfig: '{{ item.RuntimeVersionConfig }}'
      LoggingConfig: '{{ item.LoggingConfig }}'
      TenancyConfig: '{{ item.TenancyConfig }}'
- discovery_id: aws.lambda.listLayers
  calls:
  - action: listLayers
    save_as: response
    on_error: continue
    params:
      MaxItems: 1000
  emit:
    as: item
    items_for: '{{ response.Layers }}'
    item:
      LayerName: '{{ item.LayerName }}'
      LayerArn: '{{ item.LayerArn }}'
      LatestMatchingVersion: '{{ item.LatestMatchingVersion }}'
- discovery_id: aws.lambda.getAlias
  calls:
  - action: getAlias
    save_as: response
    on_error: continue
    params:
      FunctionName: '{{ item.FunctionName }}'
  emit:
    as: item
    items_for: '{{ response.RoutingConfig }}'
    item:
      AdditionalVersionWeights: '{{ item.AdditionalVersionWeights }}'
  for_each: aws.lambda.listFunctions
- discovery_id: aws.lambda.getCodeSigningConfig
  calls:
  - action: getCodeSigningConfig
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.CodeSigningConfig }}'
    item:
      CodeSigningConfigId: '{{ item.CodeSigningConfigId }}'
      CodeSigningConfigArn: '{{ item.CodeSigningConfigArn }}'
      Description: '{{ item.Description }}'
      AllowedPublishers: '{{ item.AllowedPublishers }}'
      CodeSigningPolicies: '{{ item.CodeSigningPolicies }}'
      LastModified: '{{ item.LastModified }}'
- discovery_id: aws.lambda.getEventSourceMapping
  calls:
  - action: getEventSourceMapping
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Topics }}'
- discovery_id: aws.lambda.getFunction
  calls:
  - action: getFunction
    save_as: response
    on_error: continue
    params:
      FunctionName: '{{ item.FunctionName }}'
  emit:
    as: item
    items_for: '{{ response.Configuration }}'
    item:
      FunctionName: '{{ item.FunctionName }}'
      FunctionArn: '{{ item.FunctionArn }}'
      Runtime: '{{ item.Runtime }}'
      Role: '{{ item.Role }}'
      Handler: '{{ item.Handler }}'
      CodeSize: '{{ item.CodeSize }}'
      Description: '{{ item.Description }}'
      Timeout: '{{ item.Timeout }}'
      MemorySize: '{{ item.MemorySize }}'
      LastModified: '{{ item.LastModified }}'
      CodeSha256: '{{ item.CodeSha256 }}'
      Version: '{{ item.Version }}'
      VpcConfig: '{{ item.VpcConfig }}'
      DeadLetterConfig: '{{ item.DeadLetterConfig }}'
      Environment: '{{ item.Environment }}'
      KMSKeyArn: '{{ item.KMSKeyArn }}'
      TracingConfig: '{{ item.TracingConfig }}'
      MasterArn: '{{ item.MasterArn }}'
      RevisionId: '{{ item.RevisionId }}'
      Layers: '{{ item.Layers }}'
      State: '{{ item.State }}'
      StateReason: '{{ item.StateReason }}'
      StateReasonCode: '{{ item.StateReasonCode }}'
      LastUpdateStatus: '{{ item.LastUpdateStatus }}'
      LastUpdateStatusReason: '{{ item.LastUpdateStatusReason }}'
      LastUpdateStatusReasonCode: '{{ item.LastUpdateStatusReasonCode }}'
      FileSystemConfigs: '{{ item.FileSystemConfigs }}'
      PackageType: '{{ item.PackageType }}'
      ImageConfigResponse: '{{ item.ImageConfigResponse }}'
      SigningProfileVersionArn: '{{ item.SigningProfileVersionArn }}'
      SigningJobArn: '{{ item.SigningJobArn }}'
      Architectures: '{{ item.Architectures }}'
      EphemeralStorage: '{{ item.EphemeralStorage }}'
      SnapStart: '{{ item.SnapStart }}'
      RuntimeVersionConfig: '{{ item.RuntimeVersionConfig }}'
      LoggingConfig: '{{ item.LoggingConfig }}'
      TenancyConfig: '{{ item.TenancyConfig }}'
  for_each: aws.lambda.listFunctions
- discovery_id: aws.lambda.getFunctionCodeSigningConfig
  calls:
  - action: getFunctionCodeSigningConfig
    save_as: response
    on_error: continue
    params:
      FunctionName: '{{ item.FunctionName }}'
  emit:
    as: item
    items_for: '{{ response.CodeSigningConfigArn }}'
  for_each: aws.lambda.listFunctions
- discovery_id: aws.lambda.getFunctionConcurrency
  calls:
  - action: getFunctionConcurrency
    save_as: response
    on_error: continue
    params:
      FunctionName: '{{ item.FunctionName }}'
  emit:
    as: item
    items_for: '{{ response.ReservedConcurrentExecutions }}'
  for_each: aws.lambda.listFunctions
- discovery_id: aws.lambda.getFunctionConfiguration
  calls:
  - action: getFunctionConfiguration
    save_as: response
    on_error: continue
    params:
      FunctionName: '{{ item.FunctionName }}'
  emit:
    as: item
    items_for: '{{ response.Layers }}'
    item:
      Arn: '{{ item.Arn }}'
      CodeSize: '{{ item.CodeSize }}'
      SigningProfileVersionArn: '{{ item.SigningProfileVersionArn }}'
      SigningJobArn: '{{ item.SigningJobArn }}'
  for_each: aws.lambda.listFunctions
- discovery_id: aws.lambda.getFunctionEventInvokeConfig
  calls:
  - action: getFunctionEventInvokeConfig
    save_as: response
    on_error: continue
    params:
      FunctionName: '{{ item.FunctionName }}'
  emit:
    as: item
    items_for: '{{ response.DestinationConfig }}'
    item:
      OnSuccess: '{{ item.OnSuccess }}'
      OnFailure: '{{ item.OnFailure }}'
  for_each: aws.lambda.listFunctions
- discovery_id: aws.lambda.getFunctionRecursionConfig
  calls:
  - action: getFunctionRecursionConfig
    save_as: response
    on_error: continue
    params:
      FunctionName: '{{ item.FunctionName }}'
  emit:
    as: item
    items_for: '{{ response.RecursiveLoop }}'
  for_each: aws.lambda.listFunctions
- discovery_id: aws.lambda.getFunctionUrlConfig
  calls:
  - action: getFunctionUrlConfig
    save_as: response
    on_error: continue
    params:
      FunctionName: '{{ item.FunctionName }}'
  emit:
    as: item
    items_for: '{{ response.Cors }}'
    item:
      AllowCredentials: '{{ item.AllowCredentials }}'
      AllowHeaders: '{{ item.AllowHeaders }}'
      AllowMethods: '{{ item.AllowMethods }}'
      AllowOrigins: '{{ item.AllowOrigins }}'
      ExposeHeaders: '{{ item.ExposeHeaders }}'
      MaxAge: '{{ item.MaxAge }}'
  for_each: aws.lambda.listFunctions
- discovery_id: aws.lambda.getLayerVersion
  calls:
  - action: getLayerVersion
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.CompatibleRuntimes }}'
- discovery_id: aws.lambda.getLayerVersionByArn
  calls:
  - action: getLayerVersionByArn
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.CompatibleRuntimes }}'
- discovery_id: aws.lambda.getLayerVersionPolicy
  calls:
  - action: getLayerVersionPolicy
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Policy }}'
- discovery_id: aws.lambda.getPolicy
  calls:
  - action: getPolicy
    save_as: response
    on_error: continue
    params:
      FunctionName: '{{ item.FunctionName }}'
  emit:
    as: item
    items_for: '{{ response.Policy }}'
  for_each: aws.lambda.listFunctions
- discovery_id: aws.lambda.getProvisionedConcurrencyConfig
  calls:
  - action: getProvisionedConcurrencyConfig
    save_as: response
    on_error: continue
    params:
      FunctionName: '{{ item.FunctionName }}'
  emit:
    as: item
    items_for: '{{ response.RequestedProvisionedConcurrentExecutions }}'
  for_each: aws.lambda.listFunctions
- discovery_id: aws.lambda.getRuntimeManagementConfig
  calls:
  - action: getRuntimeManagementConfig
    save_as: response
    on_error: continue
    params:
      FunctionName: '{{ item.FunctionName }}'
  emit:
    as: item
    items_for: '{{ response.UpdateRuntimeOn }}'
  for_each: aws.lambda.listFunctions
- discovery_id: aws.lambda.listAliases
  calls:
  - action: listAliases
    save_as: response
    on_error: continue
    params:
      MaxItems: 1000
      FunctionName: '{{ item.FunctionName }}'
  emit:
    as: item
    items_for: '{{ response.Aliases }}'
    item:
      AliasArn: '{{ item.AliasArn }}'
      Name: '{{ item.Name }}'
      FunctionVersion: '{{ item.FunctionVersion }}'
      Description: '{{ item.Description }}'
      RoutingConfig: '{{ item.RoutingConfig }}'
      RevisionId: '{{ item.RevisionId }}'
  for_each: aws.lambda.listFunctions
- discovery_id: aws.lambda.listFunctionEventInvokeConfigs
  calls:
  - action: listFunctionEventInvokeConfigs
    save_as: response
    on_error: continue
    params:
      MaxItems: 1000
      FunctionName: '{{ item.FunctionName }}'
  emit:
    as: item
    items_for: '{{ response.FunctionEventInvokeConfigs }}'
    item:
      LastModified: '{{ item.LastModified }}'
      FunctionArn: '{{ item.FunctionArn }}'
      MaximumRetryAttempts: '{{ item.MaximumRetryAttempts }}'
      MaximumEventAgeInSeconds: '{{ item.MaximumEventAgeInSeconds }}'
      DestinationConfig: '{{ item.DestinationConfig }}'
  for_each: aws.lambda.listFunctions
- discovery_id: aws.lambda.listFunctionUrlConfigs
  calls:
  - action: listFunctionUrlConfigs
    save_as: response
    on_error: continue
    params:
      MaxItems: 1000
      FunctionName: '{{ item.FunctionName }}'
  emit:
    as: item
    items_for: '{{ response.FunctionUrlConfigs }}'
    item:
      FunctionUrl: '{{ item.FunctionUrl }}'
      FunctionArn: '{{ item.FunctionArn }}'
      CreationTime: '{{ item.CreationTime }}'
      LastModifiedTime: '{{ item.LastModifiedTime }}'
      Cors: '{{ item.Cors }}'
      AuthType: '{{ item.AuthType }}'
      InvokeMode: '{{ item.InvokeMode }}'
  for_each: aws.lambda.listFunctions
- discovery_id: aws.lambda.listFunctionsByCodeSigningConfig
  calls:
  - action: listFunctionsByCodeSigningConfig
    save_as: response
    on_error: continue
    params:
      MaxItems: 1000
  emit:
    as: item
    items_for: '{{ response.FunctionArns }}'
- discovery_id: aws.lambda.listLayerVersions
  calls:
  - action: listLayerVersions
    save_as: response
    on_error: continue
    params:
      MaxItems: 1000
  emit:
    as: item
    items_for: '{{ response.LayerVersions }}'
    item:
      LayerVersionArn: '{{ item.LayerVersionArn }}'
      Version: '{{ item.Version }}'
      Description: '{{ item.Description }}'
      CreatedDate: '{{ item.CreatedDate }}'
      CompatibleRuntimes: '{{ item.CompatibleRuntimes }}'
      LicenseInfo: '{{ item.LicenseInfo }}'
      CompatibleArchitectures: '{{ item.CompatibleArchitectures }}'
- discovery_id: aws.lambda.listProvisionedConcurrencyConfigs
  calls:
  - action: listProvisionedConcurrencyConfigs
    save_as: response
    on_error: continue
    params:
      MaxItems: 1000
      FunctionName: '{{ item.FunctionName }}'
  emit:
    as: item
    items_for: '{{ response.ProvisionedConcurrencyConfigs }}'
    item:
      FunctionArn: '{{ item.FunctionArn }}'
      RequestedProvisionedConcurrentExecutions: '{{ item.RequestedProvisionedConcurrentExecutions
        }}'
      AvailableProvisionedConcurrentExecutions: '{{ item.AvailableProvisionedConcurrentExecutions
        }}'
      AllocatedProvisionedConcurrentExecutions: '{{ item.AllocatedProvisionedConcurrentExecutions
        }}'
      Status: '{{ item.Status }}'
      StatusReason: '{{ item.StatusReason }}'
      LastModified: '{{ item.LastModified }}'
  for_each: aws.lambda.listFunctions
- discovery_id: aws.lambda.listTags
  calls:
  - action: listTags
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Tags }}'
- discovery_id: aws.lambda.listVersionsByFunction
  calls:
  - action: listVersionsByFunction
    save_as: response
    on_error: continue
    params:
      MaxItems: 1000
      FunctionName: '{{ item.FunctionName }}'
  emit:
    as: item
    items_for: '{{ response.Versions }}'
    item:
      FunctionName: '{{ item.FunctionName }}'
      FunctionArn: '{{ item.FunctionArn }}'
      Runtime: '{{ item.Runtime }}'
      Role: '{{ item.Role }}'
      Handler: '{{ item.Handler }}'
      CodeSize: '{{ item.CodeSize }}'
      Description: '{{ item.Description }}'
      Timeout: '{{ item.Timeout }}'
      MemorySize: '{{ item.MemorySize }}'
      LastModified: '{{ item.LastModified }}'
      CodeSha256: '{{ item.CodeSha256 }}'
      Version: '{{ item.Version }}'
      VpcConfig: '{{ item.VpcConfig }}'
      DeadLetterConfig: '{{ item.DeadLetterConfig }}'
      Environment: '{{ item.Environment }}'
      KMSKeyArn: '{{ item.KMSKeyArn }}'
      TracingConfig: '{{ item.TracingConfig }}'
      MasterArn: '{{ item.MasterArn }}'
      RevisionId: '{{ item.RevisionId }}'
      Layers: '{{ item.Layers }}'
      State: '{{ item.State }}'
      StateReason: '{{ item.StateReason }}'
      StateReasonCode: '{{ item.StateReasonCode }}'
      LastUpdateStatus: '{{ item.LastUpdateStatus }}'
      LastUpdateStatusReason: '{{ item.LastUpdateStatusReason }}'
      LastUpdateStatusReasonCode: '{{ item.LastUpdateStatusReasonCode }}'
      FileSystemConfigs: '{{ item.FileSystemConfigs }}'
      PackageType: '{{ item.PackageType }}'
      ImageConfigResponse: '{{ item.ImageConfigResponse }}'
      SigningProfileVersionArn: '{{ item.SigningProfileVersionArn }}'
      SigningJobArn: '{{ item.SigningJobArn }}'
      Architectures: '{{ item.Architectures }}'
      EphemeralStorage: '{{ item.EphemeralStorage }}'
      SnapStart: '{{ item.SnapStart }}'
      RuntimeVersionConfig: '{{ item.RuntimeVersionConfig }}'
      LoggingConfig: '{{ item.LoggingConfig }}'
      TenancyConfig: '{{ item.TenancyConfig }}'
  for_each: aws.lambda.listFunctions
checks: []
