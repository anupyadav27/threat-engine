      JobId: '{{ item.JobId }}'
      JobName: '{{ item.JobName }}'
      PreSignedUrl: '{{ item.PreSignedUrl }}'
      SkippedUsers: '{{ item.SkippedUsers }}'
      StartDate: '{{ item.StartDate }}'
      UserImportJob: '{{ item.UserImportJob }}'
      UserPoolId: '{{ item.UserPoolId }}'
- discovery_id: aws.cognito-idp.list_user_pool_clients
  calls:
  - action: list_user_pool_clients
    save_as: response
    on_error: continue
  emit:
