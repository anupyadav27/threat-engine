- discovery_id: aws.cognito-idp.list_users
  calls:
  - action: list_users
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Users }}'
    item:
      Attributes: '{{ item.Attributes }}'
