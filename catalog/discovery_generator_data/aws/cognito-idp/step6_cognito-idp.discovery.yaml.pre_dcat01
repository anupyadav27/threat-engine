- discovery_id: aws.cognito-idp.get_user_pool_mfa_config
  calls:
  - action: get_user_pool_mfa_config
    save_as: response
    on_error: continue
  emit:
    as: item
    item:
      EmailMfaConfiguration: '{{ response.SmsMfaConfiguration.EmailMfaConfiguration
        }}'
      SmsAuthenticationMessage: '{{ response.SmsMfaConfiguration.SmsAuthenticationMessage
        }}'
      SmsConfiguration: '{{ response.SmsMfaConfiguration.SmsConfiguration }}'
      SmsMfaConfiguration: '{{ response.SmsMfaConfiguration.SmsMfaConfiguration }}'
      SoftwareTokenMfaConfiguration: '{{ response.SmsMfaConfiguration.SoftwareTokenMfaConfiguration
        }}'
      WebAuthnConfiguration: '{{ response.SmsMfaConfiguration.WebAuthnConfiguration
        }}'
- discovery_id: aws.cognito-idp.list_devices
  calls:
  - action: list_devices
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Devices }}'
    item:
      DeviceAttributes: '{{ item.DeviceAttributes }}'
      DeviceCreateDate: '{{ item.DeviceCreateDate }}'
      DeviceKey: '{{ item.DeviceKey }}'
      DeviceLastAuthenticatedDate: '{{ item.DeviceLastAuthenticatedDate }}'
      DeviceLastModifiedDate: '{{ item.DeviceLastModifiedDate }}'
- discovery_id: aws.cognito-idp.list_groups
  calls:
  - action: list_groups
    save_as: response
    on_error: continue
  emit:
