version: '1.0'
provider: aws
service: cognito-idp
services:
  client: cognito-idp
  module: boto3.client
discovery:
- discovery_id: aws.cognito-idp.describe_identity_provider
  calls:
  - action: describe_identity_provider
    save_as: response
    on_error: continue
  emit:
    as: item
    item:
      CreationDate: '{{ response.IdentityProvider.CreationDate }}'
      AttributeMapping: '{{ response.IdentityProvider.AttributeMapping }}'
      IdpIdentifiers: '{{ response.IdentityProvider.IdpIdentifiers }}'
      LastModifiedDate: '{{ response.IdentityProvider.LastModifiedDate }}'
      ProviderDetails: '{{ response.IdentityProvider.ProviderDetails }}'
      ProviderName: '{{ response.IdentityProvider.ProviderName }}'
      ProviderType: '{{ response.IdentityProvider.ProviderType }}'
      UserPoolId: '{{ response.IdentityProvider.UserPoolId }}'
- discovery_id: aws.cognito-idp.describe_managed_login_branding
  calls:
  - action: describe_managed_login_branding
    save_as: response
    on_error: continue
  emit:
    as: item
    item:
      CreationDate: '{{ response.ManagedLoginBranding.CreationDate }}'
      Assets: '{{ response.ManagedLoginBranding.Assets }}'
      LastModifiedDate: '{{ response.ManagedLoginBranding.LastModifiedDate }}'
      ManagedLoginBranding: '{{ response.ManagedLoginBranding.ManagedLoginBranding
        }}'
      ManagedLoginBrandingId: '{{ response.ManagedLoginBranding.ManagedLoginBrandingId
        }}'
      Settings: '{{ response.ManagedLoginBranding.Settings }}'
      UseCognitoProvidedValues: '{{ response.ManagedLoginBranding.UseCognitoProvidedValues
        }}'
      UserPoolId: '{{ response.ManagedLoginBranding.UserPoolId }}'
- discovery_id: aws.cognito-idp.describe_managed_login_branding_by_client
  calls:
  - action: describe_managed_login_branding_by_client
    save_as: response
    on_error: continue
  emit:
    as: item
    item:
      CreationDate: '{{ response.ManagedLoginBranding.CreationDate }}'
      Assets: '{{ response.ManagedLoginBranding.Assets }}'
      LastModifiedDate: '{{ response.ManagedLoginBranding.LastModifiedDate }}'
      ManagedLoginBrandingId: '{{ response.ManagedLoginBranding.ManagedLoginBrandingId
        }}'
      Settings: '{{ response.ManagedLoginBranding.Settings }}'
      UseCognitoProvidedValues: '{{ response.ManagedLoginBranding.UseCognitoProvidedValues
        }}'
      UserPoolId: '{{ response.ManagedLoginBranding.UserPoolId }}'
- discovery_id: aws.cognito-idp.describe_resource_server
  calls:
  - action: describe_resource_server
    save_as: response
    on_error: continue
  emit:
    as: item
    item:
      Name: '{{ response.ResourceServer.Name }}'
      Identifier: '{{ response.ResourceServer.Identifier }}'
      ResourceServer: '{{ response.ResourceServer.ResourceServer }}'
      Scopes: '{{ response.ResourceServer.Scopes }}'
      UserPoolId: '{{ response.ResourceServer.UserPoolId }}'
- discovery_id: aws.cognito-idp.describe_risk_configuration
  calls:
  - action: describe_risk_configuration
    save_as: response
    on_error: continue
  emit:
    as: item
    item:
      AccountTakeoverRiskConfiguration: '{{ response.RiskConfiguration.AccountTakeoverRiskConfiguration
        }}'
      ClientId: '{{ response.RiskConfiguration.ClientId }}'
      CompromisedCredentialsRiskConfiguration: '{{ response.RiskConfiguration.CompromisedCredentialsRiskConfiguration
        }}'
      LastModifiedDate: '{{ response.RiskConfiguration.LastModifiedDate }}'
      RiskConfiguration: '{{ response.RiskConfiguration.RiskConfiguration }}'
      RiskExceptionConfiguration: '{{ response.RiskConfiguration.RiskExceptionConfiguration
        }}'
      UserPoolId: '{{ response.RiskConfiguration.UserPoolId }}'
- discovery_id: aws.cognito-idp.describe_terms
  calls:
  - action: describe_terms
    save_as: response
    on_error: continue
  emit:
    as: item
    item:
      CreationDate: '{{ response.Terms.CreationDate }}'
      ClientId: '{{ response.Terms.ClientId }}'
      Enforcement: '{{ response.Terms.Enforcement }}'
      LastModifiedDate: '{{ response.Terms.LastModifiedDate }}'
      Links: '{{ response.Terms.Links }}'
      TermsId: '{{ response.Terms.TermsId }}'
      TermsName: '{{ response.Terms.TermsName }}'
      TermsSource: '{{ response.Terms.TermsSource }}'
      UserPoolId: '{{ response.Terms.UserPoolId }}'
- discovery_id: aws.cognito-idp.describe_user_import_job
  calls:
  - action: describe_user_import_job
    save_as: response
    on_error: continue
  emit:
    as: item
    item:
      CreationDate: '{{ response.UserImportJob.CreationDate }}'
      Status: '{{ response.UserImportJob.Status }}'
      CloudWatchLogsRoleArn: '{{ response.UserImportJob.CloudWatchLogsRoleArn }}'
      CompletionDate: '{{ response.UserImportJob.CompletionDate }}'
      CompletionMessage: '{{ response.UserImportJob.CompletionMessage }}'
      FailedUsers: '{{ response.UserImportJob.FailedUsers }}'
      ImportedUsers: '{{ response.UserImportJob.ImportedUsers }}'
      JobId: '{{ response.UserImportJob.JobId }}'
      JobName: '{{ response.UserImportJob.JobName }}'
      PreSignedUrl: '{{ response.UserImportJob.PreSignedUrl }}'
      SkippedUsers: '{{ response.UserImportJob.SkippedUsers }}'
      StartDate: '{{ response.UserImportJob.StartDate }}'
      UserImportJob: '{{ response.UserImportJob.UserImportJob }}'
      UserPoolId: '{{ response.UserImportJob.UserPoolId }}'
- discovery_id: aws.cognito-idp.describe_user_pool
  calls:
  - action: describe_user_pool
    save_as: response
    on_error: continue
  emit:
    as: item
    item:
      Arn: '{{ response.UserPool.Arn }}'
      CreationDate: '{{ response.UserPool.CreationDate }}'
      DeletionProtection: '{{ response.UserPool.DeletionProtection }}'
      Id: '{{ response.UserPool.Id }}'
      Name: '{{ response.UserPool.Name }}'
      Status: '{{ response.UserPool.Status }}'
      AccountRecoverySetting: '{{ response.UserPool.AccountRecoverySetting }}'
      AdminCreateUserConfig: '{{ response.UserPool.AdminCreateUserConfig }}'
      AliasAttributes: '{{ response.UserPool.AliasAttributes }}'
      AutoVerifiedAttributes: '{{ response.UserPool.AutoVerifiedAttributes }}'
      CustomDomain: '{{ response.UserPool.CustomDomain }}'
      DeviceConfiguration: '{{ response.UserPool.DeviceConfiguration }}'
      Domain: '{{ response.UserPool.Domain }}'
      EmailConfiguration: '{{ response.UserPool.EmailConfiguration }}'
      EmailConfigurationFailure: '{{ response.UserPool.EmailConfigurationFailure }}'
      EmailVerificationMessage: '{{ response.UserPool.EmailVerificationMessage }}'
      EmailVerificationSubject: '{{ response.UserPool.EmailVerificationSubject }}'
      EstimatedNumberOfUsers: '{{ response.UserPool.EstimatedNumberOfUsers }}'
      LambdaConfig: '{{ response.UserPool.LambdaConfig }}'
      LastModifiedDate: '{{ response.UserPool.LastModifiedDate }}'
      MfaConfiguration: '{{ response.UserPool.MfaConfiguration }}'
      Policies: '{{ response.UserPool.Policies }}'
      SchemaAttributes: '{{ response.UserPool.SchemaAttributes }}'
      SmsAuthenticationMessage: '{{ response.UserPool.SmsAuthenticationMessage }}'
      SmsConfiguration: '{{ response.UserPool.SmsConfiguration }}'
      SmsConfigurationFailure: '{{ response.UserPool.SmsConfigurationFailure }}'
      SmsVerificationMessage: '{{ response.UserPool.SmsVerificationMessage }}'
      UserAttributeUpdateSettings: '{{ response.UserPool.UserAttributeUpdateSettings
        }}'
      UserPool: '{{ response.UserPool.UserPool }}'
      UserPoolAddOns: '{{ response.UserPool.UserPoolAddOns }}'
      UserPoolTags: '{{ response.UserPool.UserPoolTags }}'
      UserPoolTier: '{{ response.UserPool.UserPoolTier }}'
      UsernameAttributes: '{{ response.UserPool.UsernameAttributes }}'
      UsernameConfiguration: '{{ response.UserPool.UsernameConfiguration }}'
      VerificationMessageTemplate: '{{ response.UserPool.VerificationMessageTemplate
        }}'
- discovery_id: aws.cognito-idp.describe_user_pool_client
  calls:
  - action: describe_user_pool_client
    save_as: response
    on_error: continue
  emit:
    as: item
    item:
      CreationDate: '{{ response.UserPoolClient.CreationDate }}'
      AccessTokenValidity: '{{ response.UserPoolClient.AccessTokenValidity }}'
      AllowedOAuthFlows: '{{ response.UserPoolClient.AllowedOAuthFlows }}'
      AllowedOAuthFlowsUserPoolClient: '{{ response.UserPoolClient.AllowedOAuthFlowsUserPoolClient
        }}'
      AllowedOAuthScopes: '{{ response.UserPoolClient.AllowedOAuthScopes }}'
      AnalyticsConfiguration: '{{ response.UserPoolClient.AnalyticsConfiguration }}'
      AuthSessionValidity: '{{ response.UserPoolClient.AuthSessionValidity }}'
      CallbackURLs: '{{ response.UserPoolClient.CallbackURLs }}'
      ClientId: '{{ response.UserPoolClient.ClientId }}'
      ClientName: '{{ response.UserPoolClient.ClientName }}'
      ClientSecret: '{{ response.UserPoolClient.ClientSecret }}'
      DefaultRedirectURI: '{{ response.UserPoolClient.DefaultRedirectURI }}'
      EnablePropagateAdditionalUserContextData: '{{ response.UserPoolClient.EnablePropagateAdditionalUserContextData
        }}'
      EnableTokenRevocation: '{{ response.UserPoolClient.EnableTokenRevocation }}'
      ExplicitAuthFlows: '{{ response.UserPoolClient.ExplicitAuthFlows }}'
      IdTokenValidity: '{{ response.UserPoolClient.IdTokenValidity }}'
      LastModifiedDate: '{{ response.UserPoolClient.LastModifiedDate }}'
      LogoutURLs: '{{ response.UserPoolClient.LogoutURLs }}'
      PreventUserExistenceErrors: '{{ response.UserPoolClient.PreventUserExistenceErrors
        }}'
      ReadAttributes: '{{ response.UserPoolClient.ReadAttributes }}'
      RefreshTokenRotation: '{{ response.UserPoolClient.RefreshTokenRotation }}'
      RefreshTokenValidity: '{{ response.UserPoolClient.RefreshTokenValidity }}'
      SupportedIdentityProviders: '{{ response.UserPoolClient.SupportedIdentityProviders
        }}'
      TokenValidityUnits: '{{ response.UserPoolClient.TokenValidityUnits }}'
      UserPoolId: '{{ response.UserPoolClient.UserPoolId }}'
      WriteAttributes: '{{ response.UserPoolClient.WriteAttributes }}'
- discovery_id: aws.cognito-idp.describe_user_pool_domain
  calls:
  - action: describe_user_pool_domain
    save_as: response
    on_error: continue
  emit:
    as: item
    item:
      Status: '{{ response.DomainDescription.Status }}'
      AWSAccountId: '{{ response.DomainDescription.AWSAccountId }}'
      CloudFrontDistribution: '{{ response.DomainDescription.CloudFrontDistribution
        }}'
      CustomDomainConfig: '{{ response.DomainDescription.CustomDomainConfig }}'
      Domain: '{{ response.DomainDescription.Domain }}'
      DomainDescription: '{{ response.DomainDescription.DomainDescription }}'
      ManagedLoginVersion: '{{ response.DomainDescription.ManagedLoginVersion }}'
      S3Bucket: '{{ response.DomainDescription.S3Bucket }}'
      UserPoolId: '{{ response.DomainDescription.UserPoolId }}'
      Version: '{{ response.DomainDescription.Version }}'
- discovery_id: aws.cognito-idp.get_csv_header
  calls:
  - action: get_csv_header
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.CSVHeader }}'
    item:
      CSVHeader: '{{ item.CSVHeader }}'
- discovery_id: aws.cognito-idp.get_device
  calls:
  - action: get_device
    save_as: response
    on_error: continue
  emit:
    as: item
    item:
      DeviceAttributes: '{{ response.Device.DeviceAttributes }}'
      DeviceCreateDate: '{{ response.Device.DeviceCreateDate }}'
      DeviceKey: '{{ response.Device.DeviceKey }}'
      DeviceLastAuthenticatedDate: '{{ response.Device.DeviceLastAuthenticatedDate
        }}'
      DeviceLastModifiedDate: '{{ response.Device.DeviceLastModifiedDate }}'
- discovery_id: aws.cognito-idp.get_group
  calls:
  - action: get_group
    save_as: response
    on_error: continue
  emit:
    as: item
    item:
      CreationDate: '{{ response.Group.CreationDate }}'
      RoleArn: '{{ response.Group.RoleArn }}'
      Description: '{{ response.Group.Description }}'
      GroupName: '{{ response.Group.GroupName }}'
      LastModifiedDate: '{{ response.Group.LastModifiedDate }}'
      Precedence: '{{ response.Group.Precedence }}'
      UserPoolId: '{{ response.Group.UserPoolId }}'
- discovery_id: aws.cognito-idp.get_identity_provider_by_identifier
  calls:
  - action: get_identity_provider_by_identifier
    save_as: response
    on_error: continue
  emit:
    as: item
    item:
      CreationDate: '{{ response.IdentityProvider.CreationDate }}'
      AttributeMapping: '{{ response.IdentityProvider.AttributeMapping }}'
      IdentityProvider: '{{ response.IdentityProvider.IdentityProvider }}'
      IdpIdentifiers: '{{ response.IdentityProvider.IdpIdentifiers }}'
      LastModifiedDate: '{{ response.IdentityProvider.LastModifiedDate }}'
      ProviderDetails: '{{ response.IdentityProvider.ProviderDetails }}'
      ProviderName: '{{ response.IdentityProvider.ProviderName }}'
      ProviderType: '{{ response.IdentityProvider.ProviderType }}'
      UserPoolId: '{{ response.IdentityProvider.UserPoolId }}'
- discovery_id: aws.cognito-idp.get_log_delivery_configuration
  calls:
  - action: get_log_delivery_configuration
    save_as: response
    on_error: continue
  emit:
    as: item
    item:
      LogConfigurations: '{{ response.LogDeliveryConfiguration.LogConfigurations }}'
      LogDeliveryConfiguration: '{{ response.LogDeliveryConfiguration.LogDeliveryConfiguration
        }}'
      UserPoolId: '{{ response.LogDeliveryConfiguration.UserPoolId }}'
- discovery_id: aws.cognito-idp.get_signing_certificate
  calls:
  - action: get_signing_certificate
    save_as: response
    on_error: continue
  emit:
    as: item
    item:
      Certificate: '{{ response.Certificate }}'
- discovery_id: aws.cognito-idp.get_tokens_from_refresh_token
  calls:
  - action: get_tokens_from_refresh_token
    save_as: response
    on_error: continue
  emit:
    as: item
    item:
      AccessToken: '{{ response.AuthenticationResult.AccessToken }}'
      ExpiresIn: '{{ response.AuthenticationResult.ExpiresIn }}'
      IdToken: '{{ response.AuthenticationResult.IdToken }}'
      NewDeviceMetadata: '{{ response.AuthenticationResult.NewDeviceMetadata }}'
      RefreshToken: '{{ response.AuthenticationResult.RefreshToken }}'
      TokenType: '{{ response.AuthenticationResult.TokenType }}'
- discovery_id: aws.cognito-idp.get_ui_customization
  calls:
  - action: get_ui_customization
    save_as: response
    on_error: continue
  emit:
    as: item
    item:
      CreationDate: '{{ response.UICustomization.CreationDate }}'
      CSS: '{{ response.UICustomization.CSS }}'
      CSSVersion: '{{ response.UICustomization.CSSVersion }}'
      ClientId: '{{ response.UICustomization.ClientId }}'
      ImageUrl: '{{ response.UICustomization.ImageUrl }}'
      LastModifiedDate: '{{ response.UICustomization.LastModifiedDate }}'
      UICustomization: '{{ response.UICustomization.UICustomization }}'
      UserPoolId: '{{ response.UICustomization.UserPoolId }}'
- discovery_id: aws.cognito-idp.get_user
  calls:
  - action: get_user
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.UserAttributes }}'
    item:
      Name: '{{ item.Name }}'
      PreferredMfaSetting: '{{ item.PreferredMfaSetting }}'
      UserMFASettingList: '{{ item.UserMFASettingList }}'
      Value: '{{ item.Value }}'
- discovery_id: aws.cognito-idp.get_user_attribute_verification_code
  calls:
  - action: get_user_attribute_verification_code
    save_as: response
    on_error: continue
  emit:
    as: item
    item:
      AttributeName: '{{ response.CodeDeliveryDetails.AttributeName }}'
      DeliveryMedium: '{{ response.CodeDeliveryDetails.DeliveryMedium }}'
      Destination: '{{ response.CodeDeliveryDetails.Destination }}'
- discovery_id: aws.cognito-idp.get_user_auth_factors
  calls:
  - action: get_user_auth_factors
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.UserMFASettingList }}'
    item:
