    save_as: response
    on_error: continue
  emit:
    as: item
    item:
      Tags: '{{ response.Tags }}'
- discovery_id: aws.cognito-idp.list_terms
  calls:
  - action: list_terms
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Terms }}'
    item:
      CreationDate: '{{ item.CreationDate }}'
      Enforcement: '{{ item.Enforcement }}'
      LastModifiedDate: '{{ item.LastModifiedDate }}'
      TermsId: '{{ item.TermsId }}'
