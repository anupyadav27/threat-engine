      Precedence: '{{ item.Precedence }}'
      UserPoolId: '{{ item.UserPoolId }}'
- discovery_id: aws.cognito-idp.list_identity_providers
  calls:
  - action: list_identity_providers
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Providers }}'
    item:
