      memorySizeInGBs: '{{ item.memorySizeInGBs }}'
      nodeCount: '{{ item.nodeCount }}'
      ocid: '{{ item.ocid }}'
      ociResourceAnchorName: '{{ item.ociResourceAnchorName }}'
      ociUrl: '{{ item.ociUrl }}'
      domain: '{{ item.domain }}'
      scanDnsName: '{{ item.scanDnsName }}'
      scanDnsRecordId: '{{ item.scanDnsRecordId }}'
      scanIpIds: '{{ item.scanIpIds }}'
      shape: '{{ item.shape }}'
      sshPublicKeys: '{{ item.sshPublicKeys }}'
      storageSizeInGBs: '{{ item.storageSizeInGBs }}'
      systemVersion: '{{ item.systemVersion }}'
      createdAt: '{{ item.createdAt }}'
      timeZone: '{{ item.timeZone }}'
      vipIds: '{{ item.vipIds }}'
      odbNetworkId: '{{ item.odbNetworkId }}'
      percentProgress: '{{ item.percentProgress }}'
      computeModel: '{{ item.computeModel }}'
      iamRoles: '{{ item.iamRoles }}'
- discovery_id: aws.odb.listDbSystemShapes
  calls:
