version: '1.0'
provider: aws
service: odb
services:
  client: odb
  module: boto3.client
discovery:
- discovery_id: aws.odb.getOciOnboardingStatus
  calls:
  - action: getOciOnboardingStatus
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ociIdentityDomain }}'
    item:
      ociIdentityDomainId: '{{ item.ociIdentityDomainId }}'
      ociIdentityDomainResourceUrl: '{{ item.ociIdentityDomainResourceUrl }}'
      ociIdentityDomainUrl: '{{ item.ociIdentityDomainUrl }}'
      status: '{{ item.status }}'
      statusReason: '{{ item.statusReason }}'
      accountSetupCloudFormationUrl: '{{ item.accountSetupCloudFormationUrl }}'
- discovery_id: aws.odb.listCloudAutonomousVmClusters
  calls:
  - action: listCloudAutonomousVmClusters
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.cloudAutonomousVmClusters }}'
    item:
      cloudAutonomousVmClusterId: '{{ item.cloudAutonomousVmClusterId }}'
      cloudAutonomousVmClusterArn: '{{ item.cloudAutonomousVmClusterArn }}'
      odbNetworkId: '{{ item.odbNetworkId }}'
      ociResourceAnchorName: '{{ item.ociResourceAnchorName }}'
      percentProgress: '{{ item.percentProgress }}'
      displayName: '{{ item.displayName }}'
      status: '{{ item.status }}'
      statusReason: '{{ item.statusReason }}'
      cloudExadataInfrastructureId: '{{ item.cloudExadataInfrastructureId }}'
      autonomousDataStoragePercentage: '{{ item.autonomousDataStoragePercentage }}'
      autonomousDataStorageSizeInTBs: '{{ item.autonomousDataStorageSizeInTBs }}'
      availableAutonomousDataStorageSizeInTBs: '{{ item.availableAutonomousDataStorageSizeInTBs
        }}'
      availableContainerDatabases: '{{ item.availableContainerDatabases }}'
      availableCpus: '{{ item.availableCpus }}'
      computeModel: '{{ item.computeModel }}'
      cpuCoreCount: '{{ item.cpuCoreCount }}'
      cpuCoreCountPerNode: '{{ item.cpuCoreCountPerNode }}'
      cpuPercentage: '{{ item.cpuPercentage }}'
      dataStorageSizeInGBs: '{{ item.dataStorageSizeInGBs }}'
      dataStorageSizeInTBs: '{{ item.dataStorageSizeInTBs }}'
      dbNodeStorageSizeInGBs: '{{ item.dbNodeStorageSizeInGBs }}'
      dbServers: '{{ item.dbServers }}'
      description: '{{ item.description }}'
      domain: '{{ item.domain }}'
      exadataStorageInTBsLowestScaledValue: '{{ item.exadataStorageInTBsLowestScaledValue
        }}'
      hostname: '{{ item.hostname }}'
      ocid: '{{ item.ocid }}'
      ociUrl: '{{ item.ociUrl }}'
      isMtlsEnabledVmCluster: '{{ item.isMtlsEnabledVmCluster }}'
      licenseModel: '{{ item.licenseModel }}'
      maintenanceWindow: '{{ item.maintenanceWindow }}'
      maxAcdsLowestScaledValue: '{{ item.maxAcdsLowestScaledValue }}'
      memoryPerOracleComputeUnitInGBs: '{{ item.memoryPerOracleComputeUnitInGBs }}'
      memorySizeInGBs: '{{ item.memorySizeInGBs }}'
      nodeCount: '{{ item.nodeCount }}'
      nonProvisionableAutonomousContainerDatabases: '{{ item.nonProvisionableAutonomousContainerDatabases
        }}'
      provisionableAutonomousContainerDatabases: '{{ item.provisionableAutonomousContainerDatabases
        }}'
      provisionedAutonomousContainerDatabases: '{{ item.provisionedAutonomousContainerDatabases
        }}'
      provisionedCpus: '{{ item.provisionedCpus }}'
      reclaimableCpus: '{{ item.reclaimableCpus }}'
      reservedCpus: '{{ item.reservedCpus }}'
      scanListenerPortNonTls: '{{ item.scanListenerPortNonTls }}'
      scanListenerPortTls: '{{ item.scanListenerPortTls }}'
      shape: '{{ item.shape }}'
      createdAt: '{{ item.createdAt }}'
      timeDatabaseSslCertificateExpires: '{{ item.timeDatabaseSslCertificateExpires
        }}'
      timeOrdsCertificateExpires: '{{ item.timeOrdsCertificateExpires }}'
      timeZone: '{{ item.timeZone }}'
      totalContainerDatabases: '{{ item.totalContainerDatabases }}'
- discovery_id: aws.odb.listCloudExadataInfrastructures
  calls:
  - action: listCloudExadataInfrastructures
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.cloudExadataInfrastructures }}'
    item:
      cloudExadataInfrastructureId: '{{ item.cloudExadataInfrastructureId }}'
      displayName: '{{ item.displayName }}'
      status: '{{ item.status }}'
      statusReason: '{{ item.statusReason }}'
      cloudExadataInfrastructureArn: '{{ item.cloudExadataInfrastructureArn }}'
      activatedStorageCount: '{{ item.activatedStorageCount }}'
      additionalStorageCount: '{{ item.additionalStorageCount }}'
      availableStorageSizeInGBs: '{{ item.availableStorageSizeInGBs }}'
      availabilityZone: '{{ item.availabilityZone }}'
      availabilityZoneId: '{{ item.availabilityZoneId }}'
      computeCount: '{{ item.computeCount }}'
      cpuCount: '{{ item.cpuCount }}'
      customerContactsToSendToOCI: '{{ item.customerContactsToSendToOCI }}'
      dataStorageSizeInTBs: '{{ item.dataStorageSizeInTBs }}'
      dbNodeStorageSizeInGBs: '{{ item.dbNodeStorageSizeInGBs }}'
      dbServerVersion: '{{ item.dbServerVersion }}'
      lastMaintenanceRunId: '{{ item.lastMaintenanceRunId }}'
      maintenanceWindow: '{{ item.maintenanceWindow }}'
      maxCpuCount: '{{ item.maxCpuCount }}'
      maxDataStorageInTBs: '{{ item.maxDataStorageInTBs }}'
      maxDbNodeStorageSizeInGBs: '{{ item.maxDbNodeStorageSizeInGBs }}'
      maxMemoryInGBs: '{{ item.maxMemoryInGBs }}'
      memorySizeInGBs: '{{ item.memorySizeInGBs }}'
      monthlyDbServerVersion: '{{ item.monthlyDbServerVersion }}'
      monthlyStorageServerVersion: '{{ item.monthlyStorageServerVersion }}'
      nextMaintenanceRunId: '{{ item.nextMaintenanceRunId }}'
      ociResourceAnchorName: '{{ item.ociResourceAnchorName }}'
      ociUrl: '{{ item.ociUrl }}'
      ocid: '{{ item.ocid }}'
      shape: '{{ item.shape }}'
      storageCount: '{{ item.storageCount }}'
      storageServerVersion: '{{ item.storageServerVersion }}'
      createdAt: '{{ item.createdAt }}'
      totalStorageSizeInGBs: '{{ item.totalStorageSizeInGBs }}'
      percentProgress: '{{ item.percentProgress }}'
      databaseServerType: '{{ item.databaseServerType }}'
      storageServerType: '{{ item.storageServerType }}'
      computeModel: '{{ item.computeModel }}'
- discovery_id: aws.odb.listCloudVmClusters
  calls:
  - action: listCloudVmClusters
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.cloudVmClusters }}'
    item:
      cloudVmClusterId: '{{ item.cloudVmClusterId }}'
      displayName: '{{ item.displayName }}'
      status: '{{ item.status }}'
      statusReason: '{{ item.statusReason }}'
      cloudVmClusterArn: '{{ item.cloudVmClusterArn }}'
      cloudExadataInfrastructureId: '{{ item.cloudExadataInfrastructureId }}'
      clusterName: '{{ item.clusterName }}'
      cpuCoreCount: '{{ item.cpuCoreCount }}'
      dataCollectionOptions: '{{ item.dataCollectionOptions }}'
      dataStorageSizeInTBs: '{{ item.dataStorageSizeInTBs }}'
      dbNodeStorageSizeInGBs: '{{ item.dbNodeStorageSizeInGBs }}'
      dbServers: '{{ item.dbServers }}'
      diskRedundancy: '{{ item.diskRedundancy }}'
      giVersion: '{{ item.giVersion }}'
