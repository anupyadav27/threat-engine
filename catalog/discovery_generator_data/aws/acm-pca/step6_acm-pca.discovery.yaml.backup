version: '1.0'
provider: aws
service: acm-pca
services:
  client: acm-pca
  module: boto3.client
discovery:
- discovery_id: aws.acm-pca.listCertificateAuthorities
  calls:
  - action: listCertificateAuthorities
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.CertificateAuthorities }}'
    item:
      Arn: '{{ item.Arn }}'
      OwnerAccount: '{{ item.OwnerAccount }}'
      CreatedAt: '{{ item.CreatedAt }}'
      LastStateChangeAt: '{{ item.LastStateChangeAt }}'
      Type: '{{ item.Type }}'
      Serial: '{{ item.Serial }}'
      Status: '{{ item.Status }}'
      NotBefore: '{{ item.NotBefore }}'
      NotAfter: '{{ item.NotAfter }}'
      FailureReason: '{{ item.FailureReason }}'
      CertificateAuthorityConfiguration: '{{ item.CertificateAuthorityConfiguration
        }}'
      RevocationConfiguration: '{{ item.RevocationConfiguration }}'
      RestorableUntil: '{{ item.RestorableUntil }}'
      KeyStorageSecurityStandard: '{{ item.KeyStorageSecurityStandard }}'
      UsageMode: '{{ item.UsageMode }}'
- discovery_id: aws.acm-pca.describeCertificateAuthority
  calls:
  - action: describeCertificateAuthority
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.CertificateAuthority }}'
    item:
      Arn: '{{ item.Arn }}'
      OwnerAccount: '{{ item.OwnerAccount }}'
      CreatedAt: '{{ item.CreatedAt }}'
      LastStateChangeAt: '{{ item.LastStateChangeAt }}'
      Type: '{{ item.Type }}'
      Serial: '{{ item.Serial }}'
      Status: '{{ item.Status }}'
      NotBefore: '{{ item.NotBefore }}'
      NotAfter: '{{ item.NotAfter }}'
      FailureReason: '{{ item.FailureReason }}'
      CertificateAuthorityConfiguration: '{{ item.CertificateAuthorityConfiguration
        }}'
      RevocationConfiguration: '{{ item.RevocationConfiguration }}'
      RestorableUntil: '{{ item.RestorableUntil }}'
      KeyStorageSecurityStandard: '{{ item.KeyStorageSecurityStandard }}'
      UsageMode: '{{ item.UsageMode }}'
- discovery_id: aws.acm-pca.describeCertificateAuthorityAuditReport
  calls:
  - action: describeCertificateAuthorityAuditReport
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AuditReportStatus }}'
- discovery_id: aws.acm-pca.getCertificate
  calls:
  - action: getCertificate
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Certificate }}'
- discovery_id: aws.acm-pca.getCertificateAuthorityCertificate
  calls:
  - action: getCertificateAuthorityCertificate
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Certificate }}'
- discovery_id: aws.acm-pca.getCertificateAuthorityCsr
  calls:
  - action: getCertificateAuthorityCsr
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Csr }}'
- discovery_id: aws.acm-pca.getPolicy
  calls:
  - action: getPolicy
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Policy }}'
- discovery_id: aws.acm-pca.listPermissions
  calls:
  - action: listPermissions
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Permissions }}'
    item:
      CertificateAuthorityArn: '{{ item.CertificateAuthorityArn }}'
      CreatedAt: '{{ item.CreatedAt }}'
      Principal: '{{ item.Principal }}'
      SourceAccount: '{{ item.SourceAccount }}'
      Actions: '{{ item.Actions }}'
      Policy: '{{ item.Policy }}'
- discovery_id: aws.acm-pca.listTags
  calls:
  - action: listTags
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Tags }}'
    item:
      Key: '{{ item.Key }}'
      Value: '{{ item.Value }}'
checks: []
