version: '1.0'
provider: aws
service: cloudwatch
services:
  client: cloudwatch
  module: boto3.client
discovery:
- discovery_id: aws.cloudwatch.describeAlarmHistory
  calls:
  - action: describeAlarmHistory
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AlarmHistoryItems }}'
    item:
      AlarmName: '{{ item.AlarmName }}'
      AlarmContributorId: '{{ item.AlarmContributorId }}'
      AlarmType: '{{ item.AlarmType }}'
      Timestamp: '{{ item.Timestamp }}'
      HistoryItemType: '{{ item.HistoryItemType }}'
      HistorySummary: '{{ item.HistorySummary }}'
      HistoryData: '{{ item.HistoryData }}'
      AlarmContributorAttributes: '{{ item.AlarmContributorAttributes }}'
- discovery_id: aws.cloudwatch.describeAlarms
  calls:
  - action: describeAlarms
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.CompositeAlarms }}'
    item:
      ActionsEnabled: '{{ item.ActionsEnabled }}'
      AlarmActions: '{{ item.AlarmActions }}'
      AlarmArn: '{{ item.AlarmArn }}'
      AlarmConfigurationUpdatedTimestamp: '{{ item.AlarmConfigurationUpdatedTimestamp
        }}'
      AlarmDescription: '{{ item.AlarmDescription }}'
      AlarmName: '{{ item.AlarmName }}'
      AlarmRule: '{{ item.AlarmRule }}'
      InsufficientDataActions: '{{ item.InsufficientDataActions }}'
      OKActions: '{{ item.OKActions }}'
      StateReason: '{{ item.StateReason }}'
      StateReasonData: '{{ item.StateReasonData }}'
      StateUpdatedTimestamp: '{{ item.StateUpdatedTimestamp }}'
      StateValue: '{{ item.StateValue }}'
      StateTransitionedTimestamp: '{{ item.StateTransitionedTimestamp }}'
      ActionsSuppressedBy: '{{ item.ActionsSuppressedBy }}'
      ActionsSuppressedReason: '{{ item.ActionsSuppressedReason }}'
      ActionsSuppressor: '{{ item.ActionsSuppressor }}'
      ActionsSuppressorWaitPeriod: '{{ item.ActionsSuppressorWaitPeriod }}'
      ActionsSuppressorExtensionPeriod: '{{ item.ActionsSuppressorExtensionPeriod
        }}'
- discovery_id: aws.cloudwatch.describeAnomalyDetectors
  calls:
  - action: describeAnomalyDetectors
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AnomalyDetectors }}'
    item:
      Namespace: '{{ item.Namespace }}'
      MetricName: '{{ item.MetricName }}'
      Dimensions: '{{ item.Dimensions }}'
      Stat: '{{ item.Stat }}'
      Configuration: '{{ item.Configuration }}'
      StateValue: '{{ item.StateValue }}'
      MetricCharacteristics: '{{ item.MetricCharacteristics }}'
      SingleMetricAnomalyDetector: '{{ item.SingleMetricAnomalyDetector }}'
      MetricMathAnomalyDetector: '{{ item.MetricMathAnomalyDetector }}'
- discovery_id: aws.cloudwatch.describeInsightRules
  calls:
  - action: describeInsightRules
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.InsightRules }}'
    item:
      Name: '{{ item.Name }}'
      State: '{{ item.State }}'
      Schema: '{{ item.Schema }}'
      Definition: '{{ item.Definition }}'
      ManagedRule: '{{ item.ManagedRule }}'
      ApplyOnTransformedLogs: '{{ item.ApplyOnTransformedLogs }}'
- discovery_id: aws.cloudwatch.listDashboards
  calls:
  - action: listDashboards
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.DashboardEntries }}'
    item:
      DashboardName: '{{ item.DashboardName }}'
      DashboardArn: '{{ item.DashboardArn }}'
      LastModified: '{{ item.LastModified }}'
      Size: '{{ item.Size }}'
- discovery_id: aws.cloudwatch.listMetricStreams
  calls:
  - action: listMetricStreams
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Entries }}'
    item:
      Arn: '{{ item.Arn }}'
      CreationDate: '{{ item.CreationDate }}'
      LastUpdateDate: '{{ item.LastUpdateDate }}'
      Name: '{{ item.Name }}'
      FirehoseArn: '{{ item.FirehoseArn }}'
      State: '{{ item.State }}'
      OutputFormat: '{{ item.OutputFormat }}'
- discovery_id: aws.cloudwatch.listMetrics
  calls:
  - action: listMetrics
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Metrics }}'
    item:
      Namespace: '{{ item.Namespace }}'
      MetricName: '{{ item.MetricName }}'
      Dimensions: '{{ item.Dimensions }}'
- discovery_id: aws.cloudwatch.describeAlarmContributors
  calls:
  - action: describeAlarmContributors
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AlarmContributors }}'
    item:
      ContributorId: '{{ item.ContributorId }}'
      ContributorAttributes: '{{ item.ContributorAttributes }}'
      StateReason: '{{ item.StateReason }}'
      StateTransitionedTimestamp: '{{ item.StateTransitionedTimestamp }}'
- discovery_id: aws.cloudwatch.describeAlarmsForMetric
  calls:
  - action: describeAlarmsForMetric
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.MetricAlarms }}'
    item:
      AlarmName: '{{ item.AlarmName }}'
      AlarmArn: '{{ item.AlarmArn }}'
      AlarmDescription: '{{ item.AlarmDescription }}'
      AlarmConfigurationUpdatedTimestamp: '{{ item.AlarmConfigurationUpdatedTimestamp
        }}'
      ActionsEnabled: '{{ item.ActionsEnabled }}'
      OKActions: '{{ item.OKActions }}'
      AlarmActions: '{{ item.AlarmActions }}'
      InsufficientDataActions: '{{ item.InsufficientDataActions }}'
      StateValue: '{{ item.StateValue }}'
      StateReason: '{{ item.StateReason }}'
      StateReasonData: '{{ item.StateReasonData }}'
      StateUpdatedTimestamp: '{{ item.StateUpdatedTimestamp }}'
      MetricName: '{{ item.MetricName }}'
      Namespace: '{{ item.Namespace }}'
      Statistic: '{{ item.Statistic }}'
      ExtendedStatistic: '{{ item.ExtendedStatistic }}'
      Dimensions: '{{ item.Dimensions }}'
      Period: '{{ item.Period }}'
      Unit: '{{ item.Unit }}'
      EvaluationPeriods: '{{ item.EvaluationPeriods }}'
      DatapointsToAlarm: '{{ item.DatapointsToAlarm }}'
      Threshold: '{{ item.Threshold }}'
      ComparisonOperator: '{{ item.ComparisonOperator }}'
      TreatMissingData: '{{ item.TreatMissingData }}'
      EvaluateLowSampleCountPercentile: '{{ item.EvaluateLowSampleCountPercentile
        }}'
      Metrics: '{{ item.Metrics }}'
      ThresholdMetricId: '{{ item.ThresholdMetricId }}'
      EvaluationState: '{{ item.EvaluationState }}'
      StateTransitionedTimestamp: '{{ item.StateTransitionedTimestamp }}'
- discovery_id: aws.cloudwatch.getDashboard
  calls:
  - action: getDashboard
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.DashboardArn }}'
- discovery_id: aws.cloudwatch.getInsightRuleReport
  calls:
  - action: getInsightRuleReport
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.KeyLabels }}'
- discovery_id: aws.cloudwatch.getMetricData
  calls:
  - action: getMetricData
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.MetricDataResults }}'
    item:
      Id: '{{ item.Id }}'
      Label: '{{ item.Label }}'
      Timestamps: '{{ item.Timestamps }}'
      Values: '{{ item.Values }}'
      StatusCode: '{{ item.StatusCode }}'
      Messages: '{{ item.Messages }}'
- discovery_id: aws.cloudwatch.getMetricStatistics
  calls:
  - action: getMetricStatistics
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Datapoints }}'
    item:
      Timestamp: '{{ item.Timestamp }}'
      SampleCount: '{{ item.SampleCount }}'
      Average: '{{ item.Average }}'
      Sum: '{{ item.Sum }}'
      Minimum: '{{ item.Minimum }}'
      Maximum: '{{ item.Maximum }}'
      Unit: '{{ item.Unit }}'
      ExtendedStatistics: '{{ item.ExtendedStatistics }}'
- discovery_id: aws.cloudwatch.getMetricStream
  calls:
  - action: getMetricStream
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.IncludeFilters }}'
    item:
      Namespace: '{{ item.Namespace }}'
      MetricNames: '{{ item.MetricNames }}'
- discovery_id: aws.cloudwatch.getMetricWidgetImage
  calls:
  - action: getMetricWidgetImage
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.MetricWidgetImage }}'
- discovery_id: aws.cloudwatch.listManagedInsightRules
  calls:
  - action: listManagedInsightRules
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.ManagedRules }}'
    item:
      TemplateName: '{{ item.TemplateName }}'
      ResourceARN: '{{ item.ResourceARN }}'
      RuleState: '{{ item.RuleState }}'
- discovery_id: aws.cloudwatch.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Tags }}'
    item:
      Key: '{{ item.Key }}'
      Value: '{{ item.Value }}'
checks: []
