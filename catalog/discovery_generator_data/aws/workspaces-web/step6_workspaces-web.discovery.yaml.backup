version: '1.0'
provider: aws
service: workspaces-web
services:
  client: workspaces-web
  module: boto3.client
discovery:
- discovery_id: aws.workspaces-web.listBrowserSettings
  calls:
  - action: listBrowserSettings
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.browserSettings }}'
    item:
      browserSettingsArn: '{{ item.browserSettingsArn }}'
- discovery_id: aws.workspaces-web.listDataProtectionSettings
  calls:
  - action: listDataProtectionSettings
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.dataProtectionSettings }}'
    item:
      dataProtectionSettingsArn: '{{ item.dataProtectionSettingsArn }}'
      displayName: '{{ item.displayName }}'
      description: '{{ item.description }}'
      creationDate: '{{ item.creationDate }}'
- discovery_id: aws.workspaces-web.listIpAccessSettings
  calls:
  - action: listIpAccessSettings
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ipAccessSettings }}'
    item:
      ipAccessSettingsArn: '{{ item.ipAccessSettingsArn }}'
      displayName: '{{ item.displayName }}'
      description: '{{ item.description }}'
      creationDate: '{{ item.creationDate }}'
- discovery_id: aws.workspaces-web.listNetworkSettings
  calls:
  - action: listNetworkSettings
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.networkSettings }}'
    item:
      networkSettingsArn: '{{ item.networkSettingsArn }}'
      vpcId: '{{ item.vpcId }}'
- discovery_id: aws.workspaces-web.listPortals
  calls:
  - action: listPortals
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.portals }}'
    item:
      portalArn: '{{ item.portalArn }}'
      rendererType: '{{ item.rendererType }}'
      browserType: '{{ item.browserType }}'
      portalStatus: '{{ item.portalStatus }}'
      portalEndpoint: '{{ item.portalEndpoint }}'
      displayName: '{{ item.displayName }}'
      creationDate: '{{ item.creationDate }}'
      browserSettingsArn: '{{ item.browserSettingsArn }}'
      dataProtectionSettingsArn: '{{ item.dataProtectionSettingsArn }}'
      userSettingsArn: '{{ item.userSettingsArn }}'
      networkSettingsArn: '{{ item.networkSettingsArn }}'
      sessionLoggerArn: '{{ item.sessionLoggerArn }}'
      trustStoreArn: '{{ item.trustStoreArn }}'
      userAccessLoggingSettingsArn: '{{ item.userAccessLoggingSettingsArn }}'
      authenticationType: '{{ item.authenticationType }}'
      ipAccessSettingsArn: '{{ item.ipAccessSettingsArn }}'
      instanceType: '{{ item.instanceType }}'
      maxConcurrentSessions: '{{ item.maxConcurrentSessions }}'
- discovery_id: aws.workspaces-web.listSessionLoggers
  calls:
  - action: listSessionLoggers
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.sessionLoggers }}'
    item:
      sessionLoggerArn: '{{ item.sessionLoggerArn }}'
      logConfiguration: '{{ item.logConfiguration }}'
      displayName: '{{ item.displayName }}'
      creationDate: '{{ item.creationDate }}'
- discovery_id: aws.workspaces-web.listTrustStores
  calls:
  - action: listTrustStores
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.trustStores }}'
    item:
      trustStoreArn: '{{ item.trustStoreArn }}'
- discovery_id: aws.workspaces-web.listUserAccessLoggingSettings
  calls:
  - action: listUserAccessLoggingSettings
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.userAccessLoggingSettings }}'
    item:
      userAccessLoggingSettingsArn: '{{ item.userAccessLoggingSettingsArn }}'
      kinesisStreamArn: '{{ item.kinesisStreamArn }}'
- discovery_id: aws.workspaces-web.listUserSettings
  calls:
  - action: listUserSettings
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.userSettings }}'
    item:
      userSettingsArn: '{{ item.userSettingsArn }}'
      copyAllowed: '{{ item.copyAllowed }}'
      pasteAllowed: '{{ item.pasteAllowed }}'
      downloadAllowed: '{{ item.downloadAllowed }}'
      uploadAllowed: '{{ item.uploadAllowed }}'
      printAllowed: '{{ item.printAllowed }}'
      disconnectTimeoutInMinutes: '{{ item.disconnectTimeoutInMinutes }}'
      idleDisconnectTimeoutInMinutes: '{{ item.idleDisconnectTimeoutInMinutes }}'
      cookieSynchronizationConfiguration: '{{ item.cookieSynchronizationConfiguration
        }}'
      deepLinkAllowed: '{{ item.deepLinkAllowed }}'
      toolbarConfiguration: '{{ item.toolbarConfiguration }}'
- discovery_id: aws.workspaces-web.getBrowserSettings
  calls:
  - action: getBrowserSettings
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.browserSettings }}'
    item:
      browserSettingsArn: '{{ item.browserSettingsArn }}'
      associatedPortalArns: '{{ item.associatedPortalArns }}'
      browserPolicy: '{{ item.browserPolicy }}'
      customerManagedKey: '{{ item.customerManagedKey }}'
      additionalEncryptionContext: '{{ item.additionalEncryptionContext }}'
      webContentFilteringPolicy: '{{ item.webContentFilteringPolicy }}'
- discovery_id: aws.workspaces-web.getDataProtectionSettings
  calls:
  - action: getDataProtectionSettings
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.dataProtectionSettings }}'
    item:
      dataProtectionSettingsArn: '{{ item.dataProtectionSettingsArn }}'
      inlineRedactionConfiguration: '{{ item.inlineRedactionConfiguration }}'
      associatedPortalArns: '{{ item.associatedPortalArns }}'
      displayName: '{{ item.displayName }}'
      description: '{{ item.description }}'
      creationDate: '{{ item.creationDate }}'
      customerManagedKey: '{{ item.customerManagedKey }}'
      additionalEncryptionContext: '{{ item.additionalEncryptionContext }}'
- discovery_id: aws.workspaces-web.getIdentityProvider
  calls:
  - action: getIdentityProvider
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.identityProvider }}'
    item:
      identityProviderArn: '{{ item.identityProviderArn }}'
      identityProviderName: '{{ item.identityProviderName }}'
      identityProviderType: '{{ item.identityProviderType }}'
      identityProviderDetails: '{{ item.identityProviderDetails }}'
- discovery_id: aws.workspaces-web.getIpAccessSettings
  calls:
  - action: getIpAccessSettings
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ipAccessSettings }}'
    item:
      ipAccessSettingsArn: '{{ item.ipAccessSettingsArn }}'
      associatedPortalArns: '{{ item.associatedPortalArns }}'
      ipRules: '{{ item.ipRules }}'
      displayName: '{{ item.displayName }}'
      description: '{{ item.description }}'
      creationDate: '{{ item.creationDate }}'
      customerManagedKey: '{{ item.customerManagedKey }}'
      additionalEncryptionContext: '{{ item.additionalEncryptionContext }}'
- discovery_id: aws.workspaces-web.getNetworkSettings
  calls:
  - action: getNetworkSettings
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.networkSettings }}'
    item:
      networkSettingsArn: '{{ item.networkSettingsArn }}'
      associatedPortalArns: '{{ item.associatedPortalArns }}'
      vpcId: '{{ item.vpcId }}'
      subnetIds: '{{ item.subnetIds }}'
      securityGroupIds: '{{ item.securityGroupIds }}'
- discovery_id: aws.workspaces-web.getPortal
  calls:
  - action: getPortal
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.portal }}'
    item:
      portalArn: '{{ item.portalArn }}'
      rendererType: '{{ item.rendererType }}'
      browserType: '{{ item.browserType }}'
      portalStatus: '{{ item.portalStatus }}'
      portalEndpoint: '{{ item.portalEndpoint }}'
      displayName: '{{ item.displayName }}'
      creationDate: '{{ item.creationDate }}'
      browserSettingsArn: '{{ item.browserSettingsArn }}'
      dataProtectionSettingsArn: '{{ item.dataProtectionSettingsArn }}'
      userSettingsArn: '{{ item.userSettingsArn }}'
      networkSettingsArn: '{{ item.networkSettingsArn }}'
      sessionLoggerArn: '{{ item.sessionLoggerArn }}'
      trustStoreArn: '{{ item.trustStoreArn }}'
      statusReason: '{{ item.statusReason }}'
      userAccessLoggingSettingsArn: '{{ item.userAccessLoggingSettingsArn }}'
      authenticationType: '{{ item.authenticationType }}'
      ipAccessSettingsArn: '{{ item.ipAccessSettingsArn }}'
      customerManagedKey: '{{ item.customerManagedKey }}'
      additionalEncryptionContext: '{{ item.additionalEncryptionContext }}'
      instanceType: '{{ item.instanceType }}'
      maxConcurrentSessions: '{{ item.maxConcurrentSessions }}'
- discovery_id: aws.workspaces-web.getPortalServiceProviderMetadata
  calls:
  - action: getPortalServiceProviderMetadata
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.portalArn }}'
- discovery_id: aws.workspaces-web.getSession
  calls:
  - action: getSession
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.session }}'
    item:
      portalArn: '{{ item.portalArn }}'
      sessionId: '{{ item.sessionId }}'
      username: '{{ item.username }}'
      clientIpAddresses: '{{ item.clientIpAddresses }}'
      status: '{{ item.status }}'
      startTime: '{{ item.startTime }}'
      endTime: '{{ item.endTime }}'
- discovery_id: aws.workspaces-web.getSessionLogger
  calls:
  - action: getSessionLogger
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.sessionLogger }}'
    item:
      sessionLoggerArn: '{{ item.sessionLoggerArn }}'
      eventFilter: '{{ item.eventFilter }}'
      logConfiguration: '{{ item.logConfiguration }}'
      customerManagedKey: '{{ item.customerManagedKey }}'
      additionalEncryptionContext: '{{ item.additionalEncryptionContext }}'
      associatedPortalArns: '{{ item.associatedPortalArns }}'
      displayName: '{{ item.displayName }}'
      creationDate: '{{ item.creationDate }}'
- discovery_id: aws.workspaces-web.getTrustStore
  calls:
  - action: getTrustStore
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.trustStore }}'
    item:
      associatedPortalArns: '{{ item.associatedPortalArns }}'
      trustStoreArn: '{{ item.trustStoreArn }}'
- discovery_id: aws.workspaces-web.getTrustStoreCertificate
  calls:
  - action: getTrustStoreCertificate
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.certificate }}'
    item:
      thumbprint: '{{ item.thumbprint }}'
      subject: '{{ item.subject }}'
      issuer: '{{ item.issuer }}'
      notValidBefore: '{{ item.notValidBefore }}'
      notValidAfter: '{{ item.notValidAfter }}'
      body: '{{ item.body }}'
- discovery_id: aws.workspaces-web.getUserAccessLoggingSettings
  calls:
  - action: getUserAccessLoggingSettings
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.userAccessLoggingSettings }}'
    item:
      userAccessLoggingSettingsArn: '{{ item.userAccessLoggingSettingsArn }}'
      associatedPortalArns: '{{ item.associatedPortalArns }}'
      kinesisStreamArn: '{{ item.kinesisStreamArn }}'
- discovery_id: aws.workspaces-web.getUserSettings
  calls:
  - action: getUserSettings
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.userSettings }}'
    item:
      userSettingsArn: '{{ item.userSettingsArn }}'
      associatedPortalArns: '{{ item.associatedPortalArns }}'
      copyAllowed: '{{ item.copyAllowed }}'
      pasteAllowed: '{{ item.pasteAllowed }}'
      downloadAllowed: '{{ item.downloadAllowed }}'
      uploadAllowed: '{{ item.uploadAllowed }}'
      printAllowed: '{{ item.printAllowed }}'
      disconnectTimeoutInMinutes: '{{ item.disconnectTimeoutInMinutes }}'
      idleDisconnectTimeoutInMinutes: '{{ item.idleDisconnectTimeoutInMinutes }}'
      cookieSynchronizationConfiguration: '{{ item.cookieSynchronizationConfiguration
        }}'
      customerManagedKey: '{{ item.customerManagedKey }}'
      additionalEncryptionContext: '{{ item.additionalEncryptionContext }}'
      deepLinkAllowed: '{{ item.deepLinkAllowed }}'
      toolbarConfiguration: '{{ item.toolbarConfiguration }}'
- discovery_id: aws.workspaces-web.listIdentityProviders
  calls:
  - action: listIdentityProviders
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.identityProviders }}'
    item:
      identityProviderArn: '{{ item.identityProviderArn }}'
      identityProviderName: '{{ item.identityProviderName }}'
      identityProviderType: '{{ item.identityProviderType }}'
- discovery_id: aws.workspaces-web.listSessions
  calls:
  - action: listSessions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.sessions }}'
    item:
      portalArn: '{{ item.portalArn }}'
      sessionId: '{{ item.sessionId }}'
      username: '{{ item.username }}'
      status: '{{ item.status }}'
      startTime: '{{ item.startTime }}'
      endTime: '{{ item.endTime }}'
- discovery_id: aws.workspaces-web.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tags }}'
    item:
      Key: '{{ item.Key }}'
      Value: '{{ item.Value }}'
- discovery_id: aws.workspaces-web.listTrustStoreCertificates
  calls:
  - action: listTrustStoreCertificates
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.certificateList }}'
    item:
      thumbprint: '{{ item.thumbprint }}'
      subject: '{{ item.subject }}'
      issuer: '{{ item.issuer }}'
      notValidBefore: '{{ item.notValidBefore }}'
      notValidAfter: '{{ item.notValidAfter }}'
checks: []
