version: '1.0'
provider: aws
service: codepipeline
services:
  client: codepipeline
  module: boto3.client
discovery:
- discovery_id: aws.codepipeline.listActionTypes
  calls:
  - action: listActionTypes
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.actionTypes }}'
    item:
      id: '{{ item.id }}'
      settings: '{{ item.settings }}'
      actionConfigurationProperties: '{{ item.actionConfigurationProperties }}'
      inputArtifactDetails: '{{ item.inputArtifactDetails }}'
      outputArtifactDetails: '{{ item.outputArtifactDetails }}'
- discovery_id: aws.codepipeline.listPipelines
  calls:
  - action: listPipelines
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.pipelines }}'
    item:
      name: '{{ item.name }}'
      version: '{{ item.version }}'
      pipelineType: '{{ item.pipelineType }}'
      executionMode: '{{ item.executionMode }}'
      created: '{{ item.created }}'
      updated: '{{ item.updated }}'
- discovery_id: aws.codepipeline.listRuleTypes
  calls:
  - action: listRuleTypes
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ruleTypes }}'
    item:
      id: '{{ item.id }}'
      settings: '{{ item.settings }}'
      ruleConfigurationProperties: '{{ item.ruleConfigurationProperties }}'
      inputArtifactDetails: '{{ item.inputArtifactDetails }}'
- discovery_id: aws.codepipeline.listWebhooks
  calls:
  - action: listWebhooks
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.webhooks }}'
    item:
      definition: '{{ item.definition }}'
      url: '{{ item.url }}'
      errorMessage: '{{ item.errorMessage }}'
      errorCode: '{{ item.errorCode }}'
      lastTriggered: '{{ item.lastTriggered }}'
      arn: '{{ item.arn }}'
      tags: '{{ item.tags }}'
- discovery_id: aws.codepipeline.getActionType
  calls:
  - action: getActionType
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.actionType }}'
    item:
      description: '{{ item.description }}'
      executor: '{{ item.executor }}'
      id: '{{ item.id }}'
      inputArtifactDetails: '{{ item.inputArtifactDetails }}'
      outputArtifactDetails: '{{ item.outputArtifactDetails }}'
      permissions: '{{ item.permissions }}'
      properties: '{{ item.properties }}'
      urls: '{{ item.urls }}'
- discovery_id: aws.codepipeline.getJobDetails
  calls:
  - action: getJobDetails
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.jobDetails }}'
    item:
      id: '{{ item.id }}'
      data: '{{ item.data }}'
      accountId: '{{ item.accountId }}'
- discovery_id: aws.codepipeline.getPipeline
  calls:
  - action: getPipeline
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.pipeline }}'
    item:
      name: '{{ item.name }}'
      roleArn: '{{ item.roleArn }}'
      artifactStore: '{{ item.artifactStore }}'
      artifactStores: '{{ item.artifactStores }}'
      stages: '{{ item.stages }}'
      version: '{{ item.version }}'
      executionMode: '{{ item.executionMode }}'
      pipelineType: '{{ item.pipelineType }}'
      variables: '{{ item.variables }}'
      triggers: '{{ item.triggers }}'
- discovery_id: aws.codepipeline.getPipelineExecution
  calls:
  - action: getPipelineExecution
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.pipelineExecution }}'
    item:
      pipelineName: '{{ item.pipelineName }}'
      pipelineVersion: '{{ item.pipelineVersion }}'
      pipelineExecutionId: '{{ item.pipelineExecutionId }}'
      status: '{{ item.status }}'
      statusSummary: '{{ item.statusSummary }}'
      artifactRevisions: '{{ item.artifactRevisions }}'
      variables: '{{ item.variables }}'
      trigger: '{{ item.trigger }}'
      executionMode: '{{ item.executionMode }}'
      executionType: '{{ item.executionType }}'
      rollbackMetadata: '{{ item.rollbackMetadata }}'
- discovery_id: aws.codepipeline.getPipelineState
  calls:
  - action: getPipelineState
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.stageStates }}'
    item:
      stageName: '{{ item.stageName }}'
      inboundExecution: '{{ item.inboundExecution }}'
      inboundExecutions: '{{ item.inboundExecutions }}'
      inboundTransitionState: '{{ item.inboundTransitionState }}'
      actionStates: '{{ item.actionStates }}'
      latestExecution: '{{ item.latestExecution }}'
      beforeEntryConditionState: '{{ item.beforeEntryConditionState }}'
      onSuccessConditionState: '{{ item.onSuccessConditionState }}'
      onFailureConditionState: '{{ item.onFailureConditionState }}'
      retryStageMetadata: '{{ item.retryStageMetadata }}'
- discovery_id: aws.codepipeline.getThirdPartyJobDetails
  calls:
  - action: getThirdPartyJobDetails
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.jobDetails }}'
    item:
      id: '{{ item.id }}'
      data: '{{ item.data }}'
      nonce: '{{ item.nonce }}'
- discovery_id: aws.codepipeline.listActionExecutions
  calls:
  - action: listActionExecutions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.actionExecutionDetails }}'
    item:
      pipelineExecutionId: '{{ item.pipelineExecutionId }}'
      actionExecutionId: '{{ item.actionExecutionId }}'
      pipelineVersion: '{{ item.pipelineVersion }}'
      stageName: '{{ item.stageName }}'
      actionName: '{{ item.actionName }}'
      startTime: '{{ item.startTime }}'
      lastUpdateTime: '{{ item.lastUpdateTime }}'
      updatedBy: '{{ item.updatedBy }}'
      status: '{{ item.status }}'
      input: '{{ item.input }}'
      output: '{{ item.output }}'
- discovery_id: aws.codepipeline.listDeployActionExecutionTargets
  calls:
  - action: listDeployActionExecutionTargets
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.targets }}'
    item:
      targetId: '{{ item.targetId }}'
      targetType: '{{ item.targetType }}'
      status: '{{ item.status }}'
      startTime: '{{ item.startTime }}'
      endTime: '{{ item.endTime }}'
      events: '{{ item.events }}'
- discovery_id: aws.codepipeline.listPipelineExecutions
  calls:
  - action: listPipelineExecutions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.pipelineExecutionSummaries }}'
    item:
      pipelineExecutionId: '{{ item.pipelineExecutionId }}'
      status: '{{ item.status }}'
      statusSummary: '{{ item.statusSummary }}'
      startTime: '{{ item.startTime }}'
      lastUpdateTime: '{{ item.lastUpdateTime }}'
      sourceRevisions: '{{ item.sourceRevisions }}'
      trigger: '{{ item.trigger }}'
      stopTrigger: '{{ item.stopTrigger }}'
      executionMode: '{{ item.executionMode }}'
      executionType: '{{ item.executionType }}'
      rollbackMetadata: '{{ item.rollbackMetadata }}'
- discovery_id: aws.codepipeline.listRuleExecutions
  calls:
  - action: listRuleExecutions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ruleExecutionDetails }}'
    item:
      pipelineExecutionId: '{{ item.pipelineExecutionId }}'
      ruleExecutionId: '{{ item.ruleExecutionId }}'
      pipelineVersion: '{{ item.pipelineVersion }}'
      stageName: '{{ item.stageName }}'
      ruleName: '{{ item.ruleName }}'
      startTime: '{{ item.startTime }}'
      lastUpdateTime: '{{ item.lastUpdateTime }}'
      updatedBy: '{{ item.updatedBy }}'
      status: '{{ item.status }}'
      input: '{{ item.input }}'
      output: '{{ item.output }}'
- discovery_id: aws.codepipeline.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tags }}'
    item:
      key: '{{ item.key }}'
      value: '{{ item.value }}'
checks: []
