version: '1.0'
provider: aws
service: appfabric
services:
  client: appfabric
  module: boto3.client
discovery:
- discovery_id: aws.appfabric.listAppBundles
  calls:
  - action: listAppBundles
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.appBundleSummaryList }}'
    item:
      arn: '{{ item.arn }}'
- discovery_id: aws.appfabric.getAppAuthorization
  calls:
  - action: getAppAuthorization
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.appAuthorization }}'
    item:
      appAuthorizationArn: '{{ item.appAuthorizationArn }}'
      appBundleArn: '{{ item.appBundleArn }}'
      app: '{{ item.app }}'
      tenant: '{{ item.tenant }}'
      authType: '{{ item.authType }}'
      status: '{{ item.status }}'
      createdAt: '{{ item.createdAt }}'
      updatedAt: '{{ item.updatedAt }}'
      persona: '{{ item.persona }}'
      authUrl: '{{ item.authUrl }}'
- discovery_id: aws.appfabric.getAppBundle
  calls:
  - action: getAppBundle
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.appBundle }}'
    item:
      arn: '{{ item.arn }}'
      customerManagedKeyArn: '{{ item.customerManagedKeyArn }}'
- discovery_id: aws.appfabric.getIngestion
  calls:
  - action: getIngestion
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ingestion }}'
    item:
      arn: '{{ item.arn }}'
      appBundleArn: '{{ item.appBundleArn }}'
      app: '{{ item.app }}'
      tenantId: '{{ item.tenantId }}'
      createdAt: '{{ item.createdAt }}'
      updatedAt: '{{ item.updatedAt }}'
      state: '{{ item.state }}'
      ingestionType: '{{ item.ingestionType }}'
- discovery_id: aws.appfabric.getIngestionDestination
  calls:
  - action: getIngestionDestination
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ingestionDestination }}'
    item:
      arn: '{{ item.arn }}'
      ingestionArn: '{{ item.ingestionArn }}'
      processingConfiguration: '{{ item.processingConfiguration }}'
      destinationConfiguration: '{{ item.destinationConfiguration }}'
      status: '{{ item.status }}'
      statusReason: '{{ item.statusReason }}'
      createdAt: '{{ item.createdAt }}'
      updatedAt: '{{ item.updatedAt }}'
- discovery_id: aws.appfabric.listAppAuthorizations
  calls:
  - action: listAppAuthorizations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.appAuthorizationSummaryList }}'
    item:
      appAuthorizationArn: '{{ item.appAuthorizationArn }}'
      appBundleArn: '{{ item.appBundleArn }}'
      app: '{{ item.app }}'
      tenant: '{{ item.tenant }}'
      status: '{{ item.status }}'
      updatedAt: '{{ item.updatedAt }}'
- discovery_id: aws.appfabric.listIngestionDestinations
  calls:
  - action: listIngestionDestinations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ingestionDestinations }}'
    item:
      arn: '{{ item.arn }}'
- discovery_id: aws.appfabric.listIngestions
  calls:
  - action: listIngestions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ingestions }}'
    item:
      arn: '{{ item.arn }}'
      app: '{{ item.app }}'
      tenantId: '{{ item.tenantId }}'
      state: '{{ item.state }}'
- discovery_id: aws.appfabric.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tags }}'
    item:
      key: '{{ item.key }}'
      value: '{{ item.value }}'
checks: []
