version: '1.0'
provider: aws
service: finspace
services:
  client: finspace
  module: boto3.client
discovery:
- discovery_id: aws.finspace.listEnvironments
  calls:
  - action: listEnvironments
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.environments }}'
    item:
      name: '{{ item.name }}'
      environmentId: '{{ item.environmentId }}'
      awsAccountId: '{{ item.awsAccountId }}'
      status: '{{ item.status }}'
      environmentUrl: '{{ item.environmentUrl }}'
      description: '{{ item.description }}'
      environmentArn: '{{ item.environmentArn }}'
      sageMakerStudioDomainUrl: '{{ item.sageMakerStudioDomainUrl }}'
      kmsKeyId: '{{ item.kmsKeyId }}'
      dedicatedServiceAccountId: '{{ item.dedicatedServiceAccountId }}'
      federationMode: '{{ item.federationMode }}'
      federationParameters: '{{ item.federationParameters }}'
- discovery_id: aws.finspace.listKxEnvironments
  calls:
  - action: listKxEnvironments
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.environments }}'
    item:
      name: '{{ item.name }}'
      environmentId: '{{ item.environmentId }}'
      awsAccountId: '{{ item.awsAccountId }}'
      status: '{{ item.status }}'
      tgwStatus: '{{ item.tgwStatus }}'
      dnsStatus: '{{ item.dnsStatus }}'
      errorMessage: '{{ item.errorMessage }}'
      description: '{{ item.description }}'
      environmentArn: '{{ item.environmentArn }}'
      kmsKeyId: '{{ item.kmsKeyId }}'
      dedicatedServiceAccountId: '{{ item.dedicatedServiceAccountId }}'
      transitGatewayConfiguration: '{{ item.transitGatewayConfiguration }}'
      customDNSConfiguration: '{{ item.customDNSConfiguration }}'
      creationTimestamp: '{{ item.creationTimestamp }}'
      updateTimestamp: '{{ item.updateTimestamp }}'
      availabilityZoneIds: '{{ item.availabilityZoneIds }}'
      certificateAuthorityArn: '{{ item.certificateAuthorityArn }}'
- discovery_id: aws.finspace.getEnvironment
  calls:
  - action: getEnvironment
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.environment }}'
    item:
      name: '{{ item.name }}'
      environmentId: '{{ item.environmentId }}'
      awsAccountId: '{{ item.awsAccountId }}'
      status: '{{ item.status }}'
      environmentUrl: '{{ item.environmentUrl }}'
      description: '{{ item.description }}'
      environmentArn: '{{ item.environmentArn }}'
      sageMakerStudioDomainUrl: '{{ item.sageMakerStudioDomainUrl }}'
      kmsKeyId: '{{ item.kmsKeyId }}'
      dedicatedServiceAccountId: '{{ item.dedicatedServiceAccountId }}'
      federationMode: '{{ item.federationMode }}'
      federationParameters: '{{ item.federationParameters }}'
- discovery_id: aws.finspace.getKxChangeset
  calls:
  - action: getKxChangeset
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.changeRequests }}'
    item:
      changeType: '{{ item.changeType }}'
      s3Path: '{{ item.s3Path }}'
      dbPath: '{{ item.dbPath }}'
- discovery_id: aws.finspace.getKxCluster
  calls:
  - action: getKxCluster
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.volumes }}'
    item:
      volumeName: '{{ item.volumeName }}'
      volumeType: '{{ item.volumeType }}'
- discovery_id: aws.finspace.getKxConnectionString
  calls:
  - action: getKxConnectionString
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.signedConnectionString }}'
- discovery_id: aws.finspace.getKxDatabase
  calls:
  - action: getKxDatabase
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.databaseName }}'
- discovery_id: aws.finspace.getKxDataview
  calls:
  - action: getKxDataview
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.segmentConfigurations }}'
    item:
      dbPaths: '{{ item.dbPaths }}'
      volumeName: '{{ item.volumeName }}'
      onDemand: '{{ item.onDemand }}'
- discovery_id: aws.finspace.getKxEnvironment
  calls:
  - action: getKxEnvironment
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.customDNSConfiguration }}'
    item:
      customDNSServerName: '{{ item.customDNSServerName }}'
      customDNSServerIP: '{{ item.customDNSServerIP }}'
- discovery_id: aws.finspace.getKxScalingGroup
  calls:
  - action: getKxScalingGroup
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.clusters }}'
- discovery_id: aws.finspace.getKxUser
  calls:
  - action: getKxUser
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.userName }}'
- discovery_id: aws.finspace.getKxVolume
  calls:
  - action: getKxVolume
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.availabilityZoneIds }}'
- discovery_id: aws.finspace.listKxChangesets
  calls:
  - action: listKxChangesets
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.kxChangesets }}'
    item:
      changesetId: '{{ item.changesetId }}'
      createdTimestamp: '{{ item.createdTimestamp }}'
      activeFromTimestamp: '{{ item.activeFromTimestamp }}'
      lastModifiedTimestamp: '{{ item.lastModifiedTimestamp }}'
      status: '{{ item.status }}'
- discovery_id: aws.finspace.listKxClusterNodes
  calls:
  - action: listKxClusterNodes
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.nodes }}'
    item:
      nodeId: '{{ item.nodeId }}'
      availabilityZoneId: '{{ item.availabilityZoneId }}'
      launchTime: '{{ item.launchTime }}'
      status: '{{ item.status }}'
- discovery_id: aws.finspace.listKxClusters
  calls:
  - action: listKxClusters
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.kxClusterSummaries }}'
    item:
      status: '{{ item.status }}'
      statusReason: '{{ item.statusReason }}'
      clusterName: '{{ item.clusterName }}'
      clusterType: '{{ item.clusterType }}'
      clusterDescription: '{{ item.clusterDescription }}'
      releaseLabel: '{{ item.releaseLabel }}'
      volumes: '{{ item.volumes }}'
      initializationScript: '{{ item.initializationScript }}'
      executionRole: '{{ item.executionRole }}'
      azMode: '{{ item.azMode }}'
      availabilityZoneId: '{{ item.availabilityZoneId }}'
      lastModifiedTimestamp: '{{ item.lastModifiedTimestamp }}'
      createdTimestamp: '{{ item.createdTimestamp }}'
- discovery_id: aws.finspace.listKxDatabases
  calls:
  - action: listKxDatabases
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.kxDatabases }}'
    item:
      databaseName: '{{ item.databaseName }}'
      createdTimestamp: '{{ item.createdTimestamp }}'
      lastModifiedTimestamp: '{{ item.lastModifiedTimestamp }}'
- discovery_id: aws.finspace.listKxDataviews
  calls:
  - action: listKxDataviews
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.kxDataviews }}'
    item:
      environmentId: '{{ item.environmentId }}'
      databaseName: '{{ item.databaseName }}'
      dataviewName: '{{ item.dataviewName }}'
      azMode: '{{ item.azMode }}'
      availabilityZoneId: '{{ item.availabilityZoneId }}'
      changesetId: '{{ item.changesetId }}'
      segmentConfigurations: '{{ item.segmentConfigurations }}'
      activeVersions: '{{ item.activeVersions }}'
      status: '{{ item.status }}'
      description: '{{ item.description }}'
      autoUpdate: '{{ item.autoUpdate }}'
      readWrite: '{{ item.readWrite }}'
      createdTimestamp: '{{ item.createdTimestamp }}'
      lastModifiedTimestamp: '{{ item.lastModifiedTimestamp }}'
      statusReason: '{{ item.statusReason }}'
- discovery_id: aws.finspace.listKxScalingGroups
  calls:
  - action: listKxScalingGroups
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.scalingGroups }}'
    item:
      scalingGroupName: '{{ item.scalingGroupName }}'
      hostType: '{{ item.hostType }}'
      clusters: '{{ item.clusters }}'
      availabilityZoneId: '{{ item.availabilityZoneId }}'
      status: '{{ item.status }}'
      statusReason: '{{ item.statusReason }}'
      lastModifiedTimestamp: '{{ item.lastModifiedTimestamp }}'
      createdTimestamp: '{{ item.createdTimestamp }}'
- discovery_id: aws.finspace.listKxUsers
  calls:
  - action: listKxUsers
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.users }}'
    item:
      userArn: '{{ item.userArn }}'
      userName: '{{ item.userName }}'
      iamRole: '{{ item.iamRole }}'
      createTimestamp: '{{ item.createTimestamp }}'
      updateTimestamp: '{{ item.updateTimestamp }}'
- discovery_id: aws.finspace.listKxVolumes
  calls:
  - action: listKxVolumes
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.kxVolumeSummaries }}'
    item:
      volumeName: '{{ item.volumeName }}'
      volumeType: '{{ item.volumeType }}'
      status: '{{ item.status }}'
      description: '{{ item.description }}'
      statusReason: '{{ item.statusReason }}'
      azMode: '{{ item.azMode }}'
      availabilityZoneIds: '{{ item.availabilityZoneIds }}'
      createdTimestamp: '{{ item.createdTimestamp }}'
      lastModifiedTimestamp: '{{ item.lastModifiedTimestamp }}'
- discovery_id: aws.finspace.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tags }}'
checks: []
