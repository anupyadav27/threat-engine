version: '1.0'
provider: aws
service: macie2
services:
  client: macie2
  module: boto3.client
discovery:
- discovery_id: aws.macie2.describeBuckets
  calls:
  - action: describeBuckets
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.buckets }}'
    item:
      accountId: '{{ item.accountId }}'
      allowsUnencryptedObjectUploads: '{{ item.allowsUnencryptedObjectUploads }}'
      automatedDiscoveryMonitoringStatus: '{{ item.automatedDiscoveryMonitoringStatus
        }}'
      bucketArn: '{{ item.bucketArn }}'
      bucketCreatedAt: '{{ item.bucketCreatedAt }}'
      bucketName: '{{ item.bucketName }}'
      classifiableObjectCount: '{{ item.classifiableObjectCount }}'
      classifiableSizeInBytes: '{{ item.classifiableSizeInBytes }}'
      errorCode: '{{ item.errorCode }}'
      errorMessage: '{{ item.errorMessage }}'
      jobDetails: '{{ item.jobDetails }}'
      lastAutomatedDiscoveryTime: '{{ item.lastAutomatedDiscoveryTime }}'
      lastUpdated: '{{ item.lastUpdated }}'
      objectCount: '{{ item.objectCount }}'
      objectCountByEncryptionType: '{{ item.objectCountByEncryptionType }}'
      publicAccess: '{{ item.publicAccess }}'
      region: '{{ item.region }}'
      replicationDetails: '{{ item.replicationDetails }}'
      sensitivityScore: '{{ item.sensitivityScore }}'
      serverSideEncryption: '{{ item.serverSideEncryption }}'
      sharedAccess: '{{ item.sharedAccess }}'
      sizeInBytes: '{{ item.sizeInBytes }}'
      sizeInBytesCompressed: '{{ item.sizeInBytesCompressed }}'
      tags: '{{ item.tags }}'
      unclassifiableObjectCount: '{{ item.unclassifiableObjectCount }}'
      unclassifiableObjectSizeInBytes: '{{ item.unclassifiableObjectSizeInBytes }}'
      versioning: '{{ item.versioning }}'
- discovery_id: aws.macie2.describeOrganizationConfiguration
  calls:
  - action: describeOrganizationConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.autoEnable }}'
- discovery_id: aws.macie2.getAdministratorAccount
  calls:
  - action: getAdministratorAccount
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.administrator }}'
    item:
      accountId: '{{ item.accountId }}'
      invitationId: '{{ item.invitationId }}'
      invitedAt: '{{ item.invitedAt }}'
      relationshipStatus: '{{ item.relationshipStatus }}'
- discovery_id: aws.macie2.getAutomatedDiscoveryConfiguration
  calls:
  - action: getAutomatedDiscoveryConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.autoEnableOrganizationMembers }}'
- discovery_id: aws.macie2.getBucketStatistics
  calls:
  - action: getBucketStatistics
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.bucketCountByEffectivePermission }}'
    item:
      publiclyAccessible: '{{ item.publiclyAccessible }}'
      publiclyReadable: '{{ item.publiclyReadable }}'
      publiclyWritable: '{{ item.publiclyWritable }}'
      unknown: '{{ item.unknown }}'
- discovery_id: aws.macie2.getClassificationExportConfiguration
  calls:
  - action: getClassificationExportConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.configuration }}'
    item:
      s3Destination: '{{ item.s3Destination }}'
- discovery_id: aws.macie2.getFindingsPublicationConfiguration
  calls:
  - action: getFindingsPublicationConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.securityHubConfiguration }}'
    item:
      publishClassificationFindings: '{{ item.publishClassificationFindings }}'
      publishPolicyFindings: '{{ item.publishPolicyFindings }}'
- discovery_id: aws.macie2.getInvitationsCount
  calls:
  - action: getInvitationsCount
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.invitationsCount }}'
- discovery_id: aws.macie2.getMacieSession
  calls:
  - action: getMacieSession
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.createdAt }}'
- discovery_id: aws.macie2.getMasterAccount
  calls:
  - action: getMasterAccount
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.master }}'
    item:
      accountId: '{{ item.accountId }}'
      invitationId: '{{ item.invitationId }}'
      invitedAt: '{{ item.invitedAt }}'
      relationshipStatus: '{{ item.relationshipStatus }}'
- discovery_id: aws.macie2.getRevealConfiguration
  calls:
  - action: getRevealConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.configuration }}'
    item:
      kmsKeyId: '{{ item.kmsKeyId }}'
      status: '{{ item.status }}'
- discovery_id: aws.macie2.getUsageStatistics
  calls:
  - action: getUsageStatistics
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.records }}'
    item:
      accountId: '{{ item.accountId }}'
      automatedDiscoveryFreeTrialStartDate: '{{ item.automatedDiscoveryFreeTrialStartDate
        }}'
      freeTrialStartDate: '{{ item.freeTrialStartDate }}'
      usage: '{{ item.usage }}'
- discovery_id: aws.macie2.getUsageTotals
  calls:
  - action: getUsageTotals
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.usageTotals }}'
    item:
      currency: '{{ item.currency }}'
      estimatedCost: '{{ item.estimatedCost }}'
      type: '{{ item.type }}'
- discovery_id: aws.macie2.listAllowLists
  calls:
  - action: listAllowLists
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.allowLists }}'
    item:
      arn: '{{ item.arn }}'
      createdAt: '{{ item.createdAt }}'
      description: '{{ item.description }}'
      id: '{{ item.id }}'
      name: '{{ item.name }}'
      updatedAt: '{{ item.updatedAt }}'
- discovery_id: aws.macie2.listAutomatedDiscoveryAccounts
  calls:
  - action: listAutomatedDiscoveryAccounts
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
    item:
      accountId: '{{ item.accountId }}'
      status: '{{ item.status }}'
- discovery_id: aws.macie2.listClassificationJobs
  calls:
  - action: listClassificationJobs
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
    item:
      bucketCriteria: '{{ item.bucketCriteria }}'
      bucketDefinitions: '{{ item.bucketDefinitions }}'
      createdAt: '{{ item.createdAt }}'
      jobId: '{{ item.jobId }}'
      jobStatus: '{{ item.jobStatus }}'
      jobType: '{{ item.jobType }}'
      lastRunErrorStatus: '{{ item.lastRunErrorStatus }}'
      name: '{{ item.name }}'
      userPausedDetails: '{{ item.userPausedDetails }}'
- discovery_id: aws.macie2.listClassificationScopes
  calls:
  - action: listClassificationScopes
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.classificationScopes }}'
    item:
      id: '{{ item.id }}'
      name: '{{ item.name }}'
- discovery_id: aws.macie2.listCustomDataIdentifiers
  calls:
  - action: listCustomDataIdentifiers
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
    item:
      arn: '{{ item.arn }}'
      createdAt: '{{ item.createdAt }}'
      description: '{{ item.description }}'
      id: '{{ item.id }}'
      name: '{{ item.name }}'
- discovery_id: aws.macie2.listFindings
  calls:
  - action: listFindings
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.findingIds }}'
- discovery_id: aws.macie2.listFindingsFilters
  calls:
  - action: listFindingsFilters
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.findingsFilterListItems }}'
    item:
      action: '{{ item.action }}'
      arn: '{{ item.arn }}'
      id: '{{ item.id }}'
      name: '{{ item.name }}'
      tags: '{{ item.tags }}'
- discovery_id: aws.macie2.listInvitations
  calls:
  - action: listInvitations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.invitations }}'
    item:
      accountId: '{{ item.accountId }}'
      invitationId: '{{ item.invitationId }}'
      invitedAt: '{{ item.invitedAt }}'
      relationshipStatus: '{{ item.relationshipStatus }}'
- discovery_id: aws.macie2.listManagedDataIdentifiers
  calls:
  - action: listManagedDataIdentifiers
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
    item:
      category: '{{ item.category }}'
      id: '{{ item.id }}'
- discovery_id: aws.macie2.listMembers
  calls:
  - action: listMembers
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.members }}'
    item:
      accountId: '{{ item.accountId }}'
      administratorAccountId: '{{ item.administratorAccountId }}'
      arn: '{{ item.arn }}'
      email: '{{ item.email }}'
      invitedAt: '{{ item.invitedAt }}'
      masterAccountId: '{{ item.masterAccountId }}'
      relationshipStatus: '{{ item.relationshipStatus }}'
      tags: '{{ item.tags }}'
      updatedAt: '{{ item.updatedAt }}'
- discovery_id: aws.macie2.listOrganizationAdminAccounts
  calls:
  - action: listOrganizationAdminAccounts
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.adminAccounts }}'
    item:
      accountId: '{{ item.accountId }}'
      status: '{{ item.status }}'
- discovery_id: aws.macie2.listSensitivityInspectionTemplates
  calls:
  - action: listSensitivityInspectionTemplates
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.sensitivityInspectionTemplates }}'
    item:
      id: '{{ item.id }}'
      name: '{{ item.name }}'
- discovery_id: aws.macie2.searchResources
  calls:
  - action: searchResources
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.matchingResources }}'
    item:
      matchingBucket: '{{ item.matchingBucket }}'
- discovery_id: aws.macie2.describeClassificationJob
  calls:
  - action: describeClassificationJob
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.allowListIds }}'
- discovery_id: aws.macie2.getAllowList
  calls:
  - action: getAllowList
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.criteria }}'
    item:
      regex: '{{ item.regex }}'
      s3WordsList: '{{ item.s3WordsList }}'
- discovery_id: aws.macie2.getClassificationScope
  calls:
  - action: getClassificationScope
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.s3 }}'
    item:
      excludes: '{{ item.excludes }}'
- discovery_id: aws.macie2.getCustomDataIdentifier
  calls:
  - action: getCustomDataIdentifier
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ignoreWords }}'
- discovery_id: aws.macie2.getFindingStatistics
  calls:
  - action: getFindingStatistics
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.countsByGroup }}'
    item:
      count: '{{ item.count }}'
      groupKey: '{{ item.groupKey }}'
- discovery_id: aws.macie2.getFindings
  calls:
  - action: getFindings
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.findings }}'
    item:
      accountId: '{{ item.accountId }}'
      archived: '{{ item.archived }}'
      category: '{{ item.category }}'
      classificationDetails: '{{ item.classificationDetails }}'
      count: '{{ item.count }}'
      createdAt: '{{ item.createdAt }}'
      description: '{{ item.description }}'
      id: '{{ item.id }}'
      partition: '{{ item.partition }}'
      policyDetails: '{{ item.policyDetails }}'
      region: '{{ item.region }}'
      resourcesAffected: '{{ item.resourcesAffected }}'
      sample: '{{ item.sample }}'
      schemaVersion: '{{ item.schemaVersion }}'
      severity: '{{ item.severity }}'
      title: '{{ item.title }}'
      type: '{{ item.type }}'
      updatedAt: '{{ item.updatedAt }}'
- discovery_id: aws.macie2.getFindingsFilter
  calls:
  - action: getFindingsFilter
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.findingCriteria }}'
    item:
      criterion: '{{ item.criterion }}'
- discovery_id: aws.macie2.getMember
  calls:
  - action: getMember
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.accountId }}'
- discovery_id: aws.macie2.getResourceProfile
  calls:
  - action: getResourceProfile
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.statistics }}'
    item:
      totalBytesClassified: '{{ item.totalBytesClassified }}'
      totalDetections: '{{ item.totalDetections }}'
      totalDetectionsSuppressed: '{{ item.totalDetectionsSuppressed }}'
      totalItemsClassified: '{{ item.totalItemsClassified }}'
      totalItemsSensitive: '{{ item.totalItemsSensitive }}'
      totalItemsSkipped: '{{ item.totalItemsSkipped }}'
      totalItemsSkippedInvalidEncryption: '{{ item.totalItemsSkippedInvalidEncryption
        }}'
      totalItemsSkippedInvalidKms: '{{ item.totalItemsSkippedInvalidKms }}'
      totalItemsSkippedPermissionDenied: '{{ item.totalItemsSkippedPermissionDenied
        }}'
- discovery_id: aws.macie2.getSensitiveDataOccurrences
  calls:
  - action: getSensitiveDataOccurrences
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.error }}'
- discovery_id: aws.macie2.getSensitiveDataOccurrencesAvailability
  calls:
  - action: getSensitiveDataOccurrencesAvailability
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.reasons }}'
- discovery_id: aws.macie2.getSensitivityInspectionTemplate
  calls:
  - action: getSensitivityInspectionTemplate
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.excludes }}'
    item:
      managedDataIdentifierIds: '{{ item.managedDataIdentifierIds }}'
- discovery_id: aws.macie2.listResourceProfileArtifacts
  calls:
  - action: listResourceProfileArtifacts
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.artifacts }}'
    item:
      arn: '{{ item.arn }}'
      classificationResultStatus: '{{ item.classificationResultStatus }}'
      sensitive: '{{ item.sensitive }}'
- discovery_id: aws.macie2.listResourceProfileDetections
  calls:
  - action: listResourceProfileDetections
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.detections }}'
    item:
      arn: '{{ item.arn }}'
      count: '{{ item.count }}'
      id: '{{ item.id }}'
      name: '{{ item.name }}'
      suppressed: '{{ item.suppressed }}'
      type: '{{ item.type }}'
- discovery_id: aws.macie2.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tags }}'
checks: []
