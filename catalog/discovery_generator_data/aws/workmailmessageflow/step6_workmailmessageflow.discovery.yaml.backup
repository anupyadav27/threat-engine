version: '1.0'
provider: aws
service: workmailmessageflow
services:
  client: workmailmessageflow
  module: boto3.client
discovery:
- discovery_id: aws.workmailmessageflow.getRawMessageContent
  calls:
  - action: getRawMessageContent
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.messageContent }}'
checks: []
