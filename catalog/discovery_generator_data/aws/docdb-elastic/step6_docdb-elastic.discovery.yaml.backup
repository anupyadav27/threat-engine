version: '1.0'
provider: aws
service: docdb-elastic
services:
  client: docdb-elastic
  module: boto3.client
discovery:
- discovery_id: aws.docdb-elastic.listClusterSnapshots
  calls:
  - action: listClusterSnapshots
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.snapshots }}'
    item:
      clusterArn: '{{ item.clusterArn }}'
      snapshotArn: '{{ item.snapshotArn }}'
      snapshotCreationTime: '{{ item.snapshotCreationTime }}'
      snapshotName: '{{ item.snapshotName }}'
      status: '{{ item.status }}'
- discovery_id: aws.docdb-elastic.listClusters
  calls:
  - action: listClusters
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.clusters }}'
    item:
      clusterArn: '{{ item.clusterArn }}'
      clusterName: '{{ item.clusterName }}'
      status: '{{ item.status }}'
- discovery_id: aws.docdb-elastic.listPendingMaintenanceActions
  calls:
  - action: listPendingMaintenanceActions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.resourcePendingMaintenanceActions }}'
    item:
      pendingMaintenanceActionDetails: '{{ item.pendingMaintenanceActionDetails }}'
      resourceArn: '{{ item.resourceArn }}'
- discovery_id: aws.docdb-elastic.getCluster
  calls:
  - action: getCluster
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.cluster }}'
    item:
      adminUserName: '{{ item.adminUserName }}'
      authType: '{{ item.authType }}'
      backupRetentionPeriod: '{{ item.backupRetentionPeriod }}'
      clusterArn: '{{ item.clusterArn }}'
      clusterEndpoint: '{{ item.clusterEndpoint }}'
      clusterName: '{{ item.clusterName }}'
      createTime: '{{ item.createTime }}'
      kmsKeyId: '{{ item.kmsKeyId }}'
      preferredBackupWindow: '{{ item.preferredBackupWindow }}'
      preferredMaintenanceWindow: '{{ item.preferredMaintenanceWindow }}'
      shardCapacity: '{{ item.shardCapacity }}'
      shardCount: '{{ item.shardCount }}'
      shardInstanceCount: '{{ item.shardInstanceCount }}'
      shards: '{{ item.shards }}'
      status: '{{ item.status }}'
      subnetIds: '{{ item.subnetIds }}'
      vpcSecurityGroupIds: '{{ item.vpcSecurityGroupIds }}'
- discovery_id: aws.docdb-elastic.getClusterSnapshot
  calls:
  - action: getClusterSnapshot
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.snapshot }}'
    item:
      adminUserName: '{{ item.adminUserName }}'
      clusterArn: '{{ item.clusterArn }}'
      clusterCreationTime: '{{ item.clusterCreationTime }}'
      kmsKeyId: '{{ item.kmsKeyId }}'
      snapshotArn: '{{ item.snapshotArn }}'
      snapshotCreationTime: '{{ item.snapshotCreationTime }}'
      snapshotName: '{{ item.snapshotName }}'
      snapshotType: '{{ item.snapshotType }}'
      status: '{{ item.status }}'
      subnetIds: '{{ item.subnetIds }}'
      vpcSecurityGroupIds: '{{ item.vpcSecurityGroupIds }}'
- discovery_id: aws.docdb-elastic.getPendingMaintenanceAction
  calls:
  - action: getPendingMaintenanceAction
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.resourcePendingMaintenanceAction }}'
    item:
      pendingMaintenanceActionDetails: '{{ item.pendingMaintenanceActionDetails }}'
      resourceArn: '{{ item.resourceArn }}'
- discovery_id: aws.docdb-elastic.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tags }}'
checks: []
