version: '1.0'
provider: aws
service: eks
services:
  client: eks
  module: boto3.client
discovery:
- discovery_id: aws.eks.describeAddonVersions
  calls:
  - action: describeAddonVersions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.addons }}'
    item:
      addonName: '{{ item.addonName }}'
      type: '{{ item.type }}'
      addonVersions: '{{ item.addonVersions }}'
      publisher: '{{ item.publisher }}'
      owner: '{{ item.owner }}'
      marketplaceInformation: '{{ item.marketplaceInformation }}'
      defaultNamespace: '{{ item.defaultNamespace }}'
- discovery_id: aws.eks.describeClusterVersions
  calls:
  - action: describeClusterVersions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.clusterVersions }}'
    item:
      clusterVersion: '{{ item.clusterVersion }}'
      clusterType: '{{ item.clusterType }}'
      defaultPlatformVersion: '{{ item.defaultPlatformVersion }}'
      defaultVersion: '{{ item.defaultVersion }}'
      releaseDate: '{{ item.releaseDate }}'
      endOfStandardSupportDate: '{{ item.endOfStandardSupportDate }}'
      endOfExtendedSupportDate: '{{ item.endOfExtendedSupportDate }}'
      status: '{{ item.status }}'
      versionStatus: '{{ item.versionStatus }}'
      kubernetesPatchVersion: '{{ item.kubernetesPatchVersion }}'
- discovery_id: aws.eks.listAccessPolicies
  calls:
  - action: listAccessPolicies
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.accessPolicies }}'
    item:
      name: '{{ item.name }}'
      arn: '{{ item.arn }}'
- discovery_id: aws.eks.listClusters
  calls:
  - action: listClusters
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.clusters }}'
- discovery_id: aws.eks.listEksAnywhereSubscriptions
  calls:
  - action: listEksAnywhereSubscriptions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.subscriptions }}'
    item:
      id: '{{ item.id }}'
      arn: '{{ item.arn }}'
      createdAt: '{{ item.createdAt }}'
      effectiveDate: '{{ item.effectiveDate }}'
      expirationDate: '{{ item.expirationDate }}'
      licenseQuantity: '{{ item.licenseQuantity }}'
      licenseType: '{{ item.licenseType }}'
      term: '{{ item.term }}'
      status: '{{ item.status }}'
      autoRenew: '{{ item.autoRenew }}'
      licenseArns: '{{ item.licenseArns }}'
      licenses: '{{ item.licenses }}'
      tags: '{{ item.tags }}'
- discovery_id: aws.eks.describeAccessEntry
  calls:
  - action: describeAccessEntry
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.accessEntry }}'
    item:
      clusterName: '{{ item.clusterName }}'
      principalArn: '{{ item.principalArn }}'
      kubernetesGroups: '{{ item.kubernetesGroups }}'
      accessEntryArn: '{{ item.accessEntryArn }}'
      createdAt: '{{ item.createdAt }}'
      modifiedAt: '{{ item.modifiedAt }}'
      tags: '{{ item.tags }}'
      username: '{{ item.username }}'
      type: '{{ item.type }}'
- discovery_id: aws.eks.describeAddon
  calls:
  - action: describeAddon
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.addon }}'
    item:
      addonName: '{{ item.addonName }}'
      clusterName: '{{ item.clusterName }}'
      status: '{{ item.status }}'
      addonVersion: '{{ item.addonVersion }}'
      health: '{{ item.health }}'
      addonArn: '{{ item.addonArn }}'
      createdAt: '{{ item.createdAt }}'
      modifiedAt: '{{ item.modifiedAt }}'
      serviceAccountRoleArn: '{{ item.serviceAccountRoleArn }}'
      tags: '{{ item.tags }}'
      publisher: '{{ item.publisher }}'
      owner: '{{ item.owner }}'
      marketplaceInformation: '{{ item.marketplaceInformation }}'
      configurationValues: '{{ item.configurationValues }}'
      podIdentityAssociations: '{{ item.podIdentityAssociations }}'
      namespaceConfig: '{{ item.namespaceConfig }}'
- discovery_id: aws.eks.describeAddonConfiguration
  calls:
  - action: describeAddonConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.podIdentityConfiguration }}'
    item:
      serviceAccount: '{{ item.serviceAccount }}'
      recommendedManagedPolicies: '{{ item.recommendedManagedPolicies }}'
- discovery_id: aws.eks.describeCluster
  calls:
  - action: describeCluster
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.cluster }}'
    item:
      name: '{{ item.name }}'
      arn: '{{ item.arn }}'
      createdAt: '{{ item.createdAt }}'
      version: '{{ item.version }}'
      endpoint: '{{ item.endpoint }}'
      roleArn: '{{ item.roleArn }}'
      resourcesVpcConfig: '{{ item.resourcesVpcConfig }}'
      kubernetesNetworkConfig: '{{ item.kubernetesNetworkConfig }}'
      logging: '{{ item.logging }}'
      identity: '{{ item.identity }}'
      status: '{{ item.status }}'
      certificateAuthority: '{{ item.certificateAuthority }}'
      clientRequestToken: '{{ item.clientRequestToken }}'
      platformVersion: '{{ item.platformVersion }}'
      tags: '{{ item.tags }}'
      encryptionConfig: '{{ item.encryptionConfig }}'
      connectorConfig: '{{ item.connectorConfig }}'
      id: '{{ item.id }}'
      health: '{{ item.health }}'
      outpostConfig: '{{ item.outpostConfig }}'
      accessConfig: '{{ item.accessConfig }}'
      upgradePolicy: '{{ item.upgradePolicy }}'
      zonalShiftConfig: '{{ item.zonalShiftConfig }}'
      remoteNetworkConfig: '{{ item.remoteNetworkConfig }}'
      computeConfig: '{{ item.computeConfig }}'
      storageConfig: '{{ item.storageConfig }}'
      deletionProtection: '{{ item.deletionProtection }}'
      controlPlaneScalingConfig: '{{ item.controlPlaneScalingConfig }}'
- discovery_id: aws.eks.describeEksAnywhereSubscription
  calls:
  - action: describeEksAnywhereSubscription
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.subscription }}'
    item:
      id: '{{ item.id }}'
      arn: '{{ item.arn }}'
      createdAt: '{{ item.createdAt }}'
      effectiveDate: '{{ item.effectiveDate }}'
      expirationDate: '{{ item.expirationDate }}'
      licenseQuantity: '{{ item.licenseQuantity }}'
      licenseType: '{{ item.licenseType }}'
      term: '{{ item.term }}'
      status: '{{ item.status }}'
      autoRenew: '{{ item.autoRenew }}'
      licenseArns: '{{ item.licenseArns }}'
      licenses: '{{ item.licenses }}'
      tags: '{{ item.tags }}'
- discovery_id: aws.eks.describeFargateProfile
  calls:
  - action: describeFargateProfile
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.fargateProfile }}'
    item:
      fargateProfileName: '{{ item.fargateProfileName }}'
      fargateProfileArn: '{{ item.fargateProfileArn }}'
      clusterName: '{{ item.clusterName }}'
      createdAt: '{{ item.createdAt }}'
      podExecutionRoleArn: '{{ item.podExecutionRoleArn }}'
      subnets: '{{ item.subnets }}'
      selectors: '{{ item.selectors }}'
      status: '{{ item.status }}'
      tags: '{{ item.tags }}'
      health: '{{ item.health }}'
- discovery_id: aws.eks.describeIdentityProviderConfig
  calls:
  - action: describeIdentityProviderConfig
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.identityProviderConfig }}'
    item:
      oidc: '{{ item.oidc }}'
- discovery_id: aws.eks.describeInsight
  calls:
  - action: describeInsight
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.insight }}'
    item:
      id: '{{ item.id }}'
      name: '{{ item.name }}'
      category: '{{ item.category }}'
      kubernetesVersion: '{{ item.kubernetesVersion }}'
      lastRefreshTime: '{{ item.lastRefreshTime }}'
      lastTransitionTime: '{{ item.lastTransitionTime }}'
      description: '{{ item.description }}'
      insightStatus: '{{ item.insightStatus }}'
      recommendation: '{{ item.recommendation }}'
      additionalInfo: '{{ item.additionalInfo }}'
      resources: '{{ item.resources }}'
      categorySpecificSummary: '{{ item.categorySpecificSummary }}'
- discovery_id: aws.eks.describeInsightsRefresh
  calls:
  - action: describeInsightsRefresh
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.message }}'
- discovery_id: aws.eks.describeNodegroup
  calls:
  - action: describeNodegroup
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.nodegroup }}'
    item:
      nodegroupName: '{{ item.nodegroupName }}'
      nodegroupArn: '{{ item.nodegroupArn }}'
      clusterName: '{{ item.clusterName }}'
      version: '{{ item.version }}'
      releaseVersion: '{{ item.releaseVersion }}'
      createdAt: '{{ item.createdAt }}'
      modifiedAt: '{{ item.modifiedAt }}'
      status: '{{ item.status }}'
      capacityType: '{{ item.capacityType }}'
      scalingConfig: '{{ item.scalingConfig }}'
      instanceTypes: '{{ item.instanceTypes }}'
      subnets: '{{ item.subnets }}'
      remoteAccess: '{{ item.remoteAccess }}'
      amiType: '{{ item.amiType }}'
      nodeRole: '{{ item.nodeRole }}'
      labels: '{{ item.labels }}'
      taints: '{{ item.taints }}'
      resources: '{{ item.resources }}'
      diskSize: '{{ item.diskSize }}'
      health: '{{ item.health }}'
      updateConfig: '{{ item.updateConfig }}'
      nodeRepairConfig: '{{ item.nodeRepairConfig }}'
      launchTemplate: '{{ item.launchTemplate }}'
      tags: '{{ item.tags }}'
- discovery_id: aws.eks.describePodIdentityAssociation
  calls:
  - action: describePodIdentityAssociation
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.association }}'
    item:
      clusterName: '{{ item.clusterName }}'
      namespace: '{{ item.namespace }}'
      serviceAccount: '{{ item.serviceAccount }}'
      roleArn: '{{ item.roleArn }}'
      associationArn: '{{ item.associationArn }}'
      associationId: '{{ item.associationId }}'
      tags: '{{ item.tags }}'
      createdAt: '{{ item.createdAt }}'
      modifiedAt: '{{ item.modifiedAt }}'
      ownerArn: '{{ item.ownerArn }}'
      disableSessionTags: '{{ item.disableSessionTags }}'
      targetRoleArn: '{{ item.targetRoleArn }}'
      externalId: '{{ item.externalId }}'
- discovery_id: aws.eks.describeUpdate
  calls:
  - action: describeUpdate
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.update }}'
    item:
      id: '{{ item.id }}'
      status: '{{ item.status }}'
      type: '{{ item.type }}'
      params: '{{ item.params }}'
      createdAt: '{{ item.createdAt }}'
      errors: '{{ item.errors }}'
- discovery_id: aws.eks.listAccessEntries
  calls:
  - action: listAccessEntries
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.accessEntries }}'
- discovery_id: aws.eks.listAddons
  calls:
  - action: listAddons
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.addons }}'
- discovery_id: aws.eks.listAssociatedAccessPolicies
  calls:
  - action: listAssociatedAccessPolicies
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.associatedAccessPolicies }}'
    item:
      policyArn: '{{ item.policyArn }}'
      accessScope: '{{ item.accessScope }}'
      associatedAt: '{{ item.associatedAt }}'
      modifiedAt: '{{ item.modifiedAt }}'
- discovery_id: aws.eks.listFargateProfiles
  calls:
  - action: listFargateProfiles
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.fargateProfileNames }}'
- discovery_id: aws.eks.listIdentityProviderConfigs
  calls:
  - action: listIdentityProviderConfigs
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.identityProviderConfigs }}'
    item:
      type: '{{ item.type }}'
      name: '{{ item.name }}'
- discovery_id: aws.eks.listInsights
  calls:
  - action: listInsights
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.insights }}'
    item:
      id: '{{ item.id }}'
      name: '{{ item.name }}'
      category: '{{ item.category }}'
      kubernetesVersion: '{{ item.kubernetesVersion }}'
      lastRefreshTime: '{{ item.lastRefreshTime }}'
      lastTransitionTime: '{{ item.lastTransitionTime }}'
      description: '{{ item.description }}'
      insightStatus: '{{ item.insightStatus }}'
- discovery_id: aws.eks.listNodegroups
  calls:
  - action: listNodegroups
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.nodegroups }}'
- discovery_id: aws.eks.listPodIdentityAssociations
  calls:
  - action: listPodIdentityAssociations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.associations }}'
    item:
      clusterName: '{{ item.clusterName }}'
      namespace: '{{ item.namespace }}'
      serviceAccount: '{{ item.serviceAccount }}'
      associationArn: '{{ item.associationArn }}'
      associationId: '{{ item.associationId }}'
      ownerArn: '{{ item.ownerArn }}'
- discovery_id: aws.eks.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tags }}'
- discovery_id: aws.eks.listUpdates
  calls:
  - action: listUpdates
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.updateIds }}'
checks: []
