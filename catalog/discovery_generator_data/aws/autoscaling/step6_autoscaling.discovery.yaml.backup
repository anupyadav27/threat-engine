version: '1.0'
provider: aws
service: autoscaling
services:
  client: autoscaling
  module: boto3.client
discovery:
- discovery_id: aws.autoscaling.describeAccountLimits
  calls:
  - action: describeAccountLimits
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.MaxNumberOfAutoScalingGroups }}'
- discovery_id: aws.autoscaling.describeAdjustmentTypes
  calls:
  - action: describeAdjustmentTypes
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AdjustmentTypes }}'
    item:
      AdjustmentType: '{{ item.AdjustmentType }}'
- discovery_id: aws.autoscaling.describeAutoScalingGroups
  calls:
  - action: describeAutoScalingGroups
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AutoScalingGroups }}'
    item:
      AutoScalingGroupName: '{{ item.AutoScalingGroupName }}'
      AutoScalingGroupARN: '{{ item.AutoScalingGroupARN }}'
      LaunchConfigurationName: '{{ item.LaunchConfigurationName }}'
      LaunchTemplate: '{{ item.LaunchTemplate }}'
      MixedInstancesPolicy: '{{ item.MixedInstancesPolicy }}'
      MinSize: '{{ item.MinSize }}'
      MaxSize: '{{ item.MaxSize }}'
      DesiredCapacity: '{{ item.DesiredCapacity }}'
      PredictedCapacity: '{{ item.PredictedCapacity }}'
      DefaultCooldown: '{{ item.DefaultCooldown }}'
      AvailabilityZones: '{{ item.AvailabilityZones }}'
      LoadBalancerNames: '{{ item.LoadBalancerNames }}'
      TargetGroupARNs: '{{ item.TargetGroupARNs }}'
      HealthCheckType: '{{ item.HealthCheckType }}'
      HealthCheckGracePeriod: '{{ item.HealthCheckGracePeriod }}'
      Instances: '{{ item.Instances }}'
      CreatedTime: '{{ item.CreatedTime }}'
      SuspendedProcesses: '{{ item.SuspendedProcesses }}'
      PlacementGroup: '{{ item.PlacementGroup }}'
      VPCZoneIdentifier: '{{ item.VPCZoneIdentifier }}'
      EnabledMetrics: '{{ item.EnabledMetrics }}'
      Status: '{{ item.Status }}'
      Tags: '{{ item.Tags }}'
      TerminationPolicies: '{{ item.TerminationPolicies }}'
      NewInstancesProtectedFromScaleIn: '{{ item.NewInstancesProtectedFromScaleIn
        }}'
      ServiceLinkedRoleARN: '{{ item.ServiceLinkedRoleARN }}'
      MaxInstanceLifetime: '{{ item.MaxInstanceLifetime }}'
      CapacityRebalance: '{{ item.CapacityRebalance }}'
      WarmPoolConfiguration: '{{ item.WarmPoolConfiguration }}'
      WarmPoolSize: '{{ item.WarmPoolSize }}'
      Context: '{{ item.Context }}'
      DesiredCapacityType: '{{ item.DesiredCapacityType }}'
      DefaultInstanceWarmup: '{{ item.DefaultInstanceWarmup }}'
      TrafficSources: '{{ item.TrafficSources }}'
      InstanceMaintenancePolicy: '{{ item.InstanceMaintenancePolicy }}'
      AvailabilityZoneDistribution: '{{ item.AvailabilityZoneDistribution }}'
      AvailabilityZoneImpairmentPolicy: '{{ item.AvailabilityZoneImpairmentPolicy
        }}'
      CapacityReservationSpecification: '{{ item.CapacityReservationSpecification
        }}'
      InstanceLifecyclePolicy: '{{ item.InstanceLifecyclePolicy }}'
- discovery_id: aws.autoscaling.describeAutoScalingInstances
  calls:
  - action: describeAutoScalingInstances
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AutoScalingInstances }}'
    item:
      InstanceId: '{{ item.InstanceId }}'
      InstanceType: '{{ item.InstanceType }}'
      AutoScalingGroupName: '{{ item.AutoScalingGroupName }}'
      AvailabilityZone: '{{ item.AvailabilityZone }}'
      LifecycleState: '{{ item.LifecycleState }}'
      HealthStatus: '{{ item.HealthStatus }}'
      LaunchConfigurationName: '{{ item.LaunchConfigurationName }}'
      LaunchTemplate: '{{ item.LaunchTemplate }}'
      ImageId: '{{ item.ImageId }}'
      ProtectedFromScaleIn: '{{ item.ProtectedFromScaleIn }}'
      WeightedCapacity: '{{ item.WeightedCapacity }}'
- discovery_id: aws.autoscaling.describeAutoScalingNotificationTypes
  calls:
  - action: describeAutoScalingNotificationTypes
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AutoScalingNotificationTypes }}'
- discovery_id: aws.autoscaling.describeLaunchConfigurations
  calls:
  - action: describeLaunchConfigurations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.LaunchConfigurations }}'
    item:
      LaunchConfigurationName: '{{ item.LaunchConfigurationName }}'
      LaunchConfigurationARN: '{{ item.LaunchConfigurationARN }}'
      ImageId: '{{ item.ImageId }}'
      KeyName: '{{ item.KeyName }}'
      SecurityGroups: '{{ item.SecurityGroups }}'
      ClassicLinkVPCId: '{{ item.ClassicLinkVPCId }}'
      ClassicLinkVPCSecurityGroups: '{{ item.ClassicLinkVPCSecurityGroups }}'
      UserData: '{{ item.UserData }}'
      InstanceType: '{{ item.InstanceType }}'
      KernelId: '{{ item.KernelId }}'
      RamdiskId: '{{ item.RamdiskId }}'
      BlockDeviceMappings: '{{ item.BlockDeviceMappings }}'
      InstanceMonitoring: '{{ item.InstanceMonitoring }}'
      SpotPrice: '{{ item.SpotPrice }}'
      IamInstanceProfile: '{{ item.IamInstanceProfile }}'
      CreatedTime: '{{ item.CreatedTime }}'
      EbsOptimized: '{{ item.EbsOptimized }}'
      AssociatePublicIpAddress: '{{ item.AssociatePublicIpAddress }}'
      PlacementTenancy: '{{ item.PlacementTenancy }}'
      MetadataOptions: '{{ item.MetadataOptions }}'
- discovery_id: aws.autoscaling.describeLifecycleHookTypes
  calls:
  - action: describeLifecycleHookTypes
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.LifecycleHookTypes }}'
- discovery_id: aws.autoscaling.describeMetricCollectionTypes
  calls:
  - action: describeMetricCollectionTypes
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Metrics }}'
    item:
      Metric: '{{ item.Metric }}'
- discovery_id: aws.autoscaling.describeNotificationConfigurations
  calls:
  - action: describeNotificationConfigurations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.NotificationConfigurations }}'
    item:
      AutoScalingGroupName: '{{ item.AutoScalingGroupName }}'
      TopicARN: '{{ item.TopicARN }}'
      NotificationType: '{{ item.NotificationType }}'
- discovery_id: aws.autoscaling.describePolicies
  calls:
  - action: describePolicies
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ScalingPolicies }}'
    item:
      AutoScalingGroupName: '{{ item.AutoScalingGroupName }}'
      PolicyName: '{{ item.PolicyName }}'
      PolicyARN: '{{ item.PolicyARN }}'
      PolicyType: '{{ item.PolicyType }}'
      AdjustmentType: '{{ item.AdjustmentType }}'
      MinAdjustmentStep: '{{ item.MinAdjustmentStep }}'
      MinAdjustmentMagnitude: '{{ item.MinAdjustmentMagnitude }}'
      ScalingAdjustment: '{{ item.ScalingAdjustment }}'
      Cooldown: '{{ item.Cooldown }}'
      StepAdjustments: '{{ item.StepAdjustments }}'
      MetricAggregationType: '{{ item.MetricAggregationType }}'
      EstimatedInstanceWarmup: '{{ item.EstimatedInstanceWarmup }}'
      Alarms: '{{ item.Alarms }}'
      TargetTrackingConfiguration: '{{ item.TargetTrackingConfiguration }}'
      Enabled: '{{ item.Enabled }}'
      PredictiveScalingConfiguration: '{{ item.PredictiveScalingConfiguration }}'
- discovery_id: aws.autoscaling.describeScalingActivities
  calls:
  - action: describeScalingActivities
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Activities }}'
    item:
      ActivityId: '{{ item.ActivityId }}'
      AutoScalingGroupName: '{{ item.AutoScalingGroupName }}'
      Description: '{{ item.Description }}'
      Cause: '{{ item.Cause }}'
      StartTime: '{{ item.StartTime }}'
      EndTime: '{{ item.EndTime }}'
      StatusCode: '{{ item.StatusCode }}'
      StatusMessage: '{{ item.StatusMessage }}'
      Progress: '{{ item.Progress }}'
      Details: '{{ item.Details }}'
      AutoScalingGroupState: '{{ item.AutoScalingGroupState }}'
      AutoScalingGroupARN: '{{ item.AutoScalingGroupARN }}'
- discovery_id: aws.autoscaling.describeScalingProcessTypes
  calls:
  - action: describeScalingProcessTypes
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Processes }}'
    item:
      ProcessName: '{{ item.ProcessName }}'
- discovery_id: aws.autoscaling.describeScheduledActions
  calls:
  - action: describeScheduledActions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ScheduledUpdateGroupActions }}'
    item:
      AutoScalingGroupName: '{{ item.AutoScalingGroupName }}'
      ScheduledActionName: '{{ item.ScheduledActionName }}'
      ScheduledActionARN: '{{ item.ScheduledActionARN }}'
      Time: '{{ item.Time }}'
      StartTime: '{{ item.StartTime }}'
      EndTime: '{{ item.EndTime }}'
      Recurrence: '{{ item.Recurrence }}'
      MinSize: '{{ item.MinSize }}'
      MaxSize: '{{ item.MaxSize }}'
      DesiredCapacity: '{{ item.DesiredCapacity }}'
      TimeZone: '{{ item.TimeZone }}'
- discovery_id: aws.autoscaling.describeTags
  calls:
  - action: describeTags
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Tags }}'
    item:
      ResourceId: '{{ item.ResourceId }}'
      ResourceType: '{{ item.ResourceType }}'
      Key: '{{ item.Key }}'
      Value: '{{ item.Value }}'
      PropagateAtLaunch: '{{ item.PropagateAtLaunch }}'
- discovery_id: aws.autoscaling.describeTerminationPolicyTypes
  calls:
  - action: describeTerminationPolicyTypes
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.TerminationPolicyTypes }}'
- discovery_id: aws.autoscaling.describeInstanceRefreshes
  calls:
  - action: describeInstanceRefreshes
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.InstanceRefreshes }}'
    item:
      InstanceRefreshId: '{{ item.InstanceRefreshId }}'
      AutoScalingGroupName: '{{ item.AutoScalingGroupName }}'
      Status: '{{ item.Status }}'
      StatusReason: '{{ item.StatusReason }}'
      StartTime: '{{ item.StartTime }}'
      EndTime: '{{ item.EndTime }}'
      PercentageComplete: '{{ item.PercentageComplete }}'
      InstancesToUpdate: '{{ item.InstancesToUpdate }}'
      ProgressDetails: '{{ item.ProgressDetails }}'
      Preferences: '{{ item.Preferences }}'
      DesiredConfiguration: '{{ item.DesiredConfiguration }}'
      RollbackDetails: '{{ item.RollbackDetails }}'
      Strategy: '{{ item.Strategy }}'
- discovery_id: aws.autoscaling.describeLifecycleHooks
  calls:
  - action: describeLifecycleHooks
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.LifecycleHooks }}'
    item:
      LifecycleHookName: '{{ item.LifecycleHookName }}'
      AutoScalingGroupName: '{{ item.AutoScalingGroupName }}'
      LifecycleTransition: '{{ item.LifecycleTransition }}'
      NotificationTargetARN: '{{ item.NotificationTargetARN }}'
      RoleARN: '{{ item.RoleARN }}'
      NotificationMetadata: '{{ item.NotificationMetadata }}'
      HeartbeatTimeout: '{{ item.HeartbeatTimeout }}'
      GlobalTimeout: '{{ item.GlobalTimeout }}'
      DefaultResult: '{{ item.DefaultResult }}'
- discovery_id: aws.autoscaling.describeLoadBalancerTargetGroups
  calls:
  - action: describeLoadBalancerTargetGroups
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.LoadBalancerTargetGroups }}'
    item:
      LoadBalancerTargetGroupARN: '{{ item.LoadBalancerTargetGroupARN }}'
      State: '{{ item.State }}'
- discovery_id: aws.autoscaling.describeLoadBalancers
  calls:
  - action: describeLoadBalancers
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.LoadBalancers }}'
    item:
      LoadBalancerName: '{{ item.LoadBalancerName }}'
      State: '{{ item.State }}'
- discovery_id: aws.autoscaling.describeTrafficSources
  calls:
  - action: describeTrafficSources
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.TrafficSources }}'
    item:
      TrafficSource: '{{ item.TrafficSource }}'
      State: '{{ item.State }}'
      Identifier: '{{ item.Identifier }}'
      Type: '{{ item.Type }}'
- discovery_id: aws.autoscaling.describeWarmPool
  calls:
  - action: describeWarmPool
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Instances }}'
    item:
      InstanceId: '{{ item.InstanceId }}'
      InstanceType: '{{ item.InstanceType }}'
      AvailabilityZone: '{{ item.AvailabilityZone }}'
      LifecycleState: '{{ item.LifecycleState }}'
      HealthStatus: '{{ item.HealthStatus }}'
      LaunchConfigurationName: '{{ item.LaunchConfigurationName }}'
      LaunchTemplate: '{{ item.LaunchTemplate }}'
      ImageId: '{{ item.ImageId }}'
      ProtectedFromScaleIn: '{{ item.ProtectedFromScaleIn }}'
      WeightedCapacity: '{{ item.WeightedCapacity }}'
- discovery_id: aws.autoscaling.getPredictiveScalingForecast
  calls:
  - action: getPredictiveScalingForecast
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.LoadForecast }}'
    item:
      Timestamps: '{{ item.Timestamps }}'
      Values: '{{ item.Values }}'
      MetricSpecification: '{{ item.MetricSpecification }}'
checks: []
