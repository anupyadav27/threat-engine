version: '1.0'
provider: aws
service: directoryservice
services:
  client: directoryservice
  module: boto3.client
discovery:
- discovery_id: aws.directoryservice.describeDirectories
  calls:
  - action: describeDirectories
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.DirectoryDescriptions }}'
    item:
      DirectoryId: '{{ item.DirectoryId }}'
      Name: '{{ item.Name }}'
      ShortName: '{{ item.ShortName }}'
      Size: '{{ item.Size }}'
      Edition: '{{ item.Edition }}'
      Alias: '{{ item.Alias }}'
      AccessUrl: '{{ item.AccessUrl }}'
      Description: '{{ item.Description }}'
      DnsIpAddrs: '{{ item.DnsIpAddrs }}'
      DnsIpv6Addrs: '{{ item.DnsIpv6Addrs }}'
      Stage: '{{ item.Stage }}'
      ShareStatus: '{{ item.ShareStatus }}'
      ShareMethod: '{{ item.ShareMethod }}'
      ShareNotes: '{{ item.ShareNotes }}'
      LaunchTime: '{{ item.LaunchTime }}'
      StageLastUpdatedDateTime: '{{ item.StageLastUpdatedDateTime }}'
      Type: '{{ item.Type }}'
      VpcSettings: '{{ item.VpcSettings }}'
      ConnectSettings: '{{ item.ConnectSettings }}'
      RadiusSettings: '{{ item.RadiusSettings }}'
      RadiusStatus: '{{ item.RadiusStatus }}'
      StageReason: '{{ item.StageReason }}'
      SsoEnabled: '{{ item.SsoEnabled }}'
      DesiredNumberOfDomainControllers: '{{ item.DesiredNumberOfDomainControllers
        }}'
      OwnerDirectoryDescription: '{{ item.OwnerDirectoryDescription }}'
      RegionsInfo: '{{ item.RegionsInfo }}'
      OsVersion: '{{ item.OsVersion }}'
      HybridSettings: '{{ item.HybridSettings }}'
      NetworkType: '{{ item.NetworkType }}'
- discovery_id: aws.directoryservice.describeEventTopics
  calls:
  - action: describeEventTopics
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.EventTopics }}'
    item:
      DirectoryId: '{{ item.DirectoryId }}'
      TopicName: '{{ item.TopicName }}'
      TopicArn: '{{ item.TopicArn }}'
      CreatedDateTime: '{{ item.CreatedDateTime }}'
      Status: '{{ item.Status }}'
- discovery_id: aws.directoryservice.describeSnapshots
  calls:
  - action: describeSnapshots
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Snapshots }}'
    item:
      DirectoryId: '{{ item.DirectoryId }}'
      SnapshotId: '{{ item.SnapshotId }}'
      Type: '{{ item.Type }}'
      Name: '{{ item.Name }}'
      Status: '{{ item.Status }}'
      StartTime: '{{ item.StartTime }}'
- discovery_id: aws.directoryservice.describeTrusts
  calls:
  - action: describeTrusts
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Trusts }}'
    item:
      DirectoryId: '{{ item.DirectoryId }}'
      TrustId: '{{ item.TrustId }}'
      RemoteDomainName: '{{ item.RemoteDomainName }}'
      TrustType: '{{ item.TrustType }}'
      TrustDirection: '{{ item.TrustDirection }}'
      TrustState: '{{ item.TrustState }}'
      CreatedDateTime: '{{ item.CreatedDateTime }}'
      LastUpdatedDateTime: '{{ item.LastUpdatedDateTime }}'
      StateLastUpdatedDateTime: '{{ item.StateLastUpdatedDateTime }}'
      TrustStateReason: '{{ item.TrustStateReason }}'
      SelectiveAuth: '{{ item.SelectiveAuth }}'
- discovery_id: aws.directoryservice.getDirectoryLimits
  calls:
  - action: getDirectoryLimits
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.DirectoryLimits }}'
    item:
      CloudOnlyDirectoriesLimit: '{{ item.CloudOnlyDirectoriesLimit }}'
      CloudOnlyDirectoriesCurrentCount: '{{ item.CloudOnlyDirectoriesCurrentCount
        }}'
      CloudOnlyDirectoriesLimitReached: '{{ item.CloudOnlyDirectoriesLimitReached
        }}'
      CloudOnlyMicrosoftADLimit: '{{ item.CloudOnlyMicrosoftADLimit }}'
      CloudOnlyMicrosoftADCurrentCount: '{{ item.CloudOnlyMicrosoftADCurrentCount
        }}'
      CloudOnlyMicrosoftADLimitReached: '{{ item.CloudOnlyMicrosoftADLimitReached
        }}'
      ConnectedDirectoriesLimit: '{{ item.ConnectedDirectoriesLimit }}'
      ConnectedDirectoriesCurrentCount: '{{ item.ConnectedDirectoriesCurrentCount
        }}'
      ConnectedDirectoriesLimitReached: '{{ item.ConnectedDirectoriesLimitReached
        }}'
- discovery_id: aws.directoryservice.listAdAssessments
  calls:
  - action: listAdAssessments
    save_as: response
    on_error: continue
    params:
      Limit: 1000
  emit:
    as: item
    items_for: '{{ response.Assessments }}'
    item:
      AssessmentId: '{{ item.AssessmentId }}'
      DirectoryId: '{{ item.DirectoryId }}'
      DnsName: '{{ item.DnsName }}'
      StartTime: '{{ item.StartTime }}'
      LastUpdateDateTime: '{{ item.LastUpdateDateTime }}'
      Status: '{{ item.Status }}'
      CustomerDnsIps: '{{ item.CustomerDnsIps }}'
      ReportType: '{{ item.ReportType }}'
- discovery_id: aws.directoryservice.listLogSubscriptions
  calls:
  - action: listLogSubscriptions
    save_as: response
    on_error: continue
    params:
      Limit: 1000
  emit:
    as: item
    items_for: '{{ response.LogSubscriptions }}'
    item:
      DirectoryId: '{{ item.DirectoryId }}'
      LogGroupName: '{{ item.LogGroupName }}'
      SubscriptionCreatedDateTime: '{{ item.SubscriptionCreatedDateTime }}'
- discovery_id: aws.directoryservice.describeAdAssessment
  calls:
  - action: describeAdAssessment
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AssessmentReports }}'
    item:
      DomainControllerIp: '{{ item.DomainControllerIp }}'
      Validations: '{{ item.Validations }}'
- discovery_id: aws.directoryservice.describeCaEnrollmentPolicy
  calls:
  - action: describeCaEnrollmentPolicy
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.DirectoryId }}'
- discovery_id: aws.directoryservice.describeCertificate
  calls:
  - action: describeCertificate
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Certificate }}'
    item:
      CertificateId: '{{ item.CertificateId }}'
      State: '{{ item.State }}'
      StateReason: '{{ item.StateReason }}'
      CommonName: '{{ item.CommonName }}'
      RegisteredDateTime: '{{ item.RegisteredDateTime }}'
      ExpiryDateTime: '{{ item.ExpiryDateTime }}'
      Type: '{{ item.Type }}'
      ClientCertAuthSettings: '{{ item.ClientCertAuthSettings }}'
- discovery_id: aws.directoryservice.describeClientAuthenticationSettings
  calls:
  - action: describeClientAuthenticationSettings
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ClientAuthenticationSettingsInfo }}'
    item:
      Type: '{{ item.Type }}'
      Status: '{{ item.Status }}'
      LastUpdatedDateTime: '{{ item.LastUpdatedDateTime }}'
- discovery_id: aws.directoryservice.describeConditionalForwarders
  calls:
  - action: describeConditionalForwarders
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ConditionalForwarders }}'
    item:
      RemoteDomainName: '{{ item.RemoteDomainName }}'
      DnsIpAddrs: '{{ item.DnsIpAddrs }}'
      DnsIpv6Addrs: '{{ item.DnsIpv6Addrs }}'
      ReplicationScope: '{{ item.ReplicationScope }}'
- discovery_id: aws.directoryservice.describeDirectoryDataAccess
  calls:
  - action: describeDirectoryDataAccess
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.DataAccessStatus }}'
- discovery_id: aws.directoryservice.describeDomainControllers
  calls:
  - action: describeDomainControllers
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.DomainControllers }}'
    item:
      DirectoryId: '{{ item.DirectoryId }}'
      DomainControllerId: '{{ item.DomainControllerId }}'
      DnsIpAddr: '{{ item.DnsIpAddr }}'
      DnsIpv6Addr: '{{ item.DnsIpv6Addr }}'
      VpcId: '{{ item.VpcId }}'
      SubnetId: '{{ item.SubnetId }}'
      AvailabilityZone: '{{ item.AvailabilityZone }}'
      Status: '{{ item.Status }}'
      StatusReason: '{{ item.StatusReason }}'
      LaunchTime: '{{ item.LaunchTime }}'
      StatusLastUpdatedDateTime: '{{ item.StatusLastUpdatedDateTime }}'
- discovery_id: aws.directoryservice.describeHybridAdUpdate
  calls:
  - action: describeHybridAdUpdate
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.UpdateActivities }}'
    item:
      SelfManagedInstances: '{{ item.SelfManagedInstances }}'
      HybridAdministratorAccount: '{{ item.HybridAdministratorAccount }}'
- discovery_id: aws.directoryservice.describeLdapsSettings
  calls:
  - action: describeLdapsSettings
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.LDAPSSettingsInfo }}'
    item:
      LDAPSStatus: '{{ item.LDAPSStatus }}'
      LDAPSStatusReason: '{{ item.LDAPSStatusReason }}'
      LastUpdatedDateTime: '{{ item.LastUpdatedDateTime }}'
- discovery_id: aws.directoryservice.describeRegions
  calls:
  - action: describeRegions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.RegionsDescription }}'
    item:
      DirectoryId: '{{ item.DirectoryId }}'
      RegionName: '{{ item.RegionName }}'
      RegionType: '{{ item.RegionType }}'
      Status: '{{ item.Status }}'
      VpcSettings: '{{ item.VpcSettings }}'
      DesiredNumberOfDomainControllers: '{{ item.DesiredNumberOfDomainControllers
        }}'
      LaunchTime: '{{ item.LaunchTime }}'
      StatusLastUpdatedDateTime: '{{ item.StatusLastUpdatedDateTime }}'
      LastUpdatedDateTime: '{{ item.LastUpdatedDateTime }}'
- discovery_id: aws.directoryservice.describeSettings
  calls:
  - action: describeSettings
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.SettingEntries }}'
    item:
      Type: '{{ item.Type }}'
      Name: '{{ item.Name }}'
      AllowedValues: '{{ item.AllowedValues }}'
      AppliedValue: '{{ item.AppliedValue }}'
      RequestedValue: '{{ item.RequestedValue }}'
      RequestStatus: '{{ item.RequestStatus }}'
      RequestDetailedStatus: '{{ item.RequestDetailedStatus }}'
      RequestStatusMessage: '{{ item.RequestStatusMessage }}'
      LastUpdatedDateTime: '{{ item.LastUpdatedDateTime }}'
      LastRequestedDateTime: '{{ item.LastRequestedDateTime }}'
      DataType: '{{ item.DataType }}'
- discovery_id: aws.directoryservice.describeSharedDirectories
  calls:
  - action: describeSharedDirectories
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.SharedDirectories }}'
    item:
      OwnerAccountId: '{{ item.OwnerAccountId }}'
      OwnerDirectoryId: '{{ item.OwnerDirectoryId }}'
      ShareMethod: '{{ item.ShareMethod }}'
      SharedAccountId: '{{ item.SharedAccountId }}'
      SharedDirectoryId: '{{ item.SharedDirectoryId }}'
      ShareStatus: '{{ item.ShareStatus }}'
      ShareNotes: '{{ item.ShareNotes }}'
      CreatedDateTime: '{{ item.CreatedDateTime }}'
      LastUpdatedDateTime: '{{ item.LastUpdatedDateTime }}'
- discovery_id: aws.directoryservice.describeUpdateDirectory
  calls:
  - action: describeUpdateDirectory
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.UpdateActivities }}'
    item:
      Region: '{{ item.Region }}'
      Status: '{{ item.Status }}'
      StatusReason: '{{ item.StatusReason }}'
      InitiatedBy: '{{ item.InitiatedBy }}'
      NewValue: '{{ item.NewValue }}'
      PreviousValue: '{{ item.PreviousValue }}'
      StartTime: '{{ item.StartTime }}'
      LastUpdatedDateTime: '{{ item.LastUpdatedDateTime }}'
- discovery_id: aws.directoryservice.getSnapshotLimits
  calls:
  - action: getSnapshotLimits
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.SnapshotLimits }}'
    item:
      ManualSnapshotsLimit: '{{ item.ManualSnapshotsLimit }}'
      ManualSnapshotsCurrentCount: '{{ item.ManualSnapshotsCurrentCount }}'
      ManualSnapshotsLimitReached: '{{ item.ManualSnapshotsLimitReached }}'
- discovery_id: aws.directoryservice.listCertificates
  calls:
  - action: listCertificates
    save_as: response
    on_error: continue
    params:
      Limit: 1000
  emit:
    as: item
    items_for: '{{ response.CertificatesInfo }}'
    item:
      CertificateId: '{{ item.CertificateId }}'
      CommonName: '{{ item.CommonName }}'
      State: '{{ item.State }}'
      ExpiryDateTime: '{{ item.ExpiryDateTime }}'
      Type: '{{ item.Type }}'
- discovery_id: aws.directoryservice.listIpRoutes
  calls:
  - action: listIpRoutes
    save_as: response
    on_error: continue
    params:
      Limit: 1000
  emit:
    as: item
    items_for: '{{ response.IpRoutesInfo }}'
    item:
      DirectoryId: '{{ item.DirectoryId }}'
      CidrIp: '{{ item.CidrIp }}'
      CidrIpv6: '{{ item.CidrIpv6 }}'
      IpRouteStatusMsg: '{{ item.IpRouteStatusMsg }}'
      AddedDateTime: '{{ item.AddedDateTime }}'
      IpRouteStatusReason: '{{ item.IpRouteStatusReason }}'
      Description: '{{ item.Description }}'
- discovery_id: aws.directoryservice.listSchemaExtensions
  calls:
  - action: listSchemaExtensions
    save_as: response
    on_error: continue
    params:
      Limit: 1000
  emit:
    as: item
    items_for: '{{ response.SchemaExtensionsInfo }}'
    item:
      DirectoryId: '{{ item.DirectoryId }}'
      SchemaExtensionId: '{{ item.SchemaExtensionId }}'
      Description: '{{ item.Description }}'
      SchemaExtensionStatus: '{{ item.SchemaExtensionStatus }}'
      SchemaExtensionStatusReason: '{{ item.SchemaExtensionStatusReason }}'
      StartDateTime: '{{ item.StartDateTime }}'
      EndDateTime: '{{ item.EndDateTime }}'
- discovery_id: aws.directoryservice.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
    params:
      Limit: 1000
  emit:
    as: item
    items_for: '{{ response.Tags }}'
    item:
      Key: '{{ item.Key }}'
      Value: '{{ item.Value }}'
checks: []
