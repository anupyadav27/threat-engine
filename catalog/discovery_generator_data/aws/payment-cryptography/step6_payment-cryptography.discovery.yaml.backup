version: '1.0'
provider: aws
service: payment-cryptography
services:
  client: payment-cryptography
  module: boto3.client
discovery:
- discovery_id: aws.payment-cryptography.getDefaultKeyReplicationRegions
  calls:
  - action: getDefaultKeyReplicationRegions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.EnabledReplicationRegions }}'
- discovery_id: aws.payment-cryptography.listAliases
  calls:
  - action: listAliases
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Aliases }}'
    item:
      AliasName: '{{ item.AliasName }}'
      KeyArn: '{{ item.KeyArn }}'
- discovery_id: aws.payment-cryptography.listKeys
  calls:
  - action: listKeys
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Keys }}'
    item:
      KeyArn: '{{ item.KeyArn }}'
      KeyState: '{{ item.KeyState }}'
      KeyAttributes: '{{ item.KeyAttributes }}'
      KeyCheckValue: '{{ item.KeyCheckValue }}'
      Exportable: '{{ item.Exportable }}'
      Enabled: '{{ item.Enabled }}'
      MultiRegionKeyType: '{{ item.MultiRegionKeyType }}'
      PrimaryRegion: '{{ item.PrimaryRegion }}'
- discovery_id: aws.payment-cryptography.getAlias
  calls:
  - action: getAlias
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Alias }}'
    item:
      AliasName: '{{ item.AliasName }}'
      KeyArn: '{{ item.KeyArn }}'
- discovery_id: aws.payment-cryptography.getCertificateSigningRequest
  calls:
  - action: getCertificateSigningRequest
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.CertificateSigningRequest }}'
- discovery_id: aws.payment-cryptography.getKey
  calls:
  - action: getKey
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Key }}'
    item:
      KeyArn: '{{ item.KeyArn }}'
      KeyAttributes: '{{ item.KeyAttributes }}'
      KeyCheckValue: '{{ item.KeyCheckValue }}'
      KeyCheckValueAlgorithm: '{{ item.KeyCheckValueAlgorithm }}'
      Enabled: '{{ item.Enabled }}'
      Exportable: '{{ item.Exportable }}'
      KeyState: '{{ item.KeyState }}'
      KeyOrigin: '{{ item.KeyOrigin }}'
      CreateTimestamp: '{{ item.CreateTimestamp }}'
      UsageStartTimestamp: '{{ item.UsageStartTimestamp }}'
      UsageStopTimestamp: '{{ item.UsageStopTimestamp }}'
      DeletePendingTimestamp: '{{ item.DeletePendingTimestamp }}'
      DeleteTimestamp: '{{ item.DeleteTimestamp }}'
      DeriveKeyUsage: '{{ item.DeriveKeyUsage }}'
      MultiRegionKeyType: '{{ item.MultiRegionKeyType }}'
      PrimaryRegion: '{{ item.PrimaryRegion }}'
      ReplicationStatus: '{{ item.ReplicationStatus }}'
      UsingDefaultReplicationRegions: '{{ item.UsingDefaultReplicationRegions }}'
- discovery_id: aws.payment-cryptography.getParametersForExport
  calls:
  - action: getParametersForExport
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.SigningKeyCertificate }}'
- discovery_id: aws.payment-cryptography.getParametersForImport
  calls:
  - action: getParametersForImport
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.WrappingKeyCertificate }}'
- discovery_id: aws.payment-cryptography.getPublicKeyCertificate
  calls:
  - action: getPublicKeyCertificate
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.KeyCertificate }}'
- discovery_id: aws.payment-cryptography.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Tags }}'
    item:
      Key: '{{ item.Key }}'
      Value: '{{ item.Value }}'
checks: []
