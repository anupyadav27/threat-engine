version: '1.0'
provider: aws
service: gamelift
services:
  client: gamelift
  module: boto3.client
discovery:
- discovery_id: aws.gamelift.describeEc2InstanceLimits
  calls:
  - action: describeEc2InstanceLimits
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.EC2InstanceLimits }}'
    item:
      EC2InstanceType: '{{ item.EC2InstanceType }}'
      CurrentInstances: '{{ item.CurrentInstances }}'
      InstanceLimit: '{{ item.InstanceLimit }}'
      Location: '{{ item.Location }}'
- discovery_id: aws.gamelift.describeFleetAttributes
  calls:
  - action: describeFleetAttributes
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.FleetAttributes }}'
    item:
      FleetId: '{{ item.FleetId }}'
      FleetArn: '{{ item.FleetArn }}'
      FleetType: '{{ item.FleetType }}'
      InstanceType: '{{ item.InstanceType }}'
      Description: '{{ item.Description }}'
      Name: '{{ item.Name }}'
      CreationTime: '{{ item.CreationTime }}'
      TerminationTime: '{{ item.TerminationTime }}'
      Status: '{{ item.Status }}'
      BuildId: '{{ item.BuildId }}'
      BuildArn: '{{ item.BuildArn }}'
      ScriptId: '{{ item.ScriptId }}'
      ScriptArn: '{{ item.ScriptArn }}'
      ServerLaunchPath: '{{ item.ServerLaunchPath }}'
      ServerLaunchParameters: '{{ item.ServerLaunchParameters }}'
      LogPaths: '{{ item.LogPaths }}'
      NewGameSessionProtectionPolicy: '{{ item.NewGameSessionProtectionPolicy }}'
      OperatingSystem: '{{ item.OperatingSystem }}'
      ResourceCreationLimitPolicy: '{{ item.ResourceCreationLimitPolicy }}'
      MetricGroups: '{{ item.MetricGroups }}'
      StoppedActions: '{{ item.StoppedActions }}'
      InstanceRoleArn: '{{ item.InstanceRoleArn }}'
      CertificateConfiguration: '{{ item.CertificateConfiguration }}'
      ComputeType: '{{ item.ComputeType }}'
      AnywhereConfiguration: '{{ item.AnywhereConfiguration }}'
      InstanceRoleCredentialsProvider: '{{ item.InstanceRoleCredentialsProvider }}'
- discovery_id: aws.gamelift.describeFleetCapacity
  calls:
  - action: describeFleetCapacity
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.FleetCapacity }}'
    item:
      FleetId: '{{ item.FleetId }}'
      FleetArn: '{{ item.FleetArn }}'
      InstanceType: '{{ item.InstanceType }}'
      InstanceCounts: '{{ item.InstanceCounts }}'
      Location: '{{ item.Location }}'
      GameServerContainerGroupCounts: '{{ item.GameServerContainerGroupCounts }}'
- discovery_id: aws.gamelift.describeFleetUtilization
  calls:
  - action: describeFleetUtilization
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.FleetUtilization }}'
    item:
      FleetId: '{{ item.FleetId }}'
      FleetArn: '{{ item.FleetArn }}'
      ActiveServerProcessCount: '{{ item.ActiveServerProcessCount }}'
      ActiveGameSessionCount: '{{ item.ActiveGameSessionCount }}'
      CurrentPlayerSessionCount: '{{ item.CurrentPlayerSessionCount }}'
      MaximumPlayerSessionCount: '{{ item.MaximumPlayerSessionCount }}'
      Location: '{{ item.Location }}'
- discovery_id: aws.gamelift.describeGameSessionDetails
  calls:
  - action: describeGameSessionDetails
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.GameSessionDetails }}'
    item:
      GameSession: '{{ item.GameSession }}'
      ProtectionPolicy: '{{ item.ProtectionPolicy }}'
- discovery_id: aws.gamelift.describeGameSessionQueues
  calls:
  - action: describeGameSessionQueues
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.GameSessionQueues }}'
    item:
      Name: '{{ item.Name }}'
      GameSessionQueueArn: '{{ item.GameSessionQueueArn }}'
      TimeoutInSeconds: '{{ item.TimeoutInSeconds }}'
      PlayerLatencyPolicies: '{{ item.PlayerLatencyPolicies }}'
      Destinations: '{{ item.Destinations }}'
      FilterConfiguration: '{{ item.FilterConfiguration }}'
      PriorityConfiguration: '{{ item.PriorityConfiguration }}'
      CustomEventData: '{{ item.CustomEventData }}'
      NotificationTarget: '{{ item.NotificationTarget }}'
- discovery_id: aws.gamelift.describeGameSessions
  calls:
  - action: describeGameSessions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.GameSessions }}'
    item:
      GameSessionId: '{{ item.GameSessionId }}'
      Name: '{{ item.Name }}'
      FleetId: '{{ item.FleetId }}'
      FleetArn: '{{ item.FleetArn }}'
      CreationTime: '{{ item.CreationTime }}'
      TerminationTime: '{{ item.TerminationTime }}'
      CurrentPlayerSessionCount: '{{ item.CurrentPlayerSessionCount }}'
      MaximumPlayerSessionCount: '{{ item.MaximumPlayerSessionCount }}'
      Status: '{{ item.Status }}'
      StatusReason: '{{ item.StatusReason }}'
      GameProperties: '{{ item.GameProperties }}'
      IpAddress: '{{ item.IpAddress }}'
      DnsName: '{{ item.DnsName }}'
      Port: '{{ item.Port }}'
      PlayerSessionCreationPolicy: '{{ item.PlayerSessionCreationPolicy }}'
      CreatorId: '{{ item.CreatorId }}'
      GameSessionData: '{{ item.GameSessionData }}'
      MatchmakerData: '{{ item.MatchmakerData }}'
      Location: '{{ item.Location }}'
- discovery_id: aws.gamelift.describeMatchmakingConfigurations
  calls:
  - action: describeMatchmakingConfigurations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Configurations }}'
    item:
      Name: '{{ item.Name }}'
      ConfigurationArn: '{{ item.ConfigurationArn }}'
      Description: '{{ item.Description }}'
      GameSessionQueueArns: '{{ item.GameSessionQueueArns }}'
      RequestTimeoutSeconds: '{{ item.RequestTimeoutSeconds }}'
      AcceptanceTimeoutSeconds: '{{ item.AcceptanceTimeoutSeconds }}'
      AcceptanceRequired: '{{ item.AcceptanceRequired }}'
      RuleSetName: '{{ item.RuleSetName }}'
      RuleSetArn: '{{ item.RuleSetArn }}'
      NotificationTarget: '{{ item.NotificationTarget }}'
      AdditionalPlayerCount: '{{ item.AdditionalPlayerCount }}'
      CustomEventData: '{{ item.CustomEventData }}'
      CreationTime: '{{ item.CreationTime }}'
      GameProperties: '{{ item.GameProperties }}'
      GameSessionData: '{{ item.GameSessionData }}'
      BackfillMode: '{{ item.BackfillMode }}'
      FlexMatchMode: '{{ item.FlexMatchMode }}'
- discovery_id: aws.gamelift.describeMatchmakingRuleSets
  calls:
  - action: describeMatchmakingRuleSets
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.RuleSets }}'
    item:
      RuleSetName: '{{ item.RuleSetName }}'
      RuleSetArn: '{{ item.RuleSetArn }}'
      RuleSetBody: '{{ item.RuleSetBody }}'
      CreationTime: '{{ item.CreationTime }}'
- discovery_id: aws.gamelift.describePlayerSessions
  calls:
  - action: describePlayerSessions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.PlayerSessions }}'
    item:
      PlayerSessionId: '{{ item.PlayerSessionId }}'
      PlayerId: '{{ item.PlayerId }}'
      GameSessionId: '{{ item.GameSessionId }}'
      FleetId: '{{ item.FleetId }}'
      FleetArn: '{{ item.FleetArn }}'
      CreationTime: '{{ item.CreationTime }}'
      TerminationTime: '{{ item.TerminationTime }}'
      Status: '{{ item.Status }}'
      IpAddress: '{{ item.IpAddress }}'
      DnsName: '{{ item.DnsName }}'
      Port: '{{ item.Port }}'
      PlayerData: '{{ item.PlayerData }}'
- discovery_id: aws.gamelift.describeVpcPeeringAuthorizations
  calls:
  - action: describeVpcPeeringAuthorizations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.VpcPeeringAuthorizations }}'
    item:
      GameLiftAwsAccountId: '{{ item.GameLiftAwsAccountId }}'
      PeerVpcAwsAccountId: '{{ item.PeerVpcAwsAccountId }}'
      PeerVpcId: '{{ item.PeerVpcId }}'
      CreationTime: '{{ item.CreationTime }}'
      ExpirationTime: '{{ item.ExpirationTime }}'
- discovery_id: aws.gamelift.describeVpcPeeringConnections
  calls:
  - action: describeVpcPeeringConnections
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.VpcPeeringConnections }}'
    item:
      FleetId: '{{ item.FleetId }}'
      FleetArn: '{{ item.FleetArn }}'
      IpV4CidrBlock: '{{ item.IpV4CidrBlock }}'
      VpcPeeringConnectionId: '{{ item.VpcPeeringConnectionId }}'
      Status: '{{ item.Status }}'
      PeerVpcId: '{{ item.PeerVpcId }}'
      GameLiftVpcId: '{{ item.GameLiftVpcId }}'
- discovery_id: aws.gamelift.listAliases
  calls:
  - action: listAliases
    save_as: response
    on_error: continue
    params:
      Limit: 1000
  emit:
    as: item
    items_for: '{{ response.Aliases }}'
    item:
      AliasId: '{{ item.AliasId }}'
      Name: '{{ item.Name }}'
      AliasArn: '{{ item.AliasArn }}'
      Description: '{{ item.Description }}'
      RoutingStrategy: '{{ item.RoutingStrategy }}'
      CreationTime: '{{ item.CreationTime }}'
      LastUpdatedTime: '{{ item.LastUpdatedTime }}'
- discovery_id: aws.gamelift.listBuilds
  calls:
  - action: listBuilds
    save_as: response
    on_error: continue
    params:
      Limit: 1000
  emit:
    as: item
    items_for: '{{ response.Builds }}'
    item:
      BuildId: '{{ item.BuildId }}'
      BuildArn: '{{ item.BuildArn }}'
      Name: '{{ item.Name }}'
      Version: '{{ item.Version }}'
      Status: '{{ item.Status }}'
      SizeOnDisk: '{{ item.SizeOnDisk }}'
      OperatingSystem: '{{ item.OperatingSystem }}'
      CreationTime: '{{ item.CreationTime }}'
      ServerSdkVersion: '{{ item.ServerSdkVersion }}'
- discovery_id: aws.gamelift.listContainerFleets
  calls:
  - action: listContainerFleets
    save_as: response
    on_error: continue
    params:
      Limit: 1000
  emit:
    as: item
    items_for: '{{ response.ContainerFleets }}'
    item:
      FleetId: '{{ item.FleetId }}'
      FleetArn: '{{ item.FleetArn }}'
      FleetRoleArn: '{{ item.FleetRoleArn }}'
      GameServerContainerGroupDefinitionName: '{{ item.GameServerContainerGroupDefinitionName
        }}'
      GameServerContainerGroupDefinitionArn: '{{ item.GameServerContainerGroupDefinitionArn
        }}'
      PerInstanceContainerGroupDefinitionName: '{{ item.PerInstanceContainerGroupDefinitionName
        }}'
      PerInstanceContainerGroupDefinitionArn: '{{ item.PerInstanceContainerGroupDefinitionArn
        }}'
      InstanceConnectionPortRange: '{{ item.InstanceConnectionPortRange }}'
      InstanceInboundPermissions: '{{ item.InstanceInboundPermissions }}'
      GameServerContainerGroupsPerInstance: '{{ item.GameServerContainerGroupsPerInstance
        }}'
      MaximumGameServerContainerGroupsPerInstance: '{{ item.MaximumGameServerContainerGroupsPerInstance
        }}'
      InstanceType: '{{ item.InstanceType }}'
      BillingType: '{{ item.BillingType }}'
      Description: '{{ item.Description }}'
      CreationTime: '{{ item.CreationTime }}'
      MetricGroups: '{{ item.MetricGroups }}'
      NewGameSessionProtectionPolicy: '{{ item.NewGameSessionProtectionPolicy }}'
      GameSessionCreationLimitPolicy: '{{ item.GameSessionCreationLimitPolicy }}'
      Status: '{{ item.Status }}'
      DeploymentDetails: '{{ item.DeploymentDetails }}'
      LogConfiguration: '{{ item.LogConfiguration }}'
      LocationAttributes: '{{ item.LocationAttributes }}'
- discovery_id: aws.gamelift.listContainerGroupDefinitions
  calls:
  - action: listContainerGroupDefinitions
    save_as: response
    on_error: continue
