    item:
      GameSessionId: '{{ item.GameSessionId }}'
      Name: '{{ item.Name }}'
      FleetId: '{{ item.FleetId }}'
      FleetArn: '{{ item.FleetArn }}'
      CreationTime: '{{ item.CreationTime }}'
      TerminationTime: '{{ item.TerminationTime }}'
      CurrentPlayerSessionCount: '{{ item.CurrentPlayerSessionCount }}'
      MaximumPlayerSessionCount: '{{ item.MaximumPlayerSessionCount }}'
      Status: '{{ item.Status }}'
      StatusReason: '{{ item.StatusReason }}'
      GameProperties: '{{ item.GameProperties }}'
      IpAddress: '{{ item.IpAddress }}'
      DnsName: '{{ item.DnsName }}'
      Port: '{{ item.Port }}'
      PlayerSessionCreationPolicy: '{{ item.PlayerSessionCreationPolicy }}'
      CreatorId: '{{ item.CreatorId }}'
      GameSessionData: '{{ item.GameSessionData }}'
      MatchmakerData: '{{ item.MatchmakerData }}'
      Location: '{{ item.Location }}'
