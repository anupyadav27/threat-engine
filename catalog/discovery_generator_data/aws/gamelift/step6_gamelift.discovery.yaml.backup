      ContainerGroupType: '{{ item.ContainerGroupType }}'
      TotalMemoryLimitMebibytes: '{{ item.TotalMemoryLimitMebibytes }}'
      TotalVcpuLimit: '{{ item.TotalVcpuLimit }}'
      GameServerContainerDefinition: '{{ item.GameServerContainerDefinition }}'
      SupportContainerDefinitions: '{{ item.SupportContainerDefinitions }}'
      VersionNumber: '{{ item.VersionNumber }}'
      VersionDescription: '{{ item.VersionDescription }}'
      Status: '{{ item.Status }}'
      StatusReason: '{{ item.StatusReason }}'
- discovery_id: aws.gamelift.listFleetDeployments
  calls:
  - action: listFleetDeployments
    save_as: response
    on_error: continue
    params:
      Limit: 1000
  emit:
    as: item
    items_for: '{{ response.FleetDeployments }}'
    item:
      DeploymentId: '{{ item.DeploymentId }}'
      FleetId: '{{ item.FleetId }}'
      GameServerBinaryArn: '{{ item.GameServerBinaryArn }}'
      RollbackGameServerBinaryArn: '{{ item.RollbackGameServerBinaryArn }}'
      PerInstanceBinaryArn: '{{ item.PerInstanceBinaryArn }}'
      RollbackPerInstanceBinaryArn: '{{ item.RollbackPerInstanceBinaryArn }}'
      DeploymentStatus: '{{ item.DeploymentStatus }}'
      DeploymentConfiguration: '{{ item.DeploymentConfiguration }}'
      CreationTime: '{{ item.CreationTime }}'
- discovery_id: aws.gamelift.listFleets
  calls:
  - action: listFleets
    save_as: response
    on_error: continue
    params:
      Limit: 1000
  emit:
    as: item
    items_for: '{{ response.FleetIds }}'
- discovery_id: aws.gamelift.listGameServerGroups
  calls:
  - action: listGameServerGroups
    save_as: response
    on_error: continue
    params:
      Limit: 1000
  emit:
    as: item
    items_for: '{{ response.GameServerGroups }}'
    item:
      GameServerGroupName: '{{ item.GameServerGroupName }}'
      GameServerGroupArn: '{{ item.GameServerGroupArn }}'
      RoleArn: '{{ item.RoleArn }}'
      InstanceDefinitions: '{{ item.InstanceDefinitions }}'
      BalancingStrategy: '{{ item.BalancingStrategy }}'
      GameServerProtectionPolicy: '{{ item.GameServerProtectionPolicy }}'
      AutoScalingGroupArn: '{{ item.AutoScalingGroupArn }}'
      Status: '{{ item.Status }}'
      StatusReason: '{{ item.StatusReason }}'
      SuspendedActions: '{{ item.SuspendedActions }}'
