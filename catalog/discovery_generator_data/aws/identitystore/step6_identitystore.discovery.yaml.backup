version: '1.0'
provider: aws
service: identitystore
services:
  client: identitystore
  module: boto3.client
discovery:
- discovery_id: aws.identitystore.describeGroup
  calls:
  - action: describeGroup
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ExternalIds }}'
    item:
      Issuer: '{{ item.Issuer }}'
      Id: '{{ item.Id }}'
- discovery_id: aws.identitystore.describeGroupMembership
  calls:
  - action: describeGroupMembership
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.MemberId }}'
    item:
      UserId: '{{ item.UserId }}'
- discovery_id: aws.identitystore.describeUser
  calls:
  - action: describeUser
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ExternalIds }}'
    item:
      Issuer: '{{ item.Issuer }}'
      Id: '{{ item.Id }}'
- discovery_id: aws.identitystore.getGroupId
  calls:
  - action: getGroupId
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.GroupId }}'
- discovery_id: aws.identitystore.getGroupMembershipId
  calls:
  - action: getGroupMembershipId
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.MembershipId }}'
- discovery_id: aws.identitystore.getUserId
  calls:
  - action: getUserId
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.IdentityStoreId }}'
- discovery_id: aws.identitystore.listGroupMemberships
  calls:
  - action: listGroupMemberships
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.GroupMemberships }}'
    item:
      IdentityStoreId: '{{ item.IdentityStoreId }}'
      MembershipId: '{{ item.MembershipId }}'
      GroupId: '{{ item.GroupId }}'
      MemberId: '{{ item.MemberId }}'
      CreatedAt: '{{ item.CreatedAt }}'
      UpdatedAt: '{{ item.UpdatedAt }}'
      CreatedBy: '{{ item.CreatedBy }}'
      UpdatedBy: '{{ item.UpdatedBy }}'
- discovery_id: aws.identitystore.listGroupMembershipsForMember
  calls:
  - action: listGroupMembershipsForMember
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.GroupMemberships }}'
    item:
      IdentityStoreId: '{{ item.IdentityStoreId }}'
      MembershipId: '{{ item.MembershipId }}'
      GroupId: '{{ item.GroupId }}'
      MemberId: '{{ item.MemberId }}'
      CreatedAt: '{{ item.CreatedAt }}'
      UpdatedAt: '{{ item.UpdatedAt }}'
      CreatedBy: '{{ item.CreatedBy }}'
      UpdatedBy: '{{ item.UpdatedBy }}'
- discovery_id: aws.identitystore.listGroups
  calls:
  - action: listGroups
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Groups }}'
    item:
      GroupId: '{{ item.GroupId }}'
      DisplayName: '{{ item.DisplayName }}'
      ExternalIds: '{{ item.ExternalIds }}'
      Description: '{{ item.Description }}'
      CreatedAt: '{{ item.CreatedAt }}'
      UpdatedAt: '{{ item.UpdatedAt }}'
      CreatedBy: '{{ item.CreatedBy }}'
      UpdatedBy: '{{ item.UpdatedBy }}'
      IdentityStoreId: '{{ item.IdentityStoreId }}'
- discovery_id: aws.identitystore.listUsers
  calls:
  - action: listUsers
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Users }}'
    item:
      IdentityStoreId: '{{ item.IdentityStoreId }}'
      UserId: '{{ item.UserId }}'
      UserName: '{{ item.UserName }}'
      ExternalIds: '{{ item.ExternalIds }}'
      Name: '{{ item.Name }}'
      DisplayName: '{{ item.DisplayName }}'
      NickName: '{{ item.NickName }}'
      ProfileUrl: '{{ item.ProfileUrl }}'
      Emails: '{{ item.Emails }}'
      Addresses: '{{ item.Addresses }}'
      PhoneNumbers: '{{ item.PhoneNumbers }}'
      UserType: '{{ item.UserType }}'
      Title: '{{ item.Title }}'
      PreferredLanguage: '{{ item.PreferredLanguage }}'
      Locale: '{{ item.Locale }}'
      Timezone: '{{ item.Timezone }}'
      UserStatus: '{{ item.UserStatus }}'
      Photos: '{{ item.Photos }}'
      Website: '{{ item.Website }}'
      Birthdate: '{{ item.Birthdate }}'
      CreatedAt: '{{ item.CreatedAt }}'
      CreatedBy: '{{ item.CreatedBy }}'
      UpdatedAt: '{{ item.UpdatedAt }}'
      UpdatedBy: '{{ item.UpdatedBy }}'
checks: []
