version: '1.0'
provider: aws
service: bedrock-agent
services:
  client: bedrock-agent
  module: boto3.client
discovery:
- discovery_id: aws.bedrock-agent.listAgents
  calls:
  - action: listAgents
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.agentSummaries }}'
    item:
      agentId: '{{ item.agentId }}'
      agentName: '{{ item.agentName }}'
      agentStatus: '{{ item.agentStatus }}'
      description: '{{ item.description }}'
      updatedAt: '{{ item.updatedAt }}'
      latestAgentVersion: '{{ item.latestAgentVersion }}'
      guardrailConfiguration: '{{ item.guardrailConfiguration }}'
- discovery_id: aws.bedrock-agent.listFlows
  calls:
  - action: listFlows
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.flowSummaries }}'
    item:
      name: '{{ item.name }}'
      description: '{{ item.description }}'
      id: '{{ item.id }}'
      arn: '{{ item.arn }}'
      status: '{{ item.status }}'
      createdAt: '{{ item.createdAt }}'
      updatedAt: '{{ item.updatedAt }}'
      version: '{{ item.version }}'
- discovery_id: aws.bedrock-agent.listKnowledgeBases
  calls:
  - action: listKnowledgeBases
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.knowledgeBaseSummaries }}'
    item:
      knowledgeBaseId: '{{ item.knowledgeBaseId }}'
      name: '{{ item.name }}'
      description: '{{ item.description }}'
      status: '{{ item.status }}'
      updatedAt: '{{ item.updatedAt }}'
- discovery_id: aws.bedrock-agent.listPrompts
  calls:
  - action: listPrompts
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.promptSummaries }}'
    item:
      name: '{{ item.name }}'
      description: '{{ item.description }}'
      id: '{{ item.id }}'
      arn: '{{ item.arn }}'
      version: '{{ item.version }}'
      createdAt: '{{ item.createdAt }}'
      updatedAt: '{{ item.updatedAt }}'
- discovery_id: aws.bedrock-agent.getAgent
  calls:
  - action: getAgent
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.agent }}'
    item:
      agentId: '{{ item.agentId }}'
      agentName: '{{ item.agentName }}'
      agentArn: '{{ item.agentArn }}'
      agentVersion: '{{ item.agentVersion }}'
      clientToken: '{{ item.clientToken }}'
      instruction: '{{ item.instruction }}'
      agentStatus: '{{ item.agentStatus }}'
      foundationModel: '{{ item.foundationModel }}'
      description: '{{ item.description }}'
      orchestrationType: '{{ item.orchestrationType }}'
      customOrchestration: '{{ item.customOrchestration }}'
      idleSessionTTLInSeconds: '{{ item.idleSessionTTLInSeconds }}'
      agentResourceRoleArn: '{{ item.agentResourceRoleArn }}'
      customerEncryptionKeyArn: '{{ item.customerEncryptionKeyArn }}'
      createdAt: '{{ item.createdAt }}'
      updatedAt: '{{ item.updatedAt }}'
      preparedAt: '{{ item.preparedAt }}'
      failureReasons: '{{ item.failureReasons }}'
      recommendedActions: '{{ item.recommendedActions }}'
      promptOverrideConfiguration: '{{ item.promptOverrideConfiguration }}'
      guardrailConfiguration: '{{ item.guardrailConfiguration }}'
      memoryConfiguration: '{{ item.memoryConfiguration }}'
      agentCollaboration: '{{ item.agentCollaboration }}'
- discovery_id: aws.bedrock-agent.getAgentActionGroup
  calls:
  - action: getAgentActionGroup
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.agentActionGroup }}'
    item:
      agentId: '{{ item.agentId }}'
      agentVersion: '{{ item.agentVersion }}'
      actionGroupId: '{{ item.actionGroupId }}'
      actionGroupName: '{{ item.actionGroupName }}'
      clientToken: '{{ item.clientToken }}'
      description: '{{ item.description }}'
      createdAt: '{{ item.createdAt }}'
      updatedAt: '{{ item.updatedAt }}'
      parentActionSignature: '{{ item.parentActionSignature }}'
      parentActionGroupSignatureParams: '{{ item.parentActionGroupSignatureParams
        }}'
      actionGroupExecutor: '{{ item.actionGroupExecutor }}'
      apiSchema: '{{ item.apiSchema }}'
      functionSchema: '{{ item.functionSchema }}'
      actionGroupState: '{{ item.actionGroupState }}'
- discovery_id: aws.bedrock-agent.getAgentAlias
  calls:
  - action: getAgentAlias
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.agentAlias }}'
    item:
      agentId: '{{ item.agentId }}'
      agentAliasId: '{{ item.agentAliasId }}'
      agentAliasName: '{{ item.agentAliasName }}'
      agentAliasArn: '{{ item.agentAliasArn }}'
      clientToken: '{{ item.clientToken }}'
      description: '{{ item.description }}'
      routingConfiguration: '{{ item.routingConfiguration }}'
      createdAt: '{{ item.createdAt }}'
      updatedAt: '{{ item.updatedAt }}'
      agentAliasHistoryEvents: '{{ item.agentAliasHistoryEvents }}'
      agentAliasStatus: '{{ item.agentAliasStatus }}'
      failureReasons: '{{ item.failureReasons }}'
      aliasInvocationState: '{{ item.aliasInvocationState }}'
- discovery_id: aws.bedrock-agent.getAgentCollaborator
  calls:
  - action: getAgentCollaborator
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.agentCollaborator }}'
    item:
      agentId: '{{ item.agentId }}'
      agentVersion: '{{ item.agentVersion }}'
      agentDescriptor: '{{ item.agentDescriptor }}'
      collaboratorId: '{{ item.collaboratorId }}'
      collaborationInstruction: '{{ item.collaborationInstruction }}'
      collaboratorName: '{{ item.collaboratorName }}'
      createdAt: '{{ item.createdAt }}'
      lastUpdatedAt: '{{ item.lastUpdatedAt }}'
      relayConversationHistory: '{{ item.relayConversationHistory }}'
      clientToken: '{{ item.clientToken }}'
- discovery_id: aws.bedrock-agent.getAgentKnowledgeBase
  calls:
  - action: getAgentKnowledgeBase
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.agentKnowledgeBase }}'
    item:
      agentId: '{{ item.agentId }}'
      agentVersion: '{{ item.agentVersion }}'
      knowledgeBaseId: '{{ item.knowledgeBaseId }}'
      description: '{{ item.description }}'
      createdAt: '{{ item.createdAt }}'
      updatedAt: '{{ item.updatedAt }}'
      knowledgeBaseState: '{{ item.knowledgeBaseState }}'
- discovery_id: aws.bedrock-agent.getAgentVersion
  calls:
  - action: getAgentVersion
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.agentVersion }}'
    item:
      agentId: '{{ item.agentId }}'
      agentName: '{{ item.agentName }}'
      agentArn: '{{ item.agentArn }}'
      version: '{{ item.version }}'
      instruction: '{{ item.instruction }}'
      agentStatus: '{{ item.agentStatus }}'
      foundationModel: '{{ item.foundationModel }}'
      description: '{{ item.description }}'
      idleSessionTTLInSeconds: '{{ item.idleSessionTTLInSeconds }}'
      agentResourceRoleArn: '{{ item.agentResourceRoleArn }}'
      customerEncryptionKeyArn: '{{ item.customerEncryptionKeyArn }}'
      createdAt: '{{ item.createdAt }}'
      updatedAt: '{{ item.updatedAt }}'
      failureReasons: '{{ item.failureReasons }}'
      recommendedActions: '{{ item.recommendedActions }}'
      promptOverrideConfiguration: '{{ item.promptOverrideConfiguration }}'
      guardrailConfiguration: '{{ item.guardrailConfiguration }}'
      memoryConfiguration: '{{ item.memoryConfiguration }}'
      agentCollaboration: '{{ item.agentCollaboration }}'
- discovery_id: aws.bedrock-agent.getDataSource
  calls:
  - action: getDataSource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.dataSource }}'
    item:
      knowledgeBaseId: '{{ item.knowledgeBaseId }}'
      dataSourceId: '{{ item.dataSourceId }}'
      name: '{{ item.name }}'
      status: '{{ item.status }}'
      description: '{{ item.description }}'
      dataSourceConfiguration: '{{ item.dataSourceConfiguration }}'
      serverSideEncryptionConfiguration: '{{ item.serverSideEncryptionConfiguration
        }}'
      vectorIngestionConfiguration: '{{ item.vectorIngestionConfiguration }}'
      dataDeletionPolicy: '{{ item.dataDeletionPolicy }}'
      createdAt: '{{ item.createdAt }}'
      updatedAt: '{{ item.updatedAt }}'
      failureReasons: '{{ item.failureReasons }}'
- discovery_id: aws.bedrock-agent.getFlow
  calls:
  - action: getFlow
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.validations }}'
    item:
      message: '{{ item.message }}'
      severity: '{{ item.severity }}'
      details: '{{ item.details }}'
      type: '{{ item.type }}'
- discovery_id: aws.bedrock-agent.getFlowAlias
  calls:
  - action: getFlowAlias
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.routingConfiguration }}'
    item:
      flowVersion: '{{ item.flowVersion }}'
- discovery_id: aws.bedrock-agent.getFlowVersion
  calls:
  - action: getFlowVersion
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.definition }}'
    item:
      nodes: '{{ item.nodes }}'
      connections: '{{ item.connections }}'
- discovery_id: aws.bedrock-agent.getIngestionJob
  calls:
  - action: getIngestionJob
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ingestionJob }}'
    item:
      knowledgeBaseId: '{{ item.knowledgeBaseId }}'
      dataSourceId: '{{ item.dataSourceId }}'
      ingestionJobId: '{{ item.ingestionJobId }}'
      description: '{{ item.description }}'
      status: '{{ item.status }}'
      statistics: '{{ item.statistics }}'
      failureReasons: '{{ item.failureReasons }}'
      startedAt: '{{ item.startedAt }}'
      updatedAt: '{{ item.updatedAt }}'
- discovery_id: aws.bedrock-agent.getKnowledgeBase
  calls:
  - action: getKnowledgeBase
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.knowledgeBase }}'
    item:
      knowledgeBaseId: '{{ item.knowledgeBaseId }}'
      name: '{{ item.name }}'
      knowledgeBaseArn: '{{ item.knowledgeBaseArn }}'
      description: '{{ item.description }}'
      roleArn: '{{ item.roleArn }}'
      knowledgeBaseConfiguration: '{{ item.knowledgeBaseConfiguration }}'
      storageConfiguration: '{{ item.storageConfiguration }}'
      status: '{{ item.status }}'
      createdAt: '{{ item.createdAt }}'
      updatedAt: '{{ item.updatedAt }}'
      failureReasons: '{{ item.failureReasons }}'
- discovery_id: aws.bedrock-agent.getKnowledgeBaseDocuments
  calls:
  - action: getKnowledgeBaseDocuments
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.documentDetails }}'
    item:
      knowledgeBaseId: '{{ item.knowledgeBaseId }}'
      dataSourceId: '{{ item.dataSourceId }}'
      status: '{{ item.status }}'
      identifier: '{{ item.identifier }}'
      statusReason: '{{ item.statusReason }}'
      updatedAt: '{{ item.updatedAt }}'
- discovery_id: aws.bedrock-agent.getPrompt
  calls:
  - action: getPrompt
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.variants }}'
    item:
      name: '{{ item.name }}'
      templateType: '{{ item.templateType }}'
      templateConfiguration: '{{ item.templateConfiguration }}'
      modelId: '{{ item.modelId }}'
      inferenceConfiguration: '{{ item.inferenceConfiguration }}'
      metadata: '{{ item.metadata }}'
      additionalModelRequestFields: '{{ item.additionalModelRequestFields }}'
      genAiResource: '{{ item.genAiResource }}'
- discovery_id: aws.bedrock-agent.listAgentActionGroups
  calls:
  - action: listAgentActionGroups
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.actionGroupSummaries }}'
    item:
      actionGroupId: '{{ item.actionGroupId }}'
      actionGroupName: '{{ item.actionGroupName }}'
      actionGroupState: '{{ item.actionGroupState }}'
      description: '{{ item.description }}'
      updatedAt: '{{ item.updatedAt }}'
- discovery_id: aws.bedrock-agent.listAgentAliases
  calls:
  - action: listAgentAliases
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.agentAliasSummaries }}'
    item:
      agentAliasId: '{{ item.agentAliasId }}'
      agentAliasName: '{{ item.agentAliasName }}'
      description: '{{ item.description }}'
      routingConfiguration: '{{ item.routingConfiguration }}'
      agentAliasStatus: '{{ item.agentAliasStatus }}'
      createdAt: '{{ item.createdAt }}'
      updatedAt: '{{ item.updatedAt }}'
      aliasInvocationState: '{{ item.aliasInvocationState }}'
- discovery_id: aws.bedrock-agent.listAgentCollaborators
  calls:
  - action: listAgentCollaborators
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.agentCollaboratorSummaries }}'
    item:
      agentId: '{{ item.agentId }}'
      agentVersion: '{{ item.agentVersion }}'
      collaboratorId: '{{ item.collaboratorId }}'
      agentDescriptor: '{{ item.agentDescriptor }}'
      collaborationInstruction: '{{ item.collaborationInstruction }}'
      relayConversationHistory: '{{ item.relayConversationHistory }}'
      collaboratorName: '{{ item.collaboratorName }}'
      createdAt: '{{ item.createdAt }}'
      lastUpdatedAt: '{{ item.lastUpdatedAt }}'
- discovery_id: aws.bedrock-agent.listAgentKnowledgeBases
  calls:
  - action: listAgentKnowledgeBases
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.agentKnowledgeBaseSummaries }}'
    item:
      knowledgeBaseId: '{{ item.knowledgeBaseId }}'
      description: '{{ item.description }}'
      knowledgeBaseState: '{{ item.knowledgeBaseState }}'
      updatedAt: '{{ item.updatedAt }}'
- discovery_id: aws.bedrock-agent.listAgentVersions
  calls:
  - action: listAgentVersions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.agentVersionSummaries }}'
    item:
      agentName: '{{ item.agentName }}'
      agentStatus: '{{ item.agentStatus }}'
      agentVersion: '{{ item.agentVersion }}'
      createdAt: '{{ item.createdAt }}'
      updatedAt: '{{ item.updatedAt }}'
      description: '{{ item.description }}'
      guardrailConfiguration: '{{ item.guardrailConfiguration }}'
- discovery_id: aws.bedrock-agent.listDataSources
  calls:
  - action: listDataSources
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.dataSourceSummaries }}'
    item:
      knowledgeBaseId: '{{ item.knowledgeBaseId }}'
      dataSourceId: '{{ item.dataSourceId }}'
      name: '{{ item.name }}'
      status: '{{ item.status }}'
      description: '{{ item.description }}'
      updatedAt: '{{ item.updatedAt }}'
- discovery_id: aws.bedrock-agent.listFlowAliases
  calls:
  - action: listFlowAliases
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.flowAliasSummaries }}'
    item:
      name: '{{ item.name }}'
      description: '{{ item.description }}'
      routingConfiguration: '{{ item.routingConfiguration }}'
      concurrencyConfiguration: '{{ item.concurrencyConfiguration }}'
      flowId: '{{ item.flowId }}'
      id: '{{ item.id }}'
      arn: '{{ item.arn }}'
      createdAt: '{{ item.createdAt }}'
      updatedAt: '{{ item.updatedAt }}'
- discovery_id: aws.bedrock-agent.listFlowVersions
  calls:
  - action: listFlowVersions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.flowVersionSummaries }}'
    item:
      id: '{{ item.id }}'
      arn: '{{ item.arn }}'
      status: '{{ item.status }}'
      createdAt: '{{ item.createdAt }}'
      version: '{{ item.version }}'
- discovery_id: aws.bedrock-agent.listIngestionJobs
  calls:
  - action: listIngestionJobs
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ingestionJobSummaries }}'
    item:
      knowledgeBaseId: '{{ item.knowledgeBaseId }}'
      dataSourceId: '{{ item.dataSourceId }}'
      ingestionJobId: '{{ item.ingestionJobId }}'
      description: '{{ item.description }}'
      status: '{{ item.status }}'
      startedAt: '{{ item.startedAt }}'
      updatedAt: '{{ item.updatedAt }}'
      statistics: '{{ item.statistics }}'
- discovery_id: aws.bedrock-agent.listKnowledgeBaseDocuments
  calls:
  - action: listKnowledgeBaseDocuments
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.documentDetails }}'
    item:
      knowledgeBaseId: '{{ item.knowledgeBaseId }}'
      dataSourceId: '{{ item.dataSourceId }}'
      status: '{{ item.status }}'
      identifier: '{{ item.identifier }}'
      statusReason: '{{ item.statusReason }}'
      updatedAt: '{{ item.updatedAt }}'
- discovery_id: aws.bedrock-agent.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tags }}'
checks: []
