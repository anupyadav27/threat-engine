version: '1.0'
provider: aws
service: oam
services:
  client: oam
  module: boto3.client
discovery:
- discovery_id: aws.oam.listLinks
  calls:
  - action: listLinks
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Items }}'
    item:
      Arn: '{{ item.Arn }}'
      Id: '{{ item.Id }}'
      Label: '{{ item.Label }}'
      ResourceTypes: '{{ item.ResourceTypes }}'
      SinkArn: '{{ item.SinkArn }}'
- discovery_id: aws.oam.listSinks
  calls:
  - action: listSinks
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Items }}'
    item:
      Arn: '{{ item.Arn }}'
      Id: '{{ item.Id }}'
      Name: '{{ item.Name }}'
- discovery_id: aws.oam.getLink
  calls:
  - action: getLink
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ResourceTypes }}'
- discovery_id: aws.oam.getSink
  calls:
  - action: getSink
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Arn }}'
- discovery_id: aws.oam.getSinkPolicy
  calls:
  - action: getSinkPolicy
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Policy }}'
- discovery_id: aws.oam.listAttachedLinks
  calls:
  - action: listAttachedLinks
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Items }}'
    item:
      Label: '{{ item.Label }}'
      LinkArn: '{{ item.LinkArn }}'
      ResourceTypes: '{{ item.ResourceTypes }}'
- discovery_id: aws.oam.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Tags }}'
checks: []
