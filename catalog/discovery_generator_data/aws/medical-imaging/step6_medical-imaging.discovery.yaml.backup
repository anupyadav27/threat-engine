version: '1.0'
provider: aws
service: medical-imaging
services:
  client: medical-imaging
  module: boto3.client
discovery:
- discovery_id: aws.medical-imaging.listDatastores
  calls:
  - action: listDatastores
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.datastoreSummaries }}'
    item:
      datastoreId: '{{ item.datastoreId }}'
      datastoreName: '{{ item.datastoreName }}'
      datastoreStatus: '{{ item.datastoreStatus }}'
      datastoreArn: '{{ item.datastoreArn }}'
      createdAt: '{{ item.createdAt }}'
      updatedAt: '{{ item.updatedAt }}'
- discovery_id: aws.medical-imaging.getDicomImportJob
  calls:
  - action: getDicomImportJob
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.jobProperties }}'
    item:
      jobId: '{{ item.jobId }}'
      jobName: '{{ item.jobName }}'
      jobStatus: '{{ item.jobStatus }}'
      datastoreId: '{{ item.datastoreId }}'
      dataAccessRoleArn: '{{ item.dataAccessRoleArn }}'
      endedAt: '{{ item.endedAt }}'
      submittedAt: '{{ item.submittedAt }}'
      inputS3Uri: '{{ item.inputS3Uri }}'
      outputS3Uri: '{{ item.outputS3Uri }}'
      message: '{{ item.message }}'
- discovery_id: aws.medical-imaging.getDatastore
  calls:
  - action: getDatastore
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.datastoreProperties }}'
    item:
      datastoreId: '{{ item.datastoreId }}'
      datastoreName: '{{ item.datastoreName }}'
      datastoreStatus: '{{ item.datastoreStatus }}'
      kmsKeyArn: '{{ item.kmsKeyArn }}'
      lambdaAuthorizerArn: '{{ item.lambdaAuthorizerArn }}'
      losslessStorageFormat: '{{ item.losslessStorageFormat }}'
      datastoreArn: '{{ item.datastoreArn }}'
      createdAt: '{{ item.createdAt }}'
      updatedAt: '{{ item.updatedAt }}'
- discovery_id: aws.medical-imaging.getImageFrame
  calls:
  - action: getImageFrame
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.imageFrameBlob }}'
- discovery_id: aws.medical-imaging.getImageSet
  calls:
  - action: getImageSet
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.overrides }}'
    item:
      forced: '{{ item.forced }}'
- discovery_id: aws.medical-imaging.getImageSetMetadata
  calls:
  - action: getImageSetMetadata
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.imageSetMetadataBlob }}'
- discovery_id: aws.medical-imaging.listDicomImportJobs
  calls:
  - action: listDicomImportJobs
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.jobSummaries }}'
    item:
      jobId: '{{ item.jobId }}'
      jobName: '{{ item.jobName }}'
      jobStatus: '{{ item.jobStatus }}'
      datastoreId: '{{ item.datastoreId }}'
      dataAccessRoleArn: '{{ item.dataAccessRoleArn }}'
      endedAt: '{{ item.endedAt }}'
      submittedAt: '{{ item.submittedAt }}'
      message: '{{ item.message }}'
- discovery_id: aws.medical-imaging.listImageSetVersions
  calls:
  - action: listImageSetVersions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.imageSetPropertiesList }}'
    item:
      imageSetId: '{{ item.imageSetId }}'
      versionId: '{{ item.versionId }}'
      imageSetState: '{{ item.imageSetState }}'
      ImageSetWorkflowStatus: '{{ item.ImageSetWorkflowStatus }}'
      createdAt: '{{ item.createdAt }}'
      updatedAt: '{{ item.updatedAt }}'
      deletedAt: '{{ item.deletedAt }}'
      message: '{{ item.message }}'
      overrides: '{{ item.overrides }}'
      isPrimary: '{{ item.isPrimary }}'
- discovery_id: aws.medical-imaging.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tags }}'
- discovery_id: aws.medical-imaging.searchImageSets
  calls:
  - action: searchImageSets
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.imageSetsMetadataSummaries }}'
    item:
      imageSetId: '{{ item.imageSetId }}'
      version: '{{ item.version }}'
      createdAt: '{{ item.createdAt }}'
      updatedAt: '{{ item.updatedAt }}'
      lastAccessedAt: '{{ item.lastAccessedAt }}'
      storageTier: '{{ item.storageTier }}'
      DICOMTags: '{{ item.DICOMTags }}'
      isPrimary: '{{ item.isPrimary }}'
checks: []
