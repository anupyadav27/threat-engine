version: '1.0'
provider: aws
service: kinesis
services:
  client: kinesis
  module: boto3.client
discovery:
- discovery_id: aws.kinesis.describeAccountSettings
  calls:
  - action: describeAccountSettings
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.MinimumThroughputBillingCommitment }}'
    item:
      Status: '{{ item.Status }}'
      StartedAt: '{{ item.StartedAt }}'
      EndedAt: '{{ item.EndedAt }}'
      EarliestAllowedEndAt: '{{ item.EarliestAllowedEndAt }}'
- discovery_id: aws.kinesis.describeLimits
  calls:
  - action: describeLimits
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ShardLimit }}'
- discovery_id: aws.kinesis.describeStream
  calls:
  - action: describeStream
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.StreamDescription }}'
    item:
      StreamName: '{{ item.StreamName }}'
      StreamARN: '{{ item.StreamARN }}'
      StreamStatus: '{{ item.StreamStatus }}'
      StreamModeDetails: '{{ item.StreamModeDetails }}'
      Shards: '{{ item.Shards }}'
      HasMoreShards: '{{ item.HasMoreShards }}'
      RetentionPeriodHours: '{{ item.RetentionPeriodHours }}'
      StreamCreationTimestamp: '{{ item.StreamCreationTimestamp }}'
      EnhancedMonitoring: '{{ item.EnhancedMonitoring }}'
      EncryptionType: '{{ item.EncryptionType }}'
      KeyId: '{{ item.KeyId }}'
- discovery_id: aws.kinesis.describeStreamConsumer
  calls:
  - action: describeStreamConsumer
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ConsumerDescription }}'
    item:
      ConsumerName: '{{ item.ConsumerName }}'
      ConsumerARN: '{{ item.ConsumerARN }}'
      ConsumerStatus: '{{ item.ConsumerStatus }}'
      ConsumerCreationTimestamp: '{{ item.ConsumerCreationTimestamp }}'
      StreamARN: '{{ item.StreamARN }}'
- discovery_id: aws.kinesis.describeStreamSummary
  calls:
  - action: describeStreamSummary
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.StreamDescriptionSummary }}'
    item:
      StreamName: '{{ item.StreamName }}'
      StreamARN: '{{ item.StreamARN }}'
      StreamStatus: '{{ item.StreamStatus }}'
      StreamModeDetails: '{{ item.StreamModeDetails }}'
      RetentionPeriodHours: '{{ item.RetentionPeriodHours }}'
      StreamCreationTimestamp: '{{ item.StreamCreationTimestamp }}'
      EnhancedMonitoring: '{{ item.EnhancedMonitoring }}'
      EncryptionType: '{{ item.EncryptionType }}'
      KeyId: '{{ item.KeyId }}'
      OpenShardCount: '{{ item.OpenShardCount }}'
      ConsumerCount: '{{ item.ConsumerCount }}'
      WarmThroughput: '{{ item.WarmThroughput }}'
      MaxRecordSizeInKiB: '{{ item.MaxRecordSizeInKiB }}'
- discovery_id: aws.kinesis.listShards
  calls:
  - action: listShards
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Shards }}'
    item:
      ShardId: '{{ item.ShardId }}'
      ParentShardId: '{{ item.ParentShardId }}'
      AdjacentParentShardId: '{{ item.AdjacentParentShardId }}'
      HashKeyRange: '{{ item.HashKeyRange }}'
      SequenceNumberRange: '{{ item.SequenceNumberRange }}'
- discovery_id: aws.kinesis.listStreams
  calls:
  - action: listStreams
    save_as: response
    on_error: continue
    params:
      Limit: 1000
  emit:
    as: item
    items_for: '{{ response.StreamNames }}'
- discovery_id: aws.kinesis.listTagsForStream
  calls:
  - action: listTagsForStream
    save_as: response
    on_error: continue
    params:
      Limit: 1000
  emit:
    as: item
    items_for: '{{ response.Tags }}'
    item:
      Key: '{{ item.Key }}'
      Value: '{{ item.Value }}'
- discovery_id: aws.kinesis.getRecords
  calls:
  - action: getRecords
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Records }}'
    item:
      SequenceNumber: '{{ item.SequenceNumber }}'
      ApproximateArrivalTimestamp: '{{ item.ApproximateArrivalTimestamp }}'
      Data: '{{ item.Data }}'
      PartitionKey: '{{ item.PartitionKey }}'
      EncryptionType: '{{ item.EncryptionType }}'
- discovery_id: aws.kinesis.getResourcePolicy
  calls:
  - action: getResourcePolicy
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Policy }}'
- discovery_id: aws.kinesis.getShardIterator
  calls:
  - action: getShardIterator
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ShardIterator }}'
- discovery_id: aws.kinesis.listStreamConsumers
  calls:
  - action: listStreamConsumers
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Consumers }}'
    item:
      ConsumerName: '{{ item.ConsumerName }}'
      ConsumerARN: '{{ item.ConsumerARN }}'
      ConsumerStatus: '{{ item.ConsumerStatus }}'
      ConsumerCreationTimestamp: '{{ item.ConsumerCreationTimestamp }}'
- discovery_id: aws.kinesis.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Tags }}'
    item:
      Key: '{{ item.Key }}'
      Value: '{{ item.Value }}'
checks: []
