version: '1.0'
provider: aws
service: databrew
services:
  client: databrew
  module: boto3.client
discovery:
- discovery_id: aws.databrew.listDatasets
  calls:
  - action: listDatasets
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Datasets }}'
    item:
      AccountId: '{{ item.AccountId }}'
      CreatedBy: '{{ item.CreatedBy }}'
      CreateDate: '{{ item.CreateDate }}'
      Name: '{{ item.Name }}'
      Format: '{{ item.Format }}'
      FormatOptions: '{{ item.FormatOptions }}'
      Input: '{{ item.Input }}'
      LastModifiedDate: '{{ item.LastModifiedDate }}'
      LastModifiedBy: '{{ item.LastModifiedBy }}'
      Source: '{{ item.Source }}'
      PathOptions: '{{ item.PathOptions }}'
      Tags: '{{ item.Tags }}'
      ResourceArn: '{{ item.ResourceArn }}'
- discovery_id: aws.databrew.listJobs
  calls:
  - action: listJobs
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Jobs }}'
    item:
      AccountId: '{{ item.AccountId }}'
      CreatedBy: '{{ item.CreatedBy }}'
      CreateDate: '{{ item.CreateDate }}'
      DatasetName: '{{ item.DatasetName }}'
      EncryptionKeyArn: '{{ item.EncryptionKeyArn }}'
      EncryptionMode: '{{ item.EncryptionMode }}'
      Name: '{{ item.Name }}'
      Type: '{{ item.Type }}'
      LastModifiedBy: '{{ item.LastModifiedBy }}'
      LastModifiedDate: '{{ item.LastModifiedDate }}'
      LogSubscription: '{{ item.LogSubscription }}'
      MaxCapacity: '{{ item.MaxCapacity }}'
      MaxRetries: '{{ item.MaxRetries }}'
      Outputs: '{{ item.Outputs }}'
      DataCatalogOutputs: '{{ item.DataCatalogOutputs }}'
      DatabaseOutputs: '{{ item.DatabaseOutputs }}'
      ProjectName: '{{ item.ProjectName }}'
      RecipeReference: '{{ item.RecipeReference }}'
      ResourceArn: '{{ item.ResourceArn }}'
      RoleArn: '{{ item.RoleArn }}'
      Timeout: '{{ item.Timeout }}'
      Tags: '{{ item.Tags }}'
      JobSample: '{{ item.JobSample }}'
      ValidationConfigurations: '{{ item.ValidationConfigurations }}'
- discovery_id: aws.databrew.listProjects
  calls:
  - action: listProjects
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Projects }}'
    item:
      AccountId: '{{ item.AccountId }}'
      CreateDate: '{{ item.CreateDate }}'
      CreatedBy: '{{ item.CreatedBy }}'
      DatasetName: '{{ item.DatasetName }}'
      LastModifiedDate: '{{ item.LastModifiedDate }}'
      LastModifiedBy: '{{ item.LastModifiedBy }}'
      Name: '{{ item.Name }}'
      RecipeName: '{{ item.RecipeName }}'
      ResourceArn: '{{ item.ResourceArn }}'
      Sample: '{{ item.Sample }}'
      Tags: '{{ item.Tags }}'
      RoleArn: '{{ item.RoleArn }}'
      OpenedBy: '{{ item.OpenedBy }}'
      OpenDate: '{{ item.OpenDate }}'
- discovery_id: aws.databrew.listRecipes
  calls:
  - action: listRecipes
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Recipes }}'
    item:
      CreatedBy: '{{ item.CreatedBy }}'
      CreateDate: '{{ item.CreateDate }}'
      LastModifiedBy: '{{ item.LastModifiedBy }}'
      LastModifiedDate: '{{ item.LastModifiedDate }}'
      ProjectName: '{{ item.ProjectName }}'
      PublishedBy: '{{ item.PublishedBy }}'
      PublishedDate: '{{ item.PublishedDate }}'
      Description: '{{ item.Description }}'
      Name: '{{ item.Name }}'
      ResourceArn: '{{ item.ResourceArn }}'
      Steps: '{{ item.Steps }}'
      Tags: '{{ item.Tags }}'
      RecipeVersion: '{{ item.RecipeVersion }}'
- discovery_id: aws.databrew.listRulesets
  calls:
  - action: listRulesets
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Rulesets }}'
    item:
      AccountId: '{{ item.AccountId }}'
      CreatedBy: '{{ item.CreatedBy }}'
      CreateDate: '{{ item.CreateDate }}'
      Description: '{{ item.Description }}'
      LastModifiedBy: '{{ item.LastModifiedBy }}'
      LastModifiedDate: '{{ item.LastModifiedDate }}'
      Name: '{{ item.Name }}'
      ResourceArn: '{{ item.ResourceArn }}'
      RuleCount: '{{ item.RuleCount }}'
      Tags: '{{ item.Tags }}'
      TargetArn: '{{ item.TargetArn }}'
- discovery_id: aws.databrew.listSchedules
  calls:
  - action: listSchedules
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Schedules }}'
    item:
      AccountId: '{{ item.AccountId }}'
      CreatedBy: '{{ item.CreatedBy }}'
      CreateDate: '{{ item.CreateDate }}'
      JobNames: '{{ item.JobNames }}'
      LastModifiedBy: '{{ item.LastModifiedBy }}'
      LastModifiedDate: '{{ item.LastModifiedDate }}'
      ResourceArn: '{{ item.ResourceArn }}'
      CronExpression: '{{ item.CronExpression }}'
      Tags: '{{ item.Tags }}'
      Name: '{{ item.Name }}'
- discovery_id: aws.databrew.describeDataset
  calls:
  - action: describeDataset
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.FormatOptions }}'
    item:
      Json: '{{ item.Json }}'
      Excel: '{{ item.Excel }}'
      Csv: '{{ item.Csv }}'
- discovery_id: aws.databrew.describeJob
  calls:
  - action: describeJob
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Outputs }}'
    item:
      CompressionFormat: '{{ item.CompressionFormat }}'
      Format: '{{ item.Format }}'
      PartitionColumns: '{{ item.PartitionColumns }}'
      Location: '{{ item.Location }}'
      Overwrite: '{{ item.Overwrite }}'
      FormatOptions: '{{ item.FormatOptions }}'
      MaxOutputFiles: '{{ item.MaxOutputFiles }}'
- discovery_id: aws.databrew.describeJobRun
  calls:
  - action: describeJobRun
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ValidationConfigurations }}'
    item:
      RulesetArn: '{{ item.RulesetArn }}'
      ValidationMode: '{{ item.ValidationMode }}'
- discovery_id: aws.databrew.describeProject
  calls:
  - action: describeProject
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Sample }}'
    item:
      Size: '{{ item.Size }}'
      Type: '{{ item.Type }}'
- discovery_id: aws.databrew.describeRecipe
  calls:
  - action: describeRecipe
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Steps }}'
    item:
      Action: '{{ item.Action }}'
      ConditionExpressions: '{{ item.ConditionExpressions }}'
- discovery_id: aws.databrew.describeRuleset
  calls:
  - action: describeRuleset
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Rules }}'
    item:
      Name: '{{ item.Name }}'
      Disabled: '{{ item.Disabled }}'
      CheckExpression: '{{ item.CheckExpression }}'
      SubstitutionMap: '{{ item.SubstitutionMap }}'
      Threshold: '{{ item.Threshold }}'
      ColumnSelectors: '{{ item.ColumnSelectors }}'
- discovery_id: aws.databrew.describeSchedule
  calls:
  - action: describeSchedule
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.JobNames }}'
- discovery_id: aws.databrew.listJobRuns
  calls:
  - action: listJobRuns
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.JobRuns }}'
    item:
      Attempt: '{{ item.Attempt }}'
      CompletedOn: '{{ item.CompletedOn }}'
      DatasetName: '{{ item.DatasetName }}'
      ErrorMessage: '{{ item.ErrorMessage }}'
      ExecutionTime: '{{ item.ExecutionTime }}'
      JobName: '{{ item.JobName }}'
      RunId: '{{ item.RunId }}'
      State: '{{ item.State }}'
      LogSubscription: '{{ item.LogSubscription }}'
      LogGroupName: '{{ item.LogGroupName }}'
      Outputs: '{{ item.Outputs }}'
      DataCatalogOutputs: '{{ item.DataCatalogOutputs }}'
      DatabaseOutputs: '{{ item.DatabaseOutputs }}'
      RecipeReference: '{{ item.RecipeReference }}'
      StartedBy: '{{ item.StartedBy }}'
      StartedOn: '{{ item.StartedOn }}'
      JobSample: '{{ item.JobSample }}'
      ValidationConfigurations: '{{ item.ValidationConfigurations }}'
- discovery_id: aws.databrew.listRecipeVersions
  calls:
  - action: listRecipeVersions
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Recipes }}'
    item:
      CreatedBy: '{{ item.CreatedBy }}'
      CreateDate: '{{ item.CreateDate }}'
      LastModifiedBy: '{{ item.LastModifiedBy }}'
      LastModifiedDate: '{{ item.LastModifiedDate }}'
      ProjectName: '{{ item.ProjectName }}'
      PublishedBy: '{{ item.PublishedBy }}'
      PublishedDate: '{{ item.PublishedDate }}'
      Description: '{{ item.Description }}'
      Name: '{{ item.Name }}'
      ResourceArn: '{{ item.ResourceArn }}'
      Steps: '{{ item.Steps }}'
      Tags: '{{ item.Tags }}'
      RecipeVersion: '{{ item.RecipeVersion }}'
- discovery_id: aws.databrew.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Tags }}'
checks: []
