version: '1.0'
provider: aws
service: chime-sdk-media-pipelines
services:
  client: chime-sdk-media-pipelines
  module: boto3.client
discovery:
- discovery_id: aws.chime-sdk-media-pipelines.listMediaCapturePipelines
  calls:
  - action: listMediaCapturePipelines
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.MediaCapturePipelines }}'
    item:
      MediaPipelineId: '{{ item.MediaPipelineId }}'
      MediaPipelineArn: '{{ item.MediaPipelineArn }}'
- discovery_id: aws.chime-sdk-media-pipelines.listMediaInsightsPipelineConfigurations
  calls:
  - action: listMediaInsightsPipelineConfigurations
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.MediaInsightsPipelineConfigurations }}'
    item:
      MediaInsightsPipelineConfigurationName: '{{ item.MediaInsightsPipelineConfigurationName
        }}'
      MediaInsightsPipelineConfigurationId: '{{ item.MediaInsightsPipelineConfigurationId
        }}'
      MediaInsightsPipelineConfigurationArn: '{{ item.MediaInsightsPipelineConfigurationArn
        }}'
- discovery_id: aws.chime-sdk-media-pipelines.listMediaPipelineKinesisVideoStreamPools
  calls:
  - action: listMediaPipelineKinesisVideoStreamPools
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.KinesisVideoStreamPools }}'
    item:
      PoolName: '{{ item.PoolName }}'
      PoolId: '{{ item.PoolId }}'
      PoolArn: '{{ item.PoolArn }}'
- discovery_id: aws.chime-sdk-media-pipelines.listMediaPipelines
  calls:
  - action: listMediaPipelines
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.MediaPipelines }}'
    item:
      MediaPipelineId: '{{ item.MediaPipelineId }}'
      MediaPipelineArn: '{{ item.MediaPipelineArn }}'
- discovery_id: aws.chime-sdk-media-pipelines.getMediaCapturePipeline
  calls:
  - action: getMediaCapturePipeline
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.MediaCapturePipeline }}'
    item:
      MediaPipelineId: '{{ item.MediaPipelineId }}'
      MediaPipelineArn: '{{ item.MediaPipelineArn }}'
      SourceType: '{{ item.SourceType }}'
      SourceArn: '{{ item.SourceArn }}'
      Status: '{{ item.Status }}'
      SinkType: '{{ item.SinkType }}'
      SinkArn: '{{ item.SinkArn }}'
      CreatedTimestamp: '{{ item.CreatedTimestamp }}'
      UpdatedTimestamp: '{{ item.UpdatedTimestamp }}'
      ChimeSdkMeetingConfiguration: '{{ item.ChimeSdkMeetingConfiguration }}'
      SseAwsKeyManagementParams: '{{ item.SseAwsKeyManagementParams }}'
      SinkIamRoleArn: '{{ item.SinkIamRoleArn }}'
- discovery_id: aws.chime-sdk-media-pipelines.getMediaInsightsPipelineConfiguration
  calls:
  - action: getMediaInsightsPipelineConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.MediaInsightsPipelineConfiguration }}'
    item:
      MediaInsightsPipelineConfigurationName: '{{ item.MediaInsightsPipelineConfigurationName
        }}'
      MediaInsightsPipelineConfigurationArn: '{{ item.MediaInsightsPipelineConfigurationArn
        }}'
      ResourceAccessRoleArn: '{{ item.ResourceAccessRoleArn }}'
      RealTimeAlertConfiguration: '{{ item.RealTimeAlertConfiguration }}'
      Elements: '{{ item.Elements }}'
      MediaInsightsPipelineConfigurationId: '{{ item.MediaInsightsPipelineConfigurationId
        }}'
      CreatedTimestamp: '{{ item.CreatedTimestamp }}'
      UpdatedTimestamp: '{{ item.UpdatedTimestamp }}'
- discovery_id: aws.chime-sdk-media-pipelines.getMediaPipeline
  calls:
  - action: getMediaPipeline
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.MediaPipeline }}'
    item:
      MediaCapturePipeline: '{{ item.MediaCapturePipeline }}'
      MediaLiveConnectorPipeline: '{{ item.MediaLiveConnectorPipeline }}'
      MediaConcatenationPipeline: '{{ item.MediaConcatenationPipeline }}'
      MediaInsightsPipeline: '{{ item.MediaInsightsPipeline }}'
      MediaStreamPipeline: '{{ item.MediaStreamPipeline }}'
- discovery_id: aws.chime-sdk-media-pipelines.getMediaPipelineKinesisVideoStreamPool
  calls:
  - action: getMediaPipelineKinesisVideoStreamPool
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.KinesisVideoStreamPoolConfiguration }}'
    item:
      PoolArn: '{{ item.PoolArn }}'
      PoolName: '{{ item.PoolName }}'
      PoolId: '{{ item.PoolId }}'
      PoolStatus: '{{ item.PoolStatus }}'
      PoolSize: '{{ item.PoolSize }}'
      StreamConfiguration: '{{ item.StreamConfiguration }}'
      CreatedTimestamp: '{{ item.CreatedTimestamp }}'
      UpdatedTimestamp: '{{ item.UpdatedTimestamp }}'
- discovery_id: aws.chime-sdk-media-pipelines.getSpeakerSearchTask
  calls:
  - action: getSpeakerSearchTask
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.SpeakerSearchTask }}'
    item:
      SpeakerSearchTaskId: '{{ item.SpeakerSearchTaskId }}'
      SpeakerSearchTaskStatus: '{{ item.SpeakerSearchTaskStatus }}'
      CreatedTimestamp: '{{ item.CreatedTimestamp }}'
      UpdatedTimestamp: '{{ item.UpdatedTimestamp }}'
- discovery_id: aws.chime-sdk-media-pipelines.getVoiceToneAnalysisTask
  calls:
  - action: getVoiceToneAnalysisTask
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.VoiceToneAnalysisTask }}'
    item:
      VoiceToneAnalysisTaskId: '{{ item.VoiceToneAnalysisTaskId }}'
      VoiceToneAnalysisTaskStatus: '{{ item.VoiceToneAnalysisTaskStatus }}'
      CreatedTimestamp: '{{ item.CreatedTimestamp }}'
      UpdatedTimestamp: '{{ item.UpdatedTimestamp }}'
- discovery_id: aws.chime-sdk-media-pipelines.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Tags }}'
    item:
      Key: '{{ item.Key }}'
      Value: '{{ item.Value }}'
checks: []
