version: '1.0'
provider: aws
service: transfer
services:
  client: transfer
  module: boto3.client
discovery:
- discovery_id: aws.transfer.listCertificates
  calls:
  - action: listCertificates
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Certificates }}'
    item:
      Arn: '{{ item.Arn }}'
      CertificateId: '{{ item.CertificateId }}'
      Usage: '{{ item.Usage }}'
      Status: '{{ item.Status }}'
      ActiveDate: '{{ item.ActiveDate }}'
      InactiveDate: '{{ item.InactiveDate }}'
      Type: '{{ item.Type }}'
      Description: '{{ item.Description }}'
- discovery_id: aws.transfer.listConnectors
  calls:
  - action: listConnectors
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Connectors }}'
    item:
      Arn: '{{ item.Arn }}'
      ConnectorId: '{{ item.ConnectorId }}'
      Url: '{{ item.Url }}'
- discovery_id: aws.transfer.listProfiles
  calls:
  - action: listProfiles
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Profiles }}'
    item:
      Arn: '{{ item.Arn }}'
      ProfileId: '{{ item.ProfileId }}'
      As2Id: '{{ item.As2Id }}'
      ProfileType: '{{ item.ProfileType }}'
- discovery_id: aws.transfer.listSecurityPolicies
  calls:
  - action: listSecurityPolicies
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.SecurityPolicyNames }}'
- discovery_id: aws.transfer.listServers
  calls:
  - action: listServers
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Servers }}'
    item:
      Arn: '{{ item.Arn }}'
      Domain: '{{ item.Domain }}'
      IdentityProviderType: '{{ item.IdentityProviderType }}'
      EndpointType: '{{ item.EndpointType }}'
      LoggingRole: '{{ item.LoggingRole }}'
      ServerId: '{{ item.ServerId }}'
      State: '{{ item.State }}'
      UserCount: '{{ item.UserCount }}'
- discovery_id: aws.transfer.listWebApps
  calls:
  - action: listWebApps
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.WebApps }}'
    item:
      Arn: '{{ item.Arn }}'
      WebAppId: '{{ item.WebAppId }}'
      AccessEndpoint: '{{ item.AccessEndpoint }}'
      WebAppEndpoint: '{{ item.WebAppEndpoint }}'
      EndpointType: '{{ item.EndpointType }}'
- discovery_id: aws.transfer.listWorkflows
  calls:
  - action: listWorkflows
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Workflows }}'
    item:
      WorkflowId: '{{ item.WorkflowId }}'
      Description: '{{ item.Description }}'
      Arn: '{{ item.Arn }}'
- discovery_id: aws.transfer.describeAccess
  calls:
  - action: describeAccess
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Access }}'
    item:
      HomeDirectory: '{{ item.HomeDirectory }}'
      HomeDirectoryMappings: '{{ item.HomeDirectoryMappings }}'
      HomeDirectoryType: '{{ item.HomeDirectoryType }}'
      Policy: '{{ item.Policy }}'
      PosixProfile: '{{ item.PosixProfile }}'
      Role: '{{ item.Role }}'
      ExternalId: '{{ item.ExternalId }}'
- discovery_id: aws.transfer.describeAgreement
  calls:
  - action: describeAgreement
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Agreement }}'
    item:
      Arn: '{{ item.Arn }}'
      AgreementId: '{{ item.AgreementId }}'
      Description: '{{ item.Description }}'
      Status: '{{ item.Status }}'
      ServerId: '{{ item.ServerId }}'
      LocalProfileId: '{{ item.LocalProfileId }}'
      PartnerProfileId: '{{ item.PartnerProfileId }}'
      BaseDirectory: '{{ item.BaseDirectory }}'
      AccessRole: '{{ item.AccessRole }}'
      Tags: '{{ item.Tags }}'
      PreserveFilename: '{{ item.PreserveFilename }}'
      EnforceMessageSigning: '{{ item.EnforceMessageSigning }}'
      CustomDirectories: '{{ item.CustomDirectories }}'
- discovery_id: aws.transfer.describeCertificate
  calls:
  - action: describeCertificate
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Certificate }}'
    item:
      Arn: '{{ item.Arn }}'
      CertificateId: '{{ item.CertificateId }}'
      Usage: '{{ item.Usage }}'
      Status: '{{ item.Status }}'
      Certificate: '{{ item.Certificate }}'
      CertificateChain: '{{ item.CertificateChain }}'
      ActiveDate: '{{ item.ActiveDate }}'
      InactiveDate: '{{ item.InactiveDate }}'
      Serial: '{{ item.Serial }}'
      NotBeforeDate: '{{ item.NotBeforeDate }}'
      NotAfterDate: '{{ item.NotAfterDate }}'
      Type: '{{ item.Type }}'
      Description: '{{ item.Description }}'
      Tags: '{{ item.Tags }}'
- discovery_id: aws.transfer.describeConnector
  calls:
  - action: describeConnector
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Connector }}'
    item:
      Arn: '{{ item.Arn }}'
      ConnectorId: '{{ item.ConnectorId }}'
      Url: '{{ item.Url }}'
      As2Config: '{{ item.As2Config }}'
      AccessRole: '{{ item.AccessRole }}'
      LoggingRole: '{{ item.LoggingRole }}'
      Tags: '{{ item.Tags }}'
      SftpConfig: '{{ item.SftpConfig }}'
      ServiceManagedEgressIpAddresses: '{{ item.ServiceManagedEgressIpAddresses }}'
      SecurityPolicyName: '{{ item.SecurityPolicyName }}'
      EgressConfig: '{{ item.EgressConfig }}'
      EgressType: '{{ item.EgressType }}'
      ErrorMessage: '{{ item.ErrorMessage }}'
      Status: '{{ item.Status }}'
- discovery_id: aws.transfer.describeExecution
  calls:
  - action: describeExecution
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Execution }}'
    item:
      ExecutionId: '{{ item.ExecutionId }}'
      InitialFileLocation: '{{ item.InitialFileLocation }}'
      ServiceMetadata: '{{ item.ServiceMetadata }}'
      ExecutionRole: '{{ item.ExecutionRole }}'
      LoggingConfiguration: '{{ item.LoggingConfiguration }}'
      PosixProfile: '{{ item.PosixProfile }}'
      Status: '{{ item.Status }}'
      Results: '{{ item.Results }}'
- discovery_id: aws.transfer.describeHostKey
  calls:
  - action: describeHostKey
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.HostKey }}'
    item:
      Arn: '{{ item.Arn }}'
      HostKeyId: '{{ item.HostKeyId }}'
      HostKeyFingerprint: '{{ item.HostKeyFingerprint }}'
      Description: '{{ item.Description }}'
      Type: '{{ item.Type }}'
      DateImported: '{{ item.DateImported }}'
      Tags: '{{ item.Tags }}'
- discovery_id: aws.transfer.describeProfile
  calls:
  - action: describeProfile
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Profile }}'
    item:
      Arn: '{{ item.Arn }}'
      ProfileId: '{{ item.ProfileId }}'
      ProfileType: '{{ item.ProfileType }}'
      As2Id: '{{ item.As2Id }}'
      CertificateIds: '{{ item.CertificateIds }}'
      Tags: '{{ item.Tags }}'
- discovery_id: aws.transfer.describeSecurityPolicy
  calls:
  - action: describeSecurityPolicy
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.SecurityPolicy }}'
    item:
      Fips: '{{ item.Fips }}'
      SecurityPolicyName: '{{ item.SecurityPolicyName }}'
      SshCiphers: '{{ item.SshCiphers }}'
      SshKexs: '{{ item.SshKexs }}'
      SshMacs: '{{ item.SshMacs }}'
      TlsCiphers: '{{ item.TlsCiphers }}'
      SshHostKeyAlgorithms: '{{ item.SshHostKeyAlgorithms }}'
      Type: '{{ item.Type }}'
      Protocols: '{{ item.Protocols }}'
- discovery_id: aws.transfer.describeServer
  calls:
  - action: describeServer
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Server }}'
    item:
      Arn: '{{ item.Arn }}'
      Certificate: '{{ item.Certificate }}'
      ProtocolDetails: '{{ item.ProtocolDetails }}'
      Domain: '{{ item.Domain }}'
      EndpointDetails: '{{ item.EndpointDetails }}'
      EndpointType: '{{ item.EndpointType }}'
      HostKeyFingerprint: '{{ item.HostKeyFingerprint }}'
      IdentityProviderDetails: '{{ item.IdentityProviderDetails }}'
      IdentityProviderType: '{{ item.IdentityProviderType }}'
      LoggingRole: '{{ item.LoggingRole }}'
      PostAuthenticationLoginBanner: '{{ item.PostAuthenticationLoginBanner }}'
      PreAuthenticationLoginBanner: '{{ item.PreAuthenticationLoginBanner }}'
      Protocols: '{{ item.Protocols }}'
      SecurityPolicyName: '{{ item.SecurityPolicyName }}'
      ServerId: '{{ item.ServerId }}'
      State: '{{ item.State }}'
      Tags: '{{ item.Tags }}'
      UserCount: '{{ item.UserCount }}'
      WorkflowDetails: '{{ item.WorkflowDetails }}'
      StructuredLogDestinations: '{{ item.StructuredLogDestinations }}'
      S3StorageOptions: '{{ item.S3StorageOptions }}'
      As2ServiceManagedEgressIpAddresses: '{{ item.As2ServiceManagedEgressIpAddresses
        }}'
      IpAddressType: '{{ item.IpAddressType }}'
- discovery_id: aws.transfer.describeUser
  calls:
  - action: describeUser
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.User }}'
    item:
      Arn: '{{ item.Arn }}'
      HomeDirectory: '{{ item.HomeDirectory }}'
      HomeDirectoryMappings: '{{ item.HomeDirectoryMappings }}'
      HomeDirectoryType: '{{ item.HomeDirectoryType }}'
      Policy: '{{ item.Policy }}'
      PosixProfile: '{{ item.PosixProfile }}'
      Role: '{{ item.Role }}'
      SshPublicKeys: '{{ item.SshPublicKeys }}'
      Tags: '{{ item.Tags }}'
      UserName: '{{ item.UserName }}'
- discovery_id: aws.transfer.describeWebApp
  calls:
  - action: describeWebApp
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.WebApp }}'
    item:
      Arn: '{{ item.Arn }}'
      WebAppId: '{{ item.WebAppId }}'
      DescribedIdentityProviderDetails: '{{ item.DescribedIdentityProviderDetails
        }}'
      AccessEndpoint: '{{ item.AccessEndpoint }}'
      WebAppEndpoint: '{{ item.WebAppEndpoint }}'
      WebAppUnits: '{{ item.WebAppUnits }}'
      Tags: '{{ item.Tags }}'
      WebAppEndpointPolicy: '{{ item.WebAppEndpointPolicy }}'
      EndpointType: '{{ item.EndpointType }}'
      DescribedEndpointDetails: '{{ item.DescribedEndpointDetails }}'
- discovery_id: aws.transfer.describeWebAppCustomization
  calls:
  - action: describeWebAppCustomization
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.WebAppCustomization }}'
    item:
      Arn: '{{ item.Arn }}'
      WebAppId: '{{ item.WebAppId }}'
      Title: '{{ item.Title }}'
      LogoFile: '{{ item.LogoFile }}'
      FaviconFile: '{{ item.FaviconFile }}'
- discovery_id: aws.transfer.describeWorkflow
  calls:
  - action: describeWorkflow
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Workflow }}'
    item:
      Arn: '{{ item.Arn }}'
      Description: '{{ item.Description }}'
      Steps: '{{ item.Steps }}'
      OnExceptionSteps: '{{ item.OnExceptionSteps }}'
      WorkflowId: '{{ item.WorkflowId }}'
      Tags: '{{ item.Tags }}'
- discovery_id: aws.transfer.listAccesses
  calls:
  - action: listAccesses
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Accesses }}'
    item:
      HomeDirectory: '{{ item.HomeDirectory }}'
      HomeDirectoryType: '{{ item.HomeDirectoryType }}'
      Role: '{{ item.Role }}'
      ExternalId: '{{ item.ExternalId }}'
- discovery_id: aws.transfer.listAgreements
  calls:
  - action: listAgreements
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Agreements }}'
    item:
      Arn: '{{ item.Arn }}'
      AgreementId: '{{ item.AgreementId }}'
      Description: '{{ item.Description }}'
      Status: '{{ item.Status }}'
      ServerId: '{{ item.ServerId }}'
      LocalProfileId: '{{ item.LocalProfileId }}'
      PartnerProfileId: '{{ item.PartnerProfileId }}'
- discovery_id: aws.transfer.listExecutions
  calls:
  - action: listExecutions
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Executions }}'
    item:
      ExecutionId: '{{ item.ExecutionId }}'
      InitialFileLocation: '{{ item.InitialFileLocation }}'
      ServiceMetadata: '{{ item.ServiceMetadata }}'
      Status: '{{ item.Status }}'
- discovery_id: aws.transfer.listFileTransferResults
  calls:
  - action: listFileTransferResults
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.FileTransferResults }}'
    item:
      FilePath: '{{ item.FilePath }}'
      StatusCode: '{{ item.StatusCode }}'
      FailureCode: '{{ item.FailureCode }}'
      FailureMessage: '{{ item.FailureMessage }}'
- discovery_id: aws.transfer.listHostKeys
  calls:
  - action: listHostKeys
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.HostKeys }}'
    item:
      Arn: '{{ item.Arn }}'
      HostKeyId: '{{ item.HostKeyId }}'
      Fingerprint: '{{ item.Fingerprint }}'
      Description: '{{ item.Description }}'
      Type: '{{ item.Type }}'
      DateImported: '{{ item.DateImported }}'
- discovery_id: aws.transfer.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Tags }}'
    item:
      Key: '{{ item.Key }}'
      Value: '{{ item.Value }}'
- discovery_id: aws.transfer.listUsers
  calls:
  - action: listUsers
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Users }}'
    item:
      Arn: '{{ item.Arn }}'
      HomeDirectory: '{{ item.HomeDirectory }}'
      HomeDirectoryType: '{{ item.HomeDirectoryType }}'
      Role: '{{ item.Role }}'
      SshPublicKeyCount: '{{ item.SshPublicKeyCount }}'
      UserName: '{{ item.UserName }}'
checks: []
