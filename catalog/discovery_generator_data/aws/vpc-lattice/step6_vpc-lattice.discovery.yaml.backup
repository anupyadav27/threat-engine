version: '1.0'
provider: aws
service: vpc-lattice
services:
  client: vpc-lattice
  module: boto3.client
discovery:
- discovery_id: aws.vpc-lattice.listDomainVerifications
  calls:
  - action: listDomainVerifications
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
    item:
      id: '{{ item.id }}'
      arn: '{{ item.arn }}'
      domainName: '{{ item.domainName }}'
      status: '{{ item.status }}'
      txtMethodConfig: '{{ item.txtMethodConfig }}'
      createdAt: '{{ item.createdAt }}'
      lastVerifiedTime: '{{ item.lastVerifiedTime }}'
      tags: '{{ item.tags }}'
- discovery_id: aws.vpc-lattice.listResourceConfigurations
  calls:
  - action: listResourceConfigurations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
    item:
      id: '{{ item.id }}'
      name: '{{ item.name }}'
      arn: '{{ item.arn }}'
      resourceGatewayId: '{{ item.resourceGatewayId }}'
      resourceConfigurationGroupId: '{{ item.resourceConfigurationGroupId }}'
      type: '{{ item.type }}'
      status: '{{ item.status }}'
      amazonManaged: '{{ item.amazonManaged }}'
      createdAt: '{{ item.createdAt }}'
      lastUpdatedAt: '{{ item.lastUpdatedAt }}'
      customDomainName: '{{ item.customDomainName }}'
      domainVerificationId: '{{ item.domainVerificationId }}'
      groupDomain: '{{ item.groupDomain }}'
- discovery_id: aws.vpc-lattice.listResourceGateways
  calls:
  - action: listResourceGateways
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
    item:
      name: '{{ item.name }}'
      id: '{{ item.id }}'
      arn: '{{ item.arn }}'
      status: '{{ item.status }}'
      vpcIdentifier: '{{ item.vpcIdentifier }}'
      subnetIds: '{{ item.subnetIds }}'
      securityGroupIds: '{{ item.securityGroupIds }}'
      ipAddressType: '{{ item.ipAddressType }}'
      ipv4AddressesPerEni: '{{ item.ipv4AddressesPerEni }}'
      createdAt: '{{ item.createdAt }}'
      lastUpdatedAt: '{{ item.lastUpdatedAt }}'
- discovery_id: aws.vpc-lattice.listServiceNetworkResourceAssociations
  calls:
  - action: listServiceNetworkResourceAssociations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
    item:
      id: '{{ item.id }}'
      arn: '{{ item.arn }}'
      status: '{{ item.status }}'
      createdBy: '{{ item.createdBy }}'
      createdAt: '{{ item.createdAt }}'
      resourceConfigurationId: '{{ item.resourceConfigurationId }}'
      resourceConfigurationArn: '{{ item.resourceConfigurationArn }}'
      resourceConfigurationName: '{{ item.resourceConfigurationName }}'
      serviceNetworkId: '{{ item.serviceNetworkId }}'
      serviceNetworkArn: '{{ item.serviceNetworkArn }}'
      serviceNetworkName: '{{ item.serviceNetworkName }}'
      dnsEntry: '{{ item.dnsEntry }}'
      privateDnsEntry: '{{ item.privateDnsEntry }}'
      isManagedAssociation: '{{ item.isManagedAssociation }}'
      failureCode: '{{ item.failureCode }}'
      privateDnsEnabled: '{{ item.privateDnsEnabled }}'
- discovery_id: aws.vpc-lattice.listServiceNetworkServiceAssociations
  calls:
  - action: listServiceNetworkServiceAssociations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
    item:
      id: '{{ item.id }}'
      status: '{{ item.status }}'
      arn: '{{ item.arn }}'
      createdBy: '{{ item.createdBy }}'
      createdAt: '{{ item.createdAt }}'
      serviceId: '{{ item.serviceId }}'
      serviceName: '{{ item.serviceName }}'
      serviceArn: '{{ item.serviceArn }}'
      serviceNetworkId: '{{ item.serviceNetworkId }}'
      serviceNetworkName: '{{ item.serviceNetworkName }}'
      serviceNetworkArn: '{{ item.serviceNetworkArn }}'
      dnsEntry: '{{ item.dnsEntry }}'
      customDomainName: '{{ item.customDomainName }}'
- discovery_id: aws.vpc-lattice.listServiceNetworkVpcAssociations
  calls:
  - action: listServiceNetworkVpcAssociations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
    item:
      id: '{{ item.id }}'
      arn: '{{ item.arn }}'
      status: '{{ item.status }}'
      createdBy: '{{ item.createdBy }}'
      createdAt: '{{ item.createdAt }}'
      serviceNetworkId: '{{ item.serviceNetworkId }}'
      serviceNetworkName: '{{ item.serviceNetworkName }}'
      serviceNetworkArn: '{{ item.serviceNetworkArn }}'
      privateDnsEnabled: '{{ item.privateDnsEnabled }}'
      dnsOptions: '{{ item.dnsOptions }}'
      vpcId: '{{ item.vpcId }}'
      lastUpdatedAt: '{{ item.lastUpdatedAt }}'
- discovery_id: aws.vpc-lattice.listServiceNetworks
  calls:
  - action: listServiceNetworks
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
    item:
      id: '{{ item.id }}'
      name: '{{ item.name }}'
      arn: '{{ item.arn }}'
      createdAt: '{{ item.createdAt }}'
      lastUpdatedAt: '{{ item.lastUpdatedAt }}'
      numberOfAssociatedVPCs: '{{ item.numberOfAssociatedVPCs }}'
      numberOfAssociatedServices: '{{ item.numberOfAssociatedServices }}'
      numberOfAssociatedResourceConfigurations: '{{ item.numberOfAssociatedResourceConfigurations
        }}'
- discovery_id: aws.vpc-lattice.listServices
  calls:
  - action: listServices
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
    item:
      id: '{{ item.id }}'
      name: '{{ item.name }}'
      arn: '{{ item.arn }}'
      createdAt: '{{ item.createdAt }}'
      lastUpdatedAt: '{{ item.lastUpdatedAt }}'
      dnsEntry: '{{ item.dnsEntry }}'
      customDomainName: '{{ item.customDomainName }}'
      status: '{{ item.status }}'
- discovery_id: aws.vpc-lattice.listTargetGroups
  calls:
  - action: listTargetGroups
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
    item:
      id: '{{ item.id }}'
      arn: '{{ item.arn }}'
      name: '{{ item.name }}'
      type: '{{ item.type }}'
      createdAt: '{{ item.createdAt }}'
      port: '{{ item.port }}'
      protocol: '{{ item.protocol }}'
      ipAddressType: '{{ item.ipAddressType }}'
      vpcIdentifier: '{{ item.vpcIdentifier }}'
      lastUpdatedAt: '{{ item.lastUpdatedAt }}'
      status: '{{ item.status }}'
      serviceArns: '{{ item.serviceArns }}'
      lambdaEventStructureVersion: '{{ item.lambdaEventStructureVersion }}'
- discovery_id: aws.vpc-lattice.getAccessLogSubscription
  calls:
  - action: getAccessLogSubscription
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.id }}'
- discovery_id: aws.vpc-lattice.getAuthPolicy
  calls:
  - action: getAuthPolicy
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.policy }}'
- discovery_id: aws.vpc-lattice.getDomainVerification
  calls:
  - action: getDomainVerification
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.txtMethodConfig }}'
    item:
      value: '{{ item.value }}'
      name: '{{ item.name }}'
- discovery_id: aws.vpc-lattice.getListener
  calls:
  - action: getListener
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.defaultAction }}'
    item:
      forward: '{{ item.forward }}'
      fixedResponse: '{{ item.fixedResponse }}'
- discovery_id: aws.vpc-lattice.getResourceConfiguration
  calls:
  - action: getResourceConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.portRanges }}'
- discovery_id: aws.vpc-lattice.getResourceGateway
  calls:
  - action: getResourceGateway
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.subnetIds }}'
- discovery_id: aws.vpc-lattice.getResourcePolicy
  calls:
  - action: getResourcePolicy
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.policy }}'
- discovery_id: aws.vpc-lattice.getRule
  calls:
  - action: getRule
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.match }}'
    item:
      httpMatch: '{{ item.httpMatch }}'
- discovery_id: aws.vpc-lattice.getService
  calls:
  - action: getService
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.dnsEntry }}'
    item:
      domainName: '{{ item.domainName }}'
      hostedZoneId: '{{ item.hostedZoneId }}'
- discovery_id: aws.vpc-lattice.getServiceNetwork
  calls:
  - action: getServiceNetwork
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.sharingConfig }}'
    item:
      enabled: '{{ item.enabled }}'
- discovery_id: aws.vpc-lattice.getServiceNetworkResourceAssociation
  calls:
  - action: getServiceNetworkResourceAssociation
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.privateDnsEntry }}'
    item:
      domainName: '{{ item.domainName }}'
      hostedZoneId: '{{ item.hostedZoneId }}'
- discovery_id: aws.vpc-lattice.getServiceNetworkServiceAssociation
  calls:
  - action: getServiceNetworkServiceAssociation
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.dnsEntry }}'
    item:
      domainName: '{{ item.domainName }}'
      hostedZoneId: '{{ item.hostedZoneId }}'
- discovery_id: aws.vpc-lattice.getServiceNetworkVpcAssociation
  calls:
  - action: getServiceNetworkVpcAssociation
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.securityGroupIds }}'
- discovery_id: aws.vpc-lattice.getTargetGroup
  calls:
  - action: getTargetGroup
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.serviceArns }}'
- discovery_id: aws.vpc-lattice.listAccessLogSubscriptions
  calls:
  - action: listAccessLogSubscriptions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
    item:
      id: '{{ item.id }}'
      arn: '{{ item.arn }}'
      resourceId: '{{ item.resourceId }}'
      resourceArn: '{{ item.resourceArn }}'
      destinationArn: '{{ item.destinationArn }}'
      serviceNetworkLogType: '{{ item.serviceNetworkLogType }}'
      createdAt: '{{ item.createdAt }}'
      lastUpdatedAt: '{{ item.lastUpdatedAt }}'
- discovery_id: aws.vpc-lattice.listListeners
  calls:
  - action: listListeners
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
    item:
      arn: '{{ item.arn }}'
      id: '{{ item.id }}'
      name: '{{ item.name }}'
      protocol: '{{ item.protocol }}'
      port: '{{ item.port }}'
      createdAt: '{{ item.createdAt }}'
      lastUpdatedAt: '{{ item.lastUpdatedAt }}'
- discovery_id: aws.vpc-lattice.listResourceEndpointAssociations
  calls:
  - action: listResourceEndpointAssociations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
    item:
      id: '{{ item.id }}'
      arn: '{{ item.arn }}'
      resourceConfigurationId: '{{ item.resourceConfigurationId }}'
      resourceConfigurationArn: '{{ item.resourceConfigurationArn }}'
      resourceConfigurationName: '{{ item.resourceConfigurationName }}'
      vpcEndpointId: '{{ item.vpcEndpointId }}'
      vpcEndpointOwner: '{{ item.vpcEndpointOwner }}'
      createdBy: '{{ item.createdBy }}'
      createdAt: '{{ item.createdAt }}'
- discovery_id: aws.vpc-lattice.listRules
  calls:
  - action: listRules
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
    item:
      arn: '{{ item.arn }}'
      id: '{{ item.id }}'
      name: '{{ item.name }}'
      isDefault: '{{ item.isDefault }}'
      priority: '{{ item.priority }}'
      createdAt: '{{ item.createdAt }}'
      lastUpdatedAt: '{{ item.lastUpdatedAt }}'
- discovery_id: aws.vpc-lattice.listServiceNetworkVpcEndpointAssociations
  calls:
  - action: listServiceNetworkVpcEndpointAssociations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
    item:
      vpcEndpointId: '{{ item.vpcEndpointId }}'
      vpcId: '{{ item.vpcId }}'
      vpcEndpointOwnerId: '{{ item.vpcEndpointOwnerId }}'
      id: '{{ item.id }}'
      state: '{{ item.state }}'
      serviceNetworkArn: '{{ item.serviceNetworkArn }}'
      createdAt: '{{ item.createdAt }}'
- discovery_id: aws.vpc-lattice.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tags }}'
- discovery_id: aws.vpc-lattice.listTargets
  calls:
  - action: listTargets
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
    item:
      id: '{{ item.id }}'
      port: '{{ item.port }}'
      status: '{{ item.status }}'
      reasonCode: '{{ item.reasonCode }}'
checks: []
