version: '1.0'
provider: aws
service: workdocs
services:
  client: workdocs
  module: boto3.client
discovery:
- discovery_id: aws.workdocs.describeActivities
  calls:
  - action: describeActivities
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.UserActivities }}'
    item:
      Type: '{{ item.Type }}'
      TimeStamp: '{{ item.TimeStamp }}'
      IsIndirectActivity: '{{ item.IsIndirectActivity }}'
      OrganizationId: '{{ item.OrganizationId }}'
      Initiator: '{{ item.Initiator }}'
      Participants: '{{ item.Participants }}'
      ResourceMetadata: '{{ item.ResourceMetadata }}'
      OriginalParent: '{{ item.OriginalParent }}'
      CommentMetadata: '{{ item.CommentMetadata }}'
- discovery_id: aws.workdocs.describeUsers
  calls:
  - action: describeUsers
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Users }}'
    item:
      Id: '{{ item.Id }}'
      Username: '{{ item.Username }}'
      EmailAddress: '{{ item.EmailAddress }}'
      GivenName: '{{ item.GivenName }}'
      Surname: '{{ item.Surname }}'
      OrganizationId: '{{ item.OrganizationId }}'
      RootFolderId: '{{ item.RootFolderId }}'
      RecycleBinFolderId: '{{ item.RecycleBinFolderId }}'
      Status: '{{ item.Status }}'
      Type: '{{ item.Type }}'
      CreatedTimestamp: '{{ item.CreatedTimestamp }}'
      ModifiedTimestamp: '{{ item.ModifiedTimestamp }}'
      TimeZoneId: '{{ item.TimeZoneId }}'
      Locale: '{{ item.Locale }}'
      Storage: '{{ item.Storage }}'
- discovery_id: aws.workdocs.getResources
  calls:
  - action: getResources
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Folders }}'
    item:
      Id: '{{ item.Id }}'
      Name: '{{ item.Name }}'
      CreatorId: '{{ item.CreatorId }}'
      ParentFolderId: '{{ item.ParentFolderId }}'
      CreatedTimestamp: '{{ item.CreatedTimestamp }}'
      ModifiedTimestamp: '{{ item.ModifiedTimestamp }}'
      ResourceState: '{{ item.ResourceState }}'
      Signature: '{{ item.Signature }}'
      Labels: '{{ item.Labels }}'
      Size: '{{ item.Size }}'
      LatestVersionSize: '{{ item.LatestVersionSize }}'
- discovery_id: aws.workdocs.searchResources
  calls:
  - action: searchResources
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Items }}'
    item:
      ResourceType: '{{ item.ResourceType }}'
      WebUrl: '{{ item.WebUrl }}'
      DocumentMetadata: '{{ item.DocumentMetadata }}'
      FolderMetadata: '{{ item.FolderMetadata }}'
      CommentMetadata: '{{ item.CommentMetadata }}'
      DocumentVersionMetadata: '{{ item.DocumentVersionMetadata }}'
- discovery_id: aws.workdocs.describeComments
  calls:
  - action: describeComments
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Comments }}'
    item:
      CommentId: '{{ item.CommentId }}'
      ParentId: '{{ item.ParentId }}'
      ThreadId: '{{ item.ThreadId }}'
      Text: '{{ item.Text }}'
      Contributor: '{{ item.Contributor }}'
      CreatedTimestamp: '{{ item.CreatedTimestamp }}'
      Status: '{{ item.Status }}'
      Visibility: '{{ item.Visibility }}'
      RecipientId: '{{ item.RecipientId }}'
- discovery_id: aws.workdocs.describeDocumentVersions
  calls:
  - action: describeDocumentVersions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.DocumentVersions }}'
    item:
      Id: '{{ item.Id }}'
      Name: '{{ item.Name }}'
      ContentType: '{{ item.ContentType }}'
      Size: '{{ item.Size }}'
      Signature: '{{ item.Signature }}'
      Status: '{{ item.Status }}'
      CreatedTimestamp: '{{ item.CreatedTimestamp }}'
      ModifiedTimestamp: '{{ item.ModifiedTimestamp }}'
      ContentCreatedTimestamp: '{{ item.ContentCreatedTimestamp }}'
      ContentModifiedTimestamp: '{{ item.ContentModifiedTimestamp }}'
      CreatorId: '{{ item.CreatorId }}'
      Thumbnail: '{{ item.Thumbnail }}'
      Source: '{{ item.Source }}'
- discovery_id: aws.workdocs.describeFolderContents
  calls:
  - action: describeFolderContents
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Folders }}'
    item:
      Id: '{{ item.Id }}'
      Name: '{{ item.Name }}'
      CreatorId: '{{ item.CreatorId }}'
      ParentFolderId: '{{ item.ParentFolderId }}'
      CreatedTimestamp: '{{ item.CreatedTimestamp }}'
      ModifiedTimestamp: '{{ item.ModifiedTimestamp }}'
      ResourceState: '{{ item.ResourceState }}'
      Signature: '{{ item.Signature }}'
      Labels: '{{ item.Labels }}'
      Size: '{{ item.Size }}'
      LatestVersionSize: '{{ item.LatestVersionSize }}'
- discovery_id: aws.workdocs.describeGroups
  calls:
  - action: describeGroups
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Groups }}'
    item:
      Id: '{{ item.Id }}'
      Name: '{{ item.Name }}'
- discovery_id: aws.workdocs.describeNotificationSubscriptions
  calls:
  - action: describeNotificationSubscriptions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Subscriptions }}'
    item:
      SubscriptionId: '{{ item.SubscriptionId }}'
      EndPoint: '{{ item.EndPoint }}'
      Protocol: '{{ item.Protocol }}'
- discovery_id: aws.workdocs.describeResourcePermissions
  calls:
  - action: describeResourcePermissions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Principals }}'
    item:
      Id: '{{ item.Id }}'
      Type: '{{ item.Type }}'
      Roles: '{{ item.Roles }}'
- discovery_id: aws.workdocs.describeRootFolders
  calls:
  - action: describeRootFolders
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Folders }}'
    item:
      Id: '{{ item.Id }}'
      Name: '{{ item.Name }}'
      CreatorId: '{{ item.CreatorId }}'
      ParentFolderId: '{{ item.ParentFolderId }}'
      CreatedTimestamp: '{{ item.CreatedTimestamp }}'
      ModifiedTimestamp: '{{ item.ModifiedTimestamp }}'
      ResourceState: '{{ item.ResourceState }}'
      Signature: '{{ item.Signature }}'
      Labels: '{{ item.Labels }}'
      Size: '{{ item.Size }}'
      LatestVersionSize: '{{ item.LatestVersionSize }}'
- discovery_id: aws.workdocs.getCurrentUser
  calls:
  - action: getCurrentUser
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.User }}'
    item:
      Id: '{{ item.Id }}'
      Username: '{{ item.Username }}'
      EmailAddress: '{{ item.EmailAddress }}'
      GivenName: '{{ item.GivenName }}'
      Surname: '{{ item.Surname }}'
      OrganizationId: '{{ item.OrganizationId }}'
      RootFolderId: '{{ item.RootFolderId }}'
      RecycleBinFolderId: '{{ item.RecycleBinFolderId }}'
      Status: '{{ item.Status }}'
      Type: '{{ item.Type }}'
      CreatedTimestamp: '{{ item.CreatedTimestamp }}'
      ModifiedTimestamp: '{{ item.ModifiedTimestamp }}'
      TimeZoneId: '{{ item.TimeZoneId }}'
      Locale: '{{ item.Locale }}'
      Storage: '{{ item.Storage }}'
- discovery_id: aws.workdocs.getDocument
  calls:
  - action: getDocument
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Metadata }}'
    item:
      Id: '{{ item.Id }}'
      CreatorId: '{{ item.CreatorId }}'
      ParentFolderId: '{{ item.ParentFolderId }}'
      CreatedTimestamp: '{{ item.CreatedTimestamp }}'
      ModifiedTimestamp: '{{ item.ModifiedTimestamp }}'
      LatestVersionMetadata: '{{ item.LatestVersionMetadata }}'
      ResourceState: '{{ item.ResourceState }}'
      Labels: '{{ item.Labels }}'
- discovery_id: aws.workdocs.getDocumentPath
  calls:
  - action: getDocumentPath
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Path }}'
    item:
      Components: '{{ item.Components }}'
- discovery_id: aws.workdocs.getDocumentVersion
  calls:
  - action: getDocumentVersion
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Metadata }}'
    item:
      Id: '{{ item.Id }}'
      Name: '{{ item.Name }}'
      ContentType: '{{ item.ContentType }}'
      Size: '{{ item.Size }}'
      Signature: '{{ item.Signature }}'
      Status: '{{ item.Status }}'
      CreatedTimestamp: '{{ item.CreatedTimestamp }}'
      ModifiedTimestamp: '{{ item.ModifiedTimestamp }}'
      ContentCreatedTimestamp: '{{ item.ContentCreatedTimestamp }}'
      ContentModifiedTimestamp: '{{ item.ContentModifiedTimestamp }}'
      CreatorId: '{{ item.CreatorId }}'
      Thumbnail: '{{ item.Thumbnail }}'
      Source: '{{ item.Source }}'
- discovery_id: aws.workdocs.getFolder
  calls:
  - action: getFolder
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Metadata }}'
    item:
      Id: '{{ item.Id }}'
      Name: '{{ item.Name }}'
      CreatorId: '{{ item.CreatorId }}'
      ParentFolderId: '{{ item.ParentFolderId }}'
      CreatedTimestamp: '{{ item.CreatedTimestamp }}'
      ModifiedTimestamp: '{{ item.ModifiedTimestamp }}'
      ResourceState: '{{ item.ResourceState }}'
      Signature: '{{ item.Signature }}'
      Labels: '{{ item.Labels }}'
      Size: '{{ item.Size }}'
      LatestVersionSize: '{{ item.LatestVersionSize }}'
- discovery_id: aws.workdocs.getFolderPath
  calls:
  - action: getFolderPath
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Path }}'
    item:
      Components: '{{ item.Components }}'
checks: []
