{
  "service": "appconfigdata",
  "seed_from_list": [
    "Enabled",
    "Status"
  ],
  "enriched_from_get_describe": [
    "Configuration",
    "ContentType",
    "NextPollConfigurationToken",
    "NextPollIntervalInSeconds",
    "VersionLabel"
  ],
  "fields": {},
  "field_mappings": {},
  "source": {
    "operation_registry": "services/appconfigdata/operation_registry.json",
    "read_ops_rule": "operation name startswith List/Get/Describe/Search/Lookup",
    "excluded_keys": [
      "nextToken",
      "maxResults"
    ]
  },
  "param_source_map": {},
  "response_emit_map": {
    "GetLatestConfiguration": {
      "emit_style": "flat",
      "response_fields": [
        "NextPollConfigurationToken",
        "NextPollIntervalInSeconds",
        "ContentType",
        "VersionLabel"
      ],
      "field_type": "scalar",
      "note": "Flat emit \u2014 access top-level response fields directly"
    }
  }
}