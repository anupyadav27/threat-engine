version: '1.0'
provider: aws
service: ds-data
services:
  client: ds-data
  module: boto3.client
discovery:
- discovery_id: aws.ds-data.describeGroup
  calls:
  - action: describeGroup
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.DirectoryId }}'
- discovery_id: aws.ds-data.describeUser
  calls:
  - action: describeUser
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.DirectoryId }}'
- discovery_id: aws.ds-data.listGroupMembers
  calls:
  - action: listGroupMembers
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Members }}'
    item:
      MemberType: '{{ item.MemberType }}'
      SAMAccountName: '{{ item.SAMAccountName }}'
      SID: '{{ item.SID }}'
- discovery_id: aws.ds-data.listGroups
  calls:
  - action: listGroups
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Groups }}'
    item:
      GroupScope: '{{ item.GroupScope }}'
      GroupType: '{{ item.GroupType }}'
      SAMAccountName: '{{ item.SAMAccountName }}'
      SID: '{{ item.SID }}'
- discovery_id: aws.ds-data.listGroupsForMember
  calls:
  - action: listGroupsForMember
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Groups }}'
    item:
      GroupScope: '{{ item.GroupScope }}'
      GroupType: '{{ item.GroupType }}'
      SAMAccountName: '{{ item.SAMAccountName }}'
      SID: '{{ item.SID }}'
- discovery_id: aws.ds-data.listUsers
  calls:
  - action: listUsers
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Users }}'
    item:
      Enabled: '{{ item.Enabled }}'
      GivenName: '{{ item.GivenName }}'
      SAMAccountName: '{{ item.SAMAccountName }}'
      SID: '{{ item.SID }}'
      Surname: '{{ item.Surname }}'
- discovery_id: aws.ds-data.searchGroups
  calls:
  - action: searchGroups
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Groups }}'
    item:
      DistinguishedName: '{{ item.DistinguishedName }}'
      GroupScope: '{{ item.GroupScope }}'
      GroupType: '{{ item.GroupType }}'
      OtherAttributes: '{{ item.OtherAttributes }}'
      SAMAccountName: '{{ item.SAMAccountName }}'
      SID: '{{ item.SID }}'
- discovery_id: aws.ds-data.searchUsers
  calls:
  - action: searchUsers
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Users }}'
    item:
      DistinguishedName: '{{ item.DistinguishedName }}'
      EmailAddress: '{{ item.EmailAddress }}'
      Enabled: '{{ item.Enabled }}'
      GivenName: '{{ item.GivenName }}'
      OtherAttributes: '{{ item.OtherAttributes }}'
      SAMAccountName: '{{ item.SAMAccountName }}'
      SID: '{{ item.SID }}'
      Surname: '{{ item.Surname }}'
      UserPrincipalName: '{{ item.UserPrincipalName }}'
checks: []
