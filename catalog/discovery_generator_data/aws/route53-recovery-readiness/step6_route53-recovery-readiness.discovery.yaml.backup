version: '1.0'
provider: aws
service: route53-recovery-readiness
services:
  client: route53-recovery-readiness
  module: boto3.client
discovery:
- discovery_id: aws.route53-recovery-readiness.listCells
  calls:
  - action: listCells
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Cells }}'
    item:
      CellArn: '{{ item.CellArn }}'
      CellName: '{{ item.CellName }}'
      Cells: '{{ item.Cells }}'
      ParentReadinessScopes: '{{ item.ParentReadinessScopes }}'
      Tags: '{{ item.Tags }}'
- discovery_id: aws.route53-recovery-readiness.listCrossAccountAuthorizations
  calls:
  - action: listCrossAccountAuthorizations
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.CrossAccountAuthorizations }}'
- discovery_id: aws.route53-recovery-readiness.listReadinessChecks
  calls:
  - action: listReadinessChecks
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.ReadinessChecks }}'
    item:
      ReadinessCheckArn: '{{ item.ReadinessCheckArn }}'
      ReadinessCheckName: '{{ item.ReadinessCheckName }}'
      ResourceSet: '{{ item.ResourceSet }}'
      Tags: '{{ item.Tags }}'
- discovery_id: aws.route53-recovery-readiness.listRecoveryGroups
  calls:
  - action: listRecoveryGroups
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.RecoveryGroups }}'
    item:
      Cells: '{{ item.Cells }}'
      RecoveryGroupArn: '{{ item.RecoveryGroupArn }}'
      RecoveryGroupName: '{{ item.RecoveryGroupName }}'
      Tags: '{{ item.Tags }}'
- discovery_id: aws.route53-recovery-readiness.listResourceSets
  calls:
  - action: listResourceSets
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.ResourceSets }}'
    item:
      ResourceSetArn: '{{ item.ResourceSetArn }}'
      ResourceSetName: '{{ item.ResourceSetName }}'
      ResourceSetType: '{{ item.ResourceSetType }}'
      Resources: '{{ item.Resources }}'
      Tags: '{{ item.Tags }}'
- discovery_id: aws.route53-recovery-readiness.listRules
  calls:
  - action: listRules
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Rules }}'
    item:
      ResourceType: '{{ item.ResourceType }}'
      RuleDescription: '{{ item.RuleDescription }}'
      RuleId: '{{ item.RuleId }}'
- discovery_id: aws.route53-recovery-readiness.getArchitectureRecommendations
  calls:
  - action: getArchitectureRecommendations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Recommendations }}'
    item:
      RecommendationText: '{{ item.RecommendationText }}'
- discovery_id: aws.route53-recovery-readiness.getCell
  calls:
  - action: getCell
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Cells }}'
- discovery_id: aws.route53-recovery-readiness.getCellReadinessSummary
  calls:
  - action: getCellReadinessSummary
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ReadinessChecks }}'
    item:
      Readiness: '{{ item.Readiness }}'
      ReadinessCheckName: '{{ item.ReadinessCheckName }}'
- discovery_id: aws.route53-recovery-readiness.getReadinessCheck
  calls:
  - action: getReadinessCheck
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ReadinessCheckArn }}'
- discovery_id: aws.route53-recovery-readiness.getReadinessCheckResourceStatus
  calls:
  - action: getReadinessCheckResourceStatus
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Rules }}'
    item:
      LastCheckedTimestamp: '{{ item.LastCheckedTimestamp }}'
      Messages: '{{ item.Messages }}'
      Readiness: '{{ item.Readiness }}'
      RuleId: '{{ item.RuleId }}'
- discovery_id: aws.route53-recovery-readiness.getReadinessCheckStatus
  calls:
  - action: getReadinessCheckStatus
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Resources }}'
    item:
      ComponentId: '{{ item.ComponentId }}'
      LastCheckedTimestamp: '{{ item.LastCheckedTimestamp }}'
      Readiness: '{{ item.Readiness }}'
      ResourceArn: '{{ item.ResourceArn }}'
- discovery_id: aws.route53-recovery-readiness.getRecoveryGroup
  calls:
  - action: getRecoveryGroup
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Cells }}'
- discovery_id: aws.route53-recovery-readiness.getRecoveryGroupReadinessSummary
  calls:
  - action: getRecoveryGroupReadinessSummary
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ReadinessChecks }}'
    item:
      Readiness: '{{ item.Readiness }}'
      ReadinessCheckName: '{{ item.ReadinessCheckName }}'
- discovery_id: aws.route53-recovery-readiness.getResourceSet
  calls:
  - action: getResourceSet
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Resources }}'
    item:
      ComponentId: '{{ item.ComponentId }}'
      DnsTargetResource: '{{ item.DnsTargetResource }}'
      ReadinessScopes: '{{ item.ReadinessScopes }}'
      ResourceArn: '{{ item.ResourceArn }}'
- discovery_id: aws.route53-recovery-readiness.listTagsForResources
  calls:
  - action: listTagsForResources
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Tags }}'
checks: []
