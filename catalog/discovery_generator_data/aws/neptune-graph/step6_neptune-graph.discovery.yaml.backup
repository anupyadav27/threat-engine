version: '1.0'
provider: aws
service: neptune-graph
services:
  client: neptune-graph
  module: boto3.client
discovery:
- discovery_id: aws.neptune-graph.listExportTasks
  calls:
  - action: listExportTasks
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tasks }}'
    item:
      graphId: '{{ item.graphId }}'
      roleArn: '{{ item.roleArn }}'
      taskId: '{{ item.taskId }}'
      status: '{{ item.status }}'
      format: '{{ item.format }}'
      destination: '{{ item.destination }}'
      kmsKeyIdentifier: '{{ item.kmsKeyIdentifier }}'
      parquetType: '{{ item.parquetType }}'
      statusReason: '{{ item.statusReason }}'
- discovery_id: aws.neptune-graph.listGraphSnapshots
  calls:
  - action: listGraphSnapshots
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.graphSnapshots }}'
    item:
      id: '{{ item.id }}'
      name: '{{ item.name }}'
      arn: '{{ item.arn }}'
      sourceGraphId: '{{ item.sourceGraphId }}'
      snapshotCreateTime: '{{ item.snapshotCreateTime }}'
      status: '{{ item.status }}'
      kmsKeyIdentifier: '{{ item.kmsKeyIdentifier }}'
- discovery_id: aws.neptune-graph.listGraphs
  calls:
  - action: listGraphs
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.graphs }}'
    item:
      id: '{{ item.id }}'
      name: '{{ item.name }}'
      arn: '{{ item.arn }}'
      status: '{{ item.status }}'
      provisionedMemory: '{{ item.provisionedMemory }}'
      publicConnectivity: '{{ item.publicConnectivity }}'
      endpoint: '{{ item.endpoint }}'
      replicaCount: '{{ item.replicaCount }}'
      kmsKeyIdentifier: '{{ item.kmsKeyIdentifier }}'
      deletionProtection: '{{ item.deletionProtection }}'
- discovery_id: aws.neptune-graph.listImportTasks
  calls:
  - action: listImportTasks
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tasks }}'
    item:
      graphId: '{{ item.graphId }}'
      taskId: '{{ item.taskId }}'
      source: '{{ item.source }}'
      format: '{{ item.format }}'
      parquetType: '{{ item.parquetType }}'
      roleArn: '{{ item.roleArn }}'
      status: '{{ item.status }}'
- discovery_id: aws.neptune-graph.getExportTask
  calls:
  - action: getExportTask
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.exportTaskDetails }}'
    item:
      startTime: '{{ item.startTime }}'
      timeElapsedSeconds: '{{ item.timeElapsedSeconds }}'
      progressPercentage: '{{ item.progressPercentage }}'
      numVerticesWritten: '{{ item.numVerticesWritten }}'
      numEdgesWritten: '{{ item.numEdgesWritten }}'
- discovery_id: aws.neptune-graph.getGraph
  calls:
  - action: getGraph
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.vectorSearchConfiguration }}'
    item:
      dimension: '{{ item.dimension }}'
- discovery_id: aws.neptune-graph.getGraphSnapshot
  calls:
  - action: getGraphSnapshot
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.id }}'
- discovery_id: aws.neptune-graph.getGraphSummary
  calls:
  - action: getGraphSummary
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.graphSummary }}'
    item:
      numNodes: '{{ item.numNodes }}'
      numEdges: '{{ item.numEdges }}'
      numNodeLabels: '{{ item.numNodeLabels }}'
      numEdgeLabels: '{{ item.numEdgeLabels }}'
      nodeLabels: '{{ item.nodeLabels }}'
      edgeLabels: '{{ item.edgeLabels }}'
      numNodeProperties: '{{ item.numNodeProperties }}'
      numEdgeProperties: '{{ item.numEdgeProperties }}'
      nodeProperties: '{{ item.nodeProperties }}'
      edgeProperties: '{{ item.edgeProperties }}'
      totalNodePropertyValues: '{{ item.totalNodePropertyValues }}'
      totalEdgePropertyValues: '{{ item.totalEdgePropertyValues }}'
      nodeStructures: '{{ item.nodeStructures }}'
      edgeStructures: '{{ item.edgeStructures }}'
- discovery_id: aws.neptune-graph.getImportTask
  calls:
  - action: getImportTask
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.importOptions }}'
    item:
      neptune: '{{ item.neptune }}'
- discovery_id: aws.neptune-graph.getPrivateGraphEndpoint
  calls:
  - action: getPrivateGraphEndpoint
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.subnetIds }}'
- discovery_id: aws.neptune-graph.getQuery
  calls:
  - action: getQuery
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.id }}'
- discovery_id: aws.neptune-graph.listPrivateGraphEndpoints
  calls:
  - action: listPrivateGraphEndpoints
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.privateGraphEndpoints }}'
    item:
      vpcId: '{{ item.vpcId }}'
      subnetIds: '{{ item.subnetIds }}'
      status: '{{ item.status }}'
      vpcEndpointId: '{{ item.vpcEndpointId }}'
- discovery_id: aws.neptune-graph.listQueries
  calls:
  - action: listQueries
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.queries }}'
    item:
      id: '{{ item.id }}'
      queryString: '{{ item.queryString }}'
      waited: '{{ item.waited }}'
      elapsed: '{{ item.elapsed }}'
      state: '{{ item.state }}'
- discovery_id: aws.neptune-graph.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tags }}'
checks: []
