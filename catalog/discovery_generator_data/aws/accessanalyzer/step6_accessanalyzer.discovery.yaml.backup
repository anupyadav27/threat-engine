version: '1.0'
provider: aws
service: accessanalyzer
services:
  client: accessanalyzer
  module: boto3.client
discovery:
- discovery_id: aws.accessanalyzer.listAnalyzers
  calls:
  - action: listAnalyzers
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.analyzers }}'
    item:
      arn: '{{ item.arn }}'
      name: '{{ item.name }}'
      type: '{{ item.type }}'
      createdAt: '{{ item.createdAt }}'
      lastResourceAnalyzed: '{{ item.lastResourceAnalyzed }}'
      lastResourceAnalyzedAt: '{{ item.lastResourceAnalyzedAt }}'
      tags: '{{ item.tags }}'
      status: '{{ item.status }}'
      statusReason: '{{ item.statusReason }}'
      configuration: '{{ item.configuration }}'
- discovery_id: aws.accessanalyzer.listPolicyGenerations
  calls:
  - action: listPolicyGenerations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.policyGenerations }}'
    item:
      jobId: '{{ item.jobId }}'
      principalArn: '{{ item.principalArn }}'
      status: '{{ item.status }}'
      startedOn: '{{ item.startedOn }}'
      completedOn: '{{ item.completedOn }}'
- discovery_id: aws.accessanalyzer.getAccessPreview
  calls:
  - action: getAccessPreview
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.accessPreview }}'
    item:
      id: '{{ item.id }}'
      analyzerArn: '{{ item.analyzerArn }}'
      configurations: '{{ item.configurations }}'
      createdAt: '{{ item.createdAt }}'
      status: '{{ item.status }}'
      statusReason: '{{ item.statusReason }}'
- discovery_id: aws.accessanalyzer.getAnalyzedResource
  calls:
  - action: getAnalyzedResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.resource }}'
    item:
      resourceArn: '{{ item.resourceArn }}'
      resourceType: '{{ item.resourceType }}'
      createdAt: '{{ item.createdAt }}'
      analyzedAt: '{{ item.analyzedAt }}'
      updatedAt: '{{ item.updatedAt }}'
      isPublic: '{{ item.isPublic }}'
      actions: '{{ item.actions }}'
      sharedVia: '{{ item.sharedVia }}'
      status: '{{ item.status }}'
      resourceOwnerAccount: '{{ item.resourceOwnerAccount }}'
      error: '{{ item.error }}'
- discovery_id: aws.accessanalyzer.getAnalyzer
  calls:
  - action: getAnalyzer
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.analyzer }}'
    item:
      arn: '{{ item.arn }}'
      name: '{{ item.name }}'
      type: '{{ item.type }}'
      createdAt: '{{ item.createdAt }}'
      lastResourceAnalyzed: '{{ item.lastResourceAnalyzed }}'
      lastResourceAnalyzedAt: '{{ item.lastResourceAnalyzedAt }}'
      tags: '{{ item.tags }}'
      status: '{{ item.status }}'
      statusReason: '{{ item.statusReason }}'
      configuration: '{{ item.configuration }}'
- discovery_id: aws.accessanalyzer.getArchiveRule
  calls:
  - action: getArchiveRule
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.archiveRule }}'
    item:
      ruleName: '{{ item.ruleName }}'
      filter: '{{ item.filter }}'
      createdAt: '{{ item.createdAt }}'
      updatedAt: '{{ item.updatedAt }}'
- discovery_id: aws.accessanalyzer.getFinding
  calls:
  - action: getFinding
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.finding }}'
    item:
      id: '{{ item.id }}'
      principal: '{{ item.principal }}'
      action: '{{ item.action }}'
      resource: '{{ item.resource }}'
      isPublic: '{{ item.isPublic }}'
      resourceType: '{{ item.resourceType }}'
      condition: '{{ item.condition }}'
      createdAt: '{{ item.createdAt }}'
      analyzedAt: '{{ item.analyzedAt }}'
      updatedAt: '{{ item.updatedAt }}'
      status: '{{ item.status }}'
      resourceOwnerAccount: '{{ item.resourceOwnerAccount }}'
      error: '{{ item.error }}'
      sources: '{{ item.sources }}'
      resourceControlPolicyRestriction: '{{ item.resourceControlPolicyRestriction
        }}'
- discovery_id: aws.accessanalyzer.getFindingRecommendation
  calls:
  - action: getFindingRecommendation
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.recommendedSteps }}'
    item:
      unusedPermissionsRecommendedStep: '{{ item.unusedPermissionsRecommendedStep
        }}'
- discovery_id: aws.accessanalyzer.getFindingV2
  calls:
  - action: getFindingV2
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.findingDetails }}'
    item:
      internalAccessDetails: '{{ item.internalAccessDetails }}'
      externalAccessDetails: '{{ item.externalAccessDetails }}'
      unusedPermissionDetails: '{{ item.unusedPermissionDetails }}'
      unusedIamUserAccessKeyDetails: '{{ item.unusedIamUserAccessKeyDetails }}'
      unusedIamRoleDetails: '{{ item.unusedIamRoleDetails }}'
      unusedIamUserPasswordDetails: '{{ item.unusedIamUserPasswordDetails }}'
- discovery_id: aws.accessanalyzer.getFindingsStatistics
  calls:
  - action: getFindingsStatistics
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.findingsStatistics }}'
    item:
      externalAccessFindingsStatistics: '{{ item.externalAccessFindingsStatistics
        }}'
      internalAccessFindingsStatistics: '{{ item.internalAccessFindingsStatistics
        }}'
      unusedAccessFindingsStatistics: '{{ item.unusedAccessFindingsStatistics }}'
- discovery_id: aws.accessanalyzer.getGeneratedPolicy
  calls:
  - action: getGeneratedPolicy
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.jobDetails }}'
    item:
      jobId: '{{ item.jobId }}'
      status: '{{ item.status }}'
      startedOn: '{{ item.startedOn }}'
      completedOn: '{{ item.completedOn }}'
      jobError: '{{ item.jobError }}'
- discovery_id: aws.accessanalyzer.listAccessPreviewFindings
  calls:
  - action: listAccessPreviewFindings
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.findings }}'
    item:
      id: '{{ item.id }}'
      existingFindingId: '{{ item.existingFindingId }}'
      existingFindingStatus: '{{ item.existingFindingStatus }}'
      principal: '{{ item.principal }}'
      action: '{{ item.action }}'
      condition: '{{ item.condition }}'
      resource: '{{ item.resource }}'
      isPublic: '{{ item.isPublic }}'
      resourceType: '{{ item.resourceType }}'
      createdAt: '{{ item.createdAt }}'
      changeType: '{{ item.changeType }}'
      status: '{{ item.status }}'
      resourceOwnerAccount: '{{ item.resourceOwnerAccount }}'
      error: '{{ item.error }}'
      sources: '{{ item.sources }}'
      resourceControlPolicyRestriction: '{{ item.resourceControlPolicyRestriction
        }}'
- discovery_id: aws.accessanalyzer.listAccessPreviews
  calls:
  - action: listAccessPreviews
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.accessPreviews }}'
    item:
      id: '{{ item.id }}'
      analyzerArn: '{{ item.analyzerArn }}'
      createdAt: '{{ item.createdAt }}'
      status: '{{ item.status }}'
      statusReason: '{{ item.statusReason }}'
- discovery_id: aws.accessanalyzer.listAnalyzedResources
  calls:
  - action: listAnalyzedResources
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.analyzedResources }}'
    item:
      resourceArn: '{{ item.resourceArn }}'
      resourceOwnerAccount: '{{ item.resourceOwnerAccount }}'
      resourceType: '{{ item.resourceType }}'
- discovery_id: aws.accessanalyzer.listArchiveRules
  calls:
  - action: listArchiveRules
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.archiveRules }}'
    item:
      ruleName: '{{ item.ruleName }}'
      filter: '{{ item.filter }}'
      createdAt: '{{ item.createdAt }}'
      updatedAt: '{{ item.updatedAt }}'
- discovery_id: aws.accessanalyzer.listFindings
  calls:
  - action: listFindings
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.findings }}'
    item:
      id: '{{ item.id }}'
      principal: '{{ item.principal }}'
      action: '{{ item.action }}'
      resource: '{{ item.resource }}'
      isPublic: '{{ item.isPublic }}'
      resourceType: '{{ item.resourceType }}'
      condition: '{{ item.condition }}'
      createdAt: '{{ item.createdAt }}'
      analyzedAt: '{{ item.analyzedAt }}'
      updatedAt: '{{ item.updatedAt }}'
      status: '{{ item.status }}'
      resourceOwnerAccount: '{{ item.resourceOwnerAccount }}'
      error: '{{ item.error }}'
      sources: '{{ item.sources }}'
      resourceControlPolicyRestriction: '{{ item.resourceControlPolicyRestriction
        }}'
- discovery_id: aws.accessanalyzer.listFindingsV2
  calls:
  - action: listFindingsV2
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.findings }}'
    item:
      analyzedAt: '{{ item.analyzedAt }}'
      createdAt: '{{ item.createdAt }}'
      error: '{{ item.error }}'
      id: '{{ item.id }}'
      resource: '{{ item.resource }}'
      resourceType: '{{ item.resourceType }}'
      resourceOwnerAccount: '{{ item.resourceOwnerAccount }}'
      status: '{{ item.status }}'
      updatedAt: '{{ item.updatedAt }}'
      findingType: '{{ item.findingType }}'
- discovery_id: aws.accessanalyzer.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tags }}'
checks: []
