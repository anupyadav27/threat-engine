version: '1.0'
provider: aws
service: devops-guru
services:
  client: devops-guru
  module: boto3.client
discovery:
- discovery_id: aws.devops-guru.describeAccountHealth
  calls:
  - action: describeAccountHealth
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.OpenReactiveInsights }}'
- discovery_id: aws.devops-guru.describeEventSourcesConfig
  calls:
  - action: describeEventSourcesConfig
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.EventSources }}'
    item:
      AmazonCodeGuruProfiler: '{{ item.AmazonCodeGuruProfiler }}'
- discovery_id: aws.devops-guru.describeFeedback
  calls:
  - action: describeFeedback
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.InsightFeedback }}'
    item:
      Id: '{{ item.Id }}'
      Feedback: '{{ item.Feedback }}'
- discovery_id: aws.devops-guru.describeOrganizationHealth
  calls:
  - action: describeOrganizationHealth
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.OpenReactiveInsights }}'
- discovery_id: aws.devops-guru.describeServiceIntegration
  calls:
  - action: describeServiceIntegration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ServiceIntegration }}'
    item:
      OpsCenter: '{{ item.OpsCenter }}'
      LogsAnomalyDetection: '{{ item.LogsAnomalyDetection }}'
      KMSServerSideEncryption: '{{ item.KMSServerSideEncryption }}'
- discovery_id: aws.devops-guru.getCostEstimation
  calls:
  - action: getCostEstimation
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Costs }}'
    item:
      Type: '{{ item.Type }}'
      State: '{{ item.State }}'
      Count: '{{ item.Count }}'
      UnitCost: '{{ item.UnitCost }}'
      Cost: '{{ item.Cost }}'
- discovery_id: aws.devops-guru.listMonitoredResources
  calls:
  - action: listMonitoredResources
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.MonitoredResourceIdentifiers }}'
    item:
      MonitoredResourceName: '{{ item.MonitoredResourceName }}'
      Type: '{{ item.Type }}'
      ResourcePermission: '{{ item.ResourcePermission }}'
      LastUpdated: '{{ item.LastUpdated }}'
      ResourceCollection: '{{ item.ResourceCollection }}'
- discovery_id: aws.devops-guru.listNotificationChannels
  calls:
  - action: listNotificationChannels
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Channels }}'
    item:
      Id: '{{ item.Id }}'
      Config: '{{ item.Config }}'
- discovery_id: aws.devops-guru.describeAccountOverview
  calls:
  - action: describeAccountOverview
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ReactiveInsights }}'
- discovery_id: aws.devops-guru.describeAnomaly
  calls:
  - action: describeAnomaly
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ProactiveAnomaly }}'
    item:
      Id: '{{ item.Id }}'
      Severity: '{{ item.Severity }}'
      Status: '{{ item.Status }}'
      UpdateTime: '{{ item.UpdateTime }}'
      AnomalyTimeRange: '{{ item.AnomalyTimeRange }}'
      AnomalyReportedTimeRange: '{{ item.AnomalyReportedTimeRange }}'
      PredictionTimeRange: '{{ item.PredictionTimeRange }}'
      SourceDetails: '{{ item.SourceDetails }}'
      AssociatedInsightId: '{{ item.AssociatedInsightId }}'
      ResourceCollection: '{{ item.ResourceCollection }}'
      Limit: '{{ item.Limit }}'
      SourceMetadata: '{{ item.SourceMetadata }}'
      AnomalyResources: '{{ item.AnomalyResources }}'
      Description: '{{ item.Description }}'
- discovery_id: aws.devops-guru.describeInsight
  calls:
  - action: describeInsight
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ProactiveInsight }}'
    item:
      Id: '{{ item.Id }}'
      Name: '{{ item.Name }}'
      Severity: '{{ item.Severity }}'
      Status: '{{ item.Status }}'
      InsightTimeRange: '{{ item.InsightTimeRange }}'
      PredictionTimeRange: '{{ item.PredictionTimeRange }}'
      ResourceCollection: '{{ item.ResourceCollection }}'
      SsmOpsItemId: '{{ item.SsmOpsItemId }}'
      Description: '{{ item.Description }}'
- discovery_id: aws.devops-guru.describeOrganizationOverview
  calls:
  - action: describeOrganizationOverview
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ReactiveInsights }}'
- discovery_id: aws.devops-guru.describeOrganizationResourceCollectionHealth
  calls:
  - action: describeOrganizationResourceCollectionHealth
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.CloudFormation }}'
    item:
      StackName: '{{ item.StackName }}'
      Insight: '{{ item.Insight }}'
      AnalyzedResourceCount: '{{ item.AnalyzedResourceCount }}'
- discovery_id: aws.devops-guru.describeResourceCollectionHealth
  calls:
  - action: describeResourceCollectionHealth
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.CloudFormation }}'
    item:
      StackName: '{{ item.StackName }}'
      Insight: '{{ item.Insight }}'
      AnalyzedResourceCount: '{{ item.AnalyzedResourceCount }}'
- discovery_id: aws.devops-guru.getResourceCollection
  calls:
  - action: getResourceCollection
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ResourceCollection }}'
    item:
      CloudFormation: '{{ item.CloudFormation }}'
      Tags: '{{ item.Tags }}'
- discovery_id: aws.devops-guru.listAnomaliesForInsight
  calls:
  - action: listAnomaliesForInsight
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.ProactiveAnomalies }}'
    item:
      Id: '{{ item.Id }}'
      Severity: '{{ item.Severity }}'
      Status: '{{ item.Status }}'
      UpdateTime: '{{ item.UpdateTime }}'
      AnomalyTimeRange: '{{ item.AnomalyTimeRange }}'
      AnomalyReportedTimeRange: '{{ item.AnomalyReportedTimeRange }}'
      PredictionTimeRange: '{{ item.PredictionTimeRange }}'
      SourceDetails: '{{ item.SourceDetails }}'
      AssociatedInsightId: '{{ item.AssociatedInsightId }}'
      ResourceCollection: '{{ item.ResourceCollection }}'
      Limit: '{{ item.Limit }}'
      SourceMetadata: '{{ item.SourceMetadata }}'
      AnomalyResources: '{{ item.AnomalyResources }}'
      Description: '{{ item.Description }}'
- discovery_id: aws.devops-guru.listAnomalousLogGroups
  calls:
  - action: listAnomalousLogGroups
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.AnomalousLogGroups }}'
    item:
      LogGroupName: '{{ item.LogGroupName }}'
      ImpactStartTime: '{{ item.ImpactStartTime }}'
      ImpactEndTime: '{{ item.ImpactEndTime }}'
      NumberOfLogLinesScanned: '{{ item.NumberOfLogLinesScanned }}'
      LogAnomalyShowcases: '{{ item.LogAnomalyShowcases }}'
- discovery_id: aws.devops-guru.listEvents
  calls:
  - action: listEvents
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Events }}'
    item:
      ResourceCollection: '{{ item.ResourceCollection }}'
      Id: '{{ item.Id }}'
      Time: '{{ item.Time }}'
      EventSource: '{{ item.EventSource }}'
      Name: '{{ item.Name }}'
      DataSource: '{{ item.DataSource }}'
      EventClass: '{{ item.EventClass }}'
      Resources: '{{ item.Resources }}'
- discovery_id: aws.devops-guru.listInsights
  calls:
  - action: listInsights
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.ProactiveInsights }}'
    item:
      Id: '{{ item.Id }}'
      Name: '{{ item.Name }}'
      Severity: '{{ item.Severity }}'
      Status: '{{ item.Status }}'
      InsightTimeRange: '{{ item.InsightTimeRange }}'
      PredictionTimeRange: '{{ item.PredictionTimeRange }}'
      ResourceCollection: '{{ item.ResourceCollection }}'
      ServiceCollection: '{{ item.ServiceCollection }}'
      AssociatedResourceArns: '{{ item.AssociatedResourceArns }}'
- discovery_id: aws.devops-guru.listOrganizationInsights
  calls:
  - action: listOrganizationInsights
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.ProactiveInsights }}'
    item:
      Id: '{{ item.Id }}'
      AccountId: '{{ item.AccountId }}'
      OrganizationalUnitId: '{{ item.OrganizationalUnitId }}'
      Name: '{{ item.Name }}'
      Severity: '{{ item.Severity }}'
      Status: '{{ item.Status }}'
      InsightTimeRange: '{{ item.InsightTimeRange }}'
      PredictionTimeRange: '{{ item.PredictionTimeRange }}'
      ResourceCollection: '{{ item.ResourceCollection }}'
      ServiceCollection: '{{ item.ServiceCollection }}'
- discovery_id: aws.devops-guru.listRecommendations
  calls:
  - action: listRecommendations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Recommendations }}'
    item:
      Description: '{{ item.Description }}'
      Link: '{{ item.Link }}'
      Name: '{{ item.Name }}'
      Reason: '{{ item.Reason }}'
      RelatedEvents: '{{ item.RelatedEvents }}'
      RelatedAnomalies: '{{ item.RelatedAnomalies }}'
      Category: '{{ item.Category }}'
- discovery_id: aws.devops-guru.searchInsights
  calls:
  - action: searchInsights
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ProactiveInsights }}'
    item:
      Id: '{{ item.Id }}'
      Name: '{{ item.Name }}'
      Severity: '{{ item.Severity }}'
      Status: '{{ item.Status }}'
      InsightTimeRange: '{{ item.InsightTimeRange }}'
      PredictionTimeRange: '{{ item.PredictionTimeRange }}'
      ResourceCollection: '{{ item.ResourceCollection }}'
      ServiceCollection: '{{ item.ServiceCollection }}'
      AssociatedResourceArns: '{{ item.AssociatedResourceArns }}'
- discovery_id: aws.devops-guru.searchOrganizationInsights
  calls:
  - action: searchOrganizationInsights
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ProactiveInsights }}'
    item:
      Id: '{{ item.Id }}'
      Name: '{{ item.Name }}'
      Severity: '{{ item.Severity }}'
      Status: '{{ item.Status }}'
      InsightTimeRange: '{{ item.InsightTimeRange }}'
      PredictionTimeRange: '{{ item.PredictionTimeRange }}'
      ResourceCollection: '{{ item.ResourceCollection }}'
      ServiceCollection: '{{ item.ServiceCollection }}'
      AssociatedResourceArns: '{{ item.AssociatedResourceArns }}'
checks: []
