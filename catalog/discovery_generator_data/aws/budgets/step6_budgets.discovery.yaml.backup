version: '1.0'
provider: aws
service: budgets
services:
  client: budgets
  module: boto3.client
discovery:
- discovery_id: aws.budgets.describeBudget
  calls:
  - action: describeBudget
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Budget }}'
    item:
      BudgetName: '{{ item.BudgetName }}'
      BudgetLimit: '{{ item.BudgetLimit }}'
      PlannedBudgetLimits: '{{ item.PlannedBudgetLimits }}'
      CostFilters: '{{ item.CostFilters }}'
      CostTypes: '{{ item.CostTypes }}'
      TimeUnit: '{{ item.TimeUnit }}'
      TimePeriod: '{{ item.TimePeriod }}'
      CalculatedSpend: '{{ item.CalculatedSpend }}'
      BudgetType: '{{ item.BudgetType }}'
      LastUpdatedTime: '{{ item.LastUpdatedTime }}'
      AutoAdjustData: '{{ item.AutoAdjustData }}'
      FilterExpression: '{{ item.FilterExpression }}'
      Metrics: '{{ item.Metrics }}'
      BillingViewArn: '{{ item.BillingViewArn }}'
      HealthStatus: '{{ item.HealthStatus }}'
- discovery_id: aws.budgets.describeBudgetAction
  calls:
  - action: describeBudgetAction
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Action }}'
    item:
      ActionId: '{{ item.ActionId }}'
      BudgetName: '{{ item.BudgetName }}'
      NotificationType: '{{ item.NotificationType }}'
      ActionType: '{{ item.ActionType }}'
      ActionThreshold: '{{ item.ActionThreshold }}'
      Definition: '{{ item.Definition }}'
      ExecutionRoleArn: '{{ item.ExecutionRoleArn }}'
      ApprovalModel: '{{ item.ApprovalModel }}'
      Status: '{{ item.Status }}'
      Subscribers: '{{ item.Subscribers }}'
- discovery_id: aws.budgets.describeBudgetActionHistories
  calls:
  - action: describeBudgetActionHistories
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ActionHistories }}'
    item:
      Timestamp: '{{ item.Timestamp }}'
      Status: '{{ item.Status }}'
      EventType: '{{ item.EventType }}'
      ActionHistoryDetails: '{{ item.ActionHistoryDetails }}'
- discovery_id: aws.budgets.describeBudgetActionsForAccount
  calls:
  - action: describeBudgetActionsForAccount
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Actions }}'
    item:
      ActionId: '{{ item.ActionId }}'
      BudgetName: '{{ item.BudgetName }}'
      NotificationType: '{{ item.NotificationType }}'
      ActionType: '{{ item.ActionType }}'
      ActionThreshold: '{{ item.ActionThreshold }}'
      Definition: '{{ item.Definition }}'
      ExecutionRoleArn: '{{ item.ExecutionRoleArn }}'
      ApprovalModel: '{{ item.ApprovalModel }}'
      Status: '{{ item.Status }}'
      Subscribers: '{{ item.Subscribers }}'
- discovery_id: aws.budgets.describeBudgetActionsForBudget
  calls:
  - action: describeBudgetActionsForBudget
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Actions }}'
    item:
      ActionId: '{{ item.ActionId }}'
      BudgetName: '{{ item.BudgetName }}'
      NotificationType: '{{ item.NotificationType }}'
      ActionType: '{{ item.ActionType }}'
      ActionThreshold: '{{ item.ActionThreshold }}'
      Definition: '{{ item.Definition }}'
      ExecutionRoleArn: '{{ item.ExecutionRoleArn }}'
      ApprovalModel: '{{ item.ApprovalModel }}'
      Status: '{{ item.Status }}'
      Subscribers: '{{ item.Subscribers }}'
- discovery_id: aws.budgets.describeBudgetNotificationsForAccount
  calls:
  - action: describeBudgetNotificationsForAccount
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.BudgetNotificationsForAccount }}'
    item:
      Notifications: '{{ item.Notifications }}'
      BudgetName: '{{ item.BudgetName }}'
- discovery_id: aws.budgets.describeBudgetPerformanceHistory
  calls:
  - action: describeBudgetPerformanceHistory
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.BudgetPerformanceHistory }}'
    item:
      BudgetName: '{{ item.BudgetName }}'
      BudgetType: '{{ item.BudgetType }}'
      CostFilters: '{{ item.CostFilters }}'
      CostTypes: '{{ item.CostTypes }}'
      TimeUnit: '{{ item.TimeUnit }}'
      BillingViewArn: '{{ item.BillingViewArn }}'
      BudgetedAndActualAmountsList: '{{ item.BudgetedAndActualAmountsList }}'
- discovery_id: aws.budgets.describeBudgets
  calls:
  - action: describeBudgets
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Budgets }}'
    item:
      BudgetName: '{{ item.BudgetName }}'
      BudgetLimit: '{{ item.BudgetLimit }}'
      PlannedBudgetLimits: '{{ item.PlannedBudgetLimits }}'
      CostFilters: '{{ item.CostFilters }}'
      CostTypes: '{{ item.CostTypes }}'
      TimeUnit: '{{ item.TimeUnit }}'
      TimePeriod: '{{ item.TimePeriod }}'
      CalculatedSpend: '{{ item.CalculatedSpend }}'
      BudgetType: '{{ item.BudgetType }}'
      LastUpdatedTime: '{{ item.LastUpdatedTime }}'
      AutoAdjustData: '{{ item.AutoAdjustData }}'
      FilterExpression: '{{ item.FilterExpression }}'
      Metrics: '{{ item.Metrics }}'
      BillingViewArn: '{{ item.BillingViewArn }}'
      HealthStatus: '{{ item.HealthStatus }}'
- discovery_id: aws.budgets.describeNotificationsForBudget
  calls:
  - action: describeNotificationsForBudget
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Notifications }}'
    item:
      NotificationType: '{{ item.NotificationType }}'
      ComparisonOperator: '{{ item.ComparisonOperator }}'
      Threshold: '{{ item.Threshold }}'
      ThresholdType: '{{ item.ThresholdType }}'
      NotificationState: '{{ item.NotificationState }}'
- discovery_id: aws.budgets.describeSubscribersForNotification
  calls:
  - action: describeSubscribersForNotification
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Subscribers }}'
    item:
      SubscriptionType: '{{ item.SubscriptionType }}'
      Address: '{{ item.Address }}'
- discovery_id: aws.budgets.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ResourceTags }}'
    item:
      Key: '{{ item.Key }}'
      Value: '{{ item.Value }}'
checks: []
