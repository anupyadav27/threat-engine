version: '1.0'
provider: aws
service: pca-connector-ad
services:
  client: pca-connector-ad
  module: boto3.client
discovery:
- discovery_id: aws.pca-connector-ad.listConnectors
  calls:
  - action: listConnectors
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Connectors }}'
    item:
      Arn: '{{ item.Arn }}'
      CertificateAuthorityArn: '{{ item.CertificateAuthorityArn }}'
      CertificateEnrollmentPolicyServerEndpoint: '{{ item.CertificateEnrollmentPolicyServerEndpoint
        }}'
      CreatedAt: '{{ item.CreatedAt }}'
      DirectoryId: '{{ item.DirectoryId }}'
      Status: '{{ item.Status }}'
      StatusReason: '{{ item.StatusReason }}'
      UpdatedAt: '{{ item.UpdatedAt }}'
      VpcInformation: '{{ item.VpcInformation }}'
- discovery_id: aws.pca-connector-ad.listDirectoryRegistrations
  calls:
  - action: listDirectoryRegistrations
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.DirectoryRegistrations }}'
    item:
      Arn: '{{ item.Arn }}'
      CreatedAt: '{{ item.CreatedAt }}'
      DirectoryId: '{{ item.DirectoryId }}'
      Status: '{{ item.Status }}'
      StatusReason: '{{ item.StatusReason }}'
      UpdatedAt: '{{ item.UpdatedAt }}'
- discovery_id: aws.pca-connector-ad.getConnector
  calls:
  - action: getConnector
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Connector }}'
    item:
      Arn: '{{ item.Arn }}'
      CertificateAuthorityArn: '{{ item.CertificateAuthorityArn }}'
      CertificateEnrollmentPolicyServerEndpoint: '{{ item.CertificateEnrollmentPolicyServerEndpoint
        }}'
      CreatedAt: '{{ item.CreatedAt }}'
      DirectoryId: '{{ item.DirectoryId }}'
      Status: '{{ item.Status }}'
      StatusReason: '{{ item.StatusReason }}'
      UpdatedAt: '{{ item.UpdatedAt }}'
      VpcInformation: '{{ item.VpcInformation }}'
- discovery_id: aws.pca-connector-ad.getDirectoryRegistration
  calls:
  - action: getDirectoryRegistration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.DirectoryRegistration }}'
    item:
      Arn: '{{ item.Arn }}'
      CreatedAt: '{{ item.CreatedAt }}'
      DirectoryId: '{{ item.DirectoryId }}'
      Status: '{{ item.Status }}'
      StatusReason: '{{ item.StatusReason }}'
      UpdatedAt: '{{ item.UpdatedAt }}'
- discovery_id: aws.pca-connector-ad.getServicePrincipalName
  calls:
  - action: getServicePrincipalName
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ServicePrincipalName }}'
    item:
      ConnectorArn: '{{ item.ConnectorArn }}'
      CreatedAt: '{{ item.CreatedAt }}'
      DirectoryRegistrationArn: '{{ item.DirectoryRegistrationArn }}'
      Status: '{{ item.Status }}'
      StatusReason: '{{ item.StatusReason }}'
      UpdatedAt: '{{ item.UpdatedAt }}'
- discovery_id: aws.pca-connector-ad.getTemplate
  calls:
  - action: getTemplate
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Template }}'
    item:
      Arn: '{{ item.Arn }}'
      ConnectorArn: '{{ item.ConnectorArn }}'
      CreatedAt: '{{ item.CreatedAt }}'
      Definition: '{{ item.Definition }}'
      Name: '{{ item.Name }}'
      ObjectIdentifier: '{{ item.ObjectIdentifier }}'
      PolicySchema: '{{ item.PolicySchema }}'
      Revision: '{{ item.Revision }}'
      Status: '{{ item.Status }}'
      UpdatedAt: '{{ item.UpdatedAt }}'
- discovery_id: aws.pca-connector-ad.getTemplateGroupAccessControlEntry
  calls:
  - action: getTemplateGroupAccessControlEntry
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AccessControlEntry }}'
    item:
      AccessRights: '{{ item.AccessRights }}'
      CreatedAt: '{{ item.CreatedAt }}'
      GroupDisplayName: '{{ item.GroupDisplayName }}'
      GroupSecurityIdentifier: '{{ item.GroupSecurityIdentifier }}'
      TemplateArn: '{{ item.TemplateArn }}'
      UpdatedAt: '{{ item.UpdatedAt }}'
- discovery_id: aws.pca-connector-ad.listServicePrincipalNames
  calls:
  - action: listServicePrincipalNames
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.ServicePrincipalNames }}'
    item:
      ConnectorArn: '{{ item.ConnectorArn }}'
      CreatedAt: '{{ item.CreatedAt }}'
      DirectoryRegistrationArn: '{{ item.DirectoryRegistrationArn }}'
      Status: '{{ item.Status }}'
      StatusReason: '{{ item.StatusReason }}'
      UpdatedAt: '{{ item.UpdatedAt }}'
- discovery_id: aws.pca-connector-ad.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Tags }}'
- discovery_id: aws.pca-connector-ad.listTemplateGroupAccessControlEntries
  calls:
  - action: listTemplateGroupAccessControlEntries
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.AccessControlEntries }}'
    item:
      AccessRights: '{{ item.AccessRights }}'
      CreatedAt: '{{ item.CreatedAt }}'
      GroupDisplayName: '{{ item.GroupDisplayName }}'
      GroupSecurityIdentifier: '{{ item.GroupSecurityIdentifier }}'
      TemplateArn: '{{ item.TemplateArn }}'
      UpdatedAt: '{{ item.UpdatedAt }}'
- discovery_id: aws.pca-connector-ad.listTemplates
  calls:
  - action: listTemplates
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Templates }}'
    item:
      Arn: '{{ item.Arn }}'
      ConnectorArn: '{{ item.ConnectorArn }}'
      CreatedAt: '{{ item.CreatedAt }}'
      Definition: '{{ item.Definition }}'
      Name: '{{ item.Name }}'
      ObjectIdentifier: '{{ item.ObjectIdentifier }}'
      PolicySchema: '{{ item.PolicySchema }}'
      Revision: '{{ item.Revision }}'
      Status: '{{ item.Status }}'
      UpdatedAt: '{{ item.UpdatedAt }}'
checks: []
