version: '1.0'
provider: aws
service: groundstation
services:
  client: groundstation
  module: boto3.client
discovery:
- discovery_id: aws.groundstation.listConfigs
  calls:
  - action: listConfigs
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.configList }}'
    item:
      configId: '{{ item.configId }}'
      configType: '{{ item.configType }}'
      configArn: '{{ item.configArn }}'
      name: '{{ item.name }}'
- discovery_id: aws.groundstation.listDataflowEndpointGroups
  calls:
  - action: listDataflowEndpointGroups
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.dataflowEndpointGroupList }}'
    item:
      dataflowEndpointGroupId: '{{ item.dataflowEndpointGroupId }}'
      dataflowEndpointGroupArn: '{{ item.dataflowEndpointGroupArn }}'
- discovery_id: aws.groundstation.listGroundStations
  calls:
  - action: listGroundStations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.groundStationList }}'
    item:
      groundStationId: '{{ item.groundStationId }}'
      groundStationName: '{{ item.groundStationName }}'
      region: '{{ item.region }}'
- discovery_id: aws.groundstation.listMissionProfiles
  calls:
  - action: listMissionProfiles
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.missionProfileList }}'
    item:
      missionProfileId: '{{ item.missionProfileId }}'
      missionProfileArn: '{{ item.missionProfileArn }}'
      region: '{{ item.region }}'
      name: '{{ item.name }}'
- discovery_id: aws.groundstation.listSatellites
  calls:
  - action: listSatellites
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.satellites }}'
    item:
      satelliteId: '{{ item.satelliteId }}'
      satelliteArn: '{{ item.satelliteArn }}'
      noradSatelliteID: '{{ item.noradSatelliteID }}'
      groundStations: '{{ item.groundStations }}'
      currentEphemeris: '{{ item.currentEphemeris }}'
- discovery_id: aws.groundstation.describeContact
  calls:
  - action: describeContact
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.dataflowList }}'
    item:
      source: '{{ item.source }}'
      destination: '{{ item.destination }}'
      errorMessage: '{{ item.errorMessage }}'
- discovery_id: aws.groundstation.describeEphemeris
  calls:
  - action: describeEphemeris
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.errorReasons }}'
    item:
      errorCode: '{{ item.errorCode }}'
      errorMessage: '{{ item.errorMessage }}'
- discovery_id: aws.groundstation.getAgentConfiguration
  calls:
  - action: getAgentConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.agentId }}'
- discovery_id: aws.groundstation.getAgentTaskResponseUrl
  calls:
  - action: getAgentTaskResponseUrl
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.agentId }}'
- discovery_id: aws.groundstation.getConfig
  calls:
  - action: getConfig
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.configData }}'
    item:
      antennaDownlinkConfig: '{{ item.antennaDownlinkConfig }}'
      trackingConfig: '{{ item.trackingConfig }}'
      dataflowEndpointConfig: '{{ item.dataflowEndpointConfig }}'
      antennaDownlinkDemodDecodeConfig: '{{ item.antennaDownlinkDemodDecodeConfig
        }}'
      antennaUplinkConfig: '{{ item.antennaUplinkConfig }}'
      uplinkEchoConfig: '{{ item.uplinkEchoConfig }}'
      s3RecordingConfig: '{{ item.s3RecordingConfig }}'
- discovery_id: aws.groundstation.getDataflowEndpointGroup
  calls:
  - action: getDataflowEndpointGroup
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.endpointsDetails }}'
    item:
      securityDetails: '{{ item.securityDetails }}'
      endpoint: '{{ item.endpoint }}'
      awsGroundStationAgentEndpoint: '{{ item.awsGroundStationAgentEndpoint }}'
      uplinkAwsGroundStationAgentEndpoint: '{{ item.uplinkAwsGroundStationAgentEndpoint
        }}'
      downlinkAwsGroundStationAgentEndpoint: '{{ item.downlinkAwsGroundStationAgentEndpoint
        }}'
      healthStatus: '{{ item.healthStatus }}'
      healthReasons: '{{ item.healthReasons }}'
- discovery_id: aws.groundstation.getMinuteUsage
  calls:
  - action: getMinuteUsage
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.isReservedMinutesCustomer }}'
- discovery_id: aws.groundstation.getMissionProfile
  calls:
  - action: getMissionProfile
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.dataflowEdges }}'
- discovery_id: aws.groundstation.getSatellite
  calls:
  - action: getSatellite
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.groundStations }}'
- discovery_id: aws.groundstation.listContacts
  calls:
  - action: listContacts
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.contactList }}'
    item:
      contactId: '{{ item.contactId }}'
      missionProfileArn: '{{ item.missionProfileArn }}'
      satelliteArn: '{{ item.satelliteArn }}'
      startTime: '{{ item.startTime }}'
      endTime: '{{ item.endTime }}'
      prePassStartTime: '{{ item.prePassStartTime }}'
      postPassEndTime: '{{ item.postPassEndTime }}'
      groundStation: '{{ item.groundStation }}'
      contactStatus: '{{ item.contactStatus }}'
      errorMessage: '{{ item.errorMessage }}'
      maximumElevation: '{{ item.maximumElevation }}'
      region: '{{ item.region }}'
      tags: '{{ item.tags }}'
      visibilityStartTime: '{{ item.visibilityStartTime }}'
      visibilityEndTime: '{{ item.visibilityEndTime }}'
      ephemeris: '{{ item.ephemeris }}'
- discovery_id: aws.groundstation.listEphemerides
  calls:
  - action: listEphemerides
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ephemerides }}'
    item:
      ephemerisId: '{{ item.ephemerisId }}'
      ephemerisType: '{{ item.ephemerisType }}'
      status: '{{ item.status }}'
      priority: '{{ item.priority }}'
      enabled: '{{ item.enabled }}'
      creationTime: '{{ item.creationTime }}'
      name: '{{ item.name }}'
      sourceS3Object: '{{ item.sourceS3Object }}'
- discovery_id: aws.groundstation.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tags }}'
checks: []
