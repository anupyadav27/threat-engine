version: '1.0'
provider: aws
service: discovery
services:
  client: discovery
  module: boto3.client
discovery:
- discovery_id: aws.discovery.describeAgents
  calls:
  - action: describeAgents
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.agentsInfo }}'
    item:
      agentId: '{{ item.agentId }}'
      hostName: '{{ item.hostName }}'
      agentNetworkInfoList: '{{ item.agentNetworkInfoList }}'
      connectorId: '{{ item.connectorId }}'
      version: '{{ item.version }}'
      health: '{{ item.health }}'
      lastHealthPingTime: '{{ item.lastHealthPingTime }}'
      collectionStatus: '{{ item.collectionStatus }}'
      agentType: '{{ item.agentType }}'
      registeredTime: '{{ item.registeredTime }}'
- discovery_id: aws.discovery.describeContinuousExports
  calls:
  - action: describeContinuousExports
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.descriptions }}'
    item:
      exportId: '{{ item.exportId }}'
      status: '{{ item.status }}'
      statusDetail: '{{ item.statusDetail }}'
      s3Bucket: '{{ item.s3Bucket }}'
      startTime: '{{ item.startTime }}'
      stopTime: '{{ item.stopTime }}'
      dataSource: '{{ item.dataSource }}'
      schemaStorageConfig: '{{ item.schemaStorageConfig }}'
- discovery_id: aws.discovery.describeExportConfigurations
  calls:
  - action: describeExportConfigurations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.exportsInfo }}'
    item:
      exportId: '{{ item.exportId }}'
      exportStatus: '{{ item.exportStatus }}'
      statusMessage: '{{ item.statusMessage }}'
      configurationsDownloadUrl: '{{ item.configurationsDownloadUrl }}'
      exportRequestTime: '{{ item.exportRequestTime }}'
      isTruncated: '{{ item.isTruncated }}'
      requestedStartTime: '{{ item.requestedStartTime }}'
      requestedEndTime: '{{ item.requestedEndTime }}'
- discovery_id: aws.discovery.describeExportTasks
  calls:
  - action: describeExportTasks
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.exportsInfo }}'
    item:
      exportId: '{{ item.exportId }}'
      exportStatus: '{{ item.exportStatus }}'
      statusMessage: '{{ item.statusMessage }}'
      configurationsDownloadUrl: '{{ item.configurationsDownloadUrl }}'
      exportRequestTime: '{{ item.exportRequestTime }}'
      isTruncated: '{{ item.isTruncated }}'
      requestedStartTime: '{{ item.requestedStartTime }}'
      requestedEndTime: '{{ item.requestedEndTime }}'
- discovery_id: aws.discovery.describeImportTasks
  calls:
  - action: describeImportTasks
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tasks }}'
    item:
      importTaskId: '{{ item.importTaskId }}'
      clientRequestToken: '{{ item.clientRequestToken }}'
      name: '{{ item.name }}'
      importUrl: '{{ item.importUrl }}'
      status: '{{ item.status }}'
      importRequestTime: '{{ item.importRequestTime }}'
      importCompletionTime: '{{ item.importCompletionTime }}'
      importDeletedTime: '{{ item.importDeletedTime }}'
      fileClassification: '{{ item.fileClassification }}'
      serverImportSuccess: '{{ item.serverImportSuccess }}'
      serverImportFailure: '{{ item.serverImportFailure }}'
      applicationImportSuccess: '{{ item.applicationImportSuccess }}'
      applicationImportFailure: '{{ item.applicationImportFailure }}'
      errorsAndFailedEntriesZip: '{{ item.errorsAndFailedEntriesZip }}'
- discovery_id: aws.discovery.describeTags
  calls:
  - action: describeTags
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tags }}'
    item:
      configurationType: '{{ item.configurationType }}'
      configurationId: '{{ item.configurationId }}'
      key: '{{ item.key }}'
      value: '{{ item.value }}'
      timeOfCreation: '{{ item.timeOfCreation }}'
- discovery_id: aws.discovery.getDiscoverySummary
  calls:
  - action: getDiscoverySummary
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.agentSummary }}'
    item:
      activeAgents: '{{ item.activeAgents }}'
      healthyAgents: '{{ item.healthyAgents }}'
      blackListedAgents: '{{ item.blackListedAgents }}'
      shutdownAgents: '{{ item.shutdownAgents }}'
      unhealthyAgents: '{{ item.unhealthyAgents }}'
      totalAgents: '{{ item.totalAgents }}'
      unknownAgents: '{{ item.unknownAgents }}'
- discovery_id: aws.discovery.describeBatchDeleteConfigurationTask
  calls:
  - action: describeBatchDeleteConfigurationTask
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.task }}'
    item:
      taskId: '{{ item.taskId }}'
      status: '{{ item.status }}'
      startTime: '{{ item.startTime }}'
      endTime: '{{ item.endTime }}'
      configurationType: '{{ item.configurationType }}'
      requestedConfigurations: '{{ item.requestedConfigurations }}'
      deletedConfigurations: '{{ item.deletedConfigurations }}'
      failedConfigurations: '{{ item.failedConfigurations }}'
      deletionWarnings: '{{ item.deletionWarnings }}'
- discovery_id: aws.discovery.describeConfigurations
  calls:
  - action: describeConfigurations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.configurations }}'
- discovery_id: aws.discovery.listConfigurations
  calls:
  - action: listConfigurations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.configurations }}'
- discovery_id: aws.discovery.listServerNeighbors
  calls:
  - action: listServerNeighbors
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.neighbors }}'
    item:
      sourceServerId: '{{ item.sourceServerId }}'
      destinationServerId: '{{ item.destinationServerId }}'
      destinationPort: '{{ item.destinationPort }}'
      transportProtocol: '{{ item.transportProtocol }}'
      connectionsCount: '{{ item.connectionsCount }}'
checks: []
