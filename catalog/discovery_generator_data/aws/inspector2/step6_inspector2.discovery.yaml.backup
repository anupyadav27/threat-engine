version: '1.0'
provider: aws
service: inspector2
services:
  client: inspector2
  module: boto3.client
discovery:
- discovery_id: aws.inspector2.describeOrganizationConfiguration
  calls:
  - action: describeOrganizationConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.autoEnable }}'
    item:
      ec2: '{{ item.ec2 }}'
      ecr: '{{ item.ecr }}'
      lambda: '{{ item.lambda }}'
      lambdaCode: '{{ item.lambdaCode }}'
      codeRepository: '{{ item.codeRepository }}'
- discovery_id: aws.inspector2.getConfiguration
  calls:
  - action: getConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ecrConfiguration }}'
    item:
      rescanDurationState: '{{ item.rescanDurationState }}'
- discovery_id: aws.inspector2.getDelegatedAdminAccount
  calls:
  - action: getDelegatedAdminAccount
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.delegatedAdmin }}'
    item:
      accountId: '{{ item.accountId }}'
      relationshipStatus: '{{ item.relationshipStatus }}'
- discovery_id: aws.inspector2.getEc2DeepInspectionConfiguration
  calls:
  - action: getEc2DeepInspectionConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.packagePaths }}'
- discovery_id: aws.inspector2.getFindingsReportStatus
  calls:
  - action: getFindingsReportStatus
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.destination }}'
    item:
      bucketName: '{{ item.bucketName }}'
      keyPrefix: '{{ item.keyPrefix }}'
      kmsKeyArn: '{{ item.kmsKeyArn }}'
- discovery_id: aws.inspector2.listAccountPermissions
  calls:
  - action: listAccountPermissions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.permissions }}'
    item:
      service: '{{ item.service }}'
      operation: '{{ item.operation }}'
- discovery_id: aws.inspector2.listCisScanConfigurations
  calls:
  - action: listCisScanConfigurations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.scanConfigurations }}'
    item:
      scanConfigurationArn: '{{ item.scanConfigurationArn }}'
      ownerId: '{{ item.ownerId }}'
      scanName: '{{ item.scanName }}'
      securityLevel: '{{ item.securityLevel }}'
      schedule: '{{ item.schedule }}'
      targets: '{{ item.targets }}'
      tags: '{{ item.tags }}'
- discovery_id: aws.inspector2.listCisScans
  calls:
  - action: listCisScans
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.scans }}'
    item:
      scanArn: '{{ item.scanArn }}'
      scanConfigurationArn: '{{ item.scanConfigurationArn }}'
      status: '{{ item.status }}'
      scanName: '{{ item.scanName }}'
      scanDate: '{{ item.scanDate }}'
      failedChecks: '{{ item.failedChecks }}'
      totalChecks: '{{ item.totalChecks }}'
      targets: '{{ item.targets }}'
      scheduledBy: '{{ item.scheduledBy }}'
      securityLevel: '{{ item.securityLevel }}'
- discovery_id: aws.inspector2.listCodeSecurityIntegrations
  calls:
  - action: listCodeSecurityIntegrations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.integrations }}'
    item:
      integrationArn: '{{ item.integrationArn }}'
      name: '{{ item.name }}'
      type: '{{ item.type }}'
      status: '{{ item.status }}'
      statusReason: '{{ item.statusReason }}'
      createdOn: '{{ item.createdOn }}'
      lastUpdateOn: '{{ item.lastUpdateOn }}'
      tags: '{{ item.tags }}'
- discovery_id: aws.inspector2.listCodeSecurityScanConfigurations
  calls:
  - action: listCodeSecurityScanConfigurations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.configurations }}'
    item:
      scanConfigurationArn: '{{ item.scanConfigurationArn }}'
      name: '{{ item.name }}'
      ownerAccountId: '{{ item.ownerAccountId }}'
      periodicScanFrequency: '{{ item.periodicScanFrequency }}'
      frequencyExpression: '{{ item.frequencyExpression }}'
      continuousIntegrationScanSupportedEvents: '{{ item.continuousIntegrationScanSupportedEvents
        }}'
      ruleSetCategories: '{{ item.ruleSetCategories }}'
      scopeSettings: '{{ item.scopeSettings }}'
      tags: '{{ item.tags }}'
- discovery_id: aws.inspector2.listCoverage
  calls:
  - action: listCoverage
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.coveredResources }}'
    item:
      resourceType: '{{ item.resourceType }}'
      resourceId: '{{ item.resourceId }}'
      accountId: '{{ item.accountId }}'
      scanType: '{{ item.scanType }}'
      scanStatus: '{{ item.scanStatus }}'
      resourceMetadata: '{{ item.resourceMetadata }}'
      lastScannedAt: '{{ item.lastScannedAt }}'
      scanMode: '{{ item.scanMode }}'
- discovery_id: aws.inspector2.listCoverageStatistics
  calls:
  - action: listCoverageStatistics
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.countsByGroup }}'
    item:
      count: '{{ item.count }}'
      groupKey: '{{ item.groupKey }}'
- discovery_id: aws.inspector2.listDelegatedAdminAccounts
  calls:
  - action: listDelegatedAdminAccounts
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.delegatedAdminAccounts }}'
    item:
      accountId: '{{ item.accountId }}'
      status: '{{ item.status }}'
- discovery_id: aws.inspector2.listFilters
  calls:
  - action: listFilters
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.filters }}'
    item:
      arn: '{{ item.arn }}'
      ownerId: '{{ item.ownerId }}'
      name: '{{ item.name }}'
      criteria: '{{ item.criteria }}'
      action: '{{ item.action }}'
      createdAt: '{{ item.createdAt }}'
      updatedAt: '{{ item.updatedAt }}'
      description: '{{ item.description }}'
      reason: '{{ item.reason }}'
      tags: '{{ item.tags }}'
- discovery_id: aws.inspector2.listFindings
  calls:
  - action: listFindings
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.findings }}'
    item:
      findingArn: '{{ item.findingArn }}'
      awsAccountId: '{{ item.awsAccountId }}'
      type: '{{ item.type }}'
      description: '{{ item.description }}'
      title: '{{ item.title }}'
      remediation: '{{ item.remediation }}'
      severity: '{{ item.severity }}'
      firstObservedAt: '{{ item.firstObservedAt }}'
      lastObservedAt: '{{ item.lastObservedAt }}'
      updatedAt: '{{ item.updatedAt }}'
      status: '{{ item.status }}'
      resources: '{{ item.resources }}'
      inspectorScore: '{{ item.inspectorScore }}'
      inspectorScoreDetails: '{{ item.inspectorScoreDetails }}'
      networkReachabilityDetails: '{{ item.networkReachabilityDetails }}'
      packageVulnerabilityDetails: '{{ item.packageVulnerabilityDetails }}'
      fixAvailable: '{{ item.fixAvailable }}'
      exploitAvailable: '{{ item.exploitAvailable }}'
      exploitabilityDetails: '{{ item.exploitabilityDetails }}'
      codeVulnerabilityDetails: '{{ item.codeVulnerabilityDetails }}'
      epss: '{{ item.epss }}'
- discovery_id: aws.inspector2.listMembers
  calls:
  - action: listMembers
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.members }}'
    item:
      accountId: '{{ item.accountId }}'
      relationshipStatus: '{{ item.relationshipStatus }}'
      delegatedAdminAccountId: '{{ item.delegatedAdminAccountId }}'
      updatedAt: '{{ item.updatedAt }}'
- discovery_id: aws.inspector2.listUsageTotals
  calls:
  - action: listUsageTotals
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.totals }}'
    item:
      accountId: '{{ item.accountId }}'
      usage: '{{ item.usage }}'
- discovery_id: aws.inspector2.getCisScanReport
  calls:
  - action: getCisScanReport
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.url }}'
- discovery_id: aws.inspector2.getCisScanResultDetails
  calls:
  - action: getCisScanResultDetails
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.scanResultDetails }}'
    item:
      scanArn: '{{ item.scanArn }}'
      accountId: '{{ item.accountId }}'
      targetResourceId: '{{ item.targetResourceId }}'
      platform: '{{ item.platform }}'
      status: '{{ item.status }}'
      statusReason: '{{ item.statusReason }}'
      checkId: '{{ item.checkId }}'
      title: '{{ item.title }}'
      checkDescription: '{{ item.checkDescription }}'
      remediation: '{{ item.remediation }}'
      level: '{{ item.level }}'
      findingArn: '{{ item.findingArn }}'
- discovery_id: aws.inspector2.getClustersForImage
  calls:
  - action: getClustersForImage
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.cluster }}'
    item:
      clusterArn: '{{ item.clusterArn }}'
      clusterDetails: '{{ item.clusterDetails }}'
- discovery_id: aws.inspector2.getCodeSecurityIntegration
  calls:
  - action: getCodeSecurityIntegration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.integrationArn }}'
- discovery_id: aws.inspector2.getCodeSecurityScan
  calls:
  - action: getCodeSecurityScan
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.resource }}'
    item:
      projectId: '{{ item.projectId }}'
- discovery_id: aws.inspector2.getCodeSecurityScanConfiguration
  calls:
  - action: getCodeSecurityScanConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.configuration }}'
    item:
      periodicScanConfiguration: '{{ item.periodicScanConfiguration }}'
      continuousIntegrationScanConfiguration: '{{ item.continuousIntegrationScanConfiguration
        }}'
      ruleSetCategories: '{{ item.ruleSetCategories }}'
- discovery_id: aws.inspector2.getEncryptionKey
  calls:
  - action: getEncryptionKey
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.kmsKeyId }}'
- discovery_id: aws.inspector2.getMember
  calls:
  - action: getMember
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.member }}'
    item:
      accountId: '{{ item.accountId }}'
      relationshipStatus: '{{ item.relationshipStatus }}'
      delegatedAdminAccountId: '{{ item.delegatedAdminAccountId }}'
      updatedAt: '{{ item.updatedAt }}'
- discovery_id: aws.inspector2.getSbomExport
  calls:
  - action: getSbomExport
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.s3Destination }}'
    item:
      bucketName: '{{ item.bucketName }}'
      keyPrefix: '{{ item.keyPrefix }}'
      kmsKeyArn: '{{ item.kmsKeyArn }}'
- discovery_id: aws.inspector2.listCisScanResultsAggregatedByChecks
  calls:
  - action: listCisScanResultsAggregatedByChecks
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.checkAggregations }}'
    item:
      scanArn: '{{ item.scanArn }}'
      checkId: '{{ item.checkId }}'
      title: '{{ item.title }}'
      checkDescription: '{{ item.checkDescription }}'
      level: '{{ item.level }}'
      accountId: '{{ item.accountId }}'
      statusCounts: '{{ item.statusCounts }}'
      platform: '{{ item.platform }}'
- discovery_id: aws.inspector2.listCisScanResultsAggregatedByTargetResource
  calls:
  - action: listCisScanResultsAggregatedByTargetResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.targetResourceAggregations }}'
    item:
      scanArn: '{{ item.scanArn }}'
      targetResourceId: '{{ item.targetResourceId }}'
      accountId: '{{ item.accountId }}'
      targetResourceTags: '{{ item.targetResourceTags }}'
      statusCounts: '{{ item.statusCounts }}'
      platform: '{{ item.platform }}'
      targetStatus: '{{ item.targetStatus }}'
      targetStatusReason: '{{ item.targetStatusReason }}'
- discovery_id: aws.inspector2.listCodeSecurityScanConfigurationAssociations
  calls:
  - action: listCodeSecurityScanConfigurationAssociations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.associations }}'
    item:
      resource: '{{ item.resource }}'
- discovery_id: aws.inspector2.listFindingAggregations
  calls:
  - action: listFindingAggregations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.responses }}'
    item:
      accountAggregation: '{{ item.accountAggregation }}'
      amiAggregation: '{{ item.amiAggregation }}'
      awsEcrContainerAggregation: '{{ item.awsEcrContainerAggregation }}'
      ec2InstanceAggregation: '{{ item.ec2InstanceAggregation }}'
      findingTypeAggregation: '{{ item.findingTypeAggregation }}'
      imageLayerAggregation: '{{ item.imageLayerAggregation }}'
      packageAggregation: '{{ item.packageAggregation }}'
      repositoryAggregation: '{{ item.repositoryAggregation }}'
      titleAggregation: '{{ item.titleAggregation }}'
      lambdaLayerAggregation: '{{ item.lambdaLayerAggregation }}'
      lambdaFunctionAggregation: '{{ item.lambdaFunctionAggregation }}'
      codeRepositoryAggregation: '{{ item.codeRepositoryAggregation }}'
- discovery_id: aws.inspector2.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tags }}'
- discovery_id: aws.inspector2.searchVulnerabilities
  calls:
  - action: searchVulnerabilities
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.vulnerabilities }}'
    item:
      id: '{{ item.id }}'
      cwes: '{{ item.cwes }}'
      cisaData: '{{ item.cisaData }}'
      source: '{{ item.source }}'
      description: '{{ item.description }}'
      atigData: '{{ item.atigData }}'
      vendorSeverity: '{{ item.vendorSeverity }}'
      cvss4: '{{ item.cvss4 }}'
      cvss3: '{{ item.cvss3 }}'
      relatedVulnerabilities: '{{ item.relatedVulnerabilities }}'
      cvss2: '{{ item.cvss2 }}'
      vendorCreatedAt: '{{ item.vendorCreatedAt }}'
      vendorUpdatedAt: '{{ item.vendorUpdatedAt }}'
      sourceUrl: '{{ item.sourceUrl }}'
      referenceUrls: '{{ item.referenceUrls }}'
      exploitObserved: '{{ item.exploitObserved }}'
      detectionPlatforms: '{{ item.detectionPlatforms }}'
      epss: '{{ item.epss }}'
checks: []
