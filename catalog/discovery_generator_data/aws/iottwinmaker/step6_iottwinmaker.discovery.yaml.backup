version: '1.0'
provider: aws
service: iottwinmaker
services:
  client: iottwinmaker
  module: boto3.client
discovery:
- discovery_id: aws.iottwinmaker.getPricingPlan
  calls:
  - action: getPricingPlan
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.currentPricingPlan }}'
    item:
      billableEntityCount: '{{ item.billableEntityCount }}'
      bundleInformation: '{{ item.bundleInformation }}'
      effectiveDateTime: '{{ item.effectiveDateTime }}'
      pricingMode: '{{ item.pricingMode }}'
      updateDateTime: '{{ item.updateDateTime }}'
      updateReason: '{{ item.updateReason }}'
- discovery_id: aws.iottwinmaker.listWorkspaces
  calls:
  - action: listWorkspaces
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.workspaceSummaries }}'
    item:
      workspaceId: '{{ item.workspaceId }}'
      arn: '{{ item.arn }}'
      description: '{{ item.description }}'
      linkedServices: '{{ item.linkedServices }}'
      creationDateTime: '{{ item.creationDateTime }}'
      updateDateTime: '{{ item.updateDateTime }}'
- discovery_id: aws.iottwinmaker.getComponentType
  calls:
  - action: getComponentType
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.extendsFrom }}'
- discovery_id: aws.iottwinmaker.getEntity
  calls:
  - action: getEntity
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.status }}'
    item:
      state: '{{ item.state }}'
      error: '{{ item.error }}'
- discovery_id: aws.iottwinmaker.getMetadataTransferJob
  calls:
  - action: getMetadataTransferJob
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.sources }}'
    item:
      type: '{{ item.type }}'
      s3Configuration: '{{ item.s3Configuration }}'
      iotSiteWiseConfiguration: '{{ item.iotSiteWiseConfiguration }}'
      iotTwinMakerConfiguration: '{{ item.iotTwinMakerConfiguration }}'
- discovery_id: aws.iottwinmaker.getPropertyValue
  calls:
  - action: getPropertyValue
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tabularPropertyValues }}'
- discovery_id: aws.iottwinmaker.getPropertyValueHistory
  calls:
  - action: getPropertyValueHistory
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.propertyValues }}'
    item:
      entityPropertyReference: '{{ item.entityPropertyReference }}'
      values: '{{ item.values }}'
- discovery_id: aws.iottwinmaker.getScene
  calls:
  - action: getScene
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.capabilities }}'
- discovery_id: aws.iottwinmaker.getSyncJob
  calls:
  - action: getSyncJob
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.status }}'
    item:
      state: '{{ item.state }}'
      error: '{{ item.error }}'
- discovery_id: aws.iottwinmaker.getWorkspace
  calls:
  - action: getWorkspace
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.linkedServices }}'
- discovery_id: aws.iottwinmaker.listComponentTypes
  calls:
  - action: listComponentTypes
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.componentTypeSummaries }}'
    item:
      arn: '{{ item.arn }}'
      componentTypeId: '{{ item.componentTypeId }}'
      creationDateTime: '{{ item.creationDateTime }}'
      updateDateTime: '{{ item.updateDateTime }}'
      description: '{{ item.description }}'
      status: '{{ item.status }}'
      componentTypeName: '{{ item.componentTypeName }}'
- discovery_id: aws.iottwinmaker.listComponents
  calls:
  - action: listComponents
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.componentSummaries }}'
    item:
      componentName: '{{ item.componentName }}'
      componentTypeId: '{{ item.componentTypeId }}'
      definedIn: '{{ item.definedIn }}'
      description: '{{ item.description }}'
      propertyGroups: '{{ item.propertyGroups }}'
      status: '{{ item.status }}'
      syncSource: '{{ item.syncSource }}'
      componentPath: '{{ item.componentPath }}'
- discovery_id: aws.iottwinmaker.listEntities
  calls:
  - action: listEntities
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.entitySummaries }}'
    item:
      entityId: '{{ item.entityId }}'
      entityName: '{{ item.entityName }}'
      arn: '{{ item.arn }}'
      parentEntityId: '{{ item.parentEntityId }}'
      status: '{{ item.status }}'
      description: '{{ item.description }}'
      hasChildEntities: '{{ item.hasChildEntities }}'
      creationDateTime: '{{ item.creationDateTime }}'
      updateDateTime: '{{ item.updateDateTime }}'
- discovery_id: aws.iottwinmaker.listMetadataTransferJobs
  calls:
  - action: listMetadataTransferJobs
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.metadataTransferJobSummaries }}'
    item:
      metadataTransferJobId: '{{ item.metadataTransferJobId }}'
      arn: '{{ item.arn }}'
      creationDateTime: '{{ item.creationDateTime }}'
      updateDateTime: '{{ item.updateDateTime }}'
      status: '{{ item.status }}'
      progress: '{{ item.progress }}'
- discovery_id: aws.iottwinmaker.listProperties
  calls:
  - action: listProperties
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.propertySummaries }}'
    item:
      definition: '{{ item.definition }}'
      propertyName: '{{ item.propertyName }}'
      value: '{{ item.value }}'
      areAllPropertyValuesReturned: '{{ item.areAllPropertyValuesReturned }}'
- discovery_id: aws.iottwinmaker.listScenes
  calls:
  - action: listScenes
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.sceneSummaries }}'
    item:
      sceneId: '{{ item.sceneId }}'
      contentLocation: '{{ item.contentLocation }}'
      arn: '{{ item.arn }}'
      creationDateTime: '{{ item.creationDateTime }}'
      updateDateTime: '{{ item.updateDateTime }}'
      description: '{{ item.description }}'
- discovery_id: aws.iottwinmaker.listSyncJobs
  calls:
  - action: listSyncJobs
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.syncJobSummaries }}'
    item:
      arn: '{{ item.arn }}'
      workspaceId: '{{ item.workspaceId }}'
      syncSource: '{{ item.syncSource }}'
      status: '{{ item.status }}'
      creationDateTime: '{{ item.creationDateTime }}'
      updateDateTime: '{{ item.updateDateTime }}'
- discovery_id: aws.iottwinmaker.listSyncResources
  calls:
  - action: listSyncResources
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.syncResources }}'
    item:
      resourceType: '{{ item.resourceType }}'
      externalId: '{{ item.externalId }}'
      resourceId: '{{ item.resourceId }}'
      status: '{{ item.status }}'
      updateDateTime: '{{ item.updateDateTime }}'
- discovery_id: aws.iottwinmaker.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tags }}'
checks: []
