version: '1.0'
provider: aws
service: workmail
services:
  client: workmail
  module: boto3.client
discovery:
- discovery_id: aws.workmail.listOrganizations
  calls:
  - action: listOrganizations
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.OrganizationSummaries }}'
    item:
      OrganizationId: '{{ item.OrganizationId }}'
      Alias: '{{ item.Alias }}'
      DefaultMailDomain: '{{ item.DefaultMailDomain }}'
      ErrorMessage: '{{ item.ErrorMessage }}'
      State: '{{ item.State }}'
- discovery_id: aws.workmail.describeEmailMonitoringConfiguration
  calls:
  - action: describeEmailMonitoringConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.RoleArn }}'
- discovery_id: aws.workmail.describeEntity
  calls:
  - action: describeEntity
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.EntityId }}'
- discovery_id: aws.workmail.describeGroup
  calls:
  - action: describeGroup
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.GroupId }}'
- discovery_id: aws.workmail.describeIdentityProviderConfiguration
  calls:
  - action: describeIdentityProviderConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.IdentityCenterConfiguration }}'
    item:
      InstanceArn: '{{ item.InstanceArn }}'
      ApplicationArn: '{{ item.ApplicationArn }}'
- discovery_id: aws.workmail.describeInboundDmarcSettings
  calls:
  - action: describeInboundDmarcSettings
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Enforced }}'
- discovery_id: aws.workmail.describeMailboxExportJob
  calls:
  - action: describeMailboxExportJob
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.EntityId }}'
- discovery_id: aws.workmail.describeOrganization
  calls:
  - action: describeOrganization
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.OrganizationId }}'
- discovery_id: aws.workmail.describeResource
  calls:
  - action: describeResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.BookingOptions }}'
    item:
      AutoAcceptRequests: '{{ item.AutoAcceptRequests }}'
      AutoDeclineRecurringRequests: '{{ item.AutoDeclineRecurringRequests }}'
      AutoDeclineConflictingRequests: '{{ item.AutoDeclineConflictingRequests }}'
- discovery_id: aws.workmail.describeUser
  calls:
  - action: describeUser
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.UserId }}'
- discovery_id: aws.workmail.getAccessControlEffect
  calls:
  - action: getAccessControlEffect
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.MatchedRules }}'
- discovery_id: aws.workmail.getDefaultRetentionPolicy
  calls:
  - action: getDefaultRetentionPolicy
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.FolderConfigurations }}'
    item:
      Name: '{{ item.Name }}'
      Action: '{{ item.Action }}'
      Period: '{{ item.Period }}'
- discovery_id: aws.workmail.getImpersonationRole
  calls:
  - action: getImpersonationRole
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Rules }}'
    item:
      ImpersonationRuleId: '{{ item.ImpersonationRuleId }}'
      Name: '{{ item.Name }}'
      Description: '{{ item.Description }}'
      Effect: '{{ item.Effect }}'
      TargetUsers: '{{ item.TargetUsers }}'
      NotTargetUsers: '{{ item.NotTargetUsers }}'
- discovery_id: aws.workmail.getImpersonationRoleEffect
  calls:
  - action: getImpersonationRoleEffect
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.MatchedRules }}'
    item:
      ImpersonationRuleId: '{{ item.ImpersonationRuleId }}'
      Name: '{{ item.Name }}'
- discovery_id: aws.workmail.getMailDomain
  calls:
  - action: getMailDomain
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Records }}'
    item:
      Type: '{{ item.Type }}'
      Hostname: '{{ item.Hostname }}'
      Value: '{{ item.Value }}'
- discovery_id: aws.workmail.getMailboxDetails
  calls:
  - action: getMailboxDetails
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.MailboxQuota }}'
- discovery_id: aws.workmail.getMobileDeviceAccessEffect
  calls:
  - action: getMobileDeviceAccessEffect
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.MatchedRules }}'
    item:
      MobileDeviceAccessRuleId: '{{ item.MobileDeviceAccessRuleId }}'
      Name: '{{ item.Name }}'
- discovery_id: aws.workmail.getMobileDeviceAccessOverride
  calls:
  - action: getMobileDeviceAccessOverride
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.UserId }}'
- discovery_id: aws.workmail.getPersonalAccessTokenMetadata
  calls:
  - action: getPersonalAccessTokenMetadata
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Scopes }}'
- discovery_id: aws.workmail.listAccessControlRules
  calls:
  - action: listAccessControlRules
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Rules }}'
    item:
      Name: '{{ item.Name }}'
      Effect: '{{ item.Effect }}'
      Description: '{{ item.Description }}'
      IpRanges: '{{ item.IpRanges }}'
      NotIpRanges: '{{ item.NotIpRanges }}'
      Actions: '{{ item.Actions }}'
      NotActions: '{{ item.NotActions }}'
      UserIds: '{{ item.UserIds }}'
      NotUserIds: '{{ item.NotUserIds }}'
      DateCreated: '{{ item.DateCreated }}'
      DateModified: '{{ item.DateModified }}'
      ImpersonationRoleIds: '{{ item.ImpersonationRoleIds }}'
      NotImpersonationRoleIds: '{{ item.NotImpersonationRoleIds }}'
- discovery_id: aws.workmail.listAliases
  calls:
  - action: listAliases
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Aliases }}'
- discovery_id: aws.workmail.listAvailabilityConfigurations
  calls:
  - action: listAvailabilityConfigurations
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.AvailabilityConfigurations }}'
    item:
      DomainName: '{{ item.DomainName }}'
      ProviderType: '{{ item.ProviderType }}'
      EwsProvider: '{{ item.EwsProvider }}'
      LambdaProvider: '{{ item.LambdaProvider }}'
      DateCreated: '{{ item.DateCreated }}'
      DateModified: '{{ item.DateModified }}'
- discovery_id: aws.workmail.listGroupMembers
  calls:
  - action: listGroupMembers
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Members }}'
    item:
      Id: '{{ item.Id }}'
      Name: '{{ item.Name }}'
      Type: '{{ item.Type }}'
      State: '{{ item.State }}'
      EnabledDate: '{{ item.EnabledDate }}'
      DisabledDate: '{{ item.DisabledDate }}'
- discovery_id: aws.workmail.listGroups
  calls:
  - action: listGroups
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Groups }}'
    item:
      Id: '{{ item.Id }}'
      Email: '{{ item.Email }}'
      Name: '{{ item.Name }}'
      State: '{{ item.State }}'
      EnabledDate: '{{ item.EnabledDate }}'
      DisabledDate: '{{ item.DisabledDate }}'
- discovery_id: aws.workmail.listGroupsForEntity
  calls:
  - action: listGroupsForEntity
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Groups }}'
    item:
      GroupId: '{{ item.GroupId }}'
      GroupName: '{{ item.GroupName }}'
- discovery_id: aws.workmail.listImpersonationRoles
  calls:
  - action: listImpersonationRoles
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Roles }}'
    item:
      ImpersonationRoleId: '{{ item.ImpersonationRoleId }}'
      Name: '{{ item.Name }}'
      Type: '{{ item.Type }}'
      DateCreated: '{{ item.DateCreated }}'
      DateModified: '{{ item.DateModified }}'
- discovery_id: aws.workmail.listMailDomains
  calls:
  - action: listMailDomains
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.MailDomains }}'
    item:
      DomainName: '{{ item.DomainName }}'
      DefaultDomain: '{{ item.DefaultDomain }}'
- discovery_id: aws.workmail.listMailboxExportJobs
  calls:
  - action: listMailboxExportJobs
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Jobs }}'
    item:
      JobId: '{{ item.JobId }}'
      EntityId: '{{ item.EntityId }}'
      Description: '{{ item.Description }}'
      S3BucketName: '{{ item.S3BucketName }}'
      S3Path: '{{ item.S3Path }}'
      EstimatedProgress: '{{ item.EstimatedProgress }}'
      State: '{{ item.State }}'
      StartTime: '{{ item.StartTime }}'
      EndTime: '{{ item.EndTime }}'
- discovery_id: aws.workmail.listMailboxPermissions
  calls:
  - action: listMailboxPermissions
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Permissions }}'
    item:
      GranteeId: '{{ item.GranteeId }}'
      GranteeType: '{{ item.GranteeType }}'
      PermissionValues: '{{ item.PermissionValues }}'
- discovery_id: aws.workmail.listMobileDeviceAccessOverrides
  calls:
  - action: listMobileDeviceAccessOverrides
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Overrides }}'
    item:
      UserId: '{{ item.UserId }}'
      DeviceId: '{{ item.DeviceId }}'
      Effect: '{{ item.Effect }}'
      Description: '{{ item.Description }}'
      DateCreated: '{{ item.DateCreated }}'
      DateModified: '{{ item.DateModified }}'
- discovery_id: aws.workmail.listMobileDeviceAccessRules
  calls:
  - action: listMobileDeviceAccessRules
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Rules }}'
    item:
      MobileDeviceAccessRuleId: '{{ item.MobileDeviceAccessRuleId }}'
      Name: '{{ item.Name }}'
      Description: '{{ item.Description }}'
      Effect: '{{ item.Effect }}'
      DeviceTypes: '{{ item.DeviceTypes }}'
      NotDeviceTypes: '{{ item.NotDeviceTypes }}'
      DeviceModels: '{{ item.DeviceModels }}'
      NotDeviceModels: '{{ item.NotDeviceModels }}'
      DeviceOperatingSystems: '{{ item.DeviceOperatingSystems }}'
      NotDeviceOperatingSystems: '{{ item.NotDeviceOperatingSystems }}'
      DeviceUserAgents: '{{ item.DeviceUserAgents }}'
      NotDeviceUserAgents: '{{ item.NotDeviceUserAgents }}'
      DateCreated: '{{ item.DateCreated }}'
      DateModified: '{{ item.DateModified }}'
- discovery_id: aws.workmail.listPersonalAccessTokens
  calls:
  - action: listPersonalAccessTokens
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.PersonalAccessTokenSummaries }}'
    item:
      PersonalAccessTokenId: '{{ item.PersonalAccessTokenId }}'
      UserId: '{{ item.UserId }}'
      Name: '{{ item.Name }}'
      DateCreated: '{{ item.DateCreated }}'
      DateLastUsed: '{{ item.DateLastUsed }}'
      ExpiresTime: '{{ item.ExpiresTime }}'
      Scopes: '{{ item.Scopes }}'
- discovery_id: aws.workmail.listResourceDelegates
  calls:
  - action: listResourceDelegates
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Delegates }}'
    item:
      Id: '{{ item.Id }}'
      Type: '{{ item.Type }}'
- discovery_id: aws.workmail.listResources
  calls:
  - action: listResources
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Resources }}'
    item:
      Id: '{{ item.Id }}'
      Email: '{{ item.Email }}'
      Name: '{{ item.Name }}'
      Type: '{{ item.Type }}'
      State: '{{ item.State }}'
      EnabledDate: '{{ item.EnabledDate }}'
      DisabledDate: '{{ item.DisabledDate }}'
      Description: '{{ item.Description }}'
- discovery_id: aws.workmail.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Tags }}'
    item:
      Key: '{{ item.Key }}'
      Value: '{{ item.Value }}'
- discovery_id: aws.workmail.listUsers
  calls:
  - action: listUsers
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Users }}'
    item:
      Id: '{{ item.Id }}'
      Email: '{{ item.Email }}'
      Name: '{{ item.Name }}'
      DisplayName: '{{ item.DisplayName }}'
      State: '{{ item.State }}'
      UserRole: '{{ item.UserRole }}'
      EnabledDate: '{{ item.EnabledDate }}'
      DisabledDate: '{{ item.DisabledDate }}'
      IdentityProviderUserId: '{{ item.IdentityProviderUserId }}'
      IdentityProviderIdentityStoreId: '{{ item.IdentityProviderIdentityStoreId }}'
checks: []
