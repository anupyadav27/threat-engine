version: '1.0'
provider: aws
service: iotthingsgraph
services:
  client: iotthingsgraph
  module: boto3.client
discovery:
- discovery_id: aws.iotthingsgraph.describeNamespace
  calls:
  - action: describeNamespace
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.namespaceArn }}'
- discovery_id: aws.iotthingsgraph.getNamespaceDeletionStatus
  calls:
  - action: getNamespaceDeletionStatus
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.namespaceArn }}'
- discovery_id: aws.iotthingsgraph.searchFlowTemplates
  calls:
  - action: searchFlowTemplates
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.summaries }}'
    item:
      id: '{{ item.id }}'
      arn: '{{ item.arn }}'
      revisionNumber: '{{ item.revisionNumber }}'
      createdAt: '{{ item.createdAt }}'
- discovery_id: aws.iotthingsgraph.searchSystemInstances
  calls:
  - action: searchSystemInstances
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.summaries }}'
    item:
      id: '{{ item.id }}'
      arn: '{{ item.arn }}'
      status: '{{ item.status }}'
      target: '{{ item.target }}'
      greengrassGroupName: '{{ item.greengrassGroupName }}'
      createdAt: '{{ item.createdAt }}'
      updatedAt: '{{ item.updatedAt }}'
      greengrassGroupId: '{{ item.greengrassGroupId }}'
      greengrassGroupVersionId: '{{ item.greengrassGroupVersionId }}'
- discovery_id: aws.iotthingsgraph.searchSystemTemplates
  calls:
  - action: searchSystemTemplates
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.summaries }}'
    item:
      id: '{{ item.id }}'
      arn: '{{ item.arn }}'
      revisionNumber: '{{ item.revisionNumber }}'
      createdAt: '{{ item.createdAt }}'
- discovery_id: aws.iotthingsgraph.getEntities
  calls:
  - action: getEntities
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.descriptions }}'
    item:
      id: '{{ item.id }}'
      arn: '{{ item.arn }}'
      type: '{{ item.type }}'
      createdAt: '{{ item.createdAt }}'
      definition: '{{ item.definition }}'
- discovery_id: aws.iotthingsgraph.getFlowTemplate
  calls:
  - action: getFlowTemplate
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.description }}'
    item:
      summary: '{{ item.summary }}'
      definition: '{{ item.definition }}'
      validatedNamespaceVersion: '{{ item.validatedNamespaceVersion }}'
- discovery_id: aws.iotthingsgraph.getFlowTemplateRevisions
  calls:
  - action: getFlowTemplateRevisions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.summaries }}'
    item:
      id: '{{ item.id }}'
      arn: '{{ item.arn }}'
      revisionNumber: '{{ item.revisionNumber }}'
      createdAt: '{{ item.createdAt }}'
- discovery_id: aws.iotthingsgraph.getSystemInstance
  calls:
  - action: getSystemInstance
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.description }}'
    item:
      summary: '{{ item.summary }}'
      definition: '{{ item.definition }}'
      s3BucketName: '{{ item.s3BucketName }}'
      metricsConfiguration: '{{ item.metricsConfiguration }}'
      validatedNamespaceVersion: '{{ item.validatedNamespaceVersion }}'
      validatedDependencyRevisions: '{{ item.validatedDependencyRevisions }}'
      flowActionsRoleArn: '{{ item.flowActionsRoleArn }}'
- discovery_id: aws.iotthingsgraph.getSystemTemplate
  calls:
  - action: getSystemTemplate
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.description }}'
    item:
      summary: '{{ item.summary }}'
      definition: '{{ item.definition }}'
      validatedNamespaceVersion: '{{ item.validatedNamespaceVersion }}'
- discovery_id: aws.iotthingsgraph.getSystemTemplateRevisions
  calls:
  - action: getSystemTemplateRevisions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.summaries }}'
    item:
      id: '{{ item.id }}'
      arn: '{{ item.arn }}'
      revisionNumber: '{{ item.revisionNumber }}'
      createdAt: '{{ item.createdAt }}'
- discovery_id: aws.iotthingsgraph.getUploadStatus
  calls:
  - action: getUploadStatus
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.failureReason }}'
- discovery_id: aws.iotthingsgraph.listFlowExecutionMessages
  calls:
  - action: listFlowExecutionMessages
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.messages }}'
    item:
      messageId: '{{ item.messageId }}'
      eventType: '{{ item.eventType }}'
      timestamp: '{{ item.timestamp }}'
      payload: '{{ item.payload }}'
- discovery_id: aws.iotthingsgraph.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tags }}'
    item:
      key: '{{ item.key }}'
      value: '{{ item.value }}'
- discovery_id: aws.iotthingsgraph.searchEntities
  calls:
  - action: searchEntities
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.descriptions }}'
    item:
      id: '{{ item.id }}'
      arn: '{{ item.arn }}'
      type: '{{ item.type }}'
      createdAt: '{{ item.createdAt }}'
      definition: '{{ item.definition }}'
- discovery_id: aws.iotthingsgraph.searchFlowExecutions
  calls:
  - action: searchFlowExecutions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.summaries }}'
    item:
      flowExecutionId: '{{ item.flowExecutionId }}'
      status: '{{ item.status }}'
      systemInstanceId: '{{ item.systemInstanceId }}'
      flowTemplateId: '{{ item.flowTemplateId }}'
      createdAt: '{{ item.createdAt }}'
      updatedAt: '{{ item.updatedAt }}'
- discovery_id: aws.iotthingsgraph.searchThings
  calls:
  - action: searchThings
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.things }}'
    item:
      thingArn: '{{ item.thingArn }}'
      thingName: '{{ item.thingName }}'
checks: []
