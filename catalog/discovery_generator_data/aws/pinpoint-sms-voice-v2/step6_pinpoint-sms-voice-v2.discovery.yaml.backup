version: '1.0'
provider: aws
service: pinpoint-sms-voice-v2
services:
  client: pinpoint-sms-voice-v2
  module: boto3.client
discovery:
- discovery_id: aws.pinpoint-sms-voice-v2.describeAccountAttributes
  calls:
  - action: describeAccountAttributes
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AccountAttributes }}'
    item:
      Name: '{{ item.Name }}'
      Value: '{{ item.Value }}'
- discovery_id: aws.pinpoint-sms-voice-v2.describeAccountLimits
  calls:
  - action: describeAccountLimits
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AccountLimits }}'
    item:
      Name: '{{ item.Name }}'
      Used: '{{ item.Used }}'
      Max: '{{ item.Max }}'
- discovery_id: aws.pinpoint-sms-voice-v2.describeConfigurationSets
  calls:
  - action: describeConfigurationSets
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ConfigurationSets }}'
    item:
      ConfigurationSetArn: '{{ item.ConfigurationSetArn }}'
      ConfigurationSetName: '{{ item.ConfigurationSetName }}'
      EventDestinations: '{{ item.EventDestinations }}'
      DefaultMessageType: '{{ item.DefaultMessageType }}'
      DefaultSenderId: '{{ item.DefaultSenderId }}'
      DefaultMessageFeedbackEnabled: '{{ item.DefaultMessageFeedbackEnabled }}'
      CreatedTimestamp: '{{ item.CreatedTimestamp }}'
      ProtectConfigurationId: '{{ item.ProtectConfigurationId }}'
- discovery_id: aws.pinpoint-sms-voice-v2.describeOptOutLists
  calls:
  - action: describeOptOutLists
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.OptOutLists }}'
    item:
      OptOutListArn: '{{ item.OptOutListArn }}'
      OptOutListName: '{{ item.OptOutListName }}'
      CreatedTimestamp: '{{ item.CreatedTimestamp }}'
- discovery_id: aws.pinpoint-sms-voice-v2.describePhoneNumbers
  calls:
  - action: describePhoneNumbers
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.PhoneNumbers }}'
    item:
      PhoneNumberArn: '{{ item.PhoneNumberArn }}'
      PhoneNumberId: '{{ item.PhoneNumberId }}'
      PhoneNumber: '{{ item.PhoneNumber }}'
      Status: '{{ item.Status }}'
      IsoCountryCode: '{{ item.IsoCountryCode }}'
      MessageType: '{{ item.MessageType }}'
      NumberCapabilities: '{{ item.NumberCapabilities }}'
      NumberType: '{{ item.NumberType }}'
      MonthlyLeasingPrice: '{{ item.MonthlyLeasingPrice }}'
      TwoWayEnabled: '{{ item.TwoWayEnabled }}'
      TwoWayChannelArn: '{{ item.TwoWayChannelArn }}'
      TwoWayChannelRole: '{{ item.TwoWayChannelRole }}'
      SelfManagedOptOutsEnabled: '{{ item.SelfManagedOptOutsEnabled }}'
      OptOutListName: '{{ item.OptOutListName }}'
      InternationalSendingEnabled: '{{ item.InternationalSendingEnabled }}'
      DeletionProtectionEnabled: '{{ item.DeletionProtectionEnabled }}'
      PoolId: '{{ item.PoolId }}'
      RegistrationId: '{{ item.RegistrationId }}'
      CreatedTimestamp: '{{ item.CreatedTimestamp }}'
- discovery_id: aws.pinpoint-sms-voice-v2.describePools
  calls:
  - action: describePools
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Pools }}'
    item:
      PoolArn: '{{ item.PoolArn }}'
      PoolId: '{{ item.PoolId }}'
      Status: '{{ item.Status }}'
      MessageType: '{{ item.MessageType }}'
      TwoWayEnabled: '{{ item.TwoWayEnabled }}'
      TwoWayChannelArn: '{{ item.TwoWayChannelArn }}'
      TwoWayChannelRole: '{{ item.TwoWayChannelRole }}'
      SelfManagedOptOutsEnabled: '{{ item.SelfManagedOptOutsEnabled }}'
      OptOutListName: '{{ item.OptOutListName }}'
      SharedRoutesEnabled: '{{ item.SharedRoutesEnabled }}'
      DeletionProtectionEnabled: '{{ item.DeletionProtectionEnabled }}'
      CreatedTimestamp: '{{ item.CreatedTimestamp }}'
- discovery_id: aws.pinpoint-sms-voice-v2.describeProtectConfigurations
  calls:
  - action: describeProtectConfigurations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ProtectConfigurations }}'
    item:
      ProtectConfigurationArn: '{{ item.ProtectConfigurationArn }}'
      ProtectConfigurationId: '{{ item.ProtectConfigurationId }}'
      CreatedTimestamp: '{{ item.CreatedTimestamp }}'
      AccountDefault: '{{ item.AccountDefault }}'
      DeletionProtectionEnabled: '{{ item.DeletionProtectionEnabled }}'
- discovery_id: aws.pinpoint-sms-voice-v2.describeRegistrationAttachments
  calls:
  - action: describeRegistrationAttachments
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.RegistrationAttachments }}'
    item:
      RegistrationAttachmentArn: '{{ item.RegistrationAttachmentArn }}'
      RegistrationAttachmentId: '{{ item.RegistrationAttachmentId }}'
      AttachmentStatus: '{{ item.AttachmentStatus }}'
      AttachmentUploadErrorReason: '{{ item.AttachmentUploadErrorReason }}'
      CreatedTimestamp: '{{ item.CreatedTimestamp }}'
- discovery_id: aws.pinpoint-sms-voice-v2.describeRegistrationTypeDefinitions
  calls:
  - action: describeRegistrationTypeDefinitions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.RegistrationTypeDefinitions }}'
    item:
      RegistrationType: '{{ item.RegistrationType }}'
      SupportedAssociations: '{{ item.SupportedAssociations }}'
      DisplayHints: '{{ item.DisplayHints }}'
- discovery_id: aws.pinpoint-sms-voice-v2.describeRegistrations
  calls:
  - action: describeRegistrations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Registrations }}'
    item:
      RegistrationArn: '{{ item.RegistrationArn }}'
      RegistrationId: '{{ item.RegistrationId }}'
      RegistrationType: '{{ item.RegistrationType }}'
      RegistrationStatus: '{{ item.RegistrationStatus }}'
      CurrentVersionNumber: '{{ item.CurrentVersionNumber }}'
      ApprovedVersionNumber: '{{ item.ApprovedVersionNumber }}'
      LatestDeniedVersionNumber: '{{ item.LatestDeniedVersionNumber }}'
      AdditionalAttributes: '{{ item.AdditionalAttributes }}'
      CreatedTimestamp: '{{ item.CreatedTimestamp }}'
- discovery_id: aws.pinpoint-sms-voice-v2.describeSenderIds
  calls:
  - action: describeSenderIds
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.SenderIds }}'
    item:
      SenderIdArn: '{{ item.SenderIdArn }}'
      SenderId: '{{ item.SenderId }}'
      IsoCountryCode: '{{ item.IsoCountryCode }}'
      MessageTypes: '{{ item.MessageTypes }}'
      MonthlyLeasingPrice: '{{ item.MonthlyLeasingPrice }}'
      DeletionProtectionEnabled: '{{ item.DeletionProtectionEnabled }}'
      Registered: '{{ item.Registered }}'
      RegistrationId: '{{ item.RegistrationId }}'
- discovery_id: aws.pinpoint-sms-voice-v2.describeSpendLimits
  calls:
  - action: describeSpendLimits
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.SpendLimits }}'
    item:
      Name: '{{ item.Name }}'
      EnforcedLimit: '{{ item.EnforcedLimit }}'
      MaxLimit: '{{ item.MaxLimit }}'
      Overridden: '{{ item.Overridden }}'
- discovery_id: aws.pinpoint-sms-voice-v2.describeVerifiedDestinationNumbers
  calls:
  - action: describeVerifiedDestinationNumbers
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.VerifiedDestinationNumbers }}'
    item:
      VerifiedDestinationNumberArn: '{{ item.VerifiedDestinationNumberArn }}'
      VerifiedDestinationNumberId: '{{ item.VerifiedDestinationNumberId }}'
      DestinationPhoneNumber: '{{ item.DestinationPhoneNumber }}'
      Status: '{{ item.Status }}'
      CreatedTimestamp: '{{ item.CreatedTimestamp }}'
- discovery_id: aws.pinpoint-sms-voice-v2.describeKeywords
  calls:
  - action: describeKeywords
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Keywords }}'
    item:
      Keyword: '{{ item.Keyword }}'
      KeywordMessage: '{{ item.KeywordMessage }}'
      KeywordAction: '{{ item.KeywordAction }}'
- discovery_id: aws.pinpoint-sms-voice-v2.describeOptedOutNumbers
  calls:
  - action: describeOptedOutNumbers
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.OptedOutNumbers }}'
    item:
      OptedOutNumber: '{{ item.OptedOutNumber }}'
      OptedOutTimestamp: '{{ item.OptedOutTimestamp }}'
      EndUserOptedOut: '{{ item.EndUserOptedOut }}'
- discovery_id: aws.pinpoint-sms-voice-v2.describeRegistrationFieldDefinitions
  calls:
  - action: describeRegistrationFieldDefinitions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.RegistrationFieldDefinitions }}'
    item:
      SectionPath: '{{ item.SectionPath }}'
      FieldPath: '{{ item.FieldPath }}'
      FieldType: '{{ item.FieldType }}'
      FieldRequirement: '{{ item.FieldRequirement }}'
      SelectValidation: '{{ item.SelectValidation }}'
      TextValidation: '{{ item.TextValidation }}'
      DisplayHints: '{{ item.DisplayHints }}'
- discovery_id: aws.pinpoint-sms-voice-v2.describeRegistrationFieldValues
  calls:
  - action: describeRegistrationFieldValues
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.RegistrationFieldValues }}'
    item:
      FieldPath: '{{ item.FieldPath }}'
      SelectChoices: '{{ item.SelectChoices }}'
      TextValue: '{{ item.TextValue }}'
      RegistrationAttachmentId: '{{ item.RegistrationAttachmentId }}'
      DeniedReason: '{{ item.DeniedReason }}'
- discovery_id: aws.pinpoint-sms-voice-v2.describeRegistrationSectionDefinitions
  calls:
  - action: describeRegistrationSectionDefinitions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.RegistrationSectionDefinitions }}'
    item:
      SectionPath: '{{ item.SectionPath }}'
      DisplayHints: '{{ item.DisplayHints }}'
- discovery_id: aws.pinpoint-sms-voice-v2.describeRegistrationVersions
  calls:
  - action: describeRegistrationVersions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.RegistrationVersions }}'
    item:
      VersionNumber: '{{ item.VersionNumber }}'
      RegistrationVersionStatus: '{{ item.RegistrationVersionStatus }}'
      RegistrationVersionStatusHistory: '{{ item.RegistrationVersionStatusHistory
        }}'
      DeniedReasons: '{{ item.DeniedReasons }}'
- discovery_id: aws.pinpoint-sms-voice-v2.getProtectConfigurationCountryRuleSet
  calls:
  - action: getProtectConfigurationCountryRuleSet
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ProtectConfigurationArn }}'
- discovery_id: aws.pinpoint-sms-voice-v2.getResourcePolicy
  calls:
  - action: getResourcePolicy
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ResourceArn }}'
- discovery_id: aws.pinpoint-sms-voice-v2.listPoolOriginationIdentities
  calls:
  - action: listPoolOriginationIdentities
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.OriginationIdentities }}'
    item:
      OriginationIdentityArn: '{{ item.OriginationIdentityArn }}'
      OriginationIdentity: '{{ item.OriginationIdentity }}'
      IsoCountryCode: '{{ item.IsoCountryCode }}'
      NumberCapabilities: '{{ item.NumberCapabilities }}'
      PhoneNumber: '{{ item.PhoneNumber }}'
- discovery_id: aws.pinpoint-sms-voice-v2.listProtectConfigurationRuleSetNumberOverrides
  calls:
  - action: listProtectConfigurationRuleSetNumberOverrides
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.RuleSetNumberOverrides }}'
    item:
      DestinationPhoneNumber: '{{ item.DestinationPhoneNumber }}'
      CreatedTimestamp: '{{ item.CreatedTimestamp }}'
      Action: '{{ item.Action }}'
      IsoCountryCode: '{{ item.IsoCountryCode }}'
      ExpirationTimestamp: '{{ item.ExpirationTimestamp }}'
- discovery_id: aws.pinpoint-sms-voice-v2.listRegistrationAssociations
  calls:
  - action: listRegistrationAssociations
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.RegistrationAssociations }}'
    item:
      ResourceArn: '{{ item.ResourceArn }}'
      ResourceId: '{{ item.ResourceId }}'
      ResourceType: '{{ item.ResourceType }}'
      IsoCountryCode: '{{ item.IsoCountryCode }}'
      PhoneNumber: '{{ item.PhoneNumber }}'
- discovery_id: aws.pinpoint-sms-voice-v2.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Tags }}'
    item:
      Key: '{{ item.Key }}'
      Value: '{{ item.Value }}'
checks: []
