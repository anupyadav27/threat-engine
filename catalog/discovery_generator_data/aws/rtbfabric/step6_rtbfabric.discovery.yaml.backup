version: '1.0'
provider: aws
service: rtbfabric
services:
  client: rtbfabric
  module: boto3.client
discovery:
- discovery_id: aws.rtbfabric.listRequesterGateways
  calls:
  - action: listRequesterGateways
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.gatewayIds }}'
- discovery_id: aws.rtbfabric.listResponderGateways
  calls:
  - action: listResponderGateways
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.gatewayIds }}'
- discovery_id: aws.rtbfabric.getInboundExternalLink
  calls:
  - action: getInboundExternalLink
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.flowModules }}'
    item:
      version: '{{ item.version }}'
      name: '{{ item.name }}'
      dependsOn: '{{ item.dependsOn }}'
      moduleParameters: '{{ item.moduleParameters }}'
- discovery_id: aws.rtbfabric.getLink
  calls:
  - action: getLink
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.flowModules }}'
    item:
      version: '{{ item.version }}'
      name: '{{ item.name }}'
      dependsOn: '{{ item.dependsOn }}'
      moduleParameters: '{{ item.moduleParameters }}'
- discovery_id: aws.rtbfabric.getOutboundExternalLink
  calls:
  - action: getOutboundExternalLink
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.logSettings }}'
    item:
      applicationLogs: '{{ item.applicationLogs }}'
- discovery_id: aws.rtbfabric.getRequesterGateway
  calls:
  - action: getRequesterGateway
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.subnetIds }}'
- discovery_id: aws.rtbfabric.getResponderGateway
  calls:
  - action: getResponderGateway
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.subnetIds }}'
- discovery_id: aws.rtbfabric.listLinks
  calls:
  - action: listLinks
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.links }}'
    item:
      gatewayId: '{{ item.gatewayId }}'
      peerGatewayId: '{{ item.peerGatewayId }}'
      status: '{{ item.status }}'
      createdAt: '{{ item.createdAt }}'
      updatedAt: '{{ item.updatedAt }}'
      direction: '{{ item.direction }}'
      flowModules: '{{ item.flowModules }}'
      pendingFlowModules: '{{ item.pendingFlowModules }}'
      attributes: '{{ item.attributes }}'
      linkId: '{{ item.linkId }}'
      tags: '{{ item.tags }}'
- discovery_id: aws.rtbfabric.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tags }}'
checks: []
