version: '1.0'
provider: aws
service: identitycenter
services:
  client: identitycenter
  module: boto3.client
discovery:
- discovery_id: aws.identitycenter.getRoleCredentials
  calls:
  - action: getRoleCredentials
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.roleCredentials }}'
    item:
      accessKeyId: '{{ item.accessKeyId }}'
      secretAccessKey: '{{ item.secretAccessKey }}'
      sessionToken: '{{ item.sessionToken }}'
      expiration: '{{ item.expiration }}'
- discovery_id: aws.identitycenter.listAccountRoles
  calls:
  - action: listAccountRoles
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.roleList }}'
    item:
      roleName: '{{ item.roleName }}'
      accountId: '{{ item.accountId }}'
- discovery_id: aws.identitycenter.listAccounts
  calls:
  - action: listAccounts
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.accountList }}'
    item:
      accountId: '{{ item.accountId }}'
      accountName: '{{ item.accountName }}'
      emailAddress: '{{ item.emailAddress }}'
checks: []
