version: '1.0'
provider: aws
service: trustedadvisor
services:
  client: trustedadvisor
  module: boto3.client
discovery:
- discovery_id: aws.trustedadvisor.listChecks
  calls:
  - action: listChecks
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.checkSummaries }}'
    item:
      arn: '{{ item.arn }}'
      awsServices: '{{ item.awsServices }}'
      description: '{{ item.description }}'
      id: '{{ item.id }}'
      metadata: '{{ item.metadata }}'
      name: '{{ item.name }}'
      pillars: '{{ item.pillars }}'
      source: '{{ item.source }}'
- discovery_id: aws.trustedadvisor.listOrganizationRecommendations
  calls:
  - action: listOrganizationRecommendations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.organizationRecommendationSummaries }}'
    item:
      arn: '{{ item.arn }}'
      awsServices: '{{ item.awsServices }}'
      checkArn: '{{ item.checkArn }}'
      createdAt: '{{ item.createdAt }}'
      id: '{{ item.id }}'
      lastUpdatedAt: '{{ item.lastUpdatedAt }}'
      lifecycleStage: '{{ item.lifecycleStage }}'
      name: '{{ item.name }}'
      pillarSpecificAggregates: '{{ item.pillarSpecificAggregates }}'
      pillars: '{{ item.pillars }}'
      resourcesAggregates: '{{ item.resourcesAggregates }}'
      source: '{{ item.source }}'
      status: '{{ item.status }}'
      type: '{{ item.type }}'
- discovery_id: aws.trustedadvisor.listRecommendations
  calls:
  - action: listRecommendations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.recommendationSummaries }}'
    item:
      arn: '{{ item.arn }}'
      awsServices: '{{ item.awsServices }}'
      checkArn: '{{ item.checkArn }}'
      createdAt: '{{ item.createdAt }}'
      id: '{{ item.id }}'
      lastUpdatedAt: '{{ item.lastUpdatedAt }}'
      lifecycleStage: '{{ item.lifecycleStage }}'
      name: '{{ item.name }}'
      pillarSpecificAggregates: '{{ item.pillarSpecificAggregates }}'
      pillars: '{{ item.pillars }}'
      resourcesAggregates: '{{ item.resourcesAggregates }}'
      source: '{{ item.source }}'
      status: '{{ item.status }}'
      type: '{{ item.type }}'
- discovery_id: aws.trustedadvisor.getOrganizationRecommendation
  calls:
  - action: getOrganizationRecommendation
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.organizationRecommendation }}'
    item:
      arn: '{{ item.arn }}'
      awsServices: '{{ item.awsServices }}'
      checkArn: '{{ item.checkArn }}'
      createdAt: '{{ item.createdAt }}'
      createdBy: '{{ item.createdBy }}'
      description: '{{ item.description }}'
      id: '{{ item.id }}'
      lastUpdatedAt: '{{ item.lastUpdatedAt }}'
      lifecycleStage: '{{ item.lifecycleStage }}'
      name: '{{ item.name }}'
      pillarSpecificAggregates: '{{ item.pillarSpecificAggregates }}'
      pillars: '{{ item.pillars }}'
      resolvedAt: '{{ item.resolvedAt }}'
      resourcesAggregates: '{{ item.resourcesAggregates }}'
      source: '{{ item.source }}'
      status: '{{ item.status }}'
      type: '{{ item.type }}'
      updateReason: '{{ item.updateReason }}'
      updateReasonCode: '{{ item.updateReasonCode }}'
      updatedOnBehalfOf: '{{ item.updatedOnBehalfOf }}'
      updatedOnBehalfOfJobTitle: '{{ item.updatedOnBehalfOfJobTitle }}'
- discovery_id: aws.trustedadvisor.getRecommendation
  calls:
  - action: getRecommendation
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.recommendation }}'
    item:
      arn: '{{ item.arn }}'
      awsServices: '{{ item.awsServices }}'
      checkArn: '{{ item.checkArn }}'
      createdAt: '{{ item.createdAt }}'
      createdBy: '{{ item.createdBy }}'
      description: '{{ item.description }}'
      id: '{{ item.id }}'
      lastUpdatedAt: '{{ item.lastUpdatedAt }}'
      lifecycleStage: '{{ item.lifecycleStage }}'
      name: '{{ item.name }}'
      pillarSpecificAggregates: '{{ item.pillarSpecificAggregates }}'
      pillars: '{{ item.pillars }}'
      resolvedAt: '{{ item.resolvedAt }}'
      resourcesAggregates: '{{ item.resourcesAggregates }}'
      source: '{{ item.source }}'
      status: '{{ item.status }}'
      type: '{{ item.type }}'
      updateReason: '{{ item.updateReason }}'
      updateReasonCode: '{{ item.updateReasonCode }}'
      updatedOnBehalfOf: '{{ item.updatedOnBehalfOf }}'
      updatedOnBehalfOfJobTitle: '{{ item.updatedOnBehalfOfJobTitle }}'
- discovery_id: aws.trustedadvisor.listOrganizationRecommendationAccounts
  calls:
  - action: listOrganizationRecommendationAccounts
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.accountRecommendationLifecycleSummaries }}'
    item:
      accountId: '{{ item.accountId }}'
      accountRecommendationArn: '{{ item.accountRecommendationArn }}'
      lastUpdatedAt: '{{ item.lastUpdatedAt }}'
      lifecycleStage: '{{ item.lifecycleStage }}'
      updateReason: '{{ item.updateReason }}'
      updateReasonCode: '{{ item.updateReasonCode }}'
      updatedOnBehalfOf: '{{ item.updatedOnBehalfOf }}'
      updatedOnBehalfOfJobTitle: '{{ item.updatedOnBehalfOfJobTitle }}'
- discovery_id: aws.trustedadvisor.listOrganizationRecommendationResources
  calls:
  - action: listOrganizationRecommendationResources
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.organizationRecommendationResourceSummaries }}'
    item:
      accountId: '{{ item.accountId }}'
      arn: '{{ item.arn }}'
      awsResourceId: '{{ item.awsResourceId }}'
      exclusionStatus: '{{ item.exclusionStatus }}'
      id: '{{ item.id }}'
      lastUpdatedAt: '{{ item.lastUpdatedAt }}'
      metadata: '{{ item.metadata }}'
      recommendationArn: '{{ item.recommendationArn }}'
      regionCode: '{{ item.regionCode }}'
      status: '{{ item.status }}'
- discovery_id: aws.trustedadvisor.listRecommendationResources
  calls:
  - action: listRecommendationResources
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.recommendationResourceSummaries }}'
    item:
      arn: '{{ item.arn }}'
      awsResourceId: '{{ item.awsResourceId }}'
      exclusionStatus: '{{ item.exclusionStatus }}'
      id: '{{ item.id }}'
      lastUpdatedAt: '{{ item.lastUpdatedAt }}'
      metadata: '{{ item.metadata }}'
      recommendationArn: '{{ item.recommendationArn }}'
      regionCode: '{{ item.regionCode }}'
      status: '{{ item.status }}'
checks: []
