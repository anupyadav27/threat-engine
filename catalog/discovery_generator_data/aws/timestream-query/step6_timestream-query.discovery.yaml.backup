version: '1.0'
provider: aws
service: timestream-query
services:
  client: timestream-query
  module: boto3.client
discovery:
- discovery_id: aws.timestream-query.describeAccountSettings
  calls:
  - action: describeAccountSettings
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.QueryCompute }}'
    item:
      ComputeMode: '{{ item.ComputeMode }}'
      ProvisionedCapacity: '{{ item.ProvisionedCapacity }}'
- discovery_id: aws.timestream-query.describeEndpoints
  calls:
  - action: describeEndpoints
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Endpoints }}'
    item:
      Address: '{{ item.Address }}'
      CachePeriodInMinutes: '{{ item.CachePeriodInMinutes }}'
- discovery_id: aws.timestream-query.listScheduledQueries
  calls:
  - action: listScheduledQueries
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.ScheduledQueries }}'
    item:
      Arn: '{{ item.Arn }}'
      Name: '{{ item.Name }}'
      CreationTime: '{{ item.CreationTime }}'
      State: '{{ item.State }}'
      PreviousInvocationTime: '{{ item.PreviousInvocationTime }}'
      NextInvocationTime: '{{ item.NextInvocationTime }}'
      ErrorReportConfiguration: '{{ item.ErrorReportConfiguration }}'
      TargetDestination: '{{ item.TargetDestination }}'
      LastRunStatus: '{{ item.LastRunStatus }}'
- discovery_id: aws.timestream-query.describeScheduledQuery
  calls:
  - action: describeScheduledQuery
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ScheduledQuery }}'
    item:
      Arn: '{{ item.Arn }}'
      Name: '{{ item.Name }}'
      QueryString: '{{ item.QueryString }}'
      CreationTime: '{{ item.CreationTime }}'
      State: '{{ item.State }}'
      PreviousInvocationTime: '{{ item.PreviousInvocationTime }}'
      NextInvocationTime: '{{ item.NextInvocationTime }}'
      ScheduleConfiguration: '{{ item.ScheduleConfiguration }}'
      NotificationConfiguration: '{{ item.NotificationConfiguration }}'
      TargetConfiguration: '{{ item.TargetConfiguration }}'
      ScheduledQueryExecutionRoleArn: '{{ item.ScheduledQueryExecutionRoleArn }}'
      KmsKeyId: '{{ item.KmsKeyId }}'
      ErrorReportConfiguration: '{{ item.ErrorReportConfiguration }}'
      LastRunSummary: '{{ item.LastRunSummary }}'
      RecentlyFailedRuns: '{{ item.RecentlyFailedRuns }}'
- discovery_id: aws.timestream-query.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Tags }}'
    item:
      Key: '{{ item.Key }}'
      Value: '{{ item.Value }}'
- discovery_id: aws.timestream-query.query
  calls:
  - action: query
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Rows }}'
    item:
      Data: '{{ item.Data }}'
checks: []
