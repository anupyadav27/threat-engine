version: '1.0'
provider: aws
service: kafkaconnect
services:
  client: kafkaconnect
  module: boto3.client
discovery:
- discovery_id: aws.kafkaconnect.listConnectors
  calls:
  - action: listConnectors
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.connectors }}'
    item:
      capacity: '{{ item.capacity }}'
      connectorArn: '{{ item.connectorArn }}'
      connectorDescription: '{{ item.connectorDescription }}'
      connectorName: '{{ item.connectorName }}'
      connectorState: '{{ item.connectorState }}'
      creationTime: '{{ item.creationTime }}'
      currentVersion: '{{ item.currentVersion }}'
      kafkaCluster: '{{ item.kafkaCluster }}'
      kafkaClusterClientAuthentication: '{{ item.kafkaClusterClientAuthentication
        }}'
      kafkaClusterEncryptionInTransit: '{{ item.kafkaClusterEncryptionInTransit }}'
      kafkaConnectVersion: '{{ item.kafkaConnectVersion }}'
      logDelivery: '{{ item.logDelivery }}'
      plugins: '{{ item.plugins }}'
      serviceExecutionRoleArn: '{{ item.serviceExecutionRoleArn }}'
      workerConfiguration: '{{ item.workerConfiguration }}'
- discovery_id: aws.kafkaconnect.listCustomPlugins
  calls:
  - action: listCustomPlugins
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.customPlugins }}'
    item:
      creationTime: '{{ item.creationTime }}'
      customPluginArn: '{{ item.customPluginArn }}'
      customPluginState: '{{ item.customPluginState }}'
      description: '{{ item.description }}'
      latestRevision: '{{ item.latestRevision }}'
      name: '{{ item.name }}'
- discovery_id: aws.kafkaconnect.listWorkerConfigurations
  calls:
  - action: listWorkerConfigurations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.workerConfigurations }}'
    item:
      creationTime: '{{ item.creationTime }}'
      description: '{{ item.description }}'
      latestRevision: '{{ item.latestRevision }}'
      name: '{{ item.name }}'
      workerConfigurationArn: '{{ item.workerConfigurationArn }}'
      workerConfigurationState: '{{ item.workerConfigurationState }}'
- discovery_id: aws.kafkaconnect.describeConnector
  calls:
  - action: describeConnector
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.plugins }}'
    item:
      customPlugin: '{{ item.customPlugin }}'
- discovery_id: aws.kafkaconnect.describeConnectorOperation
  calls:
  - action: describeConnectorOperation
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.operationSteps }}'
    item:
      stepType: '{{ item.stepType }}'
      stepState: '{{ item.stepState }}'
- discovery_id: aws.kafkaconnect.describeCustomPlugin
  calls:
  - action: describeCustomPlugin
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.latestRevision }}'
    item:
      contentType: '{{ item.contentType }}'
      creationTime: '{{ item.creationTime }}'
      description: '{{ item.description }}'
      fileDescription: '{{ item.fileDescription }}'
      location: '{{ item.location }}'
      revision: '{{ item.revision }}'
- discovery_id: aws.kafkaconnect.describeWorkerConfiguration
  calls:
  - action: describeWorkerConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.latestRevision }}'
    item:
      creationTime: '{{ item.creationTime }}'
      description: '{{ item.description }}'
      propertiesFileContent: '{{ item.propertiesFileContent }}'
      revision: '{{ item.revision }}'
- discovery_id: aws.kafkaconnect.listConnectorOperations
  calls:
  - action: listConnectorOperations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.connectorOperations }}'
    item:
      connectorOperationArn: '{{ item.connectorOperationArn }}'
      connectorOperationType: '{{ item.connectorOperationType }}'
      connectorOperationState: '{{ item.connectorOperationState }}'
      creationTime: '{{ item.creationTime }}'
      endTime: '{{ item.endTime }}'
- discovery_id: aws.kafkaconnect.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tags }}'
checks: []
