version: '1.0'
provider: aws
service: cleanrooms
services:
  client: cleanrooms
  module: boto3.client
discovery:
- discovery_id: aws.cleanrooms.list_collaborations
  calls:
  - action: list_collaborations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.collaborationList }}'
    item:
      analyticsEngine: '{{ item.analyticsEngine }}'
      arn: '{{ item.arn }}'
      collaboration: '{{ item.collaboration }}'
      createTime: '{{ item.createTime }}'
      creatorAccountId: '{{ item.creatorAccountId }}'
      creatorDisplayName: '{{ item.creatorDisplayName }}'
      id: '{{ item.id }}'
      memberStatus: '{{ item.memberStatus }}'
      membershipArn: '{{ item.membershipArn }}'
      membershipId: '{{ item.membershipId }}'
      name: '{{ item.name }}'
      updateTime: '{{ item.updateTime }}'
- discovery_id: aws.cleanrooms.list_configured_tables
  calls:
  - action: list_configured_tables
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.configuredTableSummaries }}'
    item:
      analysisMethod: '{{ item.analysisMethod }}'
      analysisRuleTypes: '{{ item.analysisRuleTypes }}'
      arn: '{{ item.arn }}'
      createTime: '{{ item.createTime }}'
      id: '{{ item.id }}'
      name: '{{ item.name }}'
      selectedAnalysisMethods: '{{ item.selectedAnalysisMethods }}'
      updateTime: '{{ item.updateTime }}'
- discovery_id: aws.cleanrooms.list_memberships
  calls:
  - action: list_memberships
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.membershipSummaries }}'
    item:
      Status: '{{ item.Status }}'
      Enabled: '{{ item.Enabled }}'
      arn: '{{ item.arn }}'
      collaborationArn: '{{ item.collaborationArn }}'
      collaborationCreatorAccountId: '{{ item.collaborationCreatorAccountId }}'
      collaborationCreatorDisplayName: '{{ item.collaborationCreatorDisplayName }}'
      collaborationId: '{{ item.collaborationId }}'
      collaborationName: '{{ item.collaborationName }}'
      createTime: '{{ item.createTime }}'
      id: '{{ item.id }}'
      memberAbilities: '{{ item.memberAbilities }}'
      membership: '{{ item.membership }}'
      mlMemberAbilities: '{{ item.mlMemberAbilities }}'
      paymentConfiguration: '{{ item.paymentConfiguration }}'
      status: '{{ item.status }}'
      updateTime: '{{ item.updateTime }}'
- discovery_id: aws.cleanrooms.get_analysis_template
  calls:
  - action: get_analysis_template
    save_as: response
    on_error: continue
  emit:
    as: item
    item:
      analysisParameters: '{{ response.analysisTemplate.analysisParameters }}'
      arn: '{{ response.analysisTemplate.arn }}'
      collaborationArn: '{{ response.analysisTemplate.collaborationArn }}'
      collaborationId: '{{ response.analysisTemplate.collaborationId }}'
      createTime: '{{ response.analysisTemplate.createTime }}'
      description: '{{ response.analysisTemplate.description }}'
      errorMessageConfiguration: '{{ response.analysisTemplate.errorMessageConfiguration
        }}'
      format: '{{ response.analysisTemplate.format }}'
      id: '{{ response.analysisTemplate.id }}'
      membershipArn: '{{ response.analysisTemplate.membershipArn }}'
      membershipId: '{{ response.analysisTemplate.membershipId }}'
      name: '{{ response.analysisTemplate.name }}'
      schema: '{{ response.analysisTemplate.schema }}'
      source: '{{ response.analysisTemplate.source }}'
      sourceMetadata: '{{ response.analysisTemplate.sourceMetadata }}'
      updateTime: '{{ response.analysisTemplate.updateTime }}'
      validations: '{{ response.analysisTemplate.validations }}'
- discovery_id: aws.cleanrooms.get_collaboration
  calls:
  - action: get_collaboration
    save_as: response
    on_error: continue
  emit:
    as: item
    item:
      allowedResultRegions: '{{ response.collaboration.allowedResultRegions }}'
      analyticsEngine: '{{ response.collaboration.analyticsEngine }}'
      arn: '{{ response.collaboration.arn }}'
      autoApprovedChangeTypes: '{{ response.collaboration.autoApprovedChangeTypes
        }}'
      createTime: '{{ response.collaboration.createTime }}'
      creatorAccountId: '{{ response.collaboration.creatorAccountId }}'
      creatorDisplayName: '{{ response.collaboration.creatorDisplayName }}'
      dataEncryptionMetadata: '{{ response.collaboration.dataEncryptionMetadata }}'
      description: '{{ response.collaboration.description }}'
      id: '{{ response.collaboration.id }}'
      jobLogStatus: '{{ response.collaboration.jobLogStatus }}'
      memberStatus: '{{ response.collaboration.memberStatus }}'
      membershipArn: '{{ response.collaboration.membershipArn }}'
      membershipId: '{{ response.collaboration.membershipId }}'
      name: '{{ response.collaboration.name }}'
      queryLogStatus: '{{ response.collaboration.queryLogStatus }}'
      updateTime: '{{ response.collaboration.updateTime }}'
- discovery_id: aws.cleanrooms.get_collaboration_analysis_template
  calls:
  - action: get_collaboration_analysis_template
    save_as: response
    on_error: continue
  emit:
    as: item
    item:
      analysisParameters: '{{ response.collaborationAnalysisTemplate.analysisParameters
        }}'
      arn: '{{ response.collaborationAnalysisTemplate.arn }}'
      collaborationArn: '{{ response.collaborationAnalysisTemplate.collaborationArn
        }}'
      collaborationId: '{{ response.collaborationAnalysisTemplate.collaborationId
        }}'
      createTime: '{{ response.collaborationAnalysisTemplate.createTime }}'
      creatorAccountId: '{{ response.collaborationAnalysisTemplate.creatorAccountId
        }}'
      description: '{{ response.collaborationAnalysisTemplate.description }}'
      errorMessageConfiguration: '{{ response.collaborationAnalysisTemplate.errorMessageConfiguration
        }}'
      format: '{{ response.collaborationAnalysisTemplate.format }}'
      id: '{{ response.collaborationAnalysisTemplate.id }}'
      name: '{{ response.collaborationAnalysisTemplate.name }}'
      schema: '{{ response.collaborationAnalysisTemplate.schema }}'
      source: '{{ response.collaborationAnalysisTemplate.source }}'
      sourceMetadata: '{{ response.collaborationAnalysisTemplate.sourceMetadata }}'
      updateTime: '{{ response.collaborationAnalysisTemplate.updateTime }}'
      validations: '{{ response.collaborationAnalysisTemplate.validations }}'
- discovery_id: aws.cleanrooms.get_collaboration_change_request
  calls:
  - action: get_collaboration_change_request
    save_as: response
    on_error: continue
  emit:
    as: item
    item:
      changes: '{{ response.collaborationChangeRequest.changes }}'
      collaborationId: '{{ response.collaborationChangeRequest.collaborationId }}'
      createTime: '{{ response.collaborationChangeRequest.createTime }}'
      id: '{{ response.collaborationChangeRequest.id }}'
      isAutoApproved: '{{ response.collaborationChangeRequest.isAutoApproved }}'
      status: '{{ response.collaborationChangeRequest.status }}'
      updateTime: '{{ response.collaborationChangeRequest.updateTime }}'
- discovery_id: aws.cleanrooms.get_collaboration_configured_audience_model_association
  calls:
  - action: get_collaboration_configured_audience_model_association
    save_as: response
    on_error: continue
  emit:
    as: item
    item:
      arn: '{{ response.collaborationConfiguredAudienceModelAssociation.arn }}'
      collaborationArn: '{{ response.collaborationConfiguredAudienceModelAssociation.collaborationArn
        }}'
      collaborationId: '{{ response.collaborationConfiguredAudienceModelAssociation.collaborationId
        }}'
      configuredAudienceModelArn: '{{ response.collaborationConfiguredAudienceModelAssociation.configuredAudienceModelArn
        }}'
      createTime: '{{ response.collaborationConfiguredAudienceModelAssociation.createTime
        }}'
      creatorAccountId: '{{ response.collaborationConfiguredAudienceModelAssociation.creatorAccountId
        }}'
      description: '{{ response.collaborationConfiguredAudienceModelAssociation.description
        }}'
      id: '{{ response.collaborationConfiguredAudienceModelAssociation.id }}'
      name: '{{ response.collaborationConfiguredAudienceModelAssociation.name }}'
      updateTime: '{{ response.collaborationConfiguredAudienceModelAssociation.updateTime
        }}'
- discovery_id: aws.cleanrooms.get_collaboration_id_namespace_association
  calls:
  - action: get_collaboration_id_namespace_association
    save_as: response
    on_error: continue
  emit:
    as: item
    item:
      arn: '{{ response.collaborationIdNamespaceAssociation.arn }}'
      collaborationArn: '{{ response.collaborationIdNamespaceAssociation.collaborationArn
        }}'
      collaborationId: '{{ response.collaborationIdNamespaceAssociation.collaborationId
        }}'
      createTime: '{{ response.collaborationIdNamespaceAssociation.createTime }}'
      creatorAccountId: '{{ response.collaborationIdNamespaceAssociation.creatorAccountId
        }}'
      description: '{{ response.collaborationIdNamespaceAssociation.description }}'
      id: '{{ response.collaborationIdNamespaceAssociation.id }}'
      idMappingConfig: '{{ response.collaborationIdNamespaceAssociation.idMappingConfig
        }}'
      inputReferenceConfig: '{{ response.collaborationIdNamespaceAssociation.inputReferenceConfig
        }}'
      inputReferenceProperties: '{{ response.collaborationIdNamespaceAssociation.inputReferenceProperties
        }}'
      name: '{{ response.collaborationIdNamespaceAssociation.name }}'
      updateTime: '{{ response.collaborationIdNamespaceAssociation.updateTime }}'
- discovery_id: aws.cleanrooms.get_collaboration_privacy_budget_template
  calls:
  - action: get_collaboration_privacy_budget_template
    save_as: response
    on_error: continue
  emit:
    as: item
    item:
      arn: '{{ response.collaborationPrivacyBudgetTemplate.arn }}'
      autoRefresh: '{{ response.collaborationPrivacyBudgetTemplate.autoRefresh }}'
      collaborationArn: '{{ response.collaborationPrivacyBudgetTemplate.collaborationArn
        }}'
      collaborationId: '{{ response.collaborationPrivacyBudgetTemplate.collaborationId
        }}'
      createTime: '{{ response.collaborationPrivacyBudgetTemplate.createTime }}'
      creatorAccountId: '{{ response.collaborationPrivacyBudgetTemplate.creatorAccountId
        }}'
      id: '{{ response.collaborationPrivacyBudgetTemplate.id }}'
      parameters: '{{ response.collaborationPrivacyBudgetTemplate.parameters }}'
      privacyBudgetType: '{{ response.collaborationPrivacyBudgetTemplate.privacyBudgetType
        }}'
      updateTime: '{{ response.collaborationPrivacyBudgetTemplate.updateTime }}'
- discovery_id: aws.cleanrooms.get_configured_audience_model_association
  calls:
  - action: get_configured_audience_model_association
    save_as: response
    on_error: continue
  emit:
    as: item
    item:
      arn: '{{ response.configuredAudienceModelAssociation.arn }}'
      collaborationArn: '{{ response.configuredAudienceModelAssociation.collaborationArn
        }}'
      collaborationId: '{{ response.configuredAudienceModelAssociation.collaborationId
        }}'
      configuredAudienceModelArn: '{{ response.configuredAudienceModelAssociation.configuredAudienceModelArn
        }}'
      createTime: '{{ response.configuredAudienceModelAssociation.createTime }}'
      description: '{{ response.configuredAudienceModelAssociation.description }}'
      id: '{{ response.configuredAudienceModelAssociation.id }}'
      manageResourcePolicies: '{{ response.configuredAudienceModelAssociation.manageResourcePolicies
        }}'
      membershipArn: '{{ response.configuredAudienceModelAssociation.membershipArn
        }}'
      membershipId: '{{ response.configuredAudienceModelAssociation.membershipId }}'
      name: '{{ response.configuredAudienceModelAssociation.name }}'
      updateTime: '{{ response.configuredAudienceModelAssociation.updateTime }}'
- discovery_id: aws.cleanrooms.get_configured_table
  calls:
  - action: get_configured_table
    save_as: response
    on_error: continue
  emit:
