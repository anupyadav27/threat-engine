      description: '{{ response.idMappingTable.description }}'
      id: '{{ response.idMappingTable.id }}'
      inputReferenceConfig: '{{ response.idMappingTable.inputReferenceConfig }}'
      inputReferenceProperties: '{{ response.idMappingTable.inputReferenceProperties
        }}'
      kmsKeyArn: '{{ response.idMappingTable.kmsKeyArn }}'
      membershipArn: '{{ response.idMappingTable.membershipArn }}'
      membershipId: '{{ response.idMappingTable.membershipId }}'
