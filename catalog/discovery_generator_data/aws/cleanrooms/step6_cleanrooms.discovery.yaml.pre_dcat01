    save_as: response
    on_error: continue
  emit:
    as: item
    item:
      arn: '{{ response.idNamespaceAssociation.arn }}'
      collaborationArn: '{{ response.idNamespaceAssociation.collaborationArn }}'
      collaborationId: '{{ response.idNamespaceAssociation.collaborationId }}'
      createTime: '{{ response.idNamespaceAssociation.createTime }}'
      description: '{{ response.idNamespaceAssociation.description }}'
      id: '{{ response.idNamespaceAssociation.id }}'
      idMappingConfig: '{{ response.idNamespaceAssociation.idMappingConfig }}'
      inputReferenceConfig: '{{ response.idNamespaceAssociation.inputReferenceConfig
        }}'
      inputReferenceProperties: '{{ response.idNamespaceAssociation.inputReferenceProperties
        }}'
      membershipArn: '{{ response.idNamespaceAssociation.membershipArn }}'
      membershipId: '{{ response.idNamespaceAssociation.membershipId }}'
      name: '{{ response.idNamespaceAssociation.name }}'
      updateTime: '{{ response.idNamespaceAssociation.updateTime }}'
- discovery_id: aws.cleanrooms.get_membership
  calls:
  - action: get_membership
    save_as: response
    on_error: continue
  emit:
    as: item
    item:
      arn: '{{ response.membership.arn }}'
      collaborationArn: '{{ response.membership.collaborationArn }}'
      collaborationCreatorAccountId: '{{ response.membership.collaborationCreatorAccountId
        }}'
      collaborationCreatorDisplayName: '{{ response.membership.collaborationCreatorDisplayName
        }}'
      collaborationId: '{{ response.membership.collaborationId }}'
      collaborationName: '{{ response.membership.collaborationName }}'
      createTime: '{{ response.membership.createTime }}'
      defaultJobResultConfiguration: '{{ response.membership.defaultJobResultConfiguration
        }}'
      defaultResultConfiguration: '{{ response.membership.defaultResultConfiguration
        }}'
      id: '{{ response.membership.id }}'
      jobLogStatus: '{{ response.membership.jobLogStatus }}'
      memberAbilities: '{{ response.membership.memberAbilities }}'
      mlMemberAbilities: '{{ response.membership.mlMemberAbilities }}'
      paymentConfiguration: '{{ response.membership.paymentConfiguration }}'
      queryLogStatus: '{{ response.membership.queryLogStatus }}'
      status: '{{ response.membership.status }}'
      updateTime: '{{ response.membership.updateTime }}'
- discovery_id: aws.cleanrooms.get_privacy_budget_template
  calls:
  - action: get_privacy_budget_template
    save_as: response
    on_error: continue
  emit:
    as: item
    item:
      arn: '{{ response.privacyBudgetTemplate.arn }}'
      autoRefresh: '{{ response.privacyBudgetTemplate.autoRefresh }}'
      collaborationArn: '{{ response.privacyBudgetTemplate.collaborationArn }}'
      collaborationId: '{{ response.privacyBudgetTemplate.collaborationId }}'
      createTime: '{{ response.privacyBudgetTemplate.createTime }}'
      id: '{{ response.privacyBudgetTemplate.id }}'
      membershipArn: '{{ response.privacyBudgetTemplate.membershipArn }}'
      membershipId: '{{ response.privacyBudgetTemplate.membershipId }}'
      parameters: '{{ response.privacyBudgetTemplate.parameters }}'
      privacyBudgetType: '{{ response.privacyBudgetTemplate.privacyBudgetType }}'
      updateTime: '{{ response.privacyBudgetTemplate.updateTime }}'
- discovery_id: aws.cleanrooms.get_protected_job
  calls:
  - action: get_protected_job
    save_as: response
    on_error: continue
  emit:
    as: item
    item:
      computeConfiguration: '{{ response.protectedJob.computeConfiguration }}'
      createTime: '{{ response.protectedJob.createTime }}'
      error: '{{ response.protectedJob.error }}'
      id: '{{ response.protectedJob.id }}'
      jobParameters: '{{ response.protectedJob.jobParameters }}'
      membershipArn: '{{ response.protectedJob.membershipArn }}'
      membershipId: '{{ response.protectedJob.membershipId }}'
      result: '{{ response.protectedJob.result }}'
      resultConfiguration: '{{ response.protectedJob.resultConfiguration }}'
      statistics: '{{ response.protectedJob.statistics }}'
      status: '{{ response.protectedJob.status }}'
- discovery_id: aws.cleanrooms.get_protected_query
  calls:
  - action: get_protected_query
    save_as: response
    on_error: continue
  emit:
    as: item
    item:
      computeConfiguration: '{{ response.protectedQuery.computeConfiguration }}'
      createTime: '{{ response.protectedQuery.createTime }}'
      differentialPrivacy: '{{ response.protectedQuery.differentialPrivacy }}'
      error: '{{ response.protectedQuery.error }}'
      id: '{{ response.protectedQuery.id }}'
      membershipArn: '{{ response.protectedQuery.membershipArn }}'
      membershipId: '{{ response.protectedQuery.membershipId }}'
      result: '{{ response.protectedQuery.result }}'
      resultConfiguration: '{{ response.protectedQuery.resultConfiguration }}'
      sqlParameters: '{{ response.protectedQuery.sqlParameters }}'
      statistics: '{{ response.protectedQuery.statistics }}'
      status: '{{ response.protectedQuery.status }}'
- discovery_id: aws.cleanrooms.get_schema
  for_each: aws.cleanrooms.list_collaborations
  calls:
  - action: get_schema
    params:
      collaborationIdentifier: '{{ item.collaborationIdentifier }}'
      name: '{{ item.name }}'
    save_as: response
    on_error: continue
  emit:
    as: item
    item:
      analysisMethod: '{{ response.schema.analysisMethod }}'
      analysisRuleTypes: '{{ response.schema.analysisRuleTypes }}'
      collaborationArn: '{{ response.schema.collaborationArn }}'
      collaborationId: '{{ response.schema.collaborationId }}'
      columns: '{{ response.schema.columns }}'
      createTime: '{{ response.schema.createTime }}'
      creatorAccountId: '{{ response.schema.creatorAccountId }}'
      description: '{{ response.schema.description }}'
      name: '{{ response.schema.name }}'
      partitionKeys: '{{ response.schema.partitionKeys }}'
      resourceArn: '{{ response.schema.resourceArn }}'
      schemaStatusDetails: '{{ response.schema.schemaStatusDetails }}'
      schemaTypeProperties: '{{ response.schema.schemaTypeProperties }}'
      selectedAnalysisMethods: '{{ response.schema.selectedAnalysisMethods }}'
      type: '{{ response.schema.type }}'
      updateTime: '{{ response.schema.updateTime }}'
- discovery_id: aws.cleanrooms.get_schema_analysis_rule
  for_each: aws.cleanrooms.list_collaborations
  calls:
  - action: get_schema_analysis_rule
    params:
      collaborationIdentifier: '{{ item.collaborationIdentifier }}'
      name: '{{ item.name }}'
      type: '{{ item.type }}'
    save_as: response
    on_error: continue
  emit:
    as: item
    item:
      collaborationId: '{{ response.analysisRule.collaborationId }}'
      collaborationPolicy: '{{ response.analysisRule.collaborationPolicy }}'
      consolidatedPolicy: '{{ response.analysisRule.consolidatedPolicy }}'
      createTime: '{{ response.analysisRule.createTime }}'
      name: '{{ response.analysisRule.name }}'
      policy: '{{ response.analysisRule.policy }}'
      type: '{{ response.analysisRule.type }}'
      updateTime: '{{ response.analysisRule.updateTime }}'
- discovery_id: aws.cleanrooms.list_analysis_templates
  calls:
  - action: list_analysis_templates
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.analysisTemplateSummaries }}'
    item:
      arn: '{{ item.arn }}'
      collaborationArn: '{{ item.collaborationArn }}'
      collaborationId: '{{ item.collaborationId }}'
      createTime: '{{ item.createTime }}'
      description: '{{ item.description }}'
      id: '{{ item.id }}'
      membershipArn: '{{ item.membershipArn }}'
      membershipId: '{{ item.membershipId }}'
      name: '{{ item.name }}'
      updateTime: '{{ item.updateTime }}'
- discovery_id: aws.cleanrooms.list_collaboration_analysis_templates
  calls:
  - action: list_collaboration_analysis_templates
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.collaborationAnalysisTemplateSummaries }}'
    item:
      arn: '{{ item.arn }}'
      collaborationArn: '{{ item.collaborationArn }}'
      collaborationId: '{{ item.collaborationId }}'
      createTime: '{{ item.createTime }}'
      creatorAccountId: '{{ item.creatorAccountId }}'
      description: '{{ item.description }}'
      id: '{{ item.id }}'
      name: '{{ item.name }}'
      updateTime: '{{ item.updateTime }}'
- discovery_id: aws.cleanrooms.list_collaboration_change_requests
  calls:
  - action: list_collaboration_change_requests
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.collaborationChangeRequestSummaries }}'
    item:
      changes: '{{ item.changes }}'
      collaborationId: '{{ item.collaborationId }}'
      createTime: '{{ item.createTime }}'
      id: '{{ item.id }}'
      isAutoApproved: '{{ item.isAutoApproved }}'
      status: '{{ item.status }}'
      updateTime: '{{ item.updateTime }}'
- discovery_id: aws.cleanrooms.list_collaboration_configured_audience_model_associations
  calls:
  - action: list_collaboration_configured_audience_model_associations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.collaborationConfiguredAudienceModelAssociationSummaries
      }}'
    item:
      arn: '{{ item.arn }}'
      collaborationArn: '{{ item.collaborationArn }}'
      collaborationId: '{{ item.collaborationId }}'
      createTime: '{{ item.createTime }}'
      creatorAccountId: '{{ item.creatorAccountId }}'
      description: '{{ item.description }}'
      id: '{{ item.id }}'
      name: '{{ item.name }}'
      updateTime: '{{ item.updateTime }}'
- discovery_id: aws.cleanrooms.list_collaboration_id_namespace_associations
  calls:
  - action: list_collaboration_id_namespace_associations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.collaborationIdNamespaceAssociationSummaries }}'
    item:
      arn: '{{ item.arn }}'
