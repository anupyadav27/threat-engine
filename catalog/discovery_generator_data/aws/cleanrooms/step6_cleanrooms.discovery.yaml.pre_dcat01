    item:
      allowedColumns: '{{ response.configuredTable.allowedColumns }}'
      analysisMethod: '{{ response.configuredTable.analysisMethod }}'
      analysisRuleTypes: '{{ response.configuredTable.analysisRuleTypes }}'
      arn: '{{ response.configuredTable.arn }}'
      createTime: '{{ response.configuredTable.createTime }}'
      description: '{{ response.configuredTable.description }}'
      id: '{{ response.configuredTable.id }}'
      name: '{{ response.configuredTable.name }}'
