      updateTime: '{{ response.analysisRule.updateTime }}'
- discovery_id: aws.cleanrooms.get_configured_table_association
  calls:
  - action: get_configured_table_association
    save_as: response
    on_error: continue
  emit:
    as: item
    item:
      analysisRuleTypes: '{{ response.configuredTableAssociation.analysisRuleTypes
        }}'
      arn: '{{ response.configuredTableAssociation.arn }}'
      configuredTableArn: '{{ response.configuredTableAssociation.configuredTableArn
        }}'
      configuredTableId: '{{ response.configuredTableAssociation.configuredTableId
        }}'
      createTime: '{{ response.configuredTableAssociation.createTime }}'
      description: '{{ response.configuredTableAssociation.description }}'
      id: '{{ response.configuredTableAssociation.id }}'
      membershipArn: '{{ response.configuredTableAssociation.membershipArn }}'
      membershipId: '{{ response.configuredTableAssociation.membershipId }}'
      name: '{{ response.configuredTableAssociation.name }}'
      roleArn: '{{ response.configuredTableAssociation.roleArn }}'
      updateTime: '{{ response.configuredTableAssociation.updateTime }}'
- discovery_id: aws.cleanrooms.get_configured_table_association_analysis_rule
  calls:
  - action: get_configured_table_association_analysis_rule
    save_as: response
    on_error: continue
  emit:
    as: item
    item:
      configuredTableAssociationArn: '{{ response.analysisRule.configuredTableAssociationArn
        }}'
      configuredTableAssociationId: '{{ response.analysisRule.configuredTableAssociationId
        }}'
      createTime: '{{ response.analysisRule.createTime }}'
      membershipIdentifier: '{{ response.analysisRule.membershipIdentifier }}'
      policy: '{{ response.analysisRule.policy }}'
      type: '{{ response.analysisRule.type }}'
