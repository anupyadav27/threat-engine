- discovery_id: aws.cleanrooms.get_id_mapping_table
  calls:
  - action: get_id_mapping_table
    save_as: response
    on_error: continue
  emit:
    as: item
    item:
      arn: '{{ response.idMappingTable.arn }}'
      collaborationArn: '{{ response.idMappingTable.collaborationArn }}'
      collaborationId: '{{ response.idMappingTable.collaborationId }}'
