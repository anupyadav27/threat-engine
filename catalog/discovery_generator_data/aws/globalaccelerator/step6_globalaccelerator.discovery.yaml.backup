version: '1.0'
provider: aws
service: globalaccelerator
services:
  client: globalaccelerator
  module: boto3.client
discovery:
- discovery_id: aws.globalaccelerator.listAccelerators
  calls:
  - action: listAccelerators
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Accelerators }}'
    item:
      AcceleratorArn: '{{ item.AcceleratorArn }}'
      Name: '{{ item.Name }}'
      IpAddressType: '{{ item.IpAddressType }}'
      Enabled: '{{ item.Enabled }}'
      IpSets: '{{ item.IpSets }}'
      DnsName: '{{ item.DnsName }}'
      Status: '{{ item.Status }}'
      CreatedTime: '{{ item.CreatedTime }}'
      LastModifiedTime: '{{ item.LastModifiedTime }}'
      DualStackDnsName: '{{ item.DualStackDnsName }}'
      Events: '{{ item.Events }}'
- discovery_id: aws.globalaccelerator.listByoipCidrs
  calls:
  - action: listByoipCidrs
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.ByoipCidrs }}'
    item:
      Cidr: '{{ item.Cidr }}'
      State: '{{ item.State }}'
      Events: '{{ item.Events }}'
- discovery_id: aws.globalaccelerator.listCrossAccountAttachments
  calls:
  - action: listCrossAccountAttachments
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.CrossAccountAttachments }}'
    item:
      AttachmentArn: '{{ item.AttachmentArn }}'
      Name: '{{ item.Name }}'
      Principals: '{{ item.Principals }}'
      Resources: '{{ item.Resources }}'
      LastModifiedTime: '{{ item.LastModifiedTime }}'
      CreatedTime: '{{ item.CreatedTime }}'
- discovery_id: aws.globalaccelerator.listCrossAccountResourceAccounts
  calls:
  - action: listCrossAccountResourceAccounts
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ResourceOwnerAwsAccountIds }}'
- discovery_id: aws.globalaccelerator.listCustomRoutingAccelerators
  calls:
  - action: listCustomRoutingAccelerators
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Accelerators }}'
    item:
      AcceleratorArn: '{{ item.AcceleratorArn }}'
      Name: '{{ item.Name }}'
      IpAddressType: '{{ item.IpAddressType }}'
      Enabled: '{{ item.Enabled }}'
      IpSets: '{{ item.IpSets }}'
      DnsName: '{{ item.DnsName }}'
      Status: '{{ item.Status }}'
      CreatedTime: '{{ item.CreatedTime }}'
      LastModifiedTime: '{{ item.LastModifiedTime }}'
- discovery_id: aws.globalaccelerator.describeAccelerator
  calls:
  - action: describeAccelerator
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Accelerator }}'
    item:
      AcceleratorArn: '{{ item.AcceleratorArn }}'
      Name: '{{ item.Name }}'
      IpAddressType: '{{ item.IpAddressType }}'
      Enabled: '{{ item.Enabled }}'
      IpSets: '{{ item.IpSets }}'
      DnsName: '{{ item.DnsName }}'
      Status: '{{ item.Status }}'
      CreatedTime: '{{ item.CreatedTime }}'
      LastModifiedTime: '{{ item.LastModifiedTime }}'
      DualStackDnsName: '{{ item.DualStackDnsName }}'
      Events: '{{ item.Events }}'
- discovery_id: aws.globalaccelerator.describeAcceleratorAttributes
  calls:
  - action: describeAcceleratorAttributes
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AcceleratorAttributes }}'
    item:
      FlowLogsEnabled: '{{ item.FlowLogsEnabled }}'
      FlowLogsS3Bucket: '{{ item.FlowLogsS3Bucket }}'
      FlowLogsS3Prefix: '{{ item.FlowLogsS3Prefix }}'
- discovery_id: aws.globalaccelerator.describeCrossAccountAttachment
  calls:
  - action: describeCrossAccountAttachment
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.CrossAccountAttachment }}'
    item:
      AttachmentArn: '{{ item.AttachmentArn }}'
      Name: '{{ item.Name }}'
      Principals: '{{ item.Principals }}'
      Resources: '{{ item.Resources }}'
      LastModifiedTime: '{{ item.LastModifiedTime }}'
      CreatedTime: '{{ item.CreatedTime }}'
- discovery_id: aws.globalaccelerator.describeCustomRoutingAccelerator
  calls:
  - action: describeCustomRoutingAccelerator
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Accelerator }}'
    item:
      AcceleratorArn: '{{ item.AcceleratorArn }}'
      Name: '{{ item.Name }}'
      IpAddressType: '{{ item.IpAddressType }}'
      Enabled: '{{ item.Enabled }}'
      IpSets: '{{ item.IpSets }}'
      DnsName: '{{ item.DnsName }}'
      Status: '{{ item.Status }}'
      CreatedTime: '{{ item.CreatedTime }}'
      LastModifiedTime: '{{ item.LastModifiedTime }}'
- discovery_id: aws.globalaccelerator.describeCustomRoutingAcceleratorAttributes
  calls:
  - action: describeCustomRoutingAcceleratorAttributes
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AcceleratorAttributes }}'
    item:
      FlowLogsEnabled: '{{ item.FlowLogsEnabled }}'
      FlowLogsS3Bucket: '{{ item.FlowLogsS3Bucket }}'
      FlowLogsS3Prefix: '{{ item.FlowLogsS3Prefix }}'
- discovery_id: aws.globalaccelerator.describeCustomRoutingEndpointGroup
  calls:
  - action: describeCustomRoutingEndpointGroup
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.EndpointGroup }}'
    item:
      EndpointGroupArn: '{{ item.EndpointGroupArn }}'
      EndpointGroupRegion: '{{ item.EndpointGroupRegion }}'
      DestinationDescriptions: '{{ item.DestinationDescriptions }}'
      EndpointDescriptions: '{{ item.EndpointDescriptions }}'
- discovery_id: aws.globalaccelerator.describeCustomRoutingListener
  calls:
  - action: describeCustomRoutingListener
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Listener }}'
    item:
      ListenerArn: '{{ item.ListenerArn }}'
      PortRanges: '{{ item.PortRanges }}'
- discovery_id: aws.globalaccelerator.describeEndpointGroup
  calls:
  - action: describeEndpointGroup
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.EndpointGroup }}'
    item:
      EndpointGroupArn: '{{ item.EndpointGroupArn }}'
      EndpointGroupRegion: '{{ item.EndpointGroupRegion }}'
      EndpointDescriptions: '{{ item.EndpointDescriptions }}'
      TrafficDialPercentage: '{{ item.TrafficDialPercentage }}'
      HealthCheckPort: '{{ item.HealthCheckPort }}'
      HealthCheckProtocol: '{{ item.HealthCheckProtocol }}'
      HealthCheckPath: '{{ item.HealthCheckPath }}'
      HealthCheckIntervalSeconds: '{{ item.HealthCheckIntervalSeconds }}'
      ThresholdCount: '{{ item.ThresholdCount }}'
      PortOverrides: '{{ item.PortOverrides }}'
- discovery_id: aws.globalaccelerator.describeListener
  calls:
  - action: describeListener
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Listener }}'
    item:
      ListenerArn: '{{ item.ListenerArn }}'
      PortRanges: '{{ item.PortRanges }}'
      Protocol: '{{ item.Protocol }}'
      ClientAffinity: '{{ item.ClientAffinity }}'
- discovery_id: aws.globalaccelerator.listCrossAccountResources
  calls:
  - action: listCrossAccountResources
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.CrossAccountResources }}'
    item:
      EndpointId: '{{ item.EndpointId }}'
      Cidr: '{{ item.Cidr }}'
      AttachmentArn: '{{ item.AttachmentArn }}'
- discovery_id: aws.globalaccelerator.listCustomRoutingEndpointGroups
  calls:
  - action: listCustomRoutingEndpointGroups
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.EndpointGroups }}'
    item:
      EndpointGroupArn: '{{ item.EndpointGroupArn }}'
      EndpointGroupRegion: '{{ item.EndpointGroupRegion }}'
      DestinationDescriptions: '{{ item.DestinationDescriptions }}'
      EndpointDescriptions: '{{ item.EndpointDescriptions }}'
- discovery_id: aws.globalaccelerator.listCustomRoutingListeners
  calls:
  - action: listCustomRoutingListeners
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Listeners }}'
    item:
      ListenerArn: '{{ item.ListenerArn }}'
      PortRanges: '{{ item.PortRanges }}'
- discovery_id: aws.globalaccelerator.listCustomRoutingPortMappings
  calls:
  - action: listCustomRoutingPortMappings
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.PortMappings }}'
    item:
      AcceleratorPort: '{{ item.AcceleratorPort }}'
      EndpointGroupArn: '{{ item.EndpointGroupArn }}'
      EndpointId: '{{ item.EndpointId }}'
      DestinationSocketAddress: '{{ item.DestinationSocketAddress }}'
      Protocols: '{{ item.Protocols }}'
      DestinationTrafficState: '{{ item.DestinationTrafficState }}'
- discovery_id: aws.globalaccelerator.listCustomRoutingPortMappingsByDestination
  calls:
  - action: listCustomRoutingPortMappingsByDestination
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.DestinationPortMappings }}'
    item:
      AcceleratorArn: '{{ item.AcceleratorArn }}'
      AcceleratorSocketAddresses: '{{ item.AcceleratorSocketAddresses }}'
      EndpointGroupArn: '{{ item.EndpointGroupArn }}'
      EndpointId: '{{ item.EndpointId }}'
      EndpointGroupRegion: '{{ item.EndpointGroupRegion }}'
      DestinationSocketAddress: '{{ item.DestinationSocketAddress }}'
      IpAddressType: '{{ item.IpAddressType }}'
      DestinationTrafficState: '{{ item.DestinationTrafficState }}'
- discovery_id: aws.globalaccelerator.listEndpointGroups
  calls:
  - action: listEndpointGroups
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.EndpointGroups }}'
    item:
      EndpointGroupArn: '{{ item.EndpointGroupArn }}'
      EndpointGroupRegion: '{{ item.EndpointGroupRegion }}'
      EndpointDescriptions: '{{ item.EndpointDescriptions }}'
      TrafficDialPercentage: '{{ item.TrafficDialPercentage }}'
      HealthCheckPort: '{{ item.HealthCheckPort }}'
      HealthCheckProtocol: '{{ item.HealthCheckProtocol }}'
      HealthCheckPath: '{{ item.HealthCheckPath }}'
      HealthCheckIntervalSeconds: '{{ item.HealthCheckIntervalSeconds }}'
      ThresholdCount: '{{ item.ThresholdCount }}'
      PortOverrides: '{{ item.PortOverrides }}'
- discovery_id: aws.globalaccelerator.listListeners
  calls:
  - action: listListeners
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Listeners }}'
    item:
      ListenerArn: '{{ item.ListenerArn }}'
      PortRanges: '{{ item.PortRanges }}'
      Protocol: '{{ item.Protocol }}'
      ClientAffinity: '{{ item.ClientAffinity }}'
- discovery_id: aws.globalaccelerator.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Tags }}'
    item:
      Key: '{{ item.Key }}'
      Value: '{{ item.Value }}'
checks: []
