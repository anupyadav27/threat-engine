      capabilityConfiguration: '{{ item.capabilityConfiguration }}'
      aiAgentConfiguration: '{{ item.aiAgentConfiguration }}'
- discovery_id: aws.qconnect.getAssistantAssociation
  calls:
  - action: getAssistantAssociation
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.assistantAssociation }}'
    item:
      assistantAssociationId: '{{ item.assistantAssociationId }}'
      assistantAssociationArn: '{{ item.assistantAssociationArn }}'
      assistantId: '{{ item.assistantId }}'
      assistantArn: '{{ item.assistantArn }}'
      associationType: '{{ item.associationType }}'
      associationData: '{{ item.associationData }}'
      tags: '{{ item.tags }}'
- discovery_id: aws.qconnect.getContent
  calls:
  - action: getContent
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.content }}'
    item:
      contentArn: '{{ item.contentArn }}'
      contentId: '{{ item.contentId }}'
      knowledgeBaseArn: '{{ item.knowledgeBaseArn }}'
      knowledgeBaseId: '{{ item.knowledgeBaseId }}'
      name: '{{ item.name }}'
      revisionId: '{{ item.revisionId }}'
      title: '{{ item.title }}'
      contentType: '{{ item.contentType }}'
      status: '{{ item.status }}'
      metadata: '{{ item.metadata }}'
      tags: '{{ item.tags }}'
      linkOutUri: '{{ item.linkOutUri }}'
      url: '{{ item.url }}'
      urlExpiry: '{{ item.urlExpiry }}'
- discovery_id: aws.qconnect.getContentAssociation
  calls:
  - action: getContentAssociation
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.contentAssociation }}'
    item:
      knowledgeBaseId: '{{ item.knowledgeBaseId }}'
      knowledgeBaseArn: '{{ item.knowledgeBaseArn }}'
      contentId: '{{ item.contentId }}'
      contentArn: '{{ item.contentArn }}'
      contentAssociationId: '{{ item.contentAssociationId }}'
      contentAssociationArn: '{{ item.contentAssociationArn }}'
      associationType: '{{ item.associationType }}'
      associationData: '{{ item.associationData }}'
      tags: '{{ item.tags }}'
- discovery_id: aws.qconnect.getContentSummary
  calls:
