version: '1.0'
provider: aws
service: qconnect
services:
  client: qconnect
  module: boto3.client
discovery:
- discovery_id: aws.qconnect.listAssistants
  calls:
  - action: listAssistants
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.assistantSummaries }}'
    item:
      assistantId: '{{ item.assistantId }}'
      assistantArn: '{{ item.assistantArn }}'
      name: '{{ item.name }}'
      type: '{{ item.type }}'
      status: '{{ item.status }}'
      description: '{{ item.description }}'
      tags: '{{ item.tags }}'
      serverSideEncryptionConfiguration: '{{ item.serverSideEncryptionConfiguration
        }}'
      integrationConfiguration: '{{ item.integrationConfiguration }}'
      capabilityConfiguration: '{{ item.capabilityConfiguration }}'
      aiAgentConfiguration: '{{ item.aiAgentConfiguration }}'
- discovery_id: aws.qconnect.listKnowledgeBases
  calls:
  - action: listKnowledgeBases
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.knowledgeBaseSummaries }}'
    item:
      knowledgeBaseId: '{{ item.knowledgeBaseId }}'
      knowledgeBaseArn: '{{ item.knowledgeBaseArn }}'
      name: '{{ item.name }}'
      knowledgeBaseType: '{{ item.knowledgeBaseType }}'
      status: '{{ item.status }}'
      sourceConfiguration: '{{ item.sourceConfiguration }}'
      vectorIngestionConfiguration: '{{ item.vectorIngestionConfiguration }}'
      renderingConfiguration: '{{ item.renderingConfiguration }}'
      serverSideEncryptionConfiguration: '{{ item.serverSideEncryptionConfiguration
        }}'
      description: '{{ item.description }}'
      tags: '{{ item.tags }}'
- discovery_id: aws.qconnect.getAiAgent
  calls:
  - action: getAiAgent
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.aiAgent }}'
    item:
      assistantId: '{{ item.assistantId }}'
      assistantArn: '{{ item.assistantArn }}'
      aiAgentId: '{{ item.aiAgentId }}'
      aiAgentArn: '{{ item.aiAgentArn }}'
      name: '{{ item.name }}'
      type: '{{ item.type }}'
      configuration: '{{ item.configuration }}'
      modifiedTime: '{{ item.modifiedTime }}'
      description: '{{ item.description }}'
      visibilityStatus: '{{ item.visibilityStatus }}'
      tags: '{{ item.tags }}'
      origin: '{{ item.origin }}'
      status: '{{ item.status }}'
- discovery_id: aws.qconnect.getAiGuardrail
  calls:
  - action: getAiGuardrail
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.aiGuardrail }}'
    item:
      assistantId: '{{ item.assistantId }}'
      assistantArn: '{{ item.assistantArn }}'
      aiGuardrailArn: '{{ item.aiGuardrailArn }}'
      aiGuardrailId: '{{ item.aiGuardrailId }}'
      name: '{{ item.name }}'
      visibilityStatus: '{{ item.visibilityStatus }}'
      blockedInputMessaging: '{{ item.blockedInputMessaging }}'
      blockedOutputsMessaging: '{{ item.blockedOutputsMessaging }}'
      description: '{{ item.description }}'
      topicPolicyConfig: '{{ item.topicPolicyConfig }}'
      contentPolicyConfig: '{{ item.contentPolicyConfig }}'
      wordPolicyConfig: '{{ item.wordPolicyConfig }}'
      sensitiveInformationPolicyConfig: '{{ item.sensitiveInformationPolicyConfig
        }}'
      contextualGroundingPolicyConfig: '{{ item.contextualGroundingPolicyConfig }}'
      tags: '{{ item.tags }}'
      status: '{{ item.status }}'
      modifiedTime: '{{ item.modifiedTime }}'
- discovery_id: aws.qconnect.getAiPrompt
  calls:
  - action: getAiPrompt
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.aiPrompt }}'
    item:
      assistantId: '{{ item.assistantId }}'
      assistantArn: '{{ item.assistantArn }}'
      aiPromptId: '{{ item.aiPromptId }}'
      aiPromptArn: '{{ item.aiPromptArn }}'
      name: '{{ item.name }}'
      type: '{{ item.type }}'
      templateType: '{{ item.templateType }}'
      modelId: '{{ item.modelId }}'
      apiFormat: '{{ item.apiFormat }}'
      templateConfiguration: '{{ item.templateConfiguration }}'
      modifiedTime: '{{ item.modifiedTime }}'
      description: '{{ item.description }}'
      visibilityStatus: '{{ item.visibilityStatus }}'
      tags: '{{ item.tags }}'
      origin: '{{ item.origin }}'
      status: '{{ item.status }}'
- discovery_id: aws.qconnect.getAssistant
  calls:
  - action: getAssistant
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.assistant }}'
    item:
      assistantId: '{{ item.assistantId }}'
      assistantArn: '{{ item.assistantArn }}'
      name: '{{ item.name }}'
      type: '{{ item.type }}'
      status: '{{ item.status }}'
      description: '{{ item.description }}'
      tags: '{{ item.tags }}'
      serverSideEncryptionConfiguration: '{{ item.serverSideEncryptionConfiguration
        }}'
