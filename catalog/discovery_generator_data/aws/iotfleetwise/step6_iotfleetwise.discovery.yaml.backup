version: '1.0'
provider: aws
service: iotfleetwise
services:
  client: iotfleetwise
  module: boto3.client
discovery:
- discovery_id: aws.iotfleetwise.getEncryptionConfiguration
  calls:
  - action: getEncryptionConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.kmsKeyId }}'
- discovery_id: aws.iotfleetwise.getLoggingOptions
  calls:
  - action: getLoggingOptions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.cloudWatchLogDelivery }}'
    item:
      logType: '{{ item.logType }}'
      logGroupName: '{{ item.logGroupName }}'
- discovery_id: aws.iotfleetwise.getRegisterAccountStatus
  calls:
  - action: getRegisterAccountStatus
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.timestreamRegistrationResponse }}'
    item:
      timestreamDatabaseName: '{{ item.timestreamDatabaseName }}'
      timestreamTableName: '{{ item.timestreamTableName }}'
      timestreamDatabaseArn: '{{ item.timestreamDatabaseArn }}'
      timestreamTableArn: '{{ item.timestreamTableArn }}'
      registrationStatus: '{{ item.registrationStatus }}'
      errorMessage: '{{ item.errorMessage }}'
- discovery_id: aws.iotfleetwise.listCampaigns
  calls:
  - action: listCampaigns
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.campaignSummaries }}'
    item:
      arn: '{{ item.arn }}'
      name: '{{ item.name }}'
      description: '{{ item.description }}'
      signalCatalogArn: '{{ item.signalCatalogArn }}'
      targetArn: '{{ item.targetArn }}'
      status: '{{ item.status }}'
      creationTime: '{{ item.creationTime }}'
      lastModificationTime: '{{ item.lastModificationTime }}'
- discovery_id: aws.iotfleetwise.listDecoderManifests
  calls:
  - action: listDecoderManifests
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.summaries }}'
    item:
      name: '{{ item.name }}'
      arn: '{{ item.arn }}'
      modelManifestArn: '{{ item.modelManifestArn }}'
      description: '{{ item.description }}'
      status: '{{ item.status }}'
      creationTime: '{{ item.creationTime }}'
      lastModificationTime: '{{ item.lastModificationTime }}'
      message: '{{ item.message }}'
- discovery_id: aws.iotfleetwise.listFleets
  calls:
  - action: listFleets
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.fleetSummaries }}'
    item:
      id: '{{ item.id }}'
      arn: '{{ item.arn }}'
      description: '{{ item.description }}'
      signalCatalogArn: '{{ item.signalCatalogArn }}'
      creationTime: '{{ item.creationTime }}'
      lastModificationTime: '{{ item.lastModificationTime }}'
- discovery_id: aws.iotfleetwise.listModelManifests
  calls:
  - action: listModelManifests
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.summaries }}'
    item:
      name: '{{ item.name }}'
      arn: '{{ item.arn }}'
      signalCatalogArn: '{{ item.signalCatalogArn }}'
      description: '{{ item.description }}'
      status: '{{ item.status }}'
      creationTime: '{{ item.creationTime }}'
      lastModificationTime: '{{ item.lastModificationTime }}'
- discovery_id: aws.iotfleetwise.listSignalCatalogs
  calls:
  - action: listSignalCatalogs
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.summaries }}'
    item:
      name: '{{ item.name }}'
      arn: '{{ item.arn }}'
      creationTime: '{{ item.creationTime }}'
      lastModificationTime: '{{ item.lastModificationTime }}'
- discovery_id: aws.iotfleetwise.listStateTemplates
  calls:
  - action: listStateTemplates
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.summaries }}'
    item:
      name: '{{ item.name }}'
      arn: '{{ item.arn }}'
      signalCatalogArn: '{{ item.signalCatalogArn }}'
      description: '{{ item.description }}'
      creationTime: '{{ item.creationTime }}'
      lastModificationTime: '{{ item.lastModificationTime }}'
      id: '{{ item.id }}'
- discovery_id: aws.iotfleetwise.listVehicles
  calls:
  - action: listVehicles
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.vehicleSummaries }}'
    item:
      vehicleName: '{{ item.vehicleName }}'
      arn: '{{ item.arn }}'
      modelManifestArn: '{{ item.modelManifestArn }}'
      decoderManifestArn: '{{ item.decoderManifestArn }}'
      creationTime: '{{ item.creationTime }}'
      lastModificationTime: '{{ item.lastModificationTime }}'
      attributes: '{{ item.attributes }}'
- discovery_id: aws.iotfleetwise.getCampaign
  calls:
  - action: getCampaign
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.signalsToCollect }}'
    item:
      name: '{{ item.name }}'
      maxSampleCount: '{{ item.maxSampleCount }}'
      minimumSamplingIntervalMs: '{{ item.minimumSamplingIntervalMs }}'
      dataPartitionId: '{{ item.dataPartitionId }}'
- discovery_id: aws.iotfleetwise.getDecoderManifest
  calls:
  - action: getDecoderManifest
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.name }}'
- discovery_id: aws.iotfleetwise.getFleet
  calls:
  - action: getFleet
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.id }}'
- discovery_id: aws.iotfleetwise.getModelManifest
  calls:
  - action: getModelManifest
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.name }}'
- discovery_id: aws.iotfleetwise.getSignalCatalog
  calls:
  - action: getSignalCatalog
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.nodeCounts }}'
    item:
      totalNodes: '{{ item.totalNodes }}'
      totalBranches: '{{ item.totalBranches }}'
      totalSensors: '{{ item.totalSensors }}'
      totalAttributes: '{{ item.totalAttributes }}'
      totalActuators: '{{ item.totalActuators }}'
      totalStructs: '{{ item.totalStructs }}'
      totalProperties: '{{ item.totalProperties }}'
- discovery_id: aws.iotfleetwise.getStateTemplate
  calls:
  - action: getStateTemplate
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.stateTemplateProperties }}'
- discovery_id: aws.iotfleetwise.getVehicle
  calls:
  - action: getVehicle
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.stateTemplates }}'
    item:
      identifier: '{{ item.identifier }}'
      stateTemplateUpdateStrategy: '{{ item.stateTemplateUpdateStrategy }}'
- discovery_id: aws.iotfleetwise.getVehicleStatus
  calls:
  - action: getVehicleStatus
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.campaigns }}'
    item:
      campaignName: '{{ item.campaignName }}'
      vehicleName: '{{ item.vehicleName }}'
      status: '{{ item.status }}'
- discovery_id: aws.iotfleetwise.listDecoderManifestNetworkInterfaces
  calls:
  - action: listDecoderManifestNetworkInterfaces
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.networkInterfaces }}'
    item:
      interfaceId: '{{ item.interfaceId }}'
      type: '{{ item.type }}'
      canInterface: '{{ item.canInterface }}'
      obdInterface: '{{ item.obdInterface }}'
      vehicleMiddleware: '{{ item.vehicleMiddleware }}'
      customDecodingInterface: '{{ item.customDecodingInterface }}'
- discovery_id: aws.iotfleetwise.listDecoderManifestSignals
  calls:
  - action: listDecoderManifestSignals
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.signalDecoders }}'
    item:
      fullyQualifiedName: '{{ item.fullyQualifiedName }}'
      type: '{{ item.type }}'
      interfaceId: '{{ item.interfaceId }}'
      canSignal: '{{ item.canSignal }}'
      obdSignal: '{{ item.obdSignal }}'
      messageSignal: '{{ item.messageSignal }}'
      customDecodingSignal: '{{ item.customDecodingSignal }}'
- discovery_id: aws.iotfleetwise.listFleetsForVehicle
  calls:
  - action: listFleetsForVehicle
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.fleets }}'
- discovery_id: aws.iotfleetwise.listModelManifestNodes
  calls:
  - action: listModelManifestNodes
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.nodes }}'
    item:
      branch: '{{ item.branch }}'
      sensor: '{{ item.sensor }}'
      actuator: '{{ item.actuator }}'
      attribute: '{{ item.attribute }}'
      struct: '{{ item.struct }}'
      property: '{{ item.property }}'
- discovery_id: aws.iotfleetwise.listSignalCatalogNodes
  calls:
  - action: listSignalCatalogNodes
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.nodes }}'
    item:
      branch: '{{ item.branch }}'
      sensor: '{{ item.sensor }}'
      actuator: '{{ item.actuator }}'
      attribute: '{{ item.attribute }}'
      struct: '{{ item.struct }}'
      property: '{{ item.property }}'
- discovery_id: aws.iotfleetwise.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Tags }}'
    item:
      Key: '{{ item.Key }}'
      Value: '{{ item.Value }}'
- discovery_id: aws.iotfleetwise.listVehiclesInFleet
  calls:
  - action: listVehiclesInFleet
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.vehicles }}'
checks: []
