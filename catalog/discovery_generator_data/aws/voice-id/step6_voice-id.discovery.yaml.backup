version: '1.0'
provider: aws
service: voice-id
services:
  client: voice-id
  module: boto3.client
discovery:
- discovery_id: aws.voice-id.listDomains
  calls:
  - action: listDomains
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.DomainSummaries }}'
    item:
      Arn: '{{ item.Arn }}'
      CreatedAt: '{{ item.CreatedAt }}'
      Description: '{{ item.Description }}'
      DomainId: '{{ item.DomainId }}'
      DomainStatus: '{{ item.DomainStatus }}'
      Name: '{{ item.Name }}'
      ServerSideEncryptionConfiguration: '{{ item.ServerSideEncryptionConfiguration
        }}'
      ServerSideEncryptionUpdateDetails: '{{ item.ServerSideEncryptionUpdateDetails
        }}'
      UpdatedAt: '{{ item.UpdatedAt }}'
      WatchlistDetails: '{{ item.WatchlistDetails }}'
- discovery_id: aws.voice-id.describeDomain
  calls:
  - action: describeDomain
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Domain }}'
    item:
      Arn: '{{ item.Arn }}'
      CreatedAt: '{{ item.CreatedAt }}'
      Description: '{{ item.Description }}'
      DomainId: '{{ item.DomainId }}'
      DomainStatus: '{{ item.DomainStatus }}'
      Name: '{{ item.Name }}'
      ServerSideEncryptionConfiguration: '{{ item.ServerSideEncryptionConfiguration
        }}'
      ServerSideEncryptionUpdateDetails: '{{ item.ServerSideEncryptionUpdateDetails
        }}'
      UpdatedAt: '{{ item.UpdatedAt }}'
      WatchlistDetails: '{{ item.WatchlistDetails }}'
- discovery_id: aws.voice-id.describeFraudster
  calls:
  - action: describeFraudster
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Fraudster }}'
    item:
      CreatedAt: '{{ item.CreatedAt }}'
      DomainId: '{{ item.DomainId }}'
      GeneratedFraudsterId: '{{ item.GeneratedFraudsterId }}'
      WatchlistIds: '{{ item.WatchlistIds }}'
- discovery_id: aws.voice-id.describeFraudsterRegistrationJob
  calls:
  - action: describeFraudsterRegistrationJob
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Job }}'
    item:
      CreatedAt: '{{ item.CreatedAt }}'
      DataAccessRoleArn: '{{ item.DataAccessRoleArn }}'
      DomainId: '{{ item.DomainId }}'
      EndedAt: '{{ item.EndedAt }}'
      FailureDetails: '{{ item.FailureDetails }}'
      InputDataConfig: '{{ item.InputDataConfig }}'
      JobId: '{{ item.JobId }}'
      JobName: '{{ item.JobName }}'
      JobProgress: '{{ item.JobProgress }}'
      JobStatus: '{{ item.JobStatus }}'
      OutputDataConfig: '{{ item.OutputDataConfig }}'
      RegistrationConfig: '{{ item.RegistrationConfig }}'
- discovery_id: aws.voice-id.describeSpeaker
  calls:
  - action: describeSpeaker
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Speaker }}'
    item:
      CreatedAt: '{{ item.CreatedAt }}'
      CustomerSpeakerId: '{{ item.CustomerSpeakerId }}'
      DomainId: '{{ item.DomainId }}'
      GeneratedSpeakerId: '{{ item.GeneratedSpeakerId }}'
      LastAccessedAt: '{{ item.LastAccessedAt }}'
      Status: '{{ item.Status }}'
      UpdatedAt: '{{ item.UpdatedAt }}'
- discovery_id: aws.voice-id.describeSpeakerEnrollmentJob
  calls:
  - action: describeSpeakerEnrollmentJob
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Job }}'
    item:
      CreatedAt: '{{ item.CreatedAt }}'
      DataAccessRoleArn: '{{ item.DataAccessRoleArn }}'
      DomainId: '{{ item.DomainId }}'
      EndedAt: '{{ item.EndedAt }}'
      EnrollmentConfig: '{{ item.EnrollmentConfig }}'
      FailureDetails: '{{ item.FailureDetails }}'
      InputDataConfig: '{{ item.InputDataConfig }}'
      JobId: '{{ item.JobId }}'
      JobName: '{{ item.JobName }}'
      JobProgress: '{{ item.JobProgress }}'
      JobStatus: '{{ item.JobStatus }}'
      OutputDataConfig: '{{ item.OutputDataConfig }}'
- discovery_id: aws.voice-id.describeWatchlist
  calls:
  - action: describeWatchlist
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Watchlist }}'
    item:
      CreatedAt: '{{ item.CreatedAt }}'
      DefaultWatchlist: '{{ item.DefaultWatchlist }}'
      Description: '{{ item.Description }}'
      DomainId: '{{ item.DomainId }}'
      Name: '{{ item.Name }}'
      UpdatedAt: '{{ item.UpdatedAt }}'
      WatchlistId: '{{ item.WatchlistId }}'
- discovery_id: aws.voice-id.listFraudsterRegistrationJobs
  calls:
  - action: listFraudsterRegistrationJobs
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.JobSummaries }}'
    item:
      CreatedAt: '{{ item.CreatedAt }}'
      DomainId: '{{ item.DomainId }}'
      EndedAt: '{{ item.EndedAt }}'
      FailureDetails: '{{ item.FailureDetails }}'
      JobId: '{{ item.JobId }}'
      JobName: '{{ item.JobName }}'
      JobProgress: '{{ item.JobProgress }}'
      JobStatus: '{{ item.JobStatus }}'
- discovery_id: aws.voice-id.listFraudsters
  calls:
  - action: listFraudsters
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.FraudsterSummaries }}'
    item:
      CreatedAt: '{{ item.CreatedAt }}'
      DomainId: '{{ item.DomainId }}'
      GeneratedFraudsterId: '{{ item.GeneratedFraudsterId }}'
      WatchlistIds: '{{ item.WatchlistIds }}'
- discovery_id: aws.voice-id.listSpeakerEnrollmentJobs
  calls:
  - action: listSpeakerEnrollmentJobs
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.JobSummaries }}'
    item:
      CreatedAt: '{{ item.CreatedAt }}'
      DomainId: '{{ item.DomainId }}'
      EndedAt: '{{ item.EndedAt }}'
      FailureDetails: '{{ item.FailureDetails }}'
      JobId: '{{ item.JobId }}'
      JobName: '{{ item.JobName }}'
      JobProgress: '{{ item.JobProgress }}'
      JobStatus: '{{ item.JobStatus }}'
- discovery_id: aws.voice-id.listSpeakers
  calls:
  - action: listSpeakers
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.SpeakerSummaries }}'
    item:
      CreatedAt: '{{ item.CreatedAt }}'
      CustomerSpeakerId: '{{ item.CustomerSpeakerId }}'
      DomainId: '{{ item.DomainId }}'
      GeneratedSpeakerId: '{{ item.GeneratedSpeakerId }}'
      LastAccessedAt: '{{ item.LastAccessedAt }}'
      Status: '{{ item.Status }}'
      UpdatedAt: '{{ item.UpdatedAt }}'
- discovery_id: aws.voice-id.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Tags }}'
    item:
      Key: '{{ item.Key }}'
      Value: '{{ item.Value }}'
- discovery_id: aws.voice-id.listWatchlists
  calls:
  - action: listWatchlists
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.WatchlistSummaries }}'
    item:
      CreatedAt: '{{ item.CreatedAt }}'
      DefaultWatchlist: '{{ item.DefaultWatchlist }}'
      Description: '{{ item.Description }}'
      DomainId: '{{ item.DomainId }}'
      Name: '{{ item.Name }}'
      UpdatedAt: '{{ item.UpdatedAt }}'
      WatchlistId: '{{ item.WatchlistId }}'
checks: []
