version: '1.0'
provider: aws
service: pinpoint-sms-voice
services:
  client: pinpoint-sms-voice
  module: boto3.client
discovery:
- discovery_id: aws.pinpoint-sms-voice.listConfigurationSets
  calls:
  - action: listConfigurationSets
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ConfigurationSets }}'
- discovery_id: aws.pinpoint-sms-voice.getConfigurationSetEventDestinations
  calls:
  - action: getConfigurationSetEventDestinations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.EventDestinations }}'
    item:
      CloudWatchLogsDestination: '{{ item.CloudWatchLogsDestination }}'
      Enabled: '{{ item.Enabled }}'
      KinesisFirehoseDestination: '{{ item.KinesisFirehoseDestination }}'
      MatchingEventTypes: '{{ item.MatchingEventTypes }}'
      Name: '{{ item.Name }}'
      SnsDestination: '{{ item.SnsDestination }}'
checks: []
