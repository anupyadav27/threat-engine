    items_for: '{{ response.fleetMetrics }}'
    item:
      aggregationField: '{{ item.aggregationField }}'
      aggregationType: '{{ item.aggregationType }}'
      metricArn: '{{ item.metricArn }}'
      metricName: '{{ item.metricName }}'
      metricType: '{{ item.metricType }}'
      period: '{{ item.period }}'
      unit: '{{ item.unit }}'
      values: '{{ item.values }}'
- discovery_id: aws.iot.list_indices
  calls:
  - action: list_indices
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.indexNames }}'
    item:
      schema: '{{ item.schema }}'
- discovery_id: aws.iot.list_job_templates
  calls:
  - action: list_job_templates
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.jobTemplates }}'
    item:
      createdAt: '{{ item.createdAt }}'
      description: '{{ item.description }}'
      document: '{{ item.document }}'
      documentSource: '{{ item.documentSource }}'
      job: '{{ item.job }}'
      jobTemplateArn: '{{ item.jobTemplateArn }}'
      jobTemplateId: '{{ item.jobTemplateId }}'
      maintenanceWindows: '{{ item.maintenanceWindows }}'
- discovery_id: aws.iot.list_jobs
  calls:
  - action: list_jobs
    save_as: response
    on_error: continue
  emit:
