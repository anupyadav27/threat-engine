version: '1.0'
provider: aws
service: iot
services:
  client: iot
  module: boto3.client
discovery:
- discovery_id: aws.iot.describe_account_audit_configuration
  calls:
  - action: describe_account_audit_configuration
    save_as: response
    on_error: continue
  emit:
    as: item
    item:
      Status: '{{ response.Status }}'
      Enabled: '{{ response.Enabled }}'
      auditCheckConfigurations: '{{ response.auditCheckConfigurations }}'
      auditNotificationTargetConfigurations: '{{ response.auditNotificationTargetConfigurations
        }}'
      kmsAccessRoleArn: '{{ response.kmsAccessRoleArn }}'
      provisioningRoleArn: '{{ response.provisioningRoleArn }}'
- discovery_id: aws.iot.describe_default_authorizer
  calls:
  - action: describe_default_authorizer
    save_as: response
    on_error: continue
  emit:
    as: item
    item:
      authorizerArn: '{{ response.authorizerDescription.authorizerArn }}'
      authorizerDescription: '{{ response.authorizerDescription.authorizerDescription
        }}'
      authorizerFunctionArn: '{{ response.authorizerDescription.authorizerFunctionArn
        }}'
      authorizerName: '{{ response.authorizerDescription.authorizerName }}'
      creationDate: '{{ response.authorizerDescription.creationDate }}'
      enableCachingForHttp: '{{ response.authorizerDescription.enableCachingForHttp
        }}'
      lastModifiedDate: '{{ response.authorizerDescription.lastModifiedDate }}'
      signingDisabled: '{{ response.authorizerDescription.signingDisabled }}'
      status: '{{ response.authorizerDescription.status }}'
      tokenKeyName: '{{ response.authorizerDescription.tokenKeyName }}'
      tokenSigningPublicKeys: '{{ response.authorizerDescription.tokenSigningPublicKeys
        }}'
- discovery_id: aws.iot.describe_encryption_configuration
  calls:
  - action: describe_encryption_configuration
    save_as: response
    on_error: continue
  emit:
    as: item
    item:
      configurationDetails: '{{ response.configurationDetails }}'
      configurationStatus: '{{ response.configurationStatus }}'
      domainConfigurationStatus: '{{ response.domainConfigurationStatus }}'
      encryptionType: '{{ response.encryptionType }}'
      errorCode: '{{ response.errorCode }}'
      errorMessage: '{{ response.errorMessage }}'
      kmsAccessRoleArn: '{{ response.kmsAccessRoleArn }}'
      kmsKeyArn: '{{ response.kmsKeyArn }}'
- discovery_id: aws.iot.describe_endpoint
  calls:
  - action: describe_endpoint
    save_as: response
    on_error: continue
  emit:
    as: item
    item:
      endpointAddress: '{{ response.endpointAddress }}'
- discovery_id: aws.iot.describe_event_configurations
  calls:
  - action: describe_event_configurations
    save_as: response
    on_error: continue
  emit:
    as: item
    item:
      eventConfigurations: '{{ response.eventConfigurations }}'
- discovery_id: aws.iot.get_behavior_model_training_summaries
  calls:
  - action: get_behavior_model_training_summaries
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.summaries }}'
    item:
      behaviorName: '{{ item.behaviorName }}'
      datapointsCollectionPercentage: '{{ item.datapointsCollectionPercentage }}'
      lastModelRefreshDate: '{{ item.lastModelRefreshDate }}'
      modelStatus: '{{ item.modelStatus }}'
      securityProfileName: '{{ item.securityProfileName }}'
      summaries: '{{ item.summaries }}'
      trainingDataCollectionStartDate: '{{ item.trainingDataCollectionStartDate }}'
- discovery_id: aws.iot.get_effective_policies
  calls:
  - action: get_effective_policies
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.effectivePolicies }}'
    item:
      Statement: '{{ item.Statement }}'
      Version: '{{ item.Version }}'
      effectivePolicies: '{{ item.effectivePolicies }}'
      policyArn: '{{ item.policyArn }}'
      policyDocument: '{{ item.policyDocument }}'
      policyName: '{{ item.policyName }}'
- discovery_id: aws.iot.get_indexing_configuration
  calls:
  - action: get_indexing_configuration
    save_as: response
    on_error: continue
  emit:
    as: item
    item:
      customFields: '{{ response.thingIndexingConfiguration.customFields }}'
      deviceDefenderIndexingMode: '{{ response.thingIndexingConfiguration.deviceDefenderIndexingMode
        }}'
      filter: '{{ response.thingIndexingConfiguration.filter }}'
      managedFields: '{{ response.thingIndexingConfiguration.managedFields }}'
      namedShadowIndexingMode: '{{ response.thingIndexingConfiguration.namedShadowIndexingMode
        }}'
      thingConnectivityIndexingMode: '{{ response.thingIndexingConfiguration.thingConnectivityIndexingMode
        }}'
      thingGroupIndexingConfiguration: '{{ response.thingIndexingConfiguration.thingGroupIndexingConfiguration
        }}'
      thingIndexingConfiguration: '{{ response.thingIndexingConfiguration.thingIndexingConfiguration
        }}'
      thingIndexingMode: '{{ response.thingIndexingConfiguration.thingIndexingMode
        }}'
- discovery_id: aws.iot.get_logging_options
  calls:
  - action: get_logging_options
    save_as: response
    on_error: continue
  emit:
    as: item
    item:
      logLevel: '{{ response.logLevel }}'
      roleArn: '{{ response.roleArn }}'
- discovery_id: aws.iot.get_package_configuration
  calls:
  - action: get_package_configuration
    save_as: response
    on_error: continue
  emit:
    as: item
    item:
      enabled: '{{ response.versionUpdateByJobsConfig.enabled }}'
      roleArn: '{{ response.versionUpdateByJobsConfig.roleArn }}'
      versionUpdateByJobsConfig: '{{ response.versionUpdateByJobsConfig.versionUpdateByJobsConfig
        }}'
- discovery_id: aws.iot.get_registration_code
  calls:
  - action: get_registration_code
    save_as: response
    on_error: continue
  emit:
    as: item
    item:
      registrationCode: '{{ response.registrationCode }}'
- discovery_id: aws.iot.get_v2_logging_options
  calls:
  - action: get_v2_logging_options
    save_as: response
    on_error: continue
  emit:
    as: item
    item:
      defaultLogLevel: '{{ response.defaultLogLevel }}'
      disableAllLogs: '{{ response.disableAllLogs }}'
- discovery_id: aws.iot.list_active_violations
  calls:
  - action: list_active_violations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.activeViolations }}'
    item:
      behavior: '{{ item.behavior }}'
      defaultClientId: '{{ item.defaultClientId }}'
      disconnectReason: '{{ item.disconnectReason }}'
      lastViolationTime: '{{ item.lastViolationTime }}'
      lastViolationValue: '{{ item.lastViolationValue }}'
      principal: '{{ item.principal }}'
      securityProfileName: '{{ item.securityProfileName }}'
      verificationState: '{{ item.verificationState }}'
      verificationStateDescription: '{{ item.verificationStateDescription }}'
      violationEventAdditionalInfo: '{{ item.violationEventAdditionalInfo }}'
      violationId: '{{ item.violationId }}'
      violationStartTime: '{{ item.violationStartTime }}'
- discovery_id: aws.iot.list_audit_findings
  calls:
  - action: list_audit_findings
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.findings }}'
    item:
      actionParams: '{{ item.actionParams }}'
      additionalInfo: '{{ item.additionalInfo }}'
      auditCheckToActionsMapping: '{{ item.auditCheckToActionsMapping }}'
      auditDetails: '{{ item.auditDetails }}'
      canceledChecks: '{{ item.canceledChecks }}'
      checkName: '{{ item.checkName }}'
      compliantChecks: '{{ item.compliantChecks }}'
      endTime: '{{ item.endTime }}'
      failedChecks: '{{ item.failedChecks }}'
      failureCount: '{{ item.failureCount }}'
      finding: '{{ item.finding }}'
      findingId: '{{ item.findingId }}'
      findingTime: '{{ item.findingTime }}'
      id: '{{ item.id }}'
      inProgressChecks: '{{ item.inProgressChecks }}'
      inputFileBucket: '{{ item.inputFileBucket }}'
      inputFileKey: '{{ item.inputFileKey }}'
      isSuppressed: '{{ item.isSuppressed }}'
      nonCompliantChecks: '{{ item.nonCompliantChecks }}'
      nonCompliantResource: '{{ item.nonCompliantResource }}'
      percentageProgress: '{{ item.percentageProgress }}'
      reasonForNonCompliance: '{{ item.reasonForNonCompliance }}'
      reasonForNonComplianceCode: '{{ item.reasonForNonComplianceCode }}'
      relatedResources: '{{ item.relatedResources }}'
      resourceType: '{{ item.resourceType }}'
      severity: '{{ item.severity }}'
      statistics: '{{ item.statistics }}'
      successCount: '{{ item.successCount }}'
      taskId: '{{ item.taskId }}'
      taskStartTime: '{{ item.taskStartTime }}'
      taskSummary: '{{ item.taskSummary }}'
      templateBody: '{{ item.templateBody }}'
      totalChecks: '{{ item.totalChecks }}'
      waitingForDataCollectionChecks: '{{ item.waitingForDataCollectionChecks }}'
- discovery_id: aws.iot.list_audit_suppressions
  calls:
  - action: list_audit_suppressions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.suppressions }}'
    item:
      checkName: '{{ item.checkName }}'
      description: '{{ item.description }}'
      expirationDate: '{{ item.expirationDate }}'
      resourceIdentifier: '{{ item.resourceIdentifier }}'
      suppressIndefinitely: '{{ item.suppressIndefinitely }}'
- discovery_id: aws.iot.list_authorizers
  calls:
  - action: list_authorizers
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.authorizers }}'
    item:
      authorizerArn: '{{ item.authorizerArn }}'
      authorizerName: '{{ item.authorizerName }}'
- discovery_id: aws.iot.list_billing_groups
  calls:
  - action: list_billing_groups
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.billingGroups }}'
    item:
      billingGroupName: '{{ item.billingGroupName }}'
      groupArn: '{{ item.groupArn }}'
      groupName: '{{ item.groupName }}'
- discovery_id: aws.iot.list_ca_certificates
  calls:
  - action: list_ca_certificates
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.certificates }}'
    item:
      autoRegistrationStatus: '{{ item.autoRegistrationStatus }}'
      certificateArn: '{{ item.certificateArn }}'
      certificateDescription: '{{ item.certificateDescription }}'
      certificateId: '{{ item.certificateId }}'
      certificatePem: '{{ item.certificatePem }}'
      creationDate: '{{ item.creationDate }}'
      customerVersion: '{{ item.customerVersion }}'
      generationId: '{{ item.generationId }}'
      ownedBy: '{{ item.ownedBy }}'
      previousOwnedBy: '{{ item.previousOwnedBy }}'
      registrationConfig: '{{ item.registrationConfig }}'
      status: '{{ item.status }}'
      transferData: '{{ item.transferData }}'
      validity: '{{ item.validity }}'
- discovery_id: aws.iot.list_certificate_providers
  calls:
  - action: list_certificate_providers
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.certificateProviders }}'
    item:
      certificateProviderArn: '{{ item.certificateProviderArn }}'
      certificateProviderName: '{{ item.certificateProviderName }}'
- discovery_id: aws.iot.list_certificates
  calls:
  - action: list_certificates
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.certificates }}'
    item:
      certificateArn: '{{ item.certificateArn }}'
      certificateId: '{{ item.certificateId }}'
      certificateMode: '{{ item.certificateMode }}'
      creationDate: '{{ item.creationDate }}'
      status: '{{ item.status }}'
- discovery_id: aws.iot.list_command_executions
  calls:
  - action: list_command_executions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.commandExecutions }}'
    item:
      commandArn: '{{ item.commandArn }}'
      completedAt: '{{ item.completedAt }}'
      createdAt: '{{ item.createdAt }}'
      executionId: '{{ item.executionId }}'
      executionTimeoutSeconds: '{{ item.executionTimeoutSeconds }}'
      mandatoryParameters: '{{ item.mandatoryParameters }}'
      namespace: '{{ item.namespace }}'
      parameters: '{{ item.parameters }}'
      payload: '{{ item.payload }}'
      reasonDescription: '{{ item.reasonDescription }}'
      result: '{{ item.result }}'
      startedAt: '{{ item.startedAt }}'
      status: '{{ item.status }}'
      targetArn: '{{ item.targetArn }}'
      timeToLive: '{{ item.timeToLive }}'
- discovery_id: aws.iot.list_commands
  calls:
  - action: list_commands
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.commands }}'
    item:
      commandArn: '{{ item.commandArn }}'
      commandId: '{{ item.commandId }}'
      createdAt: '{{ item.createdAt }}'
      defaultValue: '{{ item.defaultValue }}'
      deprecated: '{{ item.deprecated }}'
      displayName: '{{ item.displayName }}'
      lastUpdatedAt: '{{ item.lastUpdatedAt }}'
      mandatoryParameters: '{{ item.mandatoryParameters }}'
      namespace: '{{ item.namespace }}'
      payload: '{{ item.payload }}'
      pendingDeletion: '{{ item.pendingDeletion }}'
      value: '{{ item.value }}'
- discovery_id: aws.iot.list_custom_metrics
  calls:
  - action: list_custom_metrics
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.metricNames }}'
    item:
      metricType: '{{ item.metricType }}'
- discovery_id: aws.iot.list_detect_mitigation_actions_executions
  calls:
  - action: list_detect_mitigation_actions_executions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.actionsExecutions }}'
    item:
      actionName: '{{ item.actionName }}'
      actionType: '{{ item.actionType }}'
      addThingsToThingGroupParams: '{{ item.addThingsToThingGroupParams }}'
      enableIoTLoggingParams: '{{ item.enableIoTLoggingParams }}'
      errorCode: '{{ item.errorCode }}'
      execution: '{{ item.execution }}'
      executionEndDate: '{{ item.executionEndDate }}'
      executionStartDate: '{{ item.executionStartDate }}'
      message: '{{ item.message }}'
      publishFindingToSnsParams: '{{ item.publishFindingToSnsParams }}'
      replaceDefaultPolicyVersionParams: '{{ item.replaceDefaultPolicyVersionParams
        }}'
      status: '{{ item.status }}'
      taskId: '{{ item.taskId }}'
      updateCACertificateParams: '{{ item.updateCACertificateParams }}'
      updateDeviceCertificateParams: '{{ item.updateDeviceCertificateParams }}'
      violationId: '{{ item.violationId }}'
- discovery_id: aws.iot.list_dimensions
  calls:
  - action: list_dimensions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.dimensionNames }}'
- discovery_id: aws.iot.list_domain_configurations
  calls:
  - action: list_domain_configurations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.domainConfigurations }}'
    item:
