- discovery_id: aws.iot.list_streams
  calls:
  - action: list_streams
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.streams }}'
    item:
      description: '{{ item.description }}'
      streamArn: '{{ item.streamArn }}'
      streamId: '{{ item.streamId }}'
      streamInfo: '{{ item.streamInfo }}'
      streamVersion: '{{ item.streamVersion }}'
- discovery_id: aws.iot.list_thing_groups
  calls:
  - action: list_thing_groups
