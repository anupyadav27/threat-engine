      createdAt: '{{ item.createdAt }}'
      destinationPackageVersions: '{{ item.destinationPackageVersions }}'
      document: '{{ item.document }}'
      documentParameters: '{{ item.documentParameters }}'
      documentSource: '{{ item.documentSource }}'
      durationInMinutes: '{{ item.durationInMinutes }}'
      forceCanceled: '{{ item.forceCanceled }}'
      isConcurrent: '{{ item.isConcurrent }}'
      jobArn: '{{ item.jobArn }}'
      jobId: '{{ item.jobId }}'
      lastUpdatedAt: '{{ item.lastUpdatedAt }}'
      maintenanceWindows: '{{ item.maintenanceWindows }}'
      namespaceId: '{{ item.namespaceId }}'
      presignedUrlConfig: '{{ item.presignedUrlConfig }}'
      reasonCode: '{{ item.reasonCode }}'
      scheduledJobRollouts: '{{ item.scheduledJobRollouts }}'
      schedulingConfig: '{{ item.schedulingConfig }}'
      startTime: '{{ item.startTime }}'
      status: '{{ item.status }}'
      targetSelection: '{{ item.targetSelection }}'
      targets: '{{ item.targets }}'
      thingGroupId: '{{ item.thingGroupId }}'
      timeoutConfig: '{{ item.timeoutConfig }}'
- discovery_id: aws.iot.list_managed_job_templates
  calls:
