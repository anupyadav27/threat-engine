- discovery_id: aws.iot.listThingsInBillingGroup
  calls:
  - action: listThingsInBillingGroup
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.things }}'
- discovery_id: aws.iot.listThingsInThingGroup
  calls:
  - action: listThingsInThingGroup
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.things }}'
- discovery_id: aws.iot.listViolationEvents
  calls:
  - action: listViolationEvents
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.violationEvents }}'
    item:
      violationId: '{{ item.violationId }}'
      thingName: '{{ item.thingName }}'
      securityProfileName: '{{ item.securityProfileName }}'
      behavior: '{{ item.behavior }}'
      metricValue: '{{ item.metricValue }}'
      violationEventAdditionalInfo: '{{ item.violationEventAdditionalInfo }}'
      violationEventType: '{{ item.violationEventType }}'
      verificationState: '{{ item.verificationState }}'
      verificationStateDescription: '{{ item.verificationStateDescription }}'
      violationEventTime: '{{ item.violationEventTime }}'
- discovery_id: aws.iot.searchIndex
  calls:
  - action: searchIndex
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.thingGroups }}'
    item:
      thingGroupName: '{{ item.thingGroupName }}'
      thingGroupId: '{{ item.thingGroupId }}'
      thingGroupDescription: '{{ item.thingGroupDescription }}'
      attributes: '{{ item.attributes }}'
      parentGroupNames: '{{ item.parentGroupNames }}'
checks: []
