version: '1.0'
provider: aws
service: iot
services:
  client: iot
  module: boto3.client
discovery:
- discovery_id: aws.iot.describeAccountAuditConfiguration
  calls:
  - action: describeAccountAuditConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.roleArn }}'
- discovery_id: aws.iot.describeDefaultAuthorizer
  calls:
  - action: describeDefaultAuthorizer
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.authorizerDescription }}'
    item:
      authorizerName: '{{ item.authorizerName }}'
      authorizerArn: '{{ item.authorizerArn }}'
      authorizerFunctionArn: '{{ item.authorizerFunctionArn }}'
      tokenKeyName: '{{ item.tokenKeyName }}'
      tokenSigningPublicKeys: '{{ item.tokenSigningPublicKeys }}'
      status: '{{ item.status }}'
      creationDate: '{{ item.creationDate }}'
      lastModifiedDate: '{{ item.lastModifiedDate }}'
      signingDisabled: '{{ item.signingDisabled }}'
      enableCachingForHttp: '{{ item.enableCachingForHttp }}'
- discovery_id: aws.iot.describeEncryptionConfiguration
  calls:
  - action: describeEncryptionConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.configurationDetails }}'
    item:
      configurationStatus: '{{ item.configurationStatus }}'
      errorCode: '{{ item.errorCode }}'
      errorMessage: '{{ item.errorMessage }}'
- discovery_id: aws.iot.describeEndpoint
  calls:
  - action: describeEndpoint
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.endpointAddress }}'
- discovery_id: aws.iot.describeEventConfigurations
  calls:
  - action: describeEventConfigurations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.eventConfigurations }}'
- discovery_id: aws.iot.getBehaviorModelTrainingSummaries
  calls:
  - action: getBehaviorModelTrainingSummaries
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.summaries }}'
    item:
      securityProfileName: '{{ item.securityProfileName }}'
      behaviorName: '{{ item.behaviorName }}'
      trainingDataCollectionStartDate: '{{ item.trainingDataCollectionStartDate }}'
      modelStatus: '{{ item.modelStatus }}'
      datapointsCollectionPercentage: '{{ item.datapointsCollectionPercentage }}'
      lastModelRefreshDate: '{{ item.lastModelRefreshDate }}'
- discovery_id: aws.iot.getEffectivePolicies
  calls:
  - action: getEffectivePolicies
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.effectivePolicies }}'
    item:
      policyName: '{{ item.policyName }}'
      policyArn: '{{ item.policyArn }}'
      policyDocument: '{{ item.policyDocument }}'
- discovery_id: aws.iot.getIndexingConfiguration
  calls:
  - action: getIndexingConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.thingIndexingConfiguration }}'
    item:
      thingIndexingMode: '{{ item.thingIndexingMode }}'
      thingConnectivityIndexingMode: '{{ item.thingConnectivityIndexingMode }}'
      deviceDefenderIndexingMode: '{{ item.deviceDefenderIndexingMode }}'
      namedShadowIndexingMode: '{{ item.namedShadowIndexingMode }}'
      managedFields: '{{ item.managedFields }}'
      customFields: '{{ item.customFields }}'
      filter: '{{ item.filter }}'
- discovery_id: aws.iot.getLoggingOptions
  calls:
  - action: getLoggingOptions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.roleArn }}'
- discovery_id: aws.iot.getPackageConfiguration
  calls:
  - action: getPackageConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.versionUpdateByJobsConfig }}'
    item:
      enabled: '{{ item.enabled }}'
      roleArn: '{{ item.roleArn }}'
- discovery_id: aws.iot.getRegistrationCode
  calls:
  - action: getRegistrationCode
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.registrationCode }}'
- discovery_id: aws.iot.getV2LoggingOptions
  calls:
  - action: getV2LoggingOptions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.roleArn }}'
- discovery_id: aws.iot.listActiveViolations
  calls:
  - action: listActiveViolations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.activeViolations }}'
    item:
      violationId: '{{ item.violationId }}'
      thingName: '{{ item.thingName }}'
      securityProfileName: '{{ item.securityProfileName }}'
      behavior: '{{ item.behavior }}'
      lastViolationValue: '{{ item.lastViolationValue }}'
      violationEventAdditionalInfo: '{{ item.violationEventAdditionalInfo }}'
      verificationState: '{{ item.verificationState }}'
      verificationStateDescription: '{{ item.verificationStateDescription }}'
      lastViolationTime: '{{ item.lastViolationTime }}'
      violationStartTime: '{{ item.violationStartTime }}'
- discovery_id: aws.iot.listAuditFindings
  calls:
  - action: listAuditFindings
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.findings }}'
    item:
      findingId: '{{ item.findingId }}'
      taskId: '{{ item.taskId }}'
      checkName: '{{ item.checkName }}'
      taskStartTime: '{{ item.taskStartTime }}'
      findingTime: '{{ item.findingTime }}'
      severity: '{{ item.severity }}'
      nonCompliantResource: '{{ item.nonCompliantResource }}'
      relatedResources: '{{ item.relatedResources }}'
      reasonForNonCompliance: '{{ item.reasonForNonCompliance }}'
      reasonForNonComplianceCode: '{{ item.reasonForNonComplianceCode }}'
      isSuppressed: '{{ item.isSuppressed }}'
- discovery_id: aws.iot.listAuditSuppressions
  calls:
  - action: listAuditSuppressions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.suppressions }}'
    item:
      checkName: '{{ item.checkName }}'
      resourceIdentifier: '{{ item.resourceIdentifier }}'
      expirationDate: '{{ item.expirationDate }}'
      suppressIndefinitely: '{{ item.suppressIndefinitely }}'
      description: '{{ item.description }}'
- discovery_id: aws.iot.listAuthorizers
  calls:
  - action: listAuthorizers
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.authorizers }}'
    item:
      authorizerName: '{{ item.authorizerName }}'
      authorizerArn: '{{ item.authorizerArn }}'
- discovery_id: aws.iot.listBillingGroups
  calls:
  - action: listBillingGroups
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.billingGroups }}'
    item:
      groupName: '{{ item.groupName }}'
      groupArn: '{{ item.groupArn }}'
- discovery_id: aws.iot.listCaCertificates
  calls:
  - action: listCaCertificates
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.certificates }}'
    item:
      certificateArn: '{{ item.certificateArn }}'
      certificateId: '{{ item.certificateId }}'
      status: '{{ item.status }}'
      creationDate: '{{ item.creationDate }}'
- discovery_id: aws.iot.listCertificateProviders
  calls:
  - action: listCertificateProviders
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.certificateProviders }}'
    item:
      certificateProviderName: '{{ item.certificateProviderName }}'
      certificateProviderArn: '{{ item.certificateProviderArn }}'
- discovery_id: aws.iot.listCertificates
  calls:
  - action: listCertificates
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.certificates }}'
    item:
      certificateArn: '{{ item.certificateArn }}'
      certificateId: '{{ item.certificateId }}'
      status: '{{ item.status }}'
      certificateMode: '{{ item.certificateMode }}'
      creationDate: '{{ item.creationDate }}'
- discovery_id: aws.iot.listCommandExecutions
  calls:
  - action: listCommandExecutions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.commandExecutions }}'
    item:
      commandArn: '{{ item.commandArn }}'
      executionId: '{{ item.executionId }}'
      targetArn: '{{ item.targetArn }}'
      status: '{{ item.status }}'
      createdAt: '{{ item.createdAt }}'
      startedAt: '{{ item.startedAt }}'
      completedAt: '{{ item.completedAt }}'
- discovery_id: aws.iot.listCommands
  calls:
  - action: listCommands
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.commands }}'
    item:
      commandArn: '{{ item.commandArn }}'
      commandId: '{{ item.commandId }}'
      displayName: '{{ item.displayName }}'
      deprecated: '{{ item.deprecated }}'
      createdAt: '{{ item.createdAt }}'
      lastUpdatedAt: '{{ item.lastUpdatedAt }}'
      pendingDeletion: '{{ item.pendingDeletion }}'
- discovery_id: aws.iot.listCustomMetrics
  calls:
  - action: listCustomMetrics
    save_as: response
    on_error: continue
  emit:
