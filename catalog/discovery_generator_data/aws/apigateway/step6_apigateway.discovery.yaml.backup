version: '1.0'
provider: aws
service: apigateway
services:
  client: apigateway
  module: boto3.client
discovery:
- discovery_id: aws.apigateway.getAccount
  calls:
  - action: getAccount
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.features }}'
- discovery_id: aws.apigateway.getApiKeys
  calls:
  - action: getApiKeys
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
    item:
      id: '{{ item.id }}'
      value: '{{ item.value }}'
      name: '{{ item.name }}'
      customerId: '{{ item.customerId }}'
      description: '{{ item.description }}'
      enabled: '{{ item.enabled }}'
      createdDate: '{{ item.createdDate }}'
      lastUpdatedDate: '{{ item.lastUpdatedDate }}'
      stageKeys: '{{ item.stageKeys }}'
      tags: '{{ item.tags }}'
- discovery_id: aws.apigateway.getClientCertificates
  calls:
  - action: getClientCertificates
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
    item:
      clientCertificateId: '{{ item.clientCertificateId }}'
      description: '{{ item.description }}'
      pemEncodedCertificate: '{{ item.pemEncodedCertificate }}'
      createdDate: '{{ item.createdDate }}'
      expirationDate: '{{ item.expirationDate }}'
      tags: '{{ item.tags }}'
- discovery_id: aws.apigateway.getDomainNameAccessAssociations
  calls:
  - action: getDomainNameAccessAssociations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
    item:
      domainNameAccessAssociationArn: '{{ item.domainNameAccessAssociationArn }}'
      domainNameArn: '{{ item.domainNameArn }}'
      accessAssociationSourceType: '{{ item.accessAssociationSourceType }}'
      accessAssociationSource: '{{ item.accessAssociationSource }}'
      tags: '{{ item.tags }}'
- discovery_id: aws.apigateway.getDomainNames
  calls:
  - action: getDomainNames
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
    item:
      domainName: '{{ item.domainName }}'
      domainNameId: '{{ item.domainNameId }}'
      domainNameArn: '{{ item.domainNameArn }}'
      certificateName: '{{ item.certificateName }}'
      certificateArn: '{{ item.certificateArn }}'
      certificateUploadDate: '{{ item.certificateUploadDate }}'
      regionalDomainName: '{{ item.regionalDomainName }}'
      regionalHostedZoneId: '{{ item.regionalHostedZoneId }}'
      regionalCertificateName: '{{ item.regionalCertificateName }}'
      regionalCertificateArn: '{{ item.regionalCertificateArn }}'
      distributionDomainName: '{{ item.distributionDomainName }}'
      distributionHostedZoneId: '{{ item.distributionHostedZoneId }}'
      endpointConfiguration: '{{ item.endpointConfiguration }}'
      domainNameStatus: '{{ item.domainNameStatus }}'
      domainNameStatusMessage: '{{ item.domainNameStatusMessage }}'
      securityPolicy: '{{ item.securityPolicy }}'
      endpointAccessMode: '{{ item.endpointAccessMode }}'
      tags: '{{ item.tags }}'
      mutualTlsAuthentication: '{{ item.mutualTlsAuthentication }}'
      ownershipVerificationCertificateArn: '{{ item.ownershipVerificationCertificateArn
        }}'
      managementPolicy: '{{ item.managementPolicy }}'
      policy: '{{ item.policy }}'
      routingMode: '{{ item.routingMode }}'
- discovery_id: aws.apigateway.getRestApis
  calls:
  - action: getRestApis
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
    item:
      id: '{{ item.id }}'
      name: '{{ item.name }}'
      description: '{{ item.description }}'
      createdDate: '{{ item.createdDate }}'
      version: '{{ item.version }}'
      warnings: '{{ item.warnings }}'
      binaryMediaTypes: '{{ item.binaryMediaTypes }}'
      minimumCompressionSize: '{{ item.minimumCompressionSize }}'
      apiKeySource: '{{ item.apiKeySource }}'
      endpointConfiguration: '{{ item.endpointConfiguration }}'
      policy: '{{ item.policy }}'
      tags: '{{ item.tags }}'
      disableExecuteApiEndpoint: '{{ item.disableExecuteApiEndpoint }}'
      rootResourceId: '{{ item.rootResourceId }}'
      securityPolicy: '{{ item.securityPolicy }}'
      endpointAccessMode: '{{ item.endpointAccessMode }}'
      apiStatus: '{{ item.apiStatus }}'
      apiStatusMessage: '{{ item.apiStatusMessage }}'
- discovery_id: aws.apigateway.getSdkTypes
  calls:
  - action: getSdkTypes
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
    item:
      id: '{{ item.id }}'
      friendlyName: '{{ item.friendlyName }}'
      description: '{{ item.description }}'
      configurationProperties: '{{ item.configurationProperties }}'
- discovery_id: aws.apigateway.getUsagePlans
  calls:
  - action: getUsagePlans
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
    item:
      id: '{{ item.id }}'
      name: '{{ item.name }}'
      description: '{{ item.description }}'
      apiStages: '{{ item.apiStages }}'
      throttle: '{{ item.throttle }}'
      quota: '{{ item.quota }}'
      productCode: '{{ item.productCode }}'
      tags: '{{ item.tags }}'
- discovery_id: aws.apigateway.getVpcLinks
  calls:
  - action: getVpcLinks
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
    item:
      id: '{{ item.id }}'
      name: '{{ item.name }}'
      description: '{{ item.description }}'
      targetArns: '{{ item.targetArns }}'
      status: '{{ item.status }}'
      statusMessage: '{{ item.statusMessage }}'
      tags: '{{ item.tags }}'
- discovery_id: aws.apigateway.getApiKey
  calls:
  - action: getApiKey
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.stageKeys }}'
- discovery_id: aws.apigateway.getAuthorizer
  calls:
  - action: getAuthorizer
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.providerARNs }}'
- discovery_id: aws.apigateway.getAuthorizers
  calls:
  - action: getAuthorizers
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
    item:
      id: '{{ item.id }}'
      name: '{{ item.name }}'
      type: '{{ item.type }}'
      providerARNs: '{{ item.providerARNs }}'
      authType: '{{ item.authType }}'
      authorizerUri: '{{ item.authorizerUri }}'
      authorizerCredentials: '{{ item.authorizerCredentials }}'
      identitySource: '{{ item.identitySource }}'
      identityValidationExpression: '{{ item.identityValidationExpression }}'
      authorizerResultTtlInSeconds: '{{ item.authorizerResultTtlInSeconds }}'
- discovery_id: aws.apigateway.getBasePathMapping
  calls:
  - action: getBasePathMapping
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.basePath }}'
- discovery_id: aws.apigateway.getBasePathMappings
  calls:
  - action: getBasePathMappings
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
    item:
      basePath: '{{ item.basePath }}'
      restApiId: '{{ item.restApiId }}'
      stage: '{{ item.stage }}'
- discovery_id: aws.apigateway.getClientCertificate
  calls:
  - action: getClientCertificate
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.clientCertificateId }}'
- discovery_id: aws.apigateway.getDeployment
  calls:
  - action: getDeployment
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.id }}'
- discovery_id: aws.apigateway.getDeployments
  calls:
  - action: getDeployments
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
    item:
      id: '{{ item.id }}'
      description: '{{ item.description }}'
      createdDate: '{{ item.createdDate }}'
      apiSummary: '{{ item.apiSummary }}'
- discovery_id: aws.apigateway.getDocumentationPart
  calls:
  - action: getDocumentationPart
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.location }}'
    item:
      type: '{{ item.type }}'
      path: '{{ item.path }}'
      method: '{{ item.method }}'
      statusCode: '{{ item.statusCode }}'
      name: '{{ item.name }}'
- discovery_id: aws.apigateway.getDocumentationParts
  calls:
  - action: getDocumentationParts
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
    item:
      id: '{{ item.id }}'
      location: '{{ item.location }}'
      properties: '{{ item.properties }}'
- discovery_id: aws.apigateway.getDocumentationVersion
  calls:
  - action: getDocumentationVersion
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.version }}'
- discovery_id: aws.apigateway.getDocumentationVersions
  calls:
  - action: getDocumentationVersions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
    item:
      version: '{{ item.version }}'
      createdDate: '{{ item.createdDate }}'
      description: '{{ item.description }}'
- discovery_id: aws.apigateway.getDomainName
  calls:
  - action: getDomainName
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.endpointConfiguration }}'
    item:
      types: '{{ item.types }}'
      ipAddressType: '{{ item.ipAddressType }}'
      vpcEndpointIds: '{{ item.vpcEndpointIds }}'
- discovery_id: aws.apigateway.getExport
  calls:
  - action: getExport
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.contentType }}'
- discovery_id: aws.apigateway.getGatewayResponse
  calls:
  - action: getGatewayResponse
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.responseType }}'
- discovery_id: aws.apigateway.getGatewayResponses
  calls:
  - action: getGatewayResponses
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
    item:
      responseType: '{{ item.responseType }}'
      statusCode: '{{ item.statusCode }}'
      responseParameters: '{{ item.responseParameters }}'
      responseTemplates: '{{ item.responseTemplates }}'
      defaultResponse: '{{ item.defaultResponse }}'
- discovery_id: aws.apigateway.getIntegration
  calls:
  - action: getIntegration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.cacheKeyParameters }}'
- discovery_id: aws.apigateway.getIntegrationResponse
  calls:
  - action: getIntegrationResponse
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.statusCode }}'
- discovery_id: aws.apigateway.getMethod
  calls:
  - action: getMethod
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.authorizationScopes }}'
- discovery_id: aws.apigateway.getMethodResponse
  calls:
  - action: getMethodResponse
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.statusCode }}'
- discovery_id: aws.apigateway.getModel
  calls:
  - action: getModel
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.id }}'
- discovery_id: aws.apigateway.getModelTemplate
  calls:
  - action: getModelTemplate
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: aws.apigateway.getModels
  calls:
  - action: getModels
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
    item:
      id: '{{ item.id }}'
      name: '{{ item.name }}'
      description: '{{ item.description }}'
      schema: '{{ item.schema }}'
      contentType: '{{ item.contentType }}'
- discovery_id: aws.apigateway.getRequestValidator
  calls:
  - action: getRequestValidator
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.id }}'
- discovery_id: aws.apigateway.getRequestValidators
  calls:
  - action: getRequestValidators
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
    item:
      id: '{{ item.id }}'
      name: '{{ item.name }}'
      validateRequestBody: '{{ item.validateRequestBody }}'
      validateRequestParameters: '{{ item.validateRequestParameters }}'
- discovery_id: aws.apigateway.getResource
  calls:
  - action: getResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.id }}'
- discovery_id: aws.apigateway.getResources
  calls:
  - action: getResources
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
    item:
      id: '{{ item.id }}'
      parentId: '{{ item.parentId }}'
      pathPart: '{{ item.pathPart }}'
      path: '{{ item.path }}'
      resourceMethods: '{{ item.resourceMethods }}'
- discovery_id: aws.apigateway.getRestApi
  calls:
  - action: getRestApi
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.warnings }}'
- discovery_id: aws.apigateway.getSdk
  calls:
  - action: getSdk
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.contentType }}'
- discovery_id: aws.apigateway.getSdkType
  calls:
  - action: getSdkType
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.configurationProperties }}'
    item:
      name: '{{ item.name }}'
      friendlyName: '{{ item.friendlyName }}'
      description: '{{ item.description }}'
      required: '{{ item.required }}'
      defaultValue: '{{ item.defaultValue }}'
- discovery_id: aws.apigateway.getStage
  calls:
  - action: getStage
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.accessLogSettings }}'
    item:
      format: '{{ item.format }}'
      destinationArn: '{{ item.destinationArn }}'
- discovery_id: aws.apigateway.getStages
  calls:
  - action: getStages
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.item }}'
    item:
      deploymentId: '{{ item.deploymentId }}'
      clientCertificateId: '{{ item.clientCertificateId }}'
      stageName: '{{ item.stageName }}'
      description: '{{ item.description }}'
      cacheClusterEnabled: '{{ item.cacheClusterEnabled }}'
      cacheClusterSize: '{{ item.cacheClusterSize }}'
      cacheClusterStatus: '{{ item.cacheClusterStatus }}'
      methodSettings: '{{ item.methodSettings }}'
      variables: '{{ item.variables }}'
      documentationVersion: '{{ item.documentationVersion }}'
      accessLogSettings: '{{ item.accessLogSettings }}'
      canarySettings: '{{ item.canarySettings }}'
      tracingEnabled: '{{ item.tracingEnabled }}'
      webAclArn: '{{ item.webAclArn }}'
      tags: '{{ item.tags }}'
      createdDate: '{{ item.createdDate }}'
      lastUpdatedDate: '{{ item.lastUpdatedDate }}'
- discovery_id: aws.apigateway.getTags
  calls:
  - action: getTags
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tags }}'
- discovery_id: aws.apigateway.getUsage
  calls:
  - action: getUsage
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.usagePlanId }}'
- discovery_id: aws.apigateway.getUsagePlan
  calls:
  - action: getUsagePlan
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.apiStages }}'
    item:
      apiId: '{{ item.apiId }}'
      stage: '{{ item.stage }}'
      throttle: '{{ item.throttle }}'
- discovery_id: aws.apigateway.getUsagePlanKey
  calls:
  - action: getUsagePlanKey
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.id }}'
- discovery_id: aws.apigateway.getUsagePlanKeys
  calls:
  - action: getUsagePlanKeys
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
    item:
      id: '{{ item.id }}'
      type: '{{ item.type }}'
      value: '{{ item.value }}'
      name: '{{ item.name }}'
- discovery_id: aws.apigateway.getVpcLink
  calls:
  - action: getVpcLink
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.targetArns }}'
checks: []
