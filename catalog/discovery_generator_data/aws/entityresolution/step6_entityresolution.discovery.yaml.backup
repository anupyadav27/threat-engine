version: '1.0'
provider: aws
service: entityresolution
services:
  client: entityresolution
  module: boto3.client
discovery:
- discovery_id: aws.entityresolution.listIdMappingWorkflows
  calls:
  - action: listIdMappingWorkflows
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.workflowSummaries }}'
    item:
      workflowName: '{{ item.workflowName }}'
      workflowArn: '{{ item.workflowArn }}'
      createdAt: '{{ item.createdAt }}'
      updatedAt: '{{ item.updatedAt }}'
- discovery_id: aws.entityresolution.listIdNamespaces
  calls:
  - action: listIdNamespaces
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.idNamespaceSummaries }}'
    item:
      idNamespaceName: '{{ item.idNamespaceName }}'
      idNamespaceArn: '{{ item.idNamespaceArn }}'
      description: '{{ item.description }}'
      idMappingWorkflowProperties: '{{ item.idMappingWorkflowProperties }}'
      type: '{{ item.type }}'
      createdAt: '{{ item.createdAt }}'
      updatedAt: '{{ item.updatedAt }}'
- discovery_id: aws.entityresolution.listMatchingWorkflows
  calls:
  - action: listMatchingWorkflows
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.workflowSummaries }}'
    item:
      workflowName: '{{ item.workflowName }}'
      workflowArn: '{{ item.workflowArn }}'
      createdAt: '{{ item.createdAt }}'
      updatedAt: '{{ item.updatedAt }}'
      resolutionType: '{{ item.resolutionType }}'
- discovery_id: aws.entityresolution.listProviderServices
  calls:
  - action: listProviderServices
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.providerServiceSummaries }}'
    item:
      providerServiceArn: '{{ item.providerServiceArn }}'
      providerName: '{{ item.providerName }}'
      providerServiceDisplayName: '{{ item.providerServiceDisplayName }}'
      providerServiceName: '{{ item.providerServiceName }}'
      providerServiceType: '{{ item.providerServiceType }}'
- discovery_id: aws.entityresolution.listSchemaMappings
  calls:
  - action: listSchemaMappings
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.schemaList }}'
    item:
      schemaName: '{{ item.schemaName }}'
      schemaArn: '{{ item.schemaArn }}'
      createdAt: '{{ item.createdAt }}'
      updatedAt: '{{ item.updatedAt }}'
      hasWorkflows: '{{ item.hasWorkflows }}'
- discovery_id: aws.entityresolution.getIdMappingJob
  calls:
  - action: getIdMappingJob
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.outputSourceConfig }}'
    item:
      roleArn: '{{ item.roleArn }}'
      outputS3Path: '{{ item.outputS3Path }}'
      KMSArn: '{{ item.KMSArn }}'
- discovery_id: aws.entityresolution.getIdMappingWorkflow
  calls:
  - action: getIdMappingWorkflow
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.inputSourceConfig }}'
    item:
      inputSourceARN: '{{ item.inputSourceARN }}'
      schemaName: '{{ item.schemaName }}'
      type: '{{ item.type }}'
- discovery_id: aws.entityresolution.getIdNamespace
  calls:
  - action: getIdNamespace
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.inputSourceConfig }}'
    item:
      inputSourceARN: '{{ item.inputSourceARN }}'
      schemaName: '{{ item.schemaName }}'
- discovery_id: aws.entityresolution.getMatchId
  calls:
  - action: getMatchId
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.matchId }}'
- discovery_id: aws.entityresolution.getMatchingJob
  calls:
  - action: getMatchingJob
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.outputSourceConfig }}'
    item:
      roleArn: '{{ item.roleArn }}'
      outputS3Path: '{{ item.outputS3Path }}'
      KMSArn: '{{ item.KMSArn }}'
- discovery_id: aws.entityresolution.getMatchingWorkflow
  calls:
  - action: getMatchingWorkflow
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.inputSourceConfig }}'
    item:
      inputSourceARN: '{{ item.inputSourceARN }}'
      schemaName: '{{ item.schemaName }}'
      applyNormalization: '{{ item.applyNormalization }}'
- discovery_id: aws.entityresolution.getPolicy
  calls:
  - action: getPolicy
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.arn }}'
- discovery_id: aws.entityresolution.getProviderService
  calls:
  - action: getProviderService
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.providerConfigurationDefinition }}'
- discovery_id: aws.entityresolution.getSchemaMapping
  calls:
  - action: getSchemaMapping
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.mappedInputFields }}'
    item:
      fieldName: '{{ item.fieldName }}'
      type: '{{ item.type }}'
      groupName: '{{ item.groupName }}'
      matchKey: '{{ item.matchKey }}'
      subType: '{{ item.subType }}'
      hashed: '{{ item.hashed }}'
- discovery_id: aws.entityresolution.listIdMappingJobs
  calls:
  - action: listIdMappingJobs
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.jobs }}'
    item:
      jobId: '{{ item.jobId }}'
      status: '{{ item.status }}'
      startTime: '{{ item.startTime }}'
      endTime: '{{ item.endTime }}'
- discovery_id: aws.entityresolution.listMatchingJobs
  calls:
  - action: listMatchingJobs
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.jobs }}'
    item:
      jobId: '{{ item.jobId }}'
      status: '{{ item.status }}'
      startTime: '{{ item.startTime }}'
      endTime: '{{ item.endTime }}'
- discovery_id: aws.entityresolution.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tags }}'
checks: []
