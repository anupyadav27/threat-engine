version: '1.0'
provider: aws
service: scheduler
services:
  client: scheduler
  module: boto3.client
discovery:
- discovery_id: aws.scheduler.listScheduleGroups
  calls:
  - action: listScheduleGroups
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.ScheduleGroups }}'
    item:
      Arn: '{{ item.Arn }}'
      CreationDate: '{{ item.CreationDate }}'
      LastModificationDate: '{{ item.LastModificationDate }}'
      Name: '{{ item.Name }}'
      State: '{{ item.State }}'
- discovery_id: aws.scheduler.listSchedules
  calls:
  - action: listSchedules
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Schedules }}'
    item:
      Arn: '{{ item.Arn }}'
      CreationDate: '{{ item.CreationDate }}'
      GroupName: '{{ item.GroupName }}'
      LastModificationDate: '{{ item.LastModificationDate }}'
      Name: '{{ item.Name }}'
      State: '{{ item.State }}'
      Target: '{{ item.Target }}'
- discovery_id: aws.scheduler.getSchedule
  calls:
  - action: getSchedule
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.FlexibleTimeWindow }}'
    item:
      MaximumWindowInMinutes: '{{ item.MaximumWindowInMinutes }}'
      Mode: '{{ item.Mode }}'
- discovery_id: aws.scheduler.getScheduleGroup
  calls:
  - action: getScheduleGroup
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Arn }}'
- discovery_id: aws.scheduler.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Tags }}'
    item:
      Key: '{{ item.Key }}'
      Value: '{{ item.Value }}'
checks: []
