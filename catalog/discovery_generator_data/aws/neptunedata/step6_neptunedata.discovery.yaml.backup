version: '1.0'
provider: aws
service: neptunedata
services:
  client: neptunedata
  module: boto3.client
discovery:
- discovery_id: aws.neptunedata.getEngineStatus
  calls:
  - action: getEngineStatus
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.gremlin }}'
    item:
      version: '{{ item.version }}'
- discovery_id: aws.neptunedata.getPropertygraphStatistics
  calls:
  - action: getPropertygraphStatistics
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.payload }}'
    item:
      autoCompute: '{{ item.autoCompute }}'
      active: '{{ item.active }}'
      statisticsId: '{{ item.statisticsId }}'
      date: '{{ item.date }}'
      note: '{{ item.note }}'
      signatureInfo: '{{ item.signatureInfo }}'
- discovery_id: aws.neptunedata.getPropertygraphStream
  calls:
  - action: getPropertygraphStream
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.records }}'
    item:
      commitTimestampInMillis: '{{ item.commitTimestampInMillis }}'
      eventId: '{{ item.eventId }}'
      data: '{{ item.data }}'
      op: '{{ item.op }}'
      isLastOp: '{{ item.isLastOp }}'
- discovery_id: aws.neptunedata.getPropertygraphSummary
  calls:
  - action: getPropertygraphSummary
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.payload }}'
    item:
      version: '{{ item.version }}'
      lastStatisticsComputationTime: '{{ item.lastStatisticsComputationTime }}'
      graphSummary: '{{ item.graphSummary }}'
- discovery_id: aws.neptunedata.getRdfGraphSummary
  calls:
  - action: getRdfGraphSummary
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.payload }}'
    item:
      version: '{{ item.version }}'
      lastStatisticsComputationTime: '{{ item.lastStatisticsComputationTime }}'
      graphSummary: '{{ item.graphSummary }}'
- discovery_id: aws.neptunedata.getSparqlStatistics
  calls:
  - action: getSparqlStatistics
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.payload }}'
    item:
      autoCompute: '{{ item.autoCompute }}'
      active: '{{ item.active }}'
      statisticsId: '{{ item.statisticsId }}'
      date: '{{ item.date }}'
      note: '{{ item.note }}'
      signatureInfo: '{{ item.signatureInfo }}'
- discovery_id: aws.neptunedata.getSparqlStream
  calls:
  - action: getSparqlStream
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.records }}'
    item:
      commitTimestampInMillis: '{{ item.commitTimestampInMillis }}'
      eventId: '{{ item.eventId }}'
      data: '{{ item.data }}'
      op: '{{ item.op }}'
      isLastOp: '{{ item.isLastOp }}'
- discovery_id: aws.neptunedata.listGremlinQueries
  calls:
  - action: listGremlinQueries
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.queries }}'
    item:
      queryId: '{{ item.queryId }}'
      queryString: '{{ item.queryString }}'
      queryEvalStats: '{{ item.queryEvalStats }}'
- discovery_id: aws.neptunedata.listLoaderJobs
  calls:
  - action: listLoaderJobs
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.payload }}'
    item:
      loadIds: '{{ item.loadIds }}'
- discovery_id: aws.neptunedata.listMlDataProcessingJobs
  calls:
  - action: listMlDataProcessingJobs
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ids }}'
- discovery_id: aws.neptunedata.listMlEndpoints
  calls:
  - action: listMlEndpoints
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ids }}'
- discovery_id: aws.neptunedata.listMlModelTrainingJobs
  calls:
  - action: listMlModelTrainingJobs
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ids }}'
- discovery_id: aws.neptunedata.listMlModelTransformJobs
  calls:
  - action: listMlModelTransformJobs
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ids }}'
- discovery_id: aws.neptunedata.listOpenCypherQueries
  calls:
  - action: listOpenCypherQueries
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.queries }}'
    item:
      queryId: '{{ item.queryId }}'
      queryString: '{{ item.queryString }}'
      queryEvalStats: '{{ item.queryEvalStats }}'
- discovery_id: aws.neptunedata.getGremlinQueryStatus
  calls:
  - action: getGremlinQueryStatus
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.queryEvalStats }}'
    item:
      waited: '{{ item.waited }}'
      elapsed: '{{ item.elapsed }}'
      cancelled: '{{ item.cancelled }}'
      subqueries: '{{ item.subqueries }}'
- discovery_id: aws.neptunedata.getLoaderJobStatus
  calls:
  - action: getLoaderJobStatus
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.payload }}'
- discovery_id: aws.neptunedata.getMlDataProcessingJob
  calls:
  - action: getMlDataProcessingJob
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.processingJob }}'
    item:
      name: '{{ item.name }}'
      arn: '{{ item.arn }}'
      status: '{{ item.status }}'
      outputLocation: '{{ item.outputLocation }}'
      failureReason: '{{ item.failureReason }}'
      cloudwatchLogUrl: '{{ item.cloudwatchLogUrl }}'
- discovery_id: aws.neptunedata.getMlEndpoint
  calls:
  - action: getMlEndpoint
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.endpoint }}'
    item:
      name: '{{ item.name }}'
      arn: '{{ item.arn }}'
      status: '{{ item.status }}'
      outputLocation: '{{ item.outputLocation }}'
      failureReason: '{{ item.failureReason }}'
      cloudwatchLogUrl: '{{ item.cloudwatchLogUrl }}'
- discovery_id: aws.neptunedata.getMlModelTrainingJob
  calls:
  - action: getMlModelTrainingJob
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.mlModels }}'
    item:
      name: '{{ item.name }}'
      arn: '{{ item.arn }}'
- discovery_id: aws.neptunedata.getMlModelTransformJob
  calls:
  - action: getMlModelTransformJob
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.models }}'
    item:
      name: '{{ item.name }}'
      arn: '{{ item.arn }}'
- discovery_id: aws.neptunedata.getOpenCypherQueryStatus
  calls:
  - action: getOpenCypherQueryStatus
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.queryEvalStats }}'
    item:
      waited: '{{ item.waited }}'
      elapsed: '{{ item.elapsed }}'
      cancelled: '{{ item.cancelled }}'
      subqueries: '{{ item.subqueries }}'
checks: []
