version: '1.0'
provider: aws
service: chime-sdk-identity
services:
  client: chime-sdk-identity
  module: boto3.client
discovery:
- discovery_id: aws.chime-sdk-identity.listAppInstances
  calls:
  - action: listAppInstances
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.AppInstances }}'
    item:
      AppInstanceArn: '{{ item.AppInstanceArn }}'
      Name: '{{ item.Name }}'
      Metadata: '{{ item.Metadata }}'
- discovery_id: aws.chime-sdk-identity.describeAppInstance
  calls:
  - action: describeAppInstance
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AppInstance }}'
    item:
      AppInstanceArn: '{{ item.AppInstanceArn }}'
      Name: '{{ item.Name }}'
      CreatedTimestamp: '{{ item.CreatedTimestamp }}'
      LastUpdatedTimestamp: '{{ item.LastUpdatedTimestamp }}'
      Metadata: '{{ item.Metadata }}'
- discovery_id: aws.chime-sdk-identity.describeAppInstanceAdmin
  calls:
  - action: describeAppInstanceAdmin
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AppInstanceAdmin }}'
    item:
      Admin: '{{ item.Admin }}'
      AppInstanceArn: '{{ item.AppInstanceArn }}'
      CreatedTimestamp: '{{ item.CreatedTimestamp }}'
- discovery_id: aws.chime-sdk-identity.describeAppInstanceBot
  calls:
  - action: describeAppInstanceBot
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AppInstanceBot }}'
    item:
      AppInstanceBotArn: '{{ item.AppInstanceBotArn }}'
      Name: '{{ item.Name }}'
      Configuration: '{{ item.Configuration }}'
      CreatedTimestamp: '{{ item.CreatedTimestamp }}'
      LastUpdatedTimestamp: '{{ item.LastUpdatedTimestamp }}'
      Metadata: '{{ item.Metadata }}'
- discovery_id: aws.chime-sdk-identity.describeAppInstanceUser
  calls:
  - action: describeAppInstanceUser
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AppInstanceUser }}'
    item:
      AppInstanceUserArn: '{{ item.AppInstanceUserArn }}'
      Name: '{{ item.Name }}'
      Metadata: '{{ item.Metadata }}'
      CreatedTimestamp: '{{ item.CreatedTimestamp }}'
      LastUpdatedTimestamp: '{{ item.LastUpdatedTimestamp }}'
      ExpirationSettings: '{{ item.ExpirationSettings }}'
- discovery_id: aws.chime-sdk-identity.describeAppInstanceUserEndpoint
  calls:
  - action: describeAppInstanceUserEndpoint
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AppInstanceUserEndpoint }}'
    item:
      AppInstanceUserArn: '{{ item.AppInstanceUserArn }}'
      EndpointId: '{{ item.EndpointId }}'
      Name: '{{ item.Name }}'
      Type: '{{ item.Type }}'
      ResourceArn: '{{ item.ResourceArn }}'
      EndpointAttributes: '{{ item.EndpointAttributes }}'
      CreatedTimestamp: '{{ item.CreatedTimestamp }}'
      LastUpdatedTimestamp: '{{ item.LastUpdatedTimestamp }}'
      AllowMessages: '{{ item.AllowMessages }}'
      EndpointState: '{{ item.EndpointState }}'
- discovery_id: aws.chime-sdk-identity.getAppInstanceRetentionSettings
  calls:
  - action: getAppInstanceRetentionSettings
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AppInstanceRetentionSettings }}'
    item:
      ChannelRetentionSettings: '{{ item.ChannelRetentionSettings }}'
- discovery_id: aws.chime-sdk-identity.listAppInstanceAdmins
  calls:
  - action: listAppInstanceAdmins
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.AppInstanceAdmins }}'
    item:
      Admin: '{{ item.Admin }}'
- discovery_id: aws.chime-sdk-identity.listAppInstanceBots
  calls:
  - action: listAppInstanceBots
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.AppInstanceBots }}'
    item:
      AppInstanceBotArn: '{{ item.AppInstanceBotArn }}'
      Name: '{{ item.Name }}'
      Metadata: '{{ item.Metadata }}'
- discovery_id: aws.chime-sdk-identity.listAppInstanceUserEndpoints
  calls:
  - action: listAppInstanceUserEndpoints
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.AppInstanceUserEndpoints }}'
    item:
      AppInstanceUserArn: '{{ item.AppInstanceUserArn }}'
      EndpointId: '{{ item.EndpointId }}'
      Name: '{{ item.Name }}'
      Type: '{{ item.Type }}'
      AllowMessages: '{{ item.AllowMessages }}'
      EndpointState: '{{ item.EndpointState }}'
- discovery_id: aws.chime-sdk-identity.listAppInstanceUsers
  calls:
  - action: listAppInstanceUsers
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.AppInstanceUsers }}'
    item:
      AppInstanceUserArn: '{{ item.AppInstanceUserArn }}'
      Name: '{{ item.Name }}'
      Metadata: '{{ item.Metadata }}'
- discovery_id: aws.chime-sdk-identity.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Tags }}'
    item:
      Key: '{{ item.Key }}'
      Value: '{{ item.Value }}'
checks: []
