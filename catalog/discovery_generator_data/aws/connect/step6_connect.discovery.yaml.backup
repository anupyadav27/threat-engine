version: '1.0'
provider: aws
service: connect
services:
  client: connect
  module: boto3.client
discovery:
- discovery_id: aws.connect.listInstances
  calls:
  - action: listInstances
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.InstanceSummaryList }}'
    item:
      Id: '{{ item.Id }}'
      Arn: '{{ item.Arn }}'
      IdentityManagementType: '{{ item.IdentityManagementType }}'
      InstanceAlias: '{{ item.InstanceAlias }}'
      CreatedTime: '{{ item.CreatedTime }}'
      ServiceRole: '{{ item.ServiceRole }}'
      InstanceStatus: '{{ item.InstanceStatus }}'
      InboundCallsEnabled: '{{ item.InboundCallsEnabled }}'
      OutboundCallsEnabled: '{{ item.OutboundCallsEnabled }}'
      InstanceAccessUrl: '{{ item.InstanceAccessUrl }}'
- discovery_id: aws.connect.listPhoneNumbersV2
  calls:
  - action: listPhoneNumbersV2
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.ListPhoneNumbersSummaryList }}'
    item:
      PhoneNumberId: '{{ item.PhoneNumberId }}'
      PhoneNumberArn: '{{ item.PhoneNumberArn }}'
      PhoneNumber: '{{ item.PhoneNumber }}'
      PhoneNumberCountryCode: '{{ item.PhoneNumberCountryCode }}'
      PhoneNumberType: '{{ item.PhoneNumberType }}'
      TargetArn: '{{ item.TargetArn }}'
      InstanceId: '{{ item.InstanceId }}'
      PhoneNumberDescription: '{{ item.PhoneNumberDescription }}'
      SourcePhoneNumberArn: '{{ item.SourcePhoneNumberArn }}'
- discovery_id: aws.connect.listTrafficDistributionGroups
  calls:
  - action: listTrafficDistributionGroups
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.TrafficDistributionGroupSummaryList }}'
    item:
      Id: '{{ item.Id }}'
      Arn: '{{ item.Arn }}'
      Name: '{{ item.Name }}'
      InstanceArn: '{{ item.InstanceArn }}'
      Status: '{{ item.Status }}'
      IsDefault: '{{ item.IsDefault }}'
- discovery_id: aws.connect.describeAgentStatus
  calls:
  - action: describeAgentStatus
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AgentStatus }}'
    item:
      AgentStatusARN: '{{ item.AgentStatusARN }}'
      AgentStatusId: '{{ item.AgentStatusId }}'
      Name: '{{ item.Name }}'
      Description: '{{ item.Description }}'
      Type: '{{ item.Type }}'
      DisplayOrder: '{{ item.DisplayOrder }}'
      State: '{{ item.State }}'
      Tags: '{{ item.Tags }}'
      LastModifiedTime: '{{ item.LastModifiedTime }}'
      LastModifiedRegion: '{{ item.LastModifiedRegion }}'
- discovery_id: aws.connect.describeAuthenticationProfile
  calls:
  - action: describeAuthenticationProfile
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AuthenticationProfile }}'
    item:
      Id: '{{ item.Id }}'
      Arn: '{{ item.Arn }}'
      Name: '{{ item.Name }}'
      Description: '{{ item.Description }}'
      AllowedIps: '{{ item.AllowedIps }}'
      BlockedIps: '{{ item.BlockedIps }}'
      IsDefault: '{{ item.IsDefault }}'
      CreatedTime: '{{ item.CreatedTime }}'
      LastModifiedTime: '{{ item.LastModifiedTime }}'
      LastModifiedRegion: '{{ item.LastModifiedRegion }}'
      PeriodicSessionDuration: '{{ item.PeriodicSessionDuration }}'
      MaxSessionDuration: '{{ item.MaxSessionDuration }}'
      SessionInactivityDuration: '{{ item.SessionInactivityDuration }}'
      SessionInactivityHandlingEnabled: '{{ item.SessionInactivityHandlingEnabled
        }}'
- discovery_id: aws.connect.describeContact
  calls:
  - action: describeContact
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Contact }}'
    item:
      Arn: '{{ item.Arn }}'
      Id: '{{ item.Id }}'
      InitialContactId: '{{ item.InitialContactId }}'
      PreviousContactId: '{{ item.PreviousContactId }}'
      ContactAssociationId: '{{ item.ContactAssociationId }}'
      InitiationMethod: '{{ item.InitiationMethod }}'
      Name: '{{ item.Name }}'
      Description: '{{ item.Description }}'
      Channel: '{{ item.Channel }}'
      QueueInfo: '{{ item.QueueInfo }}'
      AgentInfo: '{{ item.AgentInfo }}'
      InitiationTimestamp: '{{ item.InitiationTimestamp }}'
      DisconnectTimestamp: '{{ item.DisconnectTimestamp }}'
      LastUpdateTimestamp: '{{ item.LastUpdateTimestamp }}'
      LastPausedTimestamp: '{{ item.LastPausedTimestamp }}'
      LastResumedTimestamp: '{{ item.LastResumedTimestamp }}'
      RingStartTimestamp: '{{ item.RingStartTimestamp }}'
      TotalPauseCount: '{{ item.TotalPauseCount }}'
      TotalPauseDurationInSeconds: '{{ item.TotalPauseDurationInSeconds }}'
      ScheduledTimestamp: '{{ item.ScheduledTimestamp }}'
      RelatedContactId: '{{ item.RelatedContactId }}'
      WisdomInfo: '{{ item.WisdomInfo }}'
      CustomerId: '{{ item.CustomerId }}'
      CustomerEndpoint: '{{ item.CustomerEndpoint }}'
      SystemEndpoint: '{{ item.SystemEndpoint }}'
      QueueTimeAdjustmentSeconds: '{{ item.QueueTimeAdjustmentSeconds }}'
      QueuePriority: '{{ item.QueuePriority }}'
      Tags: '{{ item.Tags }}'
      ConnectedToSystemTimestamp: '{{ item.ConnectedToSystemTimestamp }}'
      RoutingCriteria: '{{ item.RoutingCriteria }}'
      Customer: '{{ item.Customer }}'
      Campaign: '{{ item.Campaign }}'
      AnsweringMachineDetectionStatus: '{{ item.AnsweringMachineDetectionStatus }}'
      CustomerVoiceActivity: '{{ item.CustomerVoiceActivity }}'
      QualityMetrics: '{{ item.QualityMetrics }}'
      ChatMetrics: '{{ item.ChatMetrics }}'
      DisconnectDetails: '{{ item.DisconnectDetails }}'
      AdditionalEmailRecipients: '{{ item.AdditionalEmailRecipients }}'
      SegmentAttributes: '{{ item.SegmentAttributes }}'
      Recordings: '{{ item.Recordings }}'
      DisconnectReason: '{{ item.DisconnectReason }}'
      ContactEvaluations: '{{ item.ContactEvaluations }}'
      TaskTemplateInfo: '{{ item.TaskTemplateInfo }}'
      ContactDetails: '{{ item.ContactDetails }}'
      OutboundStrategy: '{{ item.OutboundStrategy }}'
      Attributes: '{{ item.Attributes }}'
- discovery_id: aws.connect.describeContactEvaluation
  calls:
  - action: describeContactEvaluation
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Evaluation }}'
    item:
      EvaluationId: '{{ item.EvaluationId }}'
      EvaluationArn: '{{ item.EvaluationArn }}'
      Metadata: '{{ item.Metadata }}'
      Answers: '{{ item.Answers }}'
      Notes: '{{ item.Notes }}'
      Status: '{{ item.Status }}'
      Scores: '{{ item.Scores }}'
      CreatedTime: '{{ item.CreatedTime }}'
      LastModifiedTime: '{{ item.LastModifiedTime }}'
      EvaluationType: '{{ item.EvaluationType }}'
      Tags: '{{ item.Tags }}'
- discovery_id: aws.connect.describeContactFlow
  calls:
  - action: describeContactFlow
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ContactFlow }}'
    item:
      Arn: '{{ item.Arn }}'
      Id: '{{ item.Id }}'
      Name: '{{ item.Name }}'
      Type: '{{ item.Type }}'
      State: '{{ item.State }}'
      Status: '{{ item.Status }}'
      Description: '{{ item.Description }}'
      Content: '{{ item.Content }}'
      Tags: '{{ item.Tags }}'
      FlowContentSha256: '{{ item.FlowContentSha256 }}'
      Version: '{{ item.Version }}'
      VersionDescription: '{{ item.VersionDescription }}'
      LastModifiedTime: '{{ item.LastModifiedTime }}'
      LastModifiedRegion: '{{ item.LastModifiedRegion }}'
- discovery_id: aws.connect.describeContactFlowModule
  calls:
  - action: describeContactFlowModule
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ContactFlowModule }}'
    item:
      Arn: '{{ item.Arn }}'
      Id: '{{ item.Id }}'
      Name: '{{ item.Name }}'
      Content: '{{ item.Content }}'
      Description: '{{ item.Description }}'
      State: '{{ item.State }}'
      Status: '{{ item.Status }}'
      Tags: '{{ item.Tags }}'
      FlowModuleContentSha256: '{{ item.FlowModuleContentSha256 }}'
      Version: '{{ item.Version }}'
      VersionDescription: '{{ item.VersionDescription }}'
      Settings: '{{ item.Settings }}'
      ExternalInvocationConfiguration: '{{ item.ExternalInvocationConfiguration }}'
- discovery_id: aws.connect.describeContactFlowModuleAlias
  calls:
  - action: describeContactFlowModuleAlias
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ContactFlowModuleAlias }}'
    item:
