version: '1.0'
provider: aws
service: partnercentral-selling
services:
  client: partnercentral-selling
  module: boto3.client
discovery:
- discovery_id: aws.partnercentral-selling.getAwsOpportunitySummary
  calls:
  - action: getAwsOpportunitySummary
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.OpportunityTeam }}'
    item:
      Email: '{{ item.Email }}'
      FirstName: '{{ item.FirstName }}'
      LastName: '{{ item.LastName }}'
      BusinessTitle: '{{ item.BusinessTitle }}'
- discovery_id: aws.partnercentral-selling.getEngagement
  calls:
  - action: getEngagement
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Contexts }}'
    item:
      Type: '{{ item.Type }}'
      Payload: '{{ item.Payload }}'
- discovery_id: aws.partnercentral-selling.getEngagementInvitation
  calls:
  - action: getEngagementInvitation
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ExistingMembers }}'
    item:
      CompanyName: '{{ item.CompanyName }}'
      WebsiteUrl: '{{ item.WebsiteUrl }}'
- discovery_id: aws.partnercentral-selling.getOpportunity
  calls:
  - action: getOpportunity
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.PrimaryNeedsFromAws }}'
- discovery_id: aws.partnercentral-selling.getResourceSnapshot
  calls:
  - action: getResourceSnapshot
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Payload }}'
    item:
      OpportunitySummary: '{{ item.OpportunitySummary }}'
- discovery_id: aws.partnercentral-selling.getResourceSnapshotJob
  calls:
  - action: getResourceSnapshotJob
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Catalog }}'
- discovery_id: aws.partnercentral-selling.getSellingSystemSettings
  calls:
  - action: getSellingSystemSettings
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Catalog }}'
- discovery_id: aws.partnercentral-selling.listEngagementByAcceptingInvitationTasks
  calls:
  - action: listEngagementByAcceptingInvitationTasks
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.TaskSummaries }}'
    item:
      TaskId: '{{ item.TaskId }}'
      TaskArn: '{{ item.TaskArn }}'
      StartTime: '{{ item.StartTime }}'
      TaskStatus: '{{ item.TaskStatus }}'
      Message: '{{ item.Message }}'
      ReasonCode: '{{ item.ReasonCode }}'
      OpportunityId: '{{ item.OpportunityId }}'
      ResourceSnapshotJobId: '{{ item.ResourceSnapshotJobId }}'
      EngagementInvitationId: '{{ item.EngagementInvitationId }}'
- discovery_id: aws.partnercentral-selling.listEngagementFromOpportunityTasks
  calls:
  - action: listEngagementFromOpportunityTasks
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.TaskSummaries }}'
    item:
      TaskId: '{{ item.TaskId }}'
      TaskArn: '{{ item.TaskArn }}'
      StartTime: '{{ item.StartTime }}'
      TaskStatus: '{{ item.TaskStatus }}'
      Message: '{{ item.Message }}'
      ReasonCode: '{{ item.ReasonCode }}'
      OpportunityId: '{{ item.OpportunityId }}'
      ResourceSnapshotJobId: '{{ item.ResourceSnapshotJobId }}'
      EngagementId: '{{ item.EngagementId }}'
      EngagementInvitationId: '{{ item.EngagementInvitationId }}'
- discovery_id: aws.partnercentral-selling.listEngagementInvitations
  calls:
  - action: listEngagementInvitations
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.EngagementInvitationSummaries }}'
    item:
      Arn: '{{ item.Arn }}'
      PayloadType: '{{ item.PayloadType }}'
      Id: '{{ item.Id }}'
      EngagementId: '{{ item.EngagementId }}'
      EngagementTitle: '{{ item.EngagementTitle }}'
      Status: '{{ item.Status }}'
      InvitationDate: '{{ item.InvitationDate }}'
      ExpirationDate: '{{ item.ExpirationDate }}'
      SenderAwsAccountId: '{{ item.SenderAwsAccountId }}'
      SenderCompanyName: '{{ item.SenderCompanyName }}'
      Receiver: '{{ item.Receiver }}'
      Catalog: '{{ item.Catalog }}'
      ParticipantType: '{{ item.ParticipantType }}'
- discovery_id: aws.partnercentral-selling.listEngagementMembers
  calls:
  - action: listEngagementMembers
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.EngagementMemberList }}'
    item:
      CompanyName: '{{ item.CompanyName }}'
      WebsiteUrl: '{{ item.WebsiteUrl }}'
      AccountId: '{{ item.AccountId }}'
- discovery_id: aws.partnercentral-selling.listEngagementResourceAssociations
  calls:
  - action: listEngagementResourceAssociations
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.EngagementResourceAssociationSummaries }}'
    item:
      Catalog: '{{ item.Catalog }}'
      EngagementId: '{{ item.EngagementId }}'
      ResourceType: '{{ item.ResourceType }}'
      ResourceId: '{{ item.ResourceId }}'
      CreatedBy: '{{ item.CreatedBy }}'
- discovery_id: aws.partnercentral-selling.listEngagements
  calls:
  - action: listEngagements
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.EngagementSummaryList }}'
    item:
      Arn: '{{ item.Arn }}'
      Id: '{{ item.Id }}'
      Title: '{{ item.Title }}'
      CreatedAt: '{{ item.CreatedAt }}'
      CreatedBy: '{{ item.CreatedBy }}'
      MemberCount: '{{ item.MemberCount }}'
- discovery_id: aws.partnercentral-selling.listOpportunities
  calls:
  - action: listOpportunities
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.OpportunitySummaries }}'
    item:
      Catalog: '{{ item.Catalog }}'
      Id: '{{ item.Id }}'
      Arn: '{{ item.Arn }}'
      PartnerOpportunityIdentifier: '{{ item.PartnerOpportunityIdentifier }}'
      OpportunityType: '{{ item.OpportunityType }}'
      LastModifiedDate: '{{ item.LastModifiedDate }}'
      CreatedDate: '{{ item.CreatedDate }}'
      LifeCycle: '{{ item.LifeCycle }}'
      Customer: '{{ item.Customer }}'
      Project: '{{ item.Project }}'
- discovery_id: aws.partnercentral-selling.listResourceSnapshotJobs
  calls:
  - action: listResourceSnapshotJobs
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.ResourceSnapshotJobSummaries }}'
    item:
      Id: '{{ item.Id }}'
      Arn: '{{ item.Arn }}'
      EngagementId: '{{ item.EngagementId }}'
      Status: '{{ item.Status }}'
- discovery_id: aws.partnercentral-selling.listResourceSnapshots
  calls:
  - action: listResourceSnapshots
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.ResourceSnapshotSummaries }}'
    item:
      Arn: '{{ item.Arn }}'
      Revision: '{{ item.Revision }}'
      ResourceType: '{{ item.ResourceType }}'
      ResourceId: '{{ item.ResourceId }}'
      ResourceSnapshotTemplateName: '{{ item.ResourceSnapshotTemplateName }}'
      CreatedBy: '{{ item.CreatedBy }}'
- discovery_id: aws.partnercentral-selling.listSolutions
  calls:
  - action: listSolutions
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.SolutionSummaries }}'
    item:
      Catalog: '{{ item.Catalog }}'
      Id: '{{ item.Id }}'
      Arn: '{{ item.Arn }}'
      Name: '{{ item.Name }}'
      Status: '{{ item.Status }}'
      Category: '{{ item.Category }}'
      CreatedDate: '{{ item.CreatedDate }}'
- discovery_id: aws.partnercentral-selling.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Tags }}'
    item:
      Key: '{{ item.Key }}'
      Value: '{{ item.Value }}'
checks: []
