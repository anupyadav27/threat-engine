version: '1.0'
provider: aws
service: observabilityadmin
services:
  client: observabilityadmin
  module: boto3.client
discovery:
- discovery_id: aws.observabilityadmin.getTelemetryEnrichmentStatus
  calls:
  - action: getTelemetryEnrichmentStatus
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Status }}'
- discovery_id: aws.observabilityadmin.getTelemetryEvaluationStatus
  calls:
  - action: getTelemetryEvaluationStatus
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Status }}'
- discovery_id: aws.observabilityadmin.getTelemetryEvaluationStatusForOrganization
  calls:
  - action: getTelemetryEvaluationStatusForOrganization
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Status }}'
- discovery_id: aws.observabilityadmin.listCentralizationRulesForOrganization
  calls:
  - action: listCentralizationRulesForOrganization
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.CentralizationRuleSummaries }}'
    item:
      RuleName: '{{ item.RuleName }}'
      RuleArn: '{{ item.RuleArn }}'
      CreatorAccountId: '{{ item.CreatorAccountId }}'
      CreatedTimeStamp: '{{ item.CreatedTimeStamp }}'
      CreatedRegion: '{{ item.CreatedRegion }}'
      LastUpdateTimeStamp: '{{ item.LastUpdateTimeStamp }}'
      RuleHealth: '{{ item.RuleHealth }}'
      FailureReason: '{{ item.FailureReason }}'
      DestinationAccountId: '{{ item.DestinationAccountId }}'
      DestinationRegion: '{{ item.DestinationRegion }}'
- discovery_id: aws.observabilityadmin.listResourceTelemetry
  calls:
  - action: listResourceTelemetry
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.TelemetryConfigurations }}'
    item:
      AccountIdentifier: '{{ item.AccountIdentifier }}'
      TelemetryConfigurationState: '{{ item.TelemetryConfigurationState }}'
      ResourceType: '{{ item.ResourceType }}'
      ResourceIdentifier: '{{ item.ResourceIdentifier }}'
      ResourceTags: '{{ item.ResourceTags }}'
      LastUpdateTimeStamp: '{{ item.LastUpdateTimeStamp }}'
- discovery_id: aws.observabilityadmin.listResourceTelemetryForOrganization
  calls:
  - action: listResourceTelemetryForOrganization
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.TelemetryConfigurations }}'
    item:
      AccountIdentifier: '{{ item.AccountIdentifier }}'
      TelemetryConfigurationState: '{{ item.TelemetryConfigurationState }}'
      ResourceType: '{{ item.ResourceType }}'
      ResourceIdentifier: '{{ item.ResourceIdentifier }}'
      ResourceTags: '{{ item.ResourceTags }}'
      LastUpdateTimeStamp: '{{ item.LastUpdateTimeStamp }}'
- discovery_id: aws.observabilityadmin.listTelemetryRules
  calls:
  - action: listTelemetryRules
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.TelemetryRuleSummaries }}'
    item:
      RuleName: '{{ item.RuleName }}'
      RuleArn: '{{ item.RuleArn }}'
      CreatedTimeStamp: '{{ item.CreatedTimeStamp }}'
      LastUpdateTimeStamp: '{{ item.LastUpdateTimeStamp }}'
      ResourceType: '{{ item.ResourceType }}'
      TelemetryType: '{{ item.TelemetryType }}'
- discovery_id: aws.observabilityadmin.listTelemetryRulesForOrganization
  calls:
  - action: listTelemetryRulesForOrganization
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.TelemetryRuleSummaries }}'
    item:
      RuleName: '{{ item.RuleName }}'
      RuleArn: '{{ item.RuleArn }}'
      CreatedTimeStamp: '{{ item.CreatedTimeStamp }}'
      LastUpdateTimeStamp: '{{ item.LastUpdateTimeStamp }}'
      ResourceType: '{{ item.ResourceType }}'
      TelemetryType: '{{ item.TelemetryType }}'
- discovery_id: aws.observabilityadmin.getCentralizationRuleForOrganization
  calls:
  - action: getCentralizationRuleForOrganization
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.CentralizationRule }}'
    item:
      Source: '{{ item.Source }}'
      Destination: '{{ item.Destination }}'
- discovery_id: aws.observabilityadmin.getTelemetryRule
  calls:
  - action: getTelemetryRule
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.TelemetryRule }}'
    item:
      ResourceType: '{{ item.ResourceType }}'
      TelemetryType: '{{ item.TelemetryType }}'
      DestinationConfiguration: '{{ item.DestinationConfiguration }}'
      Scope: '{{ item.Scope }}'
      SelectionCriteria: '{{ item.SelectionCriteria }}'
- discovery_id: aws.observabilityadmin.getTelemetryRuleForOrganization
  calls:
  - action: getTelemetryRuleForOrganization
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.TelemetryRule }}'
    item:
      ResourceType: '{{ item.ResourceType }}'
      TelemetryType: '{{ item.TelemetryType }}'
      DestinationConfiguration: '{{ item.DestinationConfiguration }}'
      Scope: '{{ item.Scope }}'
      SelectionCriteria: '{{ item.SelectionCriteria }}'
- discovery_id: aws.observabilityadmin.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Tags }}'
checks: []
