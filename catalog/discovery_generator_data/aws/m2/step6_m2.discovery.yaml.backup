version: '1.0'
provider: aws
service: m2
services:
  client: m2
  module: boto3.client
discovery:
- discovery_id: aws.m2.getSignedBluinsightsUrl
  calls:
  - action: getSignedBluinsightsUrl
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.signedBiUrl }}'
- discovery_id: aws.m2.listApplications
  calls:
  - action: listApplications
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.applications }}'
    item:
      applicationArn: '{{ item.applicationArn }}'
      applicationId: '{{ item.applicationId }}'
      applicationVersion: '{{ item.applicationVersion }}'
      creationTime: '{{ item.creationTime }}'
      deploymentStatus: '{{ item.deploymentStatus }}'
      description: '{{ item.description }}'
      engineType: '{{ item.engineType }}'
      environmentId: '{{ item.environmentId }}'
      lastStartTime: '{{ item.lastStartTime }}'
      name: '{{ item.name }}'
      roleArn: '{{ item.roleArn }}'
      status: '{{ item.status }}'
      versionStatus: '{{ item.versionStatus }}'
- discovery_id: aws.m2.listEngineVersions
  calls:
  - action: listEngineVersions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.engineVersions }}'
    item:
      engineType: '{{ item.engineType }}'
      engineVersion: '{{ item.engineVersion }}'
- discovery_id: aws.m2.listEnvironments
  calls:
  - action: listEnvironments
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.environments }}'
    item:
      creationTime: '{{ item.creationTime }}'
      engineType: '{{ item.engineType }}'
      engineVersion: '{{ item.engineVersion }}'
      environmentArn: '{{ item.environmentArn }}'
      environmentId: '{{ item.environmentId }}'
      instanceType: '{{ item.instanceType }}'
      name: '{{ item.name }}'
      networkType: '{{ item.networkType }}'
      status: '{{ item.status }}'
- discovery_id: aws.m2.getApplication
  calls:
  - action: getApplication
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.listenerArns }}'
- discovery_id: aws.m2.getApplicationVersion
  calls:
  - action: getApplicationVersion
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.applicationVersion }}'
- discovery_id: aws.m2.getBatchJobExecution
  calls:
  - action: getBatchJobExecution
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.batchJobIdentifier }}'
    item:
      fileBatchJobIdentifier: '{{ item.fileBatchJobIdentifier }}'
      restartBatchJobIdentifier: '{{ item.restartBatchJobIdentifier }}'
      s3BatchJobIdentifier: '{{ item.s3BatchJobIdentifier }}'
      scriptBatchJobIdentifier: '{{ item.scriptBatchJobIdentifier }}'
- discovery_id: aws.m2.getDataSetDetails
  calls:
  - action: getDataSetDetails
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.dataSetOrg }}'
    item:
      gdg: '{{ item.gdg }}'
      po: '{{ item.po }}'
      ps: '{{ item.ps }}'
      vsam: '{{ item.vsam }}'
- discovery_id: aws.m2.getDataSetExportTask
  calls:
  - action: getDataSetExportTask
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.summary }}'
    item:
      failed: '{{ item.failed }}'
      inProgress: '{{ item.inProgress }}'
      pending: '{{ item.pending }}'
      succeeded: '{{ item.succeeded }}'
      total: '{{ item.total }}'
- discovery_id: aws.m2.getDataSetImportTask
  calls:
  - action: getDataSetImportTask
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.summary }}'
    item:
      failed: '{{ item.failed }}'
      inProgress: '{{ item.inProgress }}'
      pending: '{{ item.pending }}'
      succeeded: '{{ item.succeeded }}'
      total: '{{ item.total }}'
- discovery_id: aws.m2.getDeployment
  calls:
  - action: getDeployment
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.applicationId }}'
- discovery_id: aws.m2.getEnvironment
  calls:
  - action: getEnvironment
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.securityGroupIds }}'
- discovery_id: aws.m2.listApplicationVersions
  calls:
  - action: listApplicationVersions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.applicationVersions }}'
    item:
      applicationVersion: '{{ item.applicationVersion }}'
      creationTime: '{{ item.creationTime }}'
      status: '{{ item.status }}'
      statusReason: '{{ item.statusReason }}'
- discovery_id: aws.m2.listBatchJobDefinitions
  calls:
  - action: listBatchJobDefinitions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.batchJobDefinitions }}'
    item:
      fileBatchJobDefinition: '{{ item.fileBatchJobDefinition }}'
      scriptBatchJobDefinition: '{{ item.scriptBatchJobDefinition }}'
- discovery_id: aws.m2.listBatchJobExecutions
  calls:
  - action: listBatchJobExecutions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.batchJobExecutions }}'
    item:
      applicationId: '{{ item.applicationId }}'
      batchJobIdentifier: '{{ item.batchJobIdentifier }}'
      endTime: '{{ item.endTime }}'
      executionId: '{{ item.executionId }}'
      jobId: '{{ item.jobId }}'
      jobName: '{{ item.jobName }}'
      jobType: '{{ item.jobType }}'
      returnCode: '{{ item.returnCode }}'
      startTime: '{{ item.startTime }}'
      status: '{{ item.status }}'
- discovery_id: aws.m2.listBatchJobRestartPoints
  calls:
  - action: listBatchJobRestartPoints
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.batchJobSteps }}'
    item:
      procStepName: '{{ item.procStepName }}'
      procStepNumber: '{{ item.procStepNumber }}'
      stepCheckpoint: '{{ item.stepCheckpoint }}'
      stepCheckpointStatus: '{{ item.stepCheckpointStatus }}'
      stepCheckpointTime: '{{ item.stepCheckpointTime }}'
      stepCondCode: '{{ item.stepCondCode }}'
      stepName: '{{ item.stepName }}'
      stepNumber: '{{ item.stepNumber }}'
      stepRestartable: '{{ item.stepRestartable }}'
- discovery_id: aws.m2.listDataSetExportHistory
  calls:
  - action: listDataSetExportHistory
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.dataSetExportTasks }}'
    item:
      status: '{{ item.status }}'
      statusReason: '{{ item.statusReason }}'
      summary: '{{ item.summary }}'
      taskId: '{{ item.taskId }}'
- discovery_id: aws.m2.listDataSetImportHistory
  calls:
  - action: listDataSetImportHistory
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.dataSetImportTasks }}'
    item:
      status: '{{ item.status }}'
      statusReason: '{{ item.statusReason }}'
      summary: '{{ item.summary }}'
      taskId: '{{ item.taskId }}'
- discovery_id: aws.m2.listDataSets
  calls:
  - action: listDataSets
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.dataSets }}'
    item:
      creationTime: '{{ item.creationTime }}'
      dataSetName: '{{ item.dataSetName }}'
      dataSetOrg: '{{ item.dataSetOrg }}'
      format: '{{ item.format }}'
      lastReferencedTime: '{{ item.lastReferencedTime }}'
      lastUpdatedTime: '{{ item.lastUpdatedTime }}'
- discovery_id: aws.m2.listDeployments
  calls:
  - action: listDeployments
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.deployments }}'
    item:
      applicationId: '{{ item.applicationId }}'
      applicationVersion: '{{ item.applicationVersion }}'
      creationTime: '{{ item.creationTime }}'
      deploymentId: '{{ item.deploymentId }}'
      environmentId: '{{ item.environmentId }}'
      status: '{{ item.status }}'
      statusReason: '{{ item.statusReason }}'
- discovery_id: aws.m2.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tags }}'
checks: []
