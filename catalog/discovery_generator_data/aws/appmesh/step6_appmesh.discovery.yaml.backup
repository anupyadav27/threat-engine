version: '1.0'
provider: aws
service: appmesh
services:
  client: appmesh
  module: boto3.client
discovery:
- discovery_id: aws.appmesh.listMeshes
  calls:
  - action: listMeshes
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.meshes }}'
    item:
      arn: '{{ item.arn }}'
      createdAt: '{{ item.createdAt }}'
      lastUpdatedAt: '{{ item.lastUpdatedAt }}'
      meshName: '{{ item.meshName }}'
      meshOwner: '{{ item.meshOwner }}'
      resourceOwner: '{{ item.resourceOwner }}'
      version: '{{ item.version }}'
- discovery_id: aws.appmesh.describeGatewayRoute
  calls:
  - action: describeGatewayRoute
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.gatewayRoute }}'
    item:
      gatewayRouteName: '{{ item.gatewayRouteName }}'
      meshName: '{{ item.meshName }}'
      metadata: '{{ item.metadata }}'
      spec: '{{ item.spec }}'
      status: '{{ item.status }}'
      virtualGatewayName: '{{ item.virtualGatewayName }}'
- discovery_id: aws.appmesh.describeMesh
  calls:
  - action: describeMesh
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.mesh }}'
    item:
      meshName: '{{ item.meshName }}'
      metadata: '{{ item.metadata }}'
      spec: '{{ item.spec }}'
      status: '{{ item.status }}'
- discovery_id: aws.appmesh.describeRoute
  calls:
  - action: describeRoute
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.route }}'
    item:
      meshName: '{{ item.meshName }}'
      metadata: '{{ item.metadata }}'
      routeName: '{{ item.routeName }}'
      spec: '{{ item.spec }}'
      status: '{{ item.status }}'
      virtualRouterName: '{{ item.virtualRouterName }}'
- discovery_id: aws.appmesh.describeVirtualGateway
  calls:
  - action: describeVirtualGateway
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.virtualGateway }}'
    item:
      meshName: '{{ item.meshName }}'
      metadata: '{{ item.metadata }}'
      spec: '{{ item.spec }}'
      status: '{{ item.status }}'
      virtualGatewayName: '{{ item.virtualGatewayName }}'
- discovery_id: aws.appmesh.describeVirtualNode
  calls:
  - action: describeVirtualNode
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.virtualNode }}'
    item:
      meshName: '{{ item.meshName }}'
      metadata: '{{ item.metadata }}'
      spec: '{{ item.spec }}'
      status: '{{ item.status }}'
      virtualNodeName: '{{ item.virtualNodeName }}'
- discovery_id: aws.appmesh.describeVirtualRouter
  calls:
  - action: describeVirtualRouter
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.virtualRouter }}'
    item:
      meshName: '{{ item.meshName }}'
      metadata: '{{ item.metadata }}'
      spec: '{{ item.spec }}'
      status: '{{ item.status }}'
      virtualRouterName: '{{ item.virtualRouterName }}'
- discovery_id: aws.appmesh.describeVirtualService
  calls:
  - action: describeVirtualService
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.virtualService }}'
    item:
      meshName: '{{ item.meshName }}'
      metadata: '{{ item.metadata }}'
      spec: '{{ item.spec }}'
      status: '{{ item.status }}'
      virtualServiceName: '{{ item.virtualServiceName }}'
- discovery_id: aws.appmesh.listGatewayRoutes
  calls:
  - action: listGatewayRoutes
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.gatewayRoutes }}'
    item:
      arn: '{{ item.arn }}'
      createdAt: '{{ item.createdAt }}'
      gatewayRouteName: '{{ item.gatewayRouteName }}'
      lastUpdatedAt: '{{ item.lastUpdatedAt }}'
      meshName: '{{ item.meshName }}'
      meshOwner: '{{ item.meshOwner }}'
      resourceOwner: '{{ item.resourceOwner }}'
      version: '{{ item.version }}'
      virtualGatewayName: '{{ item.virtualGatewayName }}'
- discovery_id: aws.appmesh.listRoutes
  calls:
  - action: listRoutes
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.routes }}'
    item:
      arn: '{{ item.arn }}'
      createdAt: '{{ item.createdAt }}'
      lastUpdatedAt: '{{ item.lastUpdatedAt }}'
      meshName: '{{ item.meshName }}'
      meshOwner: '{{ item.meshOwner }}'
      resourceOwner: '{{ item.resourceOwner }}'
      routeName: '{{ item.routeName }}'
      version: '{{ item.version }}'
      virtualRouterName: '{{ item.virtualRouterName }}'
- discovery_id: aws.appmesh.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tags }}'
    item:
      key: '{{ item.key }}'
      value: '{{ item.value }}'
- discovery_id: aws.appmesh.listVirtualGateways
  calls:
  - action: listVirtualGateways
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.virtualGateways }}'
    item:
      arn: '{{ item.arn }}'
      createdAt: '{{ item.createdAt }}'
      lastUpdatedAt: '{{ item.lastUpdatedAt }}'
      meshName: '{{ item.meshName }}'
      meshOwner: '{{ item.meshOwner }}'
      resourceOwner: '{{ item.resourceOwner }}'
      version: '{{ item.version }}'
      virtualGatewayName: '{{ item.virtualGatewayName }}'
- discovery_id: aws.appmesh.listVirtualNodes
  calls:
  - action: listVirtualNodes
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.virtualNodes }}'
    item:
      arn: '{{ item.arn }}'
      createdAt: '{{ item.createdAt }}'
      lastUpdatedAt: '{{ item.lastUpdatedAt }}'
      meshName: '{{ item.meshName }}'
      meshOwner: '{{ item.meshOwner }}'
      resourceOwner: '{{ item.resourceOwner }}'
      version: '{{ item.version }}'
      virtualNodeName: '{{ item.virtualNodeName }}'
- discovery_id: aws.appmesh.listVirtualRouters
  calls:
  - action: listVirtualRouters
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.virtualRouters }}'
    item:
      arn: '{{ item.arn }}'
      createdAt: '{{ item.createdAt }}'
      lastUpdatedAt: '{{ item.lastUpdatedAt }}'
      meshName: '{{ item.meshName }}'
      meshOwner: '{{ item.meshOwner }}'
      resourceOwner: '{{ item.resourceOwner }}'
      version: '{{ item.version }}'
      virtualRouterName: '{{ item.virtualRouterName }}'
- discovery_id: aws.appmesh.listVirtualServices
  calls:
  - action: listVirtualServices
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.virtualServices }}'
    item:
      arn: '{{ item.arn }}'
      createdAt: '{{ item.createdAt }}'
      lastUpdatedAt: '{{ item.lastUpdatedAt }}'
      meshName: '{{ item.meshName }}'
      meshOwner: '{{ item.meshOwner }}'
      resourceOwner: '{{ item.resourceOwner }}'
      version: '{{ item.version }}'
      virtualServiceName: '{{ item.virtualServiceName }}'
checks: []
