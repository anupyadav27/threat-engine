version: '1.0'
provider: aws
service: sagemaker-edge
services:
  client: sagemaker-edge
  module: boto3.client
discovery:
- discovery_id: aws.sagemaker-edge.getDeployments
  calls:
  - action: getDeployments
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Deployments }}'
    item:
      DeploymentName: '{{ item.DeploymentName }}'
      Type: '{{ item.Type }}'
      FailureHandlingPolicy: '{{ item.FailureHandlingPolicy }}'
      Definitions: '{{ item.Definitions }}'
- discovery_id: aws.sagemaker-edge.getDeviceRegistration
  calls:
  - action: getDeviceRegistration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.DeviceRegistration }}'
checks: []
