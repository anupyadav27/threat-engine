version: '1.0'
provider: aws
service: connectparticipant
services:
  client: connectparticipant
  module: boto3.client
discovery:
- discovery_id: aws.connectparticipant.describeView
  calls:
  - action: describeView
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.View }}'
    item:
      Id: '{{ item.Id }}'
      Arn: '{{ item.Arn }}'
      Name: '{{ item.Name }}'
      Version: '{{ item.Version }}'
      Content: '{{ item.Content }}'
- discovery_id: aws.connectparticipant.getAttachment
  calls:
  - action: getAttachment
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Url }}'
- discovery_id: aws.connectparticipant.getAuthenticationUrl
  calls:
  - action: getAuthenticationUrl
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AuthenticationUrl }}'
- discovery_id: aws.connectparticipant.getTranscript
  calls:
  - action: getTranscript
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Transcript }}'
    item:
      AbsoluteTime: '{{ item.AbsoluteTime }}'
      Content: '{{ item.Content }}'
      ContentType: '{{ item.ContentType }}'
      Id: '{{ item.Id }}'
      Type: '{{ item.Type }}'
      ParticipantId: '{{ item.ParticipantId }}'
      DisplayName: '{{ item.DisplayName }}'
      ParticipantRole: '{{ item.ParticipantRole }}'
      Attachments: '{{ item.Attachments }}'
      MessageMetadata: '{{ item.MessageMetadata }}'
      RelatedContactId: '{{ item.RelatedContactId }}'
      ContactId: '{{ item.ContactId }}'
checks: []
