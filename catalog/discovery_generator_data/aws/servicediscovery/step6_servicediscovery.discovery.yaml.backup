version: '1.0'
provider: aws
service: servicediscovery
services:
  client: servicediscovery
  module: boto3.client
discovery:
- discovery_id: aws.servicediscovery.listNamespaces
  calls:
  - action: listNamespaces
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Namespaces }}'
    item:
      Id: '{{ item.Id }}'
      Arn: '{{ item.Arn }}'
      ResourceOwner: '{{ item.ResourceOwner }}'
      Name: '{{ item.Name }}'
      Type: '{{ item.Type }}'
      Description: '{{ item.Description }}'
      ServiceCount: '{{ item.ServiceCount }}'
      Properties: '{{ item.Properties }}'
      CreateDate: '{{ item.CreateDate }}'
- discovery_id: aws.servicediscovery.listOperations
  calls:
  - action: listOperations
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Operations }}'
    item:
      Id: '{{ item.Id }}'
      Status: '{{ item.Status }}'
- discovery_id: aws.servicediscovery.listServices
  calls:
  - action: listServices
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Services }}'
    item:
      Id: '{{ item.Id }}'
      Arn: '{{ item.Arn }}'
      ResourceOwner: '{{ item.ResourceOwner }}'
      Name: '{{ item.Name }}'
      Type: '{{ item.Type }}'
      Description: '{{ item.Description }}'
      InstanceCount: '{{ item.InstanceCount }}'
      DnsConfig: '{{ item.DnsConfig }}'
      HealthCheckConfig: '{{ item.HealthCheckConfig }}'
      HealthCheckCustomConfig: '{{ item.HealthCheckCustomConfig }}'
      CreateDate: '{{ item.CreateDate }}'
      CreatedByAccount: '{{ item.CreatedByAccount }}'
- discovery_id: aws.servicediscovery.getInstance
  calls:
  - action: getInstance
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Instance }}'
    item:
      Id: '{{ item.Id }}'
      CreatorRequestId: '{{ item.CreatorRequestId }}'
      Attributes: '{{ item.Attributes }}'
      CreatedByAccount: '{{ item.CreatedByAccount }}'
- discovery_id: aws.servicediscovery.getInstancesHealthStatus
  calls:
  - action: getInstancesHealthStatus
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Status }}'
- discovery_id: aws.servicediscovery.getNamespace
  calls:
  - action: getNamespace
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Namespace }}'
    item:
      Id: '{{ item.Id }}'
      Arn: '{{ item.Arn }}'
      ResourceOwner: '{{ item.ResourceOwner }}'
      Name: '{{ item.Name }}'
      Type: '{{ item.Type }}'
      Description: '{{ item.Description }}'
      ServiceCount: '{{ item.ServiceCount }}'
      Properties: '{{ item.Properties }}'
      CreateDate: '{{ item.CreateDate }}'
      CreatorRequestId: '{{ item.CreatorRequestId }}'
- discovery_id: aws.servicediscovery.getOperation
  calls:
  - action: getOperation
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Operation }}'
    item:
      Id: '{{ item.Id }}'
      OwnerAccount: '{{ item.OwnerAccount }}'
      Type: '{{ item.Type }}'
      Status: '{{ item.Status }}'
      ErrorMessage: '{{ item.ErrorMessage }}'
      ErrorCode: '{{ item.ErrorCode }}'
      CreateDate: '{{ item.CreateDate }}'
      UpdateDate: '{{ item.UpdateDate }}'
      Targets: '{{ item.Targets }}'
- discovery_id: aws.servicediscovery.getService
  calls:
  - action: getService
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Service }}'
    item:
      Id: '{{ item.Id }}'
      Arn: '{{ item.Arn }}'
      ResourceOwner: '{{ item.ResourceOwner }}'
      Name: '{{ item.Name }}'
      NamespaceId: '{{ item.NamespaceId }}'
      Description: '{{ item.Description }}'
      InstanceCount: '{{ item.InstanceCount }}'
      DnsConfig: '{{ item.DnsConfig }}'
      Type: '{{ item.Type }}'
      HealthCheckConfig: '{{ item.HealthCheckConfig }}'
      HealthCheckCustomConfig: '{{ item.HealthCheckCustomConfig }}'
      CreateDate: '{{ item.CreateDate }}'
      CreatorRequestId: '{{ item.CreatorRequestId }}'
      CreatedByAccount: '{{ item.CreatedByAccount }}'
- discovery_id: aws.servicediscovery.getServiceAttributes
  calls:
  - action: getServiceAttributes
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ServiceAttributes }}'
    item:
      ServiceArn: '{{ item.ServiceArn }}'
      ResourceOwner: '{{ item.ResourceOwner }}'
      Attributes: '{{ item.Attributes }}'
- discovery_id: aws.servicediscovery.listInstances
  calls:
  - action: listInstances
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Instances }}'
    item:
      Id: '{{ item.Id }}'
      Attributes: '{{ item.Attributes }}'
      CreatedByAccount: '{{ item.CreatedByAccount }}'
- discovery_id: aws.servicediscovery.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Tags }}'
    item:
      Key: '{{ item.Key }}'
      Value: '{{ item.Value }}'
checks: []
