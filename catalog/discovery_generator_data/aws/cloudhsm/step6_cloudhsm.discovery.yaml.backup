version: '1.0'
provider: aws
service: cloudhsm
services:
  client: cloudhsm
  module: boto3.client
discovery:
- discovery_id: aws.cloudhsm.describeHsm
  calls:
  - action: describeHsm
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Partitions }}'
- discovery_id: aws.cloudhsm.describeLunaClient
  calls:
  - action: describeLunaClient
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ClientArn }}'
- discovery_id: aws.cloudhsm.listAvailableZones
  calls:
  - action: listAvailableZones
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AZList }}'
- discovery_id: aws.cloudhsm.listHapgs
  calls:
  - action: listHapgs
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.HapgList }}'
- discovery_id: aws.cloudhsm.listHsms
  calls:
  - action: listHsms
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.HsmList }}'
- discovery_id: aws.cloudhsm.listLunaClients
  calls:
  - action: listLunaClients
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ClientList }}'
- discovery_id: aws.cloudhsm.describeHapg
  calls:
  - action: describeHapg
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.PartitionSerialList }}'
- discovery_id: aws.cloudhsm.getConfig
  calls:
  - action: getConfig
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ConfigType }}'
- discovery_id: aws.cloudhsm.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.TagList }}'
    item:
      Key: '{{ item.Key }}'
      Value: '{{ item.Value }}'
checks: []
