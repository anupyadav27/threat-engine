version: '1.0'
provider: aws
service: managedblockchain
services:
  client: managedblockchain
  module: boto3.client
discovery:
- discovery_id: aws.managedblockchain.listAccessors
  calls:
  - action: listAccessors
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Accessors }}'
    item:
      Id: '{{ item.Id }}'
      Type: '{{ item.Type }}'
      Status: '{{ item.Status }}'
      CreationDate: '{{ item.CreationDate }}'
      Arn: '{{ item.Arn }}'
      NetworkType: '{{ item.NetworkType }}'
- discovery_id: aws.managedblockchain.listInvitations
  calls:
  - action: listInvitations
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Invitations }}'
    item:
      InvitationId: '{{ item.InvitationId }}'
      CreationDate: '{{ item.CreationDate }}'
      ExpirationDate: '{{ item.ExpirationDate }}'
      Status: '{{ item.Status }}'
      NetworkSummary: '{{ item.NetworkSummary }}'
      Arn: '{{ item.Arn }}'
- discovery_id: aws.managedblockchain.listNetworks
  calls:
  - action: listNetworks
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Networks }}'
    item:
      Id: '{{ item.Id }}'
      Name: '{{ item.Name }}'
      Description: '{{ item.Description }}'
      Framework: '{{ item.Framework }}'
      FrameworkVersion: '{{ item.FrameworkVersion }}'
      Status: '{{ item.Status }}'
      CreationDate: '{{ item.CreationDate }}'
      Arn: '{{ item.Arn }}'
- discovery_id: aws.managedblockchain.getAccessor
  calls:
  - action: getAccessor
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Accessor }}'
    item:
      Id: '{{ item.Id }}'
      Type: '{{ item.Type }}'
      BillingToken: '{{ item.BillingToken }}'
      Status: '{{ item.Status }}'
      CreationDate: '{{ item.CreationDate }}'
      Arn: '{{ item.Arn }}'
      Tags: '{{ item.Tags }}'
      NetworkType: '{{ item.NetworkType }}'
- discovery_id: aws.managedblockchain.getMember
  calls:
  - action: getMember
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Member }}'
    item:
      NetworkId: '{{ item.NetworkId }}'
      Id: '{{ item.Id }}'
      Name: '{{ item.Name }}'
      Description: '{{ item.Description }}'
      FrameworkAttributes: '{{ item.FrameworkAttributes }}'
      LogPublishingConfiguration: '{{ item.LogPublishingConfiguration }}'
      Status: '{{ item.Status }}'
      CreationDate: '{{ item.CreationDate }}'
      Tags: '{{ item.Tags }}'
      Arn: '{{ item.Arn }}'
      KmsKeyArn: '{{ item.KmsKeyArn }}'
- discovery_id: aws.managedblockchain.getNetwork
  calls:
  - action: getNetwork
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Network }}'
    item:
      Id: '{{ item.Id }}'
      Name: '{{ item.Name }}'
      Description: '{{ item.Description }}'
      Framework: '{{ item.Framework }}'
      FrameworkVersion: '{{ item.FrameworkVersion }}'
      FrameworkAttributes: '{{ item.FrameworkAttributes }}'
      VpcEndpointServiceName: '{{ item.VpcEndpointServiceName }}'
      VotingPolicy: '{{ item.VotingPolicy }}'
      Status: '{{ item.Status }}'
      CreationDate: '{{ item.CreationDate }}'
      Tags: '{{ item.Tags }}'
      Arn: '{{ item.Arn }}'
- discovery_id: aws.managedblockchain.getNode
  calls:
  - action: getNode
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Node }}'
    item:
      NetworkId: '{{ item.NetworkId }}'
      MemberId: '{{ item.MemberId }}'
      Id: '{{ item.Id }}'
      InstanceType: '{{ item.InstanceType }}'
      AvailabilityZone: '{{ item.AvailabilityZone }}'
      FrameworkAttributes: '{{ item.FrameworkAttributes }}'
      LogPublishingConfiguration: '{{ item.LogPublishingConfiguration }}'
      StateDB: '{{ item.StateDB }}'
      Status: '{{ item.Status }}'
      CreationDate: '{{ item.CreationDate }}'
      Tags: '{{ item.Tags }}'
      Arn: '{{ item.Arn }}'
      KmsKeyArn: '{{ item.KmsKeyArn }}'
- discovery_id: aws.managedblockchain.getProposal
  calls:
  - action: getProposal
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Proposal }}'
    item:
      ProposalId: '{{ item.ProposalId }}'
      NetworkId: '{{ item.NetworkId }}'
      Description: '{{ item.Description }}'
      Actions: '{{ item.Actions }}'
      ProposedByMemberId: '{{ item.ProposedByMemberId }}'
      ProposedByMemberName: '{{ item.ProposedByMemberName }}'
      Status: '{{ item.Status }}'
      CreationDate: '{{ item.CreationDate }}'
      ExpirationDate: '{{ item.ExpirationDate }}'
      YesVoteCount: '{{ item.YesVoteCount }}'
      NoVoteCount: '{{ item.NoVoteCount }}'
      OutstandingVoteCount: '{{ item.OutstandingVoteCount }}'
      Tags: '{{ item.Tags }}'
      Arn: '{{ item.Arn }}'
- discovery_id: aws.managedblockchain.listMembers
  calls:
  - action: listMembers
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Members }}'
    item:
      Id: '{{ item.Id }}'
      Name: '{{ item.Name }}'
      Description: '{{ item.Description }}'
      Status: '{{ item.Status }}'
      CreationDate: '{{ item.CreationDate }}'
      IsOwned: '{{ item.IsOwned }}'
      Arn: '{{ item.Arn }}'
- discovery_id: aws.managedblockchain.listNodes
  calls:
  - action: listNodes
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Nodes }}'
    item:
      Id: '{{ item.Id }}'
      Status: '{{ item.Status }}'
      CreationDate: '{{ item.CreationDate }}'
      AvailabilityZone: '{{ item.AvailabilityZone }}'
      InstanceType: '{{ item.InstanceType }}'
      Arn: '{{ item.Arn }}'
- discovery_id: aws.managedblockchain.listProposalVotes
  calls:
  - action: listProposalVotes
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.ProposalVotes }}'
    item:
      Vote: '{{ item.Vote }}'
      MemberName: '{{ item.MemberName }}'
      MemberId: '{{ item.MemberId }}'
- discovery_id: aws.managedblockchain.listProposals
  calls:
  - action: listProposals
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Proposals }}'
    item:
      ProposalId: '{{ item.ProposalId }}'
      Description: '{{ item.Description }}'
      ProposedByMemberId: '{{ item.ProposedByMemberId }}'
      ProposedByMemberName: '{{ item.ProposedByMemberName }}'
      Status: '{{ item.Status }}'
      CreationDate: '{{ item.CreationDate }}'
      ExpirationDate: '{{ item.ExpirationDate }}'
      Arn: '{{ item.Arn }}'
- discovery_id: aws.managedblockchain.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Tags }}'
checks: []
