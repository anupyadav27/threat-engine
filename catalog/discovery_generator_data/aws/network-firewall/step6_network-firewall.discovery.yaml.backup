version: '1.0'
provider: aws
service: network-firewall
services:
  client: network-firewall
  module: boto3.client
discovery:
- discovery_id: aws.network-firewall.describeFirewall
  calls:
  - action: describeFirewall
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Firewall }}'
    item:
      FirewallName: '{{ item.FirewallName }}'
      FirewallArn: '{{ item.FirewallArn }}'
      FirewallPolicyArn: '{{ item.FirewallPolicyArn }}'
      VpcId: '{{ item.VpcId }}'
      SubnetMappings: '{{ item.SubnetMappings }}'
      DeleteProtection: '{{ item.DeleteProtection }}'
      SubnetChangeProtection: '{{ item.SubnetChangeProtection }}'
      FirewallPolicyChangeProtection: '{{ item.FirewallPolicyChangeProtection }}'
      Description: '{{ item.Description }}'
      FirewallId: '{{ item.FirewallId }}'
      Tags: '{{ item.Tags }}'
      EncryptionConfiguration: '{{ item.EncryptionConfiguration }}'
      NumberOfAssociations: '{{ item.NumberOfAssociations }}'
      EnabledAnalysisTypes: '{{ item.EnabledAnalysisTypes }}'
      TransitGatewayId: '{{ item.TransitGatewayId }}'
      TransitGatewayOwnerAccountId: '{{ item.TransitGatewayOwnerAccountId }}'
      AvailabilityZoneMappings: '{{ item.AvailabilityZoneMappings }}'
      AvailabilityZoneChangeProtection: '{{ item.AvailabilityZoneChangeProtection
        }}'
- discovery_id: aws.network-firewall.describeFirewallMetadata
  calls:
  - action: describeFirewallMetadata
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.FirewallArn }}'
- discovery_id: aws.network-firewall.describeFirewallPolicy
  calls:
  - action: describeFirewallPolicy
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.FirewallPolicyResponse }}'
    item:
      FirewallPolicyName: '{{ item.FirewallPolicyName }}'
      FirewallPolicyArn: '{{ item.FirewallPolicyArn }}'
      FirewallPolicyId: '{{ item.FirewallPolicyId }}'
      Description: '{{ item.Description }}'
      FirewallPolicyStatus: '{{ item.FirewallPolicyStatus }}'
      Tags: '{{ item.Tags }}'
      ConsumedStatelessRuleCapacity: '{{ item.ConsumedStatelessRuleCapacity }}'
      ConsumedStatefulRuleCapacity: '{{ item.ConsumedStatefulRuleCapacity }}'
      NumberOfAssociations: '{{ item.NumberOfAssociations }}'
      EncryptionConfiguration: '{{ item.EncryptionConfiguration }}'
      LastModifiedTime: '{{ item.LastModifiedTime }}'
- discovery_id: aws.network-firewall.describeLoggingConfiguration
  calls:
  - action: describeLoggingConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.LoggingConfiguration }}'
    item:
      LogDestinationConfigs: '{{ item.LogDestinationConfigs }}'
- discovery_id: aws.network-firewall.describeProxy
  calls:
  - action: describeProxy
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Proxy }}'
    item:
      ProxyName: '{{ item.ProxyName }}'
      ProxyArn: '{{ item.ProxyArn }}'
      ProxyConfigurationName: '{{ item.ProxyConfigurationName }}'
      ProxyConfigurationArn: '{{ item.ProxyConfigurationArn }}'
      NatGatewayId: '{{ item.NatGatewayId }}'
      ProxyState: '{{ item.ProxyState }}'
      ProxyModifyState: '{{ item.ProxyModifyState }}'
      ListenerProperties: '{{ item.ListenerProperties }}'
      TlsInterceptProperties: '{{ item.TlsInterceptProperties }}'
      VpcEndpointServiceName: '{{ item.VpcEndpointServiceName }}'
      PrivateDNSName: '{{ item.PrivateDNSName }}'
      CreateTime: '{{ item.CreateTime }}'
      DeleteTime: '{{ item.DeleteTime }}'
      UpdateTime: '{{ item.UpdateTime }}'
      FailureCode: '{{ item.FailureCode }}'
      FailureMessage: '{{ item.FailureMessage }}'
      Tags: '{{ item.Tags }}'
- discovery_id: aws.network-firewall.describeProxyConfiguration
  calls:
  - action: describeProxyConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ProxyConfiguration }}'
    item:
      ProxyConfigurationName: '{{ item.ProxyConfigurationName }}'
      ProxyConfigurationArn: '{{ item.ProxyConfigurationArn }}'
      Description: '{{ item.Description }}'
      CreateTime: '{{ item.CreateTime }}'
      DeleteTime: '{{ item.DeleteTime }}'
      RuleGroups: '{{ item.RuleGroups }}'
      DefaultRulePhaseActions: '{{ item.DefaultRulePhaseActions }}'
      Tags: '{{ item.Tags }}'
- discovery_id: aws.network-firewall.describeProxyRuleGroup
  calls:
  - action: describeProxyRuleGroup
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ProxyRuleGroup }}'
    item:
      ProxyRuleGroupName: '{{ item.ProxyRuleGroupName }}'
      ProxyRuleGroupArn: '{{ item.ProxyRuleGroupArn }}'
      CreateTime: '{{ item.CreateTime }}'
      DeleteTime: '{{ item.DeleteTime }}'
      Rules: '{{ item.Rules }}'
      Description: '{{ item.Description }}'
      Tags: '{{ item.Tags }}'
- discovery_id: aws.network-firewall.describeRuleGroup
  calls:
  - action: describeRuleGroup
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.RuleGroup }}'
    item:
      RuleVariables: '{{ item.RuleVariables }}'
      ReferenceSets: '{{ item.ReferenceSets }}'
      RulesSource: '{{ item.RulesSource }}'
      StatefulRuleOptions: '{{ item.StatefulRuleOptions }}'
- discovery_id: aws.network-firewall.describeRuleGroupMetadata
  calls:
  - action: describeRuleGroupMetadata
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.StatefulRuleOptions }}'
    item:
      RuleOrder: '{{ item.RuleOrder }}'
- discovery_id: aws.network-firewall.describeRuleGroupSummary
  calls:
  - action: describeRuleGroupSummary
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Summary }}'
    item:
      RuleSummaries: '{{ item.RuleSummaries }}'
- discovery_id: aws.network-firewall.describeTlsInspectionConfiguration
  calls:
  - action: describeTlsInspectionConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.TLSInspectionConfiguration }}'
    item:
      ServerCertificateConfigurations: '{{ item.ServerCertificateConfigurations }}'
- discovery_id: aws.network-firewall.listAnalysisReports
  calls:
  - action: listAnalysisReports
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.AnalysisReports }}'
    item:
      AnalysisReportId: '{{ item.AnalysisReportId }}'
      AnalysisType: '{{ item.AnalysisType }}'
      ReportTime: '{{ item.ReportTime }}'
      Status: '{{ item.Status }}'
- discovery_id: aws.network-firewall.listFirewallPolicies
  calls:
  - action: listFirewallPolicies
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.FirewallPolicies }}'
    item:
      Name: '{{ item.Name }}'
      Arn: '{{ item.Arn }}'
- discovery_id: aws.network-firewall.listFirewalls
  calls:
  - action: listFirewalls
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Firewalls }}'
    item:
      FirewallName: '{{ item.FirewallName }}'
      FirewallArn: '{{ item.FirewallArn }}'
      TransitGatewayAttachmentId: '{{ item.TransitGatewayAttachmentId }}'
- discovery_id: aws.network-firewall.listProxies
  calls:
  - action: listProxies
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Proxies }}'
    item:
      Name: '{{ item.Name }}'
      Arn: '{{ item.Arn }}'
- discovery_id: aws.network-firewall.listProxyConfigurations
  calls:
  - action: listProxyConfigurations
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.ProxyConfigurations }}'
    item:
      Name: '{{ item.Name }}'
      Arn: '{{ item.Arn }}'
- discovery_id: aws.network-firewall.listProxyRuleGroups
  calls:
  - action: listProxyRuleGroups
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.ProxyRuleGroups }}'
    item:
      Name: '{{ item.Name }}'
      Arn: '{{ item.Arn }}'
- discovery_id: aws.network-firewall.listRuleGroups
  calls:
  - action: listRuleGroups
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.RuleGroups }}'
    item:
      Name: '{{ item.Name }}'
      Arn: '{{ item.Arn }}'
      VendorName: '{{ item.VendorName }}'
- discovery_id: aws.network-firewall.listTlsInspectionConfigurations
  calls:
  - action: listTlsInspectionConfigurations
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.TLSInspectionConfigurations }}'
    item:
      Name: '{{ item.Name }}'
      Arn: '{{ item.Arn }}'
- discovery_id: aws.network-firewall.listVpcEndpointAssociations
  calls:
  - action: listVpcEndpointAssociations
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.VpcEndpointAssociations }}'
    item:
      VpcEndpointAssociationArn: '{{ item.VpcEndpointAssociationArn }}'
- discovery_id: aws.network-firewall.describeFlowOperation
  calls:
  - action: describeFlowOperation
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.FlowOperation }}'
    item:
      MinimumFlowAgeInSeconds: '{{ item.MinimumFlowAgeInSeconds }}'
      FlowFilters: '{{ item.FlowFilters }}'
- discovery_id: aws.network-firewall.describeProxyRule
  calls:
  - action: describeProxyRule
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ProxyRule }}'
    item:
      ProxyRuleName: '{{ item.ProxyRuleName }}'
      Description: '{{ item.Description }}'
      Action: '{{ item.Action }}'
      Conditions: '{{ item.Conditions }}'
- discovery_id: aws.network-firewall.describeResourcePolicy
  calls:
  - action: describeResourcePolicy
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Policy }}'
- discovery_id: aws.network-firewall.describeVpcEndpointAssociation
  calls:
  - action: describeVpcEndpointAssociation
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.VpcEndpointAssociation }}'
    item:
      VpcEndpointAssociationId: '{{ item.VpcEndpointAssociationId }}'
      VpcEndpointAssociationArn: '{{ item.VpcEndpointAssociationArn }}'
      FirewallArn: '{{ item.FirewallArn }}'
      VpcId: '{{ item.VpcId }}'
      SubnetMapping: '{{ item.SubnetMapping }}'
      Description: '{{ item.Description }}'
      Tags: '{{ item.Tags }}'
- discovery_id: aws.network-firewall.getAnalysisReportResults
  calls:
  - action: getAnalysisReportResults
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AnalysisReportResults }}'
    item:
      Protocol: '{{ item.Protocol }}'
      FirstAccessed: '{{ item.FirstAccessed }}'
      LastAccessed: '{{ item.LastAccessed }}'
      Domain: '{{ item.Domain }}'
      Hits: '{{ item.Hits }}'
      UniqueSources: '{{ item.UniqueSources }}'
- discovery_id: aws.network-firewall.listFlowOperationResults
  calls:
  - action: listFlowOperationResults
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Flows }}'
    item:
      SourceAddress: '{{ item.SourceAddress }}'
      DestinationAddress: '{{ item.DestinationAddress }}'
      SourcePort: '{{ item.SourcePort }}'
      DestinationPort: '{{ item.DestinationPort }}'
      Protocol: '{{ item.Protocol }}'
      Age: '{{ item.Age }}'
      PacketCount: '{{ item.PacketCount }}'
      ByteCount: '{{ item.ByteCount }}'
- discovery_id: aws.network-firewall.listFlowOperations
  calls:
  - action: listFlowOperations
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.FlowOperations }}'
    item:
      FlowOperationId: '{{ item.FlowOperationId }}'
      FlowOperationType: '{{ item.FlowOperationType }}'
      FlowRequestTimestamp: '{{ item.FlowRequestTimestamp }}'
      FlowOperationStatus: '{{ item.FlowOperationStatus }}'
- discovery_id: aws.network-firewall.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Tags }}'
    item:
      Key: '{{ item.Key }}'
      Value: '{{ item.Value }}'
checks: []
