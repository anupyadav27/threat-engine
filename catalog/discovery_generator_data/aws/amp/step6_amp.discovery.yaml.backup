version: '1.0'
provider: aws
service: amp
services:
  client: amp
  module: boto3.client
discovery:
- discovery_id: aws.amp.getDefaultScraperConfiguration
  calls:
  - action: getDefaultScraperConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.configuration }}'
- discovery_id: aws.amp.listScrapers
  calls:
  - action: listScrapers
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.scrapers }}'
    item:
      alias: '{{ item.alias }}'
      scraperId: '{{ item.scraperId }}'
      arn: '{{ item.arn }}'
      roleArn: '{{ item.roleArn }}'
      status: '{{ item.status }}'
      createdAt: '{{ item.createdAt }}'
      lastModifiedAt: '{{ item.lastModifiedAt }}'
      tags: '{{ item.tags }}'
      statusReason: '{{ item.statusReason }}'
      source: '{{ item.source }}'
      destination: '{{ item.destination }}'
      roleConfiguration: '{{ item.roleConfiguration }}'
- discovery_id: aws.amp.listWorkspaces
  calls:
  - action: listWorkspaces
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.workspaces }}'
    item:
      workspaceId: '{{ item.workspaceId }}'
      alias: '{{ item.alias }}'
      arn: '{{ item.arn }}'
      status: '{{ item.status }}'
      createdAt: '{{ item.createdAt }}'
      tags: '{{ item.tags }}'
      kmsKeyArn: '{{ item.kmsKeyArn }}'
- discovery_id: aws.amp.describeAlertManagerDefinition
  calls:
  - action: describeAlertManagerDefinition
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.alertManagerDefinition }}'
    item:
      status: '{{ item.status }}'
      data: '{{ item.data }}'
      createdAt: '{{ item.createdAt }}'
      modifiedAt: '{{ item.modifiedAt }}'
- discovery_id: aws.amp.describeAnomalyDetector
  calls:
  - action: describeAnomalyDetector
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.anomalyDetector }}'
    item:
      arn: '{{ item.arn }}'
      anomalyDetectorId: '{{ item.anomalyDetectorId }}'
      alias: '{{ item.alias }}'
      evaluationIntervalInSeconds: '{{ item.evaluationIntervalInSeconds }}'
      missingDataAction: '{{ item.missingDataAction }}'
      configuration: '{{ item.configuration }}'
      labels: '{{ item.labels }}'
      status: '{{ item.status }}'
      createdAt: '{{ item.createdAt }}'
      modifiedAt: '{{ item.modifiedAt }}'
      tags: '{{ item.tags }}'
- discovery_id: aws.amp.describeLoggingConfiguration
  calls:
  - action: describeLoggingConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.loggingConfiguration }}'
    item:
      status: '{{ item.status }}'
      workspace: '{{ item.workspace }}'
      logGroupArn: '{{ item.logGroupArn }}'
      createdAt: '{{ item.createdAt }}'
      modifiedAt: '{{ item.modifiedAt }}'
- discovery_id: aws.amp.describeQueryLoggingConfiguration
  calls:
  - action: describeQueryLoggingConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.queryLoggingConfiguration }}'
    item:
      status: '{{ item.status }}'
      workspace: '{{ item.workspace }}'
      destinations: '{{ item.destinations }}'
      createdAt: '{{ item.createdAt }}'
      modifiedAt: '{{ item.modifiedAt }}'
- discovery_id: aws.amp.describeResourcePolicy
  calls:
  - action: describeResourcePolicy
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.policyDocument }}'
- discovery_id: aws.amp.describeRuleGroupsNamespace
  calls:
  - action: describeRuleGroupsNamespace
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ruleGroupsNamespace }}'
    item:
      arn: '{{ item.arn }}'
      name: '{{ item.name }}'
      status: '{{ item.status }}'
      data: '{{ item.data }}'
      createdAt: '{{ item.createdAt }}'
      modifiedAt: '{{ item.modifiedAt }}'
      tags: '{{ item.tags }}'
- discovery_id: aws.amp.describeScraper
  calls:
  - action: describeScraper
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.scraper }}'
    item:
      alias: '{{ item.alias }}'
      scraperId: '{{ item.scraperId }}'
      arn: '{{ item.arn }}'
      roleArn: '{{ item.roleArn }}'
      status: '{{ item.status }}'
      createdAt: '{{ item.createdAt }}'
      lastModifiedAt: '{{ item.lastModifiedAt }}'
      tags: '{{ item.tags }}'
      statusReason: '{{ item.statusReason }}'
      scrapeConfiguration: '{{ item.scrapeConfiguration }}'
      source: '{{ item.source }}'
      destination: '{{ item.destination }}'
      roleConfiguration: '{{ item.roleConfiguration }}'
- discovery_id: aws.amp.describeScraperLoggingConfiguration
  calls:
  - action: describeScraperLoggingConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.scraperComponents }}'
    item:
      type: '{{ item.type }}'
      config: '{{ item.config }}'
- discovery_id: aws.amp.describeWorkspace
  calls:
  - action: describeWorkspace
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.workspace }}'
    item:
      workspaceId: '{{ item.workspaceId }}'
      alias: '{{ item.alias }}'
      arn: '{{ item.arn }}'
      status: '{{ item.status }}'
      prometheusEndpoint: '{{ item.prometheusEndpoint }}'
      createdAt: '{{ item.createdAt }}'
      tags: '{{ item.tags }}'
      kmsKeyArn: '{{ item.kmsKeyArn }}'
- discovery_id: aws.amp.describeWorkspaceConfiguration
  calls:
  - action: describeWorkspaceConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.workspaceConfiguration }}'
    item:
      status: '{{ item.status }}'
      limitsPerLabelSet: '{{ item.limitsPerLabelSet }}'
      retentionPeriodInDays: '{{ item.retentionPeriodInDays }}'
- discovery_id: aws.amp.listAnomalyDetectors
  calls:
  - action: listAnomalyDetectors
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.anomalyDetectors }}'
    item:
      arn: '{{ item.arn }}'
      anomalyDetectorId: '{{ item.anomalyDetectorId }}'
      alias: '{{ item.alias }}'
      status: '{{ item.status }}'
      createdAt: '{{ item.createdAt }}'
      modifiedAt: '{{ item.modifiedAt }}'
      tags: '{{ item.tags }}'
- discovery_id: aws.amp.listRuleGroupsNamespaces
  calls:
  - action: listRuleGroupsNamespaces
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ruleGroupsNamespaces }}'
    item:
      arn: '{{ item.arn }}'
      name: '{{ item.name }}'
      status: '{{ item.status }}'
      createdAt: '{{ item.createdAt }}'
      modifiedAt: '{{ item.modifiedAt }}'
      tags: '{{ item.tags }}'
- discovery_id: aws.amp.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tags }}'
checks: []
