version: '1.0'
provider: aws
service: machinelearning
services:
  client: machinelearning
  module: boto3.client
discovery:
- discovery_id: aws.machinelearning.describeBatchPredictions
  calls:
  - action: describeBatchPredictions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Results }}'
    item:
      BatchPredictionId: '{{ item.BatchPredictionId }}'
      MLModelId: '{{ item.MLModelId }}'
      BatchPredictionDataSourceId: '{{ item.BatchPredictionDataSourceId }}'
      InputDataLocationS3: '{{ item.InputDataLocationS3 }}'
      CreatedByIamUser: '{{ item.CreatedByIamUser }}'
      CreatedAt: '{{ item.CreatedAt }}'
      LastUpdatedAt: '{{ item.LastUpdatedAt }}'
      Name: '{{ item.Name }}'
      Status: '{{ item.Status }}'
      OutputUri: '{{ item.OutputUri }}'
      Message: '{{ item.Message }}'
      ComputeTime: '{{ item.ComputeTime }}'
      FinishedAt: '{{ item.FinishedAt }}'
      StartedAt: '{{ item.StartedAt }}'
      TotalRecordCount: '{{ item.TotalRecordCount }}'
      InvalidRecordCount: '{{ item.InvalidRecordCount }}'
- discovery_id: aws.machinelearning.describeDataSources
  calls:
  - action: describeDataSources
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Results }}'
    item:
      DataSourceId: '{{ item.DataSourceId }}'
      DataLocationS3: '{{ item.DataLocationS3 }}'
      DataRearrangement: '{{ item.DataRearrangement }}'
      CreatedByIamUser: '{{ item.CreatedByIamUser }}'
      CreatedAt: '{{ item.CreatedAt }}'
      LastUpdatedAt: '{{ item.LastUpdatedAt }}'
      DataSizeInBytes: '{{ item.DataSizeInBytes }}'
      NumberOfFiles: '{{ item.NumberOfFiles }}'
      Name: '{{ item.Name }}'
      Status: '{{ item.Status }}'
      Message: '{{ item.Message }}'
      RedshiftMetadata: '{{ item.RedshiftMetadata }}'
      RDSMetadata: '{{ item.RDSMetadata }}'
      RoleARN: '{{ item.RoleARN }}'
      ComputeStatistics: '{{ item.ComputeStatistics }}'
      ComputeTime: '{{ item.ComputeTime }}'
      FinishedAt: '{{ item.FinishedAt }}'
      StartedAt: '{{ item.StartedAt }}'
- discovery_id: aws.machinelearning.describeEvaluations
  calls:
  - action: describeEvaluations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Results }}'
    item:
      EvaluationId: '{{ item.EvaluationId }}'
      MLModelId: '{{ item.MLModelId }}'
      EvaluationDataSourceId: '{{ item.EvaluationDataSourceId }}'
      InputDataLocationS3: '{{ item.InputDataLocationS3 }}'
      CreatedByIamUser: '{{ item.CreatedByIamUser }}'
      CreatedAt: '{{ item.CreatedAt }}'
      LastUpdatedAt: '{{ item.LastUpdatedAt }}'
      Name: '{{ item.Name }}'
      Status: '{{ item.Status }}'
      PerformanceMetrics: '{{ item.PerformanceMetrics }}'
      Message: '{{ item.Message }}'
      ComputeTime: '{{ item.ComputeTime }}'
      FinishedAt: '{{ item.FinishedAt }}'
      StartedAt: '{{ item.StartedAt }}'
- discovery_id: aws.machinelearning.describeMlModels
  calls:
  - action: describeMlModels
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Results }}'
    item:
      MLModelId: '{{ item.MLModelId }}'
      TrainingDataSourceId: '{{ item.TrainingDataSourceId }}'
      CreatedByIamUser: '{{ item.CreatedByIamUser }}'
      CreatedAt: '{{ item.CreatedAt }}'
      LastUpdatedAt: '{{ item.LastUpdatedAt }}'
      Name: '{{ item.Name }}'
      Status: '{{ item.Status }}'
      SizeInBytes: '{{ item.SizeInBytes }}'
      EndpointInfo: '{{ item.EndpointInfo }}'
      TrainingParameters: '{{ item.TrainingParameters }}'
      InputDataLocationS3: '{{ item.InputDataLocationS3 }}'
      Algorithm: '{{ item.Algorithm }}'
      MLModelType: '{{ item.MLModelType }}'
      ScoreThreshold: '{{ item.ScoreThreshold }}'
      ScoreThresholdLastUpdatedAt: '{{ item.ScoreThresholdLastUpdatedAt }}'
      Message: '{{ item.Message }}'
      ComputeTime: '{{ item.ComputeTime }}'
      FinishedAt: '{{ item.FinishedAt }}'
      StartedAt: '{{ item.StartedAt }}'
- discovery_id: aws.machinelearning.describeTags
  calls:
  - action: describeTags
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Tags }}'
    item:
      Key: '{{ item.Key }}'
      Value: '{{ item.Value }}'
- discovery_id: aws.machinelearning.getBatchPrediction
  calls:
  - action: getBatchPrediction
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.BatchPredictionId }}'
- discovery_id: aws.machinelearning.getDataSource
  calls:
  - action: getDataSource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.RedshiftMetadata }}'
    item:
      RedshiftDatabase: '{{ item.RedshiftDatabase }}'
      DatabaseUserName: '{{ item.DatabaseUserName }}'
      SelectSqlQuery: '{{ item.SelectSqlQuery }}'
- discovery_id: aws.machinelearning.getEvaluation
  calls:
  - action: getEvaluation
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.PerformanceMetrics }}'
    item:
      Properties: '{{ item.Properties }}'
- discovery_id: aws.machinelearning.getMlModel
  calls:
  - action: getMlModel
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.EndpointInfo }}'
    item:
      PeakRequestsPerSecond: '{{ item.PeakRequestsPerSecond }}'
      CreatedAt: '{{ item.CreatedAt }}'
      EndpointUrl: '{{ item.EndpointUrl }}'
      EndpointStatus: '{{ item.EndpointStatus }}'
checks: []
