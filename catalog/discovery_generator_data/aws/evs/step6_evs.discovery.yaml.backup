version: '1.0'
provider: aws
service: evs
services:
  client: evs
  module: boto3.client
discovery:
- discovery_id: aws.evs.listEnvironments
  calls:
  - action: listEnvironments
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.environmentSummaries }}'
    item:
      environmentId: '{{ item.environmentId }}'
      environmentName: '{{ item.environmentName }}'
      vcfVersion: '{{ item.vcfVersion }}'
      environmentStatus: '{{ item.environmentStatus }}'
      environmentState: '{{ item.environmentState }}'
      createdAt: '{{ item.createdAt }}'
      modifiedAt: '{{ item.modifiedAt }}'
      environmentArn: '{{ item.environmentArn }}'
- discovery_id: aws.evs.getEnvironment
  calls:
  - action: getEnvironment
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.environment }}'
    item:
      environmentId: '{{ item.environmentId }}'
      environmentState: '{{ item.environmentState }}'
      stateDetails: '{{ item.stateDetails }}'
      createdAt: '{{ item.createdAt }}'
      modifiedAt: '{{ item.modifiedAt }}'
      environmentArn: '{{ item.environmentArn }}'
      environmentName: '{{ item.environmentName }}'
      vpcId: '{{ item.vpcId }}'
      serviceAccessSubnetId: '{{ item.serviceAccessSubnetId }}'
      vcfVersion: '{{ item.vcfVersion }}'
      termsAccepted: '{{ item.termsAccepted }}'
      licenseInfo: '{{ item.licenseInfo }}'
      siteId: '{{ item.siteId }}'
      environmentStatus: '{{ item.environmentStatus }}'
      checks: '{{ item.checks }}'
      connectivityInfo: '{{ item.connectivityInfo }}'
      vcfHostnames: '{{ item.vcfHostnames }}'
      kmsKeyId: '{{ item.kmsKeyId }}'
      serviceAccessSecurityGroups: '{{ item.serviceAccessSecurityGroups }}'
      credentials: '{{ item.credentials }}'
- discovery_id: aws.evs.listEnvironmentHosts
  calls:
  - action: listEnvironmentHosts
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.environmentHosts }}'
    item:
      hostName: '{{ item.hostName }}'
      ipAddress: '{{ item.ipAddress }}'
      keyName: '{{ item.keyName }}'
      instanceType: '{{ item.instanceType }}'
      placementGroupId: '{{ item.placementGroupId }}'
      dedicatedHostId: '{{ item.dedicatedHostId }}'
      createdAt: '{{ item.createdAt }}'
      modifiedAt: '{{ item.modifiedAt }}'
      hostState: '{{ item.hostState }}'
      stateDetails: '{{ item.stateDetails }}'
      ec2InstanceId: '{{ item.ec2InstanceId }}'
      networkInterfaces: '{{ item.networkInterfaces }}'
- discovery_id: aws.evs.listEnvironmentVlans
  calls:
  - action: listEnvironmentVlans
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.environmentVlans }}'
    item:
      vlanId: '{{ item.vlanId }}'
      cidr: '{{ item.cidr }}'
      availabilityZone: '{{ item.availabilityZone }}'
      functionName: '{{ item.functionName }}'
      subnetId: '{{ item.subnetId }}'
      createdAt: '{{ item.createdAt }}'
      modifiedAt: '{{ item.modifiedAt }}'
      vlanState: '{{ item.vlanState }}'
      stateDetails: '{{ item.stateDetails }}'
      eipAssociations: '{{ item.eipAssociations }}'
      isPublic: '{{ item.isPublic }}'
      networkAclId: '{{ item.networkAclId }}'
- discovery_id: aws.evs.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tags }}'
checks: []
