      failureTimestamp: '{{ item.failureTimestamp }}'
      grantedTimestamp: '{{ item.grantedTimestamp }}'
      permissions: '{{ item.permissions }}'
      status: '{{ item.status }}'
      targetName: '{{ item.targetName }}'
- discovery_id: aws.datazone.getSubscriptionRequestDetails
  calls:
