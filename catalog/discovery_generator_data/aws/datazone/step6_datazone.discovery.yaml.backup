version: '1.0'
provider: aws
service: datazone
services:
  client: datazone
  module: boto3.client
discovery:
- discovery_id: aws.datazone.listDomains
  calls:
  - action: listDomains
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
    item:
      arn: '{{ item.arn }}'
      createdAt: '{{ item.createdAt }}'
      description: '{{ item.description }}'
      domainVersion: '{{ item.domainVersion }}'
      id: '{{ item.id }}'
      lastUpdatedAt: '{{ item.lastUpdatedAt }}'
      managedAccountId: '{{ item.managedAccountId }}'
      name: '{{ item.name }}'
      portalUrl: '{{ item.portalUrl }}'
      status: '{{ item.status }}'
- discovery_id: aws.datazone.getAccountPool
  calls:
  - action: getAccountPool
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.accountSource }}'
    item:
      accounts: '{{ item.accounts }}'
      customAccountPoolHandler: '{{ item.customAccountPoolHandler }}'
- discovery_id: aws.datazone.getAsset
  calls:
  - action: getAsset
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.formsOutput }}'
    item:
      content: '{{ item.content }}'
      formName: '{{ item.formName }}'
      typeName: '{{ item.typeName }}'
      typeRevision: '{{ item.typeRevision }}'
- discovery_id: aws.datazone.getAssetFilter
  calls:
  - action: getAssetFilter
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.effectiveColumnNames }}'
- discovery_id: aws.datazone.getAssetType
  calls:
  - action: getAssetType
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.createdAt }}'
- discovery_id: aws.datazone.getConnection
  calls:
  - action: getConnection
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.physicalEndpoints }}'
    item:
      awsLocation: '{{ item.awsLocation }}'
      enableTrustedIdentityPropagation: '{{ item.enableTrustedIdentityPropagation
        }}'
      glueConnection: '{{ item.glueConnection }}'
      glueConnectionName: '{{ item.glueConnectionName }}'
      host: '{{ item.host }}'
      port: '{{ item.port }}'
      protocol: '{{ item.protocol }}'
      stage: '{{ item.stage }}'
- discovery_id: aws.datazone.getDataProduct
  calls:
  - action: getDataProduct
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
    item:
      glossaryTerms: '{{ item.glossaryTerms }}'
      identifier: '{{ item.identifier }}'
      itemType: '{{ item.itemType }}'
      revision: '{{ item.revision }}'
- discovery_id: aws.datazone.getDataSource
  calls:
  - action: getDataSource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.assetFormsOutput }}'
    item:
      content: '{{ item.content }}'
      formName: '{{ item.formName }}'
      typeName: '{{ item.typeName }}'
      typeRevision: '{{ item.typeRevision }}'
- discovery_id: aws.datazone.getDataSourceRun
  calls:
  - action: getDataSourceRun
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.errorMessage }}'
    item:
      errorDetail: '{{ item.errorDetail }}'
      errorType: '{{ item.errorType }}'
- discovery_id: aws.datazone.getDomain
  calls:
  - action: getDomain
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.singleSignOn }}'
    item:
      idcInstanceArn: '{{ item.idcInstanceArn }}'
      type: '{{ item.type }}'
      userAssignment: '{{ item.userAssignment }}'
- discovery_id: aws.datazone.getDomainUnit
  calls:
  - action: getDomainUnit
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.owners }}'
    item:
      group: '{{ item.group }}'
      user: '{{ item.user }}'
- discovery_id: aws.datazone.getEnvironment
  calls:
  - action: getEnvironment
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.provisionedResources }}'
    item:
      name: '{{ item.name }}'
      provider: '{{ item.provider }}'
      type: '{{ item.type }}'
      value: '{{ item.value }}'
- discovery_id: aws.datazone.getEnvironmentAction
  calls:
  - action: getEnvironmentAction
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.parameters }}'
    item:
      awsConsoleLink: '{{ item.awsConsoleLink }}'
- discovery_id: aws.datazone.getEnvironmentBlueprint
  calls:
  - action: getEnvironmentBlueprint
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.glossaryTerms }}'
- discovery_id: aws.datazone.getEnvironmentBlueprintConfiguration
  calls:
  - action: getEnvironmentBlueprintConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.enabledRegions }}'
- discovery_id: aws.datazone.getEnvironmentCredentials
  calls:
  - action: getEnvironmentCredentials
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.accessKeyId }}'
- discovery_id: aws.datazone.getEnvironmentProfile
  calls:
  - action: getEnvironmentProfile
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.userParameters }}'
    item:
      defaultValue: '{{ item.defaultValue }}'
      description: '{{ item.description }}'
      fieldType: '{{ item.fieldType }}'
      isEditable: '{{ item.isEditable }}'
      isOptional: '{{ item.isOptional }}'
      isUpdateSupported: '{{ item.isUpdateSupported }}'
      keyName: '{{ item.keyName }}'
- discovery_id: aws.datazone.getFormType
  calls:
  - action: getFormType
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.imports }}'
    item:
      name: '{{ item.name }}'
      revision: '{{ item.revision }}'
- discovery_id: aws.datazone.getGlossary
  calls:
  - action: getGlossary
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.usageRestrictions }}'
- discovery_id: aws.datazone.getGlossaryTerm
  calls:
  - action: getGlossaryTerm
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.usageRestrictions }}'
- discovery_id: aws.datazone.getGroupProfile
  calls:
  - action: getGroupProfile
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.domainId }}'
- discovery_id: aws.datazone.getIamPortalLoginUrl
  calls:
  - action: getIamPortalLoginUrl
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.authCodeUrl }}'
- discovery_id: aws.datazone.getJobRun
  calls:
  - action: getJobRun
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.details }}'
    item:
      lineageRunDetails: '{{ item.lineageRunDetails }}'
- discovery_id: aws.datazone.getLineageEvent
  calls:
  - action: getLineageEvent
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.createdAt }}'
- discovery_id: aws.datazone.getLineageNode
  calls:
  - action: getLineageNode
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.downstreamNodes }}'
    item:
      eventTimestamp: '{{ item.eventTimestamp }}'
      id: '{{ item.id }}'
- discovery_id: aws.datazone.getListing
  calls:
  - action: getListing
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.item }}'
    item:
      assetListing: '{{ item.assetListing }}'
      dataProductListing: '{{ item.dataProductListing }}'
- discovery_id: aws.datazone.getMetadataGenerationRun
  calls:
  - action: getMetadataGenerationRun
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.target }}'
    item:
      identifier: '{{ item.identifier }}'
      revision: '{{ item.revision }}'
      type: '{{ item.type }}'
- discovery_id: aws.datazone.getProject
  calls:
  - action: getProject
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.failureReasons }}'
    item:
      code: '{{ item.code }}'
      message: '{{ item.message }}'
- discovery_id: aws.datazone.getProjectProfile
  calls:
  - action: getProjectProfile
    save_as: response
    on_error: continue
  emit:
