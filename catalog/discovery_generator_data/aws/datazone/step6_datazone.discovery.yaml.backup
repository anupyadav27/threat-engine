    items_for: '{{ response.items }}'
    item:
      createdBy: '{{ item.createdBy }}'
      domainId: '{{ item.domainId }}'
      domainUnitId: '{{ item.domainUnitId }}'
      id: '{{ item.id }}'
      name: '{{ item.name }}'
      resolutionStrategy: '{{ item.resolutionStrategy }}'
      updatedBy: '{{ item.updatedBy }}'
- discovery_id: aws.datazone.listAccountsInAccountPool
  calls:
