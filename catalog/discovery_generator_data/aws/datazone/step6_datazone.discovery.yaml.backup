      formName: '{{ item.formName }}'
      id: '{{ item.id }}'
      timestamp: '{{ item.timestamp }}'
      typeIdentifier: '{{ item.typeIdentifier }}'
      typeRevision: '{{ item.typeRevision }}'
- discovery_id: aws.datazone.getUserProfile
  calls:
