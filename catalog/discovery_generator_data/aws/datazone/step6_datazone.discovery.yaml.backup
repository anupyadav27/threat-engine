    item:
      accountPools: '{{ item.accountPools }}'
      awsAccount: '{{ item.awsAccount }}'
      awsRegion: '{{ item.awsRegion }}'
      configurationParameters: '{{ item.configurationParameters }}'
      deploymentMode: '{{ item.deploymentMode }}'
