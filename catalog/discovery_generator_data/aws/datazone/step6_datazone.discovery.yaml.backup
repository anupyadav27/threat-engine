    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.details }}'
    item:
      iam: '{{ item.iam }}'
      sso: '{{ item.sso }}'
- discovery_id: aws.datazone.listAccountPools
  calls:
