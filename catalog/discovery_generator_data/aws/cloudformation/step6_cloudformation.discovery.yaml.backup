version: '1.0'
provider: aws
service: cloudformation
services:
  client: cloudformation
  module: boto3.client
discovery:
- discovery_id: aws.cloudformation.describeAccountLimits
  calls:
  - action: describeAccountLimits
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AccountLimits }}'
    item:
      Name: '{{ item.Name }}'
      Value: '{{ item.Value }}'
- discovery_id: aws.cloudformation.describeEvents
  calls:
  - action: describeEvents
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.OperationEvents }}'
    item:
      EventId: '{{ item.EventId }}'
      StackId: '{{ item.StackId }}'
      OperationId: '{{ item.OperationId }}'
      OperationType: '{{ item.OperationType }}'
      OperationStatus: '{{ item.OperationStatus }}'
      EventType: '{{ item.EventType }}'
      LogicalResourceId: '{{ item.LogicalResourceId }}'
      PhysicalResourceId: '{{ item.PhysicalResourceId }}'
      ResourceType: '{{ item.ResourceType }}'
      Timestamp: '{{ item.Timestamp }}'
      StartTime: '{{ item.StartTime }}'
      EndTime: '{{ item.EndTime }}'
      ResourceStatus: '{{ item.ResourceStatus }}'
      ResourceStatusReason: '{{ item.ResourceStatusReason }}'
      ResourceProperties: '{{ item.ResourceProperties }}'
      ClientRequestToken: '{{ item.ClientRequestToken }}'
      HookType: '{{ item.HookType }}'
      HookStatus: '{{ item.HookStatus }}'
      HookStatusReason: '{{ item.HookStatusReason }}'
      HookInvocationPoint: '{{ item.HookInvocationPoint }}'
      HookFailureMode: '{{ item.HookFailureMode }}'
      DetailedStatus: '{{ item.DetailedStatus }}'
      ValidationFailureMode: '{{ item.ValidationFailureMode }}'
      ValidationName: '{{ item.ValidationName }}'
      ValidationStatus: '{{ item.ValidationStatus }}'
      ValidationStatusReason: '{{ item.ValidationStatusReason }}'
      ValidationPath: '{{ item.ValidationPath }}'
- discovery_id: aws.cloudformation.describeOrganizationsAccess
  calls:
  - action: describeOrganizationsAccess
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Status }}'
- discovery_id: aws.cloudformation.describePublisher
  calls:
  - action: describePublisher
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.PublisherId }}'
- discovery_id: aws.cloudformation.describeStackResources
  calls:
  - action: describeStackResources
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.StackResources }}'
    item:
      StackName: '{{ item.StackName }}'
      StackId: '{{ item.StackId }}'
      LogicalResourceId: '{{ item.LogicalResourceId }}'
      PhysicalResourceId: '{{ item.PhysicalResourceId }}'
      ResourceType: '{{ item.ResourceType }}'
      Timestamp: '{{ item.Timestamp }}'
      ResourceStatus: '{{ item.ResourceStatus }}'
      ResourceStatusReason: '{{ item.ResourceStatusReason }}'
      Description: '{{ item.Description }}'
      DriftInformation: '{{ item.DriftInformation }}'
      ModuleInfo: '{{ item.ModuleInfo }}'
- discovery_id: aws.cloudformation.describeStacks
  calls:
  - action: describeStacks
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Stacks }}'
    item:
      StackId: '{{ item.StackId }}'
      StackName: '{{ item.StackName }}'
      ChangeSetId: '{{ item.ChangeSetId }}'
      Description: '{{ item.Description }}'
      Parameters: '{{ item.Parameters }}'
      CreationTime: '{{ item.CreationTime }}'
      DeletionTime: '{{ item.DeletionTime }}'
      LastUpdatedTime: '{{ item.LastUpdatedTime }}'
      RollbackConfiguration: '{{ item.RollbackConfiguration }}'
      StackStatus: '{{ item.StackStatus }}'
      StackStatusReason: '{{ item.StackStatusReason }}'
      DisableRollback: '{{ item.DisableRollback }}'
      NotificationARNs: '{{ item.NotificationARNs }}'
      TimeoutInMinutes: '{{ item.TimeoutInMinutes }}'
      Capabilities: '{{ item.Capabilities }}'
      Outputs: '{{ item.Outputs }}'
      RoleARN: '{{ item.RoleARN }}'
      Tags: '{{ item.Tags }}'
      EnableTerminationProtection: '{{ item.EnableTerminationProtection }}'
      ParentId: '{{ item.ParentId }}'
      RootId: '{{ item.RootId }}'
      DriftInformation: '{{ item.DriftInformation }}'
      RetainExceptOnCreate: '{{ item.RetainExceptOnCreate }}'
      DeletionMode: '{{ item.DeletionMode }}'
      DetailedStatus: '{{ item.DetailedStatus }}'
      LastOperations: '{{ item.LastOperations }}'
- discovery_id: aws.cloudformation.describeType
  calls:
  - action: describeType
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.RequiredActivatedTypes }}'
    item:
      TypeNameAlias: '{{ item.TypeNameAlias }}'
      OriginalTypeName: '{{ item.OriginalTypeName }}'
      PublisherId: '{{ item.PublisherId }}'
      SupportedMajorVersions: '{{ item.SupportedMajorVersions }}'
- discovery_id: aws.cloudformation.getHookResult
  calls:
  - action: getHookResult
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Annotations }}'
    item:
      AnnotationName: '{{ item.AnnotationName }}'
      Status: '{{ item.Status }}'
      StatusMessage: '{{ item.StatusMessage }}'
      RemediationMessage: '{{ item.RemediationMessage }}'
      RemediationLink: '{{ item.RemediationLink }}'
      SeverityLevel: '{{ item.SeverityLevel }}'
- discovery_id: aws.cloudformation.getTemplate
  calls:
  - action: getTemplate
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.StagesAvailable }}'
- discovery_id: aws.cloudformation.getTemplateSummary
  calls:
  - action: getTemplateSummary
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Parameters }}'
    item:
      ParameterKey: '{{ item.ParameterKey }}'
      DefaultValue: '{{ item.DefaultValue }}'
      ParameterType: '{{ item.ParameterType }}'
      NoEcho: '{{ item.NoEcho }}'
      Description: '{{ item.Description }}'
      ParameterConstraints: '{{ item.ParameterConstraints }}'
- discovery_id: aws.cloudformation.listExports
  calls:
  - action: listExports
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Exports }}'
    item:
      ExportingStackId: '{{ item.ExportingStackId }}'
      Name: '{{ item.Name }}'
      Value: '{{ item.Value }}'
- discovery_id: aws.cloudformation.listGeneratedTemplates
  calls:
  - action: listGeneratedTemplates
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Summaries }}'
    item:
      GeneratedTemplateId: '{{ item.GeneratedTemplateId }}'
      GeneratedTemplateName: '{{ item.GeneratedTemplateName }}'
      Status: '{{ item.Status }}'
      StatusReason: '{{ item.StatusReason }}'
      CreationTime: '{{ item.CreationTime }}'
      LastUpdatedTime: '{{ item.LastUpdatedTime }}'
      NumberOfResources: '{{ item.NumberOfResources }}'
- discovery_id: aws.cloudformation.listHookResults
  calls:
  - action: listHookResults
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.HookResults }}'
    item:
      HookResultId: '{{ item.HookResultId }}'
      InvocationPoint: '{{ item.InvocationPoint }}'
      FailureMode: '{{ item.FailureMode }}'
      TypeName: '{{ item.TypeName }}'
      TypeVersionId: '{{ item.TypeVersionId }}'
      TypeConfigurationVersionId: '{{ item.TypeConfigurationVersionId }}'
      Status: '{{ item.Status }}'
      HookStatusReason: '{{ item.HookStatusReason }}'
      InvokedAt: '{{ item.InvokedAt }}'
      TargetType: '{{ item.TargetType }}'
      TargetId: '{{ item.TargetId }}'
      TypeArn: '{{ item.TypeArn }}'
      HookExecutionTarget: '{{ item.HookExecutionTarget }}'
- discovery_id: aws.cloudformation.listResourceScans
  calls:
  - action: listResourceScans
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.ResourceScanSummaries }}'
    item:
      ResourceScanId: '{{ item.ResourceScanId }}'
      Status: '{{ item.Status }}'
      StatusReason: '{{ item.StatusReason }}'
      StartTime: '{{ item.StartTime }}'
      EndTime: '{{ item.EndTime }}'
      PercentageCompleted: '{{ item.PercentageCompleted }}'
      ScanType: '{{ item.ScanType }}'
- discovery_id: aws.cloudformation.listStackRefactors
  calls:
  - action: listStackRefactors
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.StackRefactorSummaries }}'
    item:
      StackRefactorId: '{{ item.StackRefactorId }}'
      Description: '{{ item.Description }}'
      ExecutionStatus: '{{ item.ExecutionStatus }}'
      ExecutionStatusReason: '{{ item.ExecutionStatusReason }}'
      Status: '{{ item.Status }}'
      StatusReason: '{{ item.StatusReason }}'
- discovery_id: aws.cloudformation.listStackSets
  calls:
  - action: listStackSets
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Summaries }}'
    item:
      StackSetName: '{{ item.StackSetName }}'
      StackSetId: '{{ item.StackSetId }}'
      Description: '{{ item.Description }}'
      Status: '{{ item.Status }}'
      AutoDeployment: '{{ item.AutoDeployment }}'
      PermissionModel: '{{ item.PermissionModel }}'
      DriftStatus: '{{ item.DriftStatus }}'
      LastDriftCheckTimestamp: '{{ item.LastDriftCheckTimestamp }}'
      ManagedExecution: '{{ item.ManagedExecution }}'
- discovery_id: aws.cloudformation.listStacks
  calls:
  - action: listStacks
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.StackSummaries }}'
    item:
      StackId: '{{ item.StackId }}'
      StackName: '{{ item.StackName }}'
      TemplateDescription: '{{ item.TemplateDescription }}'
      CreationTime: '{{ item.CreationTime }}'
      LastUpdatedTime: '{{ item.LastUpdatedTime }}'
      DeletionTime: '{{ item.DeletionTime }}'
      StackStatus: '{{ item.StackStatus }}'
      StackStatusReason: '{{ item.StackStatusReason }}'
      ParentId: '{{ item.ParentId }}'
      RootId: '{{ item.RootId }}'
      DriftInformation: '{{ item.DriftInformation }}'
      LastOperations: '{{ item.LastOperations }}'
- discovery_id: aws.cloudformation.listTypeRegistrations
  calls:
