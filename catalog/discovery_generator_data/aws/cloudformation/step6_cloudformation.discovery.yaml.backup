- discovery_id: aws.cloudformation.listTypeVersions
  calls:
  - action: listTypeVersions
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.TypeVersionSummaries }}'
    item:
      Type: '{{ item.Type }}'
      TypeName: '{{ item.TypeName }}'
      VersionId: '{{ item.VersionId }}'
      IsDefaultVersion: '{{ item.IsDefaultVersion }}'
      Arn: '{{ item.Arn }}'
      TimeCreated: '{{ item.TimeCreated }}'
      Description: '{{ item.Description }}'
      PublicVersionNumber: '{{ item.PublicVersionNumber }}'
- discovery_id: aws.cloudformation.listTypes
  calls:
  - action: listTypes
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.TypeSummaries }}'
    item:
      Type: '{{ item.Type }}'
      TypeName: '{{ item.TypeName }}'
      DefaultVersionId: '{{ item.DefaultVersionId }}'
      TypeArn: '{{ item.TypeArn }}'
      LastUpdated: '{{ item.LastUpdated }}'
      Description: '{{ item.Description }}'
      PublisherId: '{{ item.PublisherId }}'
      OriginalTypeName: '{{ item.OriginalTypeName }}'
      PublicVersionNumber: '{{ item.PublicVersionNumber }}'
      LatestPublicVersion: '{{ item.LatestPublicVersion }}'
      PublisherIdentity: '{{ item.PublisherIdentity }}'
      PublisherName: '{{ item.PublisherName }}'
      IsActivated: '{{ item.IsActivated }}'
- discovery_id: aws.cloudformation.describeChangeSet
  calls:
  - action: describeChangeSet
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Parameters }}'
    item:
      ParameterKey: '{{ item.ParameterKey }}'
      ParameterValue: '{{ item.ParameterValue }}'
      UsePreviousValue: '{{ item.UsePreviousValue }}'
      ResolvedValue: '{{ item.ResolvedValue }}'
- discovery_id: aws.cloudformation.describeChangeSetHooks
  calls:
  - action: describeChangeSetHooks
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Hooks }}'
    item:
      InvocationPoint: '{{ item.InvocationPoint }}'
      FailureMode: '{{ item.FailureMode }}'
      TypeName: '{{ item.TypeName }}'
      TypeVersionId: '{{ item.TypeVersionId }}'
      TypeConfigurationVersionId: '{{ item.TypeConfigurationVersionId }}'
      TargetDetails: '{{ item.TargetDetails }}'
- discovery_id: aws.cloudformation.describeGeneratedTemplate
  calls:
  - action: describeGeneratedTemplate
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Resources }}'
    item:
      ResourceType: '{{ item.ResourceType }}'
      LogicalResourceId: '{{ item.LogicalResourceId }}'
      ResourceIdentifier: '{{ item.ResourceIdentifier }}'
      ResourceStatus: '{{ item.ResourceStatus }}'
      ResourceStatusReason: '{{ item.ResourceStatusReason }}'
      Warnings: '{{ item.Warnings }}'
- discovery_id: aws.cloudformation.describeResourceScan
  calls:
  - action: describeResourceScan
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ResourceTypes }}'
- discovery_id: aws.cloudformation.describeStackDriftDetectionStatus
  calls:
  - action: describeStackDriftDetectionStatus
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.StackId }}'
- discovery_id: aws.cloudformation.describeStackEvents
  calls:
  - action: describeStackEvents
    save_as: response
    on_error: continue
  emit:
