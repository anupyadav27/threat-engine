      StackInstanceStatus: '{{ item.StackInstanceStatus }}'
      StatusReason: '{{ item.StatusReason }}'
      OrganizationalUnitId: '{{ item.OrganizationalUnitId }}'
      DriftStatus: '{{ item.DriftStatus }}'
      LastDriftCheckTimestamp: '{{ item.LastDriftCheckTimestamp }}'
      LastOperationId: '{{ item.LastOperationId }}'
- discovery_id: aws.cloudformation.describeStackRefactor
  calls:
