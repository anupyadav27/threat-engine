version: '1.0'
provider: aws
service: customer-profiles
services:
  client: customer-profiles
  module: boto3.client
discovery:
- discovery_id: aws.customer-profiles.listDomains
  calls:
  - action: listDomains
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Items }}'
    item:
      DomainName: '{{ item.DomainName }}'
      CreatedAt: '{{ item.CreatedAt }}'
      LastUpdatedAt: '{{ item.LastUpdatedAt }}'
      Tags: '{{ item.Tags }}'
- discovery_id: aws.customer-profiles.listProfileObjectTypeTemplates
  calls:
  - action: listProfileObjectTypeTemplates
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Items }}'
    item:
      TemplateId: '{{ item.TemplateId }}'
      SourceName: '{{ item.SourceName }}'
      SourceObject: '{{ item.SourceObject }}'
- discovery_id: aws.customer-profiles.getAutoMergingPreview
  calls:
  - action: getAutoMergingPreview
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.DomainName }}'
- discovery_id: aws.customer-profiles.getCalculatedAttributeDefinition
  calls:
  - action: getCalculatedAttributeDefinition
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Filter }}'
    item:
      Include: '{{ item.Include }}'
      Groups: '{{ item.Groups }}'
- discovery_id: aws.customer-profiles.getCalculatedAttributeForProfile
  calls:
  - action: getCalculatedAttributeForProfile
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.CalculatedAttributeName }}'
- discovery_id: aws.customer-profiles.getDomain
  calls:
  - action: getDomain
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Stats }}'
    item:
      ProfileCount: '{{ item.ProfileCount }}'
      MeteringProfileCount: '{{ item.MeteringProfileCount }}'
      ObjectCount: '{{ item.ObjectCount }}'
      TotalSize: '{{ item.TotalSize }}'
- discovery_id: aws.customer-profiles.getDomainLayout
  calls:
  - action: getDomainLayout
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.LayoutDefinitionName }}'
- discovery_id: aws.customer-profiles.getEventStream
  calls:
  - action: getEventStream
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.DestinationDetails }}'
    item:
      Uri: '{{ item.Uri }}'
      Status: '{{ item.Status }}'
      UnhealthySince: '{{ item.UnhealthySince }}'
      Message: '{{ item.Message }}'
- discovery_id: aws.customer-profiles.getEventTrigger
  calls:
  - action: getEventTrigger
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.EventTriggerConditions }}'
    item:
      EventTriggerDimensions: '{{ item.EventTriggerDimensions }}'
      LogicalOperator: '{{ item.LogicalOperator }}'
- discovery_id: aws.customer-profiles.getIdentityResolutionJob
  calls:
  - action: getIdentityResolutionJob
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AutoMerging }}'
    item:
      Enabled: '{{ item.Enabled }}'
      Consolidation: '{{ item.Consolidation }}'
      ConflictResolution: '{{ item.ConflictResolution }}'
      MinAllowedConfidenceScoreForMerging: '{{ item.MinAllowedConfidenceScoreForMerging
        }}'
- discovery_id: aws.customer-profiles.getIntegration
  calls:
  - action: getIntegration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.EventTriggerNames }}'
- discovery_id: aws.customer-profiles.getMatches
  calls:
  - action: getMatches
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Matches }}'
    item:
      MatchId: '{{ item.MatchId }}'
      ProfileIds: '{{ item.ProfileIds }}'
      ConfidenceScore: '{{ item.ConfidenceScore }}'
- discovery_id: aws.customer-profiles.getProfileHistoryRecord
  calls:
  - action: getProfileHistoryRecord
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Id }}'
- discovery_id: aws.customer-profiles.getProfileObjectType
  calls:
  - action: getProfileObjectType
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ObjectTypeName }}'
- discovery_id: aws.customer-profiles.getProfileObjectTypeTemplate
  calls:
  - action: getProfileObjectTypeTemplate
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.TemplateId }}'
- discovery_id: aws.customer-profiles.getSegmentDefinition
  calls:
  - action: getSegmentDefinition
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.SegmentGroups }}'
    item:
      Groups: '{{ item.Groups }}'
      Include: '{{ item.Include }}'
- discovery_id: aws.customer-profiles.getSegmentEstimate
  calls:
  - action: getSegmentEstimate
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.DomainName }}'
- discovery_id: aws.customer-profiles.getSegmentMembership
  calls:
  - action: getSegmentMembership
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Profiles }}'
    item:
      ProfileId: '{{ item.ProfileId }}'
      QueryResult: '{{ item.QueryResult }}'
      Profile: '{{ item.Profile }}'
- discovery_id: aws.customer-profiles.getSegmentSnapshot
  calls:
  - action: getSegmentSnapshot
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.SnapshotId }}'
- discovery_id: aws.customer-profiles.getSimilarProfiles
  calls:
  - action: getSimilarProfiles
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ProfileIds }}'
- discovery_id: aws.customer-profiles.getUploadJob
  calls:
  - action: getUploadJob
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ResultsSummary }}'
    item:
      UpdatedRecords: '{{ item.UpdatedRecords }}'
      CreatedRecords: '{{ item.CreatedRecords }}'
      FailedRecords: '{{ item.FailedRecords }}'
- discovery_id: aws.customer-profiles.getUploadJobPath
  calls:
  - action: getUploadJobPath
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Url }}'
- discovery_id: aws.customer-profiles.getWorkflow
  calls:
  - action: getWorkflow
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Attributes }}'
    item:
      AppflowIntegration: '{{ item.AppflowIntegration }}'
- discovery_id: aws.customer-profiles.getWorkflowSteps
  calls:
  - action: getWorkflowSteps
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Items }}'
    item:
      AppflowIntegration: '{{ item.AppflowIntegration }}'
- discovery_id: aws.customer-profiles.listAccountIntegrations
  calls:
  - action: listAccountIntegrations
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Items }}'
    item:
      DomainName: '{{ item.DomainName }}'
      Uri: '{{ item.Uri }}'
      ObjectTypeName: '{{ item.ObjectTypeName }}'
      CreatedAt: '{{ item.CreatedAt }}'
      LastUpdatedAt: '{{ item.LastUpdatedAt }}'
      Tags: '{{ item.Tags }}'
      ObjectTypeNames: '{{ item.ObjectTypeNames }}'
      WorkflowId: '{{ item.WorkflowId }}'
      IsUnstructured: '{{ item.IsUnstructured }}'
      RoleArn: '{{ item.RoleArn }}'
      EventTriggerNames: '{{ item.EventTriggerNames }}'
- discovery_id: aws.customer-profiles.listCalculatedAttributeDefinitions
  calls:
  - action: listCalculatedAttributeDefinitions
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Items }}'
    item:
      CalculatedAttributeName: '{{ item.CalculatedAttributeName }}'
      DisplayName: '{{ item.DisplayName }}'
      Description: '{{ item.Description }}'
      CreatedAt: '{{ item.CreatedAt }}'
      LastUpdatedAt: '{{ item.LastUpdatedAt }}'
      UseHistoricalData: '{{ item.UseHistoricalData }}'
      Status: '{{ item.Status }}'
      Tags: '{{ item.Tags }}'
- discovery_id: aws.customer-profiles.listCalculatedAttributesForProfile
  calls:
  - action: listCalculatedAttributesForProfile
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Items }}'
    item:
      CalculatedAttributeName: '{{ item.CalculatedAttributeName }}'
      DisplayName: '{{ item.DisplayName }}'
      IsDataPartial: '{{ item.IsDataPartial }}'
      Value: '{{ item.Value }}'
      LastObjectTimestamp: '{{ item.LastObjectTimestamp }}'
- discovery_id: aws.customer-profiles.listDomainLayouts
  calls:
  - action: listDomainLayouts
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Items }}'
    item:
      LayoutDefinitionName: '{{ item.LayoutDefinitionName }}'
      Description: '{{ item.Description }}'
      DisplayName: '{{ item.DisplayName }}'
      IsDefault: '{{ item.IsDefault }}'
      LayoutType: '{{ item.LayoutType }}'
      Tags: '{{ item.Tags }}'
      CreatedAt: '{{ item.CreatedAt }}'
      LastUpdatedAt: '{{ item.LastUpdatedAt }}'
- discovery_id: aws.customer-profiles.listEventStreams
  calls:
  - action: listEventStreams
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Items }}'
    item:
      DomainName: '{{ item.DomainName }}'
      EventStreamName: '{{ item.EventStreamName }}'
      EventStreamArn: '{{ item.EventStreamArn }}'
      State: '{{ item.State }}'
      StoppedSince: '{{ item.StoppedSince }}'
      DestinationSummary: '{{ item.DestinationSummary }}'
      Tags: '{{ item.Tags }}'
- discovery_id: aws.customer-profiles.listEventTriggers
  calls:
  - action: listEventTriggers
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Items }}'
    item:
      ObjectTypeName: '{{ item.ObjectTypeName }}'
      EventTriggerName: '{{ item.EventTriggerName }}'
      Description: '{{ item.Description }}'
      CreatedAt: '{{ item.CreatedAt }}'
      LastUpdatedAt: '{{ item.LastUpdatedAt }}'
      Tags: '{{ item.Tags }}'
- discovery_id: aws.customer-profiles.listIdentityResolutionJobs
  calls:
  - action: listIdentityResolutionJobs
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.IdentityResolutionJobsList }}'
    item:
      DomainName: '{{ item.DomainName }}'
      JobId: '{{ item.JobId }}'
      Status: '{{ item.Status }}'
      JobStartTime: '{{ item.JobStartTime }}'
      JobEndTime: '{{ item.JobEndTime }}'
      JobStats: '{{ item.JobStats }}'
      ExportingLocation: '{{ item.ExportingLocation }}'
      Message: '{{ item.Message }}'
- discovery_id: aws.customer-profiles.listIntegrations
  calls:
  - action: listIntegrations
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Items }}'
    item:
      DomainName: '{{ item.DomainName }}'
      Uri: '{{ item.Uri }}'
      ObjectTypeName: '{{ item.ObjectTypeName }}'
      CreatedAt: '{{ item.CreatedAt }}'
      LastUpdatedAt: '{{ item.LastUpdatedAt }}'
      Tags: '{{ item.Tags }}'
      ObjectTypeNames: '{{ item.ObjectTypeNames }}'
      WorkflowId: '{{ item.WorkflowId }}'
      IsUnstructured: '{{ item.IsUnstructured }}'
      RoleArn: '{{ item.RoleArn }}'
      EventTriggerNames: '{{ item.EventTriggerNames }}'
- discovery_id: aws.customer-profiles.listObjectTypeAttributes
  calls:
  - action: listObjectTypeAttributes
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Items }}'
    item:
      AttributeName: '{{ item.AttributeName }}'
      LastUpdatedAt: '{{ item.LastUpdatedAt }}'
- discovery_id: aws.customer-profiles.listProfileAttributeValues
  calls:
  - action: listProfileAttributeValues
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Items }}'
    item:
      Value: '{{ item.Value }}'
- discovery_id: aws.customer-profiles.listProfileHistoryRecords
  calls:
  - action: listProfileHistoryRecords
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.ProfileHistoryRecords }}'
    item:
      Id: '{{ item.Id }}'
      ObjectTypeName: '{{ item.ObjectTypeName }}'
      CreatedAt: '{{ item.CreatedAt }}'
      LastUpdatedAt: '{{ item.LastUpdatedAt }}'
      ActionType: '{{ item.ActionType }}'
      ProfileObjectUniqueKey: '{{ item.ProfileObjectUniqueKey }}'
      PerformedBy: '{{ item.PerformedBy }}'
- discovery_id: aws.customer-profiles.listProfileObjectTypes
  calls:
  - action: listProfileObjectTypes
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Items }}'
    item:
      ObjectTypeName: '{{ item.ObjectTypeName }}'
      Description: '{{ item.Description }}'
      CreatedAt: '{{ item.CreatedAt }}'
      LastUpdatedAt: '{{ item.LastUpdatedAt }}'
      MaxProfileObjectCount: '{{ item.MaxProfileObjectCount }}'
      MaxAvailableProfileObjectCount: '{{ item.MaxAvailableProfileObjectCount }}'
      Tags: '{{ item.Tags }}'
- discovery_id: aws.customer-profiles.listProfileObjects
  calls:
  - action: listProfileObjects
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Items }}'
    item:
      ObjectTypeName: '{{ item.ObjectTypeName }}'
      ProfileObjectUniqueKey: '{{ item.ProfileObjectUniqueKey }}'
      Object: '{{ item.Object }}'
- discovery_id: aws.customer-profiles.listRuleBasedMatches
  calls:
  - action: listRuleBasedMatches
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.MatchIds }}'
- discovery_id: aws.customer-profiles.listSegmentDefinitions
  calls:
  - action: listSegmentDefinitions
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Items }}'
    item:
      SegmentDefinitionName: '{{ item.SegmentDefinitionName }}'
      DisplayName: '{{ item.DisplayName }}'
      Description: '{{ item.Description }}'
      SegmentDefinitionArn: '{{ item.SegmentDefinitionArn }}'
      CreatedAt: '{{ item.CreatedAt }}'
      Tags: '{{ item.Tags }}'
- discovery_id: aws.customer-profiles.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tags }}'
- discovery_id: aws.customer-profiles.listUploadJobs
  calls:
  - action: listUploadJobs
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Items }}'
    item:
      JobId: '{{ item.JobId }}'
      DisplayName: '{{ item.DisplayName }}'
      Status: '{{ item.Status }}'
      StatusReason: '{{ item.StatusReason }}'
      CreatedAt: '{{ item.CreatedAt }}'
      CompletedAt: '{{ item.CompletedAt }}'
      DataExpiry: '{{ item.DataExpiry }}'
- discovery_id: aws.customer-profiles.listWorkflows
  calls:
  - action: listWorkflows
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Items }}'
    item:
      WorkflowType: '{{ item.WorkflowType }}'
      WorkflowId: '{{ item.WorkflowId }}'
      Status: '{{ item.Status }}'
      StatusDescription: '{{ item.StatusDescription }}'
      CreatedAt: '{{ item.CreatedAt }}'
      LastUpdatedAt: '{{ item.LastUpdatedAt }}'
- discovery_id: aws.customer-profiles.searchProfiles
  calls:
  - action: searchProfiles
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Items }}'
    item:
      ProfileId: '{{ item.ProfileId }}'
      AccountNumber: '{{ item.AccountNumber }}'
      AdditionalInformation: '{{ item.AdditionalInformation }}'
      PartyType: '{{ item.PartyType }}'
      BusinessName: '{{ item.BusinessName }}'
      FirstName: '{{ item.FirstName }}'
      MiddleName: '{{ item.MiddleName }}'
      LastName: '{{ item.LastName }}'
      BirthDate: '{{ item.BirthDate }}'
      Gender: '{{ item.Gender }}'
      PhoneNumber: '{{ item.PhoneNumber }}'
      MobilePhoneNumber: '{{ item.MobilePhoneNumber }}'
      HomePhoneNumber: '{{ item.HomePhoneNumber }}'
      BusinessPhoneNumber: '{{ item.BusinessPhoneNumber }}'
      EmailAddress: '{{ item.EmailAddress }}'
      PersonalEmailAddress: '{{ item.PersonalEmailAddress }}'
      BusinessEmailAddress: '{{ item.BusinessEmailAddress }}'
      Address: '{{ item.Address }}'
      ShippingAddress: '{{ item.ShippingAddress }}'
      MailingAddress: '{{ item.MailingAddress }}'
      BillingAddress: '{{ item.BillingAddress }}'
      Attributes: '{{ item.Attributes }}'
      FoundByItems: '{{ item.FoundByItems }}'
      PartyTypeString: '{{ item.PartyTypeString }}'
      GenderString: '{{ item.GenderString }}'
      ProfileType: '{{ item.ProfileType }}'
      EngagementPreferences: '{{ item.EngagementPreferences }}'
checks: []
