version: '1.0'
provider: aws
service: chatbot
services:
  client: chatbot
  module: boto3.client
discovery:
- discovery_id: aws.chatbot.describeChimeWebhookConfigurations
  calls:
  - action: describeChimeWebhookConfigurations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.WebhookConfigurations }}'
    item:
      WebhookDescription: '{{ item.WebhookDescription }}'
      ChatConfigurationArn: '{{ item.ChatConfigurationArn }}'
      IamRoleArn: '{{ item.IamRoleArn }}'
      SnsTopicArns: '{{ item.SnsTopicArns }}'
      ConfigurationName: '{{ item.ConfigurationName }}'
      LoggingLevel: '{{ item.LoggingLevel }}'
      Tags: '{{ item.Tags }}'
      State: '{{ item.State }}'
      StateReason: '{{ item.StateReason }}'
- discovery_id: aws.chatbot.describeSlackChannelConfigurations
  calls:
  - action: describeSlackChannelConfigurations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.SlackChannelConfigurations }}'
    item:
      SlackTeamName: '{{ item.SlackTeamName }}'
      SlackTeamId: '{{ item.SlackTeamId }}'
      SlackChannelId: '{{ item.SlackChannelId }}'
      SlackChannelName: '{{ item.SlackChannelName }}'
      ChatConfigurationArn: '{{ item.ChatConfigurationArn }}'
      IamRoleArn: '{{ item.IamRoleArn }}'
      SnsTopicArns: '{{ item.SnsTopicArns }}'
      ConfigurationName: '{{ item.ConfigurationName }}'
      LoggingLevel: '{{ item.LoggingLevel }}'
      GuardrailPolicyArns: '{{ item.GuardrailPolicyArns }}'
      UserAuthorizationRequired: '{{ item.UserAuthorizationRequired }}'
      Tags: '{{ item.Tags }}'
      State: '{{ item.State }}'
      StateReason: '{{ item.StateReason }}'
- discovery_id: aws.chatbot.describeSlackUserIdentities
  calls:
  - action: describeSlackUserIdentities
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.SlackUserIdentities }}'
    item:
      IamRoleArn: '{{ item.IamRoleArn }}'
      ChatConfigurationArn: '{{ item.ChatConfigurationArn }}'
      SlackTeamId: '{{ item.SlackTeamId }}'
      SlackUserId: '{{ item.SlackUserId }}'
      AwsUserIdentity: '{{ item.AwsUserIdentity }}'
- discovery_id: aws.chatbot.describeSlackWorkspaces
  calls:
  - action: describeSlackWorkspaces
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.SlackWorkspaces }}'
    item:
      SlackTeamId: '{{ item.SlackTeamId }}'
      SlackTeamName: '{{ item.SlackTeamName }}'
      State: '{{ item.State }}'
      StateReason: '{{ item.StateReason }}'
- discovery_id: aws.chatbot.getAccountPreferences
  calls:
  - action: getAccountPreferences
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AccountPreferences }}'
    item:
      UserAuthorizationRequired: '{{ item.UserAuthorizationRequired }}'
      TrainingDataCollectionEnabled: '{{ item.TrainingDataCollectionEnabled }}'
- discovery_id: aws.chatbot.listCustomActions
  calls:
  - action: listCustomActions
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.CustomActions }}'
- discovery_id: aws.chatbot.listMicrosoftTeamsChannelConfigurations
  calls:
  - action: listMicrosoftTeamsChannelConfigurations
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.TeamChannelConfigurations }}'
    item:
      ChannelId: '{{ item.ChannelId }}'
      ChannelName: '{{ item.ChannelName }}'
      TeamId: '{{ item.TeamId }}'
      TeamName: '{{ item.TeamName }}'
      TenantId: '{{ item.TenantId }}'
      ChatConfigurationArn: '{{ item.ChatConfigurationArn }}'
      IamRoleArn: '{{ item.IamRoleArn }}'
      SnsTopicArns: '{{ item.SnsTopicArns }}'
      ConfigurationName: '{{ item.ConfigurationName }}'
      LoggingLevel: '{{ item.LoggingLevel }}'
      GuardrailPolicyArns: '{{ item.GuardrailPolicyArns }}'
      UserAuthorizationRequired: '{{ item.UserAuthorizationRequired }}'
      Tags: '{{ item.Tags }}'
      State: '{{ item.State }}'
      StateReason: '{{ item.StateReason }}'
- discovery_id: aws.chatbot.listMicrosoftTeamsConfiguredTeams
  calls:
  - action: listMicrosoftTeamsConfiguredTeams
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.ConfiguredTeams }}'
    item:
      TenantId: '{{ item.TenantId }}'
      TeamId: '{{ item.TeamId }}'
      TeamName: '{{ item.TeamName }}'
      State: '{{ item.State }}'
      StateReason: '{{ item.StateReason }}'
- discovery_id: aws.chatbot.listMicrosoftTeamsUserIdentities
  calls:
  - action: listMicrosoftTeamsUserIdentities
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.TeamsUserIdentities }}'
    item:
      IamRoleArn: '{{ item.IamRoleArn }}'
      ChatConfigurationArn: '{{ item.ChatConfigurationArn }}'
      TeamId: '{{ item.TeamId }}'
      UserId: '{{ item.UserId }}'
      AwsUserIdentity: '{{ item.AwsUserIdentity }}'
      TeamsChannelId: '{{ item.TeamsChannelId }}'
      TeamsTenantId: '{{ item.TeamsTenantId }}'
- discovery_id: aws.chatbot.getCustomAction
  calls:
  - action: getCustomAction
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.CustomAction }}'
    item:
      CustomActionArn: '{{ item.CustomActionArn }}'
      Definition: '{{ item.Definition }}'
      AliasName: '{{ item.AliasName }}'
      Attachments: '{{ item.Attachments }}'
      ActionName: '{{ item.ActionName }}'
- discovery_id: aws.chatbot.getMicrosoftTeamsChannelConfiguration
  calls:
  - action: getMicrosoftTeamsChannelConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ChannelConfiguration }}'
    item:
      ChannelId: '{{ item.ChannelId }}'
      ChannelName: '{{ item.ChannelName }}'
      TeamId: '{{ item.TeamId }}'
      TeamName: '{{ item.TeamName }}'
      TenantId: '{{ item.TenantId }}'
      ChatConfigurationArn: '{{ item.ChatConfigurationArn }}'
      IamRoleArn: '{{ item.IamRoleArn }}'
      SnsTopicArns: '{{ item.SnsTopicArns }}'
      ConfigurationName: '{{ item.ConfigurationName }}'
      LoggingLevel: '{{ item.LoggingLevel }}'
      GuardrailPolicyArns: '{{ item.GuardrailPolicyArns }}'
      UserAuthorizationRequired: '{{ item.UserAuthorizationRequired }}'
      Tags: '{{ item.Tags }}'
      State: '{{ item.State }}'
      StateReason: '{{ item.StateReason }}'
- discovery_id: aws.chatbot.listAssociations
  calls:
  - action: listAssociations
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Associations }}'
    item:
      Resource: '{{ item.Resource }}'
- discovery_id: aws.chatbot.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Tags }}'
    item:
      TagKey: '{{ item.TagKey }}'
      TagValue: '{{ item.TagValue }}'
checks: []
