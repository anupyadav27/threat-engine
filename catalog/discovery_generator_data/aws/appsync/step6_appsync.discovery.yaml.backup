version: '1.0'
provider: aws
service: appsync
services:
  client: appsync
  module: boto3.client
discovery:
- discovery_id: aws.appsync.listApis
  calls:
  - action: listApis
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.apis }}'
    item:
      apiId: '{{ item.apiId }}'
      name: '{{ item.name }}'
      ownerContact: '{{ item.ownerContact }}'
      tags: '{{ item.tags }}'
      dns: '{{ item.dns }}'
      apiArn: '{{ item.apiArn }}'
      created: '{{ item.created }}'
      xrayEnabled: '{{ item.xrayEnabled }}'
      wafWebAclArn: '{{ item.wafWebAclArn }}'
      eventConfig: '{{ item.eventConfig }}'
- discovery_id: aws.appsync.listDomainNames
  calls:
  - action: listDomainNames
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.domainNameConfigs }}'
    item:
      domainName: '{{ item.domainName }}'
      description: '{{ item.description }}'
      certificateArn: '{{ item.certificateArn }}'
      appsyncDomainName: '{{ item.appsyncDomainName }}'
      hostedZoneId: '{{ item.hostedZoneId }}'
      tags: '{{ item.tags }}'
      domainNameArn: '{{ item.domainNameArn }}'
- discovery_id: aws.appsync.listGraphqlApis
  calls:
  - action: listGraphqlApis
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.graphqlApis }}'
    item:
      name: '{{ item.name }}'
      apiId: '{{ item.apiId }}'
      authenticationType: '{{ item.authenticationType }}'
      logConfig: '{{ item.logConfig }}'
      userPoolConfig: '{{ item.userPoolConfig }}'
      openIDConnectConfig: '{{ item.openIDConnectConfig }}'
      arn: '{{ item.arn }}'
      uris: '{{ item.uris }}'
      tags: '{{ item.tags }}'
      additionalAuthenticationProviders: '{{ item.additionalAuthenticationProviders
        }}'
      xrayEnabled: '{{ item.xrayEnabled }}'
      wafWebAclArn: '{{ item.wafWebAclArn }}'
      lambdaAuthorizerConfig: '{{ item.lambdaAuthorizerConfig }}'
      dns: '{{ item.dns }}'
      visibility: '{{ item.visibility }}'
      apiType: '{{ item.apiType }}'
      mergedApiExecutionRoleArn: '{{ item.mergedApiExecutionRoleArn }}'
      owner: '{{ item.owner }}'
      ownerContact: '{{ item.ownerContact }}'
      introspectionConfig: '{{ item.introspectionConfig }}'
      queryDepthLimit: '{{ item.queryDepthLimit }}'
      resolverCountLimit: '{{ item.resolverCountLimit }}'
      enhancedMetricsConfig: '{{ item.enhancedMetricsConfig }}'
- discovery_id: aws.appsync.getApi
  calls:
  - action: getApi
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.api }}'
    item:
      apiId: '{{ item.apiId }}'
      name: '{{ item.name }}'
      ownerContact: '{{ item.ownerContact }}'
      tags: '{{ item.tags }}'
      dns: '{{ item.dns }}'
      apiArn: '{{ item.apiArn }}'
      created: '{{ item.created }}'
      xrayEnabled: '{{ item.xrayEnabled }}'
      wafWebAclArn: '{{ item.wafWebAclArn }}'
      eventConfig: '{{ item.eventConfig }}'
- discovery_id: aws.appsync.getApiAssociation
  calls:
  - action: getApiAssociation
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.apiAssociation }}'
    item:
      domainName: '{{ item.domainName }}'
      apiId: '{{ item.apiId }}'
      associationStatus: '{{ item.associationStatus }}'
      deploymentDetail: '{{ item.deploymentDetail }}'
- discovery_id: aws.appsync.getApiCache
  calls:
  - action: getApiCache
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.apiCache }}'
    item:
      ttl: '{{ item.ttl }}'
      apiCachingBehavior: '{{ item.apiCachingBehavior }}'
      transitEncryptionEnabled: '{{ item.transitEncryptionEnabled }}'
      atRestEncryptionEnabled: '{{ item.atRestEncryptionEnabled }}'
      type: '{{ item.type }}'
      status: '{{ item.status }}'
      healthMetricsConfig: '{{ item.healthMetricsConfig }}'
- discovery_id: aws.appsync.getChannelNamespace
  calls:
  - action: getChannelNamespace
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.channelNamespace }}'
    item:
      apiId: '{{ item.apiId }}'
      name: '{{ item.name }}'
      subscribeAuthModes: '{{ item.subscribeAuthModes }}'
      publishAuthModes: '{{ item.publishAuthModes }}'
      codeHandlers: '{{ item.codeHandlers }}'
      tags: '{{ item.tags }}'
      channelNamespaceArn: '{{ item.channelNamespaceArn }}'
      created: '{{ item.created }}'
      lastModified: '{{ item.lastModified }}'
      handlerConfigs: '{{ item.handlerConfigs }}'
- discovery_id: aws.appsync.getDataSource
  calls:
  - action: getDataSource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.dataSource }}'
    item:
      dataSourceArn: '{{ item.dataSourceArn }}'
      name: '{{ item.name }}'
      description: '{{ item.description }}'
      type: '{{ item.type }}'
      serviceRoleArn: '{{ item.serviceRoleArn }}'
      dynamodbConfig: '{{ item.dynamodbConfig }}'
      lambdaConfig: '{{ item.lambdaConfig }}'
      elasticsearchConfig: '{{ item.elasticsearchConfig }}'
      openSearchServiceConfig: '{{ item.openSearchServiceConfig }}'
      httpConfig: '{{ item.httpConfig }}'
      relationalDatabaseConfig: '{{ item.relationalDatabaseConfig }}'
      eventBridgeConfig: '{{ item.eventBridgeConfig }}'
      metricsConfig: '{{ item.metricsConfig }}'
- discovery_id: aws.appsync.getDataSourceIntrospection
  calls:
  - action: getDataSourceIntrospection
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.introspectionResult }}'
    item:
      models: '{{ item.models }}'
      nextToken: '{{ item.nextToken }}'
- discovery_id: aws.appsync.getDomainName
  calls:
  - action: getDomainName
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.domainNameConfig }}'
    item:
      domainName: '{{ item.domainName }}'
      description: '{{ item.description }}'
      certificateArn: '{{ item.certificateArn }}'
      appsyncDomainName: '{{ item.appsyncDomainName }}'
      hostedZoneId: '{{ item.hostedZoneId }}'
      tags: '{{ item.tags }}'
      domainNameArn: '{{ item.domainNameArn }}'
- discovery_id: aws.appsync.getFunction
  calls:
  - action: getFunction
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.functionConfiguration }}'
    item:
      functionId: '{{ item.functionId }}'
      functionArn: '{{ item.functionArn }}'
      name: '{{ item.name }}'
      description: '{{ item.description }}'
      dataSourceName: '{{ item.dataSourceName }}'
      requestMappingTemplate: '{{ item.requestMappingTemplate }}'
      responseMappingTemplate: '{{ item.responseMappingTemplate }}'
      functionVersion: '{{ item.functionVersion }}'
      syncConfig: '{{ item.syncConfig }}'
      maxBatchSize: '{{ item.maxBatchSize }}'
      runtime: '{{ item.runtime }}'
      code: '{{ item.code }}'
- discovery_id: aws.appsync.getGraphqlApi
  calls:
  - action: getGraphqlApi
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.graphqlApi }}'
    item:
      name: '{{ item.name }}'
      apiId: '{{ item.apiId }}'
      authenticationType: '{{ item.authenticationType }}'
      logConfig: '{{ item.logConfig }}'
      userPoolConfig: '{{ item.userPoolConfig }}'
      openIDConnectConfig: '{{ item.openIDConnectConfig }}'
      arn: '{{ item.arn }}'
      uris: '{{ item.uris }}'
      tags: '{{ item.tags }}'
      additionalAuthenticationProviders: '{{ item.additionalAuthenticationProviders
        }}'
      xrayEnabled: '{{ item.xrayEnabled }}'
      wafWebAclArn: '{{ item.wafWebAclArn }}'
      lambdaAuthorizerConfig: '{{ item.lambdaAuthorizerConfig }}'
      dns: '{{ item.dns }}'
      visibility: '{{ item.visibility }}'
      apiType: '{{ item.apiType }}'
      mergedApiExecutionRoleArn: '{{ item.mergedApiExecutionRoleArn }}'
      owner: '{{ item.owner }}'
      ownerContact: '{{ item.ownerContact }}'
      introspectionConfig: '{{ item.introspectionConfig }}'
      queryDepthLimit: '{{ item.queryDepthLimit }}'
      resolverCountLimit: '{{ item.resolverCountLimit }}'
      enhancedMetricsConfig: '{{ item.enhancedMetricsConfig }}'
- discovery_id: aws.appsync.getGraphqlApiEnvironmentVariables
  calls:
  - action: getGraphqlApiEnvironmentVariables
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.environmentVariables }}'
- discovery_id: aws.appsync.getIntrospectionSchema
  calls:
  - action: getIntrospectionSchema
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.schema }}'
- discovery_id: aws.appsync.getResolver
  calls:
  - action: getResolver
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.resolver }}'
    item:
      typeName: '{{ item.typeName }}'
      fieldName: '{{ item.fieldName }}'
      dataSourceName: '{{ item.dataSourceName }}'
      resolverArn: '{{ item.resolverArn }}'
      requestMappingTemplate: '{{ item.requestMappingTemplate }}'
      responseMappingTemplate: '{{ item.responseMappingTemplate }}'
      kind: '{{ item.kind }}'
      pipelineConfig: '{{ item.pipelineConfig }}'
      syncConfig: '{{ item.syncConfig }}'
      cachingConfig: '{{ item.cachingConfig }}'
      maxBatchSize: '{{ item.maxBatchSize }}'
      runtime: '{{ item.runtime }}'
      code: '{{ item.code }}'
      metricsConfig: '{{ item.metricsConfig }}'
- discovery_id: aws.appsync.getSchemaCreationStatus
  calls:
  - action: getSchemaCreationStatus
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.status }}'
- discovery_id: aws.appsync.getSourceApiAssociation
  calls:
  - action: getSourceApiAssociation
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.sourceApiAssociation }}'
    item:
      associationId: '{{ item.associationId }}'
      associationArn: '{{ item.associationArn }}'
      sourceApiId: '{{ item.sourceApiId }}'
      sourceApiArn: '{{ item.sourceApiArn }}'
      mergedApiArn: '{{ item.mergedApiArn }}'
      mergedApiId: '{{ item.mergedApiId }}'
      description: '{{ item.description }}'
      sourceApiAssociationConfig: '{{ item.sourceApiAssociationConfig }}'
      sourceApiAssociationStatus: '{{ item.sourceApiAssociationStatus }}'
      sourceApiAssociationStatusDetail: '{{ item.sourceApiAssociationStatusDetail
        }}'
      lastSuccessfulMergeDate: '{{ item.lastSuccessfulMergeDate }}'
- discovery_id: aws.appsync.getType
  calls:
  - action: getType
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.type }}'
    item:
      name: '{{ item.name }}'
      description: '{{ item.description }}'
      arn: '{{ item.arn }}'
      definition: '{{ item.definition }}'
      format: '{{ item.format }}'
- discovery_id: aws.appsync.listApiKeys
  calls:
  - action: listApiKeys
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.apiKeys }}'
    item:
      id: '{{ item.id }}'
      description: '{{ item.description }}'
      expires: '{{ item.expires }}'
      deletes: '{{ item.deletes }}'
- discovery_id: aws.appsync.listChannelNamespaces
  calls:
  - action: listChannelNamespaces
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.channelNamespaces }}'
    item:
      apiId: '{{ item.apiId }}'
      name: '{{ item.name }}'
      subscribeAuthModes: '{{ item.subscribeAuthModes }}'
      publishAuthModes: '{{ item.publishAuthModes }}'
      codeHandlers: '{{ item.codeHandlers }}'
      tags: '{{ item.tags }}'
      channelNamespaceArn: '{{ item.channelNamespaceArn }}'
      created: '{{ item.created }}'
      lastModified: '{{ item.lastModified }}'
      handlerConfigs: '{{ item.handlerConfigs }}'
- discovery_id: aws.appsync.listDataSources
  calls:
  - action: listDataSources
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.dataSources }}'
    item:
      dataSourceArn: '{{ item.dataSourceArn }}'
      name: '{{ item.name }}'
      description: '{{ item.description }}'
      type: '{{ item.type }}'
      serviceRoleArn: '{{ item.serviceRoleArn }}'
      dynamodbConfig: '{{ item.dynamodbConfig }}'
      lambdaConfig: '{{ item.lambdaConfig }}'
      elasticsearchConfig: '{{ item.elasticsearchConfig }}'
      openSearchServiceConfig: '{{ item.openSearchServiceConfig }}'
      httpConfig: '{{ item.httpConfig }}'
      relationalDatabaseConfig: '{{ item.relationalDatabaseConfig }}'
      eventBridgeConfig: '{{ item.eventBridgeConfig }}'
      metricsConfig: '{{ item.metricsConfig }}'
- discovery_id: aws.appsync.listFunctions
  calls:
  - action: listFunctions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.functions }}'
    item:
      functionId: '{{ item.functionId }}'
      functionArn: '{{ item.functionArn }}'
      name: '{{ item.name }}'
      description: '{{ item.description }}'
      dataSourceName: '{{ item.dataSourceName }}'
      requestMappingTemplate: '{{ item.requestMappingTemplate }}'
      responseMappingTemplate: '{{ item.responseMappingTemplate }}'
      functionVersion: '{{ item.functionVersion }}'
      syncConfig: '{{ item.syncConfig }}'
      maxBatchSize: '{{ item.maxBatchSize }}'
      runtime: '{{ item.runtime }}'
      code: '{{ item.code }}'
- discovery_id: aws.appsync.listResolvers
  calls:
  - action: listResolvers
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.resolvers }}'
    item:
      typeName: '{{ item.typeName }}'
      fieldName: '{{ item.fieldName }}'
      dataSourceName: '{{ item.dataSourceName }}'
      resolverArn: '{{ item.resolverArn }}'
      requestMappingTemplate: '{{ item.requestMappingTemplate }}'
      responseMappingTemplate: '{{ item.responseMappingTemplate }}'
      kind: '{{ item.kind }}'
      pipelineConfig: '{{ item.pipelineConfig }}'
      syncConfig: '{{ item.syncConfig }}'
      cachingConfig: '{{ item.cachingConfig }}'
      maxBatchSize: '{{ item.maxBatchSize }}'
      runtime: '{{ item.runtime }}'
      code: '{{ item.code }}'
      metricsConfig: '{{ item.metricsConfig }}'
- discovery_id: aws.appsync.listResolversByFunction
  calls:
  - action: listResolversByFunction
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.resolvers }}'
    item:
      typeName: '{{ item.typeName }}'
      fieldName: '{{ item.fieldName }}'
      dataSourceName: '{{ item.dataSourceName }}'
      resolverArn: '{{ item.resolverArn }}'
      requestMappingTemplate: '{{ item.requestMappingTemplate }}'
      responseMappingTemplate: '{{ item.responseMappingTemplate }}'
      kind: '{{ item.kind }}'
      pipelineConfig: '{{ item.pipelineConfig }}'
      syncConfig: '{{ item.syncConfig }}'
      cachingConfig: '{{ item.cachingConfig }}'
      maxBatchSize: '{{ item.maxBatchSize }}'
      runtime: '{{ item.runtime }}'
      code: '{{ item.code }}'
      metricsConfig: '{{ item.metricsConfig }}'
- discovery_id: aws.appsync.listSourceApiAssociations
  calls:
  - action: listSourceApiAssociations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.sourceApiAssociationSummaries }}'
    item:
      associationId: '{{ item.associationId }}'
      associationArn: '{{ item.associationArn }}'
      sourceApiId: '{{ item.sourceApiId }}'
      sourceApiArn: '{{ item.sourceApiArn }}'
      mergedApiId: '{{ item.mergedApiId }}'
      mergedApiArn: '{{ item.mergedApiArn }}'
      description: '{{ item.description }}'
- discovery_id: aws.appsync.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tags }}'
- discovery_id: aws.appsync.listTypes
  calls:
  - action: listTypes
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.types }}'
    item:
      name: '{{ item.name }}'
      description: '{{ item.description }}'
      arn: '{{ item.arn }}'
      definition: '{{ item.definition }}'
      format: '{{ item.format }}'
- discovery_id: aws.appsync.listTypesByAssociation
  calls:
  - action: listTypesByAssociation
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.types }}'
    item:
      name: '{{ item.name }}'
      description: '{{ item.description }}'
      arn: '{{ item.arn }}'
      definition: '{{ item.definition }}'
      format: '{{ item.format }}'
checks: []
