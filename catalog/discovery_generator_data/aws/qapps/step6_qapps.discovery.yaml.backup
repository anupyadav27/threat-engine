version: '1.0'
provider: aws
service: qapps
services:
  client: qapps
  module: boto3.client
discovery:
- discovery_id: aws.qapps.describeQAppPermissions
  calls:
  - action: describeQAppPermissions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.permissions }}'
    item:
      action: '{{ item.action }}'
      principal: '{{ item.principal }}'
- discovery_id: aws.qapps.getLibraryItem
  calls:
  - action: getLibraryItem
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.categories }}'
    item:
      id: '{{ item.id }}'
      title: '{{ item.title }}'
      color: '{{ item.color }}'
      appCount: '{{ item.appCount }}'
- discovery_id: aws.qapps.getQApp
  calls:
  - action: getQApp
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.requiredCapabilities }}'
- discovery_id: aws.qapps.getQAppSession
  calls:
  - action: getQAppSession
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.sessionId }}'
- discovery_id: aws.qapps.getQAppSessionMetadata
  calls:
  - action: getQAppSessionMetadata
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.sharingConfiguration }}'
    item:
      enabled: '{{ item.enabled }}'
      acceptResponses: '{{ item.acceptResponses }}'
      revealCards: '{{ item.revealCards }}'
- discovery_id: aws.qapps.listCategories
  calls:
  - action: listCategories
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.categories }}'
    item:
      id: '{{ item.id }}'
      title: '{{ item.title }}'
      color: '{{ item.color }}'
      appCount: '{{ item.appCount }}'
- discovery_id: aws.qapps.listLibraryItems
  calls:
  - action: listLibraryItems
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.libraryItems }}'
    item:
      libraryItemId: '{{ item.libraryItemId }}'
      appId: '{{ item.appId }}'
      appVersion: '{{ item.appVersion }}'
      categories: '{{ item.categories }}'
      status: '{{ item.status }}'
      createdAt: '{{ item.createdAt }}'
      createdBy: '{{ item.createdBy }}'
      updatedAt: '{{ item.updatedAt }}'
      updatedBy: '{{ item.updatedBy }}'
      ratingCount: '{{ item.ratingCount }}'
      isRatedByUser: '{{ item.isRatedByUser }}'
      userCount: '{{ item.userCount }}'
      isVerified: '{{ item.isVerified }}'
- discovery_id: aws.qapps.listQAppSessionData
  calls:
  - action: listQAppSessionData
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.sessionData }}'
    item:
      cardId: '{{ item.cardId }}'
      value: '{{ item.value }}'
      user: '{{ item.user }}'
      submissionId: '{{ item.submissionId }}'
      timestamp: '{{ item.timestamp }}'
- discovery_id: aws.qapps.listQApps
  calls:
  - action: listQApps
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.apps }}'
    item:
      appId: '{{ item.appId }}'
      appArn: '{{ item.appArn }}'
      title: '{{ item.title }}'
      description: '{{ item.description }}'
      createdAt: '{{ item.createdAt }}'
      canEdit: '{{ item.canEdit }}'
      status: '{{ item.status }}'
      isVerified: '{{ item.isVerified }}'
- discovery_id: aws.qapps.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tags }}'
checks: []
