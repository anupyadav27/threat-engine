version: '1.0'
provider: aws
service: lex-runtime
services:
  client: lex-runtime
  module: boto3.client
discovery:
- discovery_id: aws.lex-runtime.getSession
  calls:
  - action: getSession
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.recentIntentSummaryView }}'
    item:
      intentName: '{{ item.intentName }}'
      checkpointLabel: '{{ item.checkpointLabel }}'
      slots: '{{ item.slots }}'
      confirmationStatus: '{{ item.confirmationStatus }}'
      dialogActionType: '{{ item.dialogActionType }}'
      fulfillmentState: '{{ item.fulfillmentState }}'
      slotToElicit: '{{ item.slotToElicit }}'
checks: []
