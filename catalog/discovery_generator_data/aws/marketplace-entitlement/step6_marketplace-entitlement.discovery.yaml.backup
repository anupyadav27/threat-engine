version: '1.0'
provider: aws
service: marketplace-entitlement
services:
  client: marketplace-entitlement
  module: boto3.client
discovery:
- discovery_id: aws.marketplace-entitlement.getEntitlements
  calls:
  - action: getEntitlements
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Entitlements }}'
    item:
      ProductCode: '{{ item.ProductCode }}'
      Dimension: '{{ item.Dimension }}'
      CustomerIdentifier: '{{ item.CustomerIdentifier }}'
      CustomerAWSAccountId: '{{ item.CustomerAWSAccountId }}'
      Value: '{{ item.Value }}'
      ExpirationDate: '{{ item.ExpirationDate }}'
checks: []
