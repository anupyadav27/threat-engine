version: '1.0'
provider: aws
service: workspaces
services:
  client: workspaces
  module: boto3.client
discovery:
- discovery_id: aws.workspaces.describeAccount
  calls:
  - action: describeAccount
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.DedicatedTenancySupport }}'
- discovery_id: aws.workspaces.describeAccountModifications
  calls:
  - action: describeAccountModifications
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AccountModifications }}'
    item:
      ModificationState: '{{ item.ModificationState }}'
      DedicatedTenancySupport: '{{ item.DedicatedTenancySupport }}'
      DedicatedTenancyManagementCidrRange: '{{ item.DedicatedTenancyManagementCidrRange
        }}'
      StartTime: '{{ item.StartTime }}'
      ErrorCode: '{{ item.ErrorCode }}'
      ErrorMessage: '{{ item.ErrorMessage }}'
- discovery_id: aws.workspaces.describeApplications
  calls:
  - action: describeApplications
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Applications }}'
    item:
      ApplicationId: '{{ item.ApplicationId }}'
      Created: '{{ item.Created }}'
      Description: '{{ item.Description }}'
      LicenseType: '{{ item.LicenseType }}'
      Name: '{{ item.Name }}'
      Owner: '{{ item.Owner }}'
      State: '{{ item.State }}'
      SupportedComputeTypeNames: '{{ item.SupportedComputeTypeNames }}'
      SupportedOperatingSystemNames: '{{ item.SupportedOperatingSystemNames }}'
- discovery_id: aws.workspaces.describeConnectionAliases
  calls:
  - action: describeConnectionAliases
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ConnectionAliases }}'
    item:
      ConnectionString: '{{ item.ConnectionString }}'
      AliasId: '{{ item.AliasId }}'
      State: '{{ item.State }}'
      OwnerAccountId: '{{ item.OwnerAccountId }}'
      Associations: '{{ item.Associations }}'
- discovery_id: aws.workspaces.describeIpGroups
  calls:
  - action: describeIpGroups
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Result }}'
    item:
      groupId: '{{ item.groupId }}'
      groupName: '{{ item.groupName }}'
      groupDesc: '{{ item.groupDesc }}'
      userRules: '{{ item.userRules }}'
- discovery_id: aws.workspaces.describeWorkspaceBundles
  calls:
  - action: describeWorkspaceBundles
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Bundles }}'
    item:
      BundleId: '{{ item.BundleId }}'
      Name: '{{ item.Name }}'
      Owner: '{{ item.Owner }}'
      Description: '{{ item.Description }}'
      ImageId: '{{ item.ImageId }}'
      RootStorage: '{{ item.RootStorage }}'
      UserStorage: '{{ item.UserStorage }}'
      ComputeType: '{{ item.ComputeType }}'
      LastUpdatedTime: '{{ item.LastUpdatedTime }}'
      CreationTime: '{{ item.CreationTime }}'
      State: '{{ item.State }}'
      BundleType: '{{ item.BundleType }}'
- discovery_id: aws.workspaces.describeWorkspaceDirectories
  calls:
  - action: describeWorkspaceDirectories
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Directories }}'
    item:
      DirectoryId: '{{ item.DirectoryId }}'
      Alias: '{{ item.Alias }}'
      DirectoryName: '{{ item.DirectoryName }}'
      RegistrationCode: '{{ item.RegistrationCode }}'
      SubnetIds: '{{ item.SubnetIds }}'
      DnsIpAddresses: '{{ item.DnsIpAddresses }}'
      DnsIpv6Addresses: '{{ item.DnsIpv6Addresses }}'
      CustomerUserName: '{{ item.CustomerUserName }}'
      IamRoleId: '{{ item.IamRoleId }}'
      DirectoryType: '{{ item.DirectoryType }}'
      WorkspaceSecurityGroupId: '{{ item.WorkspaceSecurityGroupId }}'
      State: '{{ item.State }}'
      WorkspaceCreationProperties: '{{ item.WorkspaceCreationProperties }}'
      ipGroupIds: '{{ item.ipGroupIds }}'
      WorkspaceAccessProperties: '{{ item.WorkspaceAccessProperties }}'
      Tenancy: '{{ item.Tenancy }}'
      SelfservicePermissions: '{{ item.SelfservicePermissions }}'
      SamlProperties: '{{ item.SamlProperties }}'
      CertificateBasedAuthProperties: '{{ item.CertificateBasedAuthProperties }}'
      EndpointEncryptionMode: '{{ item.EndpointEncryptionMode }}'
      MicrosoftEntraConfig: '{{ item.MicrosoftEntraConfig }}'
      WorkspaceDirectoryName: '{{ item.WorkspaceDirectoryName }}'
      WorkspaceDirectoryDescription: '{{ item.WorkspaceDirectoryDescription }}'
      UserIdentityType: '{{ item.UserIdentityType }}'
      WorkspaceType: '{{ item.WorkspaceType }}'
      IDCConfig: '{{ item.IDCConfig }}'
      ActiveDirectoryConfig: '{{ item.ActiveDirectoryConfig }}'
      StreamingProperties: '{{ item.StreamingProperties }}'
      ErrorMessage: '{{ item.ErrorMessage }}'
- discovery_id: aws.workspaces.describeWorkspaceImages
  calls:
  - action: describeWorkspaceImages
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Images }}'
    item:
      ImageId: '{{ item.ImageId }}'
      Name: '{{ item.Name }}'
      Description: '{{ item.Description }}'
      OperatingSystem: '{{ item.OperatingSystem }}'
      State: '{{ item.State }}'
      RequiredTenancy: '{{ item.RequiredTenancy }}'
      ErrorCode: '{{ item.ErrorCode }}'
      ErrorMessage: '{{ item.ErrorMessage }}'
      Created: '{{ item.Created }}'
      OwnerAccountId: '{{ item.OwnerAccountId }}'
      Updates: '{{ item.Updates }}'
      ErrorDetails: '{{ item.ErrorDetails }}'
- discovery_id: aws.workspaces.describeWorkspaces
  calls:
  - action: describeWorkspaces
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Workspaces }}'
    item:
      WorkspaceId: '{{ item.WorkspaceId }}'
      DirectoryId: '{{ item.DirectoryId }}'
      UserName: '{{ item.UserName }}'
      IpAddress: '{{ item.IpAddress }}'
      Ipv6Address: '{{ item.Ipv6Address }}'
      State: '{{ item.State }}'
      BundleId: '{{ item.BundleId }}'
      SubnetId: '{{ item.SubnetId }}'
      ErrorMessage: '{{ item.ErrorMessage }}'
      ErrorCode: '{{ item.ErrorCode }}'
      ComputerName: '{{ item.ComputerName }}'
      VolumeEncryptionKey: '{{ item.VolumeEncryptionKey }}'
      UserVolumeEncryptionEnabled: '{{ item.UserVolumeEncryptionEnabled }}'
      RootVolumeEncryptionEnabled: '{{ item.RootVolumeEncryptionEnabled }}'
      WorkspaceName: '{{ item.WorkspaceName }}'
      WorkspaceProperties: '{{ item.WorkspaceProperties }}'
      ModificationStates: '{{ item.ModificationStates }}'
      RelatedWorkspaces: '{{ item.RelatedWorkspaces }}'
      DataReplicationSettings: '{{ item.DataReplicationSettings }}'
      StandbyWorkspacesProperties: '{{ item.StandbyWorkspacesProperties }}'
- discovery_id: aws.workspaces.describeWorkspacesConnectionStatus
  calls:
  - action: describeWorkspacesConnectionStatus
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.WorkspacesConnectionStatus }}'
    item:
      WorkspaceId: '{{ item.WorkspaceId }}'
      ConnectionState: '{{ item.ConnectionState }}'
      ConnectionStateCheckTimestamp: '{{ item.ConnectionStateCheckTimestamp }}'
      LastKnownUserConnectionTimestamp: '{{ item.LastKnownUserConnectionTimestamp
        }}'
- discovery_id: aws.workspaces.describeWorkspacesPools
  calls:
  - action: describeWorkspacesPools
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.WorkspacesPools }}'
    item:
      PoolId: '{{ item.PoolId }}'
      PoolArn: '{{ item.PoolArn }}'
      CapacityStatus: '{{ item.CapacityStatus }}'
      PoolName: '{{ item.PoolName }}'
      Description: '{{ item.Description }}'
      State: '{{ item.State }}'
      CreatedAt: '{{ item.CreatedAt }}'
      BundleId: '{{ item.BundleId }}'
      DirectoryId: '{{ item.DirectoryId }}'
      Errors: '{{ item.Errors }}'
      ApplicationSettings: '{{ item.ApplicationSettings }}'
      TimeoutSettings: '{{ item.TimeoutSettings }}'
      RunningMode: '{{ item.RunningMode }}'
- discovery_id: aws.workspaces.getAccountLink
  calls:
  - action: getAccountLink
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AccountLink }}'
    item:
      AccountLinkId: '{{ item.AccountLinkId }}'
      AccountLinkStatus: '{{ item.AccountLinkStatus }}'
      SourceAccountId: '{{ item.SourceAccountId }}'
      TargetAccountId: '{{ item.TargetAccountId }}'
- discovery_id: aws.workspaces.listAccountLinks
  calls:
  - action: listAccountLinks
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.AccountLinks }}'
    item:
      AccountLinkId: '{{ item.AccountLinkId }}'
      AccountLinkStatus: '{{ item.AccountLinkStatus }}'
      SourceAccountId: '{{ item.SourceAccountId }}'
      TargetAccountId: '{{ item.TargetAccountId }}'
- discovery_id: aws.workspaces.describeApplicationAssociations
  calls:
  - action: describeApplicationAssociations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Associations }}'
    item:
      ApplicationId: '{{ item.ApplicationId }}'
      AssociatedResourceId: '{{ item.AssociatedResourceId }}'
      AssociatedResourceType: '{{ item.AssociatedResourceType }}'
      Created: '{{ item.Created }}'
      LastUpdatedTime: '{{ item.LastUpdatedTime }}'
      State: '{{ item.State }}'
      StateReason: '{{ item.StateReason }}'
- discovery_id: aws.workspaces.describeBundleAssociations
  calls:
  - action: describeBundleAssociations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Associations }}'
    item:
      AssociatedResourceId: '{{ item.AssociatedResourceId }}'
      AssociatedResourceType: '{{ item.AssociatedResourceType }}'
      BundleId: '{{ item.BundleId }}'
      Created: '{{ item.Created }}'
      LastUpdatedTime: '{{ item.LastUpdatedTime }}'
      State: '{{ item.State }}'
      StateReason: '{{ item.StateReason }}'
- discovery_id: aws.workspaces.describeClientBranding
  calls:
  - action: describeClientBranding
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.DeviceTypeWindows }}'
    item:
      LogoUrl: '{{ item.LogoUrl }}'
      SupportEmail: '{{ item.SupportEmail }}'
      SupportLink: '{{ item.SupportLink }}'
      ForgotPasswordLink: '{{ item.ForgotPasswordLink }}'
      LoginMessage: '{{ item.LoginMessage }}'
- discovery_id: aws.workspaces.describeClientProperties
  calls:
  - action: describeClientProperties
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ClientPropertiesList }}'
    item:
      ResourceId: '{{ item.ResourceId }}'
      ClientProperties: '{{ item.ClientProperties }}'
- discovery_id: aws.workspaces.describeConnectClientAddIns
  calls:
  - action: describeConnectClientAddIns
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AddIns }}'
    item:
      AddInId: '{{ item.AddInId }}'
      ResourceId: '{{ item.ResourceId }}'
      Name: '{{ item.Name }}'
      URL: '{{ item.URL }}'
- discovery_id: aws.workspaces.describeConnectionAliasPermissions
  calls:
  - action: describeConnectionAliasPermissions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ConnectionAliasPermissions }}'
    item:
      SharedAccountId: '{{ item.SharedAccountId }}'
      AllowAssociation: '{{ item.AllowAssociation }}'
- discovery_id: aws.workspaces.describeCustomWorkspaceImageImport
  calls:
  - action: describeCustomWorkspaceImageImport
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ErrorDetails }}'
    item:
      ErrorCode: '{{ item.ErrorCode }}'
      ErrorMessage: '{{ item.ErrorMessage }}'
- discovery_id: aws.workspaces.describeImageAssociations
  calls:
  - action: describeImageAssociations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Associations }}'
    item:
      AssociatedResourceId: '{{ item.AssociatedResourceId }}'
      AssociatedResourceType: '{{ item.AssociatedResourceType }}'
      Created: '{{ item.Created }}'
      LastUpdatedTime: '{{ item.LastUpdatedTime }}'
      ImageId: '{{ item.ImageId }}'
      State: '{{ item.State }}'
      StateReason: '{{ item.StateReason }}'
- discovery_id: aws.workspaces.describeTags
  calls:
  - action: describeTags
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.TagList }}'
    item:
      Key: '{{ item.Key }}'
      Value: '{{ item.Value }}'
- discovery_id: aws.workspaces.describeWorkspaceAssociations
  calls:
  - action: describeWorkspaceAssociations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Associations }}'
    item:
      AssociatedResourceId: '{{ item.AssociatedResourceId }}'
      AssociatedResourceType: '{{ item.AssociatedResourceType }}'
      Created: '{{ item.Created }}'
      LastUpdatedTime: '{{ item.LastUpdatedTime }}'
      State: '{{ item.State }}'
      StateReason: '{{ item.StateReason }}'
      WorkspaceId: '{{ item.WorkspaceId }}'
- discovery_id: aws.workspaces.describeWorkspaceImagePermissions
  calls:
  - action: describeWorkspaceImagePermissions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ImagePermissions }}'
    item:
      SharedAccountId: '{{ item.SharedAccountId }}'
- discovery_id: aws.workspaces.describeWorkspaceSnapshots
  calls:
  - action: describeWorkspaceSnapshots
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.RebuildSnapshots }}'
    item:
      SnapshotTime: '{{ item.SnapshotTime }}'
- discovery_id: aws.workspaces.describeWorkspacesPoolSessions
  calls:
  - action: describeWorkspacesPoolSessions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Sessions }}'
    item:
      AuthenticationType: '{{ item.AuthenticationType }}'
      ConnectionState: '{{ item.ConnectionState }}'
      SessionId: '{{ item.SessionId }}'
      InstanceId: '{{ item.InstanceId }}'
      PoolId: '{{ item.PoolId }}'
      ExpirationTime: '{{ item.ExpirationTime }}'
      NetworkAccessConfiguration: '{{ item.NetworkAccessConfiguration }}'
      StartTime: '{{ item.StartTime }}'
      UserId: '{{ item.UserId }}'
- discovery_id: aws.workspaces.listAvailableManagementCidrRanges
  calls:
  - action: listAvailableManagementCidrRanges
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.ManagementCidrRanges }}'
checks: []
