version: '1.0'
provider: aws
service: internetmonitor
services:
  client: internetmonitor
  module: boto3.client
discovery:
- discovery_id: aws.internetmonitor.listInternetEvents
  calls:
  - action: listInternetEvents
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.InternetEvents }}'
    item:
      EventId: '{{ item.EventId }}'
      EventArn: '{{ item.EventArn }}'
      StartedAt: '{{ item.StartedAt }}'
      EndedAt: '{{ item.EndedAt }}'
      ClientLocation: '{{ item.ClientLocation }}'
      EventType: '{{ item.EventType }}'
      EventStatus: '{{ item.EventStatus }}'
- discovery_id: aws.internetmonitor.listMonitors
  calls:
  - action: listMonitors
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Monitors }}'
    item:
      MonitorName: '{{ item.MonitorName }}'
      MonitorArn: '{{ item.MonitorArn }}'
      Status: '{{ item.Status }}'
      ProcessingStatus: '{{ item.ProcessingStatus }}'
- discovery_id: aws.internetmonitor.getHealthEvent
  calls:
  - action: getHealthEvent
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ImpactedLocations }}'
    item:
      ASName: '{{ item.ASName }}'
      ASNumber: '{{ item.ASNumber }}'
      Country: '{{ item.Country }}'
      Subdivision: '{{ item.Subdivision }}'
      Metro: '{{ item.Metro }}'
      City: '{{ item.City }}'
      Latitude: '{{ item.Latitude }}'
      Longitude: '{{ item.Longitude }}'
      CountryCode: '{{ item.CountryCode }}'
      SubdivisionCode: '{{ item.SubdivisionCode }}'
      ServiceLocation: '{{ item.ServiceLocation }}'
      Status: '{{ item.Status }}'
      CausedBy: '{{ item.CausedBy }}'
      InternetHealth: '{{ item.InternetHealth }}'
      Ipv4Prefixes: '{{ item.Ipv4Prefixes }}'
- discovery_id: aws.internetmonitor.getInternetEvent
  calls:
  - action: getInternetEvent
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ClientLocation }}'
    item:
      ASName: '{{ item.ASName }}'
      ASNumber: '{{ item.ASNumber }}'
      Country: '{{ item.Country }}'
      Subdivision: '{{ item.Subdivision }}'
      Metro: '{{ item.Metro }}'
      City: '{{ item.City }}'
      Latitude: '{{ item.Latitude }}'
      Longitude: '{{ item.Longitude }}'
- discovery_id: aws.internetmonitor.getMonitor
  calls:
  - action: getMonitor
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Resources }}'
- discovery_id: aws.internetmonitor.getQueryResults
  calls:
  - action: getQueryResults
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Fields }}'
    item:
      Name: '{{ item.Name }}'
      Type: '{{ item.Type }}'
- discovery_id: aws.internetmonitor.getQueryStatus
  calls:
  - action: getQueryStatus
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Status }}'
- discovery_id: aws.internetmonitor.listHealthEvents
  calls:
  - action: listHealthEvents
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.HealthEvents }}'
    item:
      EventArn: '{{ item.EventArn }}'
      EventId: '{{ item.EventId }}'
      StartedAt: '{{ item.StartedAt }}'
      EndedAt: '{{ item.EndedAt }}'
      CreatedAt: '{{ item.CreatedAt }}'
      LastUpdatedAt: '{{ item.LastUpdatedAt }}'
      ImpactedLocations: '{{ item.ImpactedLocations }}'
      Status: '{{ item.Status }}'
      PercentOfTotalTrafficImpacted: '{{ item.PercentOfTotalTrafficImpacted }}'
      ImpactType: '{{ item.ImpactType }}'
      HealthScoreThreshold: '{{ item.HealthScoreThreshold }}'
- discovery_id: aws.internetmonitor.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Tags }}'
checks: []
