version: '1.0'
provider: aws
service: mediaconnect
services:
  client: mediaconnect
  module: boto3.client
discovery:
- discovery_id: aws.mediaconnect.listBridges
  calls:
  - action: listBridges
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Bridges }}'
    item:
      BridgeArn: '{{ item.BridgeArn }}'
      BridgeState: '{{ item.BridgeState }}'
      BridgeType: '{{ item.BridgeType }}'
      Name: '{{ item.Name }}'
      PlacementArn: '{{ item.PlacementArn }}'
- discovery_id: aws.mediaconnect.listEntitlements
  calls:
  - action: listEntitlements
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Entitlements }}'
    item:
      DataTransferSubscriberFeePercent: '{{ item.DataTransferSubscriberFeePercent
        }}'
      EntitlementArn: '{{ item.EntitlementArn }}'
      EntitlementName: '{{ item.EntitlementName }}'
- discovery_id: aws.mediaconnect.listFlows
  calls:
  - action: listFlows
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Flows }}'
    item:
      AvailabilityZone: '{{ item.AvailabilityZone }}'
      Description: '{{ item.Description }}'
      FlowArn: '{{ item.FlowArn }}'
      Name: '{{ item.Name }}'
      SourceType: '{{ item.SourceType }}'
      Status: '{{ item.Status }}'
      Maintenance: '{{ item.Maintenance }}'
- discovery_id: aws.mediaconnect.listGatewayInstances
  calls:
  - action: listGatewayInstances
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Instances }}'
    item:
      GatewayArn: '{{ item.GatewayArn }}'
      GatewayInstanceArn: '{{ item.GatewayInstanceArn }}'
      InstanceId: '{{ item.InstanceId }}'
      InstanceState: '{{ item.InstanceState }}'
- discovery_id: aws.mediaconnect.listGateways
  calls:
  - action: listGateways
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Gateways }}'
    item:
      GatewayArn: '{{ item.GatewayArn }}'
      GatewayState: '{{ item.GatewayState }}'
      Name: '{{ item.Name }}'
- discovery_id: aws.mediaconnect.listOfferings
  calls:
  - action: listOfferings
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Offerings }}'
    item:
      CurrencyCode: '{{ item.CurrencyCode }}'
      Duration: '{{ item.Duration }}'
      DurationUnits: '{{ item.DurationUnits }}'
      OfferingArn: '{{ item.OfferingArn }}'
      OfferingDescription: '{{ item.OfferingDescription }}'
      PricePerUnit: '{{ item.PricePerUnit }}'
      PriceUnits: '{{ item.PriceUnits }}'
      ResourceSpecification: '{{ item.ResourceSpecification }}'
- discovery_id: aws.mediaconnect.listReservations
  calls:
  - action: listReservations
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Reservations }}'
    item:
      CurrencyCode: '{{ item.CurrencyCode }}'
      Duration: '{{ item.Duration }}'
      DurationUnits: '{{ item.DurationUnits }}'
      End: '{{ item.End }}'
      OfferingArn: '{{ item.OfferingArn }}'
      OfferingDescription: '{{ item.OfferingDescription }}'
      PricePerUnit: '{{ item.PricePerUnit }}'
      PriceUnits: '{{ item.PriceUnits }}'
      ReservationArn: '{{ item.ReservationArn }}'
      ReservationName: '{{ item.ReservationName }}'
      ReservationState: '{{ item.ReservationState }}'
      ResourceSpecification: '{{ item.ResourceSpecification }}'
      Start: '{{ item.Start }}'
- discovery_id: aws.mediaconnect.listRouterInputs
  calls:
  - action: listRouterInputs
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.RouterInputs }}'
    item:
      Name: '{{ item.Name }}'
      Arn: '{{ item.Arn }}'
      Id: '{{ item.Id }}'
      InputType: '{{ item.InputType }}'
      State: '{{ item.State }}'
      RoutedOutputs: '{{ item.RoutedOutputs }}'
      RegionName: '{{ item.RegionName }}'
      AvailabilityZone: '{{ item.AvailabilityZone }}'
      MaximumBitrate: '{{ item.MaximumBitrate }}'
      RoutingScope: '{{ item.RoutingScope }}'
      CreatedAt: '{{ item.CreatedAt }}'
      UpdatedAt: '{{ item.UpdatedAt }}'
      MessageCount: '{{ item.MessageCount }}'
      NetworkInterfaceArn: '{{ item.NetworkInterfaceArn }}'
      MaintenanceScheduleType: '{{ item.MaintenanceScheduleType }}'
      MaintenanceSchedule: '{{ item.MaintenanceSchedule }}'
- discovery_id: aws.mediaconnect.listRouterNetworkInterfaces
  calls:
  - action: listRouterNetworkInterfaces
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.RouterNetworkInterfaces }}'
    item:
      Name: '{{ item.Name }}'
      Arn: '{{ item.Arn }}'
      Id: '{{ item.Id }}'
      NetworkInterfaceType: '{{ item.NetworkInterfaceType }}'
      AssociatedOutputCount: '{{ item.AssociatedOutputCount }}'
      AssociatedInputCount: '{{ item.AssociatedInputCount }}'
      State: '{{ item.State }}'
      RegionName: '{{ item.RegionName }}'
      CreatedAt: '{{ item.CreatedAt }}'
      UpdatedAt: '{{ item.UpdatedAt }}'
- discovery_id: aws.mediaconnect.listRouterOutputs
  calls:
  - action: listRouterOutputs
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.RouterOutputs }}'
    item:
      Name: '{{ item.Name }}'
      Arn: '{{ item.Arn }}'
      Id: '{{ item.Id }}'
      OutputType: '{{ item.OutputType }}'
      State: '{{ item.State }}'
      RoutedState: '{{ item.RoutedState }}'
      RegionName: '{{ item.RegionName }}'
      AvailabilityZone: '{{ item.AvailabilityZone }}'
      MaximumBitrate: '{{ item.MaximumBitrate }}'
      RoutingScope: '{{ item.RoutingScope }}'
      CreatedAt: '{{ item.CreatedAt }}'
      UpdatedAt: '{{ item.UpdatedAt }}'
      MessageCount: '{{ item.MessageCount }}'
      RoutedInputArn: '{{ item.RoutedInputArn }}'
      NetworkInterfaceArn: '{{ item.NetworkInterfaceArn }}'
      MaintenanceScheduleType: '{{ item.MaintenanceScheduleType }}'
      MaintenanceSchedule: '{{ item.MaintenanceSchedule }}'
- discovery_id: aws.mediaconnect.describeBridge
  calls:
  - action: describeBridge
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Bridge }}'
    item:
      BridgeArn: '{{ item.BridgeArn }}'
      BridgeMessages: '{{ item.BridgeMessages }}'
      BridgeState: '{{ item.BridgeState }}'
      EgressGatewayBridge: '{{ item.EgressGatewayBridge }}'
      IngressGatewayBridge: '{{ item.IngressGatewayBridge }}'
      Name: '{{ item.Name }}'
      Outputs: '{{ item.Outputs }}'
      PlacementArn: '{{ item.PlacementArn }}'
      SourceFailoverConfig: '{{ item.SourceFailoverConfig }}'
      Sources: '{{ item.Sources }}'
- discovery_id: aws.mediaconnect.describeFlow
  calls:
  - action: describeFlow
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Flow }}'
    item:
      AvailabilityZone: '{{ item.AvailabilityZone }}'
      Description: '{{ item.Description }}'
      EgressIp: '{{ item.EgressIp }}'
      Entitlements: '{{ item.Entitlements }}'
      FlowArn: '{{ item.FlowArn }}'
      MediaStreams: '{{ item.MediaStreams }}'
      Name: '{{ item.Name }}'
      Outputs: '{{ item.Outputs }}'
      Source: '{{ item.Source }}'
      SourceFailoverConfig: '{{ item.SourceFailoverConfig }}'
      Sources: '{{ item.Sources }}'
      Status: '{{ item.Status }}'
      VpcInterfaces: '{{ item.VpcInterfaces }}'
      Maintenance: '{{ item.Maintenance }}'
      SourceMonitoringConfig: '{{ item.SourceMonitoringConfig }}'
      FlowSize: '{{ item.FlowSize }}'
      NdiConfig: '{{ item.NdiConfig }}'
- discovery_id: aws.mediaconnect.describeFlowSourceMetadata
  calls:
  - action: describeFlowSourceMetadata
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Messages }}'
    item:
      Code: '{{ item.Code }}'
      Message: '{{ item.Message }}'
      ResourceName: '{{ item.ResourceName }}'
- discovery_id: aws.mediaconnect.describeFlowSourceThumbnail
  calls:
  - action: describeFlowSourceThumbnail
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ThumbnailDetails }}'
    item:
      FlowArn: '{{ item.FlowArn }}'
      Thumbnail: '{{ item.Thumbnail }}'
      ThumbnailMessages: '{{ item.ThumbnailMessages }}'
      Timecode: '{{ item.Timecode }}'
      Timestamp: '{{ item.Timestamp }}'
- discovery_id: aws.mediaconnect.describeGateway
  calls:
  - action: describeGateway
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Gateway }}'
    item:
      EgressCidrBlocks: '{{ item.EgressCidrBlocks }}'
      GatewayArn: '{{ item.GatewayArn }}'
      GatewayMessages: '{{ item.GatewayMessages }}'
      GatewayState: '{{ item.GatewayState }}'
      Name: '{{ item.Name }}'
      Networks: '{{ item.Networks }}'
- discovery_id: aws.mediaconnect.describeGatewayInstance
  calls:
  - action: describeGatewayInstance
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.GatewayInstance }}'
    item:
      BridgePlacement: '{{ item.BridgePlacement }}'
      ConnectionStatus: '{{ item.ConnectionStatus }}'
      GatewayArn: '{{ item.GatewayArn }}'
      GatewayInstanceArn: '{{ item.GatewayInstanceArn }}'
      InstanceId: '{{ item.InstanceId }}'
      InstanceMessages: '{{ item.InstanceMessages }}'
      InstanceState: '{{ item.InstanceState }}'
      RunningBridgeCount: '{{ item.RunningBridgeCount }}'
- discovery_id: aws.mediaconnect.describeOffering
  calls:
  - action: describeOffering
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Offering }}'
    item:
      CurrencyCode: '{{ item.CurrencyCode }}'
      Duration: '{{ item.Duration }}'
      DurationUnits: '{{ item.DurationUnits }}'
      OfferingArn: '{{ item.OfferingArn }}'
      OfferingDescription: '{{ item.OfferingDescription }}'
      PricePerUnit: '{{ item.PricePerUnit }}'
      PriceUnits: '{{ item.PriceUnits }}'
      ResourceSpecification: '{{ item.ResourceSpecification }}'
- discovery_id: aws.mediaconnect.describeReservation
  calls:
  - action: describeReservation
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Reservation }}'
    item:
      CurrencyCode: '{{ item.CurrencyCode }}'
      Duration: '{{ item.Duration }}'
      DurationUnits: '{{ item.DurationUnits }}'
      End: '{{ item.End }}'
      OfferingArn: '{{ item.OfferingArn }}'
      OfferingDescription: '{{ item.OfferingDescription }}'
      PricePerUnit: '{{ item.PricePerUnit }}'
      PriceUnits: '{{ item.PriceUnits }}'
      ReservationArn: '{{ item.ReservationArn }}'
      ReservationName: '{{ item.ReservationName }}'
      ReservationState: '{{ item.ReservationState }}'
      ResourceSpecification: '{{ item.ResourceSpecification }}'
      Start: '{{ item.Start }}'
- discovery_id: aws.mediaconnect.getRouterInput
  calls:
  - action: getRouterInput
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.RouterInput }}'
    item:
      Name: '{{ item.Name }}'
      Arn: '{{ item.Arn }}'
      Id: '{{ item.Id }}'
      State: '{{ item.State }}'
      InputType: '{{ item.InputType }}'
      Configuration: '{{ item.Configuration }}'
      RoutedOutputs: '{{ item.RoutedOutputs }}'
      MaximumRoutedOutputs: '{{ item.MaximumRoutedOutputs }}'
      RegionName: '{{ item.RegionName }}'
      AvailabilityZone: '{{ item.AvailabilityZone }}'
      MaximumBitrate: '{{ item.MaximumBitrate }}'
      Tier: '{{ item.Tier }}'
      RoutingScope: '{{ item.RoutingScope }}'
      CreatedAt: '{{ item.CreatedAt }}'
      UpdatedAt: '{{ item.UpdatedAt }}'
      Messages: '{{ item.Messages }}'
      TransitEncryption: '{{ item.TransitEncryption }}'
      Tags: '{{ item.Tags }}'
      StreamDetails: '{{ item.StreamDetails }}'
      IpAddress: '{{ item.IpAddress }}'
      MaintenanceType: '{{ item.MaintenanceType }}'
      MaintenanceConfiguration: '{{ item.MaintenanceConfiguration }}'
      MaintenanceScheduleType: '{{ item.MaintenanceScheduleType }}'
      MaintenanceSchedule: '{{ item.MaintenanceSchedule }}'
- discovery_id: aws.mediaconnect.getRouterInputSourceMetadata
  calls:
  - action: getRouterInputSourceMetadata
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.SourceMetadataDetails }}'
    item:
      SourceMetadataMessages: '{{ item.SourceMetadataMessages }}'
      Timestamp: '{{ item.Timestamp }}'
      RouterInputMetadata: '{{ item.RouterInputMetadata }}'
- discovery_id: aws.mediaconnect.getRouterInputThumbnail
  calls:
  - action: getRouterInputThumbnail
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ThumbnailDetails }}'
    item:
      ThumbnailMessages: '{{ item.ThumbnailMessages }}'
      Thumbnail: '{{ item.Thumbnail }}'
      Timecode: '{{ item.Timecode }}'
      Timestamp: '{{ item.Timestamp }}'
- discovery_id: aws.mediaconnect.getRouterNetworkInterface
  calls:
  - action: getRouterNetworkInterface
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.RouterNetworkInterface }}'
    item:
      Name: '{{ item.Name }}'
      Arn: '{{ item.Arn }}'
      Id: '{{ item.Id }}'
      State: '{{ item.State }}'
      NetworkInterfaceType: '{{ item.NetworkInterfaceType }}'
      Configuration: '{{ item.Configuration }}'
      AssociatedOutputCount: '{{ item.AssociatedOutputCount }}'
      AssociatedInputCount: '{{ item.AssociatedInputCount }}'
      RegionName: '{{ item.RegionName }}'
      CreatedAt: '{{ item.CreatedAt }}'
      UpdatedAt: '{{ item.UpdatedAt }}'
      Tags: '{{ item.Tags }}'
- discovery_id: aws.mediaconnect.getRouterOutput
  calls:
  - action: getRouterOutput
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.RouterOutput }}'
    item:
      Name: '{{ item.Name }}'
      Arn: '{{ item.Arn }}'
      Id: '{{ item.Id }}'
      State: '{{ item.State }}'
      OutputType: '{{ item.OutputType }}'
      Configuration: '{{ item.Configuration }}'
      RoutedState: '{{ item.RoutedState }}'
      RegionName: '{{ item.RegionName }}'
      AvailabilityZone: '{{ item.AvailabilityZone }}'
      MaximumBitrate: '{{ item.MaximumBitrate }}'
      RoutingScope: '{{ item.RoutingScope }}'
      Tier: '{{ item.Tier }}'
      CreatedAt: '{{ item.CreatedAt }}'
      UpdatedAt: '{{ item.UpdatedAt }}'
      Messages: '{{ item.Messages }}'
      Tags: '{{ item.Tags }}'
      StreamDetails: '{{ item.StreamDetails }}'
      IpAddress: '{{ item.IpAddress }}'
      RoutedInputArn: '{{ item.RoutedInputArn }}'
      MaintenanceType: '{{ item.MaintenanceType }}'
      MaintenanceConfiguration: '{{ item.MaintenanceConfiguration }}'
      MaintenanceScheduleType: '{{ item.MaintenanceScheduleType }}'
      MaintenanceSchedule: '{{ item.MaintenanceSchedule }}'
- discovery_id: aws.mediaconnect.listTagsForGlobalResource
  calls:
  - action: listTagsForGlobalResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Tags }}'
- discovery_id: aws.mediaconnect.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Tags }}'
checks: []
