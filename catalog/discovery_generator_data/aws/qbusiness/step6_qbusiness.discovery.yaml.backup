version: '1.0'
provider: aws
service: qbusiness
services:
  client: qbusiness
  module: boto3.client
discovery:
- discovery_id: aws.qbusiness.listApplications
  calls:
  - action: listApplications
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.applications }}'
    item:
      displayName: '{{ item.displayName }}'
      applicationId: '{{ item.applicationId }}'
      createdAt: '{{ item.createdAt }}'
      updatedAt: '{{ item.updatedAt }}'
      status: '{{ item.status }}'
      identityType: '{{ item.identityType }}'
      quickSightConfiguration: '{{ item.quickSightConfiguration }}'
- discovery_id: aws.qbusiness.listPluginTypeMetadata
  calls:
  - action: listPluginTypeMetadata
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
    item:
      type: '{{ item.type }}'
      category: '{{ item.category }}'
      description: '{{ item.description }}'
- discovery_id: aws.qbusiness.getApplication
  calls:
  - action: getApplication
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.clientIdsForOIDC }}'
- discovery_id: aws.qbusiness.getChatControlsConfiguration
  calls:
  - action: getChatControlsConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.topicConfigurations }}'
    item:
      name: '{{ item.name }}'
      description: '{{ item.description }}'
      exampleChatMessages: '{{ item.exampleChatMessages }}'
      rules: '{{ item.rules }}'
- discovery_id: aws.qbusiness.getChatResponseConfiguration
  calls:
  - action: getChatResponseConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.inUseConfiguration }}'
    item:
      responseConfigurations: '{{ item.responseConfigurations }}'
      responseConfigurationSummary: '{{ item.responseConfigurationSummary }}'
      status: '{{ item.status }}'
      error: '{{ item.error }}'
      updatedAt: '{{ item.updatedAt }}'
- discovery_id: aws.qbusiness.getDataAccessor
  calls:
  - action: getDataAccessor
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.actionConfigurations }}'
    item:
      action: '{{ item.action }}'
      filterConfiguration: '{{ item.filterConfiguration }}'
- discovery_id: aws.qbusiness.getDataSource
  calls:
  - action: getDataSource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.configuration }}'
- discovery_id: aws.qbusiness.getDocumentContent
  calls:
  - action: getDocumentContent
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.presignedUrl }}'
- discovery_id: aws.qbusiness.getGroup
  calls:
  - action: getGroup
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.statusHistory }}'
    item:
      status: '{{ item.status }}'
      lastUpdatedAt: '{{ item.lastUpdatedAt }}'
      errorDetail: '{{ item.errorDetail }}'
- discovery_id: aws.qbusiness.getIndex
  calls:
  - action: getIndex
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.documentAttributeConfigurations }}'
    item:
      name: '{{ item.name }}'
      type: '{{ item.type }}'
      search: '{{ item.search }}'
- discovery_id: aws.qbusiness.getMedia
  calls:
  - action: getMedia
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.mediaBytes }}'
- discovery_id: aws.qbusiness.getPlugin
  calls:
  - action: getPlugin
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.authConfiguration }}'
    item:
      basicAuthConfiguration: '{{ item.basicAuthConfiguration }}'
      oAuth2ClientCredentialConfiguration: '{{ item.oAuth2ClientCredentialConfiguration
        }}'
      noAuthConfiguration: '{{ item.noAuthConfiguration }}'
      idcAuthConfiguration: '{{ item.idcAuthConfiguration }}'
- discovery_id: aws.qbusiness.getPolicy
  calls:
  - action: getPolicy
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.policy }}'
- discovery_id: aws.qbusiness.getRetriever
  calls:
  - action: getRetriever
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.configuration }}'
    item:
      nativeIndexConfiguration: '{{ item.nativeIndexConfiguration }}'
      kendraIndexConfiguration: '{{ item.kendraIndexConfiguration }}'
- discovery_id: aws.qbusiness.getUser
  calls:
  - action: getUser
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.userAliases }}'
    item:
      indexId: '{{ item.indexId }}'
      dataSourceId: '{{ item.dataSourceId }}'
      userId: '{{ item.userId }}'
- discovery_id: aws.qbusiness.getWebExperience
  calls:
  - action: getWebExperience
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.origins }}'
- discovery_id: aws.qbusiness.listAttachments
  calls:
  - action: listAttachments
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.attachments }}'
    item:
      attachmentId: '{{ item.attachmentId }}'
      conversationId: '{{ item.conversationId }}'
      name: '{{ item.name }}'
      copyFrom: '{{ item.copyFrom }}'
      fileType: '{{ item.fileType }}'
      fileSize: '{{ item.fileSize }}'
      md5chksum: '{{ item.md5chksum }}'
      createdAt: '{{ item.createdAt }}'
      status: '{{ item.status }}'
      error: '{{ item.error }}'
- discovery_id: aws.qbusiness.listChatResponseConfigurations
  calls:
  - action: listChatResponseConfigurations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.chatResponseConfigurations }}'
    item:
      chatResponseConfigurationId: '{{ item.chatResponseConfigurationId }}'
      chatResponseConfigurationArn: '{{ item.chatResponseConfigurationArn }}'
      displayName: '{{ item.displayName }}'
      responseConfigurationSummary: '{{ item.responseConfigurationSummary }}'
      status: '{{ item.status }}'
      createdAt: '{{ item.createdAt }}'
      updatedAt: '{{ item.updatedAt }}'
- discovery_id: aws.qbusiness.listConversations
  calls:
  - action: listConversations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.conversations }}'
    item:
      conversationId: '{{ item.conversationId }}'
      title: '{{ item.title }}'
      startTime: '{{ item.startTime }}'
- discovery_id: aws.qbusiness.listDataAccessors
  calls:
  - action: listDataAccessors
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.dataAccessors }}'
    item:
      displayName: '{{ item.displayName }}'
      dataAccessorId: '{{ item.dataAccessorId }}'
      dataAccessorArn: '{{ item.dataAccessorArn }}'
      idcApplicationArn: '{{ item.idcApplicationArn }}'
      principal: '{{ item.principal }}'
      authenticationDetail: '{{ item.authenticationDetail }}'
      createdAt: '{{ item.createdAt }}'
      updatedAt: '{{ item.updatedAt }}'
- discovery_id: aws.qbusiness.listDataSourceSyncJobs
  calls:
  - action: listDataSourceSyncJobs
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.history }}'
    item:
      executionId: '{{ item.executionId }}'
      startTime: '{{ item.startTime }}'
      endTime: '{{ item.endTime }}'
      status: '{{ item.status }}'
      error: '{{ item.error }}'
      dataSourceErrorCode: '{{ item.dataSourceErrorCode }}'
      metrics: '{{ item.metrics }}'
- discovery_id: aws.qbusiness.listDataSources
  calls:
  - action: listDataSources
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.dataSources }}'
    item:
      displayName: '{{ item.displayName }}'
      dataSourceId: '{{ item.dataSourceId }}'
      type: '{{ item.type }}'
      createdAt: '{{ item.createdAt }}'
      updatedAt: '{{ item.updatedAt }}'
      status: '{{ item.status }}'
- discovery_id: aws.qbusiness.listDocuments
  calls:
  - action: listDocuments
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.documentDetailList }}'
    item:
      documentId: '{{ item.documentId }}'
      status: '{{ item.status }}'
      error: '{{ item.error }}'
      createdAt: '{{ item.createdAt }}'
      updatedAt: '{{ item.updatedAt }}'
- discovery_id: aws.qbusiness.listGroups
  calls:
  - action: listGroups
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
    item:
      groupName: '{{ item.groupName }}'
- discovery_id: aws.qbusiness.listIndices
  calls:
  - action: listIndices
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.indices }}'
    item:
      displayName: '{{ item.displayName }}'
      indexId: '{{ item.indexId }}'
      createdAt: '{{ item.createdAt }}'
      updatedAt: '{{ item.updatedAt }}'
      status: '{{ item.status }}'
- discovery_id: aws.qbusiness.listMessages
  calls:
  - action: listMessages
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.messages }}'
    item:
      messageId: '{{ item.messageId }}'
      body: '{{ item.body }}'
      time: '{{ item.time }}'
      type: '{{ item.type }}'
      attachments: '{{ item.attachments }}'
      sourceAttribution: '{{ item.sourceAttribution }}'
      actionReview: '{{ item.actionReview }}'
      actionExecution: '{{ item.actionExecution }}'
- discovery_id: aws.qbusiness.listPluginActions
  calls:
  - action: listPluginActions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
    item:
      actionIdentifier: '{{ item.actionIdentifier }}'
      displayName: '{{ item.displayName }}'
      instructionExample: '{{ item.instructionExample }}'
      description: '{{ item.description }}'
- discovery_id: aws.qbusiness.listPluginTypeActions
  calls:
  - action: listPluginTypeActions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
    item:
      actionIdentifier: '{{ item.actionIdentifier }}'
      displayName: '{{ item.displayName }}'
      instructionExample: '{{ item.instructionExample }}'
      description: '{{ item.description }}'
- discovery_id: aws.qbusiness.listPlugins
  calls:
  - action: listPlugins
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.plugins }}'
    item:
      pluginId: '{{ item.pluginId }}'
      displayName: '{{ item.displayName }}'
      type: '{{ item.type }}'
      serverUrl: '{{ item.serverUrl }}'
      state: '{{ item.state }}'
      buildStatus: '{{ item.buildStatus }}'
      createdAt: '{{ item.createdAt }}'
      updatedAt: '{{ item.updatedAt }}'
- discovery_id: aws.qbusiness.listRetrievers
  calls:
  - action: listRetrievers
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.retrievers }}'
    item:
      applicationId: '{{ item.applicationId }}'
      retrieverId: '{{ item.retrieverId }}'
      type: '{{ item.type }}'
      status: '{{ item.status }}'
      displayName: '{{ item.displayName }}'
- discovery_id: aws.qbusiness.listSubscriptions
  calls:
  - action: listSubscriptions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.subscriptions }}'
    item:
      subscriptionId: '{{ item.subscriptionId }}'
      subscriptionArn: '{{ item.subscriptionArn }}'
      principal: '{{ item.principal }}'
      currentSubscription: '{{ item.currentSubscription }}'
      nextSubscription: '{{ item.nextSubscription }}'
- discovery_id: aws.qbusiness.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tags }}'
    item:
      key: '{{ item.key }}'
      value: '{{ item.value }}'
- discovery_id: aws.qbusiness.listWebExperiences
  calls:
  - action: listWebExperiences
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.webExperiences }}'
    item:
      webExperienceId: '{{ item.webExperienceId }}'
      createdAt: '{{ item.createdAt }}'
      updatedAt: '{{ item.updatedAt }}'
      defaultEndpoint: '{{ item.defaultEndpoint }}'
      status: '{{ item.status }}'
- discovery_id: aws.qbusiness.searchRelevantContent
  calls:
  - action: searchRelevantContent
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.relevantContent }}'
    item:
      content: '{{ item.content }}'
      documentId: '{{ item.documentId }}'
      documentTitle: '{{ item.documentTitle }}'
      documentUri: '{{ item.documentUri }}'
      documentAttributes: '{{ item.documentAttributes }}'
      scoreAttributes: '{{ item.scoreAttributes }}'
checks: []
