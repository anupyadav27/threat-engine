version: '1.0'
provider: aws
service: redshift-serverless
services:
  client: redshift-serverless
  module: boto3.client
discovery:
- discovery_id: aws.redshift-serverless.getCredentials
  calls:
  - action: getCredentials
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.dbPassword }}'
- discovery_id: aws.redshift-serverless.getSnapshot
  calls:
  - action: getSnapshot
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.snapshot }}'
    item:
      accountsWithProvisionedRestoreAccess: '{{ item.accountsWithProvisionedRestoreAccess
        }}'
      accountsWithRestoreAccess: '{{ item.accountsWithRestoreAccess }}'
      actualIncrementalBackupSizeInMegaBytes: '{{ item.actualIncrementalBackupSizeInMegaBytes
        }}'
      adminPasswordSecretArn: '{{ item.adminPasswordSecretArn }}'
      adminPasswordSecretKmsKeyId: '{{ item.adminPasswordSecretKmsKeyId }}'
      adminUsername: '{{ item.adminUsername }}'
      backupProgressInMegaBytes: '{{ item.backupProgressInMegaBytes }}'
      currentBackupRateInMegaBytesPerSecond: '{{ item.currentBackupRateInMegaBytesPerSecond
        }}'
      elapsedTimeInSeconds: '{{ item.elapsedTimeInSeconds }}'
      estimatedSecondsToCompletion: '{{ item.estimatedSecondsToCompletion }}'
      kmsKeyId: '{{ item.kmsKeyId }}'
      namespaceArn: '{{ item.namespaceArn }}'
      namespaceName: '{{ item.namespaceName }}'
      ownerAccount: '{{ item.ownerAccount }}'
      snapshotArn: '{{ item.snapshotArn }}'
      snapshotCreateTime: '{{ item.snapshotCreateTime }}'
      snapshotName: '{{ item.snapshotName }}'
      snapshotRemainingDays: '{{ item.snapshotRemainingDays }}'
      snapshotRetentionPeriod: '{{ item.snapshotRetentionPeriod }}'
      snapshotRetentionStartTime: '{{ item.snapshotRetentionStartTime }}'
      status: '{{ item.status }}'
      totalBackupSizeInMegaBytes: '{{ item.totalBackupSizeInMegaBytes }}'
- discovery_id: aws.redshift-serverless.listCustomDomainAssociations
  calls:
  - action: listCustomDomainAssociations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.associations }}'
    item:
      customDomainCertificateArn: '{{ item.customDomainCertificateArn }}'
      customDomainCertificateExpiryTime: '{{ item.customDomainCertificateExpiryTime
        }}'
      customDomainName: '{{ item.customDomainName }}'
      workgroupName: '{{ item.workgroupName }}'
- discovery_id: aws.redshift-serverless.listEndpointAccess
  calls:
  - action: listEndpointAccess
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.endpoints }}'
    item:
      address: '{{ item.address }}'
      endpointArn: '{{ item.endpointArn }}'
      endpointCreateTime: '{{ item.endpointCreateTime }}'
      endpointName: '{{ item.endpointName }}'
      endpointStatus: '{{ item.endpointStatus }}'
      port: '{{ item.port }}'
      subnetIds: '{{ item.subnetIds }}'
      vpcEndpoint: '{{ item.vpcEndpoint }}'
      vpcSecurityGroups: '{{ item.vpcSecurityGroups }}'
      workgroupName: '{{ item.workgroupName }}'
- discovery_id: aws.redshift-serverless.listManagedWorkgroups
  calls:
  - action: listManagedWorkgroups
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.managedWorkgroups }}'
    item:
      creationDate: '{{ item.creationDate }}'
      managedWorkgroupId: '{{ item.managedWorkgroupId }}'
      managedWorkgroupName: '{{ item.managedWorkgroupName }}'
      sourceArn: '{{ item.sourceArn }}'
      status: '{{ item.status }}'
- discovery_id: aws.redshift-serverless.listNamespaces
  calls:
  - action: listNamespaces
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.namespaces }}'
    item:
      adminPasswordSecretArn: '{{ item.adminPasswordSecretArn }}'
      adminPasswordSecretKmsKeyId: '{{ item.adminPasswordSecretKmsKeyId }}'
      adminUsername: '{{ item.adminUsername }}'
      catalogArn: '{{ item.catalogArn }}'
      creationDate: '{{ item.creationDate }}'
      dbName: '{{ item.dbName }}'
      defaultIamRoleArn: '{{ item.defaultIamRoleArn }}'
      iamRoles: '{{ item.iamRoles }}'
      kmsKeyId: '{{ item.kmsKeyId }}'
      lakehouseRegistrationStatus: '{{ item.lakehouseRegistrationStatus }}'
      logExports: '{{ item.logExports }}'
      namespaceArn: '{{ item.namespaceArn }}'
      namespaceId: '{{ item.namespaceId }}'
      namespaceName: '{{ item.namespaceName }}'
      status: '{{ item.status }}'
- discovery_id: aws.redshift-serverless.listRecoveryPoints
  calls:
  - action: listRecoveryPoints
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.recoveryPoints }}'
    item:
      namespaceArn: '{{ item.namespaceArn }}'
      namespaceName: '{{ item.namespaceName }}'
      recoveryPointCreateTime: '{{ item.recoveryPointCreateTime }}'
      recoveryPointId: '{{ item.recoveryPointId }}'
      totalSizeInMegaBytes: '{{ item.totalSizeInMegaBytes }}'
      workgroupName: '{{ item.workgroupName }}'
- discovery_id: aws.redshift-serverless.listReservationOfferings
  calls:
  - action: listReservationOfferings
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.reservationOfferingsList }}'
    item:
      currencyCode: '{{ item.currencyCode }}'
      duration: '{{ item.duration }}'
      hourlyCharge: '{{ item.hourlyCharge }}'
      offeringId: '{{ item.offeringId }}'
      offeringType: '{{ item.offeringType }}'
      upfrontCharge: '{{ item.upfrontCharge }}'
- discovery_id: aws.redshift-serverless.listReservations
  calls:
  - action: listReservations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.reservationsList }}'
    item:
      capacity: '{{ item.capacity }}'
      endDate: '{{ item.endDate }}'
      offering: '{{ item.offering }}'
      reservationArn: '{{ item.reservationArn }}'
      reservationId: '{{ item.reservationId }}'
      startDate: '{{ item.startDate }}'
      status: '{{ item.status }}'
- discovery_id: aws.redshift-serverless.listScheduledActions
  calls:
  - action: listScheduledActions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.scheduledActions }}'
    item:
      namespaceName: '{{ item.namespaceName }}'
      scheduledActionName: '{{ item.scheduledActionName }}'
- discovery_id: aws.redshift-serverless.listSnapshotCopyConfigurations
  calls:
  - action: listSnapshotCopyConfigurations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.snapshotCopyConfigurations }}'
    item:
      destinationKmsKeyId: '{{ item.destinationKmsKeyId }}'
      destinationRegion: '{{ item.destinationRegion }}'
      namespaceName: '{{ item.namespaceName }}'
      snapshotCopyConfigurationArn: '{{ item.snapshotCopyConfigurationArn }}'
      snapshotCopyConfigurationId: '{{ item.snapshotCopyConfigurationId }}'
      snapshotRetentionPeriod: '{{ item.snapshotRetentionPeriod }}'
- discovery_id: aws.redshift-serverless.listSnapshots
  calls:
  - action: listSnapshots
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.snapshots }}'
    item:
      accountsWithProvisionedRestoreAccess: '{{ item.accountsWithProvisionedRestoreAccess
        }}'
      accountsWithRestoreAccess: '{{ item.accountsWithRestoreAccess }}'
      actualIncrementalBackupSizeInMegaBytes: '{{ item.actualIncrementalBackupSizeInMegaBytes
        }}'
      adminPasswordSecretArn: '{{ item.adminPasswordSecretArn }}'
      adminPasswordSecretKmsKeyId: '{{ item.adminPasswordSecretKmsKeyId }}'
      adminUsername: '{{ item.adminUsername }}'
      backupProgressInMegaBytes: '{{ item.backupProgressInMegaBytes }}'
      currentBackupRateInMegaBytesPerSecond: '{{ item.currentBackupRateInMegaBytesPerSecond
        }}'
      elapsedTimeInSeconds: '{{ item.elapsedTimeInSeconds }}'
      estimatedSecondsToCompletion: '{{ item.estimatedSecondsToCompletion }}'
      kmsKeyId: '{{ item.kmsKeyId }}'
      namespaceArn: '{{ item.namespaceArn }}'
      namespaceName: '{{ item.namespaceName }}'
      ownerAccount: '{{ item.ownerAccount }}'
      snapshotArn: '{{ item.snapshotArn }}'
      snapshotCreateTime: '{{ item.snapshotCreateTime }}'
      snapshotName: '{{ item.snapshotName }}'
      snapshotRemainingDays: '{{ item.snapshotRemainingDays }}'
      snapshotRetentionPeriod: '{{ item.snapshotRetentionPeriod }}'
      snapshotRetentionStartTime: '{{ item.snapshotRetentionStartTime }}'
      status: '{{ item.status }}'
      totalBackupSizeInMegaBytes: '{{ item.totalBackupSizeInMegaBytes }}'
- discovery_id: aws.redshift-serverless.listTableRestoreStatus
  calls:
  - action: listTableRestoreStatus
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tableRestoreStatuses }}'
    item:
      message: '{{ item.message }}'
      namespaceName: '{{ item.namespaceName }}'
      newTableName: '{{ item.newTableName }}'
      progressInMegaBytes: '{{ item.progressInMegaBytes }}'
      recoveryPointId: '{{ item.recoveryPointId }}'
      requestTime: '{{ item.requestTime }}'
      snapshotName: '{{ item.snapshotName }}'
      sourceDatabaseName: '{{ item.sourceDatabaseName }}'
      sourceSchemaName: '{{ item.sourceSchemaName }}'
      sourceTableName: '{{ item.sourceTableName }}'
      status: '{{ item.status }}'
      tableRestoreRequestId: '{{ item.tableRestoreRequestId }}'
      targetDatabaseName: '{{ item.targetDatabaseName }}'
      targetSchemaName: '{{ item.targetSchemaName }}'
      totalDataInMegaBytes: '{{ item.totalDataInMegaBytes }}'
      workgroupName: '{{ item.workgroupName }}'
- discovery_id: aws.redshift-serverless.listTracks
  calls:
  - action: listTracks
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tracks }}'
    item:
      trackName: '{{ item.trackName }}'
      updateTargets: '{{ item.updateTargets }}'
      workgroupVersion: '{{ item.workgroupVersion }}'
- discovery_id: aws.redshift-serverless.listUsageLimits
  calls:
  - action: listUsageLimits
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.usageLimits }}'
    item:
      amount: '{{ item.amount }}'
      breachAction: '{{ item.breachAction }}'
      period: '{{ item.period }}'
      resourceArn: '{{ item.resourceArn }}'
      usageLimitArn: '{{ item.usageLimitArn }}'
      usageLimitId: '{{ item.usageLimitId }}'
      usageType: '{{ item.usageType }}'
- discovery_id: aws.redshift-serverless.listWorkgroups
  calls:
  - action: listWorkgroups
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.workgroups }}'
    item:
      baseCapacity: '{{ item.baseCapacity }}'
      configParameters: '{{ item.configParameters }}'
      creationDate: '{{ item.creationDate }}'
      crossAccountVpcs: '{{ item.crossAccountVpcs }}'
      customDomainCertificateArn: '{{ item.customDomainCertificateArn }}'
      customDomainCertificateExpiryTime: '{{ item.customDomainCertificateExpiryTime
        }}'
      customDomainName: '{{ item.customDomainName }}'
      endpoint: '{{ item.endpoint }}'
      enhancedVpcRouting: '{{ item.enhancedVpcRouting }}'
      ipAddressType: '{{ item.ipAddressType }}'
      maxCapacity: '{{ item.maxCapacity }}'
      namespaceName: '{{ item.namespaceName }}'
      patchVersion: '{{ item.patchVersion }}'
      pendingTrackName: '{{ item.pendingTrackName }}'
      port: '{{ item.port }}'
      pricePerformanceTarget: '{{ item.pricePerformanceTarget }}'
      publiclyAccessible: '{{ item.publiclyAccessible }}'
      securityGroupIds: '{{ item.securityGroupIds }}'
      status: '{{ item.status }}'
      subnetIds: '{{ item.subnetIds }}'
      trackName: '{{ item.trackName }}'
      workgroupArn: '{{ item.workgroupArn }}'
      workgroupId: '{{ item.workgroupId }}'
      workgroupName: '{{ item.workgroupName }}'
      workgroupVersion: '{{ item.workgroupVersion }}'
- discovery_id: aws.redshift-serverless.getCustomDomainAssociation
  calls:
  - action: getCustomDomainAssociation
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.customDomainCertificateArn }}'
- discovery_id: aws.redshift-serverless.getEndpointAccess
  calls:
  - action: getEndpointAccess
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.endpoint }}'
    item:
      address: '{{ item.address }}'
      endpointArn: '{{ item.endpointArn }}'
      endpointCreateTime: '{{ item.endpointCreateTime }}'
      endpointName: '{{ item.endpointName }}'
      endpointStatus: '{{ item.endpointStatus }}'
      port: '{{ item.port }}'
      subnetIds: '{{ item.subnetIds }}'
      vpcEndpoint: '{{ item.vpcEndpoint }}'
      vpcSecurityGroups: '{{ item.vpcSecurityGroups }}'
      workgroupName: '{{ item.workgroupName }}'
- discovery_id: aws.redshift-serverless.getNamespace
  calls:
  - action: getNamespace
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.namespace }}'
    item:
      adminPasswordSecretArn: '{{ item.adminPasswordSecretArn }}'
      adminPasswordSecretKmsKeyId: '{{ item.adminPasswordSecretKmsKeyId }}'
      adminUsername: '{{ item.adminUsername }}'
      catalogArn: '{{ item.catalogArn }}'
      creationDate: '{{ item.creationDate }}'
      dbName: '{{ item.dbName }}'
      defaultIamRoleArn: '{{ item.defaultIamRoleArn }}'
      iamRoles: '{{ item.iamRoles }}'
      kmsKeyId: '{{ item.kmsKeyId }}'
      lakehouseRegistrationStatus: '{{ item.lakehouseRegistrationStatus }}'
      logExports: '{{ item.logExports }}'
      namespaceArn: '{{ item.namespaceArn }}'
      namespaceId: '{{ item.namespaceId }}'
      namespaceName: '{{ item.namespaceName }}'
      status: '{{ item.status }}'
- discovery_id: aws.redshift-serverless.getRecoveryPoint
  calls:
  - action: getRecoveryPoint
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.recoveryPoint }}'
    item:
      namespaceArn: '{{ item.namespaceArn }}'
      namespaceName: '{{ item.namespaceName }}'
      recoveryPointCreateTime: '{{ item.recoveryPointCreateTime }}'
      recoveryPointId: '{{ item.recoveryPointId }}'
      totalSizeInMegaBytes: '{{ item.totalSizeInMegaBytes }}'
      workgroupName: '{{ item.workgroupName }}'
- discovery_id: aws.redshift-serverless.getReservation
  calls:
  - action: getReservation
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.reservation }}'
    item:
      capacity: '{{ item.capacity }}'
      endDate: '{{ item.endDate }}'
      offering: '{{ item.offering }}'
      reservationArn: '{{ item.reservationArn }}'
      reservationId: '{{ item.reservationId }}'
      startDate: '{{ item.startDate }}'
      status: '{{ item.status }}'
- discovery_id: aws.redshift-serverless.getReservationOffering
  calls:
  - action: getReservationOffering
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.reservationOffering }}'
    item:
      currencyCode: '{{ item.currencyCode }}'
      duration: '{{ item.duration }}'
      hourlyCharge: '{{ item.hourlyCharge }}'
      offeringId: '{{ item.offeringId }}'
      offeringType: '{{ item.offeringType }}'
      upfrontCharge: '{{ item.upfrontCharge }}'
- discovery_id: aws.redshift-serverless.getResourcePolicy
  calls:
  - action: getResourcePolicy
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.resourcePolicy }}'
    item:
      policy: '{{ item.policy }}'
      resourceArn: '{{ item.resourceArn }}'
- discovery_id: aws.redshift-serverless.getScheduledAction
  calls:
  - action: getScheduledAction
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.scheduledAction }}'
    item:
      endTime: '{{ item.endTime }}'
      namespaceName: '{{ item.namespaceName }}'
      nextInvocations: '{{ item.nextInvocations }}'
      roleArn: '{{ item.roleArn }}'
      schedule: '{{ item.schedule }}'
      scheduledActionDescription: '{{ item.scheduledActionDescription }}'
      scheduledActionName: '{{ item.scheduledActionName }}'
      scheduledActionUuid: '{{ item.scheduledActionUuid }}'
      startTime: '{{ item.startTime }}'
      state: '{{ item.state }}'
      targetAction: '{{ item.targetAction }}'
- discovery_id: aws.redshift-serverless.getTableRestoreStatus
  calls:
  - action: getTableRestoreStatus
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tableRestoreStatus }}'
    item:
      message: '{{ item.message }}'
      namespaceName: '{{ item.namespaceName }}'
      newTableName: '{{ item.newTableName }}'
      progressInMegaBytes: '{{ item.progressInMegaBytes }}'
      recoveryPointId: '{{ item.recoveryPointId }}'
      requestTime: '{{ item.requestTime }}'
      snapshotName: '{{ item.snapshotName }}'
      sourceDatabaseName: '{{ item.sourceDatabaseName }}'
      sourceSchemaName: '{{ item.sourceSchemaName }}'
      sourceTableName: '{{ item.sourceTableName }}'
      status: '{{ item.status }}'
      tableRestoreRequestId: '{{ item.tableRestoreRequestId }}'
      targetDatabaseName: '{{ item.targetDatabaseName }}'
      targetSchemaName: '{{ item.targetSchemaName }}'
      totalDataInMegaBytes: '{{ item.totalDataInMegaBytes }}'
      workgroupName: '{{ item.workgroupName }}'
- discovery_id: aws.redshift-serverless.getTrack
  calls:
  - action: getTrack
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.track }}'
    item:
      trackName: '{{ item.trackName }}'
      updateTargets: '{{ item.updateTargets }}'
      workgroupVersion: '{{ item.workgroupVersion }}'
- discovery_id: aws.redshift-serverless.getUsageLimit
  calls:
  - action: getUsageLimit
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.usageLimit }}'
    item:
      amount: '{{ item.amount }}'
      breachAction: '{{ item.breachAction }}'
      period: '{{ item.period }}'
      resourceArn: '{{ item.resourceArn }}'
      usageLimitArn: '{{ item.usageLimitArn }}'
      usageLimitId: '{{ item.usageLimitId }}'
      usageType: '{{ item.usageType }}'
- discovery_id: aws.redshift-serverless.getWorkgroup
  calls:
  - action: getWorkgroup
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.workgroup }}'
    item:
      baseCapacity: '{{ item.baseCapacity }}'
      configParameters: '{{ item.configParameters }}'
      creationDate: '{{ item.creationDate }}'
      crossAccountVpcs: '{{ item.crossAccountVpcs }}'
      customDomainCertificateArn: '{{ item.customDomainCertificateArn }}'
      customDomainCertificateExpiryTime: '{{ item.customDomainCertificateExpiryTime
        }}'
      customDomainName: '{{ item.customDomainName }}'
      endpoint: '{{ item.endpoint }}'
      enhancedVpcRouting: '{{ item.enhancedVpcRouting }}'
      ipAddressType: '{{ item.ipAddressType }}'
      maxCapacity: '{{ item.maxCapacity }}'
      namespaceName: '{{ item.namespaceName }}'
      patchVersion: '{{ item.patchVersion }}'
      pendingTrackName: '{{ item.pendingTrackName }}'
      port: '{{ item.port }}'
      pricePerformanceTarget: '{{ item.pricePerformanceTarget }}'
      publiclyAccessible: '{{ item.publiclyAccessible }}'
      securityGroupIds: '{{ item.securityGroupIds }}'
      status: '{{ item.status }}'
      subnetIds: '{{ item.subnetIds }}'
      trackName: '{{ item.trackName }}'
      workgroupArn: '{{ item.workgroupArn }}'
      workgroupId: '{{ item.workgroupId }}'
      workgroupName: '{{ item.workgroupName }}'
      workgroupVersion: '{{ item.workgroupVersion }}'
- discovery_id: aws.redshift-serverless.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tags }}'
    item:
      key: '{{ item.key }}'
      value: '{{ item.value }}'
checks: []
