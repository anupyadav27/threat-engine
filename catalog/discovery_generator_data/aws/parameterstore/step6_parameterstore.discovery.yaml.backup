- discovery_id: aws.parameterstore.describeAutomationStepExecutions
  calls:
  - action: describeAutomationStepExecutions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.StepExecutions }}'
    item:
      StepName: '{{ item.StepName }}'
      Action: '{{ item.Action }}'
