version: '1.0'
provider: aws
service: parameterstore
services:
  client: parameterstore
  module: boto3.client
discovery:
- discovery_id: aws.parameterstore.describeActivations
  calls:
  - action: describeActivations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ActivationList }}'
    item:
      ActivationId: '{{ item.ActivationId }}'
      Description: '{{ item.Description }}'
      DefaultInstanceName: '{{ item.DefaultInstanceName }}'
      IamRole: '{{ item.IamRole }}'
      RegistrationLimit: '{{ item.RegistrationLimit }}'
      RegistrationsCount: '{{ item.RegistrationsCount }}'
      ExpirationDate: '{{ item.ExpirationDate }}'
      Expired: '{{ item.Expired }}'
      CreatedDate: '{{ item.CreatedDate }}'
      Tags: '{{ item.Tags }}'
- discovery_id: aws.parameterstore.describeAssociation
  calls:
  - action: describeAssociation
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AssociationDescription }}'
    item:
      Name: '{{ item.Name }}'
      InstanceId: '{{ item.InstanceId }}'
      AssociationVersion: '{{ item.AssociationVersion }}'
      Date: '{{ item.Date }}'
      LastUpdateAssociationDate: '{{ item.LastUpdateAssociationDate }}'
      Status: '{{ item.Status }}'
      Overview: '{{ item.Overview }}'
      DocumentVersion: '{{ item.DocumentVersion }}'
      AutomationTargetParameterName: '{{ item.AutomationTargetParameterName }}'
      Parameters: '{{ item.Parameters }}'
      AssociationId: '{{ item.AssociationId }}'
      Targets: '{{ item.Targets }}'
      ScheduleExpression: '{{ item.ScheduleExpression }}'
      OutputLocation: '{{ item.OutputLocation }}'
      LastExecutionDate: '{{ item.LastExecutionDate }}'
      LastSuccessfulExecutionDate: '{{ item.LastSuccessfulExecutionDate }}'
      AssociationName: '{{ item.AssociationName }}'
      MaxErrors: '{{ item.MaxErrors }}'
      MaxConcurrency: '{{ item.MaxConcurrency }}'
      ComplianceSeverity: '{{ item.ComplianceSeverity }}'
      SyncCompliance: '{{ item.SyncCompliance }}'
      ApplyOnlyAtCronInterval: '{{ item.ApplyOnlyAtCronInterval }}'
      CalendarNames: '{{ item.CalendarNames }}'
      TargetLocations: '{{ item.TargetLocations }}'
      ScheduleOffset: '{{ item.ScheduleOffset }}'
      Duration: '{{ item.Duration }}'
      TargetMaps: '{{ item.TargetMaps }}'
      AlarmConfiguration: '{{ item.AlarmConfiguration }}'
      TriggeredAlarms: '{{ item.TriggeredAlarms }}'
- discovery_id: aws.parameterstore.describeAutomationExecutions
  calls:
  - action: describeAutomationExecutions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AutomationExecutionMetadataList }}'
    item:
      AutomationExecutionId: '{{ item.AutomationExecutionId }}'
      DocumentName: '{{ item.DocumentName }}'
      DocumentVersion: '{{ item.DocumentVersion }}'
      AutomationExecutionStatus: '{{ item.AutomationExecutionStatus }}'
      ExecutionStartTime: '{{ item.ExecutionStartTime }}'
      ExecutionEndTime: '{{ item.ExecutionEndTime }}'
      ExecutedBy: '{{ item.ExecutedBy }}'
      LogFile: '{{ item.LogFile }}'
      Outputs: '{{ item.Outputs }}'
      Mode: '{{ item.Mode }}'
      ParentAutomationExecutionId: '{{ item.ParentAutomationExecutionId }}'
      CurrentStepName: '{{ item.CurrentStepName }}'
      CurrentAction: '{{ item.CurrentAction }}'
      FailureMessage: '{{ item.FailureMessage }}'
      TargetParameterName: '{{ item.TargetParameterName }}'
      Targets: '{{ item.Targets }}'
      TargetMaps: '{{ item.TargetMaps }}'
      ResolvedTargets: '{{ item.ResolvedTargets }}'
      MaxConcurrency: '{{ item.MaxConcurrency }}'
      MaxErrors: '{{ item.MaxErrors }}'
      Target: '{{ item.Target }}'
      AutomationType: '{{ item.AutomationType }}'
      AlarmConfiguration: '{{ item.AlarmConfiguration }}'
      TriggeredAlarms: '{{ item.TriggeredAlarms }}'
      TargetLocationsURL: '{{ item.TargetLocationsURL }}'
      AutomationSubtype: '{{ item.AutomationSubtype }}'
      ScheduledTime: '{{ item.ScheduledTime }}'
      Runbooks: '{{ item.Runbooks }}'
      OpsItemId: '{{ item.OpsItemId }}'
      AssociationId: '{{ item.AssociationId }}'
      ChangeRequestName: '{{ item.ChangeRequestName }}'
- discovery_id: aws.parameterstore.describeAvailablePatches
  calls:
  - action: describeAvailablePatches
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Patches }}'
    item:
      Id: '{{ item.Id }}'
      ReleaseDate: '{{ item.ReleaseDate }}'
      Title: '{{ item.Title }}'
      Description: '{{ item.Description }}'
      ContentUrl: '{{ item.ContentUrl }}'
      Vendor: '{{ item.Vendor }}'
      ProductFamily: '{{ item.ProductFamily }}'
      Product: '{{ item.Product }}'
      Classification: '{{ item.Classification }}'
      MsrcSeverity: '{{ item.MsrcSeverity }}'
      KbNumber: '{{ item.KbNumber }}'
      MsrcNumber: '{{ item.MsrcNumber }}'
      Language: '{{ item.Language }}'
      AdvisoryIds: '{{ item.AdvisoryIds }}'
      BugzillaIds: '{{ item.BugzillaIds }}'
      CVEIds: '{{ item.CVEIds }}'
      Name: '{{ item.Name }}'
      Epoch: '{{ item.Epoch }}'
      Version: '{{ item.Version }}'
      Release: '{{ item.Release }}'
      Arch: '{{ item.Arch }}'
      Severity: '{{ item.Severity }}'
      Repository: '{{ item.Repository }}'
- discovery_id: aws.parameterstore.describeInstanceInformation
  calls:
  - action: describeInstanceInformation
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.InstanceInformationList }}'
    item:
      InstanceId: '{{ item.InstanceId }}'
      PingStatus: '{{ item.PingStatus }}'
      LastPingDateTime: '{{ item.LastPingDateTime }}'
      AgentVersion: '{{ item.AgentVersion }}'
      IsLatestVersion: '{{ item.IsLatestVersion }}'
      PlatformType: '{{ item.PlatformType }}'
      PlatformName: '{{ item.PlatformName }}'
      PlatformVersion: '{{ item.PlatformVersion }}'
      ActivationId: '{{ item.ActivationId }}'
      IamRole: '{{ item.IamRole }}'
      RegistrationDate: '{{ item.RegistrationDate }}'
      ResourceType: '{{ item.ResourceType }}'
      Name: '{{ item.Name }}'
      IPAddress: '{{ item.IPAddress }}'
      ComputerName: '{{ item.ComputerName }}'
      AssociationStatus: '{{ item.AssociationStatus }}'
      LastAssociationExecutionDate: '{{ item.LastAssociationExecutionDate }}'
      LastSuccessfulAssociationExecutionDate: '{{ item.LastSuccessfulAssociationExecutionDate
        }}'
      AssociationOverview: '{{ item.AssociationOverview }}'
      SourceId: '{{ item.SourceId }}'
      SourceType: '{{ item.SourceType }}'
- discovery_id: aws.parameterstore.describeInstanceProperties
  calls:
  - action: describeInstanceProperties
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.InstanceProperties }}'
    item:
      Name: '{{ item.Name }}'
      InstanceId: '{{ item.InstanceId }}'
      InstanceType: '{{ item.InstanceType }}'
      InstanceRole: '{{ item.InstanceRole }}'
      KeyName: '{{ item.KeyName }}'
      InstanceState: '{{ item.InstanceState }}'
      Architecture: '{{ item.Architecture }}'
      IPAddress: '{{ item.IPAddress }}'
      LaunchTime: '{{ item.LaunchTime }}'
      PingStatus: '{{ item.PingStatus }}'
      LastPingDateTime: '{{ item.LastPingDateTime }}'
      AgentVersion: '{{ item.AgentVersion }}'
      PlatformType: '{{ item.PlatformType }}'
      PlatformName: '{{ item.PlatformName }}'
      PlatformVersion: '{{ item.PlatformVersion }}'
      ActivationId: '{{ item.ActivationId }}'
      IamRole: '{{ item.IamRole }}'
      RegistrationDate: '{{ item.RegistrationDate }}'
      ResourceType: '{{ item.ResourceType }}'
      ComputerName: '{{ item.ComputerName }}'
      AssociationStatus: '{{ item.AssociationStatus }}'
      LastAssociationExecutionDate: '{{ item.LastAssociationExecutionDate }}'
      LastSuccessfulAssociationExecutionDate: '{{ item.LastSuccessfulAssociationExecutionDate
        }}'
      AssociationOverview: '{{ item.AssociationOverview }}'
      SourceId: '{{ item.SourceId }}'
      SourceType: '{{ item.SourceType }}'
- discovery_id: aws.parameterstore.describeInventoryDeletions
  calls:
  - action: describeInventoryDeletions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.InventoryDeletions }}'
    item:
      DeletionId: '{{ item.DeletionId }}'
      TypeName: '{{ item.TypeName }}'
      DeletionStartTime: '{{ item.DeletionStartTime }}'
      LastStatus: '{{ item.LastStatus }}'
      LastStatusMessage: '{{ item.LastStatusMessage }}'
      DeletionSummary: '{{ item.DeletionSummary }}'
      LastStatusUpdateTime: '{{ item.LastStatusUpdateTime }}'
- discovery_id: aws.parameterstore.describeMaintenanceWindowSchedule
  calls:
  - action: describeMaintenanceWindowSchedule
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ScheduledWindowExecutions }}'
    item:
      WindowId: '{{ item.WindowId }}'
      Name: '{{ item.Name }}'
      ExecutionTime: '{{ item.ExecutionTime }}'
- discovery_id: aws.parameterstore.describeMaintenanceWindows
  calls:
  - action: describeMaintenanceWindows
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.WindowIdentities }}'
    item:
      WindowId: '{{ item.WindowId }}'
      Name: '{{ item.Name }}'
      Description: '{{ item.Description }}'
      Enabled: '{{ item.Enabled }}'
      Duration: '{{ item.Duration }}'
      Cutoff: '{{ item.Cutoff }}'
      Schedule: '{{ item.Schedule }}'
      ScheduleTimezone: '{{ item.ScheduleTimezone }}'
      ScheduleOffset: '{{ item.ScheduleOffset }}'
      EndDate: '{{ item.EndDate }}'
      StartDate: '{{ item.StartDate }}'
      NextExecutionTime: '{{ item.NextExecutionTime }}'
- discovery_id: aws.parameterstore.describeOpsItems
  calls:
  - action: describeOpsItems
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.OpsItemSummaries }}'
    item:
      CreatedBy: '{{ item.CreatedBy }}'
      CreatedTime: '{{ item.CreatedTime }}'
      LastModifiedBy: '{{ item.LastModifiedBy }}'
      LastModifiedTime: '{{ item.LastModifiedTime }}'
      Priority: '{{ item.Priority }}'
      Source: '{{ item.Source }}'
      Status: '{{ item.Status }}'
      OpsItemId: '{{ item.OpsItemId }}'
      Title: '{{ item.Title }}'
      OperationalData: '{{ item.OperationalData }}'
      Category: '{{ item.Category }}'
      Severity: '{{ item.Severity }}'
      OpsItemType: '{{ item.OpsItemType }}'
      ActualStartTime: '{{ item.ActualStartTime }}'
      ActualEndTime: '{{ item.ActualEndTime }}'
      PlannedStartTime: '{{ item.PlannedStartTime }}'
      PlannedEndTime: '{{ item.PlannedEndTime }}'
- discovery_id: aws.parameterstore.describeParameters
  calls:
  - action: describeParameters
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Parameters }}'
    item:
      Name: '{{ item.Name }}'
      ARN: '{{ item.ARN }}'
      Type: '{{ item.Type }}'
      KeyId: '{{ item.KeyId }}'
      LastModifiedDate: '{{ item.LastModifiedDate }}'
      LastModifiedUser: '{{ item.LastModifiedUser }}'
      Description: '{{ item.Description }}'
      AllowedPattern: '{{ item.AllowedPattern }}'
      Version: '{{ item.Version }}'
      Tier: '{{ item.Tier }}'
      Policies: '{{ item.Policies }}'
      DataType: '{{ item.DataType }}'
- discovery_id: aws.parameterstore.describePatchBaselines
  calls:
  - action: describePatchBaselines
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.BaselineIdentities }}'
    item:
      BaselineId: '{{ item.BaselineId }}'
      BaselineName: '{{ item.BaselineName }}'
      OperatingSystem: '{{ item.OperatingSystem }}'
      BaselineDescription: '{{ item.BaselineDescription }}'
      DefaultBaseline: '{{ item.DefaultBaseline }}'
- discovery_id: aws.parameterstore.describePatchGroups
  calls:
  - action: describePatchGroups
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Mappings }}'
    item:
      PatchGroup: '{{ item.PatchGroup }}'
      BaselineIdentity: '{{ item.BaselineIdentity }}'
- discovery_id: aws.parameterstore.getDefaultPatchBaseline
  calls:
  - action: getDefaultPatchBaseline
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.BaselineId }}'
- discovery_id: aws.parameterstore.getInventory
  calls:
  - action: getInventory
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Entities }}'
    item:
      Id: '{{ item.Id }}'
      Data: '{{ item.Data }}'
- discovery_id: aws.parameterstore.getInventorySchema
  calls:
  - action: getInventorySchema
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Schemas }}'
    item:
      TypeName: '{{ item.TypeName }}'
      Version: '{{ item.Version }}'
      Attributes: '{{ item.Attributes }}'
      DisplayName: '{{ item.DisplayName }}'
- discovery_id: aws.parameterstore.getOpsSummary
  calls:
  - action: getOpsSummary
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Entities }}'
    item:
      Id: '{{ item.Id }}'
      Data: '{{ item.Data }}'
- discovery_id: aws.parameterstore.listAssociations
  calls:
  - action: listAssociations
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Associations }}'
    item:
      Name: '{{ item.Name }}'
      InstanceId: '{{ item.InstanceId }}'
      AssociationId: '{{ item.AssociationId }}'
      AssociationVersion: '{{ item.AssociationVersion }}'
      DocumentVersion: '{{ item.DocumentVersion }}'
      Targets: '{{ item.Targets }}'
      LastExecutionDate: '{{ item.LastExecutionDate }}'
      Overview: '{{ item.Overview }}'
      ScheduleExpression: '{{ item.ScheduleExpression }}'
      AssociationName: '{{ item.AssociationName }}'
      ScheduleOffset: '{{ item.ScheduleOffset }}'
      Duration: '{{ item.Duration }}'
      TargetMaps: '{{ item.TargetMaps }}'
- discovery_id: aws.parameterstore.listCommandInvocations
  calls:
  - action: listCommandInvocations
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.CommandInvocations }}'
    item:
      CommandId: '{{ item.CommandId }}'
      InstanceId: '{{ item.InstanceId }}'
      InstanceName: '{{ item.InstanceName }}'
      Comment: '{{ item.Comment }}'
      DocumentName: '{{ item.DocumentName }}'
      DocumentVersion: '{{ item.DocumentVersion }}'
      RequestedDateTime: '{{ item.RequestedDateTime }}'
      Status: '{{ item.Status }}'
      StatusDetails: '{{ item.StatusDetails }}'
      TraceOutput: '{{ item.TraceOutput }}'
      StandardOutputUrl: '{{ item.StandardOutputUrl }}'
      StandardErrorUrl: '{{ item.StandardErrorUrl }}'
      CommandPlugins: '{{ item.CommandPlugins }}'
      ServiceRole: '{{ item.ServiceRole }}'
      NotificationConfig: '{{ item.NotificationConfig }}'
      CloudWatchOutputConfig: '{{ item.CloudWatchOutputConfig }}'
- discovery_id: aws.parameterstore.listCommands
  calls:
  - action: listCommands
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Commands }}'
    item:
      CommandId: '{{ item.CommandId }}'
      DocumentName: '{{ item.DocumentName }}'
      DocumentVersion: '{{ item.DocumentVersion }}'
      Comment: '{{ item.Comment }}'
      ExpiresAfter: '{{ item.ExpiresAfter }}'
      Parameters: '{{ item.Parameters }}'
      InstanceIds: '{{ item.InstanceIds }}'
      Targets: '{{ item.Targets }}'
      RequestedDateTime: '{{ item.RequestedDateTime }}'
      Status: '{{ item.Status }}'
      StatusDetails: '{{ item.StatusDetails }}'
      OutputS3Region: '{{ item.OutputS3Region }}'
      OutputS3BucketName: '{{ item.OutputS3BucketName }}'
      OutputS3KeyPrefix: '{{ item.OutputS3KeyPrefix }}'
      MaxConcurrency: '{{ item.MaxConcurrency }}'
      MaxErrors: '{{ item.MaxErrors }}'
      TargetCount: '{{ item.TargetCount }}'
      CompletedCount: '{{ item.CompletedCount }}'
      ErrorCount: '{{ item.ErrorCount }}'
      DeliveryTimedOutCount: '{{ item.DeliveryTimedOutCount }}'
      ServiceRole: '{{ item.ServiceRole }}'
      NotificationConfig: '{{ item.NotificationConfig }}'
      CloudWatchOutputConfig: '{{ item.CloudWatchOutputConfig }}'
      TimeoutSeconds: '{{ item.TimeoutSeconds }}'
      AlarmConfiguration: '{{ item.AlarmConfiguration }}'
      TriggeredAlarms: '{{ item.TriggeredAlarms }}'
- discovery_id: aws.parameterstore.listComplianceItems
  calls:
  - action: listComplianceItems
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.ComplianceItems }}'
    item:
      ComplianceType: '{{ item.ComplianceType }}'
      ResourceType: '{{ item.ResourceType }}'
