      ResponseCode: '{{ item.ResponseCode }}'
      Inputs: '{{ item.Inputs }}'
      Outputs: '{{ item.Outputs }}'
      Response: '{{ item.Response }}'
      FailureMessage: '{{ item.FailureMessage }}'
