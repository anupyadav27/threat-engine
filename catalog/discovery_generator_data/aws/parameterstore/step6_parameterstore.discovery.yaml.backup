      DetailedStatus: '{{ item.DetailedStatus }}'
      LastExecutionDate: '{{ item.LastExecutionDate }}'
      OutputSource: '{{ item.OutputSource }}'
- discovery_id: aws.parameterstore.describeAssociationExecutions
  calls:
  - action: describeAssociationExecutions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AssociationExecutions }}'
    item:
      AssociationId: '{{ item.AssociationId }}'
      AssociationVersion: '{{ item.AssociationVersion }}'
      ExecutionId: '{{ item.ExecutionId }}'
      Status: '{{ item.Status }}'
      DetailedStatus: '{{ item.DetailedStatus }}'
      CreatedTime: '{{ item.CreatedTime }}'
