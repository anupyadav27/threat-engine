      IsDefaultVersion: '{{ item.IsDefaultVersion }}'
      DocumentFormat: '{{ item.DocumentFormat }}'
      Status: '{{ item.Status }}'
      StatusInformation: '{{ item.StatusInformation }}'
      ReviewStatus: '{{ item.ReviewStatus }}'
- discovery_id: aws.parameterstore.listInventoryEntries
  calls:
  - action: listInventoryEntries
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Entries }}'
- discovery_id: aws.parameterstore.listNodesSummary
  calls:
  - action: listNodesSummary
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Summary }}'
- discovery_id: aws.parameterstore.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.TagList }}'
    item:
      Key: '{{ item.Key }}'
      Value: '{{ item.Value }}'
checks: []
