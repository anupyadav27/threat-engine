version: '1.0'
provider: aws
service: wafv2
services:
  client: wafv2
  module: boto3.client
discovery:
- discovery_id: aws.wafv2.getRuleGroup
  calls:
  - action: getRuleGroup
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.RuleGroup }}'
    item:
      Name: '{{ item.Name }}'
      Id: '{{ item.Id }}'
      Capacity: '{{ item.Capacity }}'
      ARN: '{{ item.ARN }}'
      Description: '{{ item.Description }}'
      Rules: '{{ item.Rules }}'
      VisibilityConfig: '{{ item.VisibilityConfig }}'
      LabelNamespace: '{{ item.LabelNamespace }}'
      CustomResponseBodies: '{{ item.CustomResponseBodies }}'
      AvailableLabels: '{{ item.AvailableLabels }}'
      ConsumedLabels: '{{ item.ConsumedLabels }}'
- discovery_id: aws.wafv2.getWebAcl
  calls:
  - action: getWebAcl
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.WebACL }}'
    item:
      Name: '{{ item.Name }}'
      Id: '{{ item.Id }}'
      ARN: '{{ item.ARN }}'
      DefaultAction: '{{ item.DefaultAction }}'
      Description: '{{ item.Description }}'
      Rules: '{{ item.Rules }}'
      VisibilityConfig: '{{ item.VisibilityConfig }}'
      DataProtectionConfig: '{{ item.DataProtectionConfig }}'
      Capacity: '{{ item.Capacity }}'
      PreProcessFirewallManagerRuleGroups: '{{ item.PreProcessFirewallManagerRuleGroups
        }}'
      PostProcessFirewallManagerRuleGroups: '{{ item.PostProcessFirewallManagerRuleGroups
        }}'
      ManagedByFirewallManager: '{{ item.ManagedByFirewallManager }}'
      LabelNamespace: '{{ item.LabelNamespace }}'
      CustomResponseBodies: '{{ item.CustomResponseBodies }}'
      CaptchaConfig: '{{ item.CaptchaConfig }}'
      ChallengeConfig: '{{ item.ChallengeConfig }}'
      TokenDomains: '{{ item.TokenDomains }}'
      AssociationConfig: '{{ item.AssociationConfig }}'
      RetrofittedByFirewallManager: '{{ item.RetrofittedByFirewallManager }}'
      OnSourceDDoSProtectionConfig: '{{ item.OnSourceDDoSProtectionConfig }}'
      ApplicationConfig: '{{ item.ApplicationConfig }}'
- discovery_id: aws.wafv2.describeAllManagedProducts
  calls:
  - action: describeAllManagedProducts
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ManagedProducts }}'
    item:
      VendorName: '{{ item.VendorName }}'
      ManagedRuleSetName: '{{ item.ManagedRuleSetName }}'
      ProductId: '{{ item.ProductId }}'
      ProductLink: '{{ item.ProductLink }}'
      ProductTitle: '{{ item.ProductTitle }}'
      ProductDescription: '{{ item.ProductDescription }}'
      SnsTopicArn: '{{ item.SnsTopicArn }}'
      IsVersioningSupported: '{{ item.IsVersioningSupported }}'
      IsAdvancedManagedRuleSet: '{{ item.IsAdvancedManagedRuleSet }}'
- discovery_id: aws.wafv2.describeManagedProductsByVendor
  calls:
  - action: describeManagedProductsByVendor
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ManagedProducts }}'
    item:
      VendorName: '{{ item.VendorName }}'
      ManagedRuleSetName: '{{ item.ManagedRuleSetName }}'
      ProductId: '{{ item.ProductId }}'
      ProductLink: '{{ item.ProductLink }}'
      ProductTitle: '{{ item.ProductTitle }}'
      ProductDescription: '{{ item.ProductDescription }}'
      SnsTopicArn: '{{ item.SnsTopicArn }}'
      IsVersioningSupported: '{{ item.IsVersioningSupported }}'
      IsAdvancedManagedRuleSet: '{{ item.IsAdvancedManagedRuleSet }}'
- discovery_id: aws.wafv2.describeManagedRuleGroup
  calls:
  - action: describeManagedRuleGroup
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Rules }}'
    item:
      Name: '{{ item.Name }}'
      Action: '{{ item.Action }}'
- discovery_id: aws.wafv2.getDecryptedApiKey
  calls:
  - action: getDecryptedApiKey
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.TokenDomains }}'
- discovery_id: aws.wafv2.getIpSet
  calls:
  - action: getIpSet
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.IPSet }}'
    item:
      Name: '{{ item.Name }}'
      Id: '{{ item.Id }}'
      ARN: '{{ item.ARN }}'
      Description: '{{ item.Description }}'
      IPAddressVersion: '{{ item.IPAddressVersion }}'
      Addresses: '{{ item.Addresses }}'
- discovery_id: aws.wafv2.getLoggingConfiguration
  calls:
  - action: getLoggingConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.LoggingConfiguration }}'
    item:
      ResourceArn: '{{ item.ResourceArn }}'
      LogDestinationConfigs: '{{ item.LogDestinationConfigs }}'
      RedactedFields: '{{ item.RedactedFields }}'
      ManagedByFirewallManager: '{{ item.ManagedByFirewallManager }}'
      LoggingFilter: '{{ item.LoggingFilter }}'
      LogType: '{{ item.LogType }}'
      LogScope: '{{ item.LogScope }}'
- discovery_id: aws.wafv2.getManagedRuleSet
  calls:
  - action: getManagedRuleSet
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ManagedRuleSet }}'
    item:
      Name: '{{ item.Name }}'
      Id: '{{ item.Id }}'
      ARN: '{{ item.ARN }}'
      Description: '{{ item.Description }}'
      PublishedVersions: '{{ item.PublishedVersions }}'
      RecommendedVersion: '{{ item.RecommendedVersion }}'
      LabelNamespace: '{{ item.LabelNamespace }}'
- discovery_id: aws.wafv2.getMobileSdkRelease
  calls:
  - action: getMobileSdkRelease
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.MobileSdkRelease }}'
    item:
      ReleaseVersion: '{{ item.ReleaseVersion }}'
      Timestamp: '{{ item.Timestamp }}'
      ReleaseNotes: '{{ item.ReleaseNotes }}'
      Tags: '{{ item.Tags }}'
- discovery_id: aws.wafv2.getPermissionPolicy
  calls:
  - action: getPermissionPolicy
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Policy }}'
- discovery_id: aws.wafv2.getRateBasedStatementManagedKeys
  calls:
  - action: getRateBasedStatementManagedKeys
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ManagedKeysIPV4 }}'
    item:
      IPAddressVersion: '{{ item.IPAddressVersion }}'
      Addresses: '{{ item.Addresses }}'
- discovery_id: aws.wafv2.getRegexPatternSet
  calls:
  - action: getRegexPatternSet
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.RegexPatternSet }}'
    item:
      Name: '{{ item.Name }}'
      Id: '{{ item.Id }}'
      ARN: '{{ item.ARN }}'
      Description: '{{ item.Description }}'
      RegularExpressionList: '{{ item.RegularExpressionList }}'
- discovery_id: aws.wafv2.getSampledRequests
  calls:
  - action: getSampledRequests
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.SampledRequests }}'
    item:
      Request: '{{ item.Request }}'
      Weight: '{{ item.Weight }}'
      Timestamp: '{{ item.Timestamp }}'
      Action: '{{ item.Action }}'
      RuleNameWithinRuleGroup: '{{ item.RuleNameWithinRuleGroup }}'
      RequestHeadersInserted: '{{ item.RequestHeadersInserted }}'
      ResponseCodeSent: '{{ item.ResponseCodeSent }}'
      Labels: '{{ item.Labels }}'
      CaptchaResponse: '{{ item.CaptchaResponse }}'
      ChallengeResponse: '{{ item.ChallengeResponse }}'
      OverriddenAction: '{{ item.OverriddenAction }}'
- discovery_id: aws.wafv2.getWebAclForResource
  calls:
  - action: getWebAclForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.WebACL }}'
    item:
      Name: '{{ item.Name }}'
      Id: '{{ item.Id }}'
      ARN: '{{ item.ARN }}'
      DefaultAction: '{{ item.DefaultAction }}'
      Description: '{{ item.Description }}'
      Rules: '{{ item.Rules }}'
      VisibilityConfig: '{{ item.VisibilityConfig }}'
      DataProtectionConfig: '{{ item.DataProtectionConfig }}'
      Capacity: '{{ item.Capacity }}'
      PreProcessFirewallManagerRuleGroups: '{{ item.PreProcessFirewallManagerRuleGroups
        }}'
      PostProcessFirewallManagerRuleGroups: '{{ item.PostProcessFirewallManagerRuleGroups
        }}'
      ManagedByFirewallManager: '{{ item.ManagedByFirewallManager }}'
      LabelNamespace: '{{ item.LabelNamespace }}'
      CustomResponseBodies: '{{ item.CustomResponseBodies }}'
      CaptchaConfig: '{{ item.CaptchaConfig }}'
      ChallengeConfig: '{{ item.ChallengeConfig }}'
      TokenDomains: '{{ item.TokenDomains }}'
      AssociationConfig: '{{ item.AssociationConfig }}'
      RetrofittedByFirewallManager: '{{ item.RetrofittedByFirewallManager }}'
      OnSourceDDoSProtectionConfig: '{{ item.OnSourceDDoSProtectionConfig }}'
      ApplicationConfig: '{{ item.ApplicationConfig }}'
- discovery_id: aws.wafv2.listApiKeys
  calls:
  - action: listApiKeys
    save_as: response
    on_error: continue
    params:
      Limit: 1000
  emit:
    as: item
    items_for: '{{ response.APIKeySummaries }}'
    item:
      TokenDomains: '{{ item.TokenDomains }}'
      APIKey: '{{ item.APIKey }}'
      CreationTimestamp: '{{ item.CreationTimestamp }}'
      Version: '{{ item.Version }}'
- discovery_id: aws.wafv2.listAvailableManagedRuleGroupVersions
  calls:
  - action: listAvailableManagedRuleGroupVersions
    save_as: response
    on_error: continue
    params:
      Limit: 1000
  emit:
    as: item
    items_for: '{{ response.Versions }}'
    item:
      Name: '{{ item.Name }}'
      LastUpdateTimestamp: '{{ item.LastUpdateTimestamp }}'
- discovery_id: aws.wafv2.listAvailableManagedRuleGroups
  calls:
  - action: listAvailableManagedRuleGroups
    save_as: response
    on_error: continue
    params:
      Limit: 1000
  emit:
    as: item
    items_for: '{{ response.ManagedRuleGroups }}'
    item:
      VendorName: '{{ item.VendorName }}'
      Name: '{{ item.Name }}'
      VersioningSupported: '{{ item.VersioningSupported }}'
      Description: '{{ item.Description }}'
- discovery_id: aws.wafv2.listIpSets
  calls:
  - action: listIpSets
    save_as: response
    on_error: continue
    params:
      Limit: 1000
  emit:
    as: item
    items_for: '{{ response.IPSets }}'
    item:
      Name: '{{ item.Name }}'
      Id: '{{ item.Id }}'
      Description: '{{ item.Description }}'
      LockToken: '{{ item.LockToken }}'
      ARN: '{{ item.ARN }}'
- discovery_id: aws.wafv2.listLoggingConfigurations
  calls:
  - action: listLoggingConfigurations
    save_as: response
    on_error: continue
    params:
      Limit: 1000
  emit:
    as: item
    items_for: '{{ response.LoggingConfigurations }}'
    item:
      ResourceArn: '{{ item.ResourceArn }}'
      LogDestinationConfigs: '{{ item.LogDestinationConfigs }}'
      RedactedFields: '{{ item.RedactedFields }}'
      ManagedByFirewallManager: '{{ item.ManagedByFirewallManager }}'
      LoggingFilter: '{{ item.LoggingFilter }}'
      LogType: '{{ item.LogType }}'
      LogScope: '{{ item.LogScope }}'
- discovery_id: aws.wafv2.listManagedRuleSets
  calls:
  - action: listManagedRuleSets
    save_as: response
    on_error: continue
    params:
      Limit: 1000
  emit:
    as: item
    items_for: '{{ response.ManagedRuleSets }}'
    item:
      Name: '{{ item.Name }}'
      Id: '{{ item.Id }}'
      Description: '{{ item.Description }}'
      LockToken: '{{ item.LockToken }}'
      ARN: '{{ item.ARN }}'
      LabelNamespace: '{{ item.LabelNamespace }}'
- discovery_id: aws.wafv2.listMobileSdkReleases
  calls:
  - action: listMobileSdkReleases
    save_as: response
    on_error: continue
    params:
      Limit: 1000
  emit:
    as: item
    items_for: '{{ response.ReleaseSummaries }}'
    item:
      ReleaseVersion: '{{ item.ReleaseVersion }}'
      Timestamp: '{{ item.Timestamp }}'
- discovery_id: aws.wafv2.listRegexPatternSets
  calls:
  - action: listRegexPatternSets
    save_as: response
    on_error: continue
    params:
      Limit: 1000
  emit:
    as: item
    items_for: '{{ response.RegexPatternSets }}'
    item:
      Name: '{{ item.Name }}'
      Id: '{{ item.Id }}'
      Description: '{{ item.Description }}'
      LockToken: '{{ item.LockToken }}'
      ARN: '{{ item.ARN }}'
- discovery_id: aws.wafv2.listResourcesForWebAcl
  calls:
  - action: listResourcesForWebAcl
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ResourceArns }}'
- discovery_id: aws.wafv2.listRuleGroups
  calls:
  - action: listRuleGroups
    save_as: response
    on_error: continue
    params:
      Limit: 1000
  emit:
    as: item
    items_for: '{{ response.RuleGroups }}'
    item:
      Name: '{{ item.Name }}'
      Id: '{{ item.Id }}'
      Description: '{{ item.Description }}'
      LockToken: '{{ item.LockToken }}'
      ARN: '{{ item.ARN }}'
- discovery_id: aws.wafv2.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
    params:
      Limit: 1000
  emit:
    as: item
    items_for: '{{ response.TagInfoForResource }}'
    item:
      ResourceARN: '{{ item.ResourceARN }}'
      TagList: '{{ item.TagList }}'
- discovery_id: aws.wafv2.listWebAcLs
  calls:
  - action: listWebAcLs
    save_as: response
    on_error: continue
    params:
      Limit: 1000
  emit:
    as: item
    items_for: '{{ response.WebACLs }}'
    item:
      Name: '{{ item.Name }}'
      Id: '{{ item.Id }}'
      Description: '{{ item.Description }}'
      LockToken: '{{ item.LockToken }}'
      ARN: '{{ item.ARN }}'
checks: []
