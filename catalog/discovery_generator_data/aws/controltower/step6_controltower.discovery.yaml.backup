version: '1.0'
provider: aws
service: controltower
services:
  client: controltower
  module: boto3.client
discovery:
- discovery_id: aws.controltower.listBaselines
  calls:
  - action: listBaselines
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.baselines }}'
    item:
      arn: '{{ item.arn }}'
      name: '{{ item.name }}'
      description: '{{ item.description }}'
- discovery_id: aws.controltower.listControlOperations
  calls:
  - action: listControlOperations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.controlOperations }}'
    item:
      operationType: '{{ item.operationType }}'
      startTime: '{{ item.startTime }}'
      endTime: '{{ item.endTime }}'
      status: '{{ item.status }}'
      statusMessage: '{{ item.statusMessage }}'
      operationIdentifier: '{{ item.operationIdentifier }}'
      controlIdentifier: '{{ item.controlIdentifier }}'
      targetIdentifier: '{{ item.targetIdentifier }}'
      enabledControlIdentifier: '{{ item.enabledControlIdentifier }}'
- discovery_id: aws.controltower.listEnabledBaselines
  calls:
  - action: listEnabledBaselines
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.enabledBaselines }}'
    item:
      arn: '{{ item.arn }}'
      baselineIdentifier: '{{ item.baselineIdentifier }}'
      baselineVersion: '{{ item.baselineVersion }}'
      driftStatusSummary: '{{ item.driftStatusSummary }}'
      targetIdentifier: '{{ item.targetIdentifier }}'
      parentIdentifier: '{{ item.parentIdentifier }}'
      statusSummary: '{{ item.statusSummary }}'
- discovery_id: aws.controltower.listEnabledControls
  calls:
  - action: listEnabledControls
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.enabledControls }}'
    item:
      arn: '{{ item.arn }}'
      controlIdentifier: '{{ item.controlIdentifier }}'
      targetIdentifier: '{{ item.targetIdentifier }}'
      statusSummary: '{{ item.statusSummary }}'
      driftStatusSummary: '{{ item.driftStatusSummary }}'
      parentIdentifier: '{{ item.parentIdentifier }}'
- discovery_id: aws.controltower.listLandingZoneOperations
  calls:
  - action: listLandingZoneOperations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.landingZoneOperations }}'
    item:
      operationType: '{{ item.operationType }}'
      operationIdentifier: '{{ item.operationIdentifier }}'
      status: '{{ item.status }}'
- discovery_id: aws.controltower.listLandingZones
  calls:
  - action: listLandingZones
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.landingZones }}'
    item:
      arn: '{{ item.arn }}'
- discovery_id: aws.controltower.getBaseline
  calls:
  - action: getBaseline
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.arn }}'
- discovery_id: aws.controltower.getBaselineOperation
  calls:
  - action: getBaselineOperation
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.baselineOperation }}'
    item:
      operationIdentifier: '{{ item.operationIdentifier }}'
      operationType: '{{ item.operationType }}'
      status: '{{ item.status }}'
      startTime: '{{ item.startTime }}'
      endTime: '{{ item.endTime }}'
      statusMessage: '{{ item.statusMessage }}'
- discovery_id: aws.controltower.getControlOperation
  calls:
  - action: getControlOperation
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.controlOperation }}'
    item:
      operationType: '{{ item.operationType }}'
      startTime: '{{ item.startTime }}'
      endTime: '{{ item.endTime }}'
      status: '{{ item.status }}'
      statusMessage: '{{ item.statusMessage }}'
      operationIdentifier: '{{ item.operationIdentifier }}'
      controlIdentifier: '{{ item.controlIdentifier }}'
      targetIdentifier: '{{ item.targetIdentifier }}'
      enabledControlIdentifier: '{{ item.enabledControlIdentifier }}'
- discovery_id: aws.controltower.getEnabledBaseline
  calls:
  - action: getEnabledBaseline
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.enabledBaselineDetails }}'
    item:
      arn: '{{ item.arn }}'
      baselineIdentifier: '{{ item.baselineIdentifier }}'
      baselineVersion: '{{ item.baselineVersion }}'
      driftStatusSummary: '{{ item.driftStatusSummary }}'
      targetIdentifier: '{{ item.targetIdentifier }}'
      parentIdentifier: '{{ item.parentIdentifier }}'
      statusSummary: '{{ item.statusSummary }}'
      parameters: '{{ item.parameters }}'
- discovery_id: aws.controltower.getEnabledControl
  calls:
  - action: getEnabledControl
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.enabledControlDetails }}'
    item:
      arn: '{{ item.arn }}'
      controlIdentifier: '{{ item.controlIdentifier }}'
      targetIdentifier: '{{ item.targetIdentifier }}'
      statusSummary: '{{ item.statusSummary }}'
      driftStatusSummary: '{{ item.driftStatusSummary }}'
      parentIdentifier: '{{ item.parentIdentifier }}'
      targetRegions: '{{ item.targetRegions }}'
      parameters: '{{ item.parameters }}'
- discovery_id: aws.controltower.getLandingZone
  calls:
  - action: getLandingZone
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.landingZone }}'
    item:
      version: '{{ item.version }}'
      remediationTypes: '{{ item.remediationTypes }}'
      arn: '{{ item.arn }}'
      status: '{{ item.status }}'
      latestAvailableVersion: '{{ item.latestAvailableVersion }}'
      driftStatus: '{{ item.driftStatus }}'
      manifest: '{{ item.manifest }}'
- discovery_id: aws.controltower.getLandingZoneOperation
  calls:
  - action: getLandingZoneOperation
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.operationDetails }}'
    item:
      operationType: '{{ item.operationType }}'
      operationIdentifier: '{{ item.operationIdentifier }}'
      status: '{{ item.status }}'
      startTime: '{{ item.startTime }}'
      endTime: '{{ item.endTime }}'
      statusMessage: '{{ item.statusMessage }}'
- discovery_id: aws.controltower.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tags }}'
checks: []
