version: '1.0'
provider: aws
service: drs
services:
  client: drs
  module: boto3.client
discovery:
- discovery_id: aws.drs.describeJobs
  calls:
  - action: describeJobs
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
    item:
      arn: '{{ item.arn }}'
      creationDateTime: '{{ item.creationDateTime }}'
      endDateTime: '{{ item.endDateTime }}'
      initiatedBy: '{{ item.initiatedBy }}'
      jobID: '{{ item.jobID }}'
      participatingResources: '{{ item.participatingResources }}'
      participatingServers: '{{ item.participatingServers }}'
      status: '{{ item.status }}'
      tags: '{{ item.tags }}'
      type: '{{ item.type }}'
- discovery_id: aws.drs.describeLaunchConfigurationTemplates
  calls:
  - action: describeLaunchConfigurationTemplates
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
    item:
      arn: '{{ item.arn }}'
      copyPrivateIp: '{{ item.copyPrivateIp }}'
      copyTags: '{{ item.copyTags }}'
      exportBucketArn: '{{ item.exportBucketArn }}'
      launchConfigurationTemplateID: '{{ item.launchConfigurationTemplateID }}'
      launchDisposition: '{{ item.launchDisposition }}'
      launchIntoSourceInstance: '{{ item.launchIntoSourceInstance }}'
      licensing: '{{ item.licensing }}'
      postLaunchEnabled: '{{ item.postLaunchEnabled }}'
      tags: '{{ item.tags }}'
      targetInstanceTypeRightSizingMethod: '{{ item.targetInstanceTypeRightSizingMethod
        }}'
- discovery_id: aws.drs.describeRecoveryInstances
  calls:
  - action: describeRecoveryInstances
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
    item:
      agentVersion: '{{ item.agentVersion }}'
      arn: '{{ item.arn }}'
      dataReplicationInfo: '{{ item.dataReplicationInfo }}'
      ec2InstanceID: '{{ item.ec2InstanceID }}'
      ec2InstanceState: '{{ item.ec2InstanceState }}'
      failback: '{{ item.failback }}'
      isDrill: '{{ item.isDrill }}'
      jobID: '{{ item.jobID }}'
      originAvailabilityZone: '{{ item.originAvailabilityZone }}'
      originEnvironment: '{{ item.originEnvironment }}'
      pointInTimeSnapshotDateTime: '{{ item.pointInTimeSnapshotDateTime }}'
      recoveryInstanceID: '{{ item.recoveryInstanceID }}'
      recoveryInstanceProperties: '{{ item.recoveryInstanceProperties }}'
      sourceOutpostArn: '{{ item.sourceOutpostArn }}'
      sourceServerID: '{{ item.sourceServerID }}'
      tags: '{{ item.tags }}'
- discovery_id: aws.drs.describeReplicationConfigurationTemplates
  calls:
  - action: describeReplicationConfigurationTemplates
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
    item:
      arn: '{{ item.arn }}'
      associateDefaultSecurityGroup: '{{ item.associateDefaultSecurityGroup }}'
      autoReplicateNewDisks: '{{ item.autoReplicateNewDisks }}'
      bandwidthThrottling: '{{ item.bandwidthThrottling }}'
      createPublicIP: '{{ item.createPublicIP }}'
      dataPlaneRouting: '{{ item.dataPlaneRouting }}'
      defaultLargeStagingDiskType: '{{ item.defaultLargeStagingDiskType }}'
      ebsEncryption: '{{ item.ebsEncryption }}'
      ebsEncryptionKeyArn: '{{ item.ebsEncryptionKeyArn }}'
      pitPolicy: '{{ item.pitPolicy }}'
      replicationConfigurationTemplateID: '{{ item.replicationConfigurationTemplateID
        }}'
      replicationServerInstanceType: '{{ item.replicationServerInstanceType }}'
      replicationServersSecurityGroupsIDs: '{{ item.replicationServersSecurityGroupsIDs
        }}'
      stagingAreaSubnetId: '{{ item.stagingAreaSubnetId }}'
      stagingAreaTags: '{{ item.stagingAreaTags }}'
      tags: '{{ item.tags }}'
      useDedicatedReplicationServer: '{{ item.useDedicatedReplicationServer }}'
- discovery_id: aws.drs.describeSourceNetworks
  calls:
  - action: describeSourceNetworks
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
    item:
      arn: '{{ item.arn }}'
      cfnStackName: '{{ item.cfnStackName }}'
      lastRecovery: '{{ item.lastRecovery }}'
      launchedVpcID: '{{ item.launchedVpcID }}'
      replicationStatus: '{{ item.replicationStatus }}'
      replicationStatusDetails: '{{ item.replicationStatusDetails }}'
      sourceAccountID: '{{ item.sourceAccountID }}'
      sourceNetworkID: '{{ item.sourceNetworkID }}'
      sourceRegion: '{{ item.sourceRegion }}'
      sourceVpcID: '{{ item.sourceVpcID }}'
      tags: '{{ item.tags }}'
- discovery_id: aws.drs.describeSourceServers
  calls:
  - action: describeSourceServers
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
    item:
      agentVersion: '{{ item.agentVersion }}'
      arn: '{{ item.arn }}'
      dataReplicationInfo: '{{ item.dataReplicationInfo }}'
      lastLaunchResult: '{{ item.lastLaunchResult }}'
      lifeCycle: '{{ item.lifeCycle }}'
      recoveryInstanceId: '{{ item.recoveryInstanceId }}'
      replicationDirection: '{{ item.replicationDirection }}'
      reversedDirectionSourceServerArn: '{{ item.reversedDirectionSourceServerArn
        }}'
      sourceCloudProperties: '{{ item.sourceCloudProperties }}'
      sourceNetworkID: '{{ item.sourceNetworkID }}'
      sourceProperties: '{{ item.sourceProperties }}'
      sourceServerID: '{{ item.sourceServerID }}'
      stagingArea: '{{ item.stagingArea }}'
      tags: '{{ item.tags }}'
- discovery_id: aws.drs.listStagingAccounts
  calls:
  - action: listStagingAccounts
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.accounts }}'
    item:
      accountID: '{{ item.accountID }}'
- discovery_id: aws.drs.describeJobLogItems
  calls:
  - action: describeJobLogItems
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
    item:
      event: '{{ item.event }}'
      eventData: '{{ item.eventData }}'
      logDateTime: '{{ item.logDateTime }}'
- discovery_id: aws.drs.describeRecoverySnapshots
  calls:
  - action: describeRecoverySnapshots
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
    item:
      ebsSnapshots: '{{ item.ebsSnapshots }}'
      expectedTimestamp: '{{ item.expectedTimestamp }}'
      snapshotID: '{{ item.snapshotID }}'
      sourceServerID: '{{ item.sourceServerID }}'
      timestamp: '{{ item.timestamp }}'
- discovery_id: aws.drs.getFailbackReplicationConfiguration
  calls:
  - action: getFailbackReplicationConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.bandwidthThrottling }}'
- discovery_id: aws.drs.getLaunchConfiguration
  calls:
  - action: getLaunchConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.launchIntoInstanceProperties }}'
    item:
      launchIntoEC2InstanceID: '{{ item.launchIntoEC2InstanceID }}'
- discovery_id: aws.drs.getReplicationConfiguration
  calls:
  - action: getReplicationConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.replicationServersSecurityGroupsIDs }}'
- discovery_id: aws.drs.listExtensibleSourceServers
  calls:
  - action: listExtensibleSourceServers
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
    item:
      arn: '{{ item.arn }}'
      hostname: '{{ item.hostname }}'
      tags: '{{ item.tags }}'
- discovery_id: aws.drs.listLaunchActions
  calls:
  - action: listLaunchActions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
    item:
      actionCode: '{{ item.actionCode }}'
      actionId: '{{ item.actionId }}'
      actionVersion: '{{ item.actionVersion }}'
      active: '{{ item.active }}'
      category: '{{ item.category }}'
      description: '{{ item.description }}'
      name: '{{ item.name }}'
      optional: '{{ item.optional }}'
      order: '{{ item.order }}'
      parameters: '{{ item.parameters }}'
      type: '{{ item.type }}'
- discovery_id: aws.drs.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tags }}'
checks: []
