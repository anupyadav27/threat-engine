version: '1.0'
provider: aws
service: codeconnections
services:
  client: codeconnections
  module: boto3.client
discovery:
- discovery_id: aws.codeconnections.listConnections
  calls:
  - action: listConnections
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Connections }}'
    item:
      ConnectionName: '{{ item.ConnectionName }}'
      ConnectionArn: '{{ item.ConnectionArn }}'
      ProviderType: '{{ item.ProviderType }}'
      OwnerAccountId: '{{ item.OwnerAccountId }}'
      ConnectionStatus: '{{ item.ConnectionStatus }}'
      HostArn: '{{ item.HostArn }}'
- discovery_id: aws.codeconnections.listHosts
  calls:
  - action: listHosts
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Hosts }}'
    item:
      Name: '{{ item.Name }}'
      HostArn: '{{ item.HostArn }}'
      ProviderType: '{{ item.ProviderType }}'
      ProviderEndpoint: '{{ item.ProviderEndpoint }}'
      VpcConfiguration: '{{ item.VpcConfiguration }}'
      Status: '{{ item.Status }}'
      StatusMessage: '{{ item.StatusMessage }}'
- discovery_id: aws.codeconnections.listRepositoryLinks
  calls:
  - action: listRepositoryLinks
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.RepositoryLinks }}'
    item:
      ConnectionArn: '{{ item.ConnectionArn }}'
      EncryptionKeyArn: '{{ item.EncryptionKeyArn }}'
      OwnerId: '{{ item.OwnerId }}'
      ProviderType: '{{ item.ProviderType }}'
      RepositoryLinkArn: '{{ item.RepositoryLinkArn }}'
      RepositoryLinkId: '{{ item.RepositoryLinkId }}'
      RepositoryName: '{{ item.RepositoryName }}'
- discovery_id: aws.codeconnections.getConnection
  calls:
  - action: getConnection
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Connection }}'
    item:
      ConnectionName: '{{ item.ConnectionName }}'
      ConnectionArn: '{{ item.ConnectionArn }}'
      ProviderType: '{{ item.ProviderType }}'
      OwnerAccountId: '{{ item.OwnerAccountId }}'
      ConnectionStatus: '{{ item.ConnectionStatus }}'
      HostArn: '{{ item.HostArn }}'
- discovery_id: aws.codeconnections.getHost
  calls:
  - action: getHost
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.VpcConfiguration }}'
    item:
      VpcId: '{{ item.VpcId }}'
      SubnetIds: '{{ item.SubnetIds }}'
      SecurityGroupIds: '{{ item.SecurityGroupIds }}'
      TlsCertificate: '{{ item.TlsCertificate }}'
- discovery_id: aws.codeconnections.getRepositoryLink
  calls:
  - action: getRepositoryLink
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.RepositoryLinkInfo }}'
    item:
      ConnectionArn: '{{ item.ConnectionArn }}'
      EncryptionKeyArn: '{{ item.EncryptionKeyArn }}'
      OwnerId: '{{ item.OwnerId }}'
      ProviderType: '{{ item.ProviderType }}'
      RepositoryLinkArn: '{{ item.RepositoryLinkArn }}'
      RepositoryLinkId: '{{ item.RepositoryLinkId }}'
      RepositoryName: '{{ item.RepositoryName }}'
- discovery_id: aws.codeconnections.getRepositorySyncStatus
  calls:
  - action: getRepositorySyncStatus
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.LatestSync }}'
    item:
      StartedAt: '{{ item.StartedAt }}'
      Status: '{{ item.Status }}'
      Events: '{{ item.Events }}'
- discovery_id: aws.codeconnections.getResourceSyncStatus
  calls:
  - action: getResourceSyncStatus
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.DesiredState }}'
    item:
      Branch: '{{ item.Branch }}'
      Directory: '{{ item.Directory }}'
      OwnerId: '{{ item.OwnerId }}'
      RepositoryName: '{{ item.RepositoryName }}'
      ProviderType: '{{ item.ProviderType }}'
      Sha: '{{ item.Sha }}'
- discovery_id: aws.codeconnections.getSyncBlockerSummary
  calls:
  - action: getSyncBlockerSummary
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.SyncBlockerSummary }}'
    item:
      ResourceName: '{{ item.ResourceName }}'
      ParentResourceName: '{{ item.ParentResourceName }}'
      LatestBlockers: '{{ item.LatestBlockers }}'
- discovery_id: aws.codeconnections.getSyncConfiguration
  calls:
  - action: getSyncConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.SyncConfiguration }}'
    item:
      Branch: '{{ item.Branch }}'
      ConfigFile: '{{ item.ConfigFile }}'
      OwnerId: '{{ item.OwnerId }}'
      ProviderType: '{{ item.ProviderType }}'
      RepositoryLinkId: '{{ item.RepositoryLinkId }}'
      RepositoryName: '{{ item.RepositoryName }}'
      ResourceName: '{{ item.ResourceName }}'
      RoleArn: '{{ item.RoleArn }}'
      SyncType: '{{ item.SyncType }}'
      PublishDeploymentStatus: '{{ item.PublishDeploymentStatus }}'
      TriggerResourceUpdateOn: '{{ item.TriggerResourceUpdateOn }}'
      PullRequestComment: '{{ item.PullRequestComment }}'
- discovery_id: aws.codeconnections.listRepositorySyncDefinitions
  calls:
  - action: listRepositorySyncDefinitions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.RepositorySyncDefinitions }}'
    item:
      Branch: '{{ item.Branch }}'
      Directory: '{{ item.Directory }}'
      Parent: '{{ item.Parent }}'
      Target: '{{ item.Target }}'
- discovery_id: aws.codeconnections.listSyncConfigurations
  calls:
  - action: listSyncConfigurations
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.SyncConfigurations }}'
    item:
      Branch: '{{ item.Branch }}'
      ConfigFile: '{{ item.ConfigFile }}'
      OwnerId: '{{ item.OwnerId }}'
      ProviderType: '{{ item.ProviderType }}'
      RepositoryLinkId: '{{ item.RepositoryLinkId }}'
      RepositoryName: '{{ item.RepositoryName }}'
      ResourceName: '{{ item.ResourceName }}'
      RoleArn: '{{ item.RoleArn }}'
      SyncType: '{{ item.SyncType }}'
      PublishDeploymentStatus: '{{ item.PublishDeploymentStatus }}'
      TriggerResourceUpdateOn: '{{ item.TriggerResourceUpdateOn }}'
      PullRequestComment: '{{ item.PullRequestComment }}'
- discovery_id: aws.codeconnections.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Tags }}'
    item:
      Key: '{{ item.Key }}'
      Value: '{{ item.Value }}'
checks: []
