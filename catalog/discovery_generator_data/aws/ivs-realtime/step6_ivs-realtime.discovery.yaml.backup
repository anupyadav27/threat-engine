version: '1.0'
provider: aws
service: ivs-realtime
services:
  client: ivs-realtime
  module: boto3.client
discovery:
- discovery_id: aws.ivs-realtime.listCompositions
  calls:
  - action: listCompositions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.compositions }}'
    item:
      arn: '{{ item.arn }}'
      stageArn: '{{ item.stageArn }}'
      destinations: '{{ item.destinations }}'
      state: '{{ item.state }}'
      tags: '{{ item.tags }}'
      startTime: '{{ item.startTime }}'
      endTime: '{{ item.endTime }}'
- discovery_id: aws.ivs-realtime.listEncoderConfigurations
  calls:
  - action: listEncoderConfigurations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.encoderConfigurations }}'
    item:
      arn: '{{ item.arn }}'
      name: '{{ item.name }}'
      tags: '{{ item.tags }}'
- discovery_id: aws.ivs-realtime.listIngestConfigurations
  calls:
  - action: listIngestConfigurations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ingestConfigurations }}'
    item:
      name: '{{ item.name }}'
      arn: '{{ item.arn }}'
      ingestProtocol: '{{ item.ingestProtocol }}'
      stageArn: '{{ item.stageArn }}'
      participantId: '{{ item.participantId }}'
      state: '{{ item.state }}'
      userId: '{{ item.userId }}'
- discovery_id: aws.ivs-realtime.listPublicKeys
  calls:
  - action: listPublicKeys
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.publicKeys }}'
    item:
      arn: '{{ item.arn }}'
      name: '{{ item.name }}'
      tags: '{{ item.tags }}'
- discovery_id: aws.ivs-realtime.listStages
  calls:
  - action: listStages
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.stages }}'
    item:
      arn: '{{ item.arn }}'
      name: '{{ item.name }}'
      activeSessionId: '{{ item.activeSessionId }}'
      tags: '{{ item.tags }}'
- discovery_id: aws.ivs-realtime.listStorageConfigurations
  calls:
  - action: listStorageConfigurations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.storageConfigurations }}'
    item:
      arn: '{{ item.arn }}'
      name: '{{ item.name }}'
      s3: '{{ item.s3 }}'
      tags: '{{ item.tags }}'
- discovery_id: aws.ivs-realtime.getComposition
  calls:
  - action: getComposition
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.composition }}'
    item:
      arn: '{{ item.arn }}'
      stageArn: '{{ item.stageArn }}'
      state: '{{ item.state }}'
      layout: '{{ item.layout }}'
      destinations: '{{ item.destinations }}'
      tags: '{{ item.tags }}'
      startTime: '{{ item.startTime }}'
      endTime: '{{ item.endTime }}'
- discovery_id: aws.ivs-realtime.getEncoderConfiguration
  calls:
  - action: getEncoderConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.encoderConfiguration }}'
    item:
      arn: '{{ item.arn }}'
      name: '{{ item.name }}'
      video: '{{ item.video }}'
      tags: '{{ item.tags }}'
- discovery_id: aws.ivs-realtime.getIngestConfiguration
  calls:
  - action: getIngestConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ingestConfiguration }}'
    item:
      name: '{{ item.name }}'
      arn: '{{ item.arn }}'
      ingestProtocol: '{{ item.ingestProtocol }}'
      streamKey: '{{ item.streamKey }}'
      stageArn: '{{ item.stageArn }}'
      participantId: '{{ item.participantId }}'
      state: '{{ item.state }}'
      userId: '{{ item.userId }}'
      attributes: '{{ item.attributes }}'
      tags: '{{ item.tags }}'
- discovery_id: aws.ivs-realtime.getParticipant
  calls:
  - action: getParticipant
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.participant }}'
    item:
      participantId: '{{ item.participantId }}'
      userId: '{{ item.userId }}'
      state: '{{ item.state }}'
      firstJoinTime: '{{ item.firstJoinTime }}'
      attributes: '{{ item.attributes }}'
      published: '{{ item.published }}'
      ispName: '{{ item.ispName }}'
      osName: '{{ item.osName }}'
      osVersion: '{{ item.osVersion }}'
      browserName: '{{ item.browserName }}'
      browserVersion: '{{ item.browserVersion }}'
      sdkVersion: '{{ item.sdkVersion }}'
      recordingS3BucketName: '{{ item.recordingS3BucketName }}'
      recordingS3Prefix: '{{ item.recordingS3Prefix }}'
      recordingState: '{{ item.recordingState }}'
      protocol: '{{ item.protocol }}'
      replicationType: '{{ item.replicationType }}'
      replicationState: '{{ item.replicationState }}'
      sourceStageArn: '{{ item.sourceStageArn }}'
      sourceSessionId: '{{ item.sourceSessionId }}'
- discovery_id: aws.ivs-realtime.getPublicKey
  calls:
  - action: getPublicKey
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.publicKey }}'
    item:
      arn: '{{ item.arn }}'
      name: '{{ item.name }}'
      publicKeyMaterial: '{{ item.publicKeyMaterial }}'
      fingerprint: '{{ item.fingerprint }}'
      tags: '{{ item.tags }}'
- discovery_id: aws.ivs-realtime.getStage
  calls:
  - action: getStage
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.stage }}'
    item:
      arn: '{{ item.arn }}'
      name: '{{ item.name }}'
      activeSessionId: '{{ item.activeSessionId }}'
      tags: '{{ item.tags }}'
      autoParticipantRecordingConfiguration: '{{ item.autoParticipantRecordingConfiguration
        }}'
      endpoints: '{{ item.endpoints }}'
- discovery_id: aws.ivs-realtime.getStageSession
  calls:
  - action: getStageSession
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.stageSession }}'
    item:
      sessionId: '{{ item.sessionId }}'
      startTime: '{{ item.startTime }}'
      endTime: '{{ item.endTime }}'
- discovery_id: aws.ivs-realtime.getStorageConfiguration
  calls:
  - action: getStorageConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.storageConfiguration }}'
    item:
      arn: '{{ item.arn }}'
      name: '{{ item.name }}'
      s3: '{{ item.s3 }}'
      tags: '{{ item.tags }}'
- discovery_id: aws.ivs-realtime.listParticipantEvents
  calls:
  - action: listParticipantEvents
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.events }}'
    item:
      name: '{{ item.name }}'
      participantId: '{{ item.participantId }}'
      eventTime: '{{ item.eventTime }}'
      remoteParticipantId: '{{ item.remoteParticipantId }}'
      errorCode: '{{ item.errorCode }}'
      destinationStageArn: '{{ item.destinationStageArn }}'
      destinationSessionId: '{{ item.destinationSessionId }}'
      replica: '{{ item.replica }}'
- discovery_id: aws.ivs-realtime.listParticipantReplicas
  calls:
  - action: listParticipantReplicas
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.replicas }}'
    item:
      sourceStageArn: '{{ item.sourceStageArn }}'
      participantId: '{{ item.participantId }}'
      sourceSessionId: '{{ item.sourceSessionId }}'
      destinationStageArn: '{{ item.destinationStageArn }}'
      destinationSessionId: '{{ item.destinationSessionId }}'
      replicationState: '{{ item.replicationState }}'
- discovery_id: aws.ivs-realtime.listParticipants
  calls:
  - action: listParticipants
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.participants }}'
    item:
      participantId: '{{ item.participantId }}'
      userId: '{{ item.userId }}'
      state: '{{ item.state }}'
      firstJoinTime: '{{ item.firstJoinTime }}'
      published: '{{ item.published }}'
      recordingState: '{{ item.recordingState }}'
      replicationType: '{{ item.replicationType }}'
      replicationState: '{{ item.replicationState }}'
      sourceStageArn: '{{ item.sourceStageArn }}'
      sourceSessionId: '{{ item.sourceSessionId }}'
- discovery_id: aws.ivs-realtime.listStageSessions
  calls:
  - action: listStageSessions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.stageSessions }}'
    item:
      sessionId: '{{ item.sessionId }}'
      startTime: '{{ item.startTime }}'
      endTime: '{{ item.endTime }}'
- discovery_id: aws.ivs-realtime.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tags }}'
checks: []
