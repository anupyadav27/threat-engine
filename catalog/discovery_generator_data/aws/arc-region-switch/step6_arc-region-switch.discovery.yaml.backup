version: '1.0'
provider: aws
service: arc-region-switch
services:
  client: arc-region-switch
  module: boto3.client
discovery:
- discovery_id: aws.arc-region-switch.listPlans
  calls:
  - action: listPlans
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.plans }}'
    item:
      arn: '{{ item.arn }}'
      owner: '{{ item.owner }}'
      name: '{{ item.name }}'
      regions: '{{ item.regions }}'
      recoveryApproach: '{{ item.recoveryApproach }}'
      primaryRegion: '{{ item.primaryRegion }}'
      version: '{{ item.version }}'
      updatedAt: '{{ item.updatedAt }}'
      description: '{{ item.description }}'
      executionRole: '{{ item.executionRole }}'
      activePlanExecution: '{{ item.activePlanExecution }}'
      recoveryTimeObjectiveMinutes: '{{ item.recoveryTimeObjectiveMinutes }}'
- discovery_id: aws.arc-region-switch.listPlansInRegion
  calls:
  - action: listPlansInRegion
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.plans }}'
    item:
      arn: '{{ item.arn }}'
      owner: '{{ item.owner }}'
      name: '{{ item.name }}'
      regions: '{{ item.regions }}'
      recoveryApproach: '{{ item.recoveryApproach }}'
      primaryRegion: '{{ item.primaryRegion }}'
      version: '{{ item.version }}'
      updatedAt: '{{ item.updatedAt }}'
      description: '{{ item.description }}'
      executionRole: '{{ item.executionRole }}'
      activePlanExecution: '{{ item.activePlanExecution }}'
      recoveryTimeObjectiveMinutes: '{{ item.recoveryTimeObjectiveMinutes }}'
- discovery_id: aws.arc-region-switch.getPlan
  calls:
  - action: getPlan
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.plan }}'
    item:
      arn: '{{ item.arn }}'
      description: '{{ item.description }}'
      workflows: '{{ item.workflows }}'
      executionRole: '{{ item.executionRole }}'
      recoveryTimeObjectiveMinutes: '{{ item.recoveryTimeObjectiveMinutes }}'
      associatedAlarms: '{{ item.associatedAlarms }}'
      triggers: '{{ item.triggers }}'
      name: '{{ item.name }}'
      regions: '{{ item.regions }}'
      recoveryApproach: '{{ item.recoveryApproach }}'
      primaryRegion: '{{ item.primaryRegion }}'
      owner: '{{ item.owner }}'
      version: '{{ item.version }}'
      updatedAt: '{{ item.updatedAt }}'
- discovery_id: aws.arc-region-switch.getPlanEvaluationStatus
  calls:
  - action: getPlanEvaluationStatus
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.warnings }}'
    item:
      workflow: '{{ item.workflow }}'
      version: '{{ item.version }}'
      stepName: '{{ item.stepName }}'
      resourceArn: '{{ item.resourceArn }}'
      warningStatus: '{{ item.warningStatus }}'
      warningUpdatedTime: '{{ item.warningUpdatedTime }}'
      warningMessage: '{{ item.warningMessage }}'
- discovery_id: aws.arc-region-switch.getPlanExecution
  calls:
  - action: getPlanExecution
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.stepStates }}'
    item:
      name: '{{ item.name }}'
      status: '{{ item.status }}'
      startTime: '{{ item.startTime }}'
      endTime: '{{ item.endTime }}'
      stepMode: '{{ item.stepMode }}'
- discovery_id: aws.arc-region-switch.getPlanInRegion
  calls:
  - action: getPlanInRegion
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.plan }}'
    item:
      arn: '{{ item.arn }}'
      description: '{{ item.description }}'
      workflows: '{{ item.workflows }}'
      executionRole: '{{ item.executionRole }}'
      recoveryTimeObjectiveMinutes: '{{ item.recoveryTimeObjectiveMinutes }}'
      associatedAlarms: '{{ item.associatedAlarms }}'
      triggers: '{{ item.triggers }}'
      name: '{{ item.name }}'
      regions: '{{ item.regions }}'
      recoveryApproach: '{{ item.recoveryApproach }}'
      primaryRegion: '{{ item.primaryRegion }}'
      owner: '{{ item.owner }}'
      version: '{{ item.version }}'
      updatedAt: '{{ item.updatedAt }}'
- discovery_id: aws.arc-region-switch.listPlanExecutionEvents
  calls:
  - action: listPlanExecutionEvents
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
    item:
      timestamp: '{{ item.timestamp }}'
      type: '{{ item.type }}'
      stepName: '{{ item.stepName }}'
      executionBlockType: '{{ item.executionBlockType }}'
      resources: '{{ item.resources }}'
      error: '{{ item.error }}'
      description: '{{ item.description }}'
      eventId: '{{ item.eventId }}'
      previousEventId: '{{ item.previousEventId }}'
- discovery_id: aws.arc-region-switch.listPlanExecutions
  calls:
  - action: listPlanExecutions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
    item:
      planArn: '{{ item.planArn }}'
      executionId: '{{ item.executionId }}'
      version: '{{ item.version }}'
      updatedAt: '{{ item.updatedAt }}'
      comment: '{{ item.comment }}'
      startTime: '{{ item.startTime }}'
      endTime: '{{ item.endTime }}'
      mode: '{{ item.mode }}'
      executionState: '{{ item.executionState }}'
      executionAction: '{{ item.executionAction }}'
      executionRegion: '{{ item.executionRegion }}'
      actualRecoveryTime: '{{ item.actualRecoveryTime }}'
- discovery_id: aws.arc-region-switch.listRoute53HealthChecks
  calls:
  - action: listRoute53HealthChecks
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.healthChecks }}'
    item:
      hostedZoneId: '{{ item.hostedZoneId }}'
      recordName: '{{ item.recordName }}'
      healthCheckId: '{{ item.healthCheckId }}'
      region: '{{ item.region }}'
- discovery_id: aws.arc-region-switch.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.resourceTags }}'
checks: []
