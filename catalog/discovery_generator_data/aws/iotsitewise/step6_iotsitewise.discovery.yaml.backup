version: '1.0'
provider: aws
service: iotsitewise
services:
  client: iotsitewise
  module: boto3.client
discovery:
- discovery_id: aws.iotsitewise.describeDefaultEncryptionConfiguration
  calls:
  - action: describeDefaultEncryptionConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.configurationStatus }}'
    item:
      state: '{{ item.state }}'
      error: '{{ item.error }}'
- discovery_id: aws.iotsitewise.describeLoggingOptions
  calls:
  - action: describeLoggingOptions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.loggingOptions }}'
    item:
      level: '{{ item.level }}'
- discovery_id: aws.iotsitewise.describeStorageConfiguration
  calls:
  - action: describeStorageConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.multiLayerStorage }}'
    item:
      customerManagedS3Storage: '{{ item.customerManagedS3Storage }}'
- discovery_id: aws.iotsitewise.describeTimeSeries
  calls:
  - action: describeTimeSeries
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.assetId }}'
- discovery_id: aws.iotsitewise.getAssetPropertyValue
  calls:
  - action: getAssetPropertyValue
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.propertyValue }}'
    item:
      value: '{{ item.value }}'
      timestamp: '{{ item.timestamp }}'
      quality: '{{ item.quality }}'
- discovery_id: aws.iotsitewise.getAssetPropertyValueHistory
  calls:
  - action: getAssetPropertyValueHistory
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.assetPropertyValueHistory }}'
    item:
      value: '{{ item.value }}'
      timestamp: '{{ item.timestamp }}'
      quality: '{{ item.quality }}'
- discovery_id: aws.iotsitewise.listAccessPolicies
  calls:
  - action: listAccessPolicies
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.accessPolicySummaries }}'
    item:
      id: '{{ item.id }}'
      identity: '{{ item.identity }}'
      resource: '{{ item.resource }}'
      permission: '{{ item.permission }}'
      creationDate: '{{ item.creationDate }}'
      lastUpdateDate: '{{ item.lastUpdateDate }}'
- discovery_id: aws.iotsitewise.listAssetModels
  calls:
  - action: listAssetModels
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.assetModelSummaries }}'
    item:
      id: '{{ item.id }}'
      externalId: '{{ item.externalId }}'
      arn: '{{ item.arn }}'
      name: '{{ item.name }}'
      assetModelType: '{{ item.assetModelType }}'
      description: '{{ item.description }}'
      creationDate: '{{ item.creationDate }}'
      lastUpdateDate: '{{ item.lastUpdateDate }}'
      status: '{{ item.status }}'
      version: '{{ item.version }}'
- discovery_id: aws.iotsitewise.listAssets
  calls:
  - action: listAssets
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.assetSummaries }}'
    item:
      id: '{{ item.id }}'
      externalId: '{{ item.externalId }}'
      arn: '{{ item.arn }}'
      name: '{{ item.name }}'
      assetModelId: '{{ item.assetModelId }}'
      creationDate: '{{ item.creationDate }}'
      lastUpdateDate: '{{ item.lastUpdateDate }}'
      status: '{{ item.status }}'
      hierarchies: '{{ item.hierarchies }}'
      description: '{{ item.description }}'
- discovery_id: aws.iotsitewise.listBulkImportJobs
  calls:
  - action: listBulkImportJobs
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.jobSummaries }}'
    item:
      id: '{{ item.id }}'
      name: '{{ item.name }}'
      status: '{{ item.status }}'
- discovery_id: aws.iotsitewise.listComputationModels
  calls:
  - action: listComputationModels
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.computationModelSummaries }}'
    item:
      id: '{{ item.id }}'
      arn: '{{ item.arn }}'
      name: '{{ item.name }}'
      description: '{{ item.description }}'
      type: '{{ item.type }}'
      creationDate: '{{ item.creationDate }}'
      lastUpdateDate: '{{ item.lastUpdateDate }}'
      status: '{{ item.status }}'
      version: '{{ item.version }}'
- discovery_id: aws.iotsitewise.listGateways
  calls:
  - action: listGateways
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.gatewaySummaries }}'
    item:
      gatewayId: '{{ item.gatewayId }}'
      gatewayName: '{{ item.gatewayName }}'
      gatewayPlatform: '{{ item.gatewayPlatform }}'
      gatewayVersion: '{{ item.gatewayVersion }}'
      gatewayCapabilitySummaries: '{{ item.gatewayCapabilitySummaries }}'
      creationDate: '{{ item.creationDate }}'
      lastUpdateDate: '{{ item.lastUpdateDate }}'
- discovery_id: aws.iotsitewise.listPortals
  calls:
  - action: listPortals
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.portalSummaries }}'
    item:
      id: '{{ item.id }}'
      name: '{{ item.name }}'
      description: '{{ item.description }}'
      startUrl: '{{ item.startUrl }}'
      creationDate: '{{ item.creationDate }}'
      lastUpdateDate: '{{ item.lastUpdateDate }}'
      roleArn: '{{ item.roleArn }}'
      status: '{{ item.status }}'
      portalType: '{{ item.portalType }}'
- discovery_id: aws.iotsitewise.listTimeSeries
  calls:
  - action: listTimeSeries
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.TimeSeriesSummaries }}'
    item:
      assetId: '{{ item.assetId }}'
      propertyId: '{{ item.propertyId }}'
      alias: '{{ item.alias }}'
      timeSeriesId: '{{ item.timeSeriesId }}'
      dataType: '{{ item.dataType }}'
      dataTypeSpec: '{{ item.dataTypeSpec }}'
      timeSeriesCreationDate: '{{ item.timeSeriesCreationDate }}'
      timeSeriesLastUpdateDate: '{{ item.timeSeriesLastUpdateDate }}'
      timeSeriesArn: '{{ item.timeSeriesArn }}'
- discovery_id: aws.iotsitewise.describeAccessPolicy
  calls:
  - action: describeAccessPolicy
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.accessPolicyIdentity }}'
    item:
      user: '{{ item.user }}'
      group: '{{ item.group }}'
      iamUser: '{{ item.iamUser }}'
      iamRole: '{{ item.iamRole }}'
- discovery_id: aws.iotsitewise.describeAction
  calls:
  - action: describeAction
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.targetResource }}'
    item:
      assetId: '{{ item.assetId }}'
      computationModelId: '{{ item.computationModelId }}'
- discovery_id: aws.iotsitewise.describeAsset
  calls:
  - action: describeAsset
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.assetProperties }}'
    item:
      id: '{{ item.id }}'
      externalId: '{{ item.externalId }}'
      name: '{{ item.name }}'
      alias: '{{ item.alias }}'
      notification: '{{ item.notification }}'
      dataType: '{{ item.dataType }}'
      dataTypeSpec: '{{ item.dataTypeSpec }}'
      unit: '{{ item.unit }}'
      path: '{{ item.path }}'
- discovery_id: aws.iotsitewise.describeAssetCompositeModel
  calls:
  - action: describeAssetCompositeModel
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.assetCompositeModelPath }}'
    item:
      id: '{{ item.id }}'
      name: '{{ item.name }}'
- discovery_id: aws.iotsitewise.describeAssetModel
  calls:
  - action: describeAssetModel
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.assetModelProperties }}'
    item:
      id: '{{ item.id }}'
      externalId: '{{ item.externalId }}'
      name: '{{ item.name }}'
      dataType: '{{ item.dataType }}'
      dataTypeSpec: '{{ item.dataTypeSpec }}'
      unit: '{{ item.unit }}'
      type: '{{ item.type }}'
      path: '{{ item.path }}'
- discovery_id: aws.iotsitewise.describeAssetModelCompositeModel
  calls:
  - action: describeAssetModelCompositeModel
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.assetModelCompositeModelPath }}'
    item:
      id: '{{ item.id }}'
      name: '{{ item.name }}'
- discovery_id: aws.iotsitewise.describeAssetModelInterfaceRelationship
  calls:
  - action: describeAssetModelInterfaceRelationship
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.propertyMappings }}'
    item:
      assetModelPropertyId: '{{ item.assetModelPropertyId }}'
      interfaceAssetModelPropertyId: '{{ item.interfaceAssetModelPropertyId }}'
- discovery_id: aws.iotsitewise.describeAssetProperty
  calls:
  - action: describeAssetProperty
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.assetProperty }}'
    item:
      id: '{{ item.id }}'
      externalId: '{{ item.externalId }}'
      name: '{{ item.name }}'
      alias: '{{ item.alias }}'
      notification: '{{ item.notification }}'
      dataType: '{{ item.dataType }}'
      unit: '{{ item.unit }}'
      type: '{{ item.type }}'
      path: '{{ item.path }}'
- discovery_id: aws.iotsitewise.describeBulkImportJob
  calls:
  - action: describeBulkImportJob
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.files }}'
    item:
      bucket: '{{ item.bucket }}'
      key: '{{ item.key }}'
      versionId: '{{ item.versionId }}'
- discovery_id: aws.iotsitewise.describeComputationModel
  calls:
  - action: describeComputationModel
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.actionDefinitions }}'
    item:
      actionDefinitionId: '{{ item.actionDefinitionId }}'
      actionName: '{{ item.actionName }}'
      actionType: '{{ item.actionType }}'
- discovery_id: aws.iotsitewise.describeComputationModelExecutionSummary
  calls:
  - action: describeComputationModelExecutionSummary
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.resolveTo }}'
    item:
      assetId: '{{ item.assetId }}'
- discovery_id: aws.iotsitewise.describeDashboard
  calls:
  - action: describeDashboard
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.dashboardId }}'
- discovery_id: aws.iotsitewise.describeDataset
  calls:
  - action: describeDataset
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.datasetSource }}'
    item:
      sourceType: '{{ item.sourceType }}'
      sourceFormat: '{{ item.sourceFormat }}'
      sourceDetail: '{{ item.sourceDetail }}'
- discovery_id: aws.iotsitewise.describeExecution
  calls:
  - action: describeExecution
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.targetResource }}'
    item:
      assetId: '{{ item.assetId }}'
      computationModelId: '{{ item.computationModelId }}'
- discovery_id: aws.iotsitewise.describeGateway
  calls:
  - action: describeGateway
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.gatewayCapabilitySummaries }}'
    item:
      capabilityNamespace: '{{ item.capabilityNamespace }}'
      capabilitySyncStatus: '{{ item.capabilitySyncStatus }}'
- discovery_id: aws.iotsitewise.describeGatewayCapabilityConfiguration
  calls:
  - action: describeGatewayCapabilityConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.gatewayId }}'
- discovery_id: aws.iotsitewise.describePortal
  calls:
  - action: describePortal
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.portalStatus }}'
    item:
      state: '{{ item.state }}'
      error: '{{ item.error }}'
- discovery_id: aws.iotsitewise.describeProject
  calls:
  - action: describeProject
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.projectId }}'
- discovery_id: aws.iotsitewise.getAssetPropertyAggregates
  calls:
  - action: getAssetPropertyAggregates
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.aggregatedValues }}'
    item:
      timestamp: '{{ item.timestamp }}'
      quality: '{{ item.quality }}'
      value: '{{ item.value }}'
- discovery_id: aws.iotsitewise.getInterpolatedAssetPropertyValues
  calls:
  - action: getInterpolatedAssetPropertyValues
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.interpolatedAssetPropertyValues }}'
    item:
      timestamp: '{{ item.timestamp }}'
      value: '{{ item.value }}'
- discovery_id: aws.iotsitewise.listActions
  calls:
  - action: listActions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.actionSummaries }}'
    item:
      actionId: '{{ item.actionId }}'
      actionDefinitionId: '{{ item.actionDefinitionId }}'
      targetResource: '{{ item.targetResource }}'
      resolveTo: '{{ item.resolveTo }}'
- discovery_id: aws.iotsitewise.listAssetModelCompositeModels
  calls:
  - action: listAssetModelCompositeModels
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.assetModelCompositeModelSummaries }}'
    item:
      id: '{{ item.id }}'
      externalId: '{{ item.externalId }}'
      name: '{{ item.name }}'
      type: '{{ item.type }}'
      description: '{{ item.description }}'
      path: '{{ item.path }}'
- discovery_id: aws.iotsitewise.listAssetModelProperties
  calls:
  - action: listAssetModelProperties
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.assetModelPropertySummaries }}'
    item:
      id: '{{ item.id }}'
      externalId: '{{ item.externalId }}'
      name: '{{ item.name }}'
      dataType: '{{ item.dataType }}'
      dataTypeSpec: '{{ item.dataTypeSpec }}'
      unit: '{{ item.unit }}'
      type: '{{ item.type }}'
      assetModelCompositeModelId: '{{ item.assetModelCompositeModelId }}'
      path: '{{ item.path }}'
      interfaceSummaries: '{{ item.interfaceSummaries }}'
- discovery_id: aws.iotsitewise.listAssetProperties
  calls:
  - action: listAssetProperties
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.assetPropertySummaries }}'
    item:
      id: '{{ item.id }}'
      externalId: '{{ item.externalId }}'
      alias: '{{ item.alias }}'
      unit: '{{ item.unit }}'
      notification: '{{ item.notification }}'
      assetCompositeModelId: '{{ item.assetCompositeModelId }}'
      path: '{{ item.path }}'
- discovery_id: aws.iotsitewise.listAssetRelationships
  calls:
  - action: listAssetRelationships
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.assetRelationshipSummaries }}'
    item:
      hierarchyInfo: '{{ item.hierarchyInfo }}'
      relationshipType: '{{ item.relationshipType }}'
- discovery_id: aws.iotsitewise.listAssociatedAssets
  calls:
  - action: listAssociatedAssets
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.assetSummaries }}'
    item:
      id: '{{ item.id }}'
      externalId: '{{ item.externalId }}'
      arn: '{{ item.arn }}'
      name: '{{ item.name }}'
      assetModelId: '{{ item.assetModelId }}'
      creationDate: '{{ item.creationDate }}'
      lastUpdateDate: '{{ item.lastUpdateDate }}'
      status: '{{ item.status }}'
      hierarchies: '{{ item.hierarchies }}'
      description: '{{ item.description }}'
- discovery_id: aws.iotsitewise.listCompositionRelationships
  calls:
  - action: listCompositionRelationships
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.compositionRelationshipSummaries }}'
    item:
      assetModelId: '{{ item.assetModelId }}'
      assetModelCompositeModelId: '{{ item.assetModelCompositeModelId }}'
      assetModelCompositeModelType: '{{ item.assetModelCompositeModelType }}'
- discovery_id: aws.iotsitewise.listComputationModelDataBindingUsages
  calls:
  - action: listComputationModelDataBindingUsages
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.dataBindingUsageSummaries }}'
    item:
      computationModelIds: '{{ item.computationModelIds }}'
      matchedDataBinding: '{{ item.matchedDataBinding }}'
- discovery_id: aws.iotsitewise.listComputationModelResolveToResources
  calls:
  - action: listComputationModelResolveToResources
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.computationModelResolveToResourceSummaries }}'
    item:
      resolveTo: '{{ item.resolveTo }}'
- discovery_id: aws.iotsitewise.listDashboards
  calls:
  - action: listDashboards
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.dashboardSummaries }}'
    item:
      id: '{{ item.id }}'
      name: '{{ item.name }}'
      description: '{{ item.description }}'
      creationDate: '{{ item.creationDate }}'
      lastUpdateDate: '{{ item.lastUpdateDate }}'
- discovery_id: aws.iotsitewise.listDatasets
  calls:
  - action: listDatasets
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.datasetSummaries }}'
    item:
      id: '{{ item.id }}'
      arn: '{{ item.arn }}'
      name: '{{ item.name }}'
      description: '{{ item.description }}'
      creationDate: '{{ item.creationDate }}'
      lastUpdateDate: '{{ item.lastUpdateDate }}'
      status: '{{ item.status }}'
- discovery_id: aws.iotsitewise.listExecutions
  calls:
  - action: listExecutions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.executionSummaries }}'
    item:
      executionId: '{{ item.executionId }}'
      actionType: '{{ item.actionType }}'
      targetResource: '{{ item.targetResource }}'
      targetResourceVersion: '{{ item.targetResourceVersion }}'
      resolveTo: '{{ item.resolveTo }}'
      executionStartTime: '{{ item.executionStartTime }}'
      executionEndTime: '{{ item.executionEndTime }}'
      executionStatus: '{{ item.executionStatus }}'
      executionEntityVersion: '{{ item.executionEntityVersion }}'
- discovery_id: aws.iotsitewise.listInterfaceRelationships
  calls:
  - action: listInterfaceRelationships
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.interfaceRelationshipSummaries }}'
    item:
      id: '{{ item.id }}'
- discovery_id: aws.iotsitewise.listProjectAssets
  calls:
  - action: listProjectAssets
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.assetIds }}'
- discovery_id: aws.iotsitewise.listProjects
  calls:
  - action: listProjects
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.projectSummaries }}'
    item:
      id: '{{ item.id }}'
      name: '{{ item.name }}'
      description: '{{ item.description }}'
      creationDate: '{{ item.creationDate }}'
      lastUpdateDate: '{{ item.lastUpdateDate }}'
- discovery_id: aws.iotsitewise.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tags }}'
checks: []
