version: '1.0'
provider: aws
service: servicecatalog-appregistry
services:
  client: servicecatalog-appregistry
  module: boto3.client
discovery:
- discovery_id: aws.servicecatalog-appregistry.getConfiguration
  calls:
  - action: getConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.configuration }}'
    item:
      tagQueryConfiguration: '{{ item.tagQueryConfiguration }}'
- discovery_id: aws.servicecatalog-appregistry.listApplications
  calls:
  - action: listApplications
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.applications }}'
    item:
      id: '{{ item.id }}'
      arn: '{{ item.arn }}'
      name: '{{ item.name }}'
      description: '{{ item.description }}'
      creationTime: '{{ item.creationTime }}'
      lastUpdateTime: '{{ item.lastUpdateTime }}'
- discovery_id: aws.servicecatalog-appregistry.listAttributeGroups
  calls:
  - action: listAttributeGroups
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.attributeGroups }}'
    item:
      id: '{{ item.id }}'
      arn: '{{ item.arn }}'
      name: '{{ item.name }}'
      description: '{{ item.description }}'
      creationTime: '{{ item.creationTime }}'
      lastUpdateTime: '{{ item.lastUpdateTime }}'
      createdBy: '{{ item.createdBy }}'
- discovery_id: aws.servicecatalog-appregistry.getApplication
  calls:
  - action: getApplication
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.integrations }}'
    item:
      resourceGroup: '{{ item.resourceGroup }}'
      applicationTagResourceGroup: '{{ item.applicationTagResourceGroup }}'
- discovery_id: aws.servicecatalog-appregistry.getAssociatedResource
  calls:
  - action: getAssociatedResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.options }}'
- discovery_id: aws.servicecatalog-appregistry.getAttributeGroup
  calls:
  - action: getAttributeGroup
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.id }}'
- discovery_id: aws.servicecatalog-appregistry.listAssociatedAttributeGroups
  calls:
  - action: listAssociatedAttributeGroups
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.attributeGroups }}'
- discovery_id: aws.servicecatalog-appregistry.listAssociatedResources
  calls:
  - action: listAssociatedResources
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.resources }}'
    item:
      name: '{{ item.name }}'
      arn: '{{ item.arn }}'
      resourceType: '{{ item.resourceType }}'
      resourceDetails: '{{ item.resourceDetails }}'
      options: '{{ item.options }}'
- discovery_id: aws.servicecatalog-appregistry.listAttributeGroupsForApplication
  calls:
  - action: listAttributeGroupsForApplication
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.attributeGroupsDetails }}'
    item:
      id: '{{ item.id }}'
      arn: '{{ item.arn }}'
      name: '{{ item.name }}'
      createdBy: '{{ item.createdBy }}'
- discovery_id: aws.servicecatalog-appregistry.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tags }}'
checks: []
