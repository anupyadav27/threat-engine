- discovery_id: aws.deadline.searchTasks
  calls:
  - action: searchTasks
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tasks }}'
    item:
      taskId: '{{ item.taskId }}'
      stepId: '{{ item.stepId }}'
      jobId: '{{ item.jobId }}'
      queueId: '{{ item.queueId }}'
      runStatus: '{{ item.runStatus }}'
      targetRunStatus: '{{ item.targetRunStatus }}'
      parameters: '{{ item.parameters }}'
      failureRetryCount: '{{ item.failureRetryCount }}'
      startedAt: '{{ item.startedAt }}'
      endedAt: '{{ item.endedAt }}'
      updatedAt: '{{ item.updatedAt }}'
      updatedBy: '{{ item.updatedBy }}'
- discovery_id: aws.deadline.searchWorkers
  calls:
  - action: searchWorkers
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.workers }}'
    item:
      fleetId: '{{ item.fleetId }}'
      workerId: '{{ item.workerId }}'
      status: '{{ item.status }}'
      hostProperties: '{{ item.hostProperties }}'
      createdBy: '{{ item.createdBy }}'
      createdAt: '{{ item.createdAt }}'
      updatedBy: '{{ item.updatedBy }}'
      updatedAt: '{{ item.updatedAt }}'
checks: []
