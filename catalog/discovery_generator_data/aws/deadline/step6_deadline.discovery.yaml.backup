version: '1.0'
provider: aws
service: deadline
services:
  client: deadline
  module: boto3.client
discovery:
- discovery_id: aws.deadline.listAvailableMeteredProducts
  calls:
  - action: listAvailableMeteredProducts
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.meteredProducts }}'
    item:
      productId: '{{ item.productId }}'
      family: '{{ item.family }}'
      vendor: '{{ item.vendor }}'
      port: '{{ item.port }}'
- discovery_id: aws.deadline.listFarms
  calls:
  - action: listFarms
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.farms }}'
    item:
      farmId: '{{ item.farmId }}'
      displayName: '{{ item.displayName }}'
      kmsKeyArn: '{{ item.kmsKeyArn }}'
      createdAt: '{{ item.createdAt }}'
      createdBy: '{{ item.createdBy }}'
      updatedAt: '{{ item.updatedAt }}'
      updatedBy: '{{ item.updatedBy }}'
- discovery_id: aws.deadline.listLicenseEndpoints
  calls:
  - action: listLicenseEndpoints
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.licenseEndpoints }}'
    item:
      licenseEndpointId: '{{ item.licenseEndpointId }}'
      status: '{{ item.status }}'
      statusMessage: '{{ item.statusMessage }}'
      vpcId: '{{ item.vpcId }}'
- discovery_id: aws.deadline.listMonitors
  calls:
  - action: listMonitors
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.monitors }}'
    item:
      monitorId: '{{ item.monitorId }}'
      displayName: '{{ item.displayName }}'
      subdomain: '{{ item.subdomain }}'
      url: '{{ item.url }}'
      roleArn: '{{ item.roleArn }}'
      identityCenterInstanceArn: '{{ item.identityCenterInstanceArn }}'
      identityCenterApplicationArn: '{{ item.identityCenterApplicationArn }}'
      createdAt: '{{ item.createdAt }}'
      createdBy: '{{ item.createdBy }}'
      updatedAt: '{{ item.updatedAt }}'
      updatedBy: '{{ item.updatedBy }}'
- discovery_id: aws.deadline.getBudget
  calls:
  - action: getBudget
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.actions }}'
    item:
      type: '{{ item.type }}'
      thresholdPercentage: '{{ item.thresholdPercentage }}'
      description: '{{ item.description }}'
- discovery_id: aws.deadline.getFarm
  calls:
  - action: getFarm
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.farmId }}'
- discovery_id: aws.deadline.getFleet
  calls:
  - action: getFleet
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.configuration }}'
    item:
      customerManaged: '{{ item.customerManaged }}'
      serviceManagedEc2: '{{ item.serviceManagedEc2 }}'
- discovery_id: aws.deadline.getJob
  calls:
  - action: getJob
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.attachments }}'
    item:
      manifests: '{{ item.manifests }}'
      fileSystem: '{{ item.fileSystem }}'
- discovery_id: aws.deadline.getLicenseEndpoint
  calls:
  - action: getLicenseEndpoint
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.subnetIds }}'
- discovery_id: aws.deadline.getLimit
  calls:
  - action: getLimit
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.displayName }}'
- discovery_id: aws.deadline.getMonitor
  calls:
  - action: getMonitor
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.monitorId }}'
- discovery_id: aws.deadline.getQueue
  calls:
  - action: getQueue
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.requiredFileSystemLocationNames }}'
- discovery_id: aws.deadline.getQueueEnvironment
  calls:
  - action: getQueueEnvironment
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.queueEnvironmentId }}'
- discovery_id: aws.deadline.getQueueFleetAssociation
  calls:
  - action: getQueueFleetAssociation
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.queueId }}'
- discovery_id: aws.deadline.getQueueLimitAssociation
  calls:
  - action: getQueueLimitAssociation
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.createdAt }}'
- discovery_id: aws.deadline.getSession
  calls:
  - action: getSession
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.log }}'
    item:
      logDriver: '{{ item.logDriver }}'
      options: '{{ item.options }}'
      parameters: '{{ item.parameters }}'
      error: '{{ item.error }}'
- discovery_id: aws.deadline.getSessionAction
  calls:
  - action: getSessionAction
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.acquiredLimits }}'
    item:
      limitId: '{{ item.limitId }}'
      count: '{{ item.count }}'
- discovery_id: aws.deadline.getSessionsStatisticsAggregation
  calls:
  - action: getSessionsStatisticsAggregation
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.statistics }}'
    item:
      queueId: '{{ item.queueId }}'
      fleetId: '{{ item.fleetId }}'
      jobId: '{{ item.jobId }}'
      jobName: '{{ item.jobName }}'
      userId: '{{ item.userId }}'
      usageType: '{{ item.usageType }}'
      licenseProduct: '{{ item.licenseProduct }}'
      instanceType: '{{ item.instanceType }}'
      count: '{{ item.count }}'
      costInUsd: '{{ item.costInUsd }}'
      runtimeInSeconds: '{{ item.runtimeInSeconds }}'
      aggregationStartTime: '{{ item.aggregationStartTime }}'
      aggregationEndTime: '{{ item.aggregationEndTime }}'
- discovery_id: aws.deadline.getStep
  calls:
  - action: getStep
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.dependencyCounts }}'
    item:
      dependenciesResolved: '{{ item.dependenciesResolved }}'
      dependenciesUnresolved: '{{ item.dependenciesUnresolved }}'
      consumersResolved: '{{ item.consumersResolved }}'
      consumersUnresolved: '{{ item.consumersUnresolved }}'
- discovery_id: aws.deadline.getStorageProfile
  calls:
  - action: getStorageProfile
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.fileSystemLocations }}'
    item:
      name: '{{ item.name }}'
      path: '{{ item.path }}'
      type: '{{ item.type }}'
- discovery_id: aws.deadline.getStorageProfileForQueue
  calls:
