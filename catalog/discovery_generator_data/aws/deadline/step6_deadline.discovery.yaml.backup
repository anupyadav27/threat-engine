      updatedAt: '{{ item.updatedAt }}'
      updatedBy: '{{ item.updatedBy }}'
      startedAt: '{{ item.startedAt }}'
      endedAt: '{{ item.endedAt }}'
      taskRunStatus: '{{ item.taskRunStatus }}'
      targetTaskRunStatus: '{{ item.targetTaskRunStatus }}'
      taskRunStatusCounts: '{{ item.taskRunStatusCounts }}'
      taskFailureRetryCount: '{{ item.taskFailureRetryCount }}'
      maxFailedTasksCount: '{{ item.maxFailedTasksCount }}'
      maxRetriesPerTask: '{{ item.maxRetriesPerTask }}'
      maxWorkerCount: '{{ item.maxWorkerCount }}'
