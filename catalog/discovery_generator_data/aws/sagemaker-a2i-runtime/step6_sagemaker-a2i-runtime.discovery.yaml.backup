version: '1.0'
provider: aws
service: sagemaker-a2i-runtime
services:
  client: sagemaker-a2i-runtime
  module: boto3.client
discovery:
- discovery_id: aws.sagemaker-a2i-runtime.describeHumanLoop
  calls:
  - action: describeHumanLoop
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.HumanLoopOutput }}'
    item:
      OutputS3Uri: '{{ item.OutputS3Uri }}'
- discovery_id: aws.sagemaker-a2i-runtime.listHumanLoops
  calls:
  - action: listHumanLoops
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.HumanLoopSummaries }}'
    item:
      HumanLoopName: '{{ item.HumanLoopName }}'
      HumanLoopStatus: '{{ item.HumanLoopStatus }}'
      CreationTime: '{{ item.CreationTime }}'
      FailureReason: '{{ item.FailureReason }}'
      FlowDefinitionArn: '{{ item.FlowDefinitionArn }}'
checks: []
