version: '1.0'
provider: aws
service: frauddetector
services:
  client: frauddetector
  module: boto3.client
discovery:
- discovery_id: aws.frauddetector.describeModelVersions
  calls:
  - action: describeModelVersions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.modelVersionDetails }}'
    item:
      modelId: '{{ item.modelId }}'
      modelType: '{{ item.modelType }}'
      modelVersionNumber: '{{ item.modelVersionNumber }}'
      status: '{{ item.status }}'
      trainingDataSource: '{{ item.trainingDataSource }}'
      trainingDataSchema: '{{ item.trainingDataSchema }}'
      externalEventsDetail: '{{ item.externalEventsDetail }}'
      ingestedEventsDetail: '{{ item.ingestedEventsDetail }}'
      trainingResult: '{{ item.trainingResult }}'
      lastUpdatedTime: '{{ item.lastUpdatedTime }}'
      createdTime: '{{ item.createdTime }}'
      arn: '{{ item.arn }}'
      trainingResultV2: '{{ item.trainingResultV2 }}'
- discovery_id: aws.frauddetector.getBatchImportJobs
  calls:
  - action: getBatchImportJobs
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.batchImports }}'
    item:
      jobId: '{{ item.jobId }}'
      status: '{{ item.status }}'
      failureReason: '{{ item.failureReason }}'
      startTime: '{{ item.startTime }}'
      completionTime: '{{ item.completionTime }}'
      inputPath: '{{ item.inputPath }}'
      outputPath: '{{ item.outputPath }}'
      eventTypeName: '{{ item.eventTypeName }}'
      iamRoleArn: '{{ item.iamRoleArn }}'
      arn: '{{ item.arn }}'
      processedRecordsCount: '{{ item.processedRecordsCount }}'
      failedRecordsCount: '{{ item.failedRecordsCount }}'
      totalRecordsCount: '{{ item.totalRecordsCount }}'
- discovery_id: aws.frauddetector.getBatchPredictionJobs
  calls:
  - action: getBatchPredictionJobs
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.batchPredictions }}'
    item:
      jobId: '{{ item.jobId }}'
      status: '{{ item.status }}'
      failureReason: '{{ item.failureReason }}'
      startTime: '{{ item.startTime }}'
      completionTime: '{{ item.completionTime }}'
      lastHeartbeatTime: '{{ item.lastHeartbeatTime }}'
      inputPath: '{{ item.inputPath }}'
      outputPath: '{{ item.outputPath }}'
      eventTypeName: '{{ item.eventTypeName }}'
      detectorName: '{{ item.detectorName }}'
      detectorVersion: '{{ item.detectorVersion }}'
      iamRoleArn: '{{ item.iamRoleArn }}'
      arn: '{{ item.arn }}'
      processedRecordsCount: '{{ item.processedRecordsCount }}'
      totalRecordsCount: '{{ item.totalRecordsCount }}'
- discovery_id: aws.frauddetector.getDetectors
  calls:
  - action: getDetectors
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.detectors }}'
    item:
      detectorId: '{{ item.detectorId }}'
      description: '{{ item.description }}'
      eventTypeName: '{{ item.eventTypeName }}'
      lastUpdatedTime: '{{ item.lastUpdatedTime }}'
      createdTime: '{{ item.createdTime }}'
      arn: '{{ item.arn }}'
- discovery_id: aws.frauddetector.getEntityTypes
  calls:
  - action: getEntityTypes
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.entityTypes }}'
    item:
      name: '{{ item.name }}'
      description: '{{ item.description }}'
      lastUpdatedTime: '{{ item.lastUpdatedTime }}'
      createdTime: '{{ item.createdTime }}'
      arn: '{{ item.arn }}'
- discovery_id: aws.frauddetector.getEventTypes
  calls:
  - action: getEventTypes
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.eventTypes }}'
    item:
      name: '{{ item.name }}'
      description: '{{ item.description }}'
      eventVariables: '{{ item.eventVariables }}'
      labels: '{{ item.labels }}'
      entityTypes: '{{ item.entityTypes }}'
      eventIngestion: '{{ item.eventIngestion }}'
      ingestedEventStatistics: '{{ item.ingestedEventStatistics }}'
      lastUpdatedTime: '{{ item.lastUpdatedTime }}'
      createdTime: '{{ item.createdTime }}'
      arn: '{{ item.arn }}'
      eventOrchestration: '{{ item.eventOrchestration }}'
- discovery_id: aws.frauddetector.getExternalModels
  calls:
  - action: getExternalModels
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.externalModels }}'
    item:
      modelEndpoint: '{{ item.modelEndpoint }}'
      modelSource: '{{ item.modelSource }}'
      invokeModelEndpointRoleArn: '{{ item.invokeModelEndpointRoleArn }}'
      inputConfiguration: '{{ item.inputConfiguration }}'
      outputConfiguration: '{{ item.outputConfiguration }}'
      modelEndpointStatus: '{{ item.modelEndpointStatus }}'
      lastUpdatedTime: '{{ item.lastUpdatedTime }}'
      createdTime: '{{ item.createdTime }}'
      arn: '{{ item.arn }}'
- discovery_id: aws.frauddetector.getKmsEncryptionKey
  calls:
  - action: getKmsEncryptionKey
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.kmsKey }}'
    item:
      kmsEncryptionKeyArn: '{{ item.kmsEncryptionKeyArn }}'
- discovery_id: aws.frauddetector.getLabels
  calls:
  - action: getLabels
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.labels }}'
    item:
      name: '{{ item.name }}'
      description: '{{ item.description }}'
      lastUpdatedTime: '{{ item.lastUpdatedTime }}'
      createdTime: '{{ item.createdTime }}'
      arn: '{{ item.arn }}'
- discovery_id: aws.frauddetector.getListsMetadata
  calls:
  - action: getListsMetadata
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.lists }}'
    item:
      name: '{{ item.name }}'
      description: '{{ item.description }}'
      variableType: '{{ item.variableType }}'
      createdTime: '{{ item.createdTime }}'
      updatedTime: '{{ item.updatedTime }}'
      arn: '{{ item.arn }}'
- discovery_id: aws.frauddetector.getModels
  calls:
  - action: getModels
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.models }}'
    item:
      modelId: '{{ item.modelId }}'
      modelType: '{{ item.modelType }}'
      description: '{{ item.description }}'
      eventTypeName: '{{ item.eventTypeName }}'
      createdTime: '{{ item.createdTime }}'
      lastUpdatedTime: '{{ item.lastUpdatedTime }}'
      arn: '{{ item.arn }}'
- discovery_id: aws.frauddetector.getOutcomes
  calls:
  - action: getOutcomes
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.outcomes }}'
    item:
      name: '{{ item.name }}'
      description: '{{ item.description }}'
      lastUpdatedTime: '{{ item.lastUpdatedTime }}'
      createdTime: '{{ item.createdTime }}'
      arn: '{{ item.arn }}'
- discovery_id: aws.frauddetector.getVariables
  calls:
  - action: getVariables
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.variables }}'
    item:
      name: '{{ item.name }}'
      dataType: '{{ item.dataType }}'
      dataSource: '{{ item.dataSource }}'
      defaultValue: '{{ item.defaultValue }}'
      description: '{{ item.description }}'
      variableType: '{{ item.variableType }}'
      lastUpdatedTime: '{{ item.lastUpdatedTime }}'
      createdTime: '{{ item.createdTime }}'
      arn: '{{ item.arn }}'
- discovery_id: aws.frauddetector.listEventPredictions
  calls:
  - action: listEventPredictions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.eventPredictionSummaries }}'
    item:
      eventId: '{{ item.eventId }}'
      eventTypeName: '{{ item.eventTypeName }}'
      eventTimestamp: '{{ item.eventTimestamp }}'
      predictionTimestamp: '{{ item.predictionTimestamp }}'
      detectorId: '{{ item.detectorId }}'
      detectorVersionId: '{{ item.detectorVersionId }}'
- discovery_id: aws.frauddetector.describeDetector
  calls:
  - action: describeDetector
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.detectorVersionSummaries }}'
    item:
      detectorVersionId: '{{ item.detectorVersionId }}'
      status: '{{ item.status }}'
      description: '{{ item.description }}'
      lastUpdatedTime: '{{ item.lastUpdatedTime }}'
- discovery_id: aws.frauddetector.getDeleteEventsByEventTypeStatus
  calls:
  - action: getDeleteEventsByEventTypeStatus
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.eventTypeName }}'
- discovery_id: aws.frauddetector.getDetectorVersion
  calls:
  - action: getDetectorVersion
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.externalModelEndpoints }}'
- discovery_id: aws.frauddetector.getEvent
  calls:
  - action: getEvent
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.event }}'
    item:
      eventId: '{{ item.eventId }}'
      eventTypeName: '{{ item.eventTypeName }}'
      eventTimestamp: '{{ item.eventTimestamp }}'
      eventVariables: '{{ item.eventVariables }}'
      currentLabel: '{{ item.currentLabel }}'
      labelTimestamp: '{{ item.labelTimestamp }}'
      entities: '{{ item.entities }}'
- discovery_id: aws.frauddetector.getEventPrediction
  calls:
  - action: getEventPrediction
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ruleResults }}'
    item:
      ruleId: '{{ item.ruleId }}'
      outcomes: '{{ item.outcomes }}'
- discovery_id: aws.frauddetector.getEventPredictionMetadata
  calls:
  - action: getEventPredictionMetadata
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.eventVariables }}'
    item:
      name: '{{ item.name }}'
      value: '{{ item.value }}'
      source: '{{ item.source }}'
- discovery_id: aws.frauddetector.getListElements
  calls:
  - action: getListElements
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.elements }}'
- discovery_id: aws.frauddetector.getModelVersion
  calls:
  - action: getModelVersion
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.trainingDataSchema }}'
    item:
      modelVariables: '{{ item.modelVariables }}'
      labelSchema: '{{ item.labelSchema }}'
- discovery_id: aws.frauddetector.getRules
  calls:
  - action: getRules
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ruleDetails }}'
    item:
      ruleId: '{{ item.ruleId }}'
      description: '{{ item.description }}'
      detectorId: '{{ item.detectorId }}'
      ruleVersion: '{{ item.ruleVersion }}'
      expression: '{{ item.expression }}'
      language: '{{ item.language }}'
      outcomes: '{{ item.outcomes }}'
      lastUpdatedTime: '{{ item.lastUpdatedTime }}'
      createdTime: '{{ item.createdTime }}'
      arn: '{{ item.arn }}'
- discovery_id: aws.frauddetector.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tags }}'
    item:
      key: '{{ item.key }}'
      value: '{{ item.value }}'
checks: []
