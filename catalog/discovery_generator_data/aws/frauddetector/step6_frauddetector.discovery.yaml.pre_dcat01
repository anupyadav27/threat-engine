# Auto-generated: minimum discoveries for check rules + inventory + engine requirements
# Sources: frauddetector
# 15 ops total
version: '1.0'
provider: aws
service: frauddetector
discovery:
  - calls:
    - action: describe_model_versions
      on_error: continue
      save_as: response
    discovery_id: aws.frauddetector.describe_model_versions
    emit:
      as: item
      item:
        arn: '{{ item.arn }}'
        createdTime: '{{ item.createdTime }}'
        externalEventsDetail: '{{ item.externalEventsDetail }}'
        ingestedEventsDetail: '{{ item.ingestedEventsDetail }}'
        lastUpdatedTime: '{{ item.lastUpdatedTime }}'
        modelId: '{{ item.modelId }}'
        modelType: '{{ item.modelType }}'
        modelVersionDetails: '{{ item.modelVersionDetails }}'
        modelVersionNumber: '{{ item.modelVersionNumber }}'
        status: '{{ item.status }}'
        trainingDataSchema: '{{ item.trainingDataSchema }}'
        trainingDataSource: '{{ item.trainingDataSource }}'
        trainingResult: '{{ item.trainingResult }}'
        trainingResultV2: '{{ item.trainingResultV2 }}'
      items_for: '{{ response.modelVersionDetails }}'
  - calls:
    - action: get_batch_import_jobs
      on_error: continue
      save_as: response
    discovery_id: aws.frauddetector.get_batch_import_jobs
    emit:
      as: item
      item:
        arn: '{{ item.arn }}'
        batchImports: '{{ item.batchImports }}'
        completionTime: '{{ item.completionTime }}'
        eventTypeName: '{{ item.eventTypeName }}'
        failedRecordsCount: '{{ item.failedRecordsCount }}'
        failureReason: '{{ item.failureReason }}'
        iamRoleArn: '{{ item.iamRoleArn }}'
        inputPath: '{{ item.inputPath }}'
        jobId: '{{ item.jobId }}'
        outputPath: '{{ item.outputPath }}'
        processedRecordsCount: '{{ item.processedRecordsCount }}'
        startTime: '{{ item.startTime }}'
        status: '{{ item.status }}'
        totalRecordsCount: '{{ item.totalRecordsCount }}'
      items_for: '{{ response.batchImports }}'
  - calls:
    - action: get_batch_prediction_jobs
      on_error: continue
      save_as: response
    discovery_id: aws.frauddetector.get_batch_prediction_jobs
    emit:
      as: item
      item:
        arn: '{{ item.arn }}'
        batchPredictions: '{{ item.batchPredictions }}'
        completionTime: '{{ item.completionTime }}'
        detectorName: '{{ item.detectorName }}'
        detectorVersion: '{{ item.detectorVersion }}'
        eventTypeName: '{{ item.eventTypeName }}'
        failureReason: '{{ item.failureReason }}'
        iamRoleArn: '{{ item.iamRoleArn }}'
        inputPath: '{{ item.inputPath }}'
        jobId: '{{ item.jobId }}'
        lastHeartbeatTime: '{{ item.lastHeartbeatTime }}'
        outputPath: '{{ item.outputPath }}'
        processedRecordsCount: '{{ item.processedRecordsCount }}'
        startTime: '{{ item.startTime }}'
        status: '{{ item.status }}'
        totalRecordsCount: '{{ item.totalRecordsCount }}'
      items_for: '{{ response.batchPredictions }}'
  - calls:
    - action: get_detectors
      on_error: continue
      save_as: response
    discovery_id: aws.frauddetector.get_detectors
    emit:
      as: item
      item:
        arn: '{{ item.arn }}'
        createdTime: '{{ item.createdTime }}'
        description: '{{ item.description }}'
        detectorId: '{{ item.detectorId }}'
        detectors: '{{ item.detectors }}'
        eventTypeName: '{{ item.eventTypeName }}'
        lastUpdatedTime: '{{ item.lastUpdatedTime }}'
      items_for: '{{ response.detectors }}'
  - calls:
    - action: get_entity_types
      on_error: continue
