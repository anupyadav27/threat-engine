        lists: '{{ item.lists }}'
        name: '{{ item.name }}'
        updatedTime: '{{ item.updatedTime }}'
        variableType: '{{ item.variableType }}'
      items_for: '{{ response.lists }}'
  - calls:
    - action: get_models
      on_error: continue
      save_as: response
    discovery_id: aws.frauddetector.get_models
    emit:
