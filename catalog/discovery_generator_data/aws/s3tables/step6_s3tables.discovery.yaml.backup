version: '1.0'
provider: aws
service: s3tables
services:
  client: s3tables
  module: boto3.client
discovery:
- discovery_id: aws.s3tables.getTable
  calls:
  - action: getTable
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.namespace }}'
- discovery_id: aws.s3tables.listTableBuckets
  calls:
  - action: listTableBuckets
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tableBuckets }}'
    item:
      arn: '{{ item.arn }}'
      name: '{{ item.name }}'
      ownerAccountId: '{{ item.ownerAccountId }}'
      createdAt: '{{ item.createdAt }}'
      tableBucketId: '{{ item.tableBucketId }}'
      type: '{{ item.type }}'
- discovery_id: aws.s3tables.getNamespace
  calls:
  - action: getNamespace
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.namespace }}'
- discovery_id: aws.s3tables.getTableBucket
  calls:
  - action: getTableBucket
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.arn }}'
- discovery_id: aws.s3tables.getTableBucketEncryption
  calls:
  - action: getTableBucketEncryption
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.encryptionConfiguration }}'
    item:
      sseAlgorithm: '{{ item.sseAlgorithm }}'
      kmsKeyArn: '{{ item.kmsKeyArn }}'
- discovery_id: aws.s3tables.getTableBucketMaintenanceConfiguration
  calls:
  - action: getTableBucketMaintenanceConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tableBucketARN }}'
- discovery_id: aws.s3tables.getTableBucketMetricsConfiguration
  calls:
  - action: getTableBucketMetricsConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tableBucketARN }}'
- discovery_id: aws.s3tables.getTableBucketPolicy
  calls:
  - action: getTableBucketPolicy
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.resourcePolicy }}'
- discovery_id: aws.s3tables.getTableEncryption
  calls:
  - action: getTableEncryption
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.encryptionConfiguration }}'
    item:
      sseAlgorithm: '{{ item.sseAlgorithm }}'
      kmsKeyArn: '{{ item.kmsKeyArn }}'
- discovery_id: aws.s3tables.getTableMaintenanceConfiguration
  calls:
  - action: getTableMaintenanceConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tableARN }}'
- discovery_id: aws.s3tables.getTableMaintenanceJobStatus
  calls:
  - action: getTableMaintenanceJobStatus
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tableARN }}'
- discovery_id: aws.s3tables.getTableMetadataLocation
  calls:
  - action: getTableMetadataLocation
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.versionToken }}'
- discovery_id: aws.s3tables.getTablePolicy
  calls:
  - action: getTablePolicy
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.resourcePolicy }}'
- discovery_id: aws.s3tables.listNamespaces
  calls:
  - action: listNamespaces
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.namespaces }}'
    item:
      namespace: '{{ item.namespace }}'
      createdAt: '{{ item.createdAt }}'
      createdBy: '{{ item.createdBy }}'
      ownerAccountId: '{{ item.ownerAccountId }}'
      namespaceId: '{{ item.namespaceId }}'
      tableBucketId: '{{ item.tableBucketId }}'
- discovery_id: aws.s3tables.listTables
  calls:
  - action: listTables
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tables }}'
    item:
      namespace: '{{ item.namespace }}'
      name: '{{ item.name }}'
      type: '{{ item.type }}'
      tableARN: '{{ item.tableARN }}'
      createdAt: '{{ item.createdAt }}'
      modifiedAt: '{{ item.modifiedAt }}'
      namespaceId: '{{ item.namespaceId }}'
      tableBucketId: '{{ item.tableBucketId }}'
- discovery_id: aws.s3tables.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tags }}'
checks: []
