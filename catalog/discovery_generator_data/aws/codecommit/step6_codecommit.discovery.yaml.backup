version: '1.0'
provider: aws
service: codecommit
services:
  client: codecommit
  module: boto3.client
discovery:
- discovery_id: aws.codecommit.getBranch
  calls:
  - action: getBranch
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.branch }}'
    item:
      branchName: '{{ item.branchName }}'
      commitId: '{{ item.commitId }}'
- discovery_id: aws.codecommit.listApprovalRuleTemplates
  calls:
  - action: listApprovalRuleTemplates
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.approvalRuleTemplateNames }}'
- discovery_id: aws.codecommit.listRepositories
  calls:
  - action: listRepositories
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.repositories }}'
    item:
      repositoryName: '{{ item.repositoryName }}'
      repositoryId: '{{ item.repositoryId }}'
- discovery_id: aws.codecommit.describeMergeConflicts
  calls:
  - action: describeMergeConflicts
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.mergeHunks }}'
    item:
      isConflict: '{{ item.isConflict }}'
      source: '{{ item.source }}'
      destination: '{{ item.destination }}'
      base: '{{ item.base }}'
- discovery_id: aws.codecommit.describePullRequestEvents
  calls:
  - action: describePullRequestEvents
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.pullRequestEvents }}'
    item:
      pullRequestId: '{{ item.pullRequestId }}'
      eventDate: '{{ item.eventDate }}'
      pullRequestEventType: '{{ item.pullRequestEventType }}'
      actorArn: '{{ item.actorArn }}'
      pullRequestCreatedEventMetadata: '{{ item.pullRequestCreatedEventMetadata }}'
      pullRequestStatusChangedEventMetadata: '{{ item.pullRequestStatusChangedEventMetadata
        }}'
      pullRequestSourceReferenceUpdatedEventMetadata: '{{ item.pullRequestSourceReferenceUpdatedEventMetadata
        }}'
      pullRequestMergedStateChangedEventMetadata: '{{ item.pullRequestMergedStateChangedEventMetadata
        }}'
      approvalRuleEventMetadata: '{{ item.approvalRuleEventMetadata }}'
      approvalStateChangedEventMetadata: '{{ item.approvalStateChangedEventMetadata
        }}'
      approvalRuleOverriddenEventMetadata: '{{ item.approvalRuleOverriddenEventMetadata
        }}'
- discovery_id: aws.codecommit.getApprovalRuleTemplate
  calls:
  - action: getApprovalRuleTemplate
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.approvalRuleTemplate }}'
    item:
      approvalRuleTemplateId: '{{ item.approvalRuleTemplateId }}'
      approvalRuleTemplateName: '{{ item.approvalRuleTemplateName }}'
      approvalRuleTemplateDescription: '{{ item.approvalRuleTemplateDescription }}'
      approvalRuleTemplateContent: '{{ item.approvalRuleTemplateContent }}'
      ruleContentSha256: '{{ item.ruleContentSha256 }}'
      lastModifiedDate: '{{ item.lastModifiedDate }}'
      creationDate: '{{ item.creationDate }}'
      lastModifiedUser: '{{ item.lastModifiedUser }}'
- discovery_id: aws.codecommit.getBlob
  calls:
  - action: getBlob
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.content }}'
- discovery_id: aws.codecommit.getComment
  calls:
  - action: getComment
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.comment }}'
    item:
      commentId: '{{ item.commentId }}'
      content: '{{ item.content }}'
      inReplyTo: '{{ item.inReplyTo }}'
      creationDate: '{{ item.creationDate }}'
      lastModifiedDate: '{{ item.lastModifiedDate }}'
      authorArn: '{{ item.authorArn }}'
      deleted: '{{ item.deleted }}'
      clientRequestToken: '{{ item.clientRequestToken }}'
      callerReactions: '{{ item.callerReactions }}'
      reactionCounts: '{{ item.reactionCounts }}'
- discovery_id: aws.codecommit.getCommentReactions
  calls:
  - action: getCommentReactions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.reactionsForComment }}'
    item:
      reaction: '{{ item.reaction }}'
      reactionUsers: '{{ item.reactionUsers }}'
      reactionsFromDeletedUsersCount: '{{ item.reactionsFromDeletedUsersCount }}'
- discovery_id: aws.codecommit.getCommentsForComparedCommit
  calls:
  - action: getCommentsForComparedCommit
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.commentsForComparedCommitData }}'
    item:
      repositoryName: '{{ item.repositoryName }}'
      beforeCommitId: '{{ item.beforeCommitId }}'
      afterCommitId: '{{ item.afterCommitId }}'
      beforeBlobId: '{{ item.beforeBlobId }}'
      afterBlobId: '{{ item.afterBlobId }}'
      location: '{{ item.location }}'
      comments: '{{ item.comments }}'
- discovery_id: aws.codecommit.getCommentsForPullRequest
  calls:
  - action: getCommentsForPullRequest
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.commentsForPullRequestData }}'
    item:
      pullRequestId: '{{ item.pullRequestId }}'
      repositoryName: '{{ item.repositoryName }}'
      beforeCommitId: '{{ item.beforeCommitId }}'
      afterCommitId: '{{ item.afterCommitId }}'
      beforeBlobId: '{{ item.beforeBlobId }}'
      afterBlobId: '{{ item.afterBlobId }}'
      location: '{{ item.location }}'
      comments: '{{ item.comments }}'
- discovery_id: aws.codecommit.getCommit
  calls:
  - action: getCommit
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.commit }}'
    item:
      commitId: '{{ item.commitId }}'
      treeId: '{{ item.treeId }}'
      parents: '{{ item.parents }}'
      message: '{{ item.message }}'
      author: '{{ item.author }}'
      committer: '{{ item.committer }}'
      additionalData: '{{ item.additionalData }}'
- discovery_id: aws.codecommit.getDifferences
  calls:
  - action: getDifferences
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.differences }}'
    item:
      beforeBlob: '{{ item.beforeBlob }}'
      afterBlob: '{{ item.afterBlob }}'
      changeType: '{{ item.changeType }}'
- discovery_id: aws.codecommit.getFile
  calls:
  - action: getFile
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.commitId }}'
- discovery_id: aws.codecommit.getFolder
  calls:
  - action: getFolder
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.subFolders }}'
    item:
      treeId: '{{ item.treeId }}'
      absolutePath: '{{ item.absolutePath }}'
      relativePath: '{{ item.relativePath }}'
- discovery_id: aws.codecommit.getMergeCommit
  calls:
  - action: getMergeCommit
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.sourceCommitId }}'
- discovery_id: aws.codecommit.getMergeConflicts
  calls:
  - action: getMergeConflicts
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.conflictMetadataList }}'
    item:
      filePath: '{{ item.filePath }}'
      fileSizes: '{{ item.fileSizes }}'
      fileModes: '{{ item.fileModes }}'
      objectTypes: '{{ item.objectTypes }}'
      numberOfConflicts: '{{ item.numberOfConflicts }}'
      isBinaryFile: '{{ item.isBinaryFile }}'
      contentConflict: '{{ item.contentConflict }}'
      fileModeConflict: '{{ item.fileModeConflict }}'
      objectTypeConflict: '{{ item.objectTypeConflict }}'
      mergeOperations: '{{ item.mergeOperations }}'
- discovery_id: aws.codecommit.getMergeOptions
  calls:
  - action: getMergeOptions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.mergeOptions }}'
- discovery_id: aws.codecommit.getPullRequest
  calls:
  - action: getPullRequest
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.pullRequest }}'
    item:
      pullRequestId: '{{ item.pullRequestId }}'
      title: '{{ item.title }}'
      description: '{{ item.description }}'
      lastActivityDate: '{{ item.lastActivityDate }}'
      creationDate: '{{ item.creationDate }}'
      pullRequestStatus: '{{ item.pullRequestStatus }}'
      authorArn: '{{ item.authorArn }}'
      pullRequestTargets: '{{ item.pullRequestTargets }}'
      clientRequestToken: '{{ item.clientRequestToken }}'
      revisionId: '{{ item.revisionId }}'
      approvalRules: '{{ item.approvalRules }}'
- discovery_id: aws.codecommit.getPullRequestApprovalStates
  calls:
  - action: getPullRequestApprovalStates
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.approvals }}'
    item:
      userArn: '{{ item.userArn }}'
      approvalState: '{{ item.approvalState }}'
- discovery_id: aws.codecommit.getPullRequestOverrideState
  calls:
  - action: getPullRequestOverrideState
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.overridden }}'
- discovery_id: aws.codecommit.getRepository
  calls:
  - action: getRepository
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.repositoryMetadata }}'
    item:
      accountId: '{{ item.accountId }}'
      repositoryId: '{{ item.repositoryId }}'
      repositoryName: '{{ item.repositoryName }}'
      repositoryDescription: '{{ item.repositoryDescription }}'
      defaultBranch: '{{ item.defaultBranch }}'
      lastModifiedDate: '{{ item.lastModifiedDate }}'
      creationDate: '{{ item.creationDate }}'
      cloneUrlHttp: '{{ item.cloneUrlHttp }}'
      cloneUrlSsh: '{{ item.cloneUrlSsh }}'
      Arn: '{{ item.Arn }}'
      kmsKeyId: '{{ item.kmsKeyId }}'
- discovery_id: aws.codecommit.getRepositoryTriggers
  calls:
  - action: getRepositoryTriggers
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.triggers }}'
    item:
      name: '{{ item.name }}'
      destinationArn: '{{ item.destinationArn }}'
      customData: '{{ item.customData }}'
      branches: '{{ item.branches }}'
      events: '{{ item.events }}'
- discovery_id: aws.codecommit.listAssociatedApprovalRuleTemplatesForRepository
  calls:
  - action: listAssociatedApprovalRuleTemplatesForRepository
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.approvalRuleTemplateNames }}'
- discovery_id: aws.codecommit.listBranches
  calls:
  - action: listBranches
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.branches }}'
- discovery_id: aws.codecommit.listFileCommitHistory
  calls:
  - action: listFileCommitHistory
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.revisionDag }}'
    item:
      commit: '{{ item.commit }}'
      blobId: '{{ item.blobId }}'
      path: '{{ item.path }}'
      revisionChildren: '{{ item.revisionChildren }}'
- discovery_id: aws.codecommit.listPullRequests
  calls:
  - action: listPullRequests
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.pullRequestIds }}'
- discovery_id: aws.codecommit.listRepositoriesForApprovalRuleTemplate
  calls:
  - action: listRepositoriesForApprovalRuleTemplate
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.repositoryNames }}'
- discovery_id: aws.codecommit.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tags }}'
checks: []
