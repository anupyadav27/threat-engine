version: '1.0'
provider: aws
service: ecs
services:
  client: ecs
  module: boto3.client
discovery:
- discovery_id: aws.ecs.describeCapacityProviders
  calls:
  - action: describeCapacityProviders
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.capacityProviders }}'
    item:
      capacityProviderArn: '{{ item.capacityProviderArn }}'
      name: '{{ item.name }}'
      cluster: '{{ item.cluster }}'
      status: '{{ item.status }}'
      autoScalingGroupProvider: '{{ item.autoScalingGroupProvider }}'
      managedInstancesProvider: '{{ item.managedInstancesProvider }}'
      updateStatus: '{{ item.updateStatus }}'
      updateStatusReason: '{{ item.updateStatusReason }}'
      tags: '{{ item.tags }}'
      type: '{{ item.type }}'
- discovery_id: aws.ecs.describeClusters
  calls:
  - action: describeClusters
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.clusters }}'
    item:
      clusterArn: '{{ item.clusterArn }}'
      clusterName: '{{ item.clusterName }}'
      configuration: '{{ item.configuration }}'
      status: '{{ item.status }}'
      registeredContainerInstancesCount: '{{ item.registeredContainerInstancesCount
        }}'
      runningTasksCount: '{{ item.runningTasksCount }}'
      pendingTasksCount: '{{ item.pendingTasksCount }}'
      activeServicesCount: '{{ item.activeServicesCount }}'
      statistics: '{{ item.statistics }}'
      tags: '{{ item.tags }}'
      settings: '{{ item.settings }}'
      capacityProviders: '{{ item.capacityProviders }}'
      defaultCapacityProviderStrategy: '{{ item.defaultCapacityProviderStrategy }}'
      attachments: '{{ item.attachments }}'
      attachmentsStatus: '{{ item.attachmentsStatus }}'
      serviceConnectDefaults: '{{ item.serviceConnectDefaults }}'
- discovery_id: aws.ecs.listAccountSettings
  calls:
  - action: listAccountSettings
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.settings }}'
    item:
      name: '{{ item.name }}'
      value: '{{ item.value }}'
      principalArn: '{{ item.principalArn }}'
      type: '{{ item.type }}'
- discovery_id: aws.ecs.listClusters
  calls:
  - action: listClusters
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.clusterArns }}'
- discovery_id: aws.ecs.listContainerInstances
  calls:
  - action: listContainerInstances
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.containerInstanceArns }}'
- discovery_id: aws.ecs.listServices
  calls:
  - action: listServices
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.serviceArns }}'
- discovery_id: aws.ecs.listTaskDefinitionFamilies
  calls:
  - action: listTaskDefinitionFamilies
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.families }}'
- discovery_id: aws.ecs.listTaskDefinitions
  calls:
  - action: listTaskDefinitions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.taskDefinitionArns }}'
- discovery_id: aws.ecs.listTasks
  calls:
  - action: listTasks
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.taskArns }}'
- discovery_id: aws.ecs.describeContainerInstances
  calls:
  - action: describeContainerInstances
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.containerInstances }}'
    item:
      containerInstanceArn: '{{ item.containerInstanceArn }}'
      ec2InstanceId: '{{ item.ec2InstanceId }}'
      capacityProviderName: '{{ item.capacityProviderName }}'
      version: '{{ item.version }}'
      versionInfo: '{{ item.versionInfo }}'
      remainingResources: '{{ item.remainingResources }}'
      registeredResources: '{{ item.registeredResources }}'
      status: '{{ item.status }}'
      statusReason: '{{ item.statusReason }}'
      agentConnected: '{{ item.agentConnected }}'
      runningTasksCount: '{{ item.runningTasksCount }}'
      pendingTasksCount: '{{ item.pendingTasksCount }}'
      agentUpdateStatus: '{{ item.agentUpdateStatus }}'
      attributes: '{{ item.attributes }}'
      registeredAt: '{{ item.registeredAt }}'
      attachments: '{{ item.attachments }}'
      tags: '{{ item.tags }}'
      healthStatus: '{{ item.healthStatus }}'
- discovery_id: aws.ecs.describeExpressGatewayService
  calls:
  - action: describeExpressGatewayService
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.service }}'
    item:
      cluster: '{{ item.cluster }}'
      serviceName: '{{ item.serviceName }}'
      serviceArn: '{{ item.serviceArn }}'
      infrastructureRoleArn: '{{ item.infrastructureRoleArn }}'
      status: '{{ item.status }}'
      currentDeployment: '{{ item.currentDeployment }}'
      activeConfigurations: '{{ item.activeConfigurations }}'
      tags: '{{ item.tags }}'
      createdAt: '{{ item.createdAt }}'
      updatedAt: '{{ item.updatedAt }}'
- discovery_id: aws.ecs.describeServiceDeployments
  calls:
  - action: describeServiceDeployments
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.serviceDeployments }}'
    item:
      serviceDeploymentArn: '{{ item.serviceDeploymentArn }}'
      serviceArn: '{{ item.serviceArn }}'
      clusterArn: '{{ item.clusterArn }}'
      createdAt: '{{ item.createdAt }}'
      startedAt: '{{ item.startedAt }}'
      finishedAt: '{{ item.finishedAt }}'
      stoppedAt: '{{ item.stoppedAt }}'
      updatedAt: '{{ item.updatedAt }}'
      sourceServiceRevisions: '{{ item.sourceServiceRevisions }}'
      targetServiceRevision: '{{ item.targetServiceRevision }}'
      status: '{{ item.status }}'
      statusReason: '{{ item.statusReason }}'
      lifecycleStage: '{{ item.lifecycleStage }}'
      deploymentConfiguration: '{{ item.deploymentConfiguration }}'
      rollback: '{{ item.rollback }}'
      deploymentCircuitBreaker: '{{ item.deploymentCircuitBreaker }}'
      alarms: '{{ item.alarms }}'
- discovery_id: aws.ecs.describeServiceRevisions
  calls:
  - action: describeServiceRevisions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.serviceRevisions }}'
    item:
      serviceRevisionArn: '{{ item.serviceRevisionArn }}'
      serviceArn: '{{ item.serviceArn }}'
      clusterArn: '{{ item.clusterArn }}'
      taskDefinition: '{{ item.taskDefinition }}'
      capacityProviderStrategy: '{{ item.capacityProviderStrategy }}'
      launchType: '{{ item.launchType }}'
      platformVersion: '{{ item.platformVersion }}'
      platformFamily: '{{ item.platformFamily }}'
      loadBalancers: '{{ item.loadBalancers }}'
      serviceRegistries: '{{ item.serviceRegistries }}'
      networkConfiguration: '{{ item.networkConfiguration }}'
      containerImages: '{{ item.containerImages }}'
      guardDutyEnabled: '{{ item.guardDutyEnabled }}'
      serviceConnectConfiguration: '{{ item.serviceConnectConfiguration }}'
      volumeConfigurations: '{{ item.volumeConfigurations }}'
      fargateEphemeralStorage: '{{ item.fargateEphemeralStorage }}'
      createdAt: '{{ item.createdAt }}'
      vpcLatticeConfigurations: '{{ item.vpcLatticeConfigurations }}'
      resolvedConfiguration: '{{ item.resolvedConfiguration }}'
      ecsManagedResources: '{{ item.ecsManagedResources }}'
- discovery_id: aws.ecs.describeServices
  calls:
  - action: describeServices
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.services }}'
    item:
      serviceArn: '{{ item.serviceArn }}'
      serviceName: '{{ item.serviceName }}'
      clusterArn: '{{ item.clusterArn }}'
      loadBalancers: '{{ item.loadBalancers }}'
      serviceRegistries: '{{ item.serviceRegistries }}'
      status: '{{ item.status }}'
      desiredCount: '{{ item.desiredCount }}'
      runningCount: '{{ item.runningCount }}'
      pendingCount: '{{ item.pendingCount }}'
      launchType: '{{ item.launchType }}'
      capacityProviderStrategy: '{{ item.capacityProviderStrategy }}'
      platformVersion: '{{ item.platformVersion }}'
      platformFamily: '{{ item.platformFamily }}'
      taskDefinition: '{{ item.taskDefinition }}'
      deploymentConfiguration: '{{ item.deploymentConfiguration }}'
      taskSets: '{{ item.taskSets }}'
      deployments: '{{ item.deployments }}'
      roleArn: '{{ item.roleArn }}'
      events: '{{ item.events }}'
      createdAt: '{{ item.createdAt }}'
      currentServiceDeployment: '{{ item.currentServiceDeployment }}'
      currentServiceRevisions: '{{ item.currentServiceRevisions }}'
      placementConstraints: '{{ item.placementConstraints }}'
      placementStrategy: '{{ item.placementStrategy }}'
      networkConfiguration: '{{ item.networkConfiguration }}'
      healthCheckGracePeriodSeconds: '{{ item.healthCheckGracePeriodSeconds }}'
      schedulingStrategy: '{{ item.schedulingStrategy }}'
      deploymentController: '{{ item.deploymentController }}'
      tags: '{{ item.tags }}'
      createdBy: '{{ item.createdBy }}'
      enableECSManagedTags: '{{ item.enableECSManagedTags }}'
      propagateTags: '{{ item.propagateTags }}'
      enableExecuteCommand: '{{ item.enableExecuteCommand }}'
      availabilityZoneRebalancing: '{{ item.availabilityZoneRebalancing }}'
      resourceManagementType: '{{ item.resourceManagementType }}'
- discovery_id: aws.ecs.describeTaskDefinition
  calls:
  - action: describeTaskDefinition
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tags }}'
    item:
      key: '{{ item.key }}'
      value: '{{ item.value }}'
- discovery_id: aws.ecs.describeTaskSets
  calls:
  - action: describeTaskSets
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.taskSets }}'
    item:
      id: '{{ item.id }}'
      taskSetArn: '{{ item.taskSetArn }}'
      serviceArn: '{{ item.serviceArn }}'
      clusterArn: '{{ item.clusterArn }}'
      startedBy: '{{ item.startedBy }}'
      externalId: '{{ item.externalId }}'
      status: '{{ item.status }}'
      taskDefinition: '{{ item.taskDefinition }}'
      computedDesiredCount: '{{ item.computedDesiredCount }}'
      pendingCount: '{{ item.pendingCount }}'
      runningCount: '{{ item.runningCount }}'
      createdAt: '{{ item.createdAt }}'
      updatedAt: '{{ item.updatedAt }}'
      launchType: '{{ item.launchType }}'
      capacityProviderStrategy: '{{ item.capacityProviderStrategy }}'
      platformVersion: '{{ item.platformVersion }}'
      platformFamily: '{{ item.platformFamily }}'
      networkConfiguration: '{{ item.networkConfiguration }}'
      loadBalancers: '{{ item.loadBalancers }}'
      serviceRegistries: '{{ item.serviceRegistries }}'
      scale: '{{ item.scale }}'
      stabilityStatus: '{{ item.stabilityStatus }}'
      stabilityStatusAt: '{{ item.stabilityStatusAt }}'
      tags: '{{ item.tags }}'
      fargateEphemeralStorage: '{{ item.fargateEphemeralStorage }}'
- discovery_id: aws.ecs.describeTasks
  calls:
  - action: describeTasks
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tasks }}'
    item:
      attachments: '{{ item.attachments }}'
      attributes: '{{ item.attributes }}'
      availabilityZone: '{{ item.availabilityZone }}'
      capacityProviderName: '{{ item.capacityProviderName }}'
      clusterArn: '{{ item.clusterArn }}'
      connectivity: '{{ item.connectivity }}'
      connectivityAt: '{{ item.connectivityAt }}'
      containerInstanceArn: '{{ item.containerInstanceArn }}'
      containers: '{{ item.containers }}'
      cpu: '{{ item.cpu }}'
      createdAt: '{{ item.createdAt }}'
      desiredStatus: '{{ item.desiredStatus }}'
      enableExecuteCommand: '{{ item.enableExecuteCommand }}'
      executionStoppedAt: '{{ item.executionStoppedAt }}'
      group: '{{ item.group }}'
      healthStatus: '{{ item.healthStatus }}'
      inferenceAccelerators: '{{ item.inferenceAccelerators }}'
      lastStatus: '{{ item.lastStatus }}'
      launchType: '{{ item.launchType }}'
      memory: '{{ item.memory }}'
      overrides: '{{ item.overrides }}'
      platformVersion: '{{ item.platformVersion }}'
      platformFamily: '{{ item.platformFamily }}'
      pullStartedAt: '{{ item.pullStartedAt }}'
      pullStoppedAt: '{{ item.pullStoppedAt }}'
      startedAt: '{{ item.startedAt }}'
      startedBy: '{{ item.startedBy }}'
      stopCode: '{{ item.stopCode }}'
      stoppedAt: '{{ item.stoppedAt }}'
      stoppedReason: '{{ item.stoppedReason }}'
      stoppingAt: '{{ item.stoppingAt }}'
      tags: '{{ item.tags }}'
      taskArn: '{{ item.taskArn }}'
      taskDefinitionArn: '{{ item.taskDefinitionArn }}'
      version: '{{ item.version }}'
      ephemeralStorage: '{{ item.ephemeralStorage }}'
      fargateEphemeralStorage: '{{ item.fargateEphemeralStorage }}'
- discovery_id: aws.ecs.getTaskProtection
  calls:
  - action: getTaskProtection
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.protectedTasks }}'
    item:
      taskArn: '{{ item.taskArn }}'
      protectionEnabled: '{{ item.protectionEnabled }}'
      expirationDate: '{{ item.expirationDate }}'
- discovery_id: aws.ecs.listAttributes
  calls:
  - action: listAttributes
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.attributes }}'
    item:
      name: '{{ item.name }}'
      value: '{{ item.value }}'
      targetType: '{{ item.targetType }}'
      targetId: '{{ item.targetId }}'
- discovery_id: aws.ecs.listServiceDeployments
  calls:
  - action: listServiceDeployments
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.serviceDeployments }}'
    item:
      serviceDeploymentArn: '{{ item.serviceDeploymentArn }}'
      serviceArn: '{{ item.serviceArn }}'
      clusterArn: '{{ item.clusterArn }}'
      startedAt: '{{ item.startedAt }}'
      createdAt: '{{ item.createdAt }}'
      finishedAt: '{{ item.finishedAt }}'
      targetServiceRevisionArn: '{{ item.targetServiceRevisionArn }}'
      status: '{{ item.status }}'
      statusReason: '{{ item.statusReason }}'
- discovery_id: aws.ecs.listServicesByNamespace
  calls:
  - action: listServicesByNamespace
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.serviceArns }}'
- discovery_id: aws.ecs.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tags }}'
    item:
      key: '{{ item.key }}'
      value: '{{ item.value }}'
checks: []
