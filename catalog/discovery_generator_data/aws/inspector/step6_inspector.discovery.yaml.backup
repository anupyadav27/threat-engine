version: '1.0'
provider: aws
service: inspector
services:
  client: inspector
  module: boto3.client
discovery:
- discovery_id: aws.inspector.describeCrossAccountAccessRole
  calls:
  - action: describeCrossAccountAccessRole
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.roleArn }}'
- discovery_id: aws.inspector.listAssessmentRuns
  calls:
  - action: listAssessmentRuns
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.assessmentRunArns }}'
- discovery_id: aws.inspector.listAssessmentTargets
  calls:
  - action: listAssessmentTargets
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.assessmentTargetArns }}'
- discovery_id: aws.inspector.listAssessmentTemplates
  calls:
  - action: listAssessmentTemplates
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.assessmentTemplateArns }}'
- discovery_id: aws.inspector.listEventSubscriptions
  calls:
  - action: listEventSubscriptions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.subscriptions }}'
    item:
      resourceArn: '{{ item.resourceArn }}'
      topicArn: '{{ item.topicArn }}'
      eventSubscriptions: '{{ item.eventSubscriptions }}'
- discovery_id: aws.inspector.listFindings
  calls:
  - action: listFindings
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.findingArns }}'
- discovery_id: aws.inspector.listRulesPackages
  calls:
  - action: listRulesPackages
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.rulesPackageArns }}'
- discovery_id: aws.inspector.describeAssessmentRuns
  calls:
  - action: describeAssessmentRuns
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.assessmentRuns }}'
    item:
      arn: '{{ item.arn }}'
      name: '{{ item.name }}'
      assessmentTemplateArn: '{{ item.assessmentTemplateArn }}'
      state: '{{ item.state }}'
      durationInSeconds: '{{ item.durationInSeconds }}'
      rulesPackageArns: '{{ item.rulesPackageArns }}'
      userAttributesForFindings: '{{ item.userAttributesForFindings }}'
      createdAt: '{{ item.createdAt }}'
      startedAt: '{{ item.startedAt }}'
      completedAt: '{{ item.completedAt }}'
      stateChangedAt: '{{ item.stateChangedAt }}'
      dataCollected: '{{ item.dataCollected }}'
      stateChanges: '{{ item.stateChanges }}'
      notifications: '{{ item.notifications }}'
      findingCounts: '{{ item.findingCounts }}'
- discovery_id: aws.inspector.describeAssessmentTargets
  calls:
  - action: describeAssessmentTargets
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.assessmentTargets }}'
    item:
      arn: '{{ item.arn }}'
      name: '{{ item.name }}'
      resourceGroupArn: '{{ item.resourceGroupArn }}'
      createdAt: '{{ item.createdAt }}'
      updatedAt: '{{ item.updatedAt }}'
- discovery_id: aws.inspector.describeAssessmentTemplates
  calls:
  - action: describeAssessmentTemplates
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.assessmentTemplates }}'
    item:
      arn: '{{ item.arn }}'
      name: '{{ item.name }}'
      assessmentTargetArn: '{{ item.assessmentTargetArn }}'
      durationInSeconds: '{{ item.durationInSeconds }}'
      rulesPackageArns: '{{ item.rulesPackageArns }}'
      userAttributesForFindings: '{{ item.userAttributesForFindings }}'
      lastAssessmentRunArn: '{{ item.lastAssessmentRunArn }}'
      assessmentRunCount: '{{ item.assessmentRunCount }}'
      createdAt: '{{ item.createdAt }}'
- discovery_id: aws.inspector.describeExclusions
  calls:
  - action: describeExclusions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.exclusions }}'
- discovery_id: aws.inspector.describeFindings
  calls:
  - action: describeFindings
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.findings }}'
    item:
      arn: '{{ item.arn }}'
      schemaVersion: '{{ item.schemaVersion }}'
      service: '{{ item.service }}'
      serviceAttributes: '{{ item.serviceAttributes }}'
      assetType: '{{ item.assetType }}'
      assetAttributes: '{{ item.assetAttributes }}'
      id: '{{ item.id }}'
      title: '{{ item.title }}'
      description: '{{ item.description }}'
      recommendation: '{{ item.recommendation }}'
      severity: '{{ item.severity }}'
      numericSeverity: '{{ item.numericSeverity }}'
      confidence: '{{ item.confidence }}'
      indicatorOfCompromise: '{{ item.indicatorOfCompromise }}'
      attributes: '{{ item.attributes }}'
      userAttributes: '{{ item.userAttributes }}'
      createdAt: '{{ item.createdAt }}'
      updatedAt: '{{ item.updatedAt }}'
- discovery_id: aws.inspector.describeResourceGroups
  calls:
  - action: describeResourceGroups
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.resourceGroups }}'
    item:
      arn: '{{ item.arn }}'
      tags: '{{ item.tags }}'
      createdAt: '{{ item.createdAt }}'
- discovery_id: aws.inspector.describeRulesPackages
  calls:
  - action: describeRulesPackages
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.rulesPackages }}'
    item:
      arn: '{{ item.arn }}'
      name: '{{ item.name }}'
      version: '{{ item.version }}'
      provider: '{{ item.provider }}'
      description: '{{ item.description }}'
- discovery_id: aws.inspector.getAssessmentReport
  calls:
  - action: getAssessmentReport
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.status }}'
- discovery_id: aws.inspector.getExclusionsPreview
  calls:
  - action: getExclusionsPreview
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.exclusionPreviews }}'
    item:
      title: '{{ item.title }}'
      description: '{{ item.description }}'
      recommendation: '{{ item.recommendation }}'
      scopes: '{{ item.scopes }}'
      attributes: '{{ item.attributes }}'
- discovery_id: aws.inspector.getTelemetryMetadata
  calls:
  - action: getTelemetryMetadata
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.telemetryMetadata }}'
    item:
      messageType: '{{ item.messageType }}'
      count: '{{ item.count }}'
      dataSize: '{{ item.dataSize }}'
- discovery_id: aws.inspector.listAssessmentRunAgents
  calls:
  - action: listAssessmentRunAgents
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.assessmentRunAgents }}'
    item:
      agentId: '{{ item.agentId }}'
      assessmentRunArn: '{{ item.assessmentRunArn }}'
      agentHealth: '{{ item.agentHealth }}'
      agentHealthCode: '{{ item.agentHealthCode }}'
      agentHealthDetails: '{{ item.agentHealthDetails }}'
      autoScalingGroup: '{{ item.autoScalingGroup }}'
      telemetryMetadata: '{{ item.telemetryMetadata }}'
- discovery_id: aws.inspector.listExclusions
  calls:
  - action: listExclusions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.exclusionArns }}'
- discovery_id: aws.inspector.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tags }}'
    item:
      key: '{{ item.key }}'
      value: '{{ item.value }}'
checks: []
