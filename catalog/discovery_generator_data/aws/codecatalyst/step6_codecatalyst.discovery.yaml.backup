version: '1.0'
provider: aws
service: codecatalyst
services:
  client: codecatalyst
  module: boto3.client
discovery:
- discovery_id: aws.codecatalyst.getUserDetails
  calls:
  - action: getUserDetails
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.primaryEmail }}'
    item:
      email: '{{ item.email }}'
      verified: '{{ item.verified }}'
- discovery_id: aws.codecatalyst.listAccessTokens
  calls:
  - action: listAccessTokens
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
    item:
      id: '{{ item.id }}'
      name: '{{ item.name }}'
      expiresTime: '{{ item.expiresTime }}'
- discovery_id: aws.codecatalyst.listSpaces
  calls:
  - action: listSpaces
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
    item:
      name: '{{ item.name }}'
      regionName: '{{ item.regionName }}'
      displayName: '{{ item.displayName }}'
      description: '{{ item.description }}'
- discovery_id: aws.codecatalyst.getDevEnvironment
  calls:
  - action: getDevEnvironment
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.repositories }}'
    item:
      repositoryName: '{{ item.repositoryName }}'
      branchName: '{{ item.branchName }}'
- discovery_id: aws.codecatalyst.getProject
  calls:
  - action: getProject
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.spaceName }}'
- discovery_id: aws.codecatalyst.getSourceRepository
  calls:
  - action: getSourceRepository
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.spaceName }}'
- discovery_id: aws.codecatalyst.getSourceRepositoryCloneUrls
  calls:
  - action: getSourceRepositoryCloneUrls
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.https }}'
- discovery_id: aws.codecatalyst.getSpace
  calls:
  - action: getSpace
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.name }}'
- discovery_id: aws.codecatalyst.getSubscription
  calls:
  - action: getSubscription
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.subscriptionType }}'
- discovery_id: aws.codecatalyst.getWorkflow
  calls:
  - action: getWorkflow
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.definition }}'
    item:
      path: '{{ item.path }}'
- discovery_id: aws.codecatalyst.getWorkflowRun
  calls:
  - action: getWorkflowRun
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.statusReasons }}'
- discovery_id: aws.codecatalyst.listDevEnvironmentSessions
  calls:
  - action: listDevEnvironmentSessions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
    item:
      spaceName: '{{ item.spaceName }}'
      projectName: '{{ item.projectName }}'
      devEnvironmentId: '{{ item.devEnvironmentId }}'
      startedTime: '{{ item.startedTime }}'
      id: '{{ item.id }}'
- discovery_id: aws.codecatalyst.listDevEnvironments
  calls:
  - action: listDevEnvironments
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
    item:
      spaceName: '{{ item.spaceName }}'
      projectName: '{{ item.projectName }}'
      id: '{{ item.id }}'
      lastUpdatedTime: '{{ item.lastUpdatedTime }}'
      creatorId: '{{ item.creatorId }}'
      status: '{{ item.status }}'
      statusReason: '{{ item.statusReason }}'
      repositories: '{{ item.repositories }}'
      alias: '{{ item.alias }}'
      ides: '{{ item.ides }}'
      instanceType: '{{ item.instanceType }}'
      inactivityTimeoutMinutes: '{{ item.inactivityTimeoutMinutes }}'
      persistentStorage: '{{ item.persistentStorage }}'
      vpcConnectionName: '{{ item.vpcConnectionName }}'
- discovery_id: aws.codecatalyst.listEventLogs
  calls:
  - action: listEventLogs
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
    item:
      id: '{{ item.id }}'
      eventName: '{{ item.eventName }}'
      eventType: '{{ item.eventType }}'
      eventCategory: '{{ item.eventCategory }}'
      eventSource: '{{ item.eventSource }}'
      eventTime: '{{ item.eventTime }}'
      operationType: '{{ item.operationType }}'
      userIdentity: '{{ item.userIdentity }}'
      projectInformation: '{{ item.projectInformation }}'
      requestId: '{{ item.requestId }}'
      requestPayload: '{{ item.requestPayload }}'
      responsePayload: '{{ item.responsePayload }}'
      errorCode: '{{ item.errorCode }}'
      sourceIpAddress: '{{ item.sourceIpAddress }}'
      userAgent: '{{ item.userAgent }}'
- discovery_id: aws.codecatalyst.listProjects
  calls:
  - action: listProjects
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
    item:
      name: '{{ item.name }}'
      displayName: '{{ item.displayName }}'
      description: '{{ item.description }}'
- discovery_id: aws.codecatalyst.listSourceRepositories
  calls:
  - action: listSourceRepositories
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
    item:
      id: '{{ item.id }}'
      name: '{{ item.name }}'
      description: '{{ item.description }}'
      lastUpdatedTime: '{{ item.lastUpdatedTime }}'
      createdTime: '{{ item.createdTime }}'
- discovery_id: aws.codecatalyst.listSourceRepositoryBranches
  calls:
  - action: listSourceRepositoryBranches
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
    item:
      ref: '{{ item.ref }}'
      name: '{{ item.name }}'
      lastUpdatedTime: '{{ item.lastUpdatedTime }}'
      headCommitId: '{{ item.headCommitId }}'
- discovery_id: aws.codecatalyst.listWorkflowRuns
  calls:
  - action: listWorkflowRuns
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
    item:
      id: '{{ item.id }}'
      workflowId: '{{ item.workflowId }}'
      workflowName: '{{ item.workflowName }}'
      status: '{{ item.status }}'
      statusReasons: '{{ item.statusReasons }}'
      startTime: '{{ item.startTime }}'
      endTime: '{{ item.endTime }}'
      lastUpdatedTime: '{{ item.lastUpdatedTime }}'
- discovery_id: aws.codecatalyst.listWorkflows
  calls:
  - action: listWorkflows
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
    item:
      id: '{{ item.id }}'
      name: '{{ item.name }}'
      sourceRepositoryName: '{{ item.sourceRepositoryName }}'
      sourceBranchName: '{{ item.sourceBranchName }}'
      definition: '{{ item.definition }}'
      createdTime: '{{ item.createdTime }}'
      lastUpdatedTime: '{{ item.lastUpdatedTime }}'
      runMode: '{{ item.runMode }}'
      status: '{{ item.status }}'
checks: []
