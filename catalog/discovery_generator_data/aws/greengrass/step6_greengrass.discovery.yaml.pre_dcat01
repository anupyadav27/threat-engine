    item:
      GroupId: '{{ response.GroupId }}'
- discovery_id: aws.greengrass.get_group_version
  calls:
  - action: get_group_version
    save_as: response
    on_error: continue
  emit:
    as: item
    item:
      ConnectorDefinitionVersionArn: '{{ response.Definition.ConnectorDefinitionVersionArn
        }}'
      CoreDefinitionVersionArn: '{{ response.Definition.CoreDefinitionVersionArn }}'
      DeviceDefinitionVersionArn: '{{ response.Definition.DeviceDefinitionVersionArn
        }}'
      FunctionDefinitionVersionArn: '{{ response.Definition.FunctionDefinitionVersionArn
        }}'
      LoggerDefinitionVersionArn: '{{ response.Definition.LoggerDefinitionVersionArn
        }}'
      ResourceDefinitionVersionArn: '{{ response.Definition.ResourceDefinitionVersionArn
        }}'
      SubscriptionDefinitionVersionArn: '{{ response.Definition.SubscriptionDefinitionVersionArn
        }}'
- discovery_id: aws.greengrass.get_logger_definition
  calls:
  - action: get_logger_definition
    save_as: response
    on_error: continue
  emit:
    as: item
    item:
      Arn: '{{ response.Arn }}'
      Id: '{{ response.Id }}'
      Name: '{{ response.Name }}'
      CreationTimestamp: '{{ response.CreationTimestamp }}'
      LastUpdatedTimestamp: '{{ response.LastUpdatedTimestamp }}'
      LatestVersion: '{{ response.LatestVersion }}'
      LatestVersionArn: '{{ response.LatestVersionArn }}'
      tags: '{{ response.tags }}'
- discovery_id: aws.greengrass.get_logger_definition_version
  calls:
  - action: get_logger_definition_version
    save_as: response
    on_error: continue
  emit:
    as: item
    item:
      Loggers: '{{ response.Definition.Loggers }}'
- discovery_id: aws.greengrass.get_resource_definition
  calls:
  - action: get_resource_definition
    save_as: response
    on_error: continue
  emit:
    as: item
    item:
      Arn: '{{ response.Arn }}'
      Id: '{{ response.Id }}'
      Name: '{{ response.Name }}'
      CreationTimestamp: '{{ response.CreationTimestamp }}'
      LastUpdatedTimestamp: '{{ response.LastUpdatedTimestamp }}'
      LatestVersion: '{{ response.LatestVersion }}'
      LatestVersionArn: '{{ response.LatestVersionArn }}'
      tags: '{{ response.tags }}'
