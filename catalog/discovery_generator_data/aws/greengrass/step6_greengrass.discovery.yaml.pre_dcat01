  calls:
  - action: get_resource_definition_version
    save_as: response
    on_error: continue
  emit:
    as: item
    item:
      Resources: '{{ response.Definition.Resources }}'
- discovery_id: aws.greengrass.get_subscription_definition
  calls:
  - action: get_subscription_definition
    save_as: response
    on_error: continue
  emit:
    as: item
    item:
