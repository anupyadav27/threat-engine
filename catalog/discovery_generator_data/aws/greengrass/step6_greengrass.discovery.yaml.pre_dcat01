      tags: '{{ response.tags }}'
- discovery_id: aws.greengrass.get_group_certificate_authority
  calls:
  - action: get_group_certificate_authority
    save_as: response
    on_error: continue
  emit:
    as: item
    item:
      GroupCertificateAuthorityArn: '{{ response.GroupCertificateAuthorityArn }}'
      GroupCertificateAuthorityId: '{{ response.GroupCertificateAuthorityId }}'
      PemEncodedCertificate: '{{ response.PemEncodedCertificate }}'
- discovery_id: aws.greengrass.get_group_certificate_configuration
  calls:
  - action: get_group_certificate_configuration
    save_as: response
    on_error: continue
  emit:
