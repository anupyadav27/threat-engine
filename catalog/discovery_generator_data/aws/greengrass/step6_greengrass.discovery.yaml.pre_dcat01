- discovery_id: aws.greengrass.get_thing_runtime_configuration
  calls:
  - action: get_thing_runtime_configuration
    save_as: response
    on_error: continue
  emit:
    as: item
    item:
      Status: '{{ response.RuntimeConfiguration.Status }}'
      Enabled: '{{ response.RuntimeConfiguration.Enabled }}'
      TelemetryConfiguration: '{{ response.RuntimeConfiguration.TelemetryConfiguration
        }}'
- discovery_id: aws.greengrass.list_bulk_deployment_detailed_reports
  for_each: aws.greengrass.list_bulk_deployments
  calls:
  - action: list_bulk_deployment_detailed_reports
    params:
      BulkDeploymentId: '{{ item.BulkDeploymentId }}'
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Deployments }}'
    item:
      CreatedAt: '{{ item.CreatedAt }}'
      DeploymentArn: '{{ item.DeploymentArn }}'
      DeploymentId: '{{ item.DeploymentId }}'
      DeploymentStatus: '{{ item.DeploymentStatus }}'
      DeploymentType: '{{ item.DeploymentType }}'
      ErrorDetails: '{{ item.ErrorDetails }}'
      ErrorMessage: '{{ item.ErrorMessage }}'
      GroupArn: '{{ item.GroupArn }}'
- discovery_id: aws.greengrass.list_connector_definition_versions
  calls:
