version: '1.0'
provider: aws
service: greengrass
is_active: false
services:
  client: greengrass
  module: boto3.client
discovery:
- discovery_id: aws.greengrass.get_service_role_for_account
  calls:
  - action: get_service_role_for_account
    save_as: response
    on_error: continue
  emit:
    as: item
    item:
      RoleArn: '{{ response.RoleArn }}'
      AssociatedAt: '{{ response.AssociatedAt }}'
- discovery_id: aws.greengrass.list_bulk_deployments
  calls:
  - action: list_bulk_deployments
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.BulkDeployments }}'
    item:
      BulkDeploymentArn: '{{ item.BulkDeploymentArn }}'
      BulkDeploymentId: '{{ item.BulkDeploymentId }}'
      CreatedAt: '{{ item.CreatedAt }}'
- discovery_id: aws.greengrass.list_connector_definitions
  calls:
  - action: list_connector_definitions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Definitions }}'
    item:
      Arn: '{{ item.Arn }}'
      Id: '{{ item.Id }}'
      Name: '{{ item.Name }}'
      Tags: '{{ item.Tags }}'
      CreationTimestamp: '{{ item.CreationTimestamp }}'
      LastUpdatedTimestamp: '{{ item.LastUpdatedTimestamp }}'
      LatestVersion: '{{ item.LatestVersion }}'
      LatestVersionArn: '{{ item.LatestVersionArn }}'
- discovery_id: aws.greengrass.list_core_definitions
  calls:
  - action: list_core_definitions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Definitions }}'
    item:
      Arn: '{{ item.Arn }}'
      Id: '{{ item.Id }}'
      Name: '{{ item.Name }}'
      Tags: '{{ item.Tags }}'
      CreationTimestamp: '{{ item.CreationTimestamp }}'
      LastUpdatedTimestamp: '{{ item.LastUpdatedTimestamp }}'
      LatestVersion: '{{ item.LatestVersion }}'
      LatestVersionArn: '{{ item.LatestVersionArn }}'
- discovery_id: aws.greengrass.list_device_definitions
  calls:
  - action: list_device_definitions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Definitions }}'
    item:
      Arn: '{{ item.Arn }}'
      Id: '{{ item.Id }}'
      Name: '{{ item.Name }}'
      Tags: '{{ item.Tags }}'
      CreationTimestamp: '{{ item.CreationTimestamp }}'
      LastUpdatedTimestamp: '{{ item.LastUpdatedTimestamp }}'
      LatestVersion: '{{ item.LatestVersion }}'
      LatestVersionArn: '{{ item.LatestVersionArn }}'
- discovery_id: aws.greengrass.list_function_definitions
  calls:
  - action: list_function_definitions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Definitions }}'
    item:
      Arn: '{{ item.Arn }}'
      Id: '{{ item.Id }}'
      Name: '{{ item.Name }}'
      Tags: '{{ item.Tags }}'
      CreationTimestamp: '{{ item.CreationTimestamp }}'
      LastUpdatedTimestamp: '{{ item.LastUpdatedTimestamp }}'
      LatestVersion: '{{ item.LatestVersion }}'
      LatestVersionArn: '{{ item.LatestVersionArn }}'
- discovery_id: aws.greengrass.list_groups
  calls:
  - action: list_groups
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Groups }}'
    item:
      Arn: '{{ item.Arn }}'
      Id: '{{ item.Id }}'
      Name: '{{ item.Name }}'
      CreationTimestamp: '{{ item.CreationTimestamp }}'
      GroupId: '{{ item.GroupId }}'
      LastUpdatedTimestamp: '{{ item.LastUpdatedTimestamp }}'
      LatestVersion: '{{ item.LatestVersion }}'
      LatestVersionArn: '{{ item.LatestVersionArn }}'
- discovery_id: aws.greengrass.list_logger_definitions
  calls:
  - action: list_logger_definitions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Definitions }}'
    item:
      Arn: '{{ item.Arn }}'
      Id: '{{ item.Id }}'
      Name: '{{ item.Name }}'
      Tags: '{{ item.Tags }}'
      CreationTimestamp: '{{ item.CreationTimestamp }}'
      LastUpdatedTimestamp: '{{ item.LastUpdatedTimestamp }}'
      LatestVersion: '{{ item.LatestVersion }}'
      LatestVersionArn: '{{ item.LatestVersionArn }}'
- discovery_id: aws.greengrass.list_resource_definitions
  calls:
  - action: list_resource_definitions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Definitions }}'
    item:
      Arn: '{{ item.Arn }}'
      Id: '{{ item.Id }}'
      Name: '{{ item.Name }}'
      Tags: '{{ item.Tags }}'
      CreationTimestamp: '{{ item.CreationTimestamp }}'
      LastUpdatedTimestamp: '{{ item.LastUpdatedTimestamp }}'
      LatestVersion: '{{ item.LatestVersion }}'
      LatestVersionArn: '{{ item.LatestVersionArn }}'
- discovery_id: aws.greengrass.list_subscription_definitions
  calls:
  - action: list_subscription_definitions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Definitions }}'
    item:
      Arn: '{{ item.Arn }}'
      Id: '{{ item.Id }}'
      Name: '{{ item.Name }}'
      Tags: '{{ item.Tags }}'
      CreationTimestamp: '{{ item.CreationTimestamp }}'
      LastUpdatedTimestamp: '{{ item.LastUpdatedTimestamp }}'
      LatestVersion: '{{ item.LatestVersion }}'
      LatestVersionArn: '{{ item.LatestVersionArn }}'
- discovery_id: aws.greengrass.get_associated_role
  calls:
  - action: get_associated_role
    save_as: response
    on_error: continue
  emit:
    as: item
    item:
      RoleArn: '{{ response.RoleArn }}'
      AssociatedAt: '{{ response.AssociatedAt }}'
- discovery_id: aws.greengrass.get_bulk_deployment_status
  for_each: aws.greengrass.list_bulk_deployments
  calls:
  - action: get_bulk_deployment_status
    params:
      BulkDeploymentId: '{{ item.BulkDeploymentId }}'
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ErrorDetails }}'
    item:
      DetailedErrorCode: '{{ item.DetailedErrorCode }}'
      DetailedErrorMessage: '{{ item.DetailedErrorMessage }}'
- discovery_id: aws.greengrass.get_connectivity_info
  calls:
  - action: get_connectivity_info
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ConnectivityInfo }}'
    item:
      Id: '{{ item.Id }}'
      HostAddress: '{{ item.HostAddress }}'
      Metadata: '{{ item.Metadata }}'
      PortNumber: '{{ item.PortNumber }}'
- discovery_id: aws.greengrass.get_connector_definition
  calls:
  - action: get_connector_definition
    save_as: response
    on_error: continue
  emit:
    as: item
    item:
      Arn: '{{ response.Arn }}'
      Id: '{{ response.Id }}'
      Name: '{{ response.Name }}'
      CreationTimestamp: '{{ response.CreationTimestamp }}'
      LastUpdatedTimestamp: '{{ response.LastUpdatedTimestamp }}'
      LatestVersion: '{{ response.LatestVersion }}'
      LatestVersionArn: '{{ response.LatestVersionArn }}'
      tags: '{{ response.tags }}'
- discovery_id: aws.greengrass.get_connector_definition_version
  calls:
  - action: get_connector_definition_version
    save_as: response
    on_error: continue
  emit:
    as: item
    item:
      Connectors: '{{ response.Definition.Connectors }}'
      Definition: '{{ response.Definition.Definition }}'
- discovery_id: aws.greengrass.get_core_definition
  calls:
  - action: get_core_definition
    save_as: response
    on_error: continue
  emit:
    as: item
    item:
      Arn: '{{ response.Arn }}'
      Id: '{{ response.Id }}'
      Name: '{{ response.Name }}'
      CreationTimestamp: '{{ response.CreationTimestamp }}'
      LastUpdatedTimestamp: '{{ response.LastUpdatedTimestamp }}'
      LatestVersion: '{{ response.LatestVersion }}'
      LatestVersionArn: '{{ response.LatestVersionArn }}'
      tags: '{{ response.tags }}'
- discovery_id: aws.greengrass.get_core_definition_version
  calls:
  - action: get_core_definition_version
    save_as: response
    on_error: continue
  emit:
    as: item
    item:
      Cores: '{{ response.Definition.Cores }}'
- discovery_id: aws.greengrass.get_deployment_status
  calls:
  - action: get_deployment_status
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ErrorDetails }}'
    item:
      DetailedErrorCode: '{{ item.DetailedErrorCode }}'
      DetailedErrorMessage: '{{ item.DetailedErrorMessage }}'
- discovery_id: aws.greengrass.get_device_definition
  calls:
  - action: get_device_definition
    save_as: response
    on_error: continue
  emit:
    as: item
    item:
      Arn: '{{ response.Arn }}'
      Id: '{{ response.Id }}'
      Name: '{{ response.Name }}'
      CreationTimestamp: '{{ response.CreationTimestamp }}'
      LastUpdatedTimestamp: '{{ response.LastUpdatedTimestamp }}'
      LatestVersion: '{{ response.LatestVersion }}'
      LatestVersionArn: '{{ response.LatestVersionArn }}'
      tags: '{{ response.tags }}'
- discovery_id: aws.greengrass.get_device_definition_version
  calls:
  - action: get_device_definition_version
    save_as: response
    on_error: continue
  emit:
    as: item
    item:
      Devices: '{{ response.Definition.Devices }}'
- discovery_id: aws.greengrass.get_function_definition
  calls:
  - action: get_function_definition
    save_as: response
    on_error: continue
  emit:
    as: item
    item:
      Arn: '{{ response.Arn }}'
      Id: '{{ response.Id }}'
      Name: '{{ response.Name }}'
      CreationTimestamp: '{{ response.CreationTimestamp }}'
      LastUpdatedTimestamp: '{{ response.LastUpdatedTimestamp }}'
      LatestVersion: '{{ response.LatestVersion }}'
      LatestVersionArn: '{{ response.LatestVersionArn }}'
      tags: '{{ response.tags }}'
- discovery_id: aws.greengrass.get_function_definition_version
  calls:
  - action: get_function_definition_version
    save_as: response
    on_error: continue
  emit:
