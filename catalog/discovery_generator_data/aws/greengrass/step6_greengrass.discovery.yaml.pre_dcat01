- discovery_id: aws.greengrass.list_logger_definition_versions
  calls:
  - action: list_logger_definition_versions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Versions }}'
    item:
      Arn: '{{ item.Arn }}'
      Id: '{{ item.Id }}'
      CreationTimestamp: '{{ item.CreationTimestamp }}'
      Version: '{{ item.Version }}'
- discovery_id: aws.greengrass.list_resource_definition_versions
  calls:
  - action: list_resource_definition_versions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Versions }}'
    item:
