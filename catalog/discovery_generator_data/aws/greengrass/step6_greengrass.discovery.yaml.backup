    items_for: '{{ response.Definition }}'
    item:
      Resources: '{{ item.Resources }}'
- discovery_id: aws.greengrass.getSubscriptionDefinition
  calls:
  - action: getSubscriptionDefinition
    save_as: response
    on_error: continue
  emit:
