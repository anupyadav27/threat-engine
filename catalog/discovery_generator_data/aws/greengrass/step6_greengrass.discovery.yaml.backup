- discovery_id: aws.greengrass.getThingRuntimeConfiguration
  calls:
  - action: getThingRuntimeConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.RuntimeConfiguration }}'
    item:
      TelemetryConfiguration: '{{ item.TelemetryConfiguration }}'
- discovery_id: aws.greengrass.listBulkDeploymentDetailedReports
  calls:
  - action: listBulkDeploymentDetailedReports
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Deployments }}'
    item:
      CreatedAt: '{{ item.CreatedAt }}'
      DeploymentArn: '{{ item.DeploymentArn }}'
      DeploymentId: '{{ item.DeploymentId }}'
      DeploymentStatus: '{{ item.DeploymentStatus }}'
      DeploymentType: '{{ item.DeploymentType }}'
      ErrorDetails: '{{ item.ErrorDetails }}'
      ErrorMessage: '{{ item.ErrorMessage }}'
      GroupArn: '{{ item.GroupArn }}'
- discovery_id: aws.greengrass.listConnectorDefinitionVersions
  calls:
  - action: listConnectorDefinitionVersions
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Versions }}'
    item:
      Arn: '{{ item.Arn }}'
      CreationTimestamp: '{{ item.CreationTimestamp }}'
      Id: '{{ item.Id }}'
      Version: '{{ item.Version }}'
- discovery_id: aws.greengrass.listCoreDefinitionVersions
  calls:
  - action: listCoreDefinitionVersions
    save_as: response
