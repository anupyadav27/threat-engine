    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Versions }}'
    item:
      Arn: '{{ item.Arn }}'
      CreationTimestamp: '{{ item.CreationTimestamp }}'
      Id: '{{ item.Id }}'
      Version: '{{ item.Version }}'
- discovery_id: aws.greengrass.listResourceDefinitionVersions
  calls:
  - action: listResourceDefinitionVersions
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
