version: '1.0'
provider: aws
service: greengrass
services:
  client: greengrass
  module: boto3.client
discovery:
- discovery_id: aws.greengrass.getServiceRoleForAccount
  calls:
  - action: getServiceRoleForAccount
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AssociatedAt }}'
- discovery_id: aws.greengrass.listBulkDeployments
  calls:
  - action: listBulkDeployments
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.BulkDeployments }}'
    item:
      BulkDeploymentArn: '{{ item.BulkDeploymentArn }}'
      BulkDeploymentId: '{{ item.BulkDeploymentId }}'
      CreatedAt: '{{ item.CreatedAt }}'
- discovery_id: aws.greengrass.listConnectorDefinitions
  calls:
  - action: listConnectorDefinitions
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Definitions }}'
    item:
      Arn: '{{ item.Arn }}'
      CreationTimestamp: '{{ item.CreationTimestamp }}'
      Id: '{{ item.Id }}'
      LastUpdatedTimestamp: '{{ item.LastUpdatedTimestamp }}'
      LatestVersion: '{{ item.LatestVersion }}'
      LatestVersionArn: '{{ item.LatestVersionArn }}'
      Name: '{{ item.Name }}'
      Tags: '{{ item.Tags }}'
- discovery_id: aws.greengrass.listCoreDefinitions
  calls:
  - action: listCoreDefinitions
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Definitions }}'
    item:
      Arn: '{{ item.Arn }}'
      CreationTimestamp: '{{ item.CreationTimestamp }}'
      Id: '{{ item.Id }}'
      LastUpdatedTimestamp: '{{ item.LastUpdatedTimestamp }}'
      LatestVersion: '{{ item.LatestVersion }}'
      LatestVersionArn: '{{ item.LatestVersionArn }}'
      Name: '{{ item.Name }}'
      Tags: '{{ item.Tags }}'
- discovery_id: aws.greengrass.listDeviceDefinitions
  calls:
  - action: listDeviceDefinitions
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Definitions }}'
    item:
      Arn: '{{ item.Arn }}'
      CreationTimestamp: '{{ item.CreationTimestamp }}'
      Id: '{{ item.Id }}'
      LastUpdatedTimestamp: '{{ item.LastUpdatedTimestamp }}'
      LatestVersion: '{{ item.LatestVersion }}'
      LatestVersionArn: '{{ item.LatestVersionArn }}'
      Name: '{{ item.Name }}'
      Tags: '{{ item.Tags }}'
- discovery_id: aws.greengrass.listFunctionDefinitions
  calls:
  - action: listFunctionDefinitions
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Definitions }}'
    item:
      Arn: '{{ item.Arn }}'
      CreationTimestamp: '{{ item.CreationTimestamp }}'
      Id: '{{ item.Id }}'
      LastUpdatedTimestamp: '{{ item.LastUpdatedTimestamp }}'
      LatestVersion: '{{ item.LatestVersion }}'
      LatestVersionArn: '{{ item.LatestVersionArn }}'
      Name: '{{ item.Name }}'
      Tags: '{{ item.Tags }}'
- discovery_id: aws.greengrass.listGroups
  calls:
  - action: listGroups
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Groups }}'
    item:
      Arn: '{{ item.Arn }}'
      CreationTimestamp: '{{ item.CreationTimestamp }}'
      Id: '{{ item.Id }}'
      LastUpdatedTimestamp: '{{ item.LastUpdatedTimestamp }}'
      LatestVersion: '{{ item.LatestVersion }}'
      LatestVersionArn: '{{ item.LatestVersionArn }}'
      Name: '{{ item.Name }}'
- discovery_id: aws.greengrass.listLoggerDefinitions
  calls:
  - action: listLoggerDefinitions
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Definitions }}'
    item:
      Arn: '{{ item.Arn }}'
      CreationTimestamp: '{{ item.CreationTimestamp }}'
      Id: '{{ item.Id }}'
      LastUpdatedTimestamp: '{{ item.LastUpdatedTimestamp }}'
      LatestVersion: '{{ item.LatestVersion }}'
      LatestVersionArn: '{{ item.LatestVersionArn }}'
      Name: '{{ item.Name }}'
      Tags: '{{ item.Tags }}'
- discovery_id: aws.greengrass.listResourceDefinitions
  calls:
  - action: listResourceDefinitions
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Definitions }}'
    item:
      Arn: '{{ item.Arn }}'
      CreationTimestamp: '{{ item.CreationTimestamp }}'
      Id: '{{ item.Id }}'
      LastUpdatedTimestamp: '{{ item.LastUpdatedTimestamp }}'
      LatestVersion: '{{ item.LatestVersion }}'
      LatestVersionArn: '{{ item.LatestVersionArn }}'
      Name: '{{ item.Name }}'
      Tags: '{{ item.Tags }}'
- discovery_id: aws.greengrass.listSubscriptionDefinitions
  calls:
  - action: listSubscriptionDefinitions
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.Definitions }}'
    item:
      Arn: '{{ item.Arn }}'
      CreationTimestamp: '{{ item.CreationTimestamp }}'
      Id: '{{ item.Id }}'
      LastUpdatedTimestamp: '{{ item.LastUpdatedTimestamp }}'
      LatestVersion: '{{ item.LatestVersion }}'
      LatestVersionArn: '{{ item.LatestVersionArn }}'
      Name: '{{ item.Name }}'
      Tags: '{{ item.Tags }}'
- discovery_id: aws.greengrass.getAssociatedRole
  calls:
  - action: getAssociatedRole
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AssociatedAt }}'
- discovery_id: aws.greengrass.getBulkDeploymentStatus
  calls:
  - action: getBulkDeploymentStatus
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ErrorDetails }}'
    item:
      DetailedErrorCode: '{{ item.DetailedErrorCode }}'
      DetailedErrorMessage: '{{ item.DetailedErrorMessage }}'
- discovery_id: aws.greengrass.getConnectivityInfo
  calls:
  - action: getConnectivityInfo
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ConnectivityInfo }}'
    item:
      HostAddress: '{{ item.HostAddress }}'
      Id: '{{ item.Id }}'
      Metadata: '{{ item.Metadata }}'
      PortNumber: '{{ item.PortNumber }}'
- discovery_id: aws.greengrass.getConnectorDefinition
  calls:
  - action: getConnectorDefinition
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Arn }}'
- discovery_id: aws.greengrass.getConnectorDefinitionVersion
  calls:
  - action: getConnectorDefinitionVersion
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Definition }}'
    item:
      Connectors: '{{ item.Connectors }}'
- discovery_id: aws.greengrass.getCoreDefinition
  calls:
  - action: getCoreDefinition
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Arn }}'
- discovery_id: aws.greengrass.getCoreDefinitionVersion
  calls:
  - action: getCoreDefinitionVersion
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Definition }}'
    item:
      Cores: '{{ item.Cores }}'
- discovery_id: aws.greengrass.getDeploymentStatus
  calls:
  - action: getDeploymentStatus
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ErrorDetails }}'
    item:
      DetailedErrorCode: '{{ item.DetailedErrorCode }}'
      DetailedErrorMessage: '{{ item.DetailedErrorMessage }}'
- discovery_id: aws.greengrass.getDeviceDefinition
  calls:
  - action: getDeviceDefinition
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Arn }}'
- discovery_id: aws.greengrass.getDeviceDefinitionVersion
  calls:
  - action: getDeviceDefinitionVersion
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Definition }}'
    item:
      Devices: '{{ item.Devices }}'
- discovery_id: aws.greengrass.getFunctionDefinition
  calls:
  - action: getFunctionDefinition
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Arn }}'
- discovery_id: aws.greengrass.getFunctionDefinitionVersion
  calls:
  - action: getFunctionDefinitionVersion
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Definition }}'
    item:
      DefaultConfig: '{{ item.DefaultConfig }}'
      Functions: '{{ item.Functions }}'
- discovery_id: aws.greengrass.getGroup
  calls:
  - action: getGroup
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Arn }}'
- discovery_id: aws.greengrass.getGroupCertificateAuthority
  calls:
  - action: getGroupCertificateAuthority
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.GroupCertificateAuthorityArn }}'
- discovery_id: aws.greengrass.getGroupCertificateConfiguration
  calls:
  - action: getGroupCertificateConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.CertificateAuthorityExpiryInMilliseconds }}'
- discovery_id: aws.greengrass.getGroupVersion
  calls:
  - action: getGroupVersion
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Definition }}'
    item:
      ConnectorDefinitionVersionArn: '{{ item.ConnectorDefinitionVersionArn }}'
      CoreDefinitionVersionArn: '{{ item.CoreDefinitionVersionArn }}'
      DeviceDefinitionVersionArn: '{{ item.DeviceDefinitionVersionArn }}'
      FunctionDefinitionVersionArn: '{{ item.FunctionDefinitionVersionArn }}'
      LoggerDefinitionVersionArn: '{{ item.LoggerDefinitionVersionArn }}'
      ResourceDefinitionVersionArn: '{{ item.ResourceDefinitionVersionArn }}'
      SubscriptionDefinitionVersionArn: '{{ item.SubscriptionDefinitionVersionArn
        }}'
- discovery_id: aws.greengrass.getLoggerDefinition
  calls:
  - action: getLoggerDefinition
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Arn }}'
- discovery_id: aws.greengrass.getLoggerDefinitionVersion
  calls:
