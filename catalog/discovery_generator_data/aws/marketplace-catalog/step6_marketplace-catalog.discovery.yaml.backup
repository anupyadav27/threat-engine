version: '1.0'
provider: aws
service: marketplace-catalog
services:
  client: marketplace-catalog
  module: boto3.client
discovery:
- discovery_id: aws.marketplace-catalog.describeChangeSet
  calls:
  - action: describeChangeSet
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ChangeSet }}'
    item:
      ChangeType: '{{ item.ChangeType }}'
      Entity: '{{ item.Entity }}'
      Details: '{{ item.Details }}'
      DetailsDocument: '{{ item.DetailsDocument }}'
      ErrorDetailList: '{{ item.ErrorDetailList }}'
      ChangeName: '{{ item.ChangeName }}'
- discovery_id: aws.marketplace-catalog.describeEntity
  calls:
  - action: describeEntity
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.DetailsDocument }}'
- discovery_id: aws.marketplace-catalog.getResourcePolicy
  calls:
  - action: getResourcePolicy
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Policy }}'
- discovery_id: aws.marketplace-catalog.listChangeSets
  calls:
  - action: listChangeSets
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.ChangeSetSummaryList }}'
    item:
      ChangeSetId: '{{ item.ChangeSetId }}'
      ChangeSetArn: '{{ item.ChangeSetArn }}'
      ChangeSetName: '{{ item.ChangeSetName }}'
      StartTime: '{{ item.StartTime }}'
      EndTime: '{{ item.EndTime }}'
      Status: '{{ item.Status }}'
      EntityIdList: '{{ item.EntityIdList }}'
      FailureCode: '{{ item.FailureCode }}'
- discovery_id: aws.marketplace-catalog.listEntities
  calls:
  - action: listEntities
    save_as: response
    on_error: continue
    params:
      MaxResults: 1000
  emit:
    as: item
    items_for: '{{ response.EntitySummaryList }}'
    item:
      Name: '{{ item.Name }}'
      EntityType: '{{ item.EntityType }}'
      EntityId: '{{ item.EntityId }}'
      EntityArn: '{{ item.EntityArn }}'
      LastModifiedDate: '{{ item.LastModifiedDate }}'
      Visibility: '{{ item.Visibility }}'
      AmiProductSummary: '{{ item.AmiProductSummary }}'
      ContainerProductSummary: '{{ item.ContainerProductSummary }}'
      DataProductSummary: '{{ item.DataProductSummary }}'
      SaaSProductSummary: '{{ item.SaaSProductSummary }}'
      OfferSummary: '{{ item.OfferSummary }}'
      ResaleAuthorizationSummary: '{{ item.ResaleAuthorizationSummary }}'
      MachineLearningProductSummary: '{{ item.MachineLearningProductSummary }}'
- discovery_id: aws.marketplace-catalog.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Tags }}'
    item:
      Key: '{{ item.Key }}'
      Value: '{{ item.Value }}'
checks: []
