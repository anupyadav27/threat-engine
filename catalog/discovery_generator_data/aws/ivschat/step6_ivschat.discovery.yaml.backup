version: '1.0'
provider: aws
service: ivschat
services:
  client: ivschat
  module: boto3.client
discovery:
- discovery_id: aws.ivschat.listLoggingConfigurations
  calls:
  - action: listLoggingConfigurations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.loggingConfigurations }}'
    item:
      arn: '{{ item.arn }}'
      id: '{{ item.id }}'
      createTime: '{{ item.createTime }}'
      updateTime: '{{ item.updateTime }}'
      name: '{{ item.name }}'
      destinationConfiguration: '{{ item.destinationConfiguration }}'
      state: '{{ item.state }}'
      tags: '{{ item.tags }}'
- discovery_id: aws.ivschat.listRooms
  calls:
  - action: listRooms
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.rooms }}'
    item:
      arn: '{{ item.arn }}'
      id: '{{ item.id }}'
      name: '{{ item.name }}'
      messageReviewHandler: '{{ item.messageReviewHandler }}'
      createTime: '{{ item.createTime }}'
      updateTime: '{{ item.updateTime }}'
      tags: '{{ item.tags }}'
      loggingConfigurationIdentifiers: '{{ item.loggingConfigurationIdentifiers }}'
- discovery_id: aws.ivschat.getLoggingConfiguration
  calls:
  - action: getLoggingConfiguration
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.destinationConfiguration }}'
    item:
      s3: '{{ item.s3 }}'
      cloudWatchLogs: '{{ item.cloudWatchLogs }}'
      firehose: '{{ item.firehose }}'
- discovery_id: aws.ivschat.getRoom
  calls:
  - action: getRoom
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.loggingConfigurationIdentifiers }}'
- discovery_id: aws.ivschat.listTagsForResource
  calls:
  - action: listTagsForResource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.tags }}'
checks: []
