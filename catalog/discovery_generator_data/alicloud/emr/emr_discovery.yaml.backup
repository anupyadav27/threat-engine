version: '1.0'
provider: alicloud
service: emr
services:
  client: emr
  module: aliyunsdkemr
discovery:
- discovery_id: alicloud.emr.DescribeClusterOperationHostTaskLog
  calls:
  - action: DescribeClusterOperationHostTaskLog
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response }}'
- discovery_id: alicloud.emr.DescribeFlow
  calls:
  - action: DescribeFlow
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response }}'
- discovery_id: alicloud.emr.DescribeClusterResourcePoolSchedulerType
  calls:
  - action: DescribeClusterResourcePoolSchedulerType
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response }}'
- discovery_id: alicloud.emr.DescribeClusterServiceConfig
  calls:
  - action: DescribeClusterServiceConfig
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response }}'
- discovery_id: alicloud.emr.DescribeClusterTemplate
  calls:
  - action: DescribeClusterTemplate
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response }}'
- discovery_id: alicloud.emr.DescribeClusterBasicInfo
  calls:
  - action: DescribeClusterBasicInfo
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response }}'
- discovery_id: alicloud.emr.DescribeFlowCategory
  calls:
  - action: DescribeFlowCategory
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response }}'
- discovery_id: alicloud.emr.DescribeClusterService
  calls:
  - action: DescribeClusterService
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response }}'
- discovery_id: alicloud.emr.DescribeClusterV2
  calls:
  - action: DescribeClusterV2
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response }}'
- discovery_id: alicloud.emr.DescribeClusterServiceConfigTag
  calls:
  - action: DescribeClusterServiceConfigTag
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response }}'
checks: []
