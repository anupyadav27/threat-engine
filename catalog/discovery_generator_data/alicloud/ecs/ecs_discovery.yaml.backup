version: '1.0'
provider: alicloud
service: ecs
services:
  client: ecs
  module: aliyunsdkecs
discovery:
- discovery_id: alicloud.ecs.DescribeAutoProvisioningGroupInstances
  calls:
  - action: DescribeAutoProvisioningGroupInstances
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response }}'
- discovery_id: alicloud.ecs.DescribeAccountAttributes
  calls:
  - action: DescribeAccountAttributes
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response }}'
- discovery_id: alicloud.ecs.DescribeAutoProvisioningGroupHistory
  calls:
  - action: DescribeAutoProvisioningGroupHistory
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response }}'
- discovery_id: alicloud.ecs.DescribeAccessPoints
  calls:
  - action: DescribeAccessPoints
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response }}'
- discovery_id: alicloud.ecs.DescribeAutoProvisioningGroups
  calls:
  - action: DescribeAutoProvisioningGroups
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response }}'
- discovery_id: alicloud.ecs.DescribeActivations
  calls:
  - action: DescribeActivations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response }}'
checks: []
