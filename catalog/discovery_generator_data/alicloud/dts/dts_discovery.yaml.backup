version: '1.0'
provider: alicloud
service: dts
services:
  client: dts
  module: aliyunsdkdts
discovery:
- discovery_id: alicloud.dts.DescribeClusterUsedUtilization
  calls:
  - action: DescribeClusterUsedUtilization
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response }}'
- discovery_id: alicloud.dts.DescribeDataCheckTableDetails
  calls:
  - action: DescribeDataCheckTableDetails
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response }}'
