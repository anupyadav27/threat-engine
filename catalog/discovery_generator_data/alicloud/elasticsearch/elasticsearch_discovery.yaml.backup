version: '1.0'
provider: alicloud
service: elasticsearch
services:
  client: elasticsearch
  module: aliyunsdkelasticsearch
discovery:
- discovery_id: alicloud.elasticsearch.DescribeApm
  calls:
  - action: DescribeApm
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response }}'
- discovery_id: alicloud.elasticsearch.DescribeComponentIndex
  calls:
  - action: DescribeComponentIndex
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response }}'
- discovery_id: alicloud.elasticsearch.DescribeDynamicSettings
  calls:
  - action: DescribeDynamicSettings
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response }}'
- discovery_id: alicloud.elasticsearch.DescribeElasticsearchHealth
  calls:
  - action: DescribeElasticsearchHealth
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response }}'
- discovery_id: alicloud.elasticsearch.DescribeAckOperator
  calls:
  - action: DescribeAckOperator
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response }}'
- discovery_id: alicloud.elasticsearch.DescribeDiagnoseReport
  calls:
  - action: DescribeDiagnoseReport
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response }}'
- discovery_id: alicloud.elasticsearch.DescribeDiagnosisSettings
  calls:
  - action: DescribeDiagnosisSettings
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response }}'
- discovery_id: alicloud.elasticsearch.DescribeConnectableClusters
  calls:
  - action: DescribeConnectableClusters
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response }}'
- discovery_id: alicloud.elasticsearch.DescribeCollector
  calls:
  - action: DescribeCollector
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response }}'
- discovery_id: alicloud.elasticsearch.DescribeDeprecatedTemplate
  calls:
  - action: DescribeDeprecatedTemplate
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response }}'
checks: []
