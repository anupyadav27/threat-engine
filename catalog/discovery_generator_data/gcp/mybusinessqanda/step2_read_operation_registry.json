    "gcp.mybusinessqanda.locations.questions.list": {
      "op": "gcp.mybusinessqanda.locations.questions.list",
      "service": "mybusinessqanda",
      "kind": "read_list",
      "http": {
        "verb": "GET",
        "path": "/v1/{+parent}"
      },
      "python_call": "svc.locations().questions().list(**params).execute()",
      "description": "Returns the paginated list of questions and some of its answers for a specified location. This operation is only valid if the specified location is verified.",
      "inputs": {
        "required": [
          {
            "param": "parent",
            "type": "string",
            "location": "path",
            "template": "{parent}",
            "slots": [
              {
                "slot": "parent",
                "source": "always_available",
                "after_segment": ""
              }
            ],
            "pattern": "^locations/[^/]+/questions$",
            "description": "Required. The name of the location to fetch questions for."
          }
        ],
        "optional": [
          "pageSize",
          "pageToken",
          "answersPerQuestion",
          "filter",
          "orderBy"
        ]
      },
      "outputs": {
        "response_schema": "ListQuestionsResponse",
        "list_field": "questions",
        "id_field": "name",
        "id_is_full_resource_name": true,
        "produces_fields": [
          {
            "path": "questions[].name",
            "type": "string",
            "is_id": true,
            "note": "resource identity \u2014 use as name/parent param for .get()"
          },
          {
            "path": "questions[].author",
            "type": "string",
            "is_id": false
          },
          {
            "path": "questions[].upvoteCount",
            "type": "string",
            "is_id": false
          },
          {
            "path": "questions[].text",
            "type": "string",
            "is_id": false
          },
          {
            "path": "questions[].createTime",
            "type": "string",
            "is_id": false
          },
          {
            "path": "questions[].updateTime",
            "type": "string",
            "is_id": false
          },
          {
            "path": "questions[].topAnswers",
            "type": "string",
            "is_id": false
          },
          {
            "path": "questions[].totalAnswerCount",
            "type": "string",
            "is_id": false
          },
          {
            "path": "totalSize",
            "type": "integer",
            "is_id": false
          }
        ]
      },
      "independent": true,
      "dependency_hints": [
        {
          "param": "parent",
          "can_come_from": [
            {
              "kind": "always_available",
              "param": "parent"
            }
          ]
        }
      ],
      "scopes": [],
      "paginated": true
    },
