                "after_segment": "locations"
              },
              {
                "slot": "keyId",
                "source": "from_list_op",
                "after_segment": "keys"
              }
            ],
            "pattern": "^projects/[^/]+/locations/[^/]+/keys/[^/]+$",
            "description": "Required. The resource name of the API key to be deleted."
