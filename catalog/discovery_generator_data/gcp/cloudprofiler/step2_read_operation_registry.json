{
  "service": "cloudprofiler",
  "version": "v2",
  "csp": "gcp",
  "title": "Cloud Profiler API",
  "base_url": "https://cloudprofiler.googleapis.com/",
  "total_operations": 2,
  "operations": {
    "gcp.cloudprofiler.projects.profiles.list": {
      "op": "gcp.cloudprofiler.projects.profiles.list",
      "service": "cloudprofiler",
      "kind": "read_list",
      "http": {
        "verb": "GET",
        "path": "/v2/{+parent}/profiles"
      },
      "python_call": "svc.projects().profiles().list(**params).execute()",
      "description": "Lists profiles which have been collected so far and for which the caller has permission to view.",
      "inputs": {
        "required": [
          {
            "param": "parent",
            "type": "string",
            "location": "path",
            "template": "{parent}",
            "slots": [
              {
                "slot": "parent",
                "source": "always_available",
                "after_segment": ""
              }
            ],
            "pattern": "^projects/[^/]+$",
            "description": "Required. The parent, which owns this collection of profiles. Format: projects/{user_project_id}"
          }
        ],
        "optional": [
          "pageSize",
          "pageToken"
        ]
      },
      "outputs": {
        "response_schema": "ListProfilesResponse",
        "list_field": "profiles",
        "id_field": "name",
        "id_is_full_resource_name": true,
        "produces_fields": [
          {
            "path": "profiles[].name",
            "type": "string",
            "is_id": true,
            "note": "resource identity \u2014 use as name/parent param for .get()"
          },
          {
            "path": "profiles[].labels",
            "type": "string",
            "is_id": false
          },
          {
            "path": "profiles[].deployment",
            "type": "string",
            "is_id": false
          },
          {
            "path": "profiles[].profileBytes",
            "type": "string",
            "is_id": false
          },
          {
            "path": "profiles[].duration",
            "type": "string",
            "is_id": false
          },
          {
            "path": "profiles[].startTime",
            "type": "string",
            "is_id": false
          },
          {
            "path": "profiles[].profileType",
            "type": "string",
            "is_id": false
          },
          {
            "path": "skippedProfiles",
            "type": "integer",
            "is_id": false
          }
        ]
      },
      "independent": true,
      "dependency_hints": [
        {
          "param": "parent",
          "can_come_from": [
            {
              "kind": "always_available",
              "param": "parent"
            }
          ]
        }
      ],
      "scopes": [
        "https://www.googleapis.com/auth/cloud-platform",
        "https://www.googleapis.com/auth/monitoring",
        "https://www.googleapis.com/auth/monitoring.write"
      ],
      "paginated": true
    },
    "gcp.cloudprofiler.projects.profiles.createOffline": {
      "op": "gcp.cloudprofiler.projects.profiles.createOffline",
      "service": "cloudprofiler",
      "kind": "other",
      "http": {
        "verb": "POST",
        "path": "/v2/{+parent}/profiles:createOffline"
      },
      "python_call": "svc.projects().profiles().createOffline(**params).execute()",
      "description": "CreateOfflineProfile creates a new profile resource in the offline mode. The client provides the profile to create along with the profile bytes, the server records it. _Direct use of this API is disco",
      "inputs": {
        "required": [
          {
            "param": "parent",
            "type": "string",
            "location": "path",
            "template": "{parent}",
            "slots": [
              {
                "slot": "parent",
                "source": "always_available",
                "after_segment": ""
              }
            ],
            "pattern": "^projects/[^/]+$",
            "description": "Parent project to create the profile in."
          }
        ],
        "optional": []
      },
      "outputs": {
        "response_schema": "Profile",
        "list_field": null,
        "id_field": null,
        "id_is_full_resource_name": false,
        "produces_fields": []
      },
      "independent": true,
      "dependency_hints": [
        {
          "param": "parent",
          "can_come_from": [
            {
              "kind": "always_available",
              "param": "parent"
            }
          ]
        }
      ],
      "scopes": [
        "https://www.googleapis.com/auth/cloud-platform",
        "https://www.googleapis.com/auth/monitoring",
        "https://www.googleapis.com/auth/monitoring.write"
      ],
      "paginated": false
    }
  }
}