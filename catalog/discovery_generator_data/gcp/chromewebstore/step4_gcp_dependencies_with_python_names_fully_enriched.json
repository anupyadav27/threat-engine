{
  "chromewebstore": {
    "service": "chromewebstore",
    "csp": "gcp",
    "data_quality": "enriched_from_csv_discovery",
    "total_operations": 2,
    "independent": [],
    "dependent": [
      {
        "operation": "media.upload",
        "resource": "media",
        "source": "csv",
        "path": "v2/publishers/{publishersId}/items/{itemsId}:upload",
        "http_method": "POST",
        "path_params": [
          "name"
        ],
        "description": "Upload a new package to an existing item.",
        "dependent_field": "publishersId;itemsId",
        "resource_identifiers": "+name"
      },
      {
        "operation": "items.fetchStatus",
        "resource": "items",
        "source": "csv",
        "path": "v2/publishers/{publishersId}/items/{itemsId}:fetchStatus",
        "http_method": "GET",
        "path_params": [
          "name"
        ],
        "description": "Fetch the status of an item.",
        "dependent_field": "publishersId;itemsId",
        "resource_identifiers": "+name"
      }
    ]
  }
}