  "operations": {
    "gcp.alertcenter.alerts.delete": {
      "op": "gcp.alertcenter.alerts.delete",
      "service": "alertcenter",
      "kind": "write_delete",
      "http": {
        "verb": "DELETE",
        "path": "/v1beta1/alerts/{alertId}"
      },
      "python_call": "svc.alerts().delete(**params).execute()",
      "description": "Marks the specified alert for deletion. An alert that has been marked for deletion is removed from Alert Center after 30 days. Marking an alert for deletion has no effect on an alert which has already",
      "inputs": {
        "required": [
          {
            "param": "alertId",
            "type": "string",
            "location": "path",
            "template": "{alertId}",
            "slots": [
              {
                "slot": "alertId",
                "source": "from_list_op",
                "after_segment": "alert"
              }
            ],
            "pattern": "",
            "description": "Required. The identifier of the alert to delete."
          }
        ],
        "optional": [
          "customerId"
        ]
      },
      "outputs": {
        "response_schema": "Empty",
        "list_field": null,
        "id_field": null,
        "id_is_full_resource_name": false,
        "produces_fields": []
      },
      "independent": false,
      "dependency_hints": [
        {
          "param": "alertId",
          "can_come_from": [
            {
              "kind": "from_list_op",
              "op": "gcp.alertcenter.alerts.list",
              "match_tier": 2,
              "match_confidence": "suffix_match",
              "list_field": "alerts",
              "id_field": "startTime",
              "produces_slot": "alertId",
              "note": "[tier 2/suffix_match] call gcp.alertcenter.alerts.list, iterate response[\"alerts\"][], extract item[\"startTime\"] \u2192 use as \"alertId\""
            }
          ]
        }
      ],
      "scopes": [
        "https://www.googleapis.com/auth/apps.alerts"
      ],
      "paginated": false
    },
