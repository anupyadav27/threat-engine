{
  "service": "firebasestorage",
  "version": "v1beta",
  "csp": "gcp",
  "title": "Cloud Storage for Firebase API",
  "base_url": "https://firebasestorage.googleapis.com/",
  "total_operations": 2,
  "operations": {
    "gcp.firebasestorage.projects.deleteDefaultBucket": {
      "op": "gcp.firebasestorage.projects.deleteDefaultBucket",
      "service": "firebasestorage",
      "kind": "write_delete",
      "http": {
        "verb": "DELETE",
        "path": "/v1beta/{+name}"
      },
      "python_call": "svc.projects().deleteDefaultBucket(**params).execute()",
      "description": "Unlinks and deletes the default bucket.",
      "inputs": {
        "required": [
          {
            "param": "name",
            "type": "string",
            "location": "path",
            "template": "projects/{project}/defaultBucket",
            "slots": [
              {
                "slot": "project",
                "source": "always_available",
                "after_segment": "projects"
              }
            ],
            "pattern": "^projects/[^/]+/defaultBucket$",
            "description": "Required. The name of the default bucket to delete, `projects/{project_id_or_number}/defaultBucket`."
          }
        ],
        "optional": []
      },
      "outputs": {
        "response_schema": "Empty",
        "list_field": null,
        "id_field": null,
        "id_is_full_resource_name": false,
        "produces_fields": []
      },
      "independent": true,
      "dependency_hints": [
        {
          "param": "name",
          "can_come_from": [
            {
              "kind": "known_format",
              "template": "projects/{project}/defaultBucket",
              "slots": [
                {
                  "slot": "project",
                  "source": "always_available",
                  "after_segment": "projects"
                }
              ]
            }
          ]
        }
      ],
      "scopes": [
        "https://www.googleapis.com/auth/cloud-platform",
        "https://www.googleapis.com/auth/firebase"
      ],
      "paginated": false
    },
    "gcp.firebasestorage.projects.defaultBucket.create": {
      "op": "gcp.firebasestorage.projects.defaultBucket.create",
      "service": "firebasestorage",
      "kind": "write_create",
      "http": {
        "verb": "POST",
        "path": "/v1beta/{+parent}/defaultBucket"
      },
      "python_call": "svc.projects().defaultBucket().create(**params).execute()",
      "description": "Creates a Spark tier-eligible Cloud Storage bucket and links it to your Firebase project. If the default bucket already exists, this method will re-link it to your Firebase project. See https://fireba",
      "inputs": {
        "required": [
          {
            "param": "parent",
            "type": "string",
            "location": "path",
            "template": "{parent}",
            "slots": [
              {
                "slot": "parent",
                "source": "always_available",
                "after_segment": ""
              }
            ],
            "pattern": "^projects/[^/]+$",
            "description": "Required. The parent resource where the default bucket will be created, `projects/{project_id_or_number}`."
          }
        ],
        "optional": []
      },
      "outputs": {
        "response_schema": "DefaultBucket",
        "list_field": null,
        "id_field": null,
        "id_is_full_resource_name": false,
        "produces_fields": []
      },
      "independent": true,
      "dependency_hints": [
        {
          "param": "parent",
          "can_come_from": [
            {
              "kind": "always_available",
              "param": "parent"
            }
          ]
        }
      ],
      "scopes": [
        "https://www.googleapis.com/auth/cloud-platform",
        "https://www.googleapis.com/auth/firebase"
      ],
      "paginated": false
    }
