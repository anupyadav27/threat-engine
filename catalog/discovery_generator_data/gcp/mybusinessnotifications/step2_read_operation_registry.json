                "source": "always_available",
                "after_segment": "accounts"
              }
            ],
            "pattern": "^accounts/[^/]+/notificationSetting$",
            "description": "Required. The resource name of the notification setting we are trying to fetch."
          }
        ],
        "optional": []
      },
      "outputs": {
        "response_schema": "NotificationSetting",
        "list_field": null,
        "id_field": null,
        "id_is_full_resource_name": false,
