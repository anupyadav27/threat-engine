  "edge_types": [
    {
      "type": "ALLOWS",
      "category": "networking",
      "direction": "security_rule -> target_resource",
      "description": "A firewall rule or policy allows traffic to/from the target.",
      "gcp_examples": [
        {
          "from": "network.firewall",
          "to": "compute.instance",
          "example": "firewallRule ALLOWS ingress to instance (via targetTag)"
        },
        {
          "from": "security.securityPolicy",
          "to": "network.loadBalancer",
          "example": "armorPolicy ALLOWS traffic to backendService"
        },
        {
          "from": "access.servicePerimeter",
          "to": "governance.project",
          "example": "servicePerimeter ALLOWS access to project APIs"
        }
      ]
    },
    {
      "type": "ASSUMES",
      "category": "identity",
      "direction": "workload -> serviceAccount",
      "description": "The source workload or identity assumes / impersonates the target service account.",
      "gcp_examples": [
        {
          "from": "compute.instance",
          "to": "identity.serviceAccount",
          "example": "instance ASSUMES serviceAccount (attached SA)"
        },
        {
          "from": "run.service",
          "to": "identity.serviceAccount",
          "example": "cloudRunService ASSUMES serviceAccount (runtime SA)"
        },
        {
          "from": "iam.workloadIdentityPool",
          "to": "identity.serviceAccount",
          "example": "externalIdentity via workloadIdentityPool ASSUMES serviceAccount"
        }
      ]
    },
    {
      "type": "ATTACHED_TO",
      "category": "attachment",
      "direction": "source -> target",
      "description": "The source resource is attached or bound to the target at the infrastructure level.",
      "gcp_examples": [
        {
          "from": "compute.disk",
          "to": "compute.instance",
          "example": "disk ATTACHED_TO instance"
        },
        {
          "from": "compute.address",
          "to": "compute.forwardingRule",
          "example": "staticIP ATTACHED_TO forwardingRule"
        },
        {
          "from": "cert.certificate",
          "to": "network.loadBalancer",
          "example": "sslCert ATTACHED_TO targetHttpsProxy"
        }
      ]
    },
    {
      "type": "BOUND_TO",
      "category": "identity",
      "direction": "policy -> resource",
      "description": "An IAM policy or binding is bound to a GCP resource.",
      "gcp_examples": [
        {
          "from": "access.policy",
          "to": "governance.project",
          "example": "iamPolicy BOUND_TO project"
        },
        {
          "from": "access.policy",
          "to": "storage.bucket",
          "example": "iamPolicy BOUND_TO bucket"
        },
        {
          "from": "orgpolicy.policy",
          "to": "governance.organization",
          "example": "orgPolicy BOUND_TO organization node"
        }
      ]
    },
    {
      "type": "CHILD_OF",
      "category": "hierarchy",
      "direction": "child -> parent",
      "description": "The source is a direct child of the target in the GCP resource hierarchy.",
      "gcp_examples": [
        {
          "from": "governance.project",
          "to": "governance.folder",
          "example": "project CHILD_OF folder"
        },
        {
          "from": "governance.folder",
          "to": "governance.organization",
          "example": "folder CHILD_OF organization"
        },
        {
          "from": "compute.disk",
          "to": "compute.instance",
          "example": "disk CHILD_OF instance (boot disk)"
        }
      ]
    },
    {
      "type": "CONNECTS_TO",
      "category": "networking",
      "direction": "source -> target",
      "description": "The source resource establishes a network connection to the target.",
      "gcp_examples": [
        {
          "from": "network.vpn",
          "to": "network.hub",
          "example": "vpnTunnel CONNECTS_TO networkConnectivityHub"
        },
        {
          "from": "network.interconnect",
          "to": "network.vpc",
          "example": "interconnectAttachment CONNECTS_TO VPC network"
        },
        {
          "from": "vpcaccess.connector",
          "to": "network.vpc",
          "example": "vpcConnector CONNECTS_TO VPC network"
        }
      ]
    },
    {
      "type": "CONTAINS",
      "category": "hierarchy",
      "direction": "parent -> child",
      "description": "The source resource logically contains the target (inverse of CHILD_OF).",
      "gcp_examples": [
        {
          "from": "governance.organization",
          "to": "governance.folder",
          "example": "organization CONTAINS folder"
        },
        {
          "from": "cloudkms.keyRing",
          "to": "crypto.kmsKey",
          "example": "keyRing CONTAINS cryptoKey"
        },
        {
          "from": "k8s.cluster",
          "to": "k8s.nodePool",
          "example": "cluster CONTAINS nodePool"
        }
      ]
    },
    {
      "type": "ENCRYPTED_BY",
      "category": "crypto",
      "direction": "resource -> key",
      "description": "The source resource's data is encrypted using the target KMS key.",
      "gcp_examples": [
        {
          "from": "storage.bucket",
          "to": "crypto.kmsKey",
          "example": "bucket ENCRYPTED_BY cloudKMSKey (CMEK)"
        },
        {
          "from": "compute.disk",
          "to": "crypto.kmsKey",
          "example": "persistentDisk ENCRYPTED_BY kmsKeyName"
        },
        {
          "from": "bigquery.dataset",
          "to": "crypto.kmsKey",
          "example": "bigqueryDataset ENCRYPTED_BY kmsKey (defaultEncryptionConfiguration)"
        }
      ]
    },
    {
      "type": "EXPOSES",
      "category": "networking",
      "direction": "source -> target",
      "description": "The source resource exposes the target service or port to a network.",
      "gcp_examples": [
        {
          "from": "network.loadBalancer",
          "to": "app.cloudRunService",
          "example": "forwardingRule EXPOSES cloudRunService"
        },
        {
          "from": "compute.instance",
          "to": "network.endpoint",
          "example": "instance EXPOSES networkEndpoint"
        },
        {
          "from": "apigateway.gateway",
          "to": "app.apiConfig",
          "example": "gateway EXPOSES apiConfig"
        }
      ]
    },
    {
      "type": "GRANTS",
      "category": "access",
      "direction": "binding -> (member, role)",
      "description": "An IAM binding grants a role to a member on a resource.",
      "gcp_examples": [
        {
          "from": "access.policy",
          "to": "access.role",
          "example": "iamBinding GRANTS roles/storage.admin to serviceAccount"
        },
        {
          "from": "access.policy",
          "to": "identity.serviceAccount",
          "example": "iamPolicy GRANTS editor role to user@example.com"
        },
        {
          "from": "iam.workloadIdentityPool",
          "to": "access.role",
          "example": "workloadIdentityPool GRANTS roles/iam.workloadIdentityUser"
        }
      ]
    },
    {
      "type": "ISSUED_BY",
      "category": "cert",
      "direction": "certificate -> authority",
      "description": "The source certificate was issued by the target certificate authority.",
      "gcp_examples": [
        {
          "from": "cert.certificate",
          "to": "cert.certificateAuthority",
          "example": "privateCACert ISSUED_BY certificateAuthority"
        },
        {
          "from": "cert.certificate",
          "to": "privateca.caPool",
          "example": "certificate ISSUED_BY caPool"
        }
      ]
    },
    {
      "type": "MEMBER_OF",
      "category": "identity",
      "direction": "member -> group_or_policy",
      "description": "The source identity is a member of the target group or policy binding.",
      "gcp_examples": [
        {
          "from": "identity.user",
          "to": "identity.group",
          "example": "user MEMBER_OF cloudIdentityGroup"
        },
        {
          "from": "identity.serviceAccount",
          "to": "identity.group",
          "example": "serviceAccount MEMBER_OF group (IAM binding)"
        },
        {
          "from": "k8s.cluster",
          "to": "k8s.hubMembership",
          "example": "cluster MEMBER_OF gkeHubFleet"
        }
      ]
    },
    {
      "type": "REFERENCES",
      "category": "reference",
      "direction": "source -> target",
      "description": "The source resource references the target by name or ID without a strong dependency.",
      "gcp_examples": [
        {
          "from": "compute.instance",
          "to": "compute.image",
          "example": "instance REFERENCES sourceImage"
        },
        {
          "from": "compute.instanceTemplate",
          "to": "compute.disk",
          "example": "instanceTemplate REFERENCES diskType"
        },
        {
          "from": "monitoring.alertPolicy",
          "to": "monitoring.notificationChannel",
          "example": "alertPolicy REFERENCES notificationChannelName"
        }
      ]
    },
    {
      "type": "ROUTES_TO",
      "category": "networking",
      "direction": "source -> target",
      "description": "The source routes traffic to the target destination.",
      "gcp_examples": [
        {
          "from": "network.route",
          "to": "network.vpc",
          "example": "route ROUTES_TO nextHopGateway"
        },
        {
          "from": "network.loadBalancer",
          "to": "compute.instanceGroup",
          "example": "backendService ROUTES_TO instanceGroup"
        },
        {
          "from": "compute.router",
          "to": "network.vpn",
          "example": "cloudRouter ROUTES_TO vpnTunnel via BGP"
        }
      ]
    },
    {
      "type": "TRUSTS",
      "category": "cert",
      "direction": "resource -> authority_or_pool",
      "description": "The source resource trusts certificates from the target authority or pool.",
      "gcp_examples": [
        {
          "from": "k8s.cluster",
          "to": "cert.certificateAuthority",
          "example": "gkeCluster TRUSTS privateCertificateAuthority"
        },
        {
          "from": "iam.workloadIdentityPool",
          "to": "identity.oauthClient",
          "example": "workloadIdentityPool TRUSTS external OIDC issuer"
        }
      ]
    },
    {
      "type": "USES",
      "category": "reference",
      "direction": "source -> target",
      "description": "The source resource actively uses the target as a dependency (stronger than REFERENCES).",
      "gcp_examples": [
        {
          "from": "run.service",
          "to": "iam.serviceAccount",
          "example": "cloudRunService USES serviceAccount (as runtime identity)"
        },
        {
          "from": "compute.instance",
          "to": "compute.machineType",
          "example": "instance USES machineType"
        },
        {
          "from": "composer.environment",
          "to": "storage.bucket",
          "example": "composerEnvironment USES GCS bucket for DAGs"
        }
      ]
    },
    {
      "type": "USES_CERT",
      "category": "cert",
      "direction": "resource -> certificate",
      "description": "The source resource uses a TLS/SSL certificate for serving or authentication.",
      "gcp_examples": [
        {
          "from": "network.loadBalancer",
          "to": "cert.certificate",
          "example": "targetHttpsProxy USES_CERT sslCertificate"
        },
        {
          "from": "compute.instance",
          "to": "cert.certificate",
          "example": "managedSSLCert USES_CERT on loadBalancer frontend"
        },
        {
          "from": "cert.certificateMap",
          "to": "cert.certificate",
          "example": "certificateMapEntry USES_CERT certificate"
        }
      ]
    },
    {
      "type": "USES_KEY",
      "category": "crypto",
      "direction": "resource -> key_or_version",
