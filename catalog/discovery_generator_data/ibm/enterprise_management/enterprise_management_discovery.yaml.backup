version: '1.0'
provider: ibm
service: enterprise_management
services:
  client: enterprise_management
discovery:
- discovery_id: ibm.enterprise_management.list_account_groups
  calls:
  - action: list_account_groups
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
- discovery_id: ibm.enterprise_management.list_accounts
  calls:
  - action: list_accounts
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
- discovery_id: ibm.enterprise_management.list_enterprises
  calls:
  - action: list_enterprises
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
checks: []
