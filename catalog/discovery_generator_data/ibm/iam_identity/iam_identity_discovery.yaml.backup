version: '1.0'
provider: ibm
service: iam_identity
services:
  client: iam_identity
discovery:
- discovery_id: ibm.iam_identity.list_account_settings_assignments
  calls:
  - action: list_account_settings_assignments
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
- discovery_id: ibm.iam_identity.list_account_settings_templates
  calls:
  - action: list_account_settings_templates
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
- discovery_id: ibm.iam_identity.list_api_keys
  calls:
  - action: list_api_keys
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
- discovery_id: ibm.iam_identity.list_profile_templates
  calls:
  - action: list_profile_templates
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
- discovery_id: ibm.iam_identity.list_service_id_group
  calls:
  - action: list_service_id_group
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
checks: []
