version: '1.0'
provider: ibm
service: catalog_management
services:
  client: catalog_management
discovery:
- discovery_id: ibm.catalog_management.list_catalogs
  calls:
  - action: list_catalogs
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
checks: []
