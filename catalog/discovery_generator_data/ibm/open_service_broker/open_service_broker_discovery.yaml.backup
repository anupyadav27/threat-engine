version: '1.0'
provider: ibm
service: open_service_broker
services:
  client: open_service_broker
discovery:
- discovery_id: ibm.open_service_broker.list_catalog
  calls:
  - action: list_catalog
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
checks: []
