version: '1.0'
provider: ibm
service: resource_controller
services:
  client: resource_controller
discovery:
- discovery_id: ibm.resource_controller.list_reclamations
  calls:
  - action: list_reclamations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
- discovery_id: ibm.resource_controller.list_resource_aliases
  calls:
  - action: list_resource_aliases
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
- discovery_id: ibm.resource_controller.list_resource_bindings
  calls:
  - action: list_resource_bindings
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
- discovery_id: ibm.resource_controller.list_resource_instances
  calls:
  - action: list_resource_instances
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
- discovery_id: ibm.resource_controller.list_resource_keys
  calls:
  - action: list_resource_keys
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
checks: []
