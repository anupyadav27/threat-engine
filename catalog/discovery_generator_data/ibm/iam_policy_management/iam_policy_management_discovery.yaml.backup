version: '1.0'
provider: ibm
service: iam_policy_management
services:
  client: iam_policy_management
discovery:
- discovery_id: ibm.iam_policy_management.list_roles
  calls:
  - action: list_roles
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
checks: []
