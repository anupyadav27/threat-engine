version: '1.0'
provider: ibm
service: context_based_restrictions
services:
  client: context_based_restrictions
discovery:
- discovery_id: ibm.context_based_restrictions.list_available_service_operations
  calls:
  - action: list_available_service_operations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
- discovery_id: ibm.context_based_restrictions.list_available_serviceref_targets
  calls:
  - action: list_available_serviceref_targets
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
checks: []
