version: '1.0'
provider: ibm
service: schematics
services:
  client: schematics
discovery:
- discovery_id: ibm.schematics.list_actions
  calls:
  - action: list_actions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
- discovery_id: ibm.schematics.list_inventories
  calls:
  - action: list_inventories
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
- discovery_id: ibm.schematics.list_jobs
  calls:
  - action: list_jobs
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
- discovery_id: ibm.schematics.list_locations
  calls:
  - action: list_locations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
- discovery_id: ibm.schematics.list_resource_group
  calls:
  - action: list_resource_group
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
checks: []
