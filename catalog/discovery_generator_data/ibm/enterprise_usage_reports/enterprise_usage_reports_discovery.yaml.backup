version: '1.0'
provider: ibm
service: enterprise_usage_reports
services:
  client: enterprise_usage_reports
  module: EnterpriseUsageReportsV1
discovery:
- discovery_id: ibm.enterprise_usage_reports.get-resource-usage-report
  calls:
  - action: get-resource-usage-report
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.item }}'
- discovery_id: ibm.enterprise_usage_reports.get-http-client
  calls:
  - action: get-http-client
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.item }}'
- discovery_id: ibm.enterprise_usage_reports.get-authenticator
  calls:
  - action: get-authenticator
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.item }}'
- discovery_id: ibm.enterprise_usage_reports.get-enable-gzip-compression
  calls:
  - action: get-enable-gzip-compression
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.item }}'
checks: []
