      "note": "for_each=azure.chaos.experiments.list_all, param={{ item.id }}"
    },
    "location": {
      "entity": "azure.location",
      "emit_field": "location",
      "producing_op": "__from_parent__",
      "discovery_id": "__from_parent__",
      "items_path": "item.location",
      "note": "From parent ARM resource: {{ item.location }}"
    }
