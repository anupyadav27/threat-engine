      "type": "string"
    },
    "PrincipalId": {
      "operators": [
        "equals",
        "not_equals",
        "contains"
      ],
      "dependency_index_entity": "chaos.item_identity",
      "type": "string"
    }
  },
  "param_source_map": {
    "parent_resource_name": {
      "entity": "chaos.parent_resource__name",
      "emit_field": "name",
      "producing_op": "azure.chaos.targets.list",
      "discovery_id": "azure.chaos.targets.list",
      "category": "targets",
      "method": "list",
      "items_path": "response.value",
      "note": "for_each=azure.chaos.targets.list, param={{ item.name }}"
    },
    "experiment_name": {
      "entity": "chaos.experiment__name",
      "emit_field": "name",
      "producing_op": "azure.chaos.experiments.list_all",
      "discovery_id": "azure.chaos.experiments.list_all",
      "category": "experiments",
      "method": "list_all",
      "items_path": "response.value",
      "note": "for_each=azure.chaos.experiments.list_all, param={{ item.name }}"
    },
    "execution_id": {
      "entity": "chaos.execution__id",
