  "fields": {
    "Enabled": {
      "operators": [
        "equals",
        "not_equals"
      ],
      "dependency_index_entity": "chaos.item_runtime_properties",
      "type": "boolean"
    },
    "Status": {
      "operators": [
        "equals",
        "not_equals",
        "in"
      ],
      "dependency_index_entity": "chaos.item_runtime_properties",
      "type": "string"
    },
    "Type": {
      "operators": [
        "equals",
        "not_equals",
