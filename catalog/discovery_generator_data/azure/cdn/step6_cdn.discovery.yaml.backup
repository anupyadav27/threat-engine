version: '1.0'
provider: azure
service: cdn
services:
  client: cdn
  module: azure.mgmt.cdn
discovery:
- discovery_id: azure.cdn.cdnmanagementclientmixin.check_endpoint_name_availability
  calls:
  - action: check_endpoint_name_availability
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.name_available }}'
- discovery_id: azure.cdn.policies.list
  calls:
  - action: list
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.cdn.profiles.list_by_resource_group
  calls:
  - action: list_by_resource_group
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.cdn.profiles.list_by_resource_group
  calls:
  - action: list_by_resource_group
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.cdn.managedrulesets.list
  calls:
  - action: list
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.cdn.edgenodes.list
  calls:
  - action: list
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.cdn.edgenodes.list
  calls:
  - action: list
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.cdn.profiles.begin_can_migrate
  calls:
  - action: begin_can_migrate
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.cdn.resourceusage.list
  calls:
  - action: list
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.cdn.profiles.begin_migrate
  calls:
  - action: begin_migrate
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.cdn.cdnmanagementclientmixin.validate_probe
  calls:
  - action: validate_probe
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.is_valid }}'
checks: []
