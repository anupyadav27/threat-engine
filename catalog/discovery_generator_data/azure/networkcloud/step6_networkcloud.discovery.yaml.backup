version: '1.0'
provider: azure
service: networkcloud
services:
  client: networkcloud
discovery:
- discovery_id: azure.networkcloud.list_by_kubernetes_cluster
  calls:
  - action: list_by_kubernetes_cluster
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.networkcloud.list_by_cluster
  calls:
  - action: list_by_cluster
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.networkcloud.list_by_resource_group
  calls:
  - action: list_by_resource_group
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.networkcloud.list_by_subscription
  calls:
  - action: list_by_subscription
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.networkcloud.list_by_cluster
  calls:
  - action: list_by_cluster
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
checks: []
