version: '1.0'
provider: azure
service: securityinsight
services:
  client: securityinsight
discovery:
- discovery_id: azure.securityinsight.list
  calls:
  - action: list
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.securityinsight.list
  calls:
  - action: list
    save_as: response
    on_error: continue
