    "location",
    "name",
    "origin",
    "properties",
    "secrets",
    "sku",
    "system_data",
    "tags",
    "type"
  ],
  "source": {
    "operation_registry": "services/healthbot/operation_registry.json",
    "read_ops_rule": "kind is read_list (seed) or read_get (enriched)",
    "excluded_keys": [
      "next_link",
      "nextLink",
      "continuation_token",
      "value",
      "skip_token",
      "max_results",
      "top",
      "skip"
    ]
  },
  "fields": {
    "Name": {
      "operators": [
        "equals",
        "not_equals",
        "in"
      ],
      "dependency_index_entity": "healthbot.item_sku",
      "type": "string"
    },
    "Tier": {
      "operators": [
        "equals",
        "not_equals",
        "in"
      ],
      "dependency_index_entity": "healthbot.item_sku",
      "type": "string"
    },
    "Type": {
      "operators": [
        "equals",
        "not_equals",
        "in"
      ],
      "dependency_index_entity": "healthbot.item_identity",
      "type": "string"
    },
    "PrincipalId": {
      "operators": [
        "equals",
        "not_equals",
        "contains"
      ],
      "dependency_index_entity": "healthbot.item_identity",
      "type": "string"
    },
    "Enabled": {
      "operators": [
        "equals",
        "not_equals"
      ],
      "dependency_index_entity": "healthbot.item_properties",
      "type": "boolean"
    },
    "Status": {
      "operators": [
        "equals",
        "not_equals",
        "in"
      ],
      "dependency_index_entity": "healthbot.item_properties",
      "type": "string"
    },
    "access_control_method": {
      "operators": [
        "equals",
        "not_equals",
        "exists",
        "not_empty"
      ],
      "type": "object",
      "enriched_from": "check_var_alignment",
      "source": "check_derived"
    },
    "key_vault_properties": {
      "operators": [
        "equals",
        "not_equals",
        "exists",
        "not_empty"
      ],
      "type": "object",
      "enriched_from": "check_var_alignment",
      "source": "check_derived"
    }
  },
  "param_source_map": {
    "bot_name": {
      "entity": "healthbot.bot__name",
      "emit_field": "name",
      "producing_op": "azure.healthbot.bots.list",
      "discovery_id": "azure.healthbot.bots.list",
      "category": "bots",
      "method": "list",
      "items_path": "response.value",
      "note": "for_each=azure.healthbot.bots.list, param={{ item.name }}"
    }
