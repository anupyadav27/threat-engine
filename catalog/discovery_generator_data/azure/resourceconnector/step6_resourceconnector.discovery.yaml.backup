version: '1.0'
provider: azure
service: resourceconnector
services:
  client: resourceconnector
  module: azure.mgmt.resourceconnector
discovery:
- discovery_id: azure.resourceconnector.appliances.list_by_resource_group
  calls:
  - action: list_by_resource_group
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.resourceconnector.appliances.list_by_subscription
  calls:
  - action: list_by_subscription
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.resourceconnector.appliances.list_operations
  calls:
  - action: list_operations
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.resourceconnector.appliances.get_telemetry_config
  calls:
  - action: get_telemetry_config
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.telemetry_instrumentation_key }}'
checks: []
