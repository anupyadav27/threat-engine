version: '1.0'
provider: azure
service: logz
services:
  client: logz
discovery:
- discovery_id: azure.logz.list_vm_host_update
  calls:
  - action: list_vm_host_update
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.logz.list_vm_hosts
  calls:
  - action: list_vm_hosts
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.logz.list_by_resource_group
  calls:
  - action: list_by_resource_group
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.logz.list_by_subscription
  calls:
  - action: list_by_subscription
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.logz.list_monitored_resources
  calls:
  - action: list_monitored_resources
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
checks: []
