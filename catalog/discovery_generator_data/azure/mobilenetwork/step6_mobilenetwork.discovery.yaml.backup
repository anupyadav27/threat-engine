version: '1.0'
provider: azure
service: mobilenetwork
services:
  client: mobilenetwork
discovery:
- discovery_id: azure.mobilenetwork.list_by_mobile_network
  calls:
  - action: list_by_mobile_network
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.mobilenetwork.list_by_packet_core_control_plane
  calls:
  - action: list_by_packet_core_control_plane
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.mobilenetwork.list_by_resource_group
  calls:
  - action: list_by_resource_group
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.mobilenetwork.list_by_subscription
  calls:
  - action: list_by_subscription
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.mobilenetwork.list_sim_groups
  calls:
  - action: list_sim_groups
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
checks: []
