version: '1.0'
provider: azure
service: authorization
services:
  client: authorization
discovery:
- discovery_id: azure.authorization.list_for_resource_group
  calls:
  - action: list_for_resource_group
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.authorization.list
  calls:
  - action: list
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.authorization.list
  calls:
  - action: list
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.authorization.list_for_resource_group
  calls:
  - action: list_for_resource_group
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.authorization.list_for_scope
  calls:
  - action: list_for_scope
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
checks: []
