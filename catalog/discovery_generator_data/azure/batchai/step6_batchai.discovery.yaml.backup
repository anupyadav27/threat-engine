version: '1.0'
provider: azure
service: batchai
services:
  client: batchai
discovery:
- discovery_id: azure.batchai.list_by_workspace
  calls:
  - action: list_by_workspace
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.batchai.list_by_workspace
  calls:
  - action: list_by_workspace
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.batchai.list_by_workspace
  calls:
  - action: list_by_workspace
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.batchai.list
  calls:
  - action: list
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.batchai.list
  calls:
  - action: list
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
checks: []
