version: '1.0'
provider: azure
service: hybridnetwork
services:
  client: hybridnetwork
discovery:
- discovery_id: azure.hybridnetwork.list_by_publisher
  calls:
  - action: list_by_publisher
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.hybridnetwork.list_by_network_function
  calls:
  - action: list_by_network_function
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.hybridnetwork.list_by_publisher
  calls:
  - action: list_by_publisher
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.hybridnetwork.list_by_resource_group
  calls:
  - action: list_by_resource_group
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.hybridnetwork.list_by_subscription
  calls:
  - action: list_by_subscription
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
checks: []
