version: '1.0'
provider: azure
service: hdinsightcontainers
services:
  client: hdinsightcontainers
discovery:
- discovery_id: azure.hdinsightcontainers.list_by_location
  calls:
  - action: list_by_location
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.hdinsightcontainers.list_by_location
  calls:
  - action: list_by_location
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.hdinsightcontainers.list
  calls:
  - action: list
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.hdinsightcontainers.list
  calls:
  - action: list
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.hdinsightcontainers.list_by_resource_group
  calls:
  - action: list_by_resource_group
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
checks: []
