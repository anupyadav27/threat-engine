version: '1.0'
provider: azure
service: healthcareapis
services:
  client: healthcareapis
discovery:
- discovery_id: azure.healthcareapis.list_by_workspace
  calls:
  - action: list_by_workspace
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.healthcareapis.list_by_workspace
  calls:
  - action: list_by_workspace
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.healthcareapis.list_by_workspace
  calls:
  - action: list_by_workspace
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.healthcareapis.list
  calls:
  - action: list
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.healthcareapis.list_by_service
  calls:
  - action: list_by_service
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
checks: []
