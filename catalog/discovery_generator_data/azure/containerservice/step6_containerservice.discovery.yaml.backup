version: '1.0'
provider: azure
service: containerservice
services:
  client: containerservice
  module: azure.mgmt.containerservice
discovery:
- discovery_id: azure.containerservice.managedclusters.list
  calls:
  - action: list
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.containerservice.managedclusters.list_by_resource_group
  calls:
  - action: list_by_resource_group
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.containerservice.snapshots.list_by_resource_group
  calls:
  - action: list_by_resource_group
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.containerservice.agentpools.list
  calls:
  - action: list
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.containerservice.managedclusters.list_mesh_revision_profiles
  calls:
  - action: list_mesh_revision_profiles
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.containerservice.trustedaccessroles.list
  calls:
  - action: list
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.containerservice.managedclusters.get_mesh_revision_profile
  calls:
  - action: get_mesh_revision_profile
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.id }}'
- discovery_id: azure.containerservice.managedclusters.list_kubernetes_versions
  calls:
  - action: list_kubernetes_versions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.values }}'
checks: []
