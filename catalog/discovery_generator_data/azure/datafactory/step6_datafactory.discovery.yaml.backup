version: '1.0'
provider: azure
service: datafactory
services:
  client: datafactory
discovery:
- discovery_id: azure.datafactory.list_by_factory
  calls:
  - action: list_by_factory
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.datafactory.list_by_factory
  calls:
  - action: list_by_factory
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.datafactory.list_by_factory
  calls:
  - action: list_by_factory
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.datafactory.list_by_factory
  calls:
  - action: list_by_factory
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.datafactory.list
  calls:
  - action: list
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
checks: []
