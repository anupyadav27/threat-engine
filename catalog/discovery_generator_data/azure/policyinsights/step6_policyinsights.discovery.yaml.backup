version: '1.0'
provider: azure
service: policyinsights
services:
  client: policyinsights
discovery:
- discovery_id: azure.policyinsights.list
  calls:
  - action: list
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.policyinsights.list_query_results_for_management_group
  calls:
  - action: list_query_results_for_management_group
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.policyinsights.list_query_results_for_policy_definition
  calls:
  - action: list_query_results_for_policy_definition
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.policyinsights.list_query_results_for_policy_set_definition
  calls:
  - action: list_query_results_for_policy_set_definition
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.policyinsights.list_query_results_for_resource
  calls:
  - action: list_query_results_for_resource
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
checks: []
