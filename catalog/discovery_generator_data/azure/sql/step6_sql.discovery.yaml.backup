version: '1.0'
provider: azure
service: sql
services:
  client: sql
  module: azure.mgmt.sql
discovery:
- discovery_id: azure.sql.servers.check_name_availability
  calls:
  - action: check_name_availability
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.name }}'
- discovery_id: azure.sql.instancepools.list_by_resource_group
  calls:
  - action: list_by_resource_group
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
checks: []
