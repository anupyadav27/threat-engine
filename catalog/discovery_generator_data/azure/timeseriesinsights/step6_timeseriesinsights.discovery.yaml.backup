version: '1.0'
provider: azure
service: timeseriesinsights
services:
  client: timeseriesinsights
discovery:
- discovery_id: azure.timeseriesinsights.list_by_environment
  calls:
  - action: list_by_environment
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.timeseriesinsights.list_by_resource_group
  calls:
  - action: list_by_resource_group
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.timeseriesinsights.list_by_subscription
  calls:
  - action: list_by_subscription
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.timeseriesinsights.list_by_environment
  calls:
  - action: list_by_environment
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.timeseriesinsights.list
  calls:
  - action: list
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
checks: []
