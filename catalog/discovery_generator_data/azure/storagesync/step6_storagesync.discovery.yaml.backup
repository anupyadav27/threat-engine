version: '1.0'
provider: azure
service: storagesync
services:
  client: storagesync
discovery:
- discovery_id: azure.storagesync.list
  calls:
  - action: list
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.storagesync.list_by_storage_sync_service
  calls:
  - action: list_by_storage_sync_service
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.storagesync.list_by_storage_sync_service
  calls:
  - action: list_by_storage_sync_service
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.storagesync.list_by_storage_sync_service
  calls:
  - action: list_by_storage_sync_service
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.storagesync.list_by_resource_group
  calls:
  - action: list_by_resource_group
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
checks: []
