version: '1.0'
provider: azure
service: paloaltonetworksngfw
services:
  client: paloaltonetworksngfw
  module: azure.mgmt.paloaltonetworksngfw
discovery:
- discovery_id: azure.paloaltonetworksngfw.firewalls.list_by_resource_group
  calls:
  - action: list_by_resource_group
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.paloaltonetworksngfw.firewalls.list_by_subscription
  calls:
  - action: list_by_subscription
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.paloaltonetworksngfw.localrulestacks.list_by_subscription
  calls:
  - action: list_by_subscription
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.paloaltonetworksngfw.globalrulestack.list
  calls:
  - action: list
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.paloaltonetworksngfw.paloaltonetworkscloudngfw.list_support_info
  calls:
  - action: list_support_info
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.product_sku }}'
- discovery_id: azure.paloaltonetworksngfw.certificateobjectglobalrulestack.list
  calls:
  - action: list
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.paloaltonetworksngfw.paloaltonetworkscloudngfw.list_product_serial_number_status
  calls:
  - action: list_product_serial_number_status
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.serial_number }}'
checks: []
