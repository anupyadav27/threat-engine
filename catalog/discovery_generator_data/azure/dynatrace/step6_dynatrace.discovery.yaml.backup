version: '1.0'
provider: azure
service: dynatrace
services:
  client: dynatrace
discovery:
- discovery_id: azure.dynatrace.list_app_services
  calls:
  - action: list_app_services
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.dynatrace.list_by_resource_group
  calls:
  - action: list_by_resource_group
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.dynatrace.list_by_subscription_id
  calls:
  - action: list_by_subscription_id
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.dynatrace.list_hosts
  calls:
  - action: list_hosts
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.dynatrace.list_monitored_resources
  calls:
  - action: list_monitored_resources
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
checks: []
