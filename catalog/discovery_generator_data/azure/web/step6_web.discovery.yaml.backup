version: '1.0'
provider: azure
service: web
services:
  client: web
  module: azure.mgmt.web
discovery:
- discovery_id: azure.web.appservicecertificateorders.list
  calls:
  - action: list
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
