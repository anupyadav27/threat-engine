version: '1.0'
provider: azure
service: recoveryservicesbackup
services:
  client: recoveryservicesbackup
discovery:
- discovery_id: azure.recoveryservicesbackup.list
  calls:
  - action: list
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
