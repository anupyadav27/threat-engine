version: '1.0'
provider: azure
service: imagebuilder
services:
  client: imagebuilder
discovery:
- discovery_id: azure.imagebuilder.list
  calls:
  - action: list
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.imagebuilder.list_by_image_template
  calls:
  - action: list_by_image_template
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.imagebuilder.list
  calls:
  - action: list
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.imagebuilder.list_by_resource_group
  calls:
  - action: list_by_resource_group
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.imagebuilder.list_run_outputs
  calls:
  - action: list_run_outputs
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
checks: []
