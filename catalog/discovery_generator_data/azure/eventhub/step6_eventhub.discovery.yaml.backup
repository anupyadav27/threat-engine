version: '1.0'
provider: azure
service: eventhub
services:
  client: eventhub
discovery:
- discovery_id: azure.eventhub.list_available_cluster_region
  calls:
  - action: list_available_cluster_region
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.eventhub.list_by_resource_group
  calls:
  - action: list_by_resource_group
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.eventhub.list_namespaces
  calls:
  - action: list_namespaces
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.eventhub.list
  calls:
  - action: list
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.eventhub.list_by_namespace
  calls:
  - action: list_by_namespace
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
checks: []
