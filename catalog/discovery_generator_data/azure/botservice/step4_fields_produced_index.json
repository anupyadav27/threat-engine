  "fields": {
    "Name": {
      "operators": [
        "equals",
        "not_equals",
        "in"
      ],
      "dependency_index_entity": "botservice.item_sku",
      "type": "string"
    },
    "Tier": {
      "operators": [
        "equals",
        "not_equals",
