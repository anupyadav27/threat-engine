version: '1.0'
provider: azure
service: logic
services:
  client: logic
  module: azure.mgmt.logic
discovery:
- discovery_id: azure.logic.integrationaccounts.list_by_resource_group
  calls:
  - action: list_by_resource_group
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
checks: []
