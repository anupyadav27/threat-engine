version: '1.0'
provider: azure
service: managednetworkfabric
services:
  client: managednetworkfabric
discovery:
- discovery_id: azure.managednetworkfabric.list_by_resource_group
  calls:
  - action: list_by_resource_group
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.managednetworkfabric.list_by_subscription
  calls:
  - action: list_by_subscription
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.managednetworkfabric.list_by_l3_isolation_domain
  calls:
  - action: list_by_l3_isolation_domain
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.managednetworkfabric.list_by_l3_isolation_domain
  calls:
  - action: list_by_l3_isolation_domain
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
- discovery_id: azure.managednetworkfabric.list_by_resource_group
  calls:
  - action: list_by_resource_group
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.value }}'
checks: []
