version: '1.0'
provider: ibm
service: enterprise_billing_units
services:
  client: enterprise_billing_units
discovery:
- discovery_id: ibm.enterprise_billing_units.list_billing_units
  calls:
  - action: list_billing_units
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
checks: []
