version: '1.0'
provider: ibm
service: global_catalog
services:
  client: global_catalog
discovery:
- discovery_id: ibm.global_catalog.list_catalog_entries
  calls:
  - action: list_catalog_entries
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
checks: []
