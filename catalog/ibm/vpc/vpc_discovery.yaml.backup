version: '1.0'
provider: ibm
service: vpc
services:
  client: vpc
discovery:
- discovery_id: ibm.vpc.list_backup_policies
  calls:
  - action: list_backup_policies
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
- discovery_id: ibm.vpc.list_bare_metal_server_profiles
  calls:
  - action: list_bare_metal_server_profiles
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
- discovery_id: ibm.vpc.list_bare_metal_servers
  calls:
  - action: list_bare_metal_servers
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
- discovery_id: ibm.vpc.list_cluster_network_profiles
  calls:
  - action: list_cluster_network_profiles
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
- discovery_id: ibm.vpc.list_cluster_networks
  calls:
  - action: list_cluster_networks
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
checks: []
