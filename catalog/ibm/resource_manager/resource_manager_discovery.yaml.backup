version: '1.0'
provider: ibm
service: resource_manager
services:
  client: resource_manager
discovery:
- discovery_id: ibm.resource_manager.list_quota_definitions
  calls:
  - action: list_quota_definitions
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
- discovery_id: ibm.resource_manager.list_resource_groups
  calls:
  - action: list_resource_groups
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.items }}'
checks: []
