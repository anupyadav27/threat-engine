version: '1.0'
provider: {{ category }}
engine: {{ tech }}
category: {{ section_slug }}
cis_section: '{{ section }}'
description: >
  {{ tech }} CIS Section {{ section }} — {{ description }}

discovery:
{% for row in rows %}
  - discovery_id: {{ row._discovery_id }}
    description: {{ row.title | replace('"', "'") }}
    calls:
{% set title_lower = row.title | lower %}
{% if 'list' in title_lower or ' all ' in title_lower or 'each' in title_lower or 'every' in title_lower %}
      - action: query_table
        query: "{{ row._sql_query }}"
        save_as: rows
    emit:
      as: items
      items: "{{ '{{' }} rows {{ '}}' }}"
      item:
        check: {{ row._check_slug }}
        value: "{{ '{{' }} item.value {{ '}}' }}"
        expected: "{{ row._expected_value }}"
{% else %}
      - action: query_setting
        query: "{{ row._sql_query }}"
        save_as: result
    emit:
      as: item
      item:
        check: {{ row._check_slug }}
        setting_name: "{{ row._param_name if row._param_name else row._check_slug }}"
        value: "{{ '{{' }} result.value {{ '}}' }}"
        expected: "{{ row._expected_value }}"
{% endif %}
{% endfor %}
