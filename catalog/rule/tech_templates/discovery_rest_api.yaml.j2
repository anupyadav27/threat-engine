version: '1.0'
provider: {{ category }}
engine: {{ tech }}
category: {{ section_slug }}
cis_section: '{{ section }}'
description: >
  {{ tech }} CIS Section {{ section }} — {{ description }}

discovery:
{% for row in rows %}
  - discovery_id: {{ row._discovery_id }}
    description: {{ row.title | replace('"', "'") }}
    calls:
      - action: http_get
        endpoint: "# TODO: map to vendor API endpoint"
        auth_type: bearer_token
        base_url_var: {{ tech | upper }}_API_BASE_URL
        save_as: result
    emit:
      as: item
      item:
        check: {{ row._check_slug }}
        value: "{{ '{{' }} result {{ '}}' }}"
        expected: "{{ row._expected_value }}"
{% endfor %}
