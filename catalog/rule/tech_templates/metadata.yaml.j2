tech_type: {{ tech }}
category: {{ category }}
cis_benchmark: CIS {{ tech_display }}
generated_by: generate_tech_rules

rules:
{% for row in rows %}
  - rule_id: {{ row._rule_id }}
    title: "{{ row.title | replace('"', "'") }}"
    severity: {{ row.severity | lower }}
    category: {{ row.benchmark_category }}
    tech_type: {{ row.benchmark_subcategory }}
    automation_type: {{ row.automation_type }}
    cis_benchmark: "{{ row.framework }} {{ row.framework_version }}"
    cis_version: "{{ row.framework_version }}"
    cis_control: "{{ row.control_id }}"
    cis_section: "{{ row.section }}"
    profile_applicability: "{{ row.profile_applicability }}"
    description: >
      {{ row._description | wordwrap(78, break_long_words=False) | indent(6) }}
    rationale: >
      {{ row._rationale | wordwrap(78, break_long_words=False) | indent(6) }}
    audit_procedure: >
      {{ row._audit_procedure | wordwrap(78, break_long_words=False) | indent(6) }}
    remediation: >
      {{ row._remediation_steps | wordwrap(78, break_long_words=False) | indent(6) }}
    references: >
      {{ row._references | wordwrap(78, break_long_words=False) | indent(6) }}
    impact: >
      {{ row._impact | wordwrap(78, break_long_words=False) | indent(6) }}
    compliance_mappings:
      cis:
        - "{{ row.framework }}_{{ row.framework_version | replace('.', '_') | replace('-', '_') }}_{{ row.control_id | replace('.', '_') }}"
      nist_800_53: []
      soc2: []
      pci_dss: []
    source_unique_id: "{{ row.unique_compliance_id }}"
    metadata_source: generated
    generated_by: generate_tech_rules
{% endfor %}
