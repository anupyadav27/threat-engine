{
  "filename": "notify_all_preferred_over_notify_metadata.json",
  "rule_id": "VULNERABILITY_PREFER_NOTIFYALL_OVER_NOTIFY",
  "title": "Prefer 'notifyAll()' over 'notify()'",
  "description": "notify and notifyAll both wake up sleeping threads waiting on the object's monitor, but notify only wakes up one single thread, while notifyAll wakes them all up. Unless you do not care which specific thread is woken up, notifyAll should be used instead.",
  "status": "ready",
  "defaultSeverity": "Major",
  "category": "Java",
  "recommendation": "Use 'notifyAll()' instead of 'notify()'",
  "impact": "Improves thread synchronization and consistency",
