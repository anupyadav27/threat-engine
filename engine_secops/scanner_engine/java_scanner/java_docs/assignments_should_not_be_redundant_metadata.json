{
  "filename": "assignments_should_not_be_redundant_metadata.json",
  "rule_id": "VULNERABILITY_CONSTANT_ISSUE",
  "title": "Avoid Redundant Assignments",
  "description": "This rule raises an issue when an assignment is useless because the assigned-to variable already holds the value on all execution paths.",
  "status": "ready",
  "defaultSeverity": "Info",
  "category": "VULNERABILITY",
  "recommendation": "Remove redundant assignments",
  "impact": "Prevent unnecessary code execution and potential security issues",
  "examples": {
    "noncompliant": [],
    "compliant": []
  },
  "references": [
    "https://rules.sonarsource.com/java/RSPEC-4165"
  ],
  "logic": {
    "node_types": [
      "Class"
    ],
    "checks": [
      {
        "type": "regex_match",
        "property_path": [
          "source"
        ],
        "patterns": [
          "(\\w+)\\s*=\\s*\\1\\s*;"
        ],
        "message": "Remove redundant assignments"
      }
    ]
  }
}