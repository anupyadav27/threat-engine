{
  "filename": "integer_to_hex_string_metadata.json",
  "rule_id": "security_mistake_integer_to_hex_string",
  "title": "Avoid using Integer.toHexString for hexadecimal string representation",
  "description": "Using Integer.toHexString can lead to incorrect hexadecimal string conversions, particularly in hash-code conversions, which may result in security vulnerabilities.",
  "status": "ready",
  "defaultSeverity": "Info",
  "category": "security",
  "recommendation": "Use String.format(\"%x\", integer) instead.",
  "impact": "Potential security vulnerability",
  "examples": {
    "noncompliant": [],
    "compliant": []
  },
  "references": [
    "https://rules.sonarsource.com/java/RSPEC-4425"
  ],
  "logic": {
    "node_types": [
      "Class"
    ],
    "checks": [
      {
        "type": "custom_function",
        "function": "check_security_mistake_integer_to_hex_string",
        "message": "Use String.format(\"%x\", integer) instead."
      }
    ]
  }
}