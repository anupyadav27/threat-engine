{
  "filename": "default_annotation_parameter_values_should_not_be_passed_as_arguments_metadata.json",
  "rule_id": "VULNERABILITY_ANNOTATION_REDUNDANT_DEFAULT_VALUES",
  "title": "Avoid Redundant Default Values in Annotation Parameters",
  "description": "Specifying the default value for an annotation parameter is redundant. Such values should be omitted in the interests of readability.",
  "status": "ready",
  "defaultSeverity": "Major",
  "category": "Java",
  "recommendation": "Omit default values in annotation parameters",
  "impact": "Improves readability and reduces potential confusion",
  "examples": {
    "noncompliant": [],
    "compliant": []
  },
  "references": [],
  "logic": {
    "node_types": [
      "Class"
    ],
    "checks": [
      {
        "type": "regex_match",
        "property_path": [
          "source"
        ],
        "patterns": [
          "@\\w+\\([^)]*value\\s*=\\s*\"\"[^)]*\\)",
          "@\\w+\\([^)]*required\\s*=\\s*true[^)]*\\)",
          "@\\w+\\([^)]*cascade\\s*=\\s*CascadeType\\.NONE[^)]*\\)",
          "@\\w+\\([^)]*fetch\\s*=\\s*FetchType\\.EAGER[^)]*\\)",
          "@\\w+\\([^)]*propagation\\s*=\\s*Propagation\\.REQUIRED[^)]*\\)",
          "@\\w+\\([^)]*isolation\\s*=\\s*Isolation\\.DEFAULT[^)]*\\)"
        ],
        "message": "Rule: Avoid Redundant Default Values in Annotation Parameters"
      }
    ]
  }
}