{
  "filename": "dateTimeFormattersMismatchedYearAndWeekNumbers_metadata.json",
  "rule_id": "security_avoid_mismatched_year_and_week_numbers",
  "title": "Avoid Mismatched Year and Week Numbers in DateTimeFormatters",
  "description": "When creating a DateTimeFormatter, ensure the year number and week number are consistent to avoid confusion.",
  "status": "ready",
  "defaultSeverity": "Info",
  "category": "Security",
  "recommendation": "Use WeekFields.weekOfWeekBasedYear() or ChronoField.ALIGNED_WEEK_OF_YEAR with a regular year.",
  "impact": "Potential confusion and security vulnerabilities.",
  "examples": {
    "noncompliant": [],
    "compliant": []
  },
  "references": [],
  "logic": {
    "node_types": [
      "Class"
    ],
    "checks": [
      {
        "type": "regex_match",
        "property_path": [
          "source"
        ],
        "patterns": [
          "DateTimeFormatter.*[Yy][Yy][Yy][Yy].*[Ww][Ww]",
          "DateTimeFormatter.*[Ww][Ww].*[Yy][Yy][Yy][Yy]",
          "ofPattern\\(.*[Yy][Yy][Yy][Yy].*[Ww][Ww].*\\)",
          "ofPattern\\(.*[Ww][Ww].*[Yy][Yy][Yy][Yy].*\\)",
          "\\\".*[Yy][Yy][Yy][Yy].*[Ww][Ww].*\\\"",
          "\\\".*[Ww][Ww].*[Yy][Yy][Yy][Yy].*\\\""
        ],
        "message": "Rule: Avoid Mismatched Year and Week Numbers in DateTimeFormatters"
      }
    ]
  }
}