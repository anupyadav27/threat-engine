{
  "filename": "constructors_should_not_return_values_metadata.json",
  "rule_id": "constructors_return_values",
  "title": "Constructors should not return values",
  "description": "Constructors should not return values. JavaScript allows returning a value from a class constructor, but this obscure feature is rarely used and is more likely a bug than the developer's intention. Constructors should initialize object properties, not return explicit values.",
  "status": "ready",
  "defaultSeverity": "Major",
  "category": "Security",
  "recommendation": "Remove the return statement from the constructor.",
  "impact": "Security risk",
  "tags": [
    "security",
    "bug",
    "convention"
  ],
  "examples": {
    "noncompliant": [
      "class User { constructor(name) { this.name = name; return this.name; } }",
      "function Person() { this.name = 'John'; return 'created'; }"
    ],
    "compliant": [
      "class User { constructor(name) { this.name = name; } }",
      "function Person() { this.name = 'John'; }"
    ]
  },
  "references": [
    "https://rules.sonarsource.com/javascript/RSPEC-6635"
  ],
  "logic": {
    "node_types": [
      "MethodDefinition",
      "FunctionDeclaration",
      "VariableDeclaration"
    ],
    "checks": [
      {
        "type": "regex_match",
        "property_path": [
          "source"
        ],
        "pattern": "constructor\\s*\\([^)]*\\)\\s*{[^}]*return\\s+(?!;\\s*})[^;}\\s][^;}]*[;}]",
        "message": "Constructor should not return values."
      },
      {
        "type": "regex_match",
        "property_path": [
          "source"
        ],
        "pattern": "function\\s+[A-Z][a-zA-Z0-9_]*\\s*\\([^)]*\\)\\s*{[^}]*return\\s+(?!;\\s*})[^;}\\s][^;}]*[;}]",
        "message": "Constructor function should not return values."
      },
      {
        "type": "regex_match",
        "property_path": [
          "source"
        ],
        "pattern": "(const|let|var)\\s+[A-Z][a-zA-Z0-9_]*\\s*=\\s*function\\s*\\([^)]*\\)\\s*{[^}]*return\\s+(?!;\\s*})[^;}\\s][^;}]*[;}]",
        "message": "Constructor function variable should not return values."
      }
    ]
  }
}