{
  "filename": "hard_coded_secrets_are_security_sensitive_metadata.json",
  "rule_id": "hardcoded_secrets_are_securitysensitive",
  "title": "Hard-coded secrets are security-sensitive",
  "description": "This rule detects variables/fields having a name matching a list of words (secret, token, credential, auth, api[_.-]?key) being assigned a pseudorandom hard-coded value. The pseudorandomness of the hard-coded value is based on its entropy and the probability to be human-readable. The randomness sensibility can be adjusted if needed.",
  "status": "ready",
  "defaultSeverity": "Info",
  "category": "Security",
  "recommendation": "Review and fix according to the rule guidelines.",
  "impact": "Security risk",
  "tags": [
    "security",
    "cert",
    "cwe",
    "owasp"
  ],
  "examples": {
    "noncompliant": [
      "// Noncompliant: Hard-coded secret value\nchar const *mySecret = \"47828a8dd77ee1eb9dde2d5e93cb221ce8c32b37\";\nchar const *apiToken = \"abc123def456ghi789\"; // Sensitive"
    ],
    "compliant": [
      "// Compliant: Reading secret from environment or secure storage\nchar const *mySecret = getenv(\"MY_SECRET_KEY\");\nchar const *apiToken = readFromSecureVault(\"api_token\");"
    ]
  },
  "references": [
    "https://rules.sonarsource.com/c/RSPEC-6418"
  ],
  "logic": {
    "node_types": [
      "AssignmentExpression",
      "VariableDeclarator"
    ],
    "checks": [
      {
        "type": "regex_match",
        "property_path": [
          "source"
        ],
        "patterns": [
          "\\b(secret|Secret|SECRET)\\s*=\\s*\"[a-fA-F0-9]{20,}\"",
          "\\b(token|Token|TOKEN)\\s*=\\s*\"[a-zA-Z0-9]{15,}\"",
          "\\b(credential|Credential|CREDENTIAL)\\s*=\\s*\"[a-zA-Z0-9]{12,}\"",
          "\\b(password|Password|PASSWORD)\\s*=\\s*\"[a-zA-Z0-9!@#$%^&*]{8,}\"",
          "\\b(api[_-]?key|apikey|ApiKey|API[_-]?KEY)\\s*=\\s*\"[a-zA-Z0-9]{16,}\"",
          "\\b(auth[_-]?token|authtoken|AuthToken|AUTH[_-]?TOKEN)\\s*=\\s*\"[a-zA-Z0-9]{20,}\"",
          "\\b(access[_-]?key|accesskey|AccessKey|ACCESS[_-]?KEY)\\s*=\\s*\"[a-zA-Z0-9]{15,}\"",
          "\\b(private[_-]?key|privatekey|PrivateKey|PRIVATE[_-]?KEY)\\s*=\\s*\"[a-zA-Z0-9+/=]{20,}\"",
          "\\b(client[_-]?secret|clientsecret|ClientSecret|CLIENT[_-]?SECRET)\\s*=\\s*\"[a-zA-Z0-9]{24,}\"",
          "\\*\\s*(secret|token|credential|password|apikey|auth)\\s*=\\s*\"[a-fA-F0-9]{16,}\"",
          "\\*\\s*(my_?secret|my_?token|my_?key)\\s*=\\s*\"[a-zA-Z0-9]{12,}\"",
          "char\\s+\\*\\s*(secret|token|key|password)\\s*=\\s*\"[a-fA-F0-9]{20,}\"",
          "const\\s+char\\s+\\*\\s*(secret|token|credential)\\s*=\\s*\"[a-zA-Z0-9]{15,}\"",
          "#define\\s+(SECRET|TOKEN|API_KEY|PASSWORD)\\s+\"[a-zA-Z0-9]{12,}\"",
          "\\b\\w*[sS]ecret\\w*\\s*=\\s*\"[a-fA-F0-9]{24,}\"",
          "\\b\\w*[tT]oken\\w*\\s*=\\s*\"[a-zA-Z0-9]{20,}\"",
          "\\b\\w*[kK]ey\\w*\\s*=\\s*\"[a-zA-Z0-9]{16,}\"",
          "\\b\\w*[pP]assword\\w*\\s*=\\s*\"[a-zA-Z0-9!@#$%^&*]{10,}\"",
          "\\b\\w*[aA]uth\\w*\\s*=\\s*\"[a-zA-Z0-9]{18,}\""
        ],
        "message": "Hard-coded secrets are security-sensitive. Review and fix according to the rule guidelines."
      }
    ]
  }
}