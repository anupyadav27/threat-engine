{
  "filename": "server_hostnames_should_be_verified_during_ssltls__metadata.json",
  "rule_id": "server_hostnames_verified_during",
  "title": "Server hostnames should be verified during SSL/TLS connections",
  "description": "Transport Layer Security (TLS) provides secure communication between systems over the internet by encrypting the data sent between them. In this process, the role of hostname validation, combined with certificate validation, is to ensure that a system is indeed the one it claims to be, adding an extra layer of trust and security. When hostname validation is disabled, the client skips this critical check.",
  "status": "ready",
  "defaultSeverity": "Critical",
  "category": "Security",
  "recommendation": "Review and fix according to the rule guidelines.",
  "impact": "Security risk",
  "tags": [
    "security",
    "cert",
    "cwe",
    "design"
  ],
  "examples": {
    "noncompliant": [
      "#include <openssl/ssl.h>\n\nSSL_CTX *ctx = SSL_CTX_new(TLS_client_method());\nSSL_set_verify(ssl, SSL_VERIFY_NONE, NULL); // Noncompliant: no hostname verification\n\n// Using curl without hostname verification\ncurl_easy_setopt(curl, CURLOPT_SSL_VERIFYHOST, 0L); // Noncompliant: disables hostname verification"
    ],
    "compliant": [
      "#include <openssl/ssl.h>\n\nSSL_CTX *ctx = SSL_CTX_new(TLS_client_method());\nSSL_set_verify(ssl, SSL_VERIFY_PEER, NULL); // Compliant: enables verification\nSSL_set1_host(ssl, \"example.com\"); // Compliant: sets expected hostname\n\n// Using curl with proper hostname verification\ncurl_easy_setopt(curl, CURLOPT_SSL_VERIFYHOST, 2L); // Compliant: full hostname verification\ncurl_easy_setopt(curl, CURLOPT_URL, \"https://example.com\"); // Compliant"
    ]
  },
  "references": [
    "https://rules.sonarsource.com/c/RSPEC-5527"
  ],
  "logic": {
    "node_types": ["TranslationUnit"],
    "checks": [
      {
        "type": "regex_match",
        "property_path": ["source"],
        "patterns": [
          "CURLOPT_SSL_VERIFYHOST\\s*,\\s*0L?\\b",
          "CURLOPT_SSL_VERIFYHOST\\s*,\\s*0\\b",
          "CURLOPT_SSL_VERIFYHOST\\s*,\\s*false\\b",
          "curl_easy_setopt\\s*\\([^)]*CURLOPT_SSL_VERIFYHOST[^)]*,\\s*0L?\\s*\\)",
          "curl_easy_setopt\\s*\\([^)]*CURLOPT_SSL_VERIFYHOST[^)]*,\\s*0\\s*\\)",
          "curl_easy_setopt\\s*\\([^)]*CURLOPT_SSL_VERIFYHOST[^)]*,\\s*false\\s*\\)"
        ],
        "message": "CURL hostname verification is disabled. Set CURLOPT_SSL_VERIFYHOST to 2 for full hostname verification.",
        "severity": "critical"
      },
      {
        "type": "regex_match",
        "property_path": ["source"],
        "patterns": [
          "CURLOPT_SSL_VERIFYPEER\\s*,\\s*0L?\\b",
          "CURLOPT_SSL_VERIFYPEER\\s*,\\s*0\\b",
          "CURLOPT_SSL_VERIFYPEER\\s*,\\s*false\\b",
          "curl_easy_setopt\\s*\\([^)]*CURLOPT_SSL_VERIFYPEER[^)]*,\\s*0L?\\s*\\)",
          "curl_easy_setopt\\s*\\([^)]*CURLOPT_SSL_VERIFYPEER[^)]*,\\s*0\\s*\\)",
          "curl_easy_setopt\\s*\\([^)]*CURLOPT_SSL_VERIFYPEER[^)]*,\\s*false\\s*\\)"
        ],
        "message": "CURL peer certificate verification is disabled. Set CURLOPT_SSL_VERIFYPEER to 1 to enable verification.",
        "severity": "critical"
      },
      {
        "type": "regex_match",
        "property_path": ["source"],
        "patterns": [
          "SSL_set_verify\\s*\\([^)]*SSL_VERIFY_NONE[^)]*\\)",
          "SSL_CTX_set_verify\\s*\\([^)]*SSL_VERIFY_NONE[^)]*\\)",
          "SSL_VERIFY_NONE\\b",
          "\\bSSL_VERIFY_NONE\\s*;",
          "=\\s*SSL_VERIFY_NONE\\b"
        ],
        "message": "OpenSSL verification is disabled. Use SSL_VERIFY_PEER for proper certificate verification.",
        "severity": "critical"
      },
      {
        "type": "regex_match",
        "property_path": ["source"],
        "patterns": [
          "SSL_set_verify_result\\s*\\([^)]*X509_V_OK[^)]*\\)",
          "SSL_CTX_set_verify_result\\s*\\([^)]*X509_V_OK[^)]*\\)"
        ],
        "message": "Manually setting SSL verification result to OK bypasses proper certificate validation.",
        "severity": "critical"
      },
      {
        "type": "regex_match",
        "property_path": ["source"],
        "patterns": [
          "X509_V_FLAG_CHECK_SS_SIGNATURE\\b",
          "X509_VERIFY_PARAM_set_flags\\s*\\([^)]*X509_V_FLAG_CHECK_SS_SIGNATURE[^)]*\\)"
        ],
        "message": "Using X509_V_FLAG_CHECK_SS_SIGNATURE may allow self-signed certificates without proper validation.",
        "severity": "warning"
      },
      {
        "type": "regex_match",
        "property_path": ["source"],
        "patterns": [
          "SSL_set_verify\\s*\\([^)]*SSL_VERIFY_PEER[^)]*\\)(?![^\\n]*SSL_set1?_host)",
          "SSL_CTX_set_verify\\s*\\([^)]*SSL_VERIFY_PEER[^)]*\\)(?![^\\n]*SSL_set1?_host)",
          "SSL_new\\s*\\([^)]*\\)(?![^}]*SSL_set1?_host)"
        ],
        "message": "OpenSSL peer verification enabled but hostname verification not configured. Use SSL_set1_host() to verify hostname.",
        "severity": "major"
      },
      {
        "type": "regex_match",
        "property_path": ["source"],
        "patterns": [
          "SSL_CTX_set_verify_mode\\s*\\([^)]*,\\s*0\\s*\\)",
          "SSL_set_verify_mode\\s*\\([^)]*,\\s*0\\s*\\)"
        ],
        "message": "SSL verification mode set to 0 disables certificate verification.",
        "severity": "critical"
      },
      {
        "type": "regex_match",
        "property_path": ["source"],
        "patterns": [
          "CURLOPT_CAINFO\\s*,\\s*NULL\\b",
          "CURLOPT_CAPATH\\s*,\\s*NULL\\b",
          "curl_easy_setopt\\s*\\([^)]*CURLOPT_CAINFO[^)]*,\\s*NULL\\s*\\)",
          "curl_easy_setopt\\s*\\([^)]*CURLOPT_CAPATH[^)]*,\\s*NULL\\s*\\)"
        ],
        "message": "Setting CA info/path to NULL may disable certificate authority verification.",
        "severity": "major"
      },
      {
        "type": "regex_match",
        "property_path": ["source"],
        "patterns": [
          "SSL_CTX_set_verify_depth\\s*\\([^)]*,\\s*0\\s*\\)",
          "SSL_set_verify_depth\\s*\\([^)]*,\\s*0\\s*\\)"
        ],
        "message": "Setting SSL verification depth to 0 disables certificate chain validation.",
        "severity": "critical"
      },
      {
        "type": "regex_match",
        "property_path": ["source"],
        "patterns": [
          "CURLOPT_SSL_CIPHER_LIST\\s*,\\s*\"[^\"]*\\b(NULL|eNULL|aNULL)\\b[^\"]*\"",
          "SSL_CTX_set_cipher_list\\s*\\([^)]*\"[^\"]*\\b(NULL|eNULL|aNULL)\\b[^\"]*\"[^)]*\\)",
          "\"(NULL|eNULL|aNULL)\"\\s*(?=\\s*\\)|;|,)",
          "\"\\s*(NULL|eNULL|aNULL)\\s*\"",
          "\"(HIGH:)?(NULL|eNULL|aNULL)\"",
          "\"[^\"]*:(NULL|eNULL|aNULL)[^\"]*\""
        ],
        "message": "Using NULL cipher suites disables encryption and authentication.",
        "severity": "critical"
      },
      {
        "type": "regex_match",
        "property_path": ["source"],
        "patterns": [
          "curl_easy_setopt\\s*\\([^)]*CURLOPT_SSL_VERIFYHOST[^)]*,\\s*1L?\\s*\\)"
        ],
        "message": "CURLOPT_SSL_VERIFYHOST set to 1 provides only partial hostname verification. Use 2 for full verification.",
        "severity": "major"
      },
      {
        "type": "regex_match",
        "property_path": ["source"],
        "patterns": [
          "SSL_CTX_load_verify_locations\\s*\\([^)]*,\\s*NULL\\s*,\\s*NULL\\s*\\)",
          "SSL_load_verify_locations\\s*\\([^)]*,\\s*NULL\\s*,\\s*NULL\\s*\\)"
        ],
        "message": "Not loading CA certificate locations may prevent proper certificate verification.",
        "severity": "major"
      },
      {
        "type": "regex_match",
        "property_path": ["source"],
        "patterns": [
          "X509_STORE_set_flags\\s*\\([^)]*X509_V_FLAG_ALLOW_PROXY_CERTS[^)]*\\)",
          "X509_VERIFY_PARAM_set_flags\\s*\\([^)]*X509_V_FLAG_ALLOW_PROXY_CERTS[^)]*\\)"
        ],
        "message": "Allowing proxy certificates may weaken certificate validation security.",
        "severity": "warning"
      },
      {
        "type": "regex_match",
        "property_path": ["source"],
        "patterns": [
          "BIO_new_ssl_connect\\s*\\([^)]*\\)(?![^}]*SSL_set1?_host)",
          "BIO_set_conn_hostname\\s*\\([^)]*\\)(?![^}]*SSL_set1?_host)",
          "BIO_new_ssl_connect\\s*\\(",
          "BIO_set_conn_hostname\\s*\\("
        ],
        "message": "Using BIO SSL connection without hostname verification. Configure hostname validation.",
        "severity": "major"
      },
      {
        "type": "regex_match",
        "property_path": ["source"],
        "patterns": [
          "CURLOPT_SSL_VERIFYSTATUS\\s*,\\s*0L?\\b",
          "CURLOPT_SSL_VERIFYSTATUS\\s*,\\s*false\\b",
          "curl_easy_setopt\\s*\\([^)]*CURLOPT_SSL_VERIFYSTATUS[^)]*,\\s*0L?\\s*\\)"
        ],
        "message": "CURL OCSP stapling verification is disabled. Enable with CURLOPT_SSL_VERIFYSTATUS for enhanced security.",
        "severity": "major"
      },
      {
        "type": "regex_match",
        "property_path": ["source"],
        "patterns": [
          "CURLOPT_PROXY_SSL_VERIFYHOST\\s*,\\s*0L?\\b",
          "CURLOPT_PROXY_SSL_VERIFYPEER\\s*,\\s*0L?\\b",
          "curl_easy_setopt\\s*\\([^)]*CURLOPT_PROXY_SSL_VERIFYHOST[^)]*,\\s*0L?\\s*\\)",
          "curl_easy_setopt\\s*\\([^)]*CURLOPT_PROXY_SSL_VERIFYPEER[^)]*,\\s*0L?\\s*\\)"
        ],
        "message": "CURL proxy SSL verification is disabled. Enable proper proxy SSL verification.",
        "severity": "critical"
      }
    ]
  }
}