{
  "rule_id": "assertions_should_not_fail_or_succeed_unconditionally",
  "title": "Assertions should not fail or succeed unconditionally",
  "type": "CODE_SMELL",
  "status": "ready",
  "defaultSeverity": "Major",
  "description": "Avoid using assert statements without providing a condition.",
  "message": "Assertion should have a conditional check.",
  "remediation": {
    "func": "Constant/Issue",
    "constantCost": "5min"
  },
  "tags": [
    "assertions",
    "testing",
    "development"
  ],
  "impact": "Readability",
  "recommendation": "Provide a condition when using assert statements.",
  "references": [
    {
      "url": "https://rules.sonarsource.com/python/RSPEC-3349",
      "type": "official"
    },
    {
      "url": "https://www.python.org/dev/peps/pep-0008/#testing",
      "type": "reference"
    }
  ],
  "examples": {
    "noncompliant": [
      {
        "code": "assert 1 == 2",
        "description": "Assert statement without condition."
      }
    ],
    "compliant": [
      {
        "code": "assert 1 == 1",
        "description": "Assert statement with conditional check."
      }
    ]
  },
