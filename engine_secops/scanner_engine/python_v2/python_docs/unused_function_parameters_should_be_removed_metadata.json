{
  "rule_id": "unused_function_parameters_should_be_removed",
  "title": "Unused function parameters should be removed",
  "type": "CODE_SMELL",
  "status": "ready",
  "defaultSeverity": "Minor",
  "description": "This rule identifies unused function parameters and suggests their removal to improve code readability and maintainability.",
  "message": "Function parameter is not used.",
  "remediation": {
    "func": "Constant/Issue",
    "constantCost": "5min"
  },
  "tags": [
    "unused",
    "function",
    "parameter"
  ],
  "impact": "Low",
  "recommendation": "Remove unused function parameters.",
  "references": [],
  "examples": {
    "noncompliant": [
      {
        "code": "def foo(x, y): pass",
        "description": "Function has an unused parameter y."
      }
    ],
    "compliant": [
      {
        "code": "def foo(x): pass",
        "description": "Function has only used parameter x."
      }
    ]
  },
  "devsecops": {
    "category": "",
    "security": "",
    "automation": "",
    "compliance": ""
  },
  "why_is_this_an_issue": "Unused function parameters can lead to confusion and make the code harder to maintain.",
  "how_to_fix": "Remove unused function parameters.",
  "security_mappings": {
    "CWE": "",
    "CERT": "",
    "OWASP": ""
  },
  "logic": {
    "node_types": ["FunctionDef"],
    "checks": [
      {
        "type": "property_comparison",
        "property": "args.args[*].arg",
        "pattern": "unused",
        "message": "Function parameter is not used."
      }
    ]
  }
}