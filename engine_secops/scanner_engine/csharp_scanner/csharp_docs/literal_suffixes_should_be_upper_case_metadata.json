{
  "filename": "literal_suffixes_should_be_upper_case_metadata.json",
  "rule_id": "literal_suffixes_upper_case",
  "title": "Literal suffixes should be upper case",
  "description": "Literal suffixes should be upper case. Using upper case literal suffixes removes the potential ambiguity between '1' (digit 1) and 'l' (letter el) for declaring literals.",
  "status": "ready",
  "defaultSeverity": "Major",
  "category": "Security",
  "recommendation": "Use uppercase suffixes (L, F, D, M) instead of lowercase (l, f, d, m) for numeric literals.",
  "impact": "Code readability and maintainability risk",
  "tags": [
    "code-smell",
    "convention",
    "maintainability",
    ".net"
  ],
  "examples": {
    "noncompliant": [
      "const long b = 0l;      // Noncompliant - lowercase l",
      "float f = 1.5f;         // Noncompliant - lowercase f",
      "decimal d = 10.5m;      // Noncompliant - lowercase m",
      "var hex = 0x1Al;        // Noncompliant - lowercase l"
    ],
    "compliant": [
      "const long b = 0L;      // Compliant - uppercase L",
      "float f = 1.5F;         // Compliant - uppercase F",
      "decimal d = 10.5M;      // Compliant - uppercase M",
      "var hex = 0x1AL;        // Compliant - uppercase L"
    ]
  },
  "references": [
    "https://rules.sonarsource.com/csharp/RSPEC-818"
  ],
  "logic": {
    "node_types": ["CompilationUnit"],
    "checks": [
      {
        "type": "custom_function",
        "function": "check_literal_suffixes_lowercase"
      }
    ],
    "never_trigger_on": [
      "Comments (single-line //, multi-line /* */, XML documentation ///)",
      "Logging statements (Console.*, Logger.*)",
      "Unit tests ([Test], [Fact], [TestMethod])",
      "String literals containing suffix patterns",
      "Uppercase suffixes (L, F, D, M)"
    ],
    "reasoning": "Literal suffixes should use uppercase (L, F, D, M) instead of lowercase (l, f, d, m) to avoid confusion between lowercase 'l' and digit '1'. Uses custom function to properly detect only lowercase suffixes and handle exclusions.",
    "validation_examples": {
      "should_trigger": [
        "const long b = 0l;",
        "float f = 1.5f;",
        "decimal d = 10.5m;",
        "var hex = 0x1Al;"
      ],
      "should_not_trigger": [
        "const long b = 0L;",
        "float f = 1.5F;",
        "decimal d = 10.5M;",
        "// Example: const long b = 0l;",
        "[Test] method with 0l"
      ]
    }
  }
}
