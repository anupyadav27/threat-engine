{\n  \"filename\": \"assignments_should_not_be_made_from_within_sub_exp_metadata.json\",\n  \"rule_id\": \"assignments_made_from_within\",\n  \"title\": \"Assignments should not be made from within sub-expressions\",\n  \"description\": \"A common code smell that can hinder the clarity of source code is making assignments within sub-expressions. This practice involves assigning a value to a variable inside a larger expression, such as within a loop or a conditional statement. This practice essentially gives a side-effect to a larger expression, thus making it less readable.\",\n  \"status\": \"ready\",\n  \"defaultSeverity\": \"Major\",\n  \"category\": \"Security\",\n  \"recommendation\": \"Review and fix according to the rule guidelines.\",\n  \"impact\": \"Security risk\",\n  \"tags\": [\n    \"security\",\n    \"bug\",\n    \".net\"\n  ],\n  \"examples\": {\n    \"noncompliant\": [\n      \"if ((x = getValue()) != null) // Noncompliant - assignment within condition\\n{\\n    ProcessValue(x);\\n}\",\n      \"while ((line = reader.ReadLine()) != null) // Noncompliant\\n{\\n    Process(line);\\n}\",\n      \"return (result = Calculate()); // Noncompliant - assignment within return\"\n    ],\n    \"compliant\": [\n      \"x = getValue(); // Compliant - separate assignment\\nif (x != null)\\n{\\n    ProcessValue(x);\\n}\",\n      \"line = reader.ReadLine(); // Compliant\\nwhile (line != null)\\n{\\n    Process(line);\\n    line = reader.ReadLine();\\n}\",\n      \"result = Calculate(); // Compliant - separate assignment\\nreturn result;\"\n    ]\n  },\n  \"references\": [\n    \"https://rules.sonarsource.com/csharp/RSPEC-1121\"\n  ],\n  \"logic\": {\n    \"node_types\": [\n      \"Assignment\"\n    ],\n    \"checks\": [\n      {\n        \"type\": \"regex_match\",\n        \"property_path\": [\n          \"source\"\n        ],\n        \"patterns\": [\n          \"\\\\([^)]*\\\\w+\\\\s*=\\\\s*[^)]*\\\\)\\\\s*[!<>=&|]{1,2}(?!=)\",\n          \"\\\\breturn\\\\s*\\\\([^)]*\\\\w+\\\\s*=\\\\s*[^)]*\\\\)\"\n        ],\n        \"exclude_patterns\": [\n          \"\\\\bfor\\\\s*\\\\([^;]*=[^;]*;[^;]*;[^)]*\\\\)\",\n          \"string\\\\.(Format|Concat|Join)\\\\([^)]*=[^)]*\\\\)\",\n          \"Console\\\\.(Write|WriteLine)\\\\([^)]*=[^)]*\\\\)\",\n          \"\\\\(\\\\w+\\\\s*\\\\+\\\\s*\\\\d+\\\\)\\\\s*\\\\*\",\n          \"\\\"[^\\\"]*=[^\\\"]*\\\"\"\n        ],\n        \"message\": \"Review and fix according to the rule guidelines.\"\n      }\n    ]\n  }\n}