          "aws.redshift.user.iam_auth_preferred_configured"
        ]
      },
      {
        "issue": "Wrong discovery usage - enhanced_vpc_routing_configured used describe_cluster_snapshots",
        "fix": "Changed to use describe_clusters discovery",
        "rules_affected": ["aws.redshift.cluster.enhanced_vpc_routing_configured"]
      },
      {
        "issue": "Wrong discovery usage - access_allowed_cidrs_minimized_configured used describe_cluster_snapshots",
        "fix": "Changed to use describe_endpoint_access discovery",
        "rules_affected": ["aws.redshift.endpointaccess.access_allowed_cidrs_minimized_configured"]
      },
      {
        "issue": "Incorrect emit structure - describe_endpoint_access and describe_endpoint_authorization didn't iterate over arrays",
        "fix": "Changed emit to use items_for to iterate over EndpointAccessList and EndpointAuthorizationList arrays",
        "rules_affected": [
          "aws.redshift.describe_endpoint_access discovery",
          "aws.redshift.describe_endpoint_authorization discovery"
        ]
      },
      {
        "issue": "Wrong value types - used string 'true'/'false' instead of boolean true/false",
        "fix": "Changed all boolean values from string to boolean type",
        "rules_affected": ["all rules with boolean checks"]
      }
    ]
