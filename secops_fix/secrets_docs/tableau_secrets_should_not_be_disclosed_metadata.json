{
  "filename": "tableau_secrets_should_not_be_disclosed_metadata.json",
  "rule_id": "tableau_secrets_disclosed",
  "title": "Tableau secrets should not be disclosed",
  "description": "In most cases, trust boundaries are violated when a secret is exposed in a source code repository or an uncontrolled deployment environment. Unintended people who don\u2019t need to know the secret might get access to it. They might then be able to use it to gain unwanted access to associated services or resources.",
  "status": "ready",
  "defaultSeverity": "Info",
  "category": "Security",
  "recommendation": "Review and fix according to the rule guidelines.",
  "impact": "Security risk",
  "tags": [
    "security",
    "cwe"
  ],
  "examples": {
    "noncompliant": [],
    "compliant": []
  },
  "references": [
    "https://rules.sonarsource.com/secrets/RSPEC-7161"
  ],
  "logic": {
    "node_types": [],
    "checks": [
      {
        "type": "regex",
        "pattern": "\\b[A-Za-z0-9]{32,64}\\b",
        "message": "Tableau Personal Access Token (PAT) or API secret detected in source code. Tableau tokens provide programmatic access to Tableau Server or Tableau Online, allowing read/write operations on workbooks, data sources, and other resources. Exposing these tokens enables unauthorized access to your Tableau environment. Revoke this token immediately and store tokens securely in environment variables or secret management systems.",
