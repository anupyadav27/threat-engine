{
  "filename": "azure_machine_learning_keys_should_not_be_disclose_metadata.json",
  "rule_id": "azure_machine_learning_keys",
  "title": "Azure Machine Learning keys should not be disclosed",
  "description": "In most cases, trust boundaries are violated when a secret is exposed in a source code repository or an uncontrolled deployment environment. Unintended people who don\u2019t need to know the secret might get access to it. They might then be able to use it to gain unwanted access to associated services or resources.",
  "status": "ready",
  "defaultSeverity": "Info",
  "category": "Security",
  "recommendation": "Review and fix according to the rule guidelines.",
  "impact": "Security risk",
  "tags": [
    "security",
    "cwe"
  ],
  "examples": {
    "noncompliant": [],
    "compliant": [
      {
        "code": "AZUREML_WORKSPACE_KEY = os.environ.get('AZUREML_WORKSPACE_KEY')",
        "description": "ML workspace key from environment variable"
      },
      {
        "code": "const scoringKey = process.env.AZUREML_SCORING_KEY",
        "description": "ML scoring key retrieved from environment"
      }
    ]
  },
  "references": [
    "https://rules.sonarsource.com/secrets/RSPEC-7022"
  ],
  "logic": {
    "node_types": [],
    "checks": [
      {
        "type": "regex",
        "pattern": "[a-zA-Z0-9+/]{40,88}={0,2}",
        "message": "Azure Machine Learning key detected",
        "context_keywords": [
          "azureml",
          "AzureML",
          "AZUREML",
          "azure_ml",
