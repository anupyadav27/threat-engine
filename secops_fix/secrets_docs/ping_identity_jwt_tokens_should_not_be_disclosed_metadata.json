{
  "filename": "ping_identity_jwt_tokens_should_not_be_disclosed_metadata.json",
  "rule_id": "ping_identity_jwt_tokens",
  "title": "Ping Identity JWT tokens should not be disclosed",
  "description": "In most cases, trust boundaries are violated when a secret is exposed in a source code repository or an uncontrolled deployment environment. Unintended people who don\u2019t need to know the secret might get access to it. They might then be able to use it to gain unwanted access to associated services or resources.",
  "status": "ready",
  "defaultSeverity": "Info",
  "category": "Security",
  "recommendation": "Review and fix according to the rule guidelines.",
  "impact": "Security risk",
  "tags": [
    "security",
    "cwe"
  ],
  "examples": {
    "noncompliant": [],
    "compliant": []
  },
  "references": [
    "https://rules.sonarsource.com/secrets/RSPEC-7567"
  ],
  "logic": {
    "node_types": [],
    "checks": [
      {
        "type": "regex",
        "pattern": "\\beyJ[A-Za-z0-9_-]{20,}\\.eyJ[A-Za-z0-9_-]{20,}\\.[A-Za-z0-9_-]{20,}\\b",
        "message": "Ping Identity JWT token detected. JWT (JSON Web Token) tokens are used for authentication and authorization in Ping Identity products including PingFederate, PingAccess, PingOne, and OAuth2 flows. These tokens provide access to identity services, SSO sessions, API resources, and protected applications. Exposing JWT tokens allows attackers to impersonate users, access protected resources, bypass authentication, gain unauthorized access to integrated systems, and compromise identity infrastructure. Tokens often contain sensitive claims and grant broad access permissions. Rotate tokens immediately if exposed and implement secure token storage practices.",
        "context_keywords": [
          "ping",
          "Ping",
          "PING",
          "pingidentity",
          "pingIdentity",
          "PingIdentity",
          "PINGIDENTITY",
