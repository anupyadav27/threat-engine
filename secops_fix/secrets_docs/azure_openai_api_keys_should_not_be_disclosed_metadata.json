{
  "filename": "azure_openai_api_keys_should_not_be_disclosed_metadata.json",
  "rule_id": "azure_openai_api_keys",
  "title": "Azure OpenAI API keys should not be disclosed",
  "description": "In most cases, trust boundaries are violated when a secret is exposed in a source code repository or an uncontrolled deployment environment. Unintended people who don\u2019t need to know the secret might get access to it. They might then be able to use it to gain unwanted access to associated services or resources.",
  "status": "ready",
  "defaultSeverity": "Info",
  "category": "Security",
  "recommendation": "Review and fix according to the rule guidelines.",
  "impact": "Security risk",
  "tags": [
    "security",
    "cwe"
  ],
  "examples": {
    "noncompliant": [],
    "compliant": [
      {
        "code": "AZURE_OPENAI_KEY = os.environ.get('AZURE_OPENAI_KEY')",
        "description": "OpenAI key from environment variable"
      },
      {
        "code": "const apiKey = process.env.AZURE_OPENAI_API_KEY",
        "description": "OpenAI key retrieved from environment"
      }
    ]
  },
  "references": [
    "https://rules.sonarsource.com/secrets/RSPEC-7219"
  ],
  "logic": {
    "node_types": [],
    "checks": [
      {
        "type": "regex",
        "pattern": "[a-zA-Z0-9+/]{40,88}={0,2}",
        "message": "Azure OpenAI API key detected",
        "context_keywords": [
          "openai",
          "OpenAI",
          "OPENAI",
          "azure_openai",
          "azureOpenai",
          "AzureOpenAI",
