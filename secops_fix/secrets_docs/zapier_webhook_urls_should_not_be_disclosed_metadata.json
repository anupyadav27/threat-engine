{
  "filename": "zapier_webhook_urls_should_not_be_disclosed_metadata.json",
  "rule_id": "zapier_webhook_urls_disclosed",
  "title": "Zapier webhook URLs should not be disclosed",
  "description": "In most cases, trust boundaries are violated when a secret is exposed in a source code repository or an uncontrolled deployment environment. Unintended people who don\u2019t need to know the secret might get access to it. They might then be able to use it to gain unwanted access to associated services or resources.",
  "status": "ready",
  "defaultSeverity": "Critical",
  "category": "Security",
  "recommendation": "Review and fix according to the rule guidelines.",
  "impact": "Security risk",
  "tags": [
    "security",
    "cwe"
  ],
  "examples": {
    "noncompliant": [],
    "compliant": []
  },
  "references": [
    "https://rules.sonarsource.com/secrets/RSPEC-6720"
  ],
  "logic": {
    "node_types": [],
    "checks": [
      {
        "type": "regex",
        "pattern": "https://hooks\\.zapier\\.com/hooks/catch/[0-9]+/[a-zA-Z0-9]+",
        "message": "Zapier webhook URL detected. This URL triggers Zapier automation workflows and provides access to connected app integrations. Exposing Zapier webhook URLs enables unauthorized workflow triggering, potential data manipulation across connected services, and abuse of automation processes. Immediately regenerate the webhook URL in your Zapier account settings and implement secure storage using environment variables.",
