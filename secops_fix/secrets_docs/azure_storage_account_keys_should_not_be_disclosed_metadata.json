{
  "filename": "azure_storage_account_keys_should_not_be_disclosed_metadata.json",
  "rule_id": "azure_storage_account_keys",
  "title": "Azure Storage Account Keys should not be disclosed",
  "description": "In most cases, trust boundaries are violated when a secret is exposed in a source code repository or an uncontrolled deployment environment. Unintended people who don\u2019t need to know the secret might get access to it. They might then be able to use it to gain unwanted access to associated services or resources.",
  "status": "ready",
  "defaultSeverity": "Info",
  "category": "Security",
  "recommendation": "Review and fix according to the rule guidelines.",
  "impact": "Security risk",
  "tags": [
    "security",
    "cwe"
  ],
  "examples": {
    "noncompliant": [],
    "compliant": [
      {
        "code": "AZURE_STORAGE_KEY = os.environ.get('AZURE_STORAGE_KEY')",
        "description": "Storage key from environment variable"
      },
      {
        "code": "const storageKey = process.env.AZURE_STORAGE_ACCOUNT_KEY",
        "description": "Storage key retrieved from environment"
      }
    ]
  },
  "references": [
    "https://rules.sonarsource.com/secrets/RSPEC-6338"
  ],
  "logic": {
    "node_types": [],
    "checks": [
      {
        "type": "regex",
        "pattern": "[A-Za-z0-9+/]{86}==",
        "message": "Azure Storage Account Key detected",
