{
  "filename": "trend_cloud_one_legacy_api_keys_should_not_be_disc_metadata.json",
  "rule_id": "trend_cloud_one_legacy",
  "title": "Trend Cloud One legacy API keys should not be disclosed",
  "description": "In most cases, trust boundaries are violated when a secret is exposed in a source code repository or an uncontrolled deployment environment. Unintended people who don\u2019t need to know the secret might get access to it. They might then be able to use it to gain unwanted access to associated services or resources.",
  "status": "ready",
  "defaultSeverity": "Info",
  "category": "Security",
  "recommendation": "Review and fix according to the rule guidelines.",
  "impact": "Security risk",
  "tags": [
    "security",
    "cwe"
  ],
  "examples": {
    "noncompliant": [],
    "compliant": []
  },
  "references": [
    "https://rules.sonarsource.com/secrets/RSPEC-7604"
  ],
  "logic": {
    "node_types": [],
    "checks": [
      {
        "type": "regex",
        "pattern": "\\b[A-Za-z0-9]{32,60}\\b",
        "message": "Trend Micro Deep Security legacy API key detected in source code. Deep Security legacy API keys provide administrative access to the legacy Trend Micro Deep Security Manager (DSM) platform for workload protection, intrusion prevention, and security policy management. Exposing these legacy keys allows unauthorized access to security configurations, vulnerability management, and critical infrastructure protections. Migrate to Trend Cloud One and revoke legacy keys immediately.",
        "context_keywords": [
          "deep_security",
          "deepSecurity",
          "DeepSecurity",
          "DEEP_SECURITY",
          "dsm",
          "DSM",
          "Dsm",
          "deep_security_manager",
          "deepSecurityManager",
          "DeepSecurityManager",
          "DEEP_SECURITY_MANAGER",
          "trend",
          "Trend",
          "TREND",
          "trendmicro",
          "TrendMicro",
          "TRENDMICRO",
          "trend_micro",
          "trendMicro",
          "TREND_MICRO",
          "legacy",
          "Legacy",
          "LEGACY",
          "legacy_api",
          "legacyApi",
          "LegacyApi",
          "LEGACY_API",
          "legacy_key",
          "legacyKey",
          "LegacyKey",
          "LEGACY_KEY",
          "api_key",
          "apiKey",
          "API_KEY",
          "ds_api_key",
          "dsApiKey",
          "DS_API_KEY",
          "dsm_api_key",
          "dsmApiKey",
          "DSM_API_KEY",
          "deep_security_key",
          "deepSecurityKey",
          "DeepSecurityKey",
          "DEEP_SECURITY_KEY",
          "workload_security",
          "workloadSecurity",
          "WorkloadSecurity",
          "WORKLOAD_SECURITY",
          "intrusion_prevention",
          "intrusionPrevention",
          "IntrusionPrevention",
          "INTRUSION_PREVENTION",
          "security_manager",
          "securityManager",
          "SecurityManager",
          "SECURITY_MANAGER"
        ]
      },
      {
        "type": "regex",
        "pattern": "(?:deep[_-]?security|Deep[_-]?Security|DEEP[_-]?SECURITY|dsm|DSM|ds)[_-]?(?:api|API|key|KEY|token|TOKEN|auth|AUTH)[_-]?(?:key|KEY|token|TOKEN)?[\"'\\s]*[:=][\"'\\s]*[A-Za-z0-9]{32,60}",
        "message": "Trend Micro Deep Security legacy API credential detected in variable assignment. Deep Security Manager (DSM) legacy credentials provide administrative access to workload protection services, security policy management, and vulnerability scanning. Exposing these legacy credentials enables unauthorized access to security configurations and infrastructure protections. Migrate to Trend Cloud One and use secure credential storage for any remaining legacy systems.",
