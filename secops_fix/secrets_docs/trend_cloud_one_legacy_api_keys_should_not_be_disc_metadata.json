      },
      {
        "type": "regex",
        "pattern": "(?:Authorization|authorization)[\"'\\s]*:[\"'\\s]*(?:Basic|basic|BASIC)\\s+[A-Za-z0-9+/]{40,}={0,2}",
        "message": "Trend Micro Deep Security legacy Basic authentication detected in authorization header. Deep Security Manager traditionally used Basic authentication with encoded credentials for API access. Exposing these authorization headers allows unauthorized administrative access to legacy security infrastructure, policy management, and vulnerability scanning systems. Migrate to Trend Cloud One and implement secure authentication.",
