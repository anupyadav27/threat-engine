          "Callback",
          "CALLBACK",
          "redirect",
          "Redirect",
          "REDIRECT",
          "flow",
          "Flow",
          "FLOW",
          "exchange"
        ]
      },
      {
        "type": "regex",
        "pattern": "(?:twitch_|TWITCH_|Twitch|twitch|TWITCH)[_-]?(?:oauth|OAuth|OAUTH)[_-]?(?:client_secret|CLIENT_SECRET|client-secret|clientSecret|ClientSecret|secret|SECRET|Secret|credentials|CREDENTIALS|Credentials)[\"'\\s]*[:=][\"'\\s]*[A-Za-z0-9_-]{40,80}",
        "message": "Twitch OAuth client secret detected in variable assignment. Client secrets are confidential credentials used with client IDs to authenticate your application with Twitch's OAuth service. Exposing client secrets allows attackers to impersonate your application, request tokens on behalf of users, and potentially access user data through your application's permissions. Store client secrets securely and rotate immediately if exposed.",
