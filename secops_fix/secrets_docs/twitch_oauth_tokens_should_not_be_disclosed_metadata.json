{
  "filename": "twitch_oauth_tokens_should_not_be_disclosed_metadata.json",
  "rule_id": "twitch_oauth_tokens_disclosed",
  "title": "Twitch OAuth tokens should not be disclosed",
  "description": "In most cases, trust boundaries are violated when a secret is exposed in a source code repository or an uncontrolled deployment environment. Unintended people who don\u2019t need to know the secret might get access to it. They might then be able to use it to gain unwanted access to associated services or resources.",
  "status": "ready",
  "defaultSeverity": "Info",
  "category": "Security",
  "recommendation": "Review and fix according to the rule guidelines.",
  "impact": "Security risk",
  "tags": [
    "security",
    "cwe"
  ],
  "examples": {
    "noncompliant": [],
    "compliant": []
  },
  "references": [
    "https://rules.sonarsource.com/secrets/RSPEC-7375"
  ],
  "logic": {
    "node_types": [],
    "checks": [
      {
        "type": "regex",
        "pattern": "\\b[A-Za-z0-9_-]{64,128}\\b",
        "message": "Twitch OAuth refresh token detected in source code. OAuth refresh tokens are long-lived credentials used to obtain new access tokens without user re-authentication. Exposing refresh tokens allows attackers to maintain persistent access to Twitch accounts, generate unlimited access tokens, and perform actions on behalf of users indefinitely. Revoke this refresh token immediately in Twitch Developer Console.",
        "context_keywords": [
          "twitch",
          "Twitch",
          "TWITCH",
          "oauth",
          "OAuth",
          "OAUTH",
          "oauth2",
          "OAuth2",
          "OAUTH2",
          "refresh_token",
          "refreshToken",
          "RefreshToken",
          "REFRESH_TOKEN",
          "refresh-token",
          "twitch_refresh_token",
          "twitchRefreshToken",
          "TwitchRefreshToken",
          "TWITCH_REFRESH_TOKEN",
          "twitch-refresh-token",
          "twitch_oauth_refresh",
          "twitchOauthRefresh",
          "TWITCH_OAUTH_REFRESH",
          "oauth_refresh_token",
          "oauthRefreshToken",
          "OAUTH_REFRESH_TOKEN",
          "refresh",
          "Refresh",
          "REFRESH",
          "token_refresh",
          "tokenRefresh",
          "TOKEN_REFRESH",
          "credentials",
          "Credentials",
          "CREDENTIALS",
          "auth",
          "Auth",
          "AUTH",
          "authentication",
          "Authorization",
          "AUTHORIZATION",
