      {
        "type": "regex",
        "pattern": "(?:twitch_|TWITCH_|Twitch|twitch|TWITCH)[_-]?(?:oauth|OAuth|OAUTH)[_-]?(?:access_token|ACCESS_TOKEN|access-token|accessToken|AccessToken|token|TOKEN|Token|bearer_token|BEARER_TOKEN|bearer-token|bearerToken|BearerToken)[\"'\\s]*[:=][\"'\\s]*[a-z0-9]{30,50}",
        "message": "Twitch OAuth access token detected in variable assignment. OAuth access tokens provide authenticated API access with specific scopes and permissions granted by users during the OAuth authorization flow. Exposing OAuth access tokens enables unauthorized access to user data, channel management, stream operations, and any other permissions granted to your application. Store OAuth tokens securely and implement proper token rotation.",
