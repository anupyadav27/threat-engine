          "Client",
          "CLIENT",
          "application",
          "Application",
          "APPLICATION",
          "api",
          "Api",
          "API",
          "helix"
        ]
      },
      {
        "type": "regex",
        "pattern": "\\b[A-Za-z0-9_-]{30,40}\\b",
        "message": "Twitch OAuth authorization code detected in source code. Authorization codes are temporary credentials issued during the OAuth flow to exchange for access tokens. While short-lived (10 minutes), exposing authorization codes can allow attackers to complete the OAuth flow and gain user access tokens with full user permissions. Never log or store authorization codes in source code.",
        "context_keywords": [
          "twitch",
          "Twitch",
          "TWITCH",
          "oauth",
          "OAuth",
          "OAUTH",
          "oauth2",
          "OAuth2",
