{
  "filename": "tailscale_webhook_keys_should_not_be_disclosed_metadata.json",
  "rule_id": "tailscale_webhook_keys_disclosed",
  "title": "Tailscale webhook keys should not be disclosed",
  "description": "In most cases, trust boundaries are violated when a secret is exposed in a source code repository or an uncontrolled deployment environment. Unintended people who don\u2019t need to know the secret might get access to it. They might then be able to use it to gain unwanted access to associated services or resources.",
  "status": "ready",
  "defaultSeverity": "Info",
  "category": "Security",
  "recommendation": "Review and fix according to the rule guidelines.",
  "impact": "Security risk",
  "tags": [
    "security",
    "cwe"
  ],
  "examples": {
    "noncompliant": [],
    "compliant": []
  },
  "references": [
    "https://rules.sonarsource.com/secrets/RSPEC-7368"
  ],
  "logic": {
    "node_types": [],
    "checks": [
      {
        "type": "regex",
        "pattern": "\\btskey-webhook-[A-Za-z0-9]{16,32}\\b",
        "message": "Tailscale webhook key detected in source code. Webhook keys are signing secrets used to verify event signatures from Tailscale webhooks, enabling secure event processing and authentication. Exposing these keys allows unauthorized parties to forge webhook events and potentially manipulate your webhook processing systems. Revoke this key immediately and store webhook keys securely in environment variables or secret management systems.",
