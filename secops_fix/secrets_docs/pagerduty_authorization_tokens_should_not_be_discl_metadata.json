{
  "filename": "pagerduty_authorization_tokens_should_not_be_discl_metadata.json",
  "rule_id": "pagerduty_authorization_tokens_disclosed",
  "title": "PagerDuty authorization tokens should not be disclosed",
  "description": "In most cases, trust boundaries are violated when a secret is exposed in a source code repository or an uncontrolled deployment environment. Unintended people who don\u2019t need to know the secret might get access to it. They might then be able to use it to gain unwanted access to associated services or resources.",
  "status": "ready",
  "defaultSeverity": "Info",
  "category": "Security",
  "recommendation": "Review and fix according to the rule guidelines.",
  "impact": "Security risk",
  "tags": [
    "security",
    "cwe"
  ],
  "examples": {
    "noncompliant": [],
    "compliant": []
  },
  "references": [
    "https://rules.sonarsource.com/secrets/RSPEC-7314"
  ],
  "logic": {
    "node_types": [],
    "checks": [
      {
        "type": "regex",
        "pattern": "\\b[a-z][a-z0-9]{19}\\b",
        "message": "PagerDuty API token detected in source code. PagerDuty API tokens provide programmatic access to incident management, on-call schedules, escalation policies, and alerting systems. Exposing these tokens enables unauthorized access to create/modify incidents, alter on-call schedules, access sensitive alert data, and disrupt critical operational workflows. Revoke this token immediately and store tokens securely in environment variables or secret management systems.",
        "context_keywords": [
          "pagerduty",
          "PagerDuty",
          "PAGERDUTY",
          "pager_duty",
          "pagerDuty",
          "PAGER_DUTY",
          "pagerduty_token",
          "pagerdutyToken",
          "PAGERDUTY_TOKEN",
          "pagerduty_api",
          "pagerdutyApi",
          "PAGERDUTY_API",
          "pagerduty_api_token",
          "pagerdutyApiToken",
          "PAGERDUTY_API_TOKEN",
          "pagerduty_key",
          "pagerdutyKey",
          "PAGERDUTY_KEY",
          "api_token",
          "apiToken",
          "API_TOKEN",
          "access_token",
          "accessToken",
          "ACCESS_TOKEN",
          "auth_token",
          "authToken",
          "AUTH_TOKEN",
          "token",
          "Token",
          "TOKEN",
          "api_key",
          "apiKey",
          "API_KEY",
          "bearer",
          "Bearer",
          "BEARER",
          "authorization",
          "Authorization",
          "AUTHORIZATION",
          "api.pagerduty.com",
          "pagerduty.com/api",
          "incident_key",
          "incidentKey",
          "INCIDENT_KEY",
          "integration_key",
          "integrationKey",
          "INTEGRATION_KEY",
          "routing_key",
          "routingKey",
          "ROUTING_KEY",
          "service_key",
          "serviceKey",
          "SERVICE_KEY"
        ]
      },
      {
        "type": "regex",
        "pattern": "\\b[a-f0-9]{32}\\b",
        "message": "PagerDuty integration key detected in source code. PagerDuty integration keys are used for Events API v1 to send incident data. Exposing these keys allows attackers to trigger false alerts, suppress real incidents, and manipulate your incident response system.",
        "context_keywords": [
          "pagerduty",
          "PagerDuty",
          "PAGERDUTY",
          "pager_duty",
          "pagerDuty",
          "PAGER_DUTY",
          "integration_key",
          "integrationKey",
          "INTEGRATION_KEY",
          "service_key",
          "serviceKey",
          "SERVICE_KEY",
          "pagerduty_key",
          "pagerdutyKey",
          "PAGERDUTY_KEY",
          "incident_key",
          "incidentKey",
          "INCIDENT_KEY",
          "events_api",
          "eventsApi",
          "EVENTS_API",
          "api.pagerduty.com",
          "events.pagerduty.com"
        ]
      },
      {
        "type": "regex",
        "pattern": "Authorization[\"'\\s]*[:=][\"'\\s]*Token\\s+[a-z][a-z0-9]{19,}",
        "message": "PagerDuty API token detected in Authorization header. Token-based authentication provides full access to PagerDuty APIs for managing incidents, schedules, and alerts.",
        "context_keywords": [
          "pagerduty",
          "PagerDuty",
          "PAGERDUTY",
          "authorization",
          "Authorization",
          "AUTHORIZATION",
          "token",
          "Token",
          "TOKEN",
          "api.pagerduty.com",
          "pagerduty_api",
          "pagerdutyApi",
          "PAGERDUTY_API"
        ]
      }
    ]
  }
}