{
  "filename": "langchain_api_keys_should_not_be_disclosed_metadata.json",
  "rule_id": "langchain_api_keys_disclosed",
  "title": "Langchain API keys should not be disclosed",
  "description": "In most cases, trust boundaries are violated when a secret is exposed in a source code repository or an uncontrolled deployment environment. Unintended people who don\u2019t need to know the secret might get access to it. They might then be able to use it to gain unwanted access to associated services or resources.",
  "status": "ready",
  "defaultSeverity": "Info",
  "category": "Security",
  "recommendation": "Review and fix according to the rule guidelines.",
  "impact": "Security risk",
  "tags": [
    "security",
    "cwe"
  ],
  "examples": {
    "noncompliant": [],
    "compliant": []
  },
  "references": [
    "https://rules.sonarsource.com/secrets/RSPEC-7291"
  ],
  "logic": {
    "node_types": [],
    "checks": [
      {
        "type": "regex",
        "pattern": "lsv2_sk_[a-zA-Z0-9_-]{32,64}",
        "message": "Detected LangSmith secret API key (lsv2_sk_). Exposing this key allows unauthorized access to LangSmith tracing, debugging, and monitoring services, enabling attackers to view application traces, LLM interactions, and potentially sensitive data processed through LangChain applications.",
        "context_keywords": [
          "langchain",
          "LangChain",
          "LANGCHAIN",
          "langsmith",
          "LangSmith",
          "LANGSMITH",
          "lsv2_sk",
          "lsv2_pk",
          "api_key",
          "apiKey",
          "api-key",
          "API_KEY",
          "LANGCHAIN_API_KEY",
          "LANGSMITH_API_KEY",
          "langchain_api_key",
          "langsmith_api_key",
          "langchainApiKey",
          "langsmithApiKey",
          "tracing_key",
          "tracingKey",
          "tracing_api_key",
          "tracingApiKey",
          "llm_tracing",
          "llmTracing",
          "langchain_tracing",
          "langchainTracing",
          "smith_api_key",
          "smithApiKey",
          "langchain.com",
          "smith.langchain.com",
          "api.smith.langchain.com",
          "LangChainTracer",
          "langchain_tracer",
          "tracing",
          "monitoring",
          "observability",
          "debug",
          "evaluation",
          "llm",
          "chain",
          "agent",
          "callback"
        ]
      },
      {
        "type": "regex",
        "pattern": "lsv2_pk_[a-zA-Z0-9_-]{32,64}",
        "message": "Detected LangSmith public API key (lsv2_pk_). While public keys are less sensitive than secret keys, exposing them can still allow unauthorized access to read-only operations on your LangSmith account, potentially exposing project structure and configuration details.",
        "context_keywords": [
          "langchain",
          "LangChain",
          "LANGCHAIN",
          "langsmith",
          "LangSmith",
          "LANGSMITH",
          "lsv2_sk",
          "lsv2_pk",
          "api_key",
          "apiKey",
          "api-key",
          "API_KEY",
          "LANGCHAIN_API_KEY",
          "LANGSMITH_API_KEY",
          "langchain_api_key",
          "langsmith_api_key",
          "langchainApiKey",
          "langsmithApiKey",
          "public_key",
          "publicKey",
          "public_api_key",
          "publicApiKey",
          "tracing_key",
          "tracingKey",
          "tracing_api_key",
          "tracingApiKey",
          "llm_tracing",
          "llmTracing",
          "langchain_tracing",
          "langchainTracing",
          "smith_api_key",
          "smithApiKey",
          "langchain.com",
          "smith.langchain.com",
          "api.smith.langchain.com",
          "LangChainTracer",
          "langchain_tracer",
          "tracing",
          "monitoring",
          "observability",
          "debug",
