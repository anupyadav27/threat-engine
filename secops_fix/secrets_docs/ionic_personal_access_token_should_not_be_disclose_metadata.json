{
  "filename": "ionic_personal_access_token_should_not_be_disclose_metadata.json",
  "rule_id": "ionic_personal_access_token",
  "title": "Ionic personal access token should not be disclosed",
  "description": "In most cases, trust boundaries are violated when a secret is exposed in a source code repository or an uncontrolled deployment environment. Unintended people who don\u2019t need to know the secret might get access to it. They might then be able to use it to gain unwanted access to associated services or resources.",
  "status": "ready",
  "defaultSeverity": "Info",
  "category": "Security",
  "recommendation": "Review and fix according to the rule guidelines.",
  "impact": "Security risk",
  "tags": [
    "security",
    "cwe"
  ],
  "examples": {
    "noncompliant": [],
    "compliant": []
  },
  "references": [
    "https://rules.sonarsource.com/secrets/RSPEC-7199"
  ],
  "logic": {
    "node_types": [],
    "checks": [
      {
        "type": "regex",
        "pattern": "\\b(?:ion_)?[A-Za-z0-9_-]{32,80}\\b",
        "message": "Ionic personal access token detected in source code",
        "context_keywords": [
          "ionic",
          "Ionic",
          "IONIC",
          "ionic_token",
          "ionicToken",
          "ionic_pat",
          "ionic_key",
          "ionic_access",
          "IONIC_TOKEN",
          "IONIC_PAT",
          "appflow",
          "Appflow",
          "APPFLOW",
          "appflow_token",
          "appflowToken",
          "ionic_appflow",
          "ionicAppflow",
          "ionic.io",
          "ionicframework.com",
          "api.ionic.io",
          "dashboard.ionicframework.com",
          "personal_access_token",
          "personalAccessToken",
          "access_token",
          "accessToken",
          "bearer",
          "authorization",
          "ionic_cli",
          "ionicCli",
          "ionic_auth",
          "ionicAuth",
          "capacitor",
          "cordova",
          "ionic_api",
          "ionicApi"
        ]
      }
    ]
  }
}