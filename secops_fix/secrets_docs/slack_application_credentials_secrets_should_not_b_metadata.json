{
  "filename": "slack_application_credentials_secrets_should_not_b_metadata.json",
  "rule_id": "slack_application_credentials_secrets",
  "title": "Slack Application Credentials secrets should not be disclosed",
  "description": "In most cases, trust boundaries are violated when a secret is exposed in a source code repository or an uncontrolled deployment environment. Unintended people who don\u2019t need to know the secret might get access to it. They might then be able to use it to gain unwanted access to associated services or resources.",
  "status": "ready",
  "defaultSeverity": "Info",
  "category": "Security",
  "recommendation": "Review and fix according to the rule guidelines.",
  "impact": "Security risk",
  "tags": [
    "security",
    "cwe"
  ],
  "examples": {
    "noncompliant": [],
    "compliant": []
  },
  "references": [
    "https://rules.sonarsource.com/secrets/RSPEC-7348"
  ],
  "logic": {
    "node_types": [],
    "checks": [
      {
        "type": "regex",
        "pattern": "\\b\\d{10,13}\\.\\d{10,13}\\b",
        "message": "Slack OAuth Client ID detected in source code. This Client ID is used for OAuth applications to authenticate with Slack's API. While the Client ID itself is considered public in OAuth flows, exposing it in source code along with the Client Secret poses a security risk. Attackers with access to both credentials can: impersonate your application, request OAuth tokens on behalf of users, access Slack workspaces where your app is installed, perform actions with your app's permissions and scopes, and potentially exhaust API rate limits under your app's quota. Immediately rotate the Client Secret associated with this Client ID through the Slack App Management console, generate a new Client Secret and update production systems, store Client ID and Client Secret in environment variables or secure secret management systems (AWS Secrets Manager, HashiCorp Vault, Azure Key Vault), never commit OAuth credentials to version control, implement secret scanning in CI/CD pipelines, use different credentials for development/staging/production environments, and enable Slack's security features like token rotation and audit logs.",
