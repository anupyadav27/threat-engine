{
  "filename": "readme_api_keys_should_not_be_disclosed_metadata.json",
  "rule_id": "readme_api_keys_disclosed",
  "title": "Readme API keys should not be disclosed",
  "description": "In most cases, trust boundaries are violated when a secret is exposed in a source code repository or an uncontrolled deployment environment. Unintended people who don\u2019t need to know the secret might get access to it. They might then be able to use it to gain unwanted access to associated services or resources.",
  "status": "ready",
  "defaultSeverity": "Info",
  "category": "Security",
  "recommendation": "Review and fix according to the rule guidelines.",
  "impact": "Security risk",
  "tags": [
    "security",
    "cwe"
  ],
  "examples": {
    "noncompliant": [],
    "compliant": []
  },
  "references": [
    "https://rules.sonarsource.com/secrets/RSPEC-7334"
  ],
  "logic": {
    "node_types": [],
    "checks": [
      {
        "type": "regex",
        "pattern": "\\brdme_[A-Za-z0-9]{32,64}\\b",
        "message": "Readme API key detected in source code. Readme API keys provide programmatic access to your documentation platform including content management, metrics, and user tracking. Exposing these credentials allows attackers to modify documentation, access analytics data, and manipulate user experiences. IMMEDIATELY rotate this key and store securely using environment variables or secret management systems (AWS Secrets Manager, Azure Key Vault, HashiCorp Vault).",
        "context_keywords": [
          "readme",
          "ReadMe",
          "README",
          "Readme",
          "readme_api",
          "readmeApi",
          "ReadMeApi",
          "README_API",
