        "pattern": "(?i)(x-readme-api-key|X_README_API_KEY|readme[_-]?api[_-]?key|README[_-]?API[_-]?KEY|readme[_-]?key|README[_-]?KEY)\\s*[:=]\\s*[\"']?([A-Za-z0-9_-]{32,64})[\"']?",
