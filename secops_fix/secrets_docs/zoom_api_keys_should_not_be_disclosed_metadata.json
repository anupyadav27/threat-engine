{
  "filename": "zoom_api_keys_should_not_be_disclosed_metadata.json",
  "rule_id": "zoom_api_keys_disclosed",
  "title": "Zoom API keys should not be disclosed",
  "description": "In most cases, trust boundaries are violated when a secret is exposed in a source code repository or an uncontrolled deployment environment. Unintended people who don\u2019t need to know the secret might get access to it. They might then be able to use it to gain unwanted access to associated services or resources.",
  "status": "ready",
  "defaultSeverity": "Info",
  "category": "Security",
  "recommendation": "Review and fix according to the rule guidelines.",
  "impact": "Security risk",
  "tags": [
    "security",
    "cwe"
  ],
  "examples": {
    "noncompliant": [],
    "compliant": []
  },
  "references": [
    "https://rules.sonarsource.com/secrets/RSPEC-7563"
  ],
  "logic": {
    "node_types": [],
    "checks": [
      {
        "type": "regex",
        "pattern": "\\b[A-Za-z0-9_-]{20,80}\\b",
        "message": "Zoom API Key detected. API Keys (also called SDK Keys or Client IDs in Zoom SDK and OAuth apps) identify your Zoom application and are used with API Secrets to authenticate API requests and generate JWT tokens. Exposing API Keys can lead to unauthorized API access when combined with the API Secret, enabling attackers to impersonate your application, access meeting data, manage users, and perform other privileged operations. Immediately regenerate your API credentials in the Zoom Marketplace and review all API access logs for suspicious activity.",
