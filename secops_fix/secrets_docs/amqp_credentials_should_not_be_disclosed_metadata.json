{
  "filename": "amqp_credentials_should_not_be_disclosed_metadata.json",
  "rule_id": "amqp_credentials_disclosed",
  "title": "AMQP credentials should not be disclosed",
  "description": "In most cases, trust boundaries are violated when a secret is exposed in a source code repository or an uncontrolled deployment environment. Unintended people who don\u2019t need to know the secret might get access to it. They might then be able to use it to gain unwanted access to associated services or resources.",
  "status": "ready",
  "defaultSeverity": "Info",
  "category": "Security",
  "recommendation": "Review and fix according to the rule guidelines.",
  "impact": "Security risk",
  "tags": [
    "security",
    "cwe"
  ],
  "examples": {
    "noncompliant": [],
    "compliant": [
      {
        "code": "AMQP_URL = os.environ.get('AMQP_CONNECTION_STRING')",
        "description": "AMQP connection string retrieved from environment variable"
      },
      {
        "code": "const amqpUrl = process.env.RABBITMQ_URL",
        "description": "AMQP URL retrieved from environment"
      }
    ]
  },
  "references": [
    "https://rules.sonarsource.com/secrets/RSPEC-6736"
  ],
  "logic": {
    "node_types": [],
    "checks": [
      {
        "type": "regex",
        "pattern": "amqps?://[a-zA-Z0-9._-]+:[^@\\s]+@[a-zA-Z0-9._-]+(?::[0-9]{1,5})?(?:/[^\\s]*)?",
        "message": "AMQP connection string with embedded credentials detected in source code",
        "context_keywords": [
          "amqp",
          "rabbitmq",
          "rabbit",
          "AMQP_URL",
          "RABBITMQ_URL",
          "message_broker",
          "queue",
          "broker"
        ]
      },
      {
        "type": "regex",
        "pattern": "amqps?://[^:]+:[^@]+@",
        "message": "AMQP URL with username and password detected in source code",
        "context_keywords": [
          "amqp",
          "rabbitmq",
          "connection",
          "broker",
          "queue",
          "message",
          "mq"
        ]
      },
      {
        "type": "regex",
        "pattern": "\\b[a-zA-Z0-9._-]{3,20}:[a-zA-Z0-9@!#$%^&*()_+={}\\[\\]|:;<>,.?/~`-]{6,}@[a-zA-Z0-9._-]+:[0-9]{4,5}",
        "message": "Potential credentials in host:port connection format detected in source code",
        "context_keywords": [
          "amqp",
          "rabbitmq",
          "rabbit",
          "broker",
          "connection_string",
          "AMQP",
          "RABBITMQ",
          "queue"
        ]
      }
    ]
  }
}