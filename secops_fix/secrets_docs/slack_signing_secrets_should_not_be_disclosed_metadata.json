{
  "filename": "slack_signing_secrets_should_not_be_disclosed_metadata.json",
  "rule_id": "slack_signing_secrets_disclosed",
  "title": "Slack signing secrets should not be disclosed",
  "description": "In most cases, trust boundaries are violated when a secret is exposed in a source code repository or an uncontrolled deployment environment. Unintended people who don\u2019t need to know the secret might get access to it. They might then be able to use it to gain unwanted access to associated services or resources.",
  "status": "ready",
  "defaultSeverity": "Info",
  "category": "Security",
  "recommendation": "Review and fix according to the rule guidelines.",
  "impact": "Security risk",
  "tags": [
    "security",
    "cwe"
  ],
  "examples": {
    "noncompliant": [],
    "compliant": []
  },
  "references": [
    "https://rules.sonarsource.com/secrets/RSPEC-7352"
  ],
  "logic": {
    "node_types": [],
    "checks": [
      {
        "type": "regex",
        "pattern": "\\b[a-f0-9]{32}\\b",
        "message": "Slack Signing Secret detected in source code. This 32-character hexadecimal string is a highly sensitive credential used to verify that requests to your Slack app are actually coming from Slack. Exposing the Signing Secret enables attackers to: forge requests that appear to come from Slack, bypass request verification and validation checks, send malicious payloads to your app endpoints, impersonate Slack to trigger unauthorized actions, execute commands or workflows without proper authorization, compromise the integrity of your Slack integration, potentially access sensitive data or perform destructive operations, and undermine the trust relationship between Slack and your application. This is a critical security vulnerability. Take immediate action: revoke the compromised Signing Secret in the Slack App Management console (https://api.slack.com/apps), generate a new Signing Secret immediately, update all production systems and services with the new secret, review application logs for suspicious request patterns or potential exploitation, store Signing Secret in secure secret management systems (AWS Secrets Manager, HashiCorp Vault, Azure Key Vault), never commit secrets to version control or expose them in logs, use environment variables with restricted access, implement secret scanning and monitoring in CI/CD pipelines, and ensure proper request verification is implemented in all Slack endpoints.",
