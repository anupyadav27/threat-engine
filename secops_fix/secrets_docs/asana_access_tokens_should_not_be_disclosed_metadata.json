{
  "filename": "asana_access_tokens_should_not_be_disclosed_metadata.json",
  "rule_id": "asana_access_tokens_disclosed",
  "title": "Asana access tokens should not be disclosed",
  "description": "In most cases, trust boundaries are violated when a secret is exposed in a source code repository or an uncontrolled deployment environment. Unintended people who don\u2019t need to know the secret might get access to it. They might then be able to use it to gain unwanted access to associated services or resources.",
  "status": "ready",
  "defaultSeverity": "Info",
  "category": "Security",
  "recommendation": "Review and fix according to the rule guidelines.",
  "impact": "Security risk",
  "tags": [
    "security",
    "cwe"
  ],
  "examples": {
    "noncompliant": [],
    "compliant": [
      {
        "code": "ASANA_ACCESS_TOKEN = os.environ.get('ASANA_ACCESS_TOKEN')",
        "description": "Asana token retrieved from environment variable"
      },
      {
        "code": "const token = process.env.ASANA_TOKEN",
        "description": "Asana token retrieved from environment"
      }
    ]
  },
  "references": [
    "https://rules.sonarsource.com/secrets/RSPEC-7215"
  ],
  "logic": {
    "node_types": [],
    "checks": [
      {
        "type": "regex",
        "pattern": "\\b[0-9]/[a-f0-9]{32}\\b",
        "message": "Asana personal access token detected in source code",
        "context_keywords": [
          "asana",
          "ASANA",
          "asana_token",
          "asana_access_token",
          "ASANA_TOKEN",
          "ASANA_ACCESS_TOKEN",
          "asana_pat",
          "asana_api",
          "api",
          "token",
          "authorization",
          "bearer",
          "auth",
          "credentials",
          "client"
        ]
      },
      {
        "type": "regex",
        "pattern": "\\b[0-9]/[A-Fa-f0-9]{32}\\b",
        "message": "Asana access token (mixed case) detected in source code",
        "context_keywords": [
          "asana",
          "ASANA",
          "token",
          "access",
          "api",
          "authorization",
          "bearer",
          "auth",
          "credentials",
          "pat"
        ]
      },
      {
        "type": "regex",
        "pattern": "Bearer\\s+[0-9]/[a-f0-9A-F]{32}",
        "message": "Asana bearer token detected in authorization header",
        "context_keywords": [
          "asana",
          "ASANA",
          "authorization",
          "bearer",
          "header",
          "auth",
          "token",
          "api"
        ]
      }
    ]
  }
}