{
  "filename": "palantir_jwts_should_not_be_disclosed_metadata.json",
  "rule_id": "palantir_jwts_disclosed",
  "title": "Palantir JWTs should not be disclosed",
  "description": "In most cases, trust boundaries are violated when a secret is exposed in a source code repository or an uncontrolled deployment environment. Unintended people who don\u2019t need to know the secret might get access to it. They might then be able to use it to gain unwanted access to associated services or resources.",
  "status": "ready",
  "defaultSeverity": "Info",
  "category": "Security",
  "recommendation": "Review and fix according to the rule guidelines.",
  "impact": "Security risk",
  "tags": [
    "security",
    "cwe"
  ],
  "examples": {
    "noncompliant": [],
    "compliant": []
  },
  "references": [
    "https://rules.sonarsource.com/secrets/RSPEC-7315"
  ],
  "logic": {
    "checks": [
      {
        "type": "regex",
        "pattern": "\\beyJ[A-Za-z0-9_-]{20,}\\.eyJ[A-Za-z0-9_-]{20,}\\.[A-Za-z0-9_-]{20,}\\b",
        "message": "Palantir Foundry JWT token detected. JWT (JSON Web Token) tokens provide authentication to Palantir Foundry platform. Exposing these tokens allows attackers to access your Foundry resources, datasets, applications, and potentially perform unauthorized operations. Rotate tokens immediately if exposed.",
        "context_keywords": [
          "palantir",
          "Palantir",
          "PALANTIR",
          "foundry",
          "Foundry",
          "FOUNDRY",
          "jwt",
          "JWT",
          "Json Web Token",
          "bearer",
          "Bearer",
          "BEARER",
          "authorization",
          "Authorization",
          "AUTHORIZATION",
          "access_token",
          "accessToken",
          "ACCESS_TOKEN",
          "auth_token",
          "authToken",
          "AUTH_TOKEN",
          "token",
          "Token",
          "TOKEN",
          "palantir_token",
          "palantirToken",
          "PALANTIR_TOKEN",
          "foundry_token",
          "foundryToken",
          "FOUNDRY_TOKEN",
          "palantir_jwt",
          "palantirJwt",
          "PALANTIR_JWT",
          "foundry_jwt",
          "foundryJwt",
          "FOUNDRY_JWT",
          "palantir_auth",
          "palantirAuth",
          "PALANTIR_AUTH",
          "foundry_auth",
          "foundryAuth",
          "FOUNDRY_AUTH",
          "palantir_api",
          "palantirApi",
          "PALANTIR_API",
          "foundry_api",
          "foundryApi",
          "FOUNDRY_API",
          "multipass",
          "Multipass",
          "MULTIPASS"
        ]
      },
      {
        "type": "regex",
        "pattern": "Authorization[\"'\\s]*[:=][\"'\\s]*Bearer\\s+eyJ[A-Za-z0-9_-]{20,}\\.eyJ[A-Za-z0-9_-]{20,}\\.[A-Za-z0-9_-]{20,}",
        "message": "Palantir Foundry JWT token detected in Authorization header. Bearer tokens in authorization headers provide direct API access to Palantir Foundry platform. Exposing these tokens allows attackers to authenticate as you, access datasets, modify resources, and compromise your Foundry environment. Rotate tokens immediately if exposed.",
        "context_keywords": [
          "palantir",
          "Palantir",
          "PALANTIR",
          "foundry",
          "Foundry",
          "FOUNDRY",
          "authorization",
          "Authorization",
          "AUTHORIZATION",
          "bearer",
          "Bearer",
          "BEARER",
          "header",
          "Header",
          "HEADER",
          "jwt",
          "JWT",
          "token",
          "Token",
          "TOKEN",
          "api",
          "Api",
          "API",
          "palantir_request",
          "palantirRequest",
          "PALANTIR_REQUEST",
          "foundry_request",
          "foundryRequest",
          "FOUNDRY_REQUEST"
        ]
      }
    ]
  }
}