{
  "filename": "plaid_keys_should_not_be_disclosed_metadata.json",
  "rule_id": "plaid_keys_disclosed",
  "title": "Plaid keys should not be disclosed",
  "description": "In most cases, trust boundaries are violated when a secret is exposed in a source code repository or an uncontrolled deployment environment. Unintended people who don\u2019t need to know the secret might get access to it. They might then be able to use it to gain unwanted access to associated services or resources.",
  "status": "ready",
  "defaultSeverity": "Info",
  "category": "Security",
  "recommendation": "Review and fix according to the rule guidelines.",
  "impact": "Security risk",
  "tags": [
    "security",
    "cwe"
  ],
  "examples": {
    "noncompliant": [],
    "compliant": []
  },
  "references": [
    "https://rules.sonarsource.com/secrets/RSPEC-7323"
  ],
  "logic": {
    "node_types": [],
    "checks": [
      {
        "type": "regex",
        "pattern": "\\b[a-f0-9]{24,30}\\b",
        "message": "Plaid client ID detected in source code. Client IDs are used to authenticate applications with the Plaid API. While less sensitive than secrets, exposing client IDs in source code reveals application architecture and OAuth2 configuration, making it easier for attackers to target your Plaid integration. Combined with a secret, these credentials enable unauthorized access to Plaid API endpoints and user financial data. Store client IDs as environment variables or in configuration management systems outside version control. Review for adjacent secret exposure.",
        "context_keywords": [
          "plaid",
          "Plaid",
          "PLAID",
          "plaid_api",
          "plaidApi",
