{
  "filename": "slack_bot_tokens_should_not_be_disclosed_metadata.json",
  "rule_id": "slack_bot_tokens_disclosed",
  "title": "Slack bot tokens should not be disclosed",
  "description": "In most cases, trust boundaries are violated when a secret is exposed in a source code repository or an uncontrolled deployment environment. Unintended people who don\u2019t need to know the secret might get access to it. They might then be able to use it to gain unwanted access to associated services or resources.",
  "status": "ready",
  "defaultSeverity": "Info",
  "category": "Security",
  "recommendation": "Review and fix according to the rule guidelines.",
  "impact": "Security risk",
  "tags": [
    "security",
    "cwe"
  ],
  "examples": {
    "noncompliant": [],
    "compliant": []
  },
  "references": [
    "https://rules.sonarsource.com/secrets/RSPEC-6731"
  ],
  "logic": {
    "node_types": [],
    "checks": [
      {
        "type": "regex",
        "pattern": "\\bxoxb-\\d{10,13}-\\d{10,13}-[A-Za-z0-9]{24}\\b",
        "message": "Slack bot token detected in source code. Bot tokens (xoxb-...) provide API access as a bot user within Slack workspaces. These tokens enable bots to read messages, post content, manage channels, access user information, and perform workspace operations based on granted scopes. Exposing bot tokens creates significant security risks: attackers can impersonate your bot within all workspaces where it's installed, read private messages and channel content to which the bot has access, post unauthorized messages or spam to channels, modify channel settings and membership, access sensitive user and workspace information, exfiltrate confidential data from conversations, perform destructive actions like deleting messages or files, and abuse bot permissions to compromise workspace security. Immediate remediation steps: revoke the compromised bot token through the Slack App Management console (https://api.slack.com/apps), generate a new bot token with appropriate OAuth scopes, update all bot instances and services with the new token, review bot access logs for unauthorized activity, audit bot permissions and reduce to minimum required scopes, implement bot activity monitoring and alerts, store bot tokens securely in environment variables or secret management systems (AWS Secrets Manager, HashiCorp Vault, Azure Key Vault), enable workspace audit logging, add token rotation procedures to security policies, never commit bot tokens to version control systems, use separate bot tokens for development, staging, and production environments, and implement IP restrictions where possible.",
