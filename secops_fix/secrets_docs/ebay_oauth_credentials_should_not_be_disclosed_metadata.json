{
  "filename": "ebay_oauth_credentials_should_not_be_disclosed_metadata.json",
  "rule_id": "ebay_oauth_credentials_disclosed",
  "title": "eBay OAuth credentials should not be disclosed",
  "description": "In most cases, trust boundaries are violated when a secret is exposed in a source code repository or an uncontrolled deployment environment. Unintended people who don\u2019t need to know the secret might get access to it. They might then be able to use it to gain unwanted access to associated services or resources.",
  "status": "ready",
  "defaultSeverity": "Info",
  "category": "Security",
  "recommendation": "Review and fix according to the rule guidelines.",
  "impact": "Security risk",
  "tags": [
    "security",
    "cwe"
  ],
  "examples": {
    "noncompliant": [],
    "compliant": [
      {
        "description": "eBay credentials from environment variables",
        "code": "ebay_client_id = os.getenv('EBAY_CLIENT_ID')\nebay_client_secret = os.getenv('EBAY_CLIENT_SECRET')"
      },
      {
        "description": "eBay credentials from configuration service",
        "code": "ebay_credentials = config_service.get_credentials('ebay')\nclient_id = ebay_credentials['client_id']"
      },
      {
        "description": "eBay OAuth using secrets manager",
        "code": "from vault import secrets_manager\nebay_config = secrets_manager.get_secret('ebay/oauth/production')"
      },
      {
        "description": "eBay credentials in documentation (placeholders)",
        "code": "# Configure your eBay credentials:\n# EBAY_CLIENT_ID=your_client_id_here\n# EBAY_CLIENT_SECRET=your_client_secret_here"
      }
    ]
  },
  "references": [
    "https://rules.sonarsource.com/secrets/RSPEC-7153"
  ],
  "logic": {
    "custom_function": "detect_ebay_oauth_credentials",
    "patterns": [
      {
        "type": "ebay_client_id",
        "regex": "\\b[A-Za-z0-9]+-[A-Za-z0-9]+-[A-Za-z0-9]+-[a-z0-9]{5,}\\b",
        "description": "eBay Client ID (App ID) pattern with hyphens"
      },
      {
        "type": "ebay_client_secret",
        "regex": "\\b[A-Z]{3,}-[0-9]{4,}-[A-Z0-9]{4,}-[A-Z0-9]{4,}-[A-Z0-9]{4,}\\b",
        "description": "eBay Client Secret (Cert ID) pattern"
      },
      {
        "type": "ebay_auth_token",
        "regex": "\\bv\\^[0-9]\\.[0-9]#[A-Za-z0-9^#\\-_]+\\b",
        "description": "eBay OAuth authorization token with v^ prefix"
      },
      {
        "type": "ebay_devid",
        "regex": "\\b[a-f0-9]{8}-[a-f0-9]{4}-[a-f0-9]{4}-[a-f0-9]{4}-[a-f0-9]{12}\\b",
        "description": "eBay Developer ID in UUID format"
      },
      {
        "type": "ebay_generic_credential",
        "regex": "\\b[A-Za-z0-9+/=_-]{40,100}\\b",
        "description": "Generic eBay OAuth credential pattern"
      }
    ],
    "context_keywords": [
      "ebay",
      "e_bay",
      "e-bay",
      "ebay_api",
      "ebay_oauth",
      "ebay_auth",
      "client_id",
      "client_secret",
      "app_id",
      "cert_id",
      "dev_id",
      "devid",
      "ebay_app_id",
      "ebay_cert_id",
      "ebay_dev_id",
      "ebay_client_id",
      "ebay_client_secret",
      "ebay_token",
      "ebay_access_token",
      "ebay_refresh_token",
      "runame",
      "ru_name",
      "redirect_url_name",
      "trading_api",
      "finding_api",
      "shopping_api",
      "ebay_sandbox",
      "ebay_production",
      "api.ebay.com",
      "ebay_credentials",
      "oauth_ebay",
      "ebay_authorization"
    ],
    "validation": {
      "min_length": 20,
      "max_length": 100,
      "entropy_threshold": 3.5,
      "character_diversity": 10,
      "requires_context": true,
      "context_required": "ebay"
    }
  }
}