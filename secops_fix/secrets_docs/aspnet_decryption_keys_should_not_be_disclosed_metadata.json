{
  "filename": "aspnet_decryption_keys_should_not_be_disclosed_metadata.json",
  "rule_id": "aspnet_decryption_keys_disclosed",
  "title": "ASP.NET decryption keys should not be disclosed",
  "description": "In most cases, trust boundaries are violated when a secret is exposed in a source code repository or an uncontrolled deployment environment. Unintended people who don\u2019t need to know the secret might get access to it. They might then be able to use it to gain unwanted access to associated services or resources.",
  "status": "ready",
  "defaultSeverity": "Info",
  "category": "Security",
  "recommendation": "Review and fix according to the rule guidelines.",
  "impact": "Security risk",
  "tags": [
    "security",
    "cwe"
  ],
  "examples": {
    "noncompliant": [],
    "compliant": [
      {
        "code": "<machineKey decryptionKey=\"AutoGenerate,IsolateApps\" validationKey=\"AutoGenerate,IsolateApps\" />",
        "description": "Auto-generated machine keys (recommended)"
      },
      {
        "code": "string decryptionKey = ConfigurationManager.AppSettings[\"DecryptionKey\"];",
        "description": "Decryption key retrieved from configuration"
      }
    ]
  },
  "references": [
    "https://rules.sonarsource.com/secrets/RSPEC-7233"
  ],
  "logic": {
    "node_types": [],
    "checks": [
      {
        "type": "regex",
        "pattern": "decryptionKey[\"'\\s:=]*[\"']([A-Fa-f0-9]{48,128})[\"']",
        "message": "ASP.NET decryption key detected in configuration",
        "context_keywords": [
          "machineKey",
          "decryptionKey",
          "ASP.NET",
          "aspnet",
          "web.config",
          "webconfig",
          "decryption",
          "AES",
          "3DES",
          "DES",
          "machine",
          "key",
          "config",
          "configuration",
          "DecryptionKey",
          "MachineKey"
        ]
      },
      {
        "type": "regex",
        "pattern": "validationKey[\"'\\s:=]*[\"']([A-Fa-f0-9]{64,128})[\"']",
        "message": "ASP.NET validation key detected in configuration",
        "context_keywords": [
          "machineKey",
          "validationKey",
          "ASP.NET",
          "aspnet",
          "web.config",
          "webconfig",
          "validation",
          "SHA1",
          "SHA256",
          "MD5",
          "HMACSHA256",
          "machine",
          "key",
          "config",
          "configuration",
          "ValidationKey",
          "MachineKey"
        ]
      },
      {
        "type": "regex",
        "pattern": "\\b[A-F0-9]{48,128}\\b",
        "message": "Potential ASP.NET machine key (hex string) detected",
        "context_keywords": [
          "machineKey",
          "decryptionKey",
          "validationKey",
          "ASP.NET",
          "aspnet",
          "DecryptionKey",
          "ValidationKey",
          "MachineKey",
          "decryption",
          "validation",
          "web.config",
          "machine",
          "key",
          "DECRYPTION",
          "VALIDATION"
        ]
      }
    ]
  }
}