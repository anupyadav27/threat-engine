{
  "filename": "jetbrains_teamcity_scrambled_secrets_should_not_be_metadata.json",
  "rule_id": "jetbrains_teamcity_scrambled_secrets",
  "title": "Jetbrains TeamCity scrambled secrets should not be disclosed",
  "description": "In most cases, trust boundaries are violated when a secret is exposed in a source code repository or an uncontrolled deployment environment. Unintended people who don\u2019t need to know the secret might get access to it. They might then be able to use it to gain unwanted access to associated services or resources.",
  "status": "ready",
  "defaultSeverity": "Info",
  "category": "Security",
  "recommendation": "Review and fix according to the rule guidelines.",
  "impact": "Security risk",
  "tags": [
    "security",
    "cwe"
  ],
  "examples": {
    "noncompliant": [],
    "compliant": []
  },
  "references": [
    "https://rules.sonarsource.com/secrets/RSPEC-7283"
  ],
  "logic": {
    "node_types": [],
    "checks": [
      {
        "type": "regex",
        "pattern": "\\bscrambled:[A-Za-z0-9+/=]{20,}\\b",
        "message": "TeamCity scrambled secret detected - these obfuscated credentials should not be exposed in source code",
