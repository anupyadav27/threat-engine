{
  "filename": "okta_oidc_client_secrets_should_not_be_disclosed_metadata.json",
  "rule_id": "okta_oidc_client_secrets",
  "title": "Okta OIDC client secrets should not be disclosed",
  "description": "In most cases, trust boundaries are violated when a secret is exposed in a source code repository or an uncontrolled deployment environment. Unintended people who don\u2019t need to know the secret might get access to it. They might then be able to use it to gain unwanted access to associated services or resources.",
  "status": "ready",
  "defaultSeverity": "Info",
  "category": "Security",
  "recommendation": "Review and fix according to the rule guidelines.",
  "impact": "Security risk",
  "tags": [
    "security",
    "cwe"
  ],
  "examples": {
    "noncompliant": [],
    "compliant": []
  },
  "references": [
    "https://rules.sonarsource.com/secrets/RSPEC-7559"
  ],
  "logic": {
    "node_types": [],
    "checks": [
      {
        "type": "regex",
        "pattern": "(?:OKTA_CLIENT_SECRET|okta_client_secret|OKTA_OIDC_SECRET|okta_oidc_secret|OKTA_OAUTH_SECRET|okta_oauth_secret|oktaClientSecret|oktaOidcSecret|oktaOauthSecret)[\"'\\s]*[:=][\"'\\s]*[A-Za-z0-9_-]{40,}",
        "message": "Okta OIDC client secret detected in variable assignment. Okta OIDC/OAuth2 client secrets provide authentication for applications using OpenID Connect. Exposing these secrets allows unauthorized users to impersonate your application, obtain access tokens, authenticate as your service, and access protected resources on behalf of users. This can lead to unauthorized access to user data, identity theft, and account takeovers. Store client secrets securely using environment variables or secret management systems.",
