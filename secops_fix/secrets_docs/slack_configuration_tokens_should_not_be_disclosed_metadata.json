{
  "filename": "slack_configuration_tokens_should_not_be_disclosed_metadata.json",
  "rule_id": "slack_configuration_tokens_disclosed",
  "title": "Slack configuration tokens should not be disclosed",
  "description": "In most cases, trust boundaries are violated when a secret is exposed in a source code repository or an uncontrolled deployment environment. Unintended people who don\u2019t need to know the secret might get access to it. They might then be able to use it to gain unwanted access to associated services or resources.",
  "status": "ready",
  "defaultSeverity": "Info",
  "category": "Security",
  "recommendation": "Review and fix according to the rule guidelines.",
  "impact": "Security risk",
  "tags": [
    "security",
    "cwe"
  ],
  "examples": {
    "noncompliant": [],
    "compliant": []
  },
  "references": [
    "https://rules.sonarsource.com/secrets/RSPEC-7351"
  ],
  "logic": {
    "node_types": [],
    "checks": [
      {
        "type": "regex",
        "pattern": "\\bxoxp-\\d+-\\d+-\\d+-[a-f0-9]+\\b",
        "message": "Slack user token detected in source code. User tokens (xoxp-...) provide user-level API access to Slack workspaces, acting on behalf of specific users rather than bots or apps. These tokens enable full user privileges for reading messages, posting content, managing channels, accessing user data, modifying workspace settings, performing administrative actions (if user is admin), accessing private channels the user belongs to, and executing any action the user is authorized to perform. Exposing user tokens creates critical security risks: attackers can impersonate the user across all workspaces they belong to, access private conversations and confidential data visible to the user, exfiltrate sensitive workspace information and files, modify user profile and account settings, send messages as the user to any accessible channel, perform destructive actions like deleting messages or files, access admin functions if the user has admin privileges, compromise integrated third-party services, and maintain persistent unauthorized access to user accounts. Immediate remediation steps: revoke the compromised user token through Slack App Management console (https://api.slack.com/apps) or user's workspace settings, force password reset for the affected user account, audit all API activity performed with the compromised token, review workspace audit logs for unauthorized actions, check for unauthorized app installations or OAuth grants, rotate all related credentials (app secrets, signing secrets), update all services with new user tokens if legitimately needed, store user tokens securely in environment variables or secret management systems (AWS Secrets Manager, HashiCorp Vault, Azure Key Vault), implement strict token access controls and monitoring, enable workspace security features like 2FA/MFA, add token usage alerts and anomaly detection, never commit user tokens to version control, use bot tokens instead of user tokens when possible (principle of least privilege), implement token rotation and expiration policies, and restrict workspace token permissions to minimum required scopes.",
