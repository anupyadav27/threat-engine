{
  "filename": "arcade_api_keys_should_not_be_disclosed_metadata.json",
  "rule_id": "arcade_api_keys_disclosed",
  "title": "Arcade API keys should not be disclosed",
  "description": "In most cases, trust boundaries are violated when a secret is exposed in a source code repository or an uncontrolled deployment environment. Unintended people who don\u2019t need to know the secret might get access to it. They might then be able to use it to gain unwanted access to associated services or resources.",
  "status": "ready",
  "defaultSeverity": "Info",
  "category": "Security",
  "recommendation": "Review and fix according to the rule guidelines.",
  "impact": "Security risk",
  "tags": [
    "security",
    "cwe"
  ],
  "examples": {
    "noncompliant": [],
    "compliant": [
      {
        "code": "ARCADE_API_KEY = os.environ.get('ARCADE_API_KEY')",
        "description": "Arcade API key retrieved from environment variable"
      },
      {
        "code": "const apiKey = process.env.ARCADE_API_KEY",
        "description": "Arcade API key retrieved from environment"
      }
    ]
  },
  "references": [
    "https://rules.sonarsource.com/secrets/RSPEC-7588"
  ],
  "logic": {
    "node_types": [],
    "checks": [
      {
        "type": "regex",
        "pattern": "\\barc_[a-zA-Z0-9_-]{32,64}\\b",
        "message": "Arcade API key detected in source code",
        "context_keywords": [
          "arcade",
          "ARCADE",
          "arc_",
          "api",
          "key",
          "apiKey",
          "API_KEY",
          "config",
          "credentials",
          "token",
          "auth",
          "client",
          "sdk",
          "game",
          "gaming",
          "player",
          "leaderboard",
          "achievement"
        ]
      },
      {
        "type": "regex",
        "pattern": "\\barcade_(live|test)_[a-zA-Z0-9_-]{32,64}\\b",
        "message": "Arcade API key (live/test) detected in source code",
        "context_keywords": [
          "arcade",
          "ARCADE",
          "api",
          "key",
          "apiKey",
          "API_KEY",
          "live",
          "test",
          "environment",
          "config",
          "credentials",
          "token",
          "auth",
          "client"
        ]
      },
      {
        "type": "regex",
        "pattern": "\\barcade_[a-zA-Z0-9_-]{36,72}\\b",
        "message": "Arcade API key (alternative format) detected in source code",
        "context_keywords": [
          "arcade",
          "ARCADE",
          "api",
          "key",
          "apiKey",
          "API_KEY",
          "config",
          "credentials",
          "token",
          "auth",
          "client",
          "sdk"
        ]
      }
    ]
  }
}