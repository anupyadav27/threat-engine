{
  "filename": "zhipu_ai_api_keys_should_not_be_disclosed_metadata.json",
  "rule_id": "zhipu_ai_api_keys",
  "title": "Zhipu AI API keys should not be disclosed",
  "description": "In most cases, trust boundaries are violated when a secret is exposed in a source code repository or an uncontrolled deployment environment. Unintended people who don\u2019t need to know the secret might get access to it. They might then be able to use it to gain unwanted access to associated services or resources.",
  "status": "ready",
  "defaultSeverity": "Info",
  "category": "Security",
  "recommendation": "Review and fix according to the rule guidelines.",
  "impact": "Security risk",
  "tags": [
    "security",
    "cwe"
  ],
  "examples": {
    "noncompliant": [],
    "compliant": []
  },
  "references": [
    "https://rules.sonarsource.com/secrets/RSPEC-7591"
  ],
  "logic": {
    "node_types": [],
    "checks": [
      {
        "type": "regex",
        "pattern": "\\b[A-Za-z0-9]{32,48}\\b",
        "message": "Zhipu AI API key detected. This key provides authenticated access to Zhipu AI's large language model services including GLM models, chat completions, and embeddings. Exposing Zhipu AI API keys enables unauthorized access to AI services, potential quota abuse, and sensitive data exposure through model interactions. Immediately revoke this key from your Zhipu AI account and implement secure credential storage using environment variables.",
