          "certificate",
          "cert",
          "privateKey",
          "private_key",
          "truststore",
          "TrustStore",
          "identity",
          "credential"
        ]
      },
      {
        "type": "regex",
        "pattern": "\\.(jks|keystore|p12|pfx|pkcs12|bks)\\b",
        "message": "Java Keystore file reference detected - potential keystore file path disclosure",
        "context_keywords": [
