{
  "filename": "java_keystore_files_should_not_be_disclosed_metadata.json",
  "rule_id": "java_keystore_files_disclosed",
  "title": "Java Keystore files should not disclose cryptographic private keys",
  "description": "In most cases, trust boundaries are violated when a secret is exposed in a source code repository or an uncontrolled deployment environment. Unintended people who don\u2019t need to know the secret might get access to it. They might then be able to use it to gain unwanted access to associated services or resources.",
  "status": "ready",
  "defaultSeverity": "Info",
  "category": "Security",
  "recommendation": "Review and fix according to the rule guidelines.",
  "impact": "Security risk",
  "tags": [
    "security",
    "cert",
    "cwe"
  ],
  "examples": {
    "noncompliant": [],
    "compliant": []
  },
  "references": [
    "https://rules.sonarsource.com/secrets/RSPEC-7203"
  ],
  "logic": {
    "node_types": [],
    "checks": [
      {
        "type": "regex",
        "pattern": "/u3\\+7[A-Za-z0-9+/=]{50,}",
        "message": "Java Keystore (JKS) file content detected - base64 encoded keystore starting with magic bytes 0xFEEDFEED",
        "context_keywords": [
          "keystore",
          "Keystore",
          "KeyStore",
          "KEYSTORE",
          "jks",
          "JKS",
          ".jks",
          "keyStore",
          "key_store",
          "KEY_STORE",
          "java",
          "Java",
          "JAVA",
          "keystoreFile",
          "keystorePath",
          "keystorePassword",
          "keystoreData",
          "keystore_file",
          "keystore_path",
          "keystore_password",
          "keystore_data",
          "certificate",
          "cert",
          "privateKey",
          "private_key",
          "truststore",
          "TrustStore"
        ]
      },
      {
        "type": "regex",
        "pattern": "MII[A-Za-z0-9+/]{100,}={0,2}",
        "message": "PKCS12 keystore file content detected - base64 encoded PKCS#12/PFX keystore",
        "context_keywords": [
          "keystore",
          "Keystore",
          "KeyStore",
          "KEYSTORE",
          "p12",
          "P12",
          ".p12",
          "pfx",
          "PFX",
          ".pfx",
          "pkcs12",
          "PKCS12",
          "pkcs",
          "PKCS",
          ".pkcs12",
          "keyStore",
          "key_store",
          "KEY_STORE",
          "keystoreFile",
          "keystorePath",
          "keystorePassword",
          "keystoreData",
          "keystore_file",
