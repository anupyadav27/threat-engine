{
  "filename": "klaviyo_api_keys_should_not_be_disclosed_metadata.json",
  "rule_id": "klaviyo_api_keys_disclosed",
  "title": "Klaviyo API keys should not be disclosed",
  "description": "In most cases, trust boundaries are violated when a secret is exposed in a source code repository or an uncontrolled deployment environment. Unintended people who don\u2019t need to know the secret might get access to it. They might then be able to use it to gain unwanted access to associated services or resources.",
  "status": "ready",
  "defaultSeverity": "Info",
  "category": "Security",
  "recommendation": "Review and fix according to the rule guidelines.",
  "impact": "Security risk",
  "tags": [
    "security",
    "cwe"
  ],
  "examples": {
    "noncompliant": [],
    "compliant": []
  },
  "references": [
    "https://rules.sonarsource.com/secrets/RSPEC-7286"
  ],
  "logic": {
    "node_types": [],
    "checks": [
      {
        "type": "regex",
        "pattern": "\\bpk_[A-Za-z0-9]{40,70}\\b",
        "message": "Klaviyo private API key detected - starts with 'pk_' prefix",
        "context_keywords": [
          "klaviyo",
          "Klaviyo",
          "KLAVIYO",
          "klaviyo_api_key",
          "klaviyoApiKey",
          "KlaviyoApiKey",
          "KLAVIYO_API_KEY",
          "klaviyo_key",
          "klaviyoKey",
          "KlaviyoKey",
          "KLAVIYO_KEY",
          "api_key",
          "apiKey",
          "ApiKey",
          "API_KEY",
          "private_key",
          "privateKey",
          "PrivateKey",
          "PRIVATE_KEY",
          "klaviyo_private_key",
          "klaviyoPrivateKey",
          "KLAVIYO_PRIVATE_KEY",
          "pk_",
          "klaviyo.com",
          "api.klaviyo.com",
          "klaviyo_client",
          "klaviyoClient",
          "KlaviyoClient",
          "marketing",
          "Marketing",
          "MARKETING",
          "email",
          "Email",
          "EMAIL",
          "campaign",
          "Campaign",
          "CAMPAIGN",
          "automation",
          "Automation",
          "AUTOMATION"
        ]
      },
      {
        "type": "regex",
        "pattern": "\\b[A-Za-z0-9]{32,50}\\b",
        "message": "Klaviyo API key detected - alphanumeric credential (32-50 chars)",
        "context_keywords": [
          "klaviyo_api_key",
          "klaviyoApiKey",
          "KLAVIYO_API_KEY",
          "klaviyo_key",
          "klaviyoKey",
          "KLAVIYO_KEY",
          "klaviyo.api.key",
          "klaviyo.key",
          "klaviyo_public_key",
          "klaviyoPublicKey",
          "KLAVIYO_PUBLIC_KEY",
          "klaviyo_secret",
          "klaviyoSecret",
          "KLAVIYO_SECRET",
          "klaviyo.com",
          "api.klaviyo.com"
        ]
      }
    ]
  }
}