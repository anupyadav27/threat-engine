          "access_token",
          "accessToken",
          "ACCESS_TOKEN",
          "refresh_token",
          "refreshToken",
          "REFRESH_TOKEN",
          "bearer",
          "Bearer",
          "BEARER",
          "credential",
          "credentials",
          "Credentials",
          "CREDENTIALS",
          "service_account",
          "serviceAccount",
          "SERVICE_ACCOUNT",
          "admin_client",
          "adminClient",
          "ADMIN_CLIENT",
          "master",
          "Master",
          "MASTER"
        ]
      },
      {
        "type": "regex",
        "pattern": "\\b[A-Za-z0-9_-]{32,64}\\b",
        "message": "Keycloak client secret detected - alphanumeric credential (32-64 chars)",
        "context_keywords": [
          "keycloak_secret",
          "keycloakSecret",
          "KEYCLOAK_SECRET",
          "client_secret",
          "clientSecret",
          "CLIENT_SECRET",
          "keycloak_client_secret",
