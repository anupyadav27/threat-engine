          "SECRET",
          "client_id",
          "clientId",
          "ClientId",
          "CLIENT_ID",
          "keycloak_client",
          "keycloakClient",
          "KeycloakClient",
          "KEYCLOAK_CLIENT",
          "realm",
          "Realm",
          "REALM",
          "realm_secret",
          "realmSecret",
          "REALM_SECRET",
          "auth",
          "Auth",
          "AUTH",
          "authentication",
          "Authentication",
          "AUTHENTICATION",
          "oidc",
          "OIDC",
          "oauth",
          "OAuth",
          "OAUTH",
          "oauth2",
