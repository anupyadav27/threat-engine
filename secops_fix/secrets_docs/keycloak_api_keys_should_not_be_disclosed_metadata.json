          "realmSecret",
          "REALM_SECRET",
          "service_account_secret",
          "serviceAccountSecret",
          "SERVICE_ACCOUNT_SECRET"
        ]
      },
      {
        "type": "regex",
        "pattern": "\\beyJ[A-Za-z0-9_-]+\\.[A-Za-z0-9_-]+\\.[A-Za-z0-9_-]+\\b",
        "message": "Keycloak JWT token detected - JSON Web Token",
        "context_keywords": [
