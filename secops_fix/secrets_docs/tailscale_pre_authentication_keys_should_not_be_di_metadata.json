{
  "filename": "tailscale_pre_authentication_keys_should_not_be_di_metadata.json",
  "rule_id": "tailscale_preauthentication_keys_disclosed",
  "title": "Tailscale pre-authentication keys should not be disclosed",
  "description": "In most cases, trust boundaries are violated when a secret is exposed in a source code repository or an uncontrolled deployment environment. Unintended people who don\u2019t need to know the secret might get access to it. They might then be able to use it to gain unwanted access to associated services or resources.",
  "status": "ready",
  "defaultSeverity": "Info",
  "category": "Security",
  "recommendation": "Review and fix according to the rule guidelines.",
  "impact": "Security risk",
  "tags": [
    "security",
    "cwe"
  ],
  "examples": {
    "noncompliant": [],
    "compliant": []
  },
  "references": [
    "https://rules.sonarsource.com/secrets/RSPEC-7366"
  ],
  "logic": {
    "node_types": [],
    "checks": [
      {
        "type": "regex",
        "pattern": "\\btskey-auth-[A-Za-z0-9]{16,32}\\b",
        "message": "Tailscale pre-authentication key detected in source code. Tailscale auth keys allow devices to automatically join your tailnet without manual approval. Exposing these keys enables unauthorized devices to connect to your private network. Revoke this key immediately and store auth keys securely in environment variables or secret management systems.",
