{
  "filename": "slack_configuration_refresh_tokens_should_not_be_d_metadata.json",
  "rule_id": "slack_configuration_refresh_tokens",
  "title": "Slack configuration refresh tokens should not be disclosed",
  "description": "In most cases, trust boundaries are violated when a secret is exposed in a source code repository or an uncontrolled deployment environment. Unintended people who don\u2019t need to know the secret might get access to it. They might then be able to use it to gain unwanted access to associated services or resources.",
  "status": "ready",
  "defaultSeverity": "Info",
  "category": "Security",
  "recommendation": "Review and fix according to the rule guidelines.",
  "impact": "Security risk",
  "tags": [
    "security",
    "cwe"
  ],
  "examples": {
    "noncompliant": [],
    "compliant": []
  },
  "references": [
    "https://rules.sonarsource.com/secrets/RSPEC-7350"
  ],
  "logic": {
    "node_types": [],
    "checks": [
      {
        "type": "regex",
        "pattern": "xoxe(?:\\.xoxp)?-1-[A-Za-z0-9_-]{98,}",
        "message": "Slack configuration/refresh token detected in source code. Configuration tokens (xoxe-1-... or xoxe.xoxp-1-...) are used in Slack's OAuth 2.0 refresh token flow and app configuration operations. These tokens enable rotating access credentials, refreshing expired access tokens, managing app configuration state, and maintaining long-term API access without re-authentication. Exposing configuration/refresh tokens creates significant security risks: attackers can generate new access tokens indefinitely without user interaction, maintain persistent unauthorized access even after password changes, impersonate users or bots to access workspace data, bypass multi-factor authentication requirements, access all resources granted to the original OAuth scope, pivot to other integrated services using refreshed tokens, and maintain long-term persistent access to the workspace. Immediate remediation steps: revoke the compromised refresh token through the Slack App Management console (https://api.slack.com/apps), generate new OAuth credentials and re-authenticate users, audit all API access performed with tokens generated from the compromised refresh token, review workspace audit logs for unauthorized activity, rotate all related OAuth credentials (client secrets, signing secrets), update all services and applications with new OAuth flow, store refresh tokens securely in environment variables or secret management systems (AWS Secrets Manager, HashiCorp Vault, Azure Key Vault), implement token rotation policies, enable workspace audit logging, monitor for unusual OAuth token generation patterns, add refresh token expiration policies, never commit refresh tokens to version control systems, use short-lived access tokens with refresh token rotation, and implement IP restrictions and rate limiting where possible.",
