{
  "filename": "akamai_api_credentials_secrets_should_not_be_discl_metadata.json",
  "rule_id": "akamai_api_credentials_secrets",
  "title": "Akamai API Credentials secrets should not be disclosed",
  "description": "In most cases, trust boundaries are violated when a secret is exposed in a source code repository or an uncontrolled deployment environment. Unintended people who don\u2019t need to know the secret might get access to it. They might then be able to use it to gain unwanted access to associated services or resources.",
  "status": "ready",
  "defaultSeverity": "Info",
  "category": "Security",
  "recommendation": "Review and fix according to the rule guidelines.",
  "impact": "Security risk",
  "tags": [
    "security",
    "cwe"
  ],
  "examples": {
    "noncompliant": [],
    "compliant": [
      {
        "code": "client_token = os.environ.get('AKAMAI_CLIENT_TOKEN')",
        "description": "Akamai token retrieved from environment variable"
      },
      {
        "code": "const token = process.env.AKAMAI_ACCESS_TOKEN",
        "description": "Akamai token retrieved from environment"
      }
    ]
  },
  "references": [
    "https://rules.sonarsource.com/secrets/RSPEC-7212"
  ],
  "logic": {
    "node_types": [],
    "checks": [
      {
        "type": "regex",
        "pattern": "\\bakab-[a-zA-Z0-9]{16,}-[a-zA-Z0-9]{16,}\\b",
        "message": "Akamai client/access token detected in source code",
        "context_keywords": [
          "akamai",
          "client_token",
          "access_token",
          "edgegrid",
          "luna.akamaiapis.net",
          "AKAMAI_CLIENT_TOKEN",
          "AKAMAI_ACCESS_TOKEN"
        ]
      },
      {
        "type": "regex",
        "pattern": "\\bakab-[a-zA-Z0-9_-]{20,50}\\b",
        "message": "Akamai API token (alternative format) detected in source code",
        "context_keywords": [
          "akamai",
          "token",
          "client",
          "access",
          "edgegrid",
          "akamaiapis",
          "AKAMAI"
        ]
      },
      {
        "type": "regex",
        "pattern": "\\b[a-zA-Z0-9+/]{40,60}={0,2}\\b",
        "message": "Potential Akamai client secret detected in source code",
        "context_keywords": [
          "akamai",
          "client_secret",
          "secret",
          "edgegrid",
          "AKAMAI_CLIENT_SECRET",
          "AKAMAI_SECRET",
          "akamaiapis"
        ]
      }
    ]
  }
}