{
  "filename": "mattermost_admin_credentials_should_not_be_disclos_metadata.json",
  "rule_id": "mattermost_admin_credentials_disclosed",
  "title": "Mattermost admin credentials should not be disclosed",
  "description": "In most cases, trust boundaries are violated when a secret is exposed in a source code repository or an uncontrolled deployment environment. Unintended people who don\u2019t need to know the secret might get access to it. They might then be able to use it to gain unwanted access to associated services or resources.",
  "status": "ready",
  "defaultSeverity": "Info",
  "category": "Security",
  "recommendation": "Review and fix according to the rule guidelines.",
  "impact": "Security risk",
  "tags": [
    "security",
    "cwe"
  ],
  "examples": {
    "noncompliant": [],
    "compliant": []
  },
  "references": [
    "https://rules.sonarsource.com/secrets/RSPEC-7575"
  ],
  "logic": {
    "node_types": [],
    "checks": [
      {
        "type": "regex",
        "pattern": "mattermost://[a-zA-Z0-9._-]+:[^@\\s'\"<>`{}]+@[a-zA-Z0-9._-]+(?::[0-9]{1,5})?",
        "message": "Mattermost connection URL with embedded admin credentials detected in source code",
        "context_keywords": [
          "mattermost",
          "Mattermost",
          "MATTERMOST",
          "mattermost_url",
          "mattermostUrl",
          "MATTERMOST_URL",
          "mattermost_connection",
          "mattermostConnection",
          "MATTERMOST_CONNECTION",
          "mattermost_admin",
          "mattermostAdmin",
          "MATTERMOST_ADMIN",
          "admin",
          "Admin",
          "ADMIN",
          "admin_user",
          "adminUser",
          "ADMIN_USER",
          "admin_password",
          "adminPassword",
          "ADMIN_PASSWORD",
          "mattermost_server",
          "mattermostServer",
          "MATTERMOST_SERVER",
          "mattermost_host",
          "mattermostHost",
          "MATTERMOST_HOST",
          "team",
          "Team",
          "TEAM",
          "chat",
          "Chat",
          "CHAT"
        ]
      },
      {
        "type": "regex",
        "pattern": "https?://[a-zA-Z0-9._-]+:[^@\\s'\"<>`{}]{6,100}@[a-zA-Z0-9._-]+(?::[0-9]{1,5})?(?:/[^\\s]*)?",
        "message": "Mattermost HTTP/HTTPS connection URL with embedded admin credentials detected",
        "context_keywords": [
          "mattermost",
          "Mattermost",
          "MATTERMOST",
          "mattermost_url",
          "mattermostUrl",
          "MATTERMOST_URL",
          "mattermost_api",
          "mattermostApi",
          "MATTERMOST_API",
          "admin",
          "Admin",
          "ADMIN",
          "admin_credentials",
          "adminCredentials",
          "ADMIN_CREDENTIALS",
          "admin_user",
          "adminUser",
          "ADMIN_USER",
          "admin_password",
          "adminPassword",
          "ADMIN_PASSWORD",
          "mattermost_admin",
          "mattermostAdmin",
          "MATTERMOST_ADMIN",
          "team_admin",
          "teamAdmin",
          "TEAM_ADMIN",
          "sysadmin",
          "system_admin",
          "systemAdmin",
          "SYSTEM_ADMIN"
        ]
      },
      {
        "type": "regex",
        "pattern": "(?<!://)\\b[a-zA-Z0-9._-]{3,30}:[^@\\s'\"<>`{}:/]{8,100}\\b",
        "message": "Potential Mattermost admin credentials in username:password format detected",
        "context_keywords": [
          "mattermost",
          "Mattermost",
          "MATTERMOST",
          "admin",
          "Admin",
          "ADMIN",
          "admin_credentials",
          "adminCredentials",
          "ADMIN_CREDENTIALS",
          "admin_user",
          "adminUser",
          "ADMIN_USER",
          "admin_username",
          "adminUsername",
          "ADMIN_USERNAME",
          "admin_password",
          "adminPassword",
          "ADMIN_PASSWORD",
          "mattermost_admin",
          "mattermostAdmin",
          "MATTERMOST_ADMIN",
          "mattermost_credentials",
          "mattermostCredentials",
          "MATTERMOST_CREDENTIALS",
          "mattermost_auth",
          "mattermostAuth",
          "MATTERMOST_AUTH",
          "sysadmin",
          "system_admin",
          "systemAdmin",
          "SYSTEM_ADMIN",
          "team_admin",
          "teamAdmin",
          "TEAM_ADMIN"
        ]
      }
    ]
  }
}