{
  "filename": "tavily_api_keys_should_not_be_disclosed_metadata.json",
  "rule_id": "tavily_api_keys_disclosed",
  "title": "Tavily API keys should not be disclosed",
  "description": "In most cases, trust boundaries are violated when a secret is exposed in a source code repository or an uncontrolled deployment environment. Unintended people who don\u2019t need to know the secret might get access to it. They might then be able to use it to gain unwanted access to associated services or resources.",
  "status": "ready",
  "defaultSeverity": "Info",
  "category": "Security",
  "recommendation": "Review and fix according to the rule guidelines.",
  "impact": "Security risk",
  "tags": [
    "security",
    "cwe"
  ],
  "examples": {
    "noncompliant": [],
    "compliant": []
  },
  "references": [
    "https://rules.sonarsource.com/secrets/RSPEC-7369"
  ],
  "logic": {
    "node_types": [],
    "checks": [
      {
        "type": "regex",
        "pattern": "\\btvly-[A-Za-z0-9_-]{20,64}\\b",
        "message": "Tavily API key detected in source code. Tavily API keys provide access to web search, content extraction, crawling, and research APIs. Exposing these keys allows unauthorized parties to consume your API quota, access search results, and potentially incur charges on your account. Revoke this key immediately and store API keys securely in environment variables or secret management systems.",
