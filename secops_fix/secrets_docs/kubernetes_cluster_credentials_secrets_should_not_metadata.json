{
  "filename": "kubernetes_cluster_credentials_secrets_should_not__metadata.json",
  "rule_id": "kubernetes_cluster_credentials_secrets",
  "title": "Kubernetes Cluster Credentials secrets should not be disclosed",
  "description": "In most cases, trust boundaries are violated when a secret is exposed in a source code repository or an uncontrolled deployment environment. Unintended people who don\u2019t need to know the secret might get access to it. They might then be able to use it to gain unwanted access to associated services or resources.",
  "status": "ready",
  "defaultSeverity": "Info",
  "category": "Security",
  "recommendation": "Review and fix according to the rule guidelines.",
  "impact": "Security risk",
  "tags": [
    "security",
    "cwe"
  ],
  "examples": {
    "noncompliant": [],
    "compliant": []
  },
  "references": [
    "https://rules.sonarsource.com/secrets/RSPEC-7288"
  ],
  "logic": {
    "node_types": [],
    "checks": [
      {
        "type": "regex",
        "pattern": "\\bcertificate-authority-data:\\s*[A-Za-z0-9+/=]{100,}",
        "message": "Kubernetes certificate authority data detected in kubeconfig",
        "context_keywords": [
          "kubernetes",
          "Kubernetes",
          "KUBERNETES",
          "k8s",
          "K8s",
          "K8S",
          "kubeconfig",
          "kube-config",
