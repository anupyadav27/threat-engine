          "kubectl",
          "kube",
          "apiserver",
          "api-server",
          "k8s-cluster",
          "kubernetes-cluster"
        ]
      },
      {
        "type": "regex",
        "pattern": "\\bclient-certificate-data:\\s*[A-Za-z0-9+/=]{100,}",
        "message": "Kubernetes client certificate data detected in kubeconfig",
        "context_keywords": [
          "kubernetes",
          "Kubernetes",
          "KUBERNETES",
          "k8s",
