{
  "filename": "zoho_oauth2_keys_should_not_be_disclosed_metadata.json",
  "rule_id": "zoho_oauth2_keys_disclosed",
  "title": "Zoho OAuth2 keys should not be disclosed",
  "description": "In most cases, trust boundaries are violated when a secret is exposed in a source code repository or an uncontrolled deployment environment. Unintended people who don\u2019t need to know the secret might get access to it. They might then be able to use it to gain unwanted access to associated services or resources.",
  "status": "ready",
  "defaultSeverity": "Info",
  "category": "Security",
  "recommendation": "Review and fix according to the rule guidelines.",
  "impact": "Security risk",
  "tags": [
    "security",
    "cwe"
  ],
  "examples": {
    "noncompliant": [],
    "compliant": []
  },
  "references": [
    "https://rules.sonarsource.com/secrets/RSPEC-7391"
  ],
  "logic": {
    "node_types": [],
    "checks": [
      {
        "type": "regex",
        "pattern": "\\b[A-Za-z0-9]{32,48}\\b",
        "message": "Zoho OAuth2 client ID detected. This client ID is used to identify your application when authenticating with Zoho services including CRM, Mail, Books, and other Zoho applications. Exposing client IDs can enable attackers to enumerate your OAuth2 configuration and potentially exploit misconfigurations. While client IDs are less sensitive than secrets, they should be stored securely and rotated if exposed. Implement secure credential storage using environment variables or secret management systems.",
        "context_keywords": [
          "zoho",
          "Zoho",
          "ZOHO",
          "zoho_oauth",
          "zohoOauth",
