{
  "filename": "atlassian_secrets_should_not_be_disclosed_metadata.json",
  "rule_id": "atlassian_secrets_disclosed",
  "title": "Atlassian secrets should not be disclosed",
  "description": "In most cases, trust boundaries are violated when a secret is exposed in a source code repository or an uncontrolled deployment environment. Unintended people who don\u2019t need to know the secret might get access to it. They might then be able to use it to gain unwanted access to associated services or resources.",
  "status": "ready",
  "defaultSeverity": "Info",
  "category": "Security",
  "recommendation": "Review and fix according to the rule guidelines.",
  "impact": "Security risk",
  "tags": [
    "security",
    "cwe"
  ],
  "examples": {
    "noncompliant": [],
    "compliant": [
      {
        "code": "ATLASSIAN_TOKEN = os.getenv('ATLASSIAN_TOKEN')",
        "description": "Token retrieved from environment variable"
      },
      {
        "code": "const jiraToken = process.env.JIRA_API_TOKEN;",
        "description": "Token loaded from environment"
      }
    ]
  },
  "references": [
    "https://rules.sonarsource.com/secrets/RSPEC-7147"
  ],
  "logic": {
    "node_types": [],
    "checks": [
      {
        "type": "regex",
        "pattern": "ATATT[a-zA-Z0-9]{40,60}",
        "message": "Atlassian API token detected (ATATT prefix)",
        "context_keywords": [
          "atlassian",
          "ATLASSIAN",
          "jira",
          "JIRA",
          "Jira",
          "confluence",
          "CONFLUENCE",
          "Confluence",
          "bitbucket",
          "BITBUCKET",
          "Bitbucket",
          "api",
          "API",
          "token",
          "TOKEN",
          "auth",
          "authorization",
          "api_token",
          "API_TOKEN",
          "bearer"
        ]
      },
      {
        "type": "regex",
        "pattern": "ATCTT[a-zA-Z0-9]{40,60}",
        "message": "Atlassian OAuth token detected (ATCTT prefix)",
        "context_keywords": [
          "atlassian",
          "ATLASSIAN",
          "jira",
          "JIRA",
          "Jira",
          "confluence",
          "CONFLUENCE",
          "Confluence",
          "bitbucket",
          "BITBUCKET",
          "Bitbucket",
          "oauth",
          "OAuth",
          "OAUTH",
          "token",
          "TOKEN",
          "auth",
          "authorization",
          "bearer",
          "access_token"
        ]
      },
      {
        "type": "regex",
        "pattern": "ATBB[a-zA-Z0-9]{32,48}",
        "message": "Bitbucket app password detected (ATBB prefix)",
        "context_keywords": [
          "bitbucket",
          "BITBUCKET",
          "Bitbucket",
          "atlassian",
          "ATLASSIAN",
          "app",
          "APP",
          "password",
          "PASSWORD",
          "auth",
          "authorization",
          "token",
          "api",
          "credential"
        ]
      },
      {
        "type": "regex",
        "pattern": "[a-zA-Z0-9]{24}:[a-f0-9]{64}",
        "message": "Potential Jira/Confluence API token format detected",
        "context_keywords": [
          "jira",
          "JIRA",
          "Jira",
          "confluence",
          "CONFLUENCE",
          "Confluence",
          "atlassian",
          "ATLASSIAN",
          "api",
          "API",
          "token",
          "TOKEN",
          "auth",
          "authorization",
          "credential",
          "secret"
        ]
      }
    ]
  }
}