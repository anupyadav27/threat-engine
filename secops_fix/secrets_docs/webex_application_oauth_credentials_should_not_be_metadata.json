{
  "filename": "webex_application_oauth_credentials_should_not_be__metadata.json",
  "rule_id": "webex_application_oauth_credentials",
  "title": "Webex application OAuth credentials should not be disclosed",
  "description": "In most cases, trust boundaries are violated when a secret is exposed in a source code repository or an uncontrolled deployment environment. Unintended people who don\u2019t need to know the secret might get access to it. They might then be able to use it to gain unwanted access to associated services or resources.",
  "status": "ready",
  "defaultSeverity": "Info",
  "category": "Security",
  "recommendation": "Review and fix according to the rule guidelines.",
  "impact": "Security risk",
  "tags": [
    "security",
    "cwe"
  ],
  "examples": {
    "noncompliant": [],
    "compliant": []
  },
  "references": [
    "https://rules.sonarsource.com/secrets/RSPEC-7381"
  ],
  "logic": {
    "node_types": [],
    "checks": [
      {
        "type": "regex",
        "pattern": "\\bC[A-Fa-f0-9]{63,69}\\b",
        "message": "Webex OAuth client ID detected in source code. OAuth client IDs are public identifiers for Webex integrations but should be managed securely to prevent unauthorized application impersonation. While client IDs are not secret, exposing them in source code can facilitate targeted attacks when combined with other credentials. Store client IDs in secure configuration management systems.",
        "context_keywords": [
          "webex",
          "Webex",
          "WEBEX",
          "webexapis",
          "webexapis.com",
          "api.webex.com",
