        "pattern": "(?:access_token|accessToken|ACCESS_TOKEN|webex_access_token|webexAccessToken|WEBEX_ACCESS_TOKEN|webex_token|webexToken|WEBEX_TOKEN)[\"'\\s]*[:=][\"'\\s]*([A-Za-z0-9+/=_-]{80,200})\\b",
