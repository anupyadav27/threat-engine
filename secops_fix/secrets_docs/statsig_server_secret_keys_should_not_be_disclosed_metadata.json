{
  "filename": "statsig_server_secret_keys_should_not_be_disclosed_metadata.json",
  "rule_id": "statsig_server_secret_keys",
  "title": "Statsig Server secret keys should not be disclosed",
  "description": "In most cases, trust boundaries are violated when a secret is exposed in a source code repository or an uncontrolled deployment environment. Unintended people who don\u2019t need to know the secret might get access to it. They might then be able to use it to gain unwanted access to associated services or resources.",
  "status": "ready",
  "defaultSeverity": "Info",
  "category": "Security",
  "recommendation": "Review and fix according to the rule guidelines.",
  "impact": "Security risk",
  "tags": [
    "security",
    "cwe"
  ],
  "examples": {
    "noncompliant": [],
    "compliant": []
  },
  "references": [
    "https://rules.sonarsource.com/secrets/RSPEC-7360"
  ],
  "logic": {
    "node_types": [],
    "checks": [
      {
        "type": "regex",
        "pattern": "\\bsecret-[A-Za-z0-9]{32,64}\\b",
        "message": "Statsig server secret key detected in source code. Statsig server secret keys provide full administrative access to your feature flags, A/B tests, experiments, analytics, and metrics data. Exposing these keys allows unauthorized users to: modify feature flag configurations affecting millions of users, manipulate experiment results and A/B test data, access sensitive analytics and user metrics, control feature rollouts and gate configurations, alter dynamic configuration values, access event logs and user data, modify user targeting rules and segments, and potentially disrupt product functionality. Store server secret keys securely using environment variables (STATSIG_SERVER_SECRET, STATSIG_SECRET_KEY) or secret management systems (HashiCorp Vault, AWS Secrets Manager, Azure Key Vault). IMMEDIATELY revoke exposed keys from Statsig Console (console.statsig.com \u2192 Settings \u2192 API Keys) and regenerate new credentials. Use client SDK keys for client-side applications (never server secret keys), enable access logging, implement IP whitelisting, use scoped keys with minimal permissions, and rotate keys regularly.",
        "context_keywords": [
          "statsig",
          "Statsig",
          "STATSIG",
          "statsig_server",
          "statsigServer",
          "StatsigServer",
          "STATSIG_SERVER",
