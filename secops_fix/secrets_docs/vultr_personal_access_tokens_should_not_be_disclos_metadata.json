{
  "filename": "vultr_personal_access_tokens_should_not_be_disclos_metadata.json",
  "rule_id": "vultr_personal_access_tokens",
  "title": "Vultr personal access tokens should not be disclosed",
  "description": "In most cases, trust boundaries are violated when a secret is exposed in a source code repository or an uncontrolled deployment environment. Unintended people who don\u2019t need to know the secret might get access to it. They might then be able to use it to gain unwanted access to associated services or resources.",
  "status": "ready",
  "defaultSeverity": "Critical",
  "category": "Security",
  "recommendation": "Review and fix according to the rule guidelines.",
  "impact": "Security risk",
  "tags": [
    "security",
    "cwe",
    "performance"
  ],
  "examples": {
    "noncompliant": [],
    "compliant": []
  },
  "references": [
    "https://rules.sonarsource.com/secrets/RSPEC-6993"
  ],
  "logic": {
    "node_types": [],
    "checks": [
      {
        "type": "regex",
        "pattern": "\\b[A-Za-z0-9]{32,64}\\b",
        "message": "Vultr personal access token detected in source code. Personal access tokens provide full API access to Vultr cloud resources including servers, storage, networking, and billing. Exposing these tokens allows unauthorized resource management, potential data access, and billing manipulation. Store tokens securely using environment variables or secure credential management.",
