    "https://rules.sonarsource.com/secrets/RSPEC-7592"
  ],
  "logic": {
    "node_types": [],
    "checks": [
      {
        "type": "regex",
        "pattern": "\\b[a-fA-F0-9]{40}\\b",
        "message": "Weights & Biases API key detected. This key provides full access to your W&B workspace, including experiment tracking, model artifacts, datasets, and team collaboration features. Unauthorized access can lead to intellectual property theft, model tampering, experiment manipulation, and sensitive research data exposure. Immediately revoke this key in your W&B settings and rotate credentials using secure environment variables.",
