{
  "filename": "sql_server_passwords_should_not_be_disclosed_metadata.json",
  "rule_id": "sql_server_passwords_disclosed",
  "title": "SQL Server passwords should not be disclosed",
  "description": "In most cases, trust boundaries are violated when a secret is exposed in a source code repository or an uncontrolled deployment environment. Unintended people who don\u2019t need to know the secret might get access to it. They might then be able to use it to gain unwanted access to associated services or resources.",
  "status": "ready",
  "defaultSeverity": "Info",
  "category": "Security",
  "recommendation": "Review and fix according to the rule guidelines.",
  "impact": "Security risk",
  "tags": [
    "security",
    "cwe"
  ],
  "examples": {
    "noncompliant": [],
    "compliant": []
  },
  "references": [
    "https://rules.sonarsource.com/secrets/RSPEC-7539"
  ],
  "logic": {
    "node_types": [],
    "checks": [
      {
        "type": "regex",
        "pattern": "(?:Server|Data Source|DataSource|server|data source|datasource)\\s*=\\s*[^;]+;[^\"']*(?:Password|password|PWD|pwd)\\s*=\\s*(?!\\{|\\$\\{|<)([A-Za-z0-9!@#$%^&*()_+=\\[\\]{}|;:,.<>?/\\\\~-]{8,50})(?![}>;])",
        "message": "SQL Server ADO.NET connection string with embedded password detected - CRITICAL. This connection string contains authentication credentials in plaintext format (Server=...;Password=xxx or Data Source=...;Password=xxx), providing direct database access to SQL Server. Exposing this allows unauthorized parties to execute SQL queries, access sensitive data including personal information and financial records, modify or delete data, execute stored procedures, potentially escalate privileges to SA level, and compromise the entire database system. IMMEDIATE ACTIONS: 1) Remove password from connection string immediately, 2) Rotate SQL Server credentials (ALTER LOGIN command), 3) Store credentials securely using Windows Integrated Authentication (preferred), Azure Key Vault, AWS Secrets Manager, HashiCorp Vault, or secure environment variables, 4) Review SQL Server audit logs for unauthorized access, 5) Implement principle of least privilege with SQL Server roles, 6) Enable SQL Server auditing and monitoring, 7) Consider using Managed Identity for Azure SQL or AWS RDS IAM authentication where applicable.",
