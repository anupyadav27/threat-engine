{
  "filename": "azure_function_access_keys_should_not_be_disclosed_metadata.json",
  "rule_id": "azure_function_access_keys",
  "title": "Azure Function access keys should not be disclosed",
  "description": "As described in the Azure Functions documentation, Azure Functions let you use keys to make it harder to access your HTTP function endpoints during development. While keys provide a default security mechanism, distributing them in public apps is a bad practice and can lead to security and maintainability issues. What is the potential impact? The impact of this access depends on what the Azure Function does and what permissions the key has.",
  "status": "ready",
  "defaultSeverity": "Info",
  "category": "Security",
  "recommendation": "Review and fix according to the rule guidelines.",
  "impact": "Security risk",
  "tags": [
    "security",
    "cwe"
  ],
  "examples": {
    "noncompliant": [],
    "compliant": [
      {
        "code": "AZURE_FUNCTION_KEY = os.environ.get('AZURE_FUNCTION_KEY')",
        "description": "Function key from environment variable"
      },
      {
        "code": "const functionKey = process.env.AZURE_FUNCTION_KEY",
        "description": "Function key retrieved from environment"
      }
    ]
  },
  "references": [
    "https://rules.sonarsource.com/secrets/RSPEC-7003"
  ],
  "logic": {
    "node_types": [],
    "checks": [
      {
        "type": "regex",
        "pattern": "[a-zA-Z0-9+/]{40,88}={0,2}",
        "message": "Azure Function access key detected",
        "context_keywords": [
          "function",
          "Function",
          "FUNCTION",
          "azure_function",
          "azureFunction",
          "AzureFunction",
          "function_key",
          "functionKey",
          "function_app",
          "functionApp",
          "FunctionApp",
          "master_key",
          "masterKey",
          "host_key",
          "hostKey",
          "default_key",
          "defaultKey",
          "x-functions-key",
          "x_functions_key",
          "functionsKey",
          "app_key",
          "appKey",
          "azurewebsites",
          "azurewebsites.net",
          "function_code",
          "functionCode",
          "admin_key",
          "adminKey"
        ]
      },
      {
        "type": "regex",
        "pattern": "code=[a-zA-Z0-9+/]{40,88}={0,2}",
        "message": "Azure Function code parameter detected",
        "context_keywords": [
          "function",
          "Function",
          "FUNCTION",
          "azure",
          "Azure",
          "AZURE",
          "azurewebsites",
          "api",
          "API",
          "endpoint",
          "invoke",
          "trigger",
          "http",
          "https",
          "url",
          "URL",
          "request"
        ]
      }
    ]
  }
}