{
  "filename": "zillow_keys_should_not_be_disclosed_metadata.json",
  "rule_id": "zillow_keys_disclosed",
  "title": "Zillow keys should not be disclosed",
  "description": "In most cases, trust boundaries are violated when a secret is exposed in a source code repository or an uncontrolled deployment environment. Unintended people who don\u2019t need to know the secret might get access to it. They might then be able to use it to gain unwanted access to associated services or resources.",
  "status": "ready",
  "defaultSeverity": "Info",
  "category": "Security",
  "recommendation": "Review and fix according to the rule guidelines.",
  "impact": "Security risk",
  "tags": [
    "security",
    "cwe"
  ],
  "examples": {
    "noncompliant": [],
    "compliant": []
  },
  "references": [
    "https://rules.sonarsource.com/secrets/RSPEC-7390"
  ],
  "logic": {
    "node_types": [],
    "checks": [
      {
        "type": "regex",
        "pattern": "\\b[A-Za-z0-9]{32,48}\\b",
        "message": "Zillow API key (ZWSID) detected. This key provides authenticated access to Zillow's real estate data services including property details, valuations (Zestimate), and market data. Exposing Zillow API keys can lead to unauthorized access to premium property data, quota abuse, and potential service disruption. Immediately revoke this key from your Zillow developer account and implement secure credential storage using environment variables or secret management systems.",
