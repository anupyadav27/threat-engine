    "node_types": [],
    "checks": [
      {
        "type": "regex",
        "pattern": "Authorization[\"'\\s]*[:=][\"'\\s]*Bearer\\s+([A-Za-z0-9+/=_-]{50,200})\\b",
        "message": "Webex access token detected in Authorization header. Bearer tokens provide authenticated access to Webex API services including meetings, messaging, calling, and administrative functions. Exposing these tokens allows unauthorized access to Webex resources and user data. Store tokens securely using environment variables or credential management systems.",
