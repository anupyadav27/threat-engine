{
  "filename": "pubnub_subscription_keys_should_not_be_disclosed_metadata.json",
  "rule_id": "pubnub_subscription_keys_disclosed",
  "title": "PubNub subscription keys should not be disclosed",
  "description": "In most cases, trust boundaries are violated when a secret is exposed in a source code repository or an uncontrolled deployment environment. Unintended people who don\u2019t need to know the secret might get access to it. They might then be able to use it to gain unwanted access to associated services or resources.",
  "status": "ready",
  "defaultSeverity": "Info",
  "category": "Security",
  "recommendation": "Review and fix according to the rule guidelines.",
  "impact": "Security risk",
  "tags": [
    "security",
    "cwe"
  ],
  "examples": {
    "noncompliant": [],
    "compliant": []
  },
  "references": [
    "https://rules.sonarsource.com/secrets/RSPEC-7329"
  ],
  "logic": {
    "node_types": [],
    "checks": [
      {
        "type": "regex",
        "pattern": "\\bsub-c-[a-f0-9]{8}-[a-f0-9]{4}-[a-f0-9]{4}-[a-f0-9]{4}-[a-f0-9]{12}\\b",
        "message": "PubNub Subscription Key detected. PubNub is a real-time messaging and data streaming platform. Subscription keys allow subscribing to channels, receiving messages, and listening to real-time events. While subscription keys are typically used in client-side code, exposing them in version control enables attackers to subscribe to private channels, monitor message streams, access historical messages (if enabled), track presence data, and potentially exhaust your subscription quota. Implement proper access control using PubNub Access Manager (PAM), rotate this key from your PubNub Admin Portal, and use environment-based configuration management. For sensitive channels, enable PAM to grant time-limited, channel-specific access tokens instead of exposing subscription keys directly.",
        "context_keywords": [
          "pubnub",
          "PubNub",
          "PUBNUB",
          "pubnub_subscribe",
          "pubnubSubscribe",
          "PubNubSubscribe",
          "PUBNUB_SUBSCRIBE",
