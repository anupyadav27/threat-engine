{
  "filename": "travis_ci_tokens_should_not_be_disclosed_metadata.json",
  "rule_id": "travis_ci_tokens_disclosed",
  "title": "Travis CI tokens should not be disclosed",
  "description": "In most cases, trust boundaries are violated when a secret is exposed in a source code repository or an uncontrolled deployment environment. Unintended people who don\u2019t need to know the secret might get access to it. They might then be able to use it to gain unwanted access to associated services or resources.",
  "status": "ready",
  "defaultSeverity": "Info",
  "category": "Security",
  "recommendation": "Review and fix according to the rule guidelines.",
  "impact": "Security risk",
  "tags": [
    "security",
    "cwe"
  ],
  "examples": {
    "noncompliant": [],
    "compliant": []
  },
  "references": [
    "https://rules.sonarsource.com/secrets/RSPEC-7370"
  ],
  "logic": {
    "node_types": [],
    "checks": [
      {
        "type": "regex",
        "pattern": "\\b[A-Za-z0-9]{22,40}\\b",
        "message": "Travis CI API token detected. These tokens provide programmatic access to Travis CI builds, repositories, and organization settings. Exposing these tokens enables unauthorized access to CI/CD pipelines, build logs, and project configurations. Revoke this token immediately from your Travis CI account settings.",
