{
  "filename": "database_passwords_should_not_be_disclosed_metadata.json",
  "rule_id": "database_passwords_disclosed",
  "title": "Database passwords should not be disclosed",
  "description": "In most cases, trust boundaries are violated when a secret is exposed in a source code repository or an uncontrolled deployment environment. Unintended people who don\u2019t need to know the secret might get access to it. They might then be able to use it to gain unwanted access to associated services or resources.",
  "status": "ready",
  "defaultSeverity": "Info",
  "category": "Security",
  "recommendation": "Review and fix according to the rule guidelines.",
  "impact": "Security risk",
  "tags": [
    "security",
    "cwe"
  ],
  "examples": {
    "noncompliant": [],
    "compliant": [
      {
        "code": "# Using environment variable for database password\nimport os\nimport psycopg2\n\ndb = psycopg2.connect(\n    dbname='production',\n    user='admin',\n    password=os.environ.get('DB_PASSWORD')\n)",
        "language": "python",
        "description": "Database password loaded from environment"
      },
      {
        "code": "// MySQL connection using environment variables\nconst mysql = require('mysql');\n\nconst connection = mysql.createConnection({\n  host: process.env.DB_HOST,\n  user: process.env.DB_USER,\n  password: process.env.DB_PASSWORD,\n  database: process.env.DB_NAME\n});",
        "language": "javascript",
        "description": "Using environment variables for database credentials"
      }
    ]
  },
  "references": [
    "https://rules.sonarsource.com/secrets/RSPEC-6703"
  ],
  "logic": {
    "node_types": [],
    "checks": [
      {
        "type": "regex",
        "pattern": "[\"']?(?:password|pwd|passwd|pass|key)[\"']?[\\s]*[=:][\\s]*[\"']?[A-Za-z0-9!@#$%^&*()_+=\\[\\]{}|;:,.<>?/\\\\~-]{8,50}",
        "message": "Detected hardcoded database password",
