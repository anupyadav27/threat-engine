{
  "filename": "mailgun_api_keys_should_not_be_disclosed_metadata.json",
  "rule_id": "mailgun_api_keys_disclosed",
  "title": "Mailgun API keys should not be disclosed",
  "description": "In most cases, trust boundaries are violated when a secret is exposed in a source code repository or an uncontrolled deployment environment. Unintended people who don\u2019t need to know the secret might get access to it. They might then be able to use it to gain unwanted access to associated services or resources.",
  "status": "ready",
  "defaultSeverity": "Info",
  "category": "Security",
  "recommendation": "Review and fix according to the rule guidelines.",
  "impact": "Security risk",
  "tags": [
    "security",
    "cwe"
  ],
  "examples": {
    "noncompliant": [],
    "compliant": [
      {
        "code": "MAILGUN_API_KEY = os.environ.get('MAILGUN_API_KEY')",
        "description": "Reading API key from environment variable"
      },
      {
        "code": "const apiKey = process.env.MAILGUN_API_KEY;\nconst mg = mailgun({apiKey, domain: DOMAIN});",
        "description": "Using environment variable instead of hardcoded value"
      }
    ]
  },
  "references": [
    "https://rules.sonarsource.com/secrets/RSPEC-6723"
  ],
  "logic": {
    "node_types": [],
    "checks": [
      {
        "type": "regex",
        "pattern": "\\bkey-[a-f0-9]{32}\\b",
        "message": "Mailgun private API key detected. Exposing this key allows unauthorized access to send emails, manage domains, and access sensitive recipient data. Revoke the key immediately and store it securely.",
        "context_keywords": [
          "mailgun",
          "Mailgun",
          "MAILGUN",
          "mailgun_api_key",
          "mailgunApiKey",
          "MailgunApiKey",
          "MAILGUN_API_KEY",
