          "MESSAGING"
        ]
      },
      {
        "type": "regex",
        "pattern": "\\bpubkey-[a-f0-9]{32}\\b",
        "message": "Mailgun public API key detected. While less sensitive than private keys, public keys can still reveal domain information and should be protected.",
        "context_keywords": [
