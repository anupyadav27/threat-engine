          "mailgunKey",
          "MailgunKey",
          "MAILGUN_KEY",
          "api_key",
          "apiKey",
          "ApiKey",
          "API_KEY",
          "mg_api_key",
          "mgApiKey",
          "MG_API_KEY",
          "mailgun.com",
          "api.mailgun.net",
          "mailgun_client",
          "mailgunClient",
