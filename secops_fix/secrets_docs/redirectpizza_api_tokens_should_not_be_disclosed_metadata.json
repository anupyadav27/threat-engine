{
  "filename": "redirectpizza_api_tokens_should_not_be_disclosed_metadata.json",
  "rule_id": "redirectpizza_api_tokens_disclosed",
  "title": "redirect.pizza API tokens should not be disclosed",
  "description": "In most cases, trust boundaries are violated when a secret is exposed in a source code repository or an uncontrolled deployment environment. Unintended people who don\u2019t need to know the secret might get access to it. They might then be able to use it to gain unwanted access to associated services or resources.",
  "status": "ready",
  "defaultSeverity": "Info",
  "category": "Security",
  "recommendation": "Review and fix according to the rule guidelines.",
  "impact": "Security risk",
  "tags": [
    "security",
    "cwe"
  ],
  "examples": {
    "noncompliant": [],
    "compliant": []
  },
  "references": [
    "https://rules.sonarsource.com/secrets/RSPEC-7139"
  ],
  "logic": {
    "node_types": [],
    "checks": [
      {
        "type": "regex",
        "pattern": "\\brdpz_[A-Za-z0-9]{32,64}\\b",
        "message": "redirect.pizza API token detected in source code. redirect.pizza tokens provide programmatic access to URL shortening and redirect management services. Exposing these credentials allows attackers to create malicious redirects, hijack existing short URLs, monitor redirect analytics, manipulate redirect rules, and potentially use the service for phishing campaigns or malware distribution. IMMEDIATELY revoke this token from your redirect.pizza dashboard, generate a new replacement token, audit all existing redirects for unauthorized modifications, review access logs for suspicious activity, store credentials securely using environment variables or secret management systems (AWS Secrets Manager, Azure Key Vault, HashiCorp Vault), and implement proper access controls.",
        "context_keywords": [
          "redirect",
          "Redirect",
          "REDIRECT",
          "pizza",
          "Pizza",
          "PIZZA",
          "redirectpizza",
          "redirectPizza",
