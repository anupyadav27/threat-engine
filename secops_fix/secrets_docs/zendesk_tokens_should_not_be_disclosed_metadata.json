{
  "filename": "zendesk_tokens_should_not_be_disclosed_metadata.json",
  "rule_id": "zendesk_tokens_disclosed",
  "title": "Zendesk tokens should not be disclosed",
  "description": "In most cases, trust boundaries are violated when a secret is exposed in a source code repository or an uncontrolled deployment environment. Unintended people who don\u2019t need to know the secret might get access to it. They might then be able to use it to gain unwanted access to associated services or resources.",
  "status": "ready",
  "defaultSeverity": "Info",
  "category": "Security",
  "recommendation": "Review and fix according to the rule guidelines.",
  "impact": "Security risk",
  "tags": [
    "security",
    "cwe"
  ],
  "examples": {
    "noncompliant": [],
    "compliant": []
  },
  "references": [
    "https://rules.sonarsource.com/secrets/RSPEC-7389"
  ],
  "logic": {
    "node_types": [],
    "checks": [
      {
        "type": "regex",
        "pattern": "\\b[A-Za-z0-9]{32,48}\\b",
        "message": "Zendesk API token detected. This token provides authenticated access to Zendesk support platform including ticket management, customer data, help center content, and support analytics. Exposing Zendesk tokens enables unauthorized access to customer support data, ticket manipulation, and potential customer information leakage. Immediately revoke this token from your Zendesk admin panel and implement secure credential storage using environment variables.",
