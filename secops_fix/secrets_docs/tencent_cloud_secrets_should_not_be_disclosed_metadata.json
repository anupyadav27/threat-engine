{
  "filename": "tencent_cloud_secrets_should_not_be_disclosed_metadata.json",
  "rule_id": "tencent_cloud_secrets_disclosed",
  "title": "Tencent Cloud secrets should not be disclosed",
  "description": "In most cases, trust boundaries are violated when a secret is exposed in a source code repository or an uncontrolled deployment environment. Unintended people who don\u2019t need to know the secret might get access to it. They might then be able to use it to gain unwanted access to associated services or resources.",
  "status": "ready",
  "defaultSeverity": "Critical",
  "category": "Security",
  "recommendation": "Review and fix according to the rule guidelines.",
  "impact": "Security risk",
  "tags": [
    "security",
    "cwe",
    "performance"
  ],
  "examples": {
    "noncompliant": [],
    "compliant": [
      {
        "code": "SECRET_ID = os.environ.get('TENCENT_SECRET_ID')",
        "description": "Tencent Cloud SecretId from environment variable"
      },
      {
        "code": "const tencentKey = process.env.TENCENT_CLOUD_SECRET_KEY",
        "description": "Tencent Cloud SecretKey from environment"
      }
    ]
  },
  "references": [
    "https://rules.sonarsource.com/secrets/RSPEC-7007"
  ],
  "logic": {
    "node_types": [],
    "checks": [
      {
        "type": "regex",
        "pattern": "\\bAKID[A-Za-z0-9]{32,40}\\b",
        "message": "Tencent Cloud SecretId detected in source code",
        "context_keywords": [
          "tencent",
          "Tencent",
          "TENCENT",
          "tencent_cloud",
          "tencentCloud",
          "TencentCloud",
          "TENCENT_CLOUD",
          "secret_id",
          "secretId",
          "SecretId",
          "SECRET_ID",
          "tencent_secret_id",
          "tencentSecretId",
          "TencentSecretId",
          "TENCENT_SECRET_ID",
          "qcloud",
          "Qcloud",
          "QCLOUD",
          "tencent_api",
          "tencentApi",
          "TencentApi",
          "TENCENT_API",
          "cos",
          "COS",
          "cvm",
          "CVM",
          "tcb",
          "TCB",
          "cam",
          "CAM",
          "cdn",
          "CDN",
          "cdb",
          "CDB",
          "credential",
          "Credential",
          "CREDENTIAL",
          "tencentcloud",
          "TencentCloud"
        ]
      },
      {
        "type": "regex",
        "pattern": "\\b(?!AKID)[A-Za-z0-9+/]{32,44}={0,2}\\b",
        "message": "Potential Tencent Cloud SecretKey detected in source code",
        "context_keywords": [
          "tencent",
          "Tencent",
          "TENCENT",
          "secret_key",
          "secretKey",
          "SecretKey",
          "SECRET_KEY",
          "tencent_secret_key",
          "tencentSecretKey",
          "TencentSecretKey",
          "TENCENT_SECRET_KEY",
          "qcloud",
          "Qcloud",
          "QCLOUD",
          "tencent_cloud",
          "tencentCloud",
          "TencentCloud",
          "TENCENT_CLOUD",
          "api_key",
          "apiKey",
          "ApiKey",
          "API_KEY",
          "access_key",
          "accessKey",
          "AccessKey",
          "ACCESS_KEY",
          "cos_secret",
          "cosSecret",
          "CosSecret",
          "COS_SECRET",
          "cvm_secret",
          "cvmSecret",
          "CvmSecret",
          "CVM_SECRET",
          "credential",
          "Credential",
          "CREDENTIAL"
        ]
      },
      {
        "type": "regex",
        "pattern": "\\b(?!AKID)[A-Z]{2,4}[A-Za-z0-9]{20,40}\\b",
        "message": "Potential Tencent Cloud service API key detected in source code",
        "context_keywords": [
          "tencent",
          "Tencent",
          "TENCENT",
          "qcloud",
          "cos",
          "COS",
          "cvm",
          "CVM",
          "tcb",
          "TCB",
          "cdn",
          "CDN",
          "api_key",
          "apiKey",
          "service_key",
          "serviceKey",
          "app_key",
          "appKey",
          "application_key",
          "applicationKey",
          "tencent_api",
          "tencentApi",
          "qcloud_api",
          "qcloudApi",
          "cvm_api",
          "cos_api",
          "tcb_api",
          "cdn_api"
        ]
      },
      {
        "type": "regex",
        "pattern": "\"SecretId\"\\s*:\\s*\"AKID[A-Za-z0-9]{32,40}\"",
        "message": "Tencent Cloud credentials object with SecretId detected in source code",
        "context_keywords": [
          "tencent",
