{
  "filename": "kubernetes_docker_secrets_should_not_be_disclosed_metadata.json",
  "rule_id": "kubernetes_docker_secrets_disclosed",
  "title": "Kubernetes Docker secrets should not be disclosed",
  "description": "In most cases, trust boundaries are violated when a secret is exposed in a source code repository or an uncontrolled deployment environment. Unintended people who don\u2019t need to know the secret might get access to it. They might then be able to use it to gain unwanted access to associated services or resources.",
  "status": "ready",
  "defaultSeverity": "Info",
  "category": "Security",
  "recommendation": "Review and fix according to the rule guidelines.",
  "impact": "Security risk",
  "tags": [
    "security",
    "cwe"
  ],
  "examples": {
    "noncompliant": [],
    "compliant": []
  },
  "references": [
    "https://rules.sonarsource.com/secrets/RSPEC-7289"
  ],
  "logic": {
    "node_types": [],
    "checks": [
      {
        "type": "regex",
        "pattern": "\\.dockerconfigjson:\\s*[A-Za-z0-9+/=]{100,}",
        "message": "Kubernetes Docker secret detected - .dockerconfigjson field with base64-encoded registry credentials",
        "context_keywords": [
          "kubernetes",
          "Kubernetes",
          "KUBERNETES",
          "k8s",
          "K8s",
          "K8S",
          "Secret",
          "secret",
          "SECRET",
          "dockerconfigjson",
          ".dockerconfigjson",
          "dockerConfigJson",
          "DockerConfigJson",
          "DOCKERCONFIGJSON",
          "docker",
          "Docker",
          "DOCKER",
          "registry",
          "Registry",
          "REGISTRY",
          "docker-registry",
          "dockerRegistry",
          "image",
          "Image",
          "IMAGE",
          "imagePullSecrets",
          "imagePullSecret",
          "ImagePullSecrets",
          "pull-secret",
          "pullSecret",
          "auth",
          "Auth",
          "AUTH",
          "auths",
          "authentication",
          "kind",
          "Kind",
          "KIND",
          "apiVersion",
          "metadata",
          "data",
          "type",
          "kubernetes.io/dockerconfigjson"
        ]
      },
      {
        "type": "regex",
        "pattern": "\\bdockerconfigjson:\\s*[A-Za-z0-9+/=]{100,}",
        "message": "Kubernetes Docker secret detected - dockerconfigjson field with base64-encoded registry credentials",
        "context_keywords": [
