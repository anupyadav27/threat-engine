{
  "filename": "algolia_keys_should_not_be_disclosed_metadata.json",
  "rule_id": "algolia_keys_disclosed",
  "title": "Algolia keys should not be disclosed",
  "description": "In most cases, trust boundaries are violated when a secret is exposed in a source code repository or an uncontrolled deployment environment. Unintended people who don\u2019t need to know the secret might get access to it. They might then be able to use it to gain unwanted access to associated services or resources.",
  "status": "ready",
  "defaultSeverity": "Info",
  "category": "Security",
  "recommendation": "Review and fix according to the rule guidelines.",
  "impact": "Security risk",
  "tags": [
    "security",
    "cwe"
  ],
  "examples": {
    "noncompliant": [],
    "compliant": [
      {
        "code": "ALGOLIA_API_KEY = os.environ.get('ALGOLIA_API_KEY')",
        "description": "Algolia API key retrieved from environment variable"
      },
      {
        "code": "const apiKey = process.env.ALGOLIA_SEARCH_KEY",
        "description": "Algolia API key retrieved from environment"
      }
    ]
  },
  "references": [
    "https://rules.sonarsource.com/secrets/RSPEC-7213"
  ],
  "logic": {
    "node_types": [],
    "checks": [
      {
        "type": "regex",
        "pattern": "\\b[a-fA-F0-9]{32}\\b",
        "message": "Algolia API key (32-char hexadecimal) detected in source code",
        "context_keywords": [
          "algolia",
          "ALGOLIA_API_KEY",
          "ALGOLIA_ADMIN_KEY",
          "ALGOLIA_SEARCH_KEY",
          "algoliasearch",
          "search-only",
          "admin-key",
          "ALGOLIA"
        ]
      },
      {
        "type": "regex",
        "pattern": "\\b[A-Z0-9]{10}\\b",
        "message": "Potential Algolia Application ID detected in source code",
        "context_keywords": [
          "algolia",
          "ALGOLIA_APP_ID",
          "ALGOLIA_APPLICATION_ID",
          "algoliasearch",
          "app_id",
          "application_id",
          "algolia_app"
        ]
      },
      {
        "type": "regex",
        "pattern": "algoliasearch\\(['\"]\\s*[A-Z0-9]{10}\\s*['\"]\\s*,\\s*['\"]\\s*[a-zA-Z0-9]{32}",
        "message": "Algolia credentials in algoliasearch() function call detected in source code",
        "context_keywords": [
          "algolia",
          "algoliasearch",
          "search",
          "client"
        ]
      },
      {
        "type": "regex",
        "pattern": "\\b[a-zA-Z0-9]{32}\\b",
        "message": "Algolia API key (32-char alphanumeric) detected in source code",
        "context_keywords": [
          "algolia",
          "ALGOLIA_API_KEY",
          "algolia_key",
          "ALGOLIA",
          "algoliasearch",
          "search_key",
          "admin_key"
        ]
      }
    ]
  }
}