{
  "filename": "artifactory_tokens_should_not_be_disclosed_metadata.json",
  "rule_id": "artifactory_tokens_disclosed",
  "title": "Artifactory tokens should not be disclosed",
  "description": "In most cases, trust boundaries are violated when a secret is exposed in a source code repository or an uncontrolled deployment environment. Unintended people who don\u2019t need to know the secret might get access to it. They might then be able to use it to gain unwanted access to associated services or resources.",
  "status": "ready",
  "defaultSeverity": "Info",
  "category": "Security",
  "recommendation": "Review and fix according to the rule guidelines.",
  "impact": "Security risk",
  "tags": [
    "security",
    "cwe"
  ],
  "examples": {
    "noncompliant": [],
    "compliant": [
      {
        "code": "ARTIFACTORY_TOKEN = os.environ.get('ARTIFACTORY_TOKEN')",
        "description": "Artifactory token retrieved from environment variable"
      },
      {
        "code": "const token = process.env.ARTIFACTORY_API_KEY",
        "description": "Artifactory API key retrieved from environment"
      }
    ]
  },
  "references": [
    "https://rules.sonarsource.com/secrets/RSPEC-6752"
  ],
  "logic": {
    "node_types": [],
    "checks": [
      {
        "type": "regex",
        "pattern": "\\bAKC[a-zA-Z0-9]{40,100}\\b",
        "message": "Artifactory access token detected in source code",
        "context_keywords": [
          "artifactory",
          "jfrog",
          "AKC",
          "X-JFrog-Art-Api",
          "artifactory_token",
          "ARTIFACTORY_TOKEN",
          "ARTIFACTORY",
          "rtUrl",
          "rt_url",
          "repository",
          "maven",
          "npm",
          "api",
          "token",
          "auth",
          "credentials"
        ]
      },
      {
        "type": "regex",
        "pattern": "\\bAP[A-Za-z0-9]{20,80}\\b",
        "message": "Artifactory API key detected in source code",
        "context_keywords": [
          "artifactory",
          "jfrog",
          "ARTIFACTORY",
          "X-JFrog-Art-Api",
          "api_key",
          "apiKey",
          "API_KEY",
          "rtUrl",
          "rt_url",
          "token",
          "auth",
          "credentials",
          "repository"
        ]
      },
      {
        "type": "regex",
        "pattern": "\\beyJ[a-zA-Z0-9_-]{30,}\\.eyJ[a-zA-Z0-9_-]{30,}\\.[a-zA-Z0-9_-]{30,}\\b",
        "message": "Artifactory identity token (JWT) detected in source code",
        "context_keywords": [
          "artifactory",
          "jfrog",
          "ARTIFACTORY",
          "identity_token",
          "jwt",
          "bearer",
          "authorization",
          "auth",
          "token",
          "rtUrl",
          "rt_url"
        ]
      }
    ]
  }
}