{
  "filename": "ldap_credentials_should_not_be_disclosed_metadata.json",
  "rule_id": "ldap_credentials_disclosed",
  "title": "LDAP credentials should not be disclosed",
  "description": "In most cases, trust boundaries are violated when a secret is exposed in a source code repository or an uncontrolled deployment environment. Unintended people who don\u2019t need to know the secret might get access to it. They might then be able to use it to gain unwanted access to associated services or resources.",
  "status": "ready",
  "defaultSeverity": "Info",
  "category": "Security",
  "recommendation": "Review and fix according to the rule guidelines.",
  "impact": "Security risk",
  "tags": [
    "security",
    "cwe"
  ],
  "examples": {
    "noncompliant": [],
    "compliant": []
  },
  "references": [
    "https://rules.sonarsource.com/secrets/RSPEC-7537"
  ],
  "logic": {
    "node_types": [],
    "checks": [
      {
        "type": "regex",
        "pattern": "ldaps?://[a-zA-Z0-9._-]+:[^@\\s'\"<>`{}]+@[a-zA-Z0-9._-]+(?::[0-9]{1,5})?",
        "message": "LDAP connection string with embedded credentials detected in source code",
        "context_keywords": [
          "ldap",
          "LDAP",
          "ldaps",
          "LDAPS",
          "ldap_url",
          "ldapUrl",
          "LDAP_URL",
          "ldap_connection",
          "ldapConnection",
          "LDAP_CONNECTION",
          "directory",
          "active_directory",
          "activeDirectory",
          "ACTIVE_DIRECTORY",
          "bind",
          "bind_dn",
          "bindDN",
          "BIND_DN",
          "ldap_server",
          "ldapServer",
          "LDAP_SERVER",
          "ldap_host",
          "ldapHost",
          "LDAP_HOST"
        ]
      },
      {
        "type": "regex",
        "pattern": "\\b[a-zA-Z0-9._-]{3,50}:[^@\\s'\"<>`{}]{6,100}@[a-zA-Z0-9._-]+:[0-9]{2,5}",
        "message": "Potential LDAP credentials in connection format detected in source code",
        "context_keywords": [
          "ldap",
          "LDAP",
          "ldaps",
          "directory",
          "active_directory",
          "ad_server",
          "adServer",
          "AD_SERVER",
          "bind_password",
          "bindPassword",
          "BIND_PASSWORD",
          "ldap_password",
          "ldapPassword",
          "LDAP_PASSWORD",
          "cn=",
          "dc=",
          "ou=",
          "distinguished_name",
          "distinguishedName",
          "DISTINGUISHED_NAME",
          "ldap_bind",
          "ldapBind",
          "LDAP_BIND",
          "auth",
          "authentication"
        ]
      },
      {
        "type": "regex",
        "pattern": "\\b[A-Za-z0-9+/]{40,200}={0,2}\\b",
        "message": "Potential LDAP bind password detected in source code",
        "context_keywords": [
          "ldap_password",
          "ldapPassword",
          "LDAP_PASSWORD",
          "bind_password",
          "bindPassword",
          "BIND_PASSWORD",
          "ldap_bind",
          "ldapBind",
          "LDAP_BIND",
          "ldap_credentials",
          "ldapCredentials",
          "LDAP_CREDENTIALS",
          "ldap_auth",
          "ldapAuth",
          "LDAP_AUTH",
          "active_directory_password",
          "activeDirectoryPassword",
          "ACTIVE_DIRECTORY_PASSWORD",
          "ad_password",
          "adPassword",
          "AD_PASSWORD",
          "directory_password",
          "directoryPassword",
          "DIRECTORY_PASSWORD",
          "ldap_secret",
          "ldapSecret",
          "LDAP_SECRET",
          "cn=",
          "dc=",
          "ou=",
          "bind_dn",
          "bindDN",
          "BIND_DN"
        ]
      }
    ]
  }
}