{
  "filename": "messagebird_keys_should_not_be_disclosed_metadata.json",
  "rule_id": "messagebird_keys_disclosed",
  "title": "MessageBird keys should not be disclosed",
  "description": "In most cases, trust boundaries are violated when a secret is exposed in a source code repository or an uncontrolled deployment environment. Unintended people who don\u2019t need to know the secret might get access to it. They might then be able to use it to gain unwanted access to associated services or resources.",
  "status": "ready",
  "defaultSeverity": "Info",
  "category": "Security",
  "recommendation": "Review and fix according to the rule guidelines.",
  "impact": "Security risk",
  "tags": [
    "security",
    "cwe"
  ],
  "examples": {
    "noncompliant": [],
    "compliant": []
  },
  "references": [
    "https://rules.sonarsource.com/secrets/RSPEC-7298"
  ],
  "logic": {
    "node_types": [],
    "checks": [
      {
        "type": "regex",
        "pattern": "\\b[A-Za-z0-9]{25,32}\\b",
        "message": "MessageBird API key detected in source code",
        "context_keywords": [
          "messagebird",
          "MessageBird",
          "MESSAGEBIRD",
          "message_bird",
          "messageBird",
          "MESSAGE_BIRD",
          "messagebird_api",
