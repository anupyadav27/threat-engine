{
  "filename": "postmark_server_token_should_not_be_disclosed_metadata.json",
  "rule_id": "postmark_server_token_disclosed",
  "title": "Postmark server token should not be disclosed",
  "description": "In most cases, trust boundaries are violated when a secret is exposed in a source code repository or an uncontrolled deployment environment. Unintended people who don\u2019t need to know the secret might get access to it. They might then be able to use it to gain unwanted access to associated services or resources.",
  "status": "ready",
  "defaultSeverity": "Info",
  "category": "Security",
  "recommendation": "Review and fix according to the rule guidelines.",
  "impact": "Security risk",
  "tags": [
    "security",
    "cwe"
  ],
  "examples": {
    "noncompliant": [],
    "compliant": []
  },
  "references": [
    "https://rules.sonarsource.com/secrets/RSPEC-6910"
  ],
  "logic": {
    "node_types": [],
    "checks": [
      {
        "type": "regex",
        "pattern": "\\b[a-f0-9]{8}-[a-f0-9]{4}-[a-f0-9]{4}-[a-f0-9]{4}-[a-f0-9]{12}\\b",
        "message": "Postmark Server Token detected. Postmark is a transactional email service that uses server tokens for API authentication. Exposing this token allows unauthorized users to send emails through your Postmark account, access message statistics, manage templates, and view bounce/spam complaints. This can lead to email spam abuse, account suspension, reputation damage, and unauthorized access to sensitive email data. Revoke this token immediately from your Postmark account settings and generate a new one. Store tokens securely in environment variables or secret management systems (AWS Secrets Manager, HashiCorp Vault, Azure Key Vault, etc.).",
        "context_keywords": [
          "postmark",
          "Postmark",
          "POSTMARK",
          "postmark_api",
          "postmarkApi",
          "PostmarkApi",
          "POSTMARK_API",
          "postmark_token",
          "postmarkToken",
          "PostmarkToken",
          "POSTMARK_TOKEN",
          "postmark_server",
          "postmarkServer",
          "PostmarkServer",
          "POSTMARK_SERVER",
          "postmark_server_token",
          "postmarkServerToken",
          "PostmarkServerToken",
          "POSTMARK_SERVER_TOKEN",
          "server_token",
          "serverToken",
          "SERVER_TOKEN",
          "api_token",
          "apiToken",
          "API_TOKEN",
          "postmark.com",
          "api.postmarkapp.com",
          "postmarkapp.com",
          "postmark_client",
          "postmarkClient",
          "PostmarkClient",
          "POSTMARK_CLIENT",
          "transactional",
          "Transactional",
          "TRANSACTIONAL",
          "transactional_email",
          "transactionalEmail",
          "TRANSACTIONAL_EMAIL",
          "email_service",
          "emailService",
          "EMAIL_SERVICE",
          "email_api",
          "emailApi",
          "EMAIL_API",
          "smtp_api",
          "smtpApi",
          "SMTP_API",
          "mail_service",
          "mailService",
          "MAIL_SERVICE",
          "mail_api",
          "mailApi",
          "MAIL_API",
          "send_email",
          "sendEmail",
          "SEND_EMAIL",
          "X-Postmark-Server-Token",
          "x-postmark-server-token"
        ]
      },
      {
        "type": "regex",
        "pattern": "(?i)(postmark_server_token|postmark_token|postmark_api_token|postmark_api_key|postmark_server_api_token)\\s*[:=]\\s*[\"']?([a-f0-9-]{32,40}|[a-f0-9]{8}-[a-f0-9]{4}-[a-f0-9]{4}-[a-f0-9]{4}-[a-f0-9]{12})[\"']?",
        "message": "Postmark Server Token detected in variable assignment. Postmark tokens provide full access to sending transactional emails, managing templates, viewing analytics, and accessing bounce/spam data. Exposing these credentials enables attackers to send unauthorized emails, exhaust your email quota, damage your sender reputation, and potentially access sensitive customer email data. Immediately revoke the exposed token and generate a new one. Implement secure token storage using environment variables or dedicated secret management services.",
        "context_keywords": [
