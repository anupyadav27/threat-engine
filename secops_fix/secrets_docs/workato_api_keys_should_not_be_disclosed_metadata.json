{
  "filename": "workato_api_keys_should_not_be_disclosed_metadata.json",
  "rule_id": "workato_api_keys_disclosed",
  "title": "Workato API keys should not be disclosed",
  "description": "In most cases, trust boundaries are violated when a secret is exposed in a source code repository or an uncontrolled deployment environment. Unintended people who don\u2019t need to know the secret might get access to it. They might then be able to use it to gain unwanted access to associated services or resources.",
  "status": "ready",
  "defaultSeverity": "Info",
  "category": "Security",
  "recommendation": "Review and fix according to the rule guidelines.",
  "impact": "Security risk",
  "tags": [
    "security",
    "cwe"
  ],
  "examples": {
    "noncompliant": [],
    "compliant": []
  },
  "references": [
    "https://rules.sonarsource.com/secrets/RSPEC-7384"
  ],
  "logic": {
    "node_types": [],
    "checks": [
      {
        "type": "regex",
        "pattern": "\\b[A-Za-z0-9]{64,128}\\b",
        "message": "Workato API token detected. This token provides authenticated access to Workato integration platform services including workflow automation, data transformation, and third-party API connections. Unauthorized access can lead to data breaches, unauthorized integrations, workflow manipulation, and exposure of connected systems. Immediately revoke this token from your Workato account settings and rotate credentials using secure environment variables.",
        "context_keywords": [
          "workato",
          "Workato",
          "WORKATO",
          "workato_api",
          "workatoApi",
          "WorkatoApi",
          "WORKATO_API",
          "workato_token",
          "workatoToken",
          "WorkatoToken",
          "WORKATO_TOKEN",
          "workato_key",
          "workatoKey",
          "WorkatoKey",
          "WORKATO_KEY",
          "workato_auth",
          "workatoAuth",
          "WorkatoAuth",
          "WORKATO_AUTH",
          "workato_access_token",
          "workatoAccessToken",
          "WorkatoAccessToken",
          "WORKATO_ACCESS_TOKEN",
          "workato_bearer_token",
          "workatoBearerToken",
          "WorkatoBearerToken",
          "WORKATO_BEARER_TOKEN",
          "integration_token",
          "integrationToken",
          "IntegrationToken",
          "INTEGRATION_TOKEN",
          "automation_token",
          "automationToken",
          "AutomationToken",
          "AUTOMATION_TOKEN",
          "workflow_token",
          "workflowToken",
          "WorkflowToken",
          "WORKFLOW_TOKEN",
          "workato.com",
          "app.workato.com",
          "www.workato.com"
        ]
      },
      {
        "type": "regex",
        "pattern": "\\b[A-Za-z0-9]{40,80}\\b",
        "message": "Workato access token or webhook token detected. This token grants access to Workato integration services including webhook verification, connector authentication, and workflow execution. Exposing Workato tokens enables unauthorized access to integrations, data manipulation across connected systems, and potential security breaches in automated workflows. Revoke immediately from Workato console and implement secure credential storage.",
        "context_keywords": [
          "workato",
          "Workato",
          "WORKATO",
          "workato_webhook",
          "workatoWebhook",
          "WorkatoWebhook",
          "WORKATO_WEBHOOK",
          "workato_connector",
          "workatoConnector",
          "WorkatoConnector",
          "WORKATO_CONNECTOR",
          "workato_oauth",
          "workatoOauth",
          "WorkatoOauth",
          "WORKATO_OAUTH",
          "workato_client_token",
          "workatoClientToken",
          "WorkatoClientToken",
          "WORKATO_CLIENT_TOKEN",
          "workato_verification",
          "workatoVerification",
          "WorkatoVerification",
          "WORKATO_VERIFICATION",
          "webhook_token",
          "webhookToken",
          "WebhookToken",
          "WEBHOOK_TOKEN",
          "connector_token",
          "connectorToken",
          "ConnectorToken",
          "CONNECTOR_TOKEN",
          "automation_key",
          "automationKey",
          "AutomationKey",
          "AUTOMATION_KEY",
          "integration_auth",
          "integrationAuth",
          "IntegrationAuth",
          "INTEGRATION_AUTH",
          "workflow_auth",
          "workflowAuth",
          "WorkflowAuth",
          "WORKFLOW_AUTH",
          "workato.com"
        ]
      },
      {
        "type": "regex",
        "pattern": "\\b[A-Za-z0-9]{20,40}\\b",
        "message": "Workato client ID or connector ID detected. These identifiers are used to authenticate and access Workato integration platform services. While less sensitive than API tokens, exposing these can reveal integration configuration details and enable targeted attacks against your automation workflows. Store securely using environment variables or configuration management.",
        "context_keywords": [
