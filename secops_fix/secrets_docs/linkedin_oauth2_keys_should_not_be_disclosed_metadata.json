{
  "filename": "linkedin_oauth2_keys_should_not_be_disclosed_metadata.json",
  "rule_id": "linkedin_oauth2_keys_disclosed",
  "title": "Linkedin OAuth2 keys should not be disclosed",
  "description": "In most cases, trust boundaries are violated when a secret is exposed in a source code repository or an uncontrolled deployment environment. Unintended people who don\u2019t need to know the secret might get access to it. They might then be able to use it to gain unwanted access to associated services or resources.",
  "status": "ready",
  "defaultSeverity": "Info",
  "category": "Security",
  "recommendation": "Review and fix according to the rule guidelines.",
  "impact": "Security risk",
  "tags": [
    "security",
    "cwe"
  ],
  "examples": {
    "noncompliant": [],
    "compliant": []
  },
  "references": [
    "https://rules.sonarsource.com/secrets/RSPEC-7294"
  ],
  "logic": {
    "node_types": [],
    "checks": [
      {
        "type": "regex",
        "pattern": "\\b[A-Za-z0-9_-]{32,99}\\b",
        "message": "LinkedIn OAuth2 client secret detected in source code",
        "context_keywords": [
          "linkedin",
          "LinkedIn",
          "LINKEDIN",
          "linkedin_api",
          "linkedinApi",
          "LINKEDIN_API",
          "linkedin_oauth",
          "linkedinOauth",
          "LINKEDIN_OAUTH",
          "linkedin_oauth2",
          "linkedinOauth2",
          "LINKEDIN_OAUTH2",
          "linkedin_client",
          "linkedinClient",
          "LINKEDIN_CLIENT",
          "linkedin_auth",
          "linkedinAuth",
          "LINKEDIN_AUTH",
          "client_secret",
          "clientSecret",
          "CLIENT_SECRET",
          "linkedin_client_secret",
          "linkedinClientSecret",
          "LINKEDIN_CLIENT_SECRET",
          "consumer_secret",
          "consumerSecret",
          "CONSUMER_SECRET",
          "app_secret",
          "appSecret",
          "APP_SECRET",
          "oauth_secret",
          "oauthSecret",
          "OAUTH_SECRET",
          "api.linkedin.com",
          "www.linkedin.com/oauth",
          "oauth2",
          "OAuth2",
          "OAUTH2"
        ]
      },
      {
        "type": "regex",
        "pattern": "\\b[A-Za-z0-9_-]{100,500}\\b",
        "message": "LinkedIn OAuth2 access token detected in source code",
        "context_keywords": [
          "linkedin",
          "LinkedIn",
          "LINKEDIN",
          "linkedin_api",
          "linkedinApi",
          "LINKEDIN_API",
          "linkedin_oauth",
          "linkedinOauth",
          "LINKEDIN_OAUTH",
          "linkedin_oauth2",
          "linkedinOauth2",
          "LINKEDIN_OAUTH2",
          "linkedin_token",
          "linkedinToken",
          "LINKEDIN_TOKEN",
          "linkedin_access_token",
          "linkedinAccessToken",
          "LINKEDIN_ACCESS_TOKEN",
          "access_token",
          "accessToken",
          "ACCESS_TOKEN",
          "oauth_token",
          "oauthToken",
          "OAUTH_TOKEN",
          "linkedin_access",
          "linkedinAccess",
          "LINKEDIN_ACCESS",
          "bearer",
          "Bearer",
          "BEARER",
          "authorization",
          "Authorization",
          "AUTHORIZATION",
          "api.linkedin.com",
          "www.linkedin.com/oauth",
          "oauth2",
          "OAuth2",
          "OAUTH2"
        ]
      },
      {
        "type": "regex",
        "pattern": "Bearer\\s+[A-Za-z0-9_-]{100,500}",
        "message": "LinkedIn OAuth2 bearer token detected in Authorization header",
        "context_keywords": [
          "linkedin",
          "LinkedIn",
          "LINKEDIN",
          "linkedin_api",
          "linkedinApi",
          "LINKEDIN_API",
