{
  "filename": "twitch_access_tokens_should_not_be_disclosed_metadata.json",
  "rule_id": "twitch_access_tokens_disclosed",
  "title": "Twitch access tokens should not be disclosed",
  "description": "In most cases, trust boundaries are violated when a secret is exposed in a source code repository or an uncontrolled deployment environment. Unintended people who don\u2019t need to know the secret might get access to it. They might then be able to use it to gain unwanted access to associated services or resources.",
  "status": "ready",
  "defaultSeverity": "Info",
  "category": "Security",
  "recommendation": "Review and fix according to the rule guidelines.",
  "impact": "Security risk",
  "tags": [
    "security",
    "cwe"
  ],
  "examples": {
    "noncompliant": [],
    "compliant": []
  },
  "references": [
    "https://rules.sonarsource.com/secrets/RSPEC-7560"
  ],
  "logic": {
    "node_types": [],
    "checks": [
      {
        "type": "regex",
        "pattern": "\\b[a-z0-9]{30}\\b",
        "message": "Twitch user access token detected in source code. User access tokens provide authenticated access to Twitch API on behalf of a specific user, enabling read/write operations on user data including channel information, stream settings, chat participation, and follower management. Exposing these tokens allows unauthorized access to user accounts and the ability to perform actions as that user. Revoke this token immediately in Twitch Developer Console.",
        "context_keywords": [
          "twitch",
          "Twitch",
          "TWITCH",
          "twitch_token",
          "twitchToken",
          "TwitchToken",
          "TWITCH_TOKEN",
