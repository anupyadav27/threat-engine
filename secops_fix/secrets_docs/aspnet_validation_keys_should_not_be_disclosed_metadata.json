{
  "filename": "aspnet_validation_keys_should_not_be_disclosed_metadata.json",
  "rule_id": "aspnet_validation_keys_disclosed",
  "title": "ASP.NET validation keys should not be disclosed",
  "description": "In most cases, trust boundaries are violated when a secret is exposed in a source code repository or an uncontrolled deployment environment. Unintended people who don\u2019t need to know the secret might get access to it. They might then be able to use it to gain unwanted access to associated services or resources.",
  "status": "ready",
  "defaultSeverity": "Info",
  "category": "Security",
  "recommendation": "Review and fix according to the rule guidelines.",
  "impact": "Security risk",
  "tags": [
    "security",
    "cwe"
  ],
  "examples": {
    "noncompliant": [],
    "compliant": [
      {
        "code": "<machineKey validationKey=\"AutoGenerate,IsolateApps\" validation=\"SHA1\" />",
        "description": "Auto-generated validation key (recommended)"
      },
      {
        "code": "string validationKey = ConfigurationManager.AppSettings[\"ValidationKey\"];",
        "description": "Validation key retrieved from configuration"
      }
    ]
  },
  "references": [
    "https://rules.sonarsource.com/secrets/RSPEC-7303"
  ],
  "logic": {
    "node_types": [],
    "checks": [
      {
        "type": "regex",
        "pattern": "validationKey[\"'\\s:=]+[\"']?([A-Fa-f0-9]{64,128})[\"']?",
        "message": "ASP.NET validation key detected in configuration",
        "context_keywords": [
          "machineKey",
          "validationKey",
          "ASP.NET",
          "aspnet",
          "web.config",
          "webconfig",
          "validation",
          "SHA1",
          "SHA256",
          "MD5",
          "HMACSHA256",
          "HMACSHA512",
          "machine",
          "key",
          "config",
          "configuration",
          "ValidationKey",
          "MachineKey",
          "system.web"
        ]
      },
      {
        "type": "regex",
        "pattern": "ValidationKey[\"'\\s:=]+[\"']?([A-Fa-f0-9]{64,128})[\"']?",
        "message": "ASP.NET ValidationKey property detected in code",
        "context_keywords": [
          "machineKey",
          "validationKey",
          "ValidationKey",
          "ASP.NET",
          "aspnet",
          "MachineKey",
          "validation",
          "SHA1",
          "SHA256",
          "HMACSHA256",
          "machine",
          "key",
          "config",
          "property"
        ]
      },
      {
        "type": "regex",
        "pattern": "\\b[A-F0-9]{64,128}\\b",
        "message": "Potential ASP.NET validation key (hex string) detected",
        "context_keywords": [
          "validationKey",
          "ValidationKey",
          "machineKey",
          "MachineKey",
          "ASP.NET",
