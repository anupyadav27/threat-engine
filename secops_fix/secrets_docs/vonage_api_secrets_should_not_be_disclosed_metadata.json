{
  "filename": "vonage_api_secrets_should_not_be_disclosed_metadata.json",
  "rule_id": "vonage_api_secrets_disclosed",
  "title": "Vonage API secrets should not be disclosed",
  "description": "In most cases, trust boundaries are violated when a secret is exposed in a source code repository or an uncontrolled deployment environment. Unintended people who don\u2019t need to know the secret might get access to it. They might then be able to use it to gain unwanted access to associated services or resources.",
  "status": "ready",
  "defaultSeverity": "Info",
  "category": "Security",
  "recommendation": "Review and fix according to the rule guidelines.",
  "impact": "Security risk",
  "tags": [
    "security",
    "cwe"
  ],
  "examples": {
    "noncompliant": [],
    "compliant": []
  },
  "references": [
    "https://rules.sonarsource.com/secrets/RSPEC-7380"
  ],
  "logic": {
    "node_types": [],
    "checks": [
      {
        "type": "regex",
        "pattern": "(?:vonage_api_secret|VONAGE_API_SECRET|vonageApiSecret|vonage_secret|VONAGE_SECRET|vonageSecret|nexmo_api_secret|NEXMO_API_SECRET|nexmoApiSecret|nexmo_secret|NEXMO_SECRET|nexmoSecret)\\s*[:=]\\s*[\"']([a-f0-9]{32})[\"']",
        "message": "Vonage API Secret detected in variable assignment. Vonage API Secrets are used with API Keys to authenticate requests to Vonage messaging, voice, video, and verification services. Exposing API Secrets provides full access to send SMS/MMS, make voice calls, manage phone numbers, and access billing information. Rotate this secret immediately in your Vonage Dashboard and implement secure credential storage.",
