          "WepayClient",
          "WEPAY_CLIENT",
          "payment_processor",
          "paymentProcessor",
          "PaymentProcessor",
          "PAYMENT_PROCESSOR",
          "payment_gateway",
          "paymentGateway",
          "PaymentGateway",
          "PAYMENT_GATEWAY",
          "wepay.com",
          "api.wepay.com"
        ]
      },
      {
        "type": "regex",
        "pattern": "\\b[A-Za-z0-9]{40,80}\\b",
        "message": "WePay access token detected. This token grants access to WePay payment services including transaction processing, account management, and sensitive financial operations. Exposing WePay tokens enables unauthorized payment manipulation, refund fraud, and access to merchant financial data. Revoke immediately from WePay developer console and implement secure credential storage.",
