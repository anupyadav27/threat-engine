{
  "filename": "wepay_tokens_should_not_be_disclosed_metadata.json",
  "rule_id": "wepay_tokens_disclosed",
  "title": "WePay tokens should not be disclosed",
  "description": "In most cases, trust boundaries are violated when a secret is exposed in a source code repository or an uncontrolled deployment environment. Unintended people who don\u2019t need to know the secret might get access to it. They might then be able to use it to gain unwanted access to associated services or resources.",
  "status": "ready",
  "defaultSeverity": "Info",
  "category": "Security",
  "recommendation": "Review and fix according to the rule guidelines.",
  "impact": "Security risk",
  "tags": [
    "security",
    "cwe"
  ],
  "examples": {
    "noncompliant": [],
    "compliant": []
  },
  "references": [
    "https://rules.sonarsource.com/secrets/RSPEC-7383"
  ],
  "logic": {
    "node_types": [],
    "checks": [
      {
        "type": "regex",
        "pattern": "\\bwp_[A-Za-z0-9]{32,64}\\b",
        "message": "WePay API token detected. This token provides authenticated access to WePay payment processing services including transaction management, merchant account operations, and financial data. Unauthorized access can lead to payment fraud, unauthorized refunds, customer data theft, and financial losses. Immediately revoke this token from your WePay dashboard and rotate credentials using secure environment variables.",
        "context_keywords": [
          "wepay",
          "WePay",
          "WEPAY",
          "we_pay",
          "wePay",
          "WE_PAY",
          "wepay_api",
          "wepayApi",
          "WepayApi",
          "WEPAY_API",
          "wepay_token",
          "wepayToken",
          "WepayToken",
          "WEPAY_TOKEN",
          "wepay_key",
