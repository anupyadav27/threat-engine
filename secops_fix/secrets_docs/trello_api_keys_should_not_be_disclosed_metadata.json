{
  "filename": "trello_api_keys_should_not_be_disclosed_metadata.json",
  "rule_id": "trello_api_keys_disclosed",
  "title": "Trello API keys should not be disclosed",
  "description": "In most cases, trust boundaries are violated when a secret is exposed in a source code repository or an uncontrolled deployment environment. Unintended people who don\u2019t need to know the secret might get access to it. They might then be able to use it to gain unwanted access to associated services or resources.",
  "status": "ready",
  "defaultSeverity": "Info",
  "category": "Security",
  "recommendation": "Review and fix according to the rule guidelines.",
  "impact": "Security risk",
  "tags": [
    "security",
    "cwe"
  ],
  "examples": {
    "noncompliant": [],
    "compliant": []
  },
  "references": [
    "https://rules.sonarsource.com/secrets/RSPEC-7371"
  ],
  "logic": {
    "node_types": [],
    "checks": [
      {
        "type": "regex",
        "pattern": "\\b[a-f0-9]{32}\\b",
        "message": "Trello API key detected. These keys provide programmatic access to Trello boards, cards, lists, and organization data. Exposing these keys enables unauthorized access to personal and team boards, sensitive project information, and the ability to modify or delete content. Revoke this key immediately from your Trello account settings.",
        "context_keywords": [
          "trello",
          "Trello",
          "TRELLO",
          "trello-api",
          "trello_api",
          "trelloApi",
          "TrelloApi",
          "TRELLO_API",
          "trello-key",
          "trello_key",
          "trelloKey",
          "TrelloKey",
          "TRELLO_KEY",
          "trello_api_key",
          "trelloApiKey",
          "TrelloApiKey",
          "TRELLO_API_KEY",
          "trello-api-key",
          "trello_client_key",
          "trelloClientKey",
          "TRELLO_CLIENT_KEY",
          "trello-client-key",
          "api_key",
          "apiKey",
          "API_KEY",
          "client_key",
          "clientKey",
          "CLIENT_KEY",
          "key",
          "Key",
          "KEY"
        ]
      },
      {
        "type": "regex",
        "pattern": "\\b[A-Za-z0-9]{64}\\b",
        "message": "Trello API token detected. These tokens provide authorized access to Trello resources on behalf of a user. Exposing these tokens enables unauthorized access to boards, cards, and user data with the same permissions as the token holder. Revoke this token immediately from your Trello account settings.",
        "context_keywords": [
          "trello",
          "Trello",
          "TRELLO",
          "trello-api",
          "trello_api",
          "trelloApi",
          "TrelloApi",
          "TRELLO_API",
