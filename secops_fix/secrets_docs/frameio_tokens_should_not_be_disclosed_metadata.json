{
  "filename": "frameio_tokens_should_not_be_disclosed_metadata.json",
  "rule_id": "frameio_tokens_disclosed",
  "title": "Frame.io tokens should not be disclosed",
  "description": "In most cases, trust boundaries are violated when a secret is exposed in a source code repository or an uncontrolled deployment environment. Unintended people who don\u2019t need to know the secret might get access to it. They might then be able to use it to gain unwanted access to associated services or resources.",
  "status": "ready",
  "defaultSeverity": "Info",
  "category": "Security",
  "recommendation": "Review and fix according to the rule guidelines.",
  "impact": "Security risk",
  "tags": [
    "security",
    "cwe"
  ],
  "examples": {
    "noncompliant": [],
    "compliant": [
      {
        "code": "FRAMEIO_TOKEN = os.environ.get('FRAMEIO_TOKEN')",
        "description": "Frame.io token retrieved from environment variable"
      },
      {
        "code": "const frameioBearerToken = process.env.FRAMEIO_API_TOKEN;",
        "description": "Frame.io token loaded securely from environment"
      }
    ]
  },
  "references": [
    "https://rules.sonarsource.com/secrets/RSPEC-7260"
  ],
  "logic": {
    "node_types": [],
    "checks": [
      {
        "type": "regex",
        "pattern": "\\bfio-u-[A-Za-z0-9_-]{60,128}\\b",
        "message": "Frame.io developer token (fio-u- prefix) detected in source code",
        "context_keywords": [
          "frameio",
          "frame_io",
          "FRAMEIO",
          "FRAME_IO",
          "frame.io",
          "fio_token",
          "fio-u-",
          "frameio_token",
          "FRAMEIO_TOKEN",
          "frameio_api",
          "FRAMEIO_API",
          "FRAMEIO_API_KEY",
          "frameio_api_key",
          "frameioclient",
          "FrameioClient",
          "frame_io_token",
          "FRAME_IO_TOKEN",
          "token",
          "api_token",
          "bearer",
          "authorization",
          "auth"
        ]
      },
      {
        "type": "regex",
        "pattern": "eyJ[a-zA-Z0-9_-]{20,}\\.eyJ[a-zA-Z0-9_-]{20,}\\.[a-zA-Z0-9_-]{20,}",
        "message": "Frame.io OAuth JWT access token detected in source code",
        "context_keywords": [
          "frameio",
          "frame_io",
          "FRAMEIO",
          "FRAME_IO",
          "frame.io",
          "frameio_token",
          "FRAMEIO_TOKEN",
          "frameio_api",
          "FRAMEIO_API",
          "FRAMEIO_API_KEY",
          "frameio_api_key",
          "frameioclient",
          "FrameioClient",
          "frame_io_token",
          "FRAME_IO_TOKEN",
          "frameio_oauth",
          "FRAMEIO_OAUTH",
          "frame_io_oauth",
          "FRAME_IO_OAUTH"
        ]
      }
    ]
  }
}