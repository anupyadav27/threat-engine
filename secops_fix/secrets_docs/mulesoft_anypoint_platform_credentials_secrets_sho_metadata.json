{
  "filename": "mulesoft_anypoint_platform_credentials_secrets_sho_metadata.json",
  "rule_id": "mulesoft_anypoint_platform_credentials",
  "title": "Mulesoft Anypoint Platform Credentials secrets should not be disclosed",
  "description": "In most cases, trust boundaries are violated when a secret is exposed in a source code repository or an uncontrolled deployment environment. Unintended people who don\u2019t need to know the secret might get access to it. They might then be able to use it to gain unwanted access to associated services or resources.",
  "status": "ready",
  "defaultSeverity": "Info",
  "category": "Security",
  "recommendation": "Review and fix according to the rule guidelines.",
  "impact": "Security risk",
  "tags": [
    "security",
    "cwe"
  ],
  "examples": {
    "noncompliant": [],
    "compliant": []
  },
  "references": [
    "https://rules.sonarsource.com/secrets/RSPEC-7214"
  ],
  "logic": {
    "node_types": [],
    "checks": [
      {
        "type": "regex",
        "pattern": "(?:anypoint|mulesoft).*(?:username|user)[\"'\\s]*[:=][\"'\\s]*[^\\s\"';,}{\\)\\]]{4,}",
        "message": "Mulesoft Anypoint Platform username detected in source code",
