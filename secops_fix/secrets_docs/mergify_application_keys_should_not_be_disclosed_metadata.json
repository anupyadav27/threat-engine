{
  "filename": "mergify_application_keys_should_not_be_disclosed_metadata.json",
  "rule_id": "mergify_application_keys_disclosed",
  "title": "Mergify application keys should not be disclosed",
  "description": "In most cases, trust boundaries are violated when a secret is exposed in a source code repository or an uncontrolled deployment environment. Unintended people who don\u2019t need to know the secret might get access to it. They might then be able to use it to gain unwanted access to associated services or resources.",
  "status": "ready",
  "defaultSeverity": "Info",
  "category": "Security",
  "recommendation": "Review and fix according to the rule guidelines.",
  "impact": "Security risk",
  "tags": [
    "security",
    "cwe"
  ],
  "examples": {
    "noncompliant": [],
    "compliant": []
  },
  "references": [
    "https://rules.sonarsource.com/secrets/RSPEC-7167"
  ],
  "logic": {
    "node_types": [],
    "checks": [
      {
        "type": "regex",
        "pattern": "\\b[A-Za-z0-9]{32,64}\\b",
        "message": "Mergify application key detected in source code",
        "context_keywords": [
          "mergify",
          "Mergify",
          "MERGIFY",
          "mergify_api",
          "mergifyApi",
          "MERGIFY_API",
          "mergify_key",
          "mergifyKey",
          "MERGIFY_KEY",
          "mergify_token",
          "mergifyToken",
          "MERGIFY_TOKEN",
          "mergify_app",
          "mergifyApp",
          "MERGIFY_APP",
          "application_key",
          "applicationKey",
          "APPLICATION_KEY",
          "api_key",
          "apiKey",
          "API_KEY",
          "api_token",
          "apiToken",
          "API_TOKEN",
          "auth_token",
          "authToken",
          "AUTH_TOKEN",
          "authentication",
          "Authorization",
          "bearer",
          "Bearer",
          "BEARER",
          "mergify.io",
          "mergify.com",
          "github",
          "GitHub",
          "GITHUB",
          "pull_request",
          "pullRequest",
          "PULL_REQUEST",
          "pr_automation",
          "prAutomation",
          "PR_AUTOMATION",
          "merge_automation",
          "mergeAutomation",
          "MERGE_AUTOMATION"
        ]
      },
      {
        "type": "regex",
        "pattern": "\\b[A-Za-z0-9_-]{32,64}\\b",
        "message": "Mergify application key detected (with separators) in source code",
