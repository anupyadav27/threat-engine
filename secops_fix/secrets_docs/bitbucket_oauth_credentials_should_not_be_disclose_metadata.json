{
  "filename": "bitbucket_oauth_credentials_should_not_be_disclose_metadata.json",
  "rule_id": "bitbucket_oauth_credentials_disclosed",
  "title": "BitBucket OAuth credentials should not be disclosed",
  "description": "In most cases, trust boundaries are violated when a secret is exposed in a source code repository or an uncontrolled deployment environment. Unintended people who don\u2019t need to know the secret might get access to it. They might then be able to use it to gain unwanted access to associated services or resources.",
  "status": "ready",
  "defaultSeverity": "Info",
  "category": "Security",
  "recommendation": "Review and fix according to the rule guidelines.",
  "impact": "Security risk",
  "tags": [
    "security",
    "cwe"
  ],
  "examples": {
    "noncompliant": [],
    "compliant": [
      "# Using environment variable\nBITBUCKET_OAUTH_KEY = os.environ.get('BITBUCKET_OAUTH_KEY')\noauth_client = OAuthClient(consumer_key=BITBUCKET_OAUTH_KEY)",
      "// Loading from secure configuration\nconst config = loadSecureConfig();\nconst oauthCreds = config.bitbucketOAuth;"
    ]
  },
  "references": [
    "https://rules.sonarsource.com/secrets/RSPEC-7144"
  ],
  "logic": {
    "node_types": [],
    "checks": [
      {
        "type": "regex",
        "pattern": "[a-zA-Z0-9]{16,32}",
        "message": "Detected BitBucket OAuth consumer key",
        "context_keywords": [
          "bitbucket",
          "Bitbucket",
          "BITBUCKET",
          "oauth",
          "OAuth",
          "OAUTH",
          "consumer_key",
          "consumerKey",
          "ConsumerKey",
          "CONSUMER_KEY",
          "oauth_key",
          "oauthKey",
          "client_id",
          "clientId",
          "oauth_consumer",
          "oauthConsumer",
          "bb_oauth",
          "bitbucket_oauth",
          "bitbucketOAuth",
          "oauth_client",
          "oauthClient"
        ]
      },
      {
        "type": "regex",
        "pattern": "[a-zA-Z0-9]{40,64}",
        "message": "Detected BitBucket OAuth consumer secret",
        "context_keywords": [
          "bitbucket",
          "Bitbucket",
          "BITBUCKET",
          "oauth",
          "OAuth",
          "OAUTH",
          "consumer_secret",
          "consumerSecret",
          "ConsumerSecret",
          "CONSUMER_SECRET",
          "oauth_secret",
          "oauthSecret",
          "client_secret",
          "clientSecret",
          "oauth_consumer_secret",
          "oauthConsumerSecret",
          "bb_oauth_secret",
          "bitbucket_oauth_secret",
          "bitbucketOAuthSecret",
          "oauth_client_secret",
          "oauthClientSecret"
        ]
      }
    ]
  }
}