{
  "filename": "elastic_cloud_credentials_should_not_be_disclosed_metadata.json",
  "rule_id": "elastic_cloud_credentials_disclosed",
  "title": "Elastic Cloud credentials should not be disclosed",
  "description": "In most cases, trust boundaries are violated when a secret is exposed in a source code repository or an uncontrolled deployment environment. Unintended people who don\u2019t need to know the secret might get access to it. They might then be able to use it to gain unwanted access to associated services or resources.",
  "status": "ready",
  "defaultSeverity": "Info",
  "category": "Security",
  "recommendation": "Review and fix according to the rule guidelines.",
  "impact": "Security risk",
  "tags": [
    "security",
    "cwe"
  ],
  "examples": {
    "noncompliant": [],
    "compliant": [
      {
        "description": "Elastic credentials from environment variables",
        "code": "cloud_id = os.getenv('ELASTIC_CLOUD_ID')\napi_key = os.getenv('ELASTIC_API_KEY')"
      },
      {
        "description": "Elastic credentials from configuration service",
        "code": "elastic_config = config_manager.get('elasticsearch')\ncloud_id = elastic_config['cloud_id']"
      },
      {
        "description": "Elastic credentials using secrets manager",
        "code": "from vault import secrets_manager\nelastic_creds = secrets_manager.get_secret('elastic/production')"
      },
      {
        "description": "Elastic credentials in documentation (placeholders)",
        "code": "# Configure your Elastic Cloud credentials:\n# ELASTIC_CLOUD_ID=your_deployment:base64_encoded_data\n# ELASTIC_API_KEY=your_api_key_here"
      }
    ]
  },
  "references": [
    "https://rules.sonarsource.com/secrets/RSPEC-7532"
  ],
  "logic": {
    "custom_function": "detect_elastic_cloud_credentials",
    "patterns": [
      {
        "type": "elastic_cloud_id",
        "regex": "\\b[a-zA-Z0-9][a-zA-Z0-9_-]{2,}:[A-Za-z0-9+/]{50,}={0,2}\\b",
        "description": "Elastic Cloud deployment ID with base64 encoded data"
      },
      {
        "type": "elastic_api_key",
        "regex": "\\b[A-Za-z0-9_-]{20,}:[A-Za-z0-9_-]{20,}\\b",
        "description": "Elastic API key in id:key format"
      },
      {
        "type": "elastic_api_key_base64",
        "regex": "\\b[A-Za-z0-9+/]{40,}={0,2}\\b",
        "description": "Base64 encoded Elastic API key"
      },
      {
        "type": "elastic_apm_token",
        "regex": "\\b[A-Za-z0-9]{40,80}\\b",
        "description": "Elastic APM Server authentication token"
      },
      {
        "type": "elastic_fleet_token",
        "regex": "\\b[A-Za-z0-9_-]{100,200}\\b",
        "description": "Elastic Fleet enrollment token"
      }
    ],
    "context_keywords": [
      "elastic",
      "elasticsearch",
      "elastic_cloud",
      "elastic-cloud",
      "cloud_id",
      "cloud.id",
      "cloudid",
      "elastic_api",
      "elastic_auth",
      "elastic_token",
      "es_cloud",
      "es_api",
      "es_auth",
      "kibana",
      "apm_server",
      "apm_token",
      "fleet_token",
      "fleet_enrollment",
      "elastic.co",
      "found.io",
      "cloud.elastic",
      "elasticsearch_url",
      "elasticsearch_api",
      "elastic_search",
      "eck",
      "elastic_cluster",
      "beats_token",
      "logstash_elastic"
    ],
    "validation": {
      "cloud_id": {
        "format": "name:base64_data",
        "min_length": 50,
        "entropy_threshold": 4.0,
        "character_diversity": 15
      },
      "api_key": {
        "format": "id:key or base64",
        "min_length": 40,
        "entropy_threshold": 4.0,
        "character_diversity": 15
      },
      "apm_token": {
        "min_length": 40,
        "max_length": 80,
        "entropy_threshold": 4.0,
        "character_diversity": 12
      },
      "fleet_token": {
        "min_length": 100,
        "max_length": 200,
        "entropy_threshold": 4.0,
        "character_diversity": 20
      },
      "requires_context": true,
      "context_required": "elastic"
    }
  }
}