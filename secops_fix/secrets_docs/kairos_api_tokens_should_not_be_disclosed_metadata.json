{
  "filename": "kairos_api_tokens_should_not_be_disclosed_metadata.json",
  "rule_id": "kairos_api_tokens_disclosed",
  "title": "Kairos API tokens should not be disclosed",
  "description": "In most cases, trust boundaries are violated when a secret is exposed in a source code repository or an uncontrolled deployment environment. Unintended people who don\u2019t need to know the secret might get access to it. They might then be able to use it to gain unwanted access to associated services or resources.",
  "status": "ready",
  "defaultSeverity": "Info",
  "category": "Security",
  "recommendation": "Review and fix according to the rule guidelines.",
  "impact": "Security risk",
  "tags": [
    "security",
    "cwe"
  ],
  "examples": {
    "noncompliant": [],
    "compliant": []
  },
  "references": [
    "https://rules.sonarsource.com/secrets/RSPEC-7016"
  ],
  "logic": {
    "node_types": [],
    "checks": [
      {
        "type": "regex",
        "pattern": "\\b[a-fA-F0-9]{32}\\b",
        "message": "Kairos API key detected - 32 character hexadecimal token",
        "context_keywords": [
          "kairos",
          "Kairos",
          "KAIROS",
          "kairos_key",
          "kairosKey",
          "KairosKey",
          "KAIROS_KEY",
          "kairos_app_key",
          "kairosAppKey",
          "kairos_api_key",
          "kairosApiKey",
          "KAIROS_APP_KEY",
          "KAIROS_API_KEY",
          "app_key",
          "appKey",
          "AppKey",
          "APP_KEY",
          "app_id",
          "appId",
          "AppId",
          "APP_ID",
          "kairos_app_id",
          "kairosAppId",
          "KAIROS_APP_ID",
          "face",
          "Face",
          "FACE",
          "face_recognition",
          "faceRecognition",
          "FaceRecognition",
          "FACE_RECOGNITION",
          "facial",
          "Facial",
          "FACIAL",
          "recognition",
          "Recognition",
          "RECOGNITION",
          "kairos.com",
          "api.kairos.com",
          "kairos_api",
          "kairosApi",
          "KairosAPI",
          "KAIROS_API",
          "detect",
          "Detect",
          "DETECT",
          "enroll",
          "Enroll",
          "ENROLL",
          "verify",
          "Verify",
          "VERIFY",
          "gallery",
          "Gallery",
          "GALLERY",
          "subject",
          "Subject",
          "SUBJECT"
        ]
      },
      {
        "type": "regex",
        "pattern": "\\b[A-Za-z0-9_-]{20,50}\\b",
        "message": "Kairos App ID detected - alphanumeric identifier",
        "context_keywords": [
          "kairos_app_id",
          "kairosAppId",
          "KAIROS_APP_ID",
          "kairos_id",
          "kairosId",
          "KAIROS_ID",
          "kairos.id",
          "kairos.app_id",
          "kairos_application_id",
          "kairosApplicationId",
          "app_id",
          "appId",
          "APP_ID",
          "application_id",
          "applicationId",
          "APPLICATION_ID"
        ]
      }
    ]
  }
}