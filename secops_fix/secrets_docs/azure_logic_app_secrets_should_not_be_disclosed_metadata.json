{
  "filename": "azure_logic_app_secrets_should_not_be_disclosed_metadata.json",
  "rule_id": "azure_logic_app_secrets",
  "title": "Azure Logic App Secrets should not be disclosed",
  "description": "In most cases, trust boundaries are violated when a secret is exposed in a source code repository or an uncontrolled deployment environment. Unintended people who don\u2019t need to know the secret might get access to it. They might then be able to use it to gain unwanted access to associated services or resources.",
  "status": "ready",
  "defaultSeverity": "Info",
  "category": "Security",
  "recommendation": "Review and fix according to the rule guidelines.",
  "impact": "Security risk",
  "tags": [
    "security",
    "cwe"
  ],
  "examples": {
    "noncompliant": [],
    "compliant": [
      {
        "code": "callback_url = os.environ.get('LOGIC_APP_CALLBACK_URL')",
        "description": "Logic App URL from environment variable"
      },
      {
        "code": "const workflowUrl = process.env.LOGIC_APP_URL",
        "description": "Logic App URL retrieved from environment"
      }
    ]
  },
  "references": [
    "https://rules.sonarsource.com/secrets/RSPEC-7008"
  ],
  "logic": {
    "node_types": [],
    "checks": [
      {
        "type": "regex",
        "pattern": "https://[a-z0-9-]+\\.logic\\.azure\\.com[^\\s]*sig=[a-zA-Z0-9%+/=-]+",
        "message": "Azure Logic App callback URL with signature detected",
        "context_keywords": [
          "logic",
          "Logic",
          "LOGIC",
          "workflow",
          "Workflow",
          "WORKFLOW",
          "callback",
          "Callback",
          "trigger",
          "Trigger",
          "invoke",
          "azure",
          "Azure",
          "logic_app",
          "logicApp",
          "LogicApp",
          "logic.azure.com",
          "webhooks",
          "webhook"
        ]
      },
      {
        "type": "regex",
        "pattern": "sp=%2F[^&\\s]+&sv=[0-9.]+&sig=[a-zA-Z0-9%+/=-]+",
        "message": "Azure Logic App SAS token detected",
        "context_keywords": [
          "logic",
          "Logic",
          "LOGIC",
          "workflow",
          "Workflow",
          "WORKFLOW",
          "sas",
          "SAS",
          "signature",
          "Signature",
          "sig",
          "token",
          "Token",
          "access",
          "Access",
          "logic_app",
          "logicApp",
          "LogicApp",
          "trigger",
          "Trigger",
          "callback",
          "authorization"
        ]
      },
      {
        "type": "regex",
        "pattern": "[a-zA-Z0-9+/]{40,88}={0,2}",
        "message": "Azure Logic App access key detected",
        "context_keywords": [
          "logic",
          "Logic",
          "LOGIC",
          "logic_app",
          "logicApp",
          "LogicApp",
          "LOGIC_APP",
          "workflow",
          "Workflow",
          "WORKFLOW",
          "workflow_key",
          "workflowKey",
          "logic_key",
          "logicKey",
          "connection_key",
          "connectionKey",
          "access_key",
          "accessKey",
          "trigger_key",
          "triggerKey",
          "callback_key",
          "callbackKey",
          "shared_key",
          "sharedKey",
          "integration",
          "Integration"
        ]
      }
    ]
  }
}