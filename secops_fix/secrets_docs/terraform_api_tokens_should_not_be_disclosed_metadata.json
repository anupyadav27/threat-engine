{
  "filename": "terraform_api_tokens_should_not_be_disclosed_metadata.json",
  "rule_id": "terraform_api_tokens_disclosed",
  "title": "Terraform API tokens should not be disclosed",
  "description": "In most cases, trust boundaries are violated when a secret is exposed in a source code repository or an uncontrolled deployment environment. Unintended people who don\u2019t need to know the secret might get access to it. They might then be able to use it to gain unwanted access to associated services or resources.",
  "status": "ready",
  "defaultSeverity": "Info",
  "category": "Security",
  "recommendation": "Review and fix according to the rule guidelines.",
  "impact": "Security risk",
  "tags": [
    "security",
    "cwe"
  ],
  "examples": {
    "noncompliant": [],
    "compliant": []
  },
  "references": [
    "https://rules.sonarsource.com/secrets/RSPEC-6998"
  ],
  "logic": {
    "node_types": [],
    "checks": [
      {
        "type": "regex",
        "pattern": "\\b[A-Za-z0-9]{14}\\.atlasv1\\.[A-Za-z0-9]{67}\\b",
        "message": "Terraform Cloud API token detected. These tokens provide programmatic access to Terraform Cloud workspaces and can manage infrastructure, state files, and organization resources. Exposing these tokens enables unauthorized access to cloud resources, potential infrastructure tampering, and sensitive state data exposure. Revoke this token immediately from your Terraform Cloud account settings.",
