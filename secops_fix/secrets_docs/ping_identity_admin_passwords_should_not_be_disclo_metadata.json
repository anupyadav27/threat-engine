{
  "filename": "ping_identity_admin_passwords_should_not_be_disclo_metadata.json",
  "rule_id": "ping_identity_admin_passwords",
  "title": "Ping Identity admin passwords should not be disclosed",
  "description": "In most cases, trust boundaries are violated when a secret is exposed in a source code repository or an uncontrolled deployment environment. Unintended people who don\u2019t need to know the secret might get access to it. They might then be able to use it to gain unwanted access to associated services or resources.",
  "status": "ready",
  "defaultSeverity": "Info",
  "category": "Security",
  "recommendation": "Review and fix according to the rule guidelines.",
  "impact": "Security risk",
  "tags": [
    "security",
    "cwe"
  ],
  "examples": {
    "noncompliant": [],
    "compliant": []
  },
  "references": [
    "https://rules.sonarsource.com/secrets/RSPEC-7574"
  ],
  "logic": {
    "node_types": [],
    "checks": [
      {
        "type": "regex",
        "pattern": "ldaps?://(?:cn=)?[a-zA-Z0-9._-]+:[^@\\s'\"<>`{}]+@[a-zA-Z0-9._-]+(?::[0-9]{1,5})?(?:/[^\\s]*)?",
        "message": "Ping Identity LDAP connection string with embedded admin credentials detected. PingDirectory and other Ping Identity LDAP services use this format for administrative access. Exposed credentials grant full directory access including user data modification, schema changes, and system configuration. This can lead to complete identity infrastructure compromise, unauthorized user access, privilege escalation, and data breaches. Immediately rotate credentials and implement secure credential storage.",
