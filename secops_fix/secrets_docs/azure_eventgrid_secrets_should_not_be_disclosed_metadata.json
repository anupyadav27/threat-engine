{
  "filename": "azure_eventgrid_secrets_should_not_be_disclosed_metadata.json",
  "rule_id": "azure_eventgrid_secrets_disclosed",
  "title": "Azure EventGrid secrets should not be disclosed",
  "description": "In most cases, trust boundaries are violated when a secret is exposed in a source code repository or an uncontrolled deployment environment. Unintended people who don\u2019t need to know the secret might get access to it. They might then be able to use it to gain unwanted access to associated services or resources.",
  "status": "ready",
  "defaultSeverity": "Info",
  "category": "Security",
  "recommendation": "Review and fix according to the rule guidelines.",
  "impact": "Security risk",
  "tags": [
    "security",
    "cwe"
  ],
  "examples": {
    "noncompliant": [],
    "compliant": [
      {
        "code": "EVENTGRID_TOPIC_KEY = os.environ.get('EVENTGRID_TOPIC_KEY')",
        "description": "EventGrid key from environment variable"
      },
      {
        "code": "const topicKey = process.env.EVENTGRID_ACCESS_KEY",
        "description": "EventGrid key retrieved from environment"
      }
    ]
  },
  "references": [
    "https://rules.sonarsource.com/secrets/RSPEC-7011"
  ],
  "logic": {
    "node_types": [],
    "checks": [
      {
        "type": "regex",
        "pattern": "[a-zA-Z0-9+/]{44,88}={0,2}",
        "message": "Azure EventGrid access key detected",
        "context_keywords": [
          "eventgrid",
          "EventGrid",
          "EVENTGRID",
          "event_grid",
          "topic_key",
          "topicKey",
          "topic_endpoint",
          "topicEndpoint",
          "access_key",
          "accessKey",
          "endpoint_key",
          "endpointKey",
          "eventGridKey",
          "event_grid_key",
          "subscription_key",
          "subscriptionKey",
          "domain_key",
          "domainKey",
          "topic_access",
          "event_hub",
          "eventHub"
        ]
      },
      {
        "type": "regex",
        "pattern": "SharedAccessSignature sr=[^&\\s]+&sig=[a-zA-Z0-9%+/=]+&se=[0-9]+&skn=[a-zA-Z0-9]+",
        "message": "Azure EventGrid SAS token detected",
        "context_keywords": [
          "eventgrid",
          "EventGrid",
          "EVENTGRID",
          "event_grid",
          "sas",
          "SAS",
          "SharedAccessSignature",
          "shared_access",
          "sasToken",
          "sas_token",
          "topic",
          "Topic",
          "TOPIC",
          "domain",
          "Domain",
          "authorization",
          "Authorization"
        ]
      }
    ]
  }
}