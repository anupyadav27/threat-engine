{
  "filename": "databricks_access_tokens_should_not_be_disclosed_metadata.json",
  "rule_id": "databricks_access_tokens_disclosed",
  "title": "Databricks access tokens should not be disclosed",
  "description": "In most cases, trust boundaries are violated when a secret is exposed in a source code repository or an uncontrolled deployment environment. Unintended people who don\u2019t need to know the secret might get access to it. They might then be able to use it to gain unwanted access to associated services or resources.",
  "status": "ready",
  "defaultSeverity": "Info",
  "category": "Security",
  "recommendation": "Review and fix according to the rule guidelines.",
  "impact": "Security risk",
  "tags": [
    "security",
    "cwe"
  ],
  "examples": {
    "noncompliant": [],
    "compliant": [
      {
        "code": "# Using environment variable for Databricks token\nimport os\nfrom databricks import sql\n\nconnection = sql.connect(\n    server_hostname=os.environ.get('DATABRICKS_HOST'),\n    http_path=os.environ.get('DATABRICKS_HTTP_PATH'),\n    access_token=os.environ.get('DATABRICKS_TOKEN')\n)",
        "language": "python",
        "description": "Databricks token loaded from environment"
      },
      {
        "code": "// Using environment variables for Databricks\nconst { WorkspaceClient } = require('@databricks/databricks-sdk');\n\nconst client = new WorkspaceClient({\n  host: process.env.DATABRICKS_HOST,\n  token: process.env.DATABRICKS_TOKEN\n});",
        "language": "javascript",
        "description": "Using environment variables for Databricks credentials"
      }
    ]
  },
  "references": [
    "https://rules.sonarsource.com/secrets/RSPEC-7010"
  ],
  "logic": {
    "node_types": [],
    "checks": [
      {
        "type": "regex",
        "pattern": "dapi[a-z0-9]{32,64}",
        "message": "Detected Databricks access token",
