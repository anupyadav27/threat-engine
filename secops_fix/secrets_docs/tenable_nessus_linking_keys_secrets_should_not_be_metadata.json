{
  "filename": "tenable_nessus_linking_keys_secrets_should_not_be__metadata.json",
  "rule_id": "tenable_nessus_linking_keys",
  "title": "Tenable Nessus linking keys secrets should not be disclosed",
  "description": "In most cases, trust boundaries are violated when a secret is exposed in a source code repository or an uncontrolled deployment environment. Unintended people who don\u2019t need to know the secret might get access to it. They might then be able to use it to gain unwanted access to associated services or resources.",
  "status": "ready",
  "defaultSeverity": "Info",
  "category": "Security",
  "recommendation": "Review and fix according to the rule guidelines.",
  "impact": "Security risk",
  "tags": [
    "security",
    "cwe"
  ],
  "examples": {
    "noncompliant": [],
    "compliant": [
      {
        "code": "NESSUS_LINKING_KEY = os.environ.get('NESSUS_LINKING_KEY')",
        "description": "Nessus linking key retrieved from environment variable"
      },
      {
        "code": "const scannerKey = process.env.TENABLE_SCANNER_KEY",
        "description": "Tenable scanner key retrieved from environment"
      }
    ]
  },
  "references": [
    "https://rules.sonarsource.com/secrets/RSPEC-7305"
  ],
