{
  "filename": "trend_cloud_one_api_keys_should_not_be_disclosed_metadata.json",
  "rule_id": "trend_cloud_one_api",
  "title": "Trend Cloud One API keys should not be disclosed",
  "description": "In most cases, trust boundaries are violated when a secret is exposed in a source code repository or an uncontrolled deployment environment. Unintended people who don\u2019t need to know the secret might get access to it. They might then be able to use it to gain unwanted access to associated services or resources.",
  "status": "ready",
  "defaultSeverity": "Info",
  "category": "Security",
  "recommendation": "Review and fix according to the rule guidelines.",
  "impact": "Security risk",
  "tags": [
    "security",
    "cwe"
  ],
  "examples": {
    "noncompliant": [],
    "compliant": []
  },
  "references": [
    "https://rules.sonarsource.com/secrets/RSPEC-7372"
  ],
  "logic": {
    "node_types": [],
    "checks": [
      {
        "type": "regex",
        "pattern": "\\b[A-Za-z0-9_-]{40,80}\\b",
        "message": "Trend Cloud One API key detected in source code. Trend Cloud One API keys provide programmatic access to Trend Micro's cloud security platform including workload security, container security, network security, and compliance services. Exposing these keys allows unauthorized access to manage security policies, view vulnerabilities, modify protections, and access sensitive security data across your cloud infrastructure. Revoke this key immediately and store API credentials securely using environment variables or secret management systems.",
        "context_keywords": [
          "trend",
          "Trend",
          "TREND",
          "trendmicro",
          "TrendMicro",
          "TRENDMICRO",
          "trend_micro",
          "TrendMicro",
          "TREND_MICRO",
          "cloudone",
          "CloudOne",
          "CLOUDONE",
