          "DeepSecurity",
          "DEEP_SECURITY",
          "trend_security",
          "trendSecurity",
          "TrendSecurity",
          "TREND_SECURITY"
        ]
      },
      {
        "type": "regex",
        "pattern": "ApiKey\\s+[A-Za-z0-9_-]{40,120}",
        "message": "Trend Cloud One API key detected in ApiKey authorization header. The 'ApiKey' authentication format is specific to Trend Micro Cloud One services and provides direct API access to workload security, container security, and network protection services. Exposing these authorization headers allows unauthorized access to security configurations, vulnerability assessments, and sensitive infrastructure data. Store API keys securely and rotate immediately if exposed.",
        "context_keywords": [
          "trend",
          "Trend",
          "TREND",
          "trendmicro",
          "TrendMicro",
          "TRENDMICRO",
          "cloudone",
          "CloudOne",
