          "container_security",
          "network_security",
          "trend_api",
          "cloudone_api",
          "request",
          "Request",
          "REQUEST"
        ]
      },
      {
        "type": "regex",
        "pattern": "(?:trend|Trend|TREND|cloudone|CloudOne|CLOUDONE)[_-]?(?:api|API|key|KEY|token|TOKEN|auth|AUTH)[_-]?(?:key|KEY|token|TOKEN)?[\"'\\s]*[:=][\"'\\s]*[A-Za-z0-9_-]{40,120}",
        "message": "Trend Cloud One API credential detected in variable assignment. Trend Micro Cloud One API credentials provide access to comprehensive cloud security services including threat detection, vulnerability management, and compliance monitoring. Exposing these credentials enables unauthorized access to security dashboards, policy configurations, and sensitive threat intelligence data. Use environment variables or secure credential storage instead of hardcoding.",
