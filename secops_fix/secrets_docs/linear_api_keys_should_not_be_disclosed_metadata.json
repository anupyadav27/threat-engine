{
  "filename": "linear_api_keys_should_not_be_disclosed_metadata.json",
  "rule_id": "linear_api_keys_disclosed",
  "title": "Linear API keys should not be disclosed",
  "description": "In most cases, trust boundaries are violated when a secret is exposed in a source code repository or an uncontrolled deployment environment. Unintended people who don\u2019t need to know the secret might get access to it. They might then be able to use it to gain unwanted access to associated services or resources.",
  "status": "ready",
  "defaultSeverity": "Info",
  "category": "Security",
  "recommendation": "Review and fix according to the rule guidelines.",
  "impact": "Security risk",
  "tags": [
    "security",
    "cwe"
  ],
  "examples": {
    "noncompliant": [],
    "compliant": []
  },
  "references": [
    "https://rules.sonarsource.com/secrets/RSPEC-7175"
  ],
  "logic": {
    "node_types": [],
    "checks": [
      {
        "type": "regex",
        "pattern": "\\blin_api_[a-zA-Z0-9]{40,50}\\b",
        "message": "Linear personal API key detected in source code",
        "context_keywords": [
          "linear",
          "Linear",
          "LINEAR",
          "linear_api",
          "linearApi",
          "LINEAR_API",
          "linear_key",
          "linearKey",
          "LINEAR_KEY",
          "api_key",
          "apiKey",
          "API_KEY",
          "personal_key",
          "personalKey",
          "PERSONAL_KEY",
          "lin_api",
          "linApi",
          "LIN_API",
          "api.linear.app",
          "linear.app/api",
          "linear_token",
          "linearToken",
          "LINEAR_TOKEN",
          "auth_token",
          "authToken",
          "AUTH_TOKEN",
          "bearer",
          "Bearer",
          "BEARER",
          "authorization",
          "Authorization",
          "AUTHORIZATION"
        ]
      },
      {
        "type": "regex",
        "pattern": "\\b[a-f0-9]{64}\\b",
        "message": "Linear OAuth2 access token detected in source code",
        "context_keywords": [
          "linear",
          "Linear",
          "LINEAR",
          "linear_api",
          "linearApi",
          "LINEAR_API",
          "linear_oauth",
          "linearOauth",
          "LINEAR_OAUTH",
          "access_token",
          "accessToken",
          "ACCESS_TOKEN",
          "oauth_token",
