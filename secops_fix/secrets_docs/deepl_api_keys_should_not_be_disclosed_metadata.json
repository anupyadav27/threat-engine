{
  "filename": "deepl_api_keys_should_not_be_disclosed_metadata.json",
  "rule_id": "deepl_api_keys_disclosed",
  "title": "DeepL API keys should not be disclosed",
  "description": "In most cases, trust boundaries are violated when a secret is exposed in a source code repository or an uncontrolled deployment environment. Unintended people who don\u2019t need to know the secret might get access to it. They might then be able to use it to gain unwanted access to associated services or resources.",
  "status": "ready",
  "defaultSeverity": "Info",
  "category": "Security",
  "recommendation": "Review and fix according to the rule guidelines.",
  "impact": "Security risk",
  "tags": [
    "security",
    "cwe"
  ],
  "examples": {
    "noncompliant": [],
    "compliant": [
      {
        "code": "# Using environment variables for DeepL\nimport os\nimport deepl\n\n# Load DeepL credentials from environment\nauth_key = os.environ.get('DEEPL_AUTH_KEY')\ntranslator = deepl.Translator(auth_key)",
        "language": "python",
        "description": "DeepL key loaded from environment"
      },
      {
        "code": "// Using environment variables for DeepL\nconst deepl = require('deepl-node');\n\nconst authKey = process.env.DEEPL_AUTH_KEY;\nconst translator = new deepl.Translator(authKey);",
        "language": "javascript",
        "description": "Using environment variables for DeepL credentials"
      }
    ]
  },
  "references": [
    "https://rules.sonarsource.com/secrets/RSPEC-7580"
  ],
  "logic": {
    "node_types": [],
    "checks": [
      {
        "type": "regex",
        "pattern": "[a-f0-9]{8}-[a-f0-9]{4}-[a-f0-9]{4}-[a-f0-9]{4}-[a-f0-9]{12}(:fx)?",
        "message": "Detected DeepL API key",
