{
  "filename": "tailscale_scim_keys_should_not_be_disclosed_metadata.json",
  "rule_id": "tailscale_scim_keys_disclosed",
  "title": "Tailscale SCIM keys should not be disclosed",
  "description": "In most cases, trust boundaries are violated when a secret is exposed in a source code repository or an uncontrolled deployment environment. Unintended people who don\u2019t need to know the secret might get access to it. They might then be able to use it to gain unwanted access to associated services or resources.",
  "status": "ready",
  "defaultSeverity": "Info",
  "category": "Security",
  "recommendation": "Review and fix according to the rule guidelines.",
  "impact": "Security risk",
  "tags": [
    "security",
    "cwe"
  ],
  "examples": {
    "noncompliant": [],
    "compliant": []
  },
  "references": [
    "https://rules.sonarsource.com/secrets/RSPEC-7367"
  ],
  "logic": {
    "node_types": [],
    "checks": [
      {
        "type": "regex",
        "pattern": "\\btskey-scim-[A-Za-z0-9]{20,40}\\b",
        "message": "Tailscale SCIM API key detected in source code. SCIM keys enable automated user and group provisioning from identity providers (Microsoft Entra ID, Okta, etc.) to Tailscale. Exposing these keys allows unauthorized manipulation of user access and group memberships in your Tailscale network. Revoke this key immediately and store SCIM keys securely in environment variables or secret management systems.",
