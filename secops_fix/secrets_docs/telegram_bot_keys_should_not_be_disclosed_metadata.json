{
  "filename": "telegram_bot_keys_should_not_be_disclosed_metadata.json",
  "rule_id": "telegram_bot_keys_disclosed",
  "title": "Telegram bot keys should not be disclosed",
  "description": "In most cases, trust boundaries are violated when a secret is exposed in a source code repository or an uncontrolled deployment environment. Unintended people who don\u2019t need to know the secret might get access to it. They might then be able to use it to gain unwanted access to associated services or resources.",
  "status": "ready",
  "defaultSeverity": "Info",
  "category": "Security",
  "recommendation": "Review and fix according to the rule guidelines.",
  "impact": "Security risk",
  "tags": [
    "security",
    "cwe"
  ],
  "examples": {
    "noncompliant": [],
    "compliant": [
      {
        "code": "TELEGRAM_BOT_TOKEN = os.environ.get('TELEGRAM_BOT_TOKEN')",
        "description": "Telegram bot token retrieved from environment variable"
      },
      {
        "code": "const token = process.env.TELEGRAM_TOKEN",
        "description": "Telegram bot token retrieved from environment"
      }
    ]
  },
  "references": [
    "https://rules.sonarsource.com/secrets/RSPEC-6701"
  ],
  "logic": {
    "node_types": [],
    "checks": [
      {
        "type": "regex",
        "pattern": "\\b\\d{8,12}:[A-Za-z0-9_-]{30,45}\\b",
        "message": "Telegram bot token detected in source code",
