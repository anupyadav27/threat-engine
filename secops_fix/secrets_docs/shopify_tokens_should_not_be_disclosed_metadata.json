{
  "filename": "shopify_tokens_should_not_be_disclosed_metadata.json",
  "rule_id": "shopify_tokens_disclosed",
  "title": "Shopify tokens should not be disclosed",
  "description": "In most cases, trust boundaries are violated when a secret is exposed in a source code repository or an uncontrolled deployment environment. Unintended people who don\u2019t need to know the secret might get access to it. They might then be able to use it to gain unwanted access to associated services or resources.",
  "status": "ready",
  "defaultSeverity": "Info",
  "category": "Security",
  "recommendation": "Review and fix according to the rule guidelines.",
  "impact": "Security risk",
  "tags": [
    "security",
    "cwe"
  ],
  "examples": {
    "noncompliant": [],
    "compliant": []
  },
  "references": [
    "https://rules.sonarsource.com/secrets/RSPEC-6769"
  ],
  "logic": {
    "node_types": [],
    "checks": [
      {
        "type": "regex",
        "pattern": "\\bshp(at|pa|ca|ss)_[a-fA-F0-9]{32}\\b",
        "message": "Shopify API token detected in source code. Shopify API tokens provide programmatic access to your Shopify store, allowing read/write operations on products, orders, customers, and other sensitive data. Exposing these tokens enables unauthorized access to your store's data and operations. Revoke this token immediately from your Shopify admin panel and store tokens securely in environment variables or secret management systems.",
