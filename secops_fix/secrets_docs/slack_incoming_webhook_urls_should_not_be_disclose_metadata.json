{
  "filename": "slack_incoming_webhook_urls_should_not_be_disclose_metadata.json",
  "rule_id": "slack_incoming_webhook_urls",
  "title": "Slack incoming webhook URLs should not be disclosed",
  "description": "In most cases, trust boundaries are violated when a secret is exposed in a source code repository or an uncontrolled deployment environment. Unintended people who don\u2019t need to know the secret might get access to it. They might then be able to use it to gain unwanted access to associated services or resources.",
  "status": "ready",
  "defaultSeverity": "Info",
  "category": "Security",
  "recommendation": "Review and fix according to the rule guidelines.",
  "impact": "Security risk",
  "tags": [
    "security",
    "cwe"
  ],
  "examples": {
    "noncompliant": [],
    "compliant": []
  },
  "references": [
    "https://rules.sonarsource.com/secrets/RSPEC-6713"
  ],
  "logic": {
    "node_types": [],
    "checks": [
      {
        "type": "regex",
        "pattern": "https://hooks\\.slack\\.com/services/[A-Z0-9]{9,11}/[A-Z0-9]{9,11}/[A-Za-z0-9]{24,}",
        "message": "Slack incoming webhook URL detected in source code. Incoming webhooks allow applications to post messages directly to Slack channels without full API access. These webhook URLs act as unique endpoints for sending data into Slack channels. Exposing webhook URLs creates security risks: attackers can spam messages to your Slack channels, send phishing or malicious content to team members, impersonate legitimate notifications to confuse users, trigger alert fatigue by flooding channels, consume webhook rate limits preventing legitimate notifications, gather intelligence about your team structure and communication patterns, and potentially inject malicious links or social engineering attacks targeting your organization. While webhooks are less privileged than API tokens (they can only post messages, not read data), unauthorized access still poses risks to team communication integrity and security. Immediate remediation steps: regenerate the compromised webhook URL in Slack channel settings (Integrations \u2192 Incoming Webhooks \u2192 Regenerate), update all applications and services with the new webhook URL, review channel message history for unauthorized posts, document when and where the webhook was exposed, implement webhook URL rotation policies, store webhook URLs in environment variables or secret management systems (AWS Secrets Manager, HashiCorp Vault, Azure Key Vault), add monitoring for unusual posting patterns or volumes, restrict webhook usage to specific IP ranges if possible, use separate webhooks for different environments (dev/staging/prod), never commit webhook URLs to version control, log all webhook POST requests for audit purposes, consider using Slack apps with OAuth instead of webhooks for more secure integrations, and educate team members about webhook URL confidentiality.",
