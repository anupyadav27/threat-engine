{
  "filename": "pinecone_api_keys_should_not_be_disclosed_metadata.json",
  "rule_id": "pinecone_api_keys_disclosed",
  "title": "Pinecone API keys should not be disclosed",
  "description": "In most cases, trust boundaries are violated when a secret is exposed in a source code repository or an uncontrolled deployment environment. Unintended people who don\u2019t need to know the secret might get access to it. They might then be able to use it to gain unwanted access to associated services or resources.",
  "status": "ready",
  "defaultSeverity": "Info",
  "category": "Security",
  "recommendation": "Review and fix according to the rule guidelines.",
  "impact": "Security risk",
  "tags": [
    "security",
    "cwe"
  ],
  "examples": {
    "noncompliant": [],
    "compliant": []
  },
  "references": [
    "https://rules.sonarsource.com/secrets/RSPEC-7319"
  ],
  "logic": {
    "node_types": [],
    "checks": [
      {
        "type": "regex",
        "pattern": "\\b[a-f0-9]{8}-[a-f0-9]{4}-[a-f0-9]{4}-[a-f0-9]{4}-[a-f0-9]{12}\\b",
        "message": "Pinecone API key detected in UUID format. Pinecone API keys provide access to vector database operations including index management, vector upserts/queries, and data operations. Exposing these keys allows unauthorized access to manipulate vector data, consume API quotas, access sensitive embeddings, and potentially exfiltrate machine learning data. Revoke exposed keys immediately from the Pinecone console and store keys securely using environment variables or secret management systems.",
        "context_keywords": [
          "pinecone",
          "Pinecone",
          "PINECONE",
          "pinecone_api",
          "pineconeApi",
          "PineconeApi",
          "PINECONE_API",
