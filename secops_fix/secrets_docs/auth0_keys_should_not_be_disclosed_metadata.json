{
  "filename": "auth0_keys_should_not_be_disclosed_metadata.json",
  "rule_id": "auth0_keys_disclosed",
  "title": "Auth0 keys should not be disclosed",
  "description": "In most cases, trust boundaries are violated when a secret is exposed in a source code repository or an uncontrolled deployment environment. Unintended people who don\u2019t need to know the secret might get access to it. They might then be able to use it to gain unwanted access to associated services or resources.",
  "status": "ready",
  "defaultSeverity": "Info",
  "category": "Security",
  "recommendation": "Review and fix according to the rule guidelines.",
  "impact": "Security risk",
  "tags": [
    "security",
    "cwe"
  ],
  "examples": {
    "noncompliant": [],
    "compliant": [
      {
        "code": "AUTH0_CLIENT_ID = os.getenv('AUTH0_CLIENT_ID')",
        "description": "Auth0 client ID from environment variable"
      },
      {
        "code": "const auth0Secret = process.env.AUTH0_CLIENT_SECRET;",
        "description": "Auth0 secret retrieved from environment"
      }
    ]
  },
  "references": [
    "https://rules.sonarsource.com/secrets/RSPEC-7216"
  ],
  "logic": {
    "node_types": [],
    "checks": [
      {
        "type": "regex",
        "pattern": "[a-zA-Z0-9_-]{32}",
        "message": "Auth0 client ID detected",
        "context_keywords": [
          "auth0",
          "AUTH0",
          "Auth0",
          "client_id",
          "CLIENT_ID",
          "clientId",
          "ClientId",
          "client-id",
          "auth_client",
          "authClientId",
          "domain",
          "tenant"
        ]
      },
      {
        "type": "regex",
        "pattern": "[a-zA-Z0-9_-]{64}",
        "message": "Auth0 client secret detected",
        "context_keywords": [
          "auth0",
          "AUTH0",
          "Auth0",
          "client_secret",
          "CLIENT_SECRET",
          "clientSecret",
          "ClientSecret",
          "client-secret",
          "auth_secret",
          "authClientSecret",
          "secret",
          "SECRET"
        ]
      },
      {
        "type": "regex",
        "pattern": "eyJ[a-zA-Z0-9_-]+\\.[a-zA-Z0-9_-]+\\.[a-zA-Z0-9_-]+",
        "message": "Auth0 Management API JWT token detected",
        "context_keywords": [
          "auth0",
          "AUTH0",
          "Auth0",
          "management",
          "api",
          "API",
          "token",
          "TOKEN",
          "jwt",
          "JWT",
          "bearer",
          "Bearer",
          "authorization",
          "access_token"
        ]
      }
    ]
  }
}