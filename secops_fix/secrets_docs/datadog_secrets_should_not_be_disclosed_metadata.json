{
  "filename": "datadog_secrets_should_not_be_disclosed_metadata.json",
  "rule_id": "datadog_secrets_disclosed",
  "title": "Datadog secrets should not be disclosed",
  "description": "In most cases, trust boundaries are violated when a secret is exposed in a source code repository or an uncontrolled deployment environment. Unintended people who don\u2019t need to know the secret might get access to it. They might then be able to use it to gain unwanted access to associated services or resources.",
  "status": "ready",
  "defaultSeverity": "Info",
  "category": "Security",
  "recommendation": "Review and fix according to the rule guidelines.",
  "impact": "Security risk",
  "tags": [
    "security",
    "cwe"
  ],
  "examples": {
    "noncompliant": [],
    "compliant": [
      {
        "code": "# Using environment variables for Datadog keys\nimport os\nfrom datadog import initialize\n\noptions = {\n    'api_key': os.environ.get('DD_API_KEY'),\n    'app_key': os.environ.get('DD_APP_KEY')\n}\n\ninitialize(**options)",
        "language": "python",
        "description": "Datadog keys loaded from environment"
      },
      {
        "code": "// Using environment variables for Datadog\nconst { StatsD } = require('hot-shots');\n\nconst dogstatsd = new StatsD({\n  host: 'localhost',\n  apiKey: process.env.DD_API_KEY,\n  appKey: process.env.DD_APP_KEY\n});",
        "language": "javascript",
        "description": "Using environment variables for Datadog credentials"
      }
    ]
  },
  "references": [
    "https://rules.sonarsource.com/secrets/RSPEC-7152"
  ],
  "logic": {
    "node_types": [],
    "checks": [
      {
        "type": "regex",
        "pattern": "[a-f0-9]{32,40}",
        "message": "Detected Datadog secret (API key or application key)",
