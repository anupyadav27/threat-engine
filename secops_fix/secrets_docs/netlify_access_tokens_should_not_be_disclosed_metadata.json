      {
        "type": "regex",
        "pattern": "https://api\\.netlify\\.com/api/v1/[^\\s]*[?&]access_token=([A-Za-z0-9_-]{40,100})",
        "message": "Netlify API URL with embedded access token detected. API URLs containing access tokens in query parameters expose credentials in logs, browser history, referrer headers, and network monitoring tools. This provides attackers with direct API access to create, modify, or delete deployments, access webhook configurations, and compromise site security. Use Authorization headers instead of URL parameters for authentication.",
