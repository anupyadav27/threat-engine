{
  "filename": "netlify_access_tokens_should_not_be_disclosed_metadata.json",
  "rule_id": "netlify_access_tokens_disclosed",
  "title": "Netlify access tokens should not be disclosed",
  "description": "In most cases, trust boundaries are violated when a secret is exposed in a source code repository or an uncontrolled deployment environment. Unintended people who don\u2019t need to know the secret might get access to it. They might then be able to use it to gain unwanted access to associated services or resources.",
  "status": "ready",
  "defaultSeverity": "Info",
  "category": "Security",
  "recommendation": "Review and fix according to the rule guidelines.",
  "impact": "Security risk",
  "tags": [
    "security",
    "cwe"
  ],
  "examples": {
    "noncompliant": [],
    "compliant": []
  },
  "references": [
    "https://rules.sonarsource.com/secrets/RSPEC-7306"
  ],
  "logic": {
    "node_types": [],
    "checks": [
      {
        "type": "regex",
        "pattern": "\\b[A-Za-z0-9_-]{40,100}\\b",
        "message": "Netlify personal access token detected in source code. This token grants full API access to your Netlify account, allowing complete control over sites, builds, deployments, domains, and account settings. Exposed tokens enable unauthorized users to modify production deployments, access environment variables, delete sites, and compromise your entire Netlify infrastructure. Store tokens securely in environment variables or secrets management systems.",
        "context_keywords": [
          "netlify",
          "Netlify",
          "NETLIFY",
          "netlify_token",
          "netlifyToken",
          "NETLIFY_TOKEN",
          "netlify_access",
          "netlifyAccess",
          "NETLIFY_ACCESS",
          "netlify_auth",
          "netlifyAuth",
          "NETLIFY_AUTH",
          "netlify_api",
          "netlifyApi",
          "NETLIFY_API",
          "netlify_pat",
          "netlifyPat",
          "NETLIFY_PAT",
          "netlify_key",
          "netlifyKey",
          "NETLIFY_KEY",
          "access_token",
          "accessToken",
          "ACCESS_TOKEN",
          "api_token",
          "apiToken",
          "API_TOKEN",
          "auth_token",
          "authToken",
          "AUTH_TOKEN",
          "personal_token",
          "personalToken",
          "PERSONAL_TOKEN",
          "personal_access_token",
          "personalAccessToken",
          "PERSONAL_ACCESS_TOKEN",
          "bearer",
          "Bearer",
          "BEARER",
          "authorization",
          "Authorization",
          "AUTHORIZATION",
          "api.netlify.com",
          "netlify.com/api",
          "netlify_deploy",
          "netlifyDeploy",
          "NETLIFY_DEPLOY",
          "deploy_token",
          "deployToken",
          "DEPLOY_TOKEN",
          "build_token",
          "buildToken",
          "BUILD_TOKEN"
        ]
      },
      {
        "type": "regex",
        "pattern": "Bearer\\s+[A-Za-z0-9_-]{40,100}",
        "message": "Netlify access token detected in Authorization header. Bearer tokens in authorization headers provide direct API access to Netlify services. Exposing these tokens allows attackers to authenticate as you, deploy malicious code to production sites, access sensitive build logs, manipulate DNS records, and compromise customer data. Use secure credential storage and rotate tokens immediately if exposed.",
        "context_keywords": [
          "netlify",
          "Netlify",
          "NETLIFY",
          "netlify_api",
          "netlifyApi",
          "NETLIFY_API",
          "authorization",
          "Authorization",
          "AUTHORIZATION",
          "bearer",
          "Bearer",
          "BEARER",
          "header",
          "Header",
          "HEADER",
          "api",
          "Api",
          "API",
          "token",
          "Token",
          "TOKEN",
          "netlify_request",
          "netlifyRequest",
          "NETLIFY_REQUEST",
          "api.netlify.com",
          "netlify.com/api",
          "http",
          "HTTP",
          "request",
          "Request",
          "REQUEST",
          "auth",
          "Auth",
          "AUTH"
        ]
      },
      {
        "type": "regex",
        "pattern": "(?:netlify|Netlify|NETLIFY)[_-]?(?:token|TOKEN|api|API|auth|AUTH|access|ACCESS|pat|PAT|key|KEY)[\"'\\s]*[:=][\"'\\s]*[A-Za-z0-9_-]{40,100}",
        "message": "Netlify API token variable detected in configuration. Hardcoded Netlify tokens in configuration files allow anyone with code access to deploy to your sites, trigger builds, access environment secrets, modify DNS settings, and control your entire Netlify infrastructure. This can lead to production outages, data breaches, or malicious code injection. Use environment variables or encrypted secrets instead.",
        "context_keywords": [
          "netlify",
          "Netlify",
          "NETLIFY",
