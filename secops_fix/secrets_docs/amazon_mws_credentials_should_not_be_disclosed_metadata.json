{
  "filename": "amazon_mws_credentials_should_not_be_disclosed_metadata.json",
  "rule_id": "amazon_mws_credentials_disclosed",
  "title": "Amazon MWS credentials should not be disclosed",
  "description": "In most cases, trust boundaries are violated when a secret is exposed in a source code repository or an uncontrolled deployment environment. Unintended people who don\u2019t need to know the secret might get access to it. They might then be able to use it to gain unwanted access to associated services or resources.",
  "status": "ready",
  "defaultSeverity": "Info",
  "category": "Security",
  "recommendation": "Review and fix according to the rule guidelines.",
  "impact": "Security risk",
  "tags": [
    "security",
    "cwe"
  ],
  "examples": {
    "noncompliant": [],
    "compliant": [
      {
        "code": "MWS_AUTH_TOKEN = os.environ.get('AMAZON_MWS_AUTH_TOKEN')",
        "description": "MWS Auth Token retrieved from environment variable"
      },
      {
        "code": "const authToken = process.env.MWS_AUTH_TOKEN",
        "description": "MWS Auth Token retrieved from environment"
      }
    ]
  },
  "references": [
    "https://rules.sonarsource.com/secrets/RSPEC-6292"
  ],
  "logic": {
    "node_types": [],
    "checks": [
      {
        "type": "regex",
        "pattern": "\\bamzn\\.mws\\.[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}\\b",
        "message": "Amazon MWS Auth Token detected in source code",
        "context_keywords": [
          "mws",
          "amazon",
          "marketplace",
          "MWS_AUTH_TOKEN",
          "mws_auth_token",
          "auth_token",
          "seller",
          "merchant"
        ]
      },
      {
        "type": "regex",
        "pattern": "\\bAKIA[0-9A-Z]{16}\\b",
        "message": "AWS Access Key ID (for MWS) detected in source code",
        "context_keywords": [
          "mws",
          "amazon",
          "marketplace",
          "seller",
          "aws_access_key",
          "access_key_id",
          "MWS",
          "merchant_id"
        ]
      },
      {
        "type": "regex",
        "pattern": "\\b[A-Z][0-9A-Z]{13,14}\\b",
        "message": "Amazon MWS Seller ID / Marketplace ID detected in source code",
        "context_keywords": [
          "mws",
          "seller_id",
          "merchant_id",
          "marketplace_id",
          "amazon",
          "MWS_SELLER_ID",
          "MWS_MERCHANT_ID",
          "SELLER_ID"
        ]
      },
      {
        "type": "regex",
        "pattern": "\\b[A-Za-z0-9/+=]{40}\\b",
        "message": "Potential AWS Secret Access Key (for MWS) detected in source code",
        "context_keywords": [
          "mws",
          "amazon",
          "secret_access_key",
          "secret_key",
          "aws_secret",
          "MWS_SECRET_KEY",
          "marketplace",
          "seller"
        ]
      }
    ]
  }
}