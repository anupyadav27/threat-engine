{
  "filename": "tailscale_oauth_keys_should_not_be_disclosed_metadata.json",
  "rule_id": "tailscale_oauth_keys_disclosed",
  "title": "Tailscale OAuth keys should not be disclosed",
  "description": "In most cases, trust boundaries are violated when a secret is exposed in a source code repository or an uncontrolled deployment environment. Unintended people who don\u2019t need to know the secret might get access to it. They might then be able to use it to gain unwanted access to associated services or resources.",
  "status": "ready",
  "defaultSeverity": "Info",
  "category": "Security",
  "recommendation": "Review and fix according to the rule guidelines.",
  "impact": "Security risk",
  "tags": [
    "security",
    "cwe"
  ],
  "examples": {
    "noncompliant": [],
    "compliant": []
  },
  "references": [
    "https://rules.sonarsource.com/secrets/RSPEC-7365"
  ],
  "logic": {
    "node_types": [],
    "checks": [
      {
        "type": "regex",
        "pattern": "\\btskey-[A-Za-z0-9]{30,40}\\b",
        "message": "Tailscale OAuth access token detected in source code. Tailscale OAuth tokens provide programmatic access to the Tailscale API, allowing read/write operations on devices, DNS settings, and other network resources. Exposing these tokens enables unauthorized access to your Tailscale network. Revoke this token immediately and store tokens securely in environment variables or secret management systems.",
