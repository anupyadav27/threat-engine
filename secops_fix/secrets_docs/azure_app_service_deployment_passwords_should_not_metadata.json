{
  "filename": "azure_app_service_deployment_passwords_should_not__metadata.json",
  "rule_id": "azure_app_service_deployment",
  "title": "Azure App Service deployment passwords should not be disclosed",
  "description": "In most cases, trust boundaries are violated when a secret is exposed in a source code repository or an uncontrolled deployment environment. Unintended people who don\u2019t need to know the secret might get access to it. They might then be able to use it to gain unwanted access to associated services or resources.",
  "status": "ready",
  "defaultSeverity": "Critical",
  "category": "Security",
  "recommendation": "Review and fix according to the rule guidelines.",
  "impact": "Security risk",
  "tags": [
    "security",
    "cwe",
    "performance"
  ],
  "examples": {
    "noncompliant": [],
    "compliant": [
      {
        "code": "AZURE_DEPLOYMENT_PASSWORD = os.environ.get('AZURE_DEPLOYMENT_PASSWORD')",
        "description": "Deployment password from environment variable"
      },
      {
        "code": "const publishPassword = process.env.AZURE_PUBLISH_PASSWORD",
        "description": "Publishing password from environment"
      }
    ]
  },
  "references": [
    "https://rules.sonarsource.com/secrets/RSPEC-7001"
  ],
  "logic": {
    "node_types": [],
    "checks": [
      {
        "type": "regex",
        "pattern": "[a-zA-Z0-9]{60,}",
        "message": "Azure App Service deployment password detected",
        "context_keywords": [
          "azure",
          "AZURE",
          "Azure",
          "deployment",
          "deploy",
          "publish",
          "publishing",
          "publishingPassword",
          "userPWD",
          "ftp",
          "FTP",
          "ftps",
          "scm",
          "SCM",
          "kudu",
          "KUDU",
          "app_service",
          "appservice",
          "webapp",
          "webApp",
          "WebApp",
          "password",
          "PASSWORD",
          "credential",
          "websitesEnable"
        ]
      },
      {
        "type": "regex",
        "pattern": "[a-zA-Z0-9._~-]{50,80}",
        "message": "Azure App Service publishing profile password detected",
        "context_keywords": [
          "azure",
          "AZURE",
          "publishingPassword",
          "userPWD",
          "publish",
          "publishing",
          "profile",
          "publishProfile",
          "deployment",
          "deploy",
          "ftp",
          "FTP",
          "scm",
          "SCM",
          "kudu",
          "app_service",
          "webapp"
        ]
      }
    ]
  }
}