{
  "filename": "slack_application_tokens_should_not_be_disclosed_metadata.json",
  "rule_id": "slack_application_tokens_disclosed",
  "title": "Slack application tokens should not be disclosed",
  "description": "In most cases, trust boundaries are violated when a secret is exposed in a source code repository or an uncontrolled deployment environment. Unintended people who don\u2019t need to know the secret might get access to it. They might then be able to use it to gain unwanted access to associated services or resources.",
  "status": "ready",
  "defaultSeverity": "Info",
  "category": "Security",
  "recommendation": "Review and fix according to the rule guidelines.",
  "impact": "Security risk",
  "tags": [
    "security",
    "cwe"
  ],
  "examples": {
    "noncompliant": [],
    "compliant": []
  },
  "references": [
    "https://rules.sonarsource.com/secrets/RSPEC-7349"
  ],
  "logic": {
    "node_types": [],
    "checks": [
      {
        "type": "regex",
        "pattern": "\\bxapp-1-[A-Za-z0-9]{1,200}\\b",
        "message": "Slack app-level token detected in source code. App-level tokens (xapp-1-...) provide Socket Mode connectivity and app-level API access for Slack applications. These tokens enable real-time bidirectional communication and perform actions at the app level (not tied to specific users or workspaces). Exposing app-level tokens creates significant security risks: attackers can establish Socket Mode connections to receive events from all workspaces where your app is installed, intercept real-time messages, events, and interactions, modify or drop events before they reach your application, access app-level API endpoints and perform administrative actions, enumerate all workspace installations and connected users, potentially exfiltrate sensitive data from multiple organizations, and impersonate your application to perform malicious activities. Immediate remediation steps: revoke the compromised app-level token through the Slack App Management console (https://api.slack.com/apps), generate a new app-level token with appropriate connection:write scope, update all Socket Mode clients and services with the new token, review Socket Mode connection logs for unauthorized access, store app-level tokens securely in environment variables or secret management systems (AWS Secrets Manager, HashiCorp Vault, Azure Key Vault), implement token rotation policies and audit logging, never commit tokens to version control or expose in logs, use different tokens for development/staging/production environments, and enable Slack's security monitoring features.",
