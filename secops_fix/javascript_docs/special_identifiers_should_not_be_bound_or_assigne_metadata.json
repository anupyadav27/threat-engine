{
  "filename": "special_identifiers_should_not_be_bound_or_assigne_metadata.json",
  "rule_id": "special_identifiers_bound_assigned",
  "title": "Special identifiers should not be bound or assigned",
  "description": "Special identifiers should not be bound or assignedAnalyze your codeconsistency-conventionalreliabilityBugpitfallWhy is this an issue?More InfoJavaScript has special identifiers that, while not reserved, still should not be used as identifiers. They form the JavaScript standard built-in objects and global properties. They are available in all environments.",
  "status": "ready",
  "defaultSeverity": "Major",
  "category": "Security",
  "recommendation": "Review and fix according to the rule guidelines.",
  "impact": "Security risk",
  "tags": [
    "security",
    "bug",
    "deprecated",
    "async"
  ],
  "examples": {
    "noncompliant": [
      "Object"
    ],
    "compliant": [
      "Function"
    ]
  },
  "references": [
    "https://rules.sonarsource.com/javascript/RSPEC-2137"
  ],
  "logic": {
    "node_types": [
      "AssignmentExpression",
      "VariableDeclaration",
      "FunctionDeclaration", 
      "ClassDeclaration"
    ],
    "checks": [
      {
        "type": "forbidden_value",
        "property_path": [
          "left",
          "name"
        ],
        "forbidden_values": [
          "Object", "Array", "String", "Number", "Boolean", "Function", "Symbol", "BigInt",
          "Math", "Date", "RegExp", "Error", "JSON", "Promise", "Proxy", "Reflect", 
          "undefined", "NaN", "Infinity", "arguments", "eval", "isNaN", "isFinite", 
          "parseInt", "parseFloat", "decodeURI", "decodeURIComponent", "encodeURI", "encodeURIComponent",
          "console", "window", "document", "global", "process", "Buffer"
        ],
        "message": "Do not assign to built-in global identifier - this can break JavaScript functionality"
      },
      {
        "type": "forbidden_value",
        "property_path": [
          "declarations", 
          0,
          "id",
          "name"
        ],
        "forbidden_values": [
          "Object", "Array", "String", "Number", "Boolean", "Function", "Symbol", "BigInt",
          "Math", "Date", "RegExp", "Error", "JSON", "Promise", "Proxy", "Reflect", 
          "undefined", "NaN", "Infinity", "arguments", "eval", "isNaN", "isFinite", 
          "parseInt", "parseFloat", "decodeURI", "decodeURIComponent", "encodeURI", "encodeURIComponent",
          "console", "window", "document", "global", "process", "Buffer"
        ],
        "message": "Do not declare variables with built-in global identifier names"
      },
      {
        "type": "forbidden_value",
        "property_path": [
          "id",
          "name"
        ],
        "forbidden_values": [
          "Object", "Array", "String", "Number", "Boolean", "Function", "Symbol", "BigInt",
          "Math", "Date", "RegExp", "Error", "JSON", "Promise", "Proxy", "Reflect", 
          "undefined", "NaN", "Infinity", "arguments", "eval", "isNaN", "isFinite", 
          "parseInt", "parseFloat", "decodeURI", "decodeURIComponent", "encodeURI", "encodeURIComponent",
          "console", "window", "document", "global", "process", "Buffer"
        ],
        "message": "Do not use built-in global identifiers as function or class names"
      }
    ]
  }
}