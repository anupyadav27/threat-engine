{
  "rule_id": "regex_alternatives_should_not_be_redundant",
  "title": "Regex alternatives should not be redundant",
  "type": "CODE_SMELL",
  "status": "ready",
  "defaultSeverity": "Minor",
  "description": "Avoid using redundant alternatives in regular expressions.",
  "message": "Redundant alternatives in a regular expression.",
  "remediation": {
    "func": "Constant/Issue",
    "constantCost": "5min"
  },
  "tags": [
    "regex",
    "performance"
  ],
  "impact": "Performance impact",
  "recommendation": "Refactor the regular expression to remove redundant alternatives.",
  "references": [],
  "examples": {
    "noncompliant": [
      {
        "code": "import re\npattern = re.compile(r'a|b|b')",
        "description": "Matches 'a' or 'b' twice."
      }
    ],
    "compliant": [
      {
        "code": "import re\npattern = re.compile(r'a|c')",
        "description": "Matches 'a' or 'c'."
      }
    ]
  },
  "devsecops": {
    "category": "",
    "security": "",
    "automation": "",
    "compliance": ""
  },
  "why_is_this_an_issue": "Redundant alternatives in a regular expression can lead to performance degradation as the engine requires more computational resources for the match.",
  "how_to_fix": "Refactor the regular expression to remove redundant alternatives.",
  "security_mappings": {
    "CWE": "",
    "CERT": "",
    "OWASP": ""
  },
  "logic": {
    "check_type": "property_comparison",
    "node_types": ["Call"],
    "property_path": ["func", "attr"],
    "forbidden_values": ["compile"],
    "additional_checks": [
      {
        "property_path": ["args", 0, "node_type"],
        "forbidden_values": ["Constant"],
        "property_path_2": ["args", 0, "value"],
        "pattern": ".*\\|(?:[^|]+\\|)*([^|]+)\\|.*\\1.*"
      }
    ]
  },
