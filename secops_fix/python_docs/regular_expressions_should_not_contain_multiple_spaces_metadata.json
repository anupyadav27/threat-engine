{
  "rule_id": "regular_expressions_should_not_contain_multiple_spaces",
  "title": "Regular expressions should not contain multiple spaces",
  "type": "CODE_SMELL",
  "status": "ready",
  "defaultSeverity": "Major",
  "description": "Regular expressions should be written without multiple spaces for readability and maintainability.",
  "message": "Multiple spaces found in regular expression.",
  "remediation": {
    "func": "Constant/Issue",
    "constantCost": "5min"
  },
  "tags": [
    "regular_expressions",
    "spaces"
  ],
  "impact": "Readability",
  "recommendation": "Avoid using multiple spaces in regular expressions.",
  "references": [],
  "examples": {
    "noncompliant": [
      {
        "code": "import re\npattern = re.compile('.*\\s\\s.*')",
        "description": "Multiple spaces in regular expression"
      }
    ],
    "compliant": [
      {
        "code": "import re\npattern = re.compile('.*\\s.*')",
        "description": "Single space in regular expression"
      }
    ]
  },
  "devsecops": {
    "category": "",
    "security": "",
    "automation": "",
    "compliance": ""
  },
  "why_is_this_an_issue": "Multiple spaces in regular expressions can make the code harder to read and maintain.",
  "how_to_fix": "Replace multiple spaces with a single space in regular expressions.",
  "security_mappings": {
    "CWE": "",
    "CERT": "",
    "OWASP": ""
  },
  "logic": {
    "check_type": "property_comparison",
    "node_types": ["Call"],
    "property_path": ["func", "attr"],
    "forbidden_values": ["compile", "match", "search", "findall", "finditer"],
    "additional_checks": [
      {
        "property_path": ["args", 0, "node_type"],
        "required_values": ["Constant"],
        "property_path_2": ["args", 0, "value"],
        "patterns": [
          ".*  +.*"
        ]
      }
    ]
  },
