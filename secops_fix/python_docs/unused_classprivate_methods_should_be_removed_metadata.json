  "remediation": {
    "func": "Constant/Issue",
    "constantCost": "5min"
  },
  "tags": [
    "unused",
    "refactoring",
    "maintainability"
  ],
  "impact": "Low",
  "recommendation": "Remove unused private methods",
  "references": [],
  "examples": {
    "noncompliant": [
      {
        "code": "class MyClass:\n    def _unused_method(self):\n        pass"
      }
    ],
    "compliant": [
      {
        "code": "class MyClass:\n    def _used_method(self):\n        pass"
      }
    ]
  },
  "devsecops": {
    "category": "",
    "security": "",
    "automation": "",
    "compliance": ""
  },
  "why_is_this_an_issue": "Unused methods in code can make it harder to reason about the application's behavior and make future changes.",
  "how_to_fix": "Either use the private method, or remove it if it's not needed.",
  "security_mappings": {
    "CWE": "",
    "CERT": "",
    "OWASP": ""
  },
  "logic": {
    "node_types": ["FunctionDef"],
    "checks": [
      {
