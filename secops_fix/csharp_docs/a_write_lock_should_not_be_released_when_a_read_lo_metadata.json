{
  "filename": "a_write_lock_should_not_be_released_when_a_read_lo_metadata.json",
  "rule_id": "write_lock_released_when",
  "title": "A write lock should not be released when a read lock has been acquired and vice versa",
  "description": "This rule detects lock type mismatches between acquisition and release operations on ReaderWriterLock and ReaderWriterLockSlim objects. Specifically detects when you acquire a write lock but release a read lock, or acquire a read lock but release a write lock. The rule uses context-aware analysis to track lock state per object instance within method scope, reducing false positives while maintaining high detection accuracy.",
  "status": "ready",
  "defaultSeverity": "Major",
  "category": "Security",
  "recommendation": "Ensure lock acquisition and release operations match the same lock type on the same object instance. Use ReleaseWriterLock/ExitWriteLock after AcquireWriterLock/EnterWriteLock, and ReleaseReaderLock/ExitReadLock after AcquireReaderLock/EnterReadLock.",
  "impact": "Security risk",
  "tags": [
    "security",
    "bug",
    ".net"
  ],
  "examples": {
    "noncompliant": [
      "rwLock.AcquireWriterLock(1000); rwLock.ReleaseReaderLock();",
      "rwLockSlim.EnterReadLock(); rwLockSlim.ExitWriteLock();",
      "lock.UpgradeToWriterLock(1000); lock.ReleaseReaderLock();"
    ],
    "compliant": [
      "rwLock.AcquireWriterLock(1000); rwLock.ReleaseWriterLock();",
      "rwLockSlim.EnterReadLock(); rwLockSlim.ExitReadLock();",
      "lock1.AcquireWriterLock(1000); lock2.ReleaseReaderLock();"
    ]
  },
  "references": [
    "https://rules.sonarsource.com/csharp/RSPEC-7131"
  ],
  "logic": {
    "node_types": [
      "CallExpression"
    ],
    "checks": [
      {
        "type": "context_aware_lock_check",
        "property_path": [
          "name"
        ],
        "acquisition_patterns": {
          "write_lock": [
            "AcquireWriterLock",
            "UpgradeToWriterLock", 
            "EnterWriteLock",
            "TryEnterWriteLock"
          ],
          "read_lock": [
            "AcquireReaderLock",
            "DowngradeFromWriterLock",
            "EnterReadLock",
            "TryEnterReadLock",
            "EnterUpgradeableReadLock",
            "TryEnterUpgradeableReadLock"
          ]
        },
        "release_patterns": {
          "write_lock": [
            "ReleaseWriterLock",
            "ExitWriteLock"
          ],
          "read_lock": [
            "ReleaseReaderLock", 
            "ExitReadLock"
          ]
        },
        "violations": [
          {
            "acquired": "write_lock",
            "released": "read_lock",
            "message": "Write lock acquired but read lock released - potential lock type mismatch"
          },
          {
            "acquired": "read_lock", 
            "released": "write_lock",
            "message": "Read lock acquired but write lock released - potential lock type mismatch"
          }
        ],
        "scope_tracking": {
          "track_object_instances": true,
          "track_method_boundaries": true,
          "ignore_different_objects": true,
          "ignore_comments": true,
          "ignore_string_literals": true,
          "ignore_method_names": true
        },
        "confidence_level": "high"
      }
    ]
  }
}