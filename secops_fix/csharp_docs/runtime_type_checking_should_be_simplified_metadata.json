{
  "filename": "runtime_type_checking_should_be_simplified_metadata.json",
  "rule_id": "runtime_type_checking_simplified",
  "title": "Runtime type checking should be simplified",
  "description": "To check the type of an object there are several options: expr is SomeType or expr.GetType() == typeof(SomeType) if the type is known at compile time, typeInstance.IsInstanceOfType(expr) if the type is calculated during runtime. If runtime calculated Types need to be compared: typeInstance1.IsAssignableFrom(typeInstance2). Depending on whether the type is returned by a GetType() or typeof() call, the IsAssignableFrom() and IsInstanceOfType() might be simplified.",
  "status": "ready",
  "defaultSeverity": "Major",
  "category": "Security",
  "recommendation": "Review and fix according to the rule guidelines.",
  "impact": "Security risk",
  "tags": [
    "security",
    "bug",
    ".net"
  ],
  "examples": {
    "noncompliant": [
      "typeof(string).IsInstanceOfType(obj); // Should use 'is' operator",
      "obj.GetType() == typeof(string); // Should use 'is' operator",
      "typeof(List<string>).IsAssignableFrom(obj.GetType()); // Complex when simple check works",
      "type1.IsAssignableFrom(typeof(string)); // Should use direct comparison"
    ],
    "compliant": [
      "obj is string; // Simple and clear",
      "obj is List<string>; // Direct type check",
      "typeof(BaseClass).IsAssignableFrom(derivedType); // When types are variables",
      "baseType.IsInstanceOfType(obj); // When type is calculated at runtime"
    ]
  },
  "references": [
    "https://rules.sonarsource.com/csharp/RSPEC-2219"
  ],
  "logic": {
    "node_types": ["MethodDeclaration", "ClassDeclaration"],
    "checks": [
      {
        "type": "regex_match",
        "property_path": ["source"],
        "pattern": "typeof\\([^)]+\\)\\.IsInstanceOfType\\(|\\w+\\.GetType\\(\\)\\s*==\\s*typeof\\(|typeof\\([^)]+\\)\\.IsAssignableFrom\\([^)]*\\.GetType\\(\\)|\\w+\\.IsAssignableFrom\\(typeof\\(",
        "exclude_patterns": [
          "Console\\.",
          "Logger\\.",
          "Debug\\.",
          "\\$\"",
          "string\\.Format",
          "\\[Test\\]",
          "Assert\\.",
          "//",
          "/\\*",
          "///"
        ]
      }
    ],
    "target_ast_nodes": ["MethodDeclaration", "ClassDeclaration"],
    "detection_conditions": [
      {
        "type": "regex_match",
        "property_path": ["source"],
        "pattern": "typeof\\([^)]+\\)\\.IsInstanceOfType\\(|\\w+\\.GetType\\(\\)\\s*==\\s*typeof\\(|typeof\\([^)]+\\)\\.IsAssignableFrom\\([^)]*\\.GetType\\(\\)|\\w+\\.IsAssignableFrom\\(typeof\\(",
        "exclude_patterns": [
          "Console\\.",
          "Logger\\.",
          "Debug\\.",
          "\\$\"",
          "string\\.Format",
          "\\[Test\\]",
          "Assert\\.",
          "//",
          "/\\*",
          "///"
        ]
      }
    ],
    "triggering_conditions": {
      "logic": "OR", 
      "conditions": [
        "Uses typeof().IsInstanceOfType() when 'is' operator would work",
        "Uses GetType() == typeof() when 'is' operator would work",
        "Uses complex type checking when simple alternative exists"
      ]
    },
    "exclusion_conditions": [
      "Type checking with runtime-calculated types",
      "Appropriate use of 'is' operator",
      "In test context",
      "In logging context"
    ],
    "never_trigger_on": [
      "Logging statements (Console.*, Logger.*, Debug.*)",
      "String formatting ($\"\", string.Format)",
      "Unit tests ([Test], [Fact], Assert.*)",
      "Comments (//, /*, ///)",
      "Runtime type comparisons where types are variables",
      "Appropriate use of 'is' operator"
    ],
    "reasoning": "Detects complex type checking patterns that can be simplified with the 'is' operator or more appropriate reflection methods. Identifies cases where typeof().IsInstanceOfType(), GetType() == typeof(), and similar patterns can be replaced with simpler and more readable alternatives.",
    "validation_examples": {
      "should_trigger": [
        "typeof(string).IsInstanceOfType(obj);",
        "obj.GetType() == typeof(string);",
        "typeof(List<string>).IsAssignableFrom(obj.GetType());",
        "type1.IsAssignableFrom(typeof(string));"
      ],
      "should_not_trigger": [
        "obj is string;",
        "obj is List<string>;",
        "baseType.IsAssignableFrom(derivedType); // both are Type variables",
        "calculatedType.IsInstanceOfType(obj); // type calculated at runtime"
      ]
    }
  }
}