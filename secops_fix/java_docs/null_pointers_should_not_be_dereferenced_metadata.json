{
  "filename": "null_pointers_should_not_be_dereferenced_metadata.json",
  "rule_id": "VULNERABILITY_AVOID_NULL_REFERENCE",
  "title": "Avoid Dereferencing Null Pointers",
  "description": "Never dereference or access a null reference to prevent NullPointerExceptions and potential security vulnerabilities.",
  "status": "ready",
  "defaultSeverity": "Major",
  "category": "VULNERABILITY",
  "recommendation": "Avoid dereferencing null references.",
  "impact": "Prevent abrupt program termination, exposure of debugging information, and potential security vulnerabilities.",
  "examples": {
    "noncompliant": [],
    "compliant": []
  },
  "references": [
    "https://rules.sonarsource.com/java/RSPEC-2259"
  ],
  "logic": {
    "node_types": [
      "Class"
    ],
    "checks": [
      {
        "type": "regex_match",
        "property_path": ["source"],
        "pattern": "(\\w+)\\s*=\\s*null;[\\s\\S]*?\\1\\.\\w+\\(",
        "message": "Avoid dereferencing null references."
      }
    ]
  }
}