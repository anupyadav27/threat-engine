{
  "filename": "tests_method_should_not_be_annotated_with_competing_annotations_metadata.json",
  "rule_id": "VULNERABILITY_AVOID_MULTIPLE_TEST_ANNOTATIONS",
  "title": "Avoid Multiple Test Annotations",
  "description": "Annotating unit tests with more than one test-related annotation can lead to unexpected behavior like failing tests or unwanted side-effects.",
  "status": "ready",
  "defaultSeverity": "Info",
  "category": "VULNERABILITY",
  "recommendation": "Remove unnecessary annotations.",
  "impact": "Potential for failing tests or unwanted side-effects.",
  "examples": {
    "noncompliant": [],
    "compliant": []
  },
  "references": [
    "https://rules.sonarsource.com/java/RSPEC-5967"
  ],
  "logic": {
    "node_types": [
      "Class"
    ],
    "checks": [
      {
        "type": "regex_match",
        "property_path": [
          "source"
        ],
        "patterns": [
          "@Test[\\s\\S]*@(org\\.testng\\.annotations\\.)?Test"
        ],
        "message": "Remove unnecessary annotations."
      }
    ]
  }
}