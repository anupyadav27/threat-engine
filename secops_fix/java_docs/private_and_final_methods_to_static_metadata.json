{
  "filename": "private_and_final_methods_to_static_metadata.json",
  "rule_id": "style_method_access_type",
  "title": "Ensure non-overridable methods (private or final) are static if they don't access instance data",
  "description": "Non-overridable methods (private or final) that don't access instance data can be static to prevent any misunderstanding about the contract of the method.",
  "status": "ready",
  "defaultSeverity": "Major",
  "category": "Style",
  "recommendation": "Make the method static",
  "impact": "Improves code readability and maintainability",
  "examples": {
    "noncompliant": [],
    "compliant": []
  },
  "references": [],
  "logic": {
    "node_types": [
      "Class"
    ],
    "checks": [
      {
        "type": "regex_match",
        "property_path": ["source"],
        "pattern": "(private|final)\\s+(?!static)[^\n]*void\\s+\\w+\\s*\\([^)]*\\)\\s*\\{[^{}]*System\\.out\\.println\\(\\\"No instance data\\\"\\)",
        "message": "Make the method static"
      }
    ]
  }
}