{
  "filename": "underscores-readable-numbers-metadata.json",
  "rule_id": "style_numeric_literals_use_underscores",
  "title": "Use underscores for readable large numbers",
  "description": "Enhance readability of large numbers by using underscores in numeric literals. This has no semantic meaning but improves maintainability.",
  "status": "ready",
  "defaultSeverity": "Major",
  "category": "Style",
  "recommendation": "Use underscores in numeric literals",
  "impact": "Improves readability and maintainability",
  "examples": {
    "noncompliant": [
      "int i = 10000000;",
      "int j = 0b01101001010011011110010101011110;",
      "long l = 0x7fffffffffffffffL;"
    ],
    "compliant": [
      "int i = 10_000_000;",
      "int j = 0b01101001_01001101_11100101_01011110;",
      "long l = 0x7fff_ffff_ffff_ffffL;"
    ]
  },
  "references": [],
  "logic": {
    "node_types": [
      "CompilationUnit"
    ],
    "checks": [
      {
        "type": "regex_match",
        "property_path": ["source"],
        "patterns": ["\\b\\d{5,}\\b"],
        "message": "Use underscores in numeric literals for readability."
      }
    ]
  }
}