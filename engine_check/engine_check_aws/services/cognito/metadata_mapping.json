      "rule_id": "aws.cognito.userpool.access_keys_rotated_90_days_or_less_when_present",
      "python_method": "list_users",
      "response_path": "Users",
      "logical_operator": "all",
      "nested_field": [
        {
          "field_path": "UserLastModifiedDate",
          "expected_value": 90,
          "operator": "less_than_or_equal_to"
        }
      ]
    },
