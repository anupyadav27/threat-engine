{
  "service": "storagesync",
  "seed_from_list": [
    "Enabled",
    "Statement",
    "Status",
    "Version",
    "group_id",
    "id",
    "name",
    "required_members",
    "required_zone_names",
    "type"
  ],
  "enriched_from_get_describe": [],
  "final_union": [
    "Enabled",
    "Statement",
    "Status",
    "Version",
    "group_id",
    "id",
    "name",
    "required_members",
    "required_zone_names",
    "type"
  ],
  "source": {
    "operation_registry": "services/storagesync/operation_registry.json",
    "read_ops_rule": "kind is read_list (seed) or read_get (enriched)",
    "excluded_keys": [
      "next_link",
      "nextLink",
      "continuation_token",
      "value",
      "skip_token",
      "max_results",
      "top",
      "skip"
    ]
  },
  "fields": {
    "Enabled": {
      "operators": [
        "equals",
        "not_equals"
      ],
      "dependency_index_entity": "storagesync.item_monitoring_configuration",
      "type": "boolean"
    },
    "Status": {
      "operators": [
        "equals",
        "not_equals",
        "in"
      ],
      "dependency_index_entity": "storagesync.item_monitoring_configuration",
      "type": "string"
    },
    "Version": {
      "operators": [
        "equals",
        "not_equals"
      ],
      "dependency_index_entity": "storagesync.item_initial_download_policy",
      "type": "string"
    },
    "Statement": {
      "operators": [
        "contains"
      ],
      "dependency_index_entity": "storagesync.item_initial_download_policy",
      "type": "array"
    }
  }
}