  "source": {
    "operation_registry": "services/signalr/operation_registry.json",
    "read_ops_rule": "kind is read_list (seed) or read_get (enriched)",
    "excluded_keys": [
      "next_link",
      "nextLink",
      "continuation_token",
      "value",
      "skip_token",
      "max_results",
      "top",
      "skip"
    ]
