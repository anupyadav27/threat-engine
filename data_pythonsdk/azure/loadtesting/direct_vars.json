    },
    "PrincipalId": {
      "operators": [
        "equals",
        "not_equals",
        "contains"
      ],
      "dependency_index_entity": "loadtesting.item_identity",
      "type": "string"
    },
    "KeySource": {
      "operators": [
        "equals",
        "not_equals",
        "in"
      ],
      "dependency_index_entity": "loadtesting.item_encryption",
      "type": "string"
    },
    "KeyVaultProperties": {
      "operators": [
        "equals",
        "not_equals"
      ],
      "dependency_index_entity": "loadtesting.item_encryption",
      "type": "object"
    }
  }
