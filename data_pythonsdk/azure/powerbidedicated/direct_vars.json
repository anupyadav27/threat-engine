  ],
  "final_union": [
    "Name",
    "Tier",
    "administration",
    "id",
    "location",
    "mode",
    "name",
    "provisioning_state",
    "sku",
    "state",
    "system_data",
    "tags",
    "tier",
    "type"
  ],
  "source": {
    "operation_registry": "services/powerbidedicated/operation_registry.json",
    "read_ops_rule": "kind is read_list (seed) or read_get (enriched)",
    "excluded_keys": [
      "next_link",
      "nextLink",
      "continuation_token",
      "value",
      "skip_token",
      "max_results",
      "top",
      "skip"
    ]
  },
  "fields": {
    "Name": {
      "operators": [
        "equals",
        "not_equals",
        "in"
      ],
      "dependency_index_entity": "powerbidedicated.item_sku",
      "type": "string"
    },
    "Tier": {
      "operators": [
        "equals",
        "not_equals",
        "in"
      ],
      "dependency_index_entity": "powerbidedicated.item_sku",
      "type": "string"
    }
  }
