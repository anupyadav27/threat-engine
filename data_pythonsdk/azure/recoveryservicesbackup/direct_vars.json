    "quota_period",
    "start_time",
    "status",
    "tags",
    "type",
    "unit"
  ],
  "source": {
    "operation_registry": "services/recoveryservicesbackup/operation_registry.json",
    "read_ops_rule": "kind is read_list (seed) or read_get (enriched)",
    "excluded_keys": [
      "next_link",
      "nextLink",
      "continuation_token",
      "value",
      "skip_token",
      "max_results",
      "top",
      "skip"
    ]
  },
  "fields": {
    "Enabled": {
      "operators": [
        "equals",
        "not_equals"
      ],
      "dependency_index_entity": "recoveryservicesbackup.item_properties",
      "type": "boolean"
    },
    "Status": {
      "operators": [
        "equals",
        "not_equals",
        "in"
      ],
      "dependency_index_entity": "recoveryservicesbackup.item_properties",
      "type": "string"
    }
  }
}