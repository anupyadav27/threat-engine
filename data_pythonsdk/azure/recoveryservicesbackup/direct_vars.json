  "enriched_from_get_describe": [
    "end_time",
    "error",
    "id",
    "name",
    "properties",
    "start_time",
    "status"
  ],
  "final_union": [
    "Enabled",
    "Status",
    "current_value",
    "display",
    "e_tag",
    "end_time",
    "error",
    "id",
    "limit",
    "location",
