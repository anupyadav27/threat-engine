{
  "service": "hanaonazure",
  "seed_from_list": [
    "Enabled",
    "Status"
  ],
  "enriched_from_get_describe": [],
  "final_union": [
    "Enabled",
    "Status"
  ],
  "source": {
    "operation_registry": "services/hanaonazure/operation_registry.json",
    "read_ops_rule": "kind is read_list (seed) or read_get (enriched)",
    "excluded_keys": [
      "next_link",
      "nextLink",
      "continuation_token",
      "value",
      "skip_token",
      "max_results",
      "top",
      "skip"
    ]
  },
  "fields": {
    "Enabled": {
      "operators": [
        "equals",
        "not_equals"
      ],
      "dependency_index_entity": "hanaonazure.item_type_properties_type",
      "type": "boolean"
    },
    "Status": {
      "operators": [
        "equals",
        "not_equals",
        "in"
      ],
      "dependency_index_entity": "hanaonazure.item_type_properties_type",
      "type": "string"
    }
  }
}