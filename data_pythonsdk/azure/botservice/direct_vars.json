  "final_union": [
    "Enabled",
    "Name",
    "Status",
    "Tier",
    "abs_code",
    "changed_time",
    "display",
    "entity_tag",
    "etag",
    "group_id",
    "group_ids",
    "id",
    "kind",
    "location",
    "message",
    "name",
    "origin",
    "private_endpoint",
    "private_link_service_connection_state",
    "properties",
    "provisioning_state",
    "required_members",
    "required_zone_names",
    "resource",
    "setting",
    "sku",
    "tags",
    "type",
    "valid",
    "zones"
  ],
  "source": {
    "operation_registry": "services/botservice/operation_registry.json",
    "read_ops_rule": "kind is read_list (seed) or read_get (enriched)",
    "excluded_keys": [
      "next_link",
      "nextLink",
      "continuation_token",
      "value",
      "skip_token",
      "max_results",
      "top",
      "skip"
    ]
  },
  "fields": {
    "Name": {
      "operators": [
        "equals",
        "not_equals",
        "in"
      ],
      "dependency_index_entity": "botservice.item_sku",
      "type": "string"
    },
    "Tier": {
      "operators": [
        "equals",
        "not_equals",
        "in"
      ],
      "dependency_index_entity": "botservice.item_sku",
      "type": "string"
    },
    "Enabled": {
      "operators": [
        "equals",
        "not_equals"
      ],
      "dependency_index_entity": "botservice.item_properties",
      "type": "boolean"
    },
    "Status": {
      "operators": [
        "equals",
        "not_equals",
        "in"
      ],
      "dependency_index_entity": "botservice.item_properties",
      "type": "string"
    }
  }
}