version: '1.0'
provider: aws
service: iam
services:
  client: iam
  module: boto3.client
discovery:
- discovery_id: aws.iam.list_delegation_requests
  calls:
  - action: list_delegation_requests
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.DelegationRequests }}'
- discovery_id: aws.iam.list_policies
  calls:
  - action: list_policies
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Policies }}'
- discovery_id: aws.iam.list_roles
  calls:
  - action: list_roles
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Roles }}'
- discovery_id: aws.iam.get_account_authorization_details
  calls:
  - action: get_account_authorization_details
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.UserDetailList }}'
- discovery_id: aws.iam.get_account_password_policy
  calls:
  - action: get_account_password_policy
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.PasswordPolicy }}'
- discovery_id: aws.iam.list_users
  calls:
  - action: list_users
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Users }}'
- discovery_id: aws.iam.list_service_specific_credentials
  calls:
  - action: list_service_specific_credentials
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ServiceSpecificCredentials }}'
- discovery_id: aws.iam.list_instance_profiles
  calls:
  - action: list_instance_profiles
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.InstanceProfiles }}'
- discovery_id: aws.iam.get_user
  calls:
  - action: get_user
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.User }}'
- discovery_id: aws.iam.list_virtual_mfa_devices
  calls:
  - action: list_virtual_mfa_devices
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.VirtualMFADevices }}'
- discovery_id: aws.iam.list_server_certificates
  calls:
  - action: list_server_certificates
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ServerCertificateMetadataList }}'
- discovery_id: aws.iam.list_groups
  calls:
  - action: list_groups
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Groups }}'
- discovery_id: aws.iam.list_signing_certificates
  calls:
  - action: list_signing_certificates
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Certificates }}'
- discovery_id: aws.iam.list_ssh_public_keys
  calls:
  - action: list_ssh_public_keys
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.SSHPublicKeys }}'
- discovery_id: aws.iam.list_access_keys
  calls:
  - action: list_access_keys
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AccessKeyMetadata }}'
- discovery_id: aws.iam.get_login_profile
  calls:
  - action: get_login_profile
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.LoginProfile }}'
- discovery_id: aws.iam.list_saml_providers
  calls:
  - action: list_saml_providers
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.SAMLProviderList }}'
- discovery_id: aws.iam.get_outbound_web_identity_federation_info
  calls:
  - action: get_outbound_web_identity_federation_info
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.IssuerIdentifier }}'
- discovery_id: aws.iam.get_credential_report
  calls:
  - action: get_credential_report
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Content }}'
- discovery_id: aws.iam.get_account_summary
  calls:
  - action: get_account_summary
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.SummaryMap }}'
- discovery_id: aws.iam.get_service_last_accessed_details
  calls:
  - action: get_service_last_accessed_details
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ServicesLastAccessed }}'
- discovery_id: aws.iam.get_organizations_access_report
  calls:
  - action: get_organizations_access_report
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.AccessDetails }}'
- discovery_id: aws.iam.get_ssh_public_key
  for_each: aws.iam.list_ssh_public_keys
  calls:
  - action: get_ssh_public_key
    save_as: response
    on_error: continue
    params:
      UserName: '{{ item.userDetailListUserName }}'
  emit:
    as: item
    items_for: '{{ response.SSHPublicKey }}'
- discovery_id: aws.iam.get_saml_provider
  calls:
  - action: get_saml_provider
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.PrivateKeyList }}'
- discovery_id: aws.iam.get_human_readable_summary
  calls:
  - action: get_human_readable_summary
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.SummaryContent }}'
- discovery_id: aws.iam.list_role_tags
  for_each: aws.iam.list_roles
  calls:
  - action: list_role_tags
    save_as: response
    on_error: continue
    params:
      RoleName: '{{ item.rolRoleName }}'
  emit:
    as: item
    items_for: '{{ response.Tags }}'
- discovery_id: aws.iam.get_access_key_last_used
  for_each: aws.iam.list_access_keys
  calls:
  - action: get_access_key_last_used
    save_as: response
    on_error: continue
    params:
      AccessKeyId: '{{ item.accessKeyMetadataAccessKeyId }}'
  emit:
    as: item
    items_for: '{{ response.AccessKeyLastUsed }}'
- discovery_id: aws.iam.get_server_certificate
  for_each: aws.iam.list_server_certificates
  calls:
  - action: get_server_certificate
    save_as: response
    on_error: continue
    params:
      ServerCertificateName: '{{ item.serverCertificateMetadataListServerCertificateName
        }}'
  emit:
    as: item
    items_for: '{{ response.ServerCertificate }}'
- discovery_id: aws.iam.get_service_linked_role_deletion_status
  calls:
  - action: get_service_linked_role_deletion_status
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Reason }}'
- discovery_id: aws.iam.get_role
  for_each: aws.iam.list_roles
  calls:
  - action: get_role
    save_as: response
    on_error: continue
    params:
      RoleName: '{{ item.rolRoleName }}'
  emit:
    as: item
    items_for: '{{ response.Role }}'
- discovery_id: aws.iam.get_mfa_device
  for_each: aws.iam.list_virtual_mfa_devices
  calls:
  - action: get_mfa_device
    save_as: response
    on_error: continue
    params:
      SerialNumber: '{{ item.mfaDevicSerialNumber }}'
  emit:
    as: item
    items_for: '{{ response.UserName }}'
- discovery_id: aws.iam.list_attached_user_policies
  for_each: aws.iam.get_account_authorization_details
  calls:
  - action: list_attached_user_policies
    save_as: response
    on_error: continue
    params:
      UserName: '{{ item.userDetailListUserName }}'
  emit:
    as: item
    items_for: '{{ response.AttachedPolicies }}'
- discovery_id: aws.iam.list_policy_versions
  for_each: aws.iam.list_attached_user_policies
  calls:
  - action: list_policy_versions
    save_as: response
    on_error: continue
    params:
      PolicyArn: '{{ item.attachedPolicyPolicyArn }}'
  emit:
    as: item
    items_for: '{{ response.Versions }}'
- discovery_id: aws.iam.get_policy
  for_each: aws.iam.list_attached_user_policies
  calls:
  - action: get_policy
    save_as: response
    on_error: continue
    params:
      PolicyArn: '{{ item.attachedPolicyPolicyArn }}'
  emit:
    as: item
    items_for: '{{ response.Policy }}'
- discovery_id: aws.iam.get_policy_version
  for_each: aws.iam.list_attached_user_policies
  calls:
  - action: get_policy_version
    save_as: response
    on_error: continue
    params:
      PolicyArn: '{{ item.policyVersionVersionId }}'
  emit:
    as: item
    items_for: '{{ response.PolicyVersion }}'
- discovery_id: aws.iam.get_service_last_accessed_details_with_entities
  for_each: aws.iam.get_service_last_accessed_details
  calls:
  - action: get_service_last_accessed_details_with_entities
    save_as: response
    on_error: continue
    params:
      JobId: '{{ item.accessDetailServiceNamespace }}'
  emit:
    as: item
    items_for: '{{ response.EntityDetailsList }}'
- discovery_id: aws.iam.get_role_policy
  for_each: aws.iam.list_policies
  calls:
  - action: get_role_policy
    save_as: response
    on_error: continue
    params:
      RoleName: '{{ item.rolRoleName }}'
  emit:
    as: item
    items_for: '{{ response.RoleName }}'
- discovery_id: aws.iam.get_open_id_connect_provider
  calls:
  - action: get_open_id_connect_provider
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.ClientIDList }}'
checks: []
