version: '1.0'
provider: aws
service: s3
services:
  client: s3
  module: boto3.client
discovery:
- discovery_id: aws.s3.list_buckets
  calls:
  - action: list_buckets
    save_as: response
    on_error: continue
  emit:
    as: item
    items_for: '{{ response.Buckets }}'
- discovery_id: aws.s3.list_object_versions
  for_each: aws.s3.list_buckets
  calls:
  - action: list_object_versions
    save_as: response
    on_error: continue
    params:
      Bucket: '{{ item.Name }}'
  emit:
    as: item
    items_for: '{{ response.Versions }}'
- discovery_id: aws.s3.get_object
  for_each: aws.s3.list_buckets
  calls:
  - action: get_object
    save_as: response
    on_error: continue
    params:
      Bucket: '{{ item.tagSetKey }}'
  emit:
    as: item
    items_for: '{{ response.Body }}'
- discovery_id: aws.s3.get_bucket_lifecycle_configuration
  for_each: aws.s3.list_buckets
  calls:
  - action: get_bucket_lifecycle_configuration
    save_as: response
    on_error: continue
    params:
      Bucket: '{{ item.Name }}'
  emit:
    as: item
    items_for: '{{ response.Rules }}'
- discovery_id: aws.s3.list_bucket_inventory_configurations
  for_each: aws.s3.list_buckets
  calls:
  - action: list_bucket_inventory_configurations
    save_as: response
    on_error: continue
    params:
      Bucket: '{{ item.Name }}'
  emit:
    as: item
    items_for: '{{ response.InventoryConfigurationList }}'
- discovery_id: aws.s3.get_bucket_cors
  for_each: aws.s3.list_buckets
  calls:
  - action: get_bucket_cors
    save_as: response
    on_error: continue
    params:
      Bucket: '{{ item.Name }}'
  emit:
    as: item
    items_for: '{{ response.CORSRules }}'
- discovery_id: aws.s3.get_bucket_acl
  for_each: aws.s3.list_buckets
  calls:
  - action: get_bucket_acl
    save_as: response
    on_error: continue
    params:
      Bucket: '{{ item.Name }}'
  emit:
    as: item
    items_for: '{{ response.Grants }}'
- discovery_id: aws.s3.get_bucket_logging
  for_each: aws.s3.list_buckets
  calls:
  - action: get_bucket_logging
    save_as: response
    on_error: continue
    params:
      Bucket: '{{ item.Name }}'
  emit:
    as: item
    items_for: '{{ response.LoggingEnabled }}'
- discovery_id: aws.s3.get_public_access_block
  for_each: aws.s3.list_buckets
  calls:
  - action: get_public_access_block
    save_as: response
    on_error: continue
    params:
      Bucket: '{{ item.Name }}'
  emit:
    as: item
    items_for: '{{ response.PublicAccessBlockConfiguration }}'
- discovery_id: aws.s3.list_multipart_uploads
  for_each: aws.s3.list_buckets
  calls:
  - action: list_multipart_uploads
    save_as: response
    on_error: continue
    params:
      Bucket: '{{ item.Name }}'
  emit:
    as: item
    items_for: '{{ response.Uploads }}'
- discovery_id: aws.s3.get_object_acl
  for_each: aws.s3.list_buckets
  calls:
  - action: get_object_acl
    save_as: response
    on_error: continue
    params:
      Bucket: '{{ item.tagSetKey }}'
  emit:
    as: item
    items_for: '{{ response.Grants }}'
- discovery_id: aws.s3.get_bucket_notification
  for_each: aws.s3.list_buckets
  calls:
  - action: get_bucket_notification
    save_as: response
    on_error: continue
    params:
      Bucket: '{{ item.Name }}'
  emit:
    as: item
    items_for: '{{ response.TopicConfiguration }}'
- discovery_id: aws.s3.get_bucket_metadata_table_configuration
  for_each: aws.s3.list_buckets
  calls:
  - action: get_bucket_metadata_table_configuration
    save_as: response
    on_error: continue
    params:
      Bucket: '{{ item.Name }}'
  emit:
    as: item
    items_for: '{{ response.GetBucketMetadataTableConfigurationResult }}'
- discovery_id: aws.s3.get_object_retention
  for_each: aws.s3.list_buckets
  calls:
  - action: get_object_retention
    save_as: response
    on_error: continue
    params:
      Bucket: '{{ item.tagSetKey }}'
  emit:
    as: item
    items_for: '{{ response.Retention }}'
- discovery_id: aws.s3.get_bucket_lifecycle
  for_each: aws.s3.list_buckets
  calls:
  - action: get_bucket_lifecycle
    save_as: response
    on_error: continue
    params:
      Bucket: '{{ item.Name }}'
  emit:
    as: item
    items_for: '{{ response.Rules }}'
- discovery_id: aws.s3.get_bucket_website
  for_each: aws.s3.list_buckets
  calls:
  - action: get_bucket_website
    save_as: response
    on_error: continue
    params:
      Bucket: '{{ item.Name }}'
  emit:
    as: item
    items_for: '{{ response.RoutingRules }}'
- discovery_id: aws.s3.get_bucket_metadata_configuration
  for_each: aws.s3.list_buckets
  calls:
  - action: get_bucket_metadata_configuration
    save_as: response
    on_error: continue
    params:
      Bucket: '{{ item.Name }}'
  emit:
    as: item
    items_for: '{{ response.GetBucketMetadataConfigurationResult }}'
- discovery_id: aws.s3.get_object_lock_configuration
  for_each: aws.s3.list_buckets
  calls:
  - action: get_object_lock_configuration
    save_as: response
    on_error: continue
    params:
      Bucket: '{{ item.Name }}'
  emit:
    as: item
    items_for: '{{ response.ObjectLockConfiguration }}'
- discovery_id: aws.s3.list_parts
  for_each: aws.s3.list_buckets
  calls:
  - action: list_parts
    save_as: response
    on_error: continue
    params:
      Bucket: '{{ item.uploadUploadId }}'
  emit:
    as: item
    items_for: '{{ response.Parts }}'
- discovery_id: aws.s3.get_object_attributes
  for_each: aws.s3.list_buckets
  calls:
  - action: get_object_attributes
    save_as: response
    on_error: continue
    params:
      Bucket: '{{ item.tagSetKey }}'
  emit:
    as: item
    items_for: '{{ response.Checksum }}'
- discovery_id: aws.s3.list_bucket_intelligent_tiering_configurations
  for_each: aws.s3.list_buckets
  calls:
  - action: list_bucket_intelligent_tiering_configurations
    save_as: response
    on_error: continue
    params:
      Bucket: '{{ item.Name }}'
  emit:
    as: item
    items_for: '{{ response.IntelligentTieringConfigurationList }}'
- discovery_id: aws.s3.get_bucket_notification_configuration
  for_each: aws.s3.list_buckets
  calls:
  - action: get_bucket_notification_configuration
    save_as: response
    on_error: continue
    params:
      Bucket: '{{ item.Name }}'
  emit:
    as: item
    items_for: '{{ response.TopicConfigurations }}'
- discovery_id: aws.s3.list_bucket_analytics_configurations
  for_each: aws.s3.list_buckets
  calls:
  - action: list_bucket_analytics_configurations
    save_as: response
    on_error: continue
    params:
      Bucket: '{{ item.Name }}'
  emit:
    as: item
    items_for: '{{ response.AnalyticsConfigurationList }}'
- discovery_id: aws.s3.get_object_tagging
  for_each: aws.s3.list_buckets
  calls:
  - action: get_object_tagging
    save_as: response
    on_error: continue
    params:
      Bucket: '{{ item.tagSetKey }}'
  emit:
    as: item
    items_for: '{{ response.TagSet }}'
- discovery_id: aws.s3.get_bucket_replication
  for_each: aws.s3.list_buckets
  calls:
  - action: get_bucket_replication
    save_as: response
    on_error: continue
    params:
      Bucket: '{{ item.Name }}'
  emit:
    as: item
    items_for: '{{ response.ReplicationConfiguration }}'
- discovery_id: aws.s3.get_bucket_policy
  for_each: aws.s3.list_buckets
  calls:
  - action: get_bucket_policy
    save_as: response
    on_error: continue
    params:
      Bucket: '{{ item.Name }}'
  emit:
    as: item
    items_for: '{{ response.Policy }}'
- discovery_id: aws.s3.get_bucket_policy_status
  for_each: aws.s3.list_buckets
  calls:
  - action: get_bucket_policy_status
    save_as: response
    on_error: continue
    params:
      Bucket: '{{ item.Name }}'
  emit:
    as: item
    items_for: '{{ response.PolicyStatus }}'
- discovery_id: aws.s3.get_bucket_request_payment
  for_each: aws.s3.list_buckets
  calls:
  - action: get_bucket_request_payment
    save_as: response
    on_error: continue
    params:
      Bucket: '{{ item.Name }}'
  emit:
    as: item
    items_for: '{{ response.Payer }}'
checks: []
