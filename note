import sys
sys.path.insert(0, "/app")
import collections

import inventory_engine.index.index_writer as iw
orig = iw.PostgresIndexWriter.write_asset_index

def patched(self, assets):
    types = collections.Counter(a.resource_type for a in assets)
    ec2 = [(a.resource_uid, (a.metadata or {}).get("emitted_fields", {}).get("IamInstanceProfile", "ABSENT")) 
           for a in assets if "instance" in (a.resource_type or "").lower() and "i-0" in (a.resource_uid or "")]
    print("EC2 instance assets:", ec2[:3])
    print("Top resource_types:", types.most_common(5))
    return orig(self, assets)

