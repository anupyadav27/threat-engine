import sys; sys.path.insert(0, '/app')
import os, psycopg2
from psycopg2.extras import RealDictCursor

# Load root_ops from pythonsdk
host = os.getenv('PYTHONSDK_DB_HOST', os.getenv('DISCOVERIES_DB_HOST', os.getenv('ONBOARDING_DB_HOST')))
conn = psycopg2.connect(host=host, port=5432, dbname='threat_engine_pythonsdk', user=os.environ['ONBOARDING_DB_USER'], password=os.environ['ONBOARDING_DB_PASSWORD'])
cur = conn.cursor(cursor_factory=RealDictCursor)
cur.execute(\"\"\"
    SELECT o.operation_name, o.operation_type, o.is_root_operation, s.service_id
    FROM operations o
    JOIN services s ON o.service_id = s.service_id
    WHERE s.csp_id = 'aws' AND s.service_id = 'aws.ec2'
      AND o.is_discovery = true
      AND o.operation_name IN ('DescribeInstances', 'DescribeInstanceImageMetadata', 'DescribeInstanceCreditSpecifications', 'DescribeTags')
\"\"\")
for r in cur.fetchall():
    print(f\"{r['operation_name']}: root={r['is_root_operation']} type={r['operation_type']}\")
conn.close()
