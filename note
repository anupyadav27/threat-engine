    merged = {}
    for k in set(base) | set(overlay):
        bv, ov = base.get(k), overlay.get(k)
        if bv not in (None, '', {}, []):
            merged[k] = bv
        elif ov not in (None, '', {}, []):
            merged[k] = ov
        else:
            merged[k] = bv
