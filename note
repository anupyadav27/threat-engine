import psycopg2, psycopg2.extras, os
conn = psycopg2.connect(
    host=os.getenv('INVENTORY_DB_HOST', os.getenv('DB_HOST')),
    port=os.getenv('INVENTORY_DB_PORT','5432'),
    dbname=os.getenv('INVENTORY_DB_NAME','threat_engine_inventory'),
    user=os.getenv('INVENTORY_DB_USER', os.getenv('DB_USER','postgres')),
    password=os.getenv('INVENTORY_DB_PASSWORD', os.getenv('DB_PASSWORD',''))
)
cur = conn.cursor(cursor_factory=psycopg2.extras.RealDictCursor)
cur.execute(\"SELECT resource_uid, properties FROM inventory_findings WHERE resource_type = 'ec2.instance' AND latest_scan_run_id = 'acfdc044-78bd-4688-92e7-837b7bef30d0' LIMIT 1\")
row = cur.fetchone()
if row:
    ef = (row['properties'] or {}).get('emitted_fields', {})
    print('IamInstanceProfile:', ef.get('IamInstanceProfile', 'MISSING'))
    print('SubnetId:', ef.get('SubnetId', 'MISSING'))
    sgs = ef.get('SecurityGroups', 'MISSING')
    print('SecurityGroups:', len(sgs) if isinstance(sgs, list) else sgs)
else:
    print('No EC2 instances in this scan')
conn.close()
