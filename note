from inventory_engine.normalizer.asset_normalizer import AssetNormalizer
from inventory_engine.normalizer.resource_classifier import ResourceClassifier, InventoryDecision

clf = ResourceClassifier(csp_id='aws')
norm = AssetNormalizer(tenant_id='default-tenant', scan_run_id='test-debug')

def _smart_merge(base, overlay):
    merged = {}
    for k in set(base) | set(overlay):
        bv, ov = base.get(k), overlay.get(k)
        if bv not in (None, '', {}, []):
            merged[k] = bv
        elif ov not in (None, '', {}, []):
            merged[k] = ov
        else:
            merged[k] = bv
    return merged

assets_by_uid = {}
for rec in records:
    disc_id = rec['discovery_id']
    decision = clf.classify_discovery_record(rec)
    is_root = clf.is_root_operation(rec)
    
    # Apply fix logic
    if decision == InventoryDecision.ENRICHMENT_ONLY:
        effective_root = is_root
    elif decision == InventoryDecision.FILTER:
        continue
    else:
        effective_root = is_root
    
    if not effective_root:
        print(f'  SKIP (enrichment): {disc_id}')
        continue
    
    asset = norm.normalize_from_discovery(rec, 'test', skip_classification=True)
    if not asset:
        print(f'  NONE asset: {disc_id}')
        continue
    
    ef = asset.metadata.get('emitted_fields', {})
    iam = ef.get('IamInstanceProfile', '__absent__')
    
    uid = asset.resource_uid
    if uid in assets_by_uid:
        existing = assets_by_uid[uid]
        existing_ef = existing.metadata.get('emitted_fields', {})
        existing.metadata['emitted_fields'] = _smart_merge(existing_ef, ef)
        merged_iam = existing.metadata['emitted_fields'].get('IamInstanceProfile', '__absent__')
        print(f'  MERGE {disc_id}: iam_in={iam!r} -> merged_iam={merged_iam!r}')
    else:
        assets_by_uid[uid] = asset
        print(f'  CREATE {disc_id}: uid={uid[-30:]} iam={iam!r}')

print()
final = list(assets_by_uid.values())[0]
print('FINAL IamInstanceProfile:', final.metadata.get('emitted_fields', {}).get('IamInstanceProfile'))
