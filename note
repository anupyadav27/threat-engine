Bash Cross-reference scan_runs with discovery_findings counts
IN
kubectl exec -n threat-engine-engines deploy/engine-inventory -- python3 -c "
import os, psycopg2
# Get scan_run_ids from scan_runs table
conn = psycopg2.connect(host=os.environ['ONBOARDING_DB_HOST'], port=5432, dbname=os.environ['ONBOARDING_DB_NAME'], user=os.environ['ONBOARDING_DB_USER'], password=os.environ['ONBOARDING_DB_PASSWORD'])
cur = conn.cursor()
cur.execute('SELECT scan_run_id, tenant_id, created_at FROM scan_runs ORDER BY created_at DESC LIMIT 10')
scan_runs = cur.fetchall()
conn.close()

disc_host = os.environ.get('DISCOVERIES_DB_HOST', os.environ.get('ONBOARDING_DB_HOST'))
conn2 = psycopg2.connect(host=disc_host, port=5432, dbname='threat_engine_discoveries', user=os.environ['ONBOARDING_DB_USER'], password=os.environ['ONBOARDING_DB_PASSWORD'])
cur2 = conn2.cursor()

for sr in scan_runs:
    cur2.execute('SELECT count(*) FROM discovery_findings WHERE scan_run_id=%s', (sr[0],))
    cnt = cur2.fetchone()[0]
    print(f'{sr[0]} tenant={sr[1]} cnt={cnt}')
conn2.close()
" 2>&1

