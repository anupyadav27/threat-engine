  "source": {
    "operation_registry": "services/datafactory/operation_registry.json",
    "read_ops_rule": "kind is read_list (seed) or read_get (enriched)",
    "excluded_keys": [
      "next_link",
      "nextLink",
      "continuation_token",
      "value",
      "skip_token",
      "max_results",
      "top",
      "skip"
    ]
  },
  "fields": {
    "Version": {
      "operators": [
        "equals",
        "not_equals"
      ],
      "dependency_index_entity": "datafactory.item_policy",
      "type": "string"
    },
    "Statement": {
      "operators": [
        "contains"
      ],
      "dependency_index_entity": "datafactory.item_policy",
      "type": "array"
    },
    "Enabled": {
      "operators": [
        "equals",
        "not_equals"
      ],
      "dependency_index_entity": "datafactory.item_properties",
      "type": "boolean"
    },
    "Status": {
      "operators": [
        "equals",
        "not_equals",
        "in"
      ],
      "dependency_index_entity": "datafactory.item_properties",
      "type": "string"
    },
    "Type": {
      "operators": [
        "equals",
        "not_equals",
        "in"
      ],
      "dependency_index_entity": "datafactory.item_identity",
      "type": "string"
    },
    "PrincipalId": {
      "operators": [
        "equals",
        "not_equals",
        "contains"
      ],
      "dependency_index_entity": "datafactory.item_identity",
      "type": "string"
    },
    "KeySource": {
      "operators": [
        "equals",
        "not_equals",
        "in"
      ],
      "dependency_index_entity": "datafactory.item_encryption",
      "type": "string"
    },
    "KeyVaultProperties": {
      "operators": [
        "equals",
        "not_equals"
      ],
      "dependency_index_entity": "datafactory.item_encryption",
      "type": "object"
    }
  }
}