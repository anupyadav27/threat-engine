  "source": {
    "operation_registry": "services/iothub/operation_registry.json",
    "read_ops_rule": "kind is read_list (seed) or read_get (enriched)",
    "excluded_keys": [
      "next_link",
      "nextLink",
      "continuation_token",
      "value",
      "skip_token",
      "max_results",
      "top",
      "skip"
    ]
  },
  "fields": {
    "Enabled": {
      "operators": [
        "equals",
        "not_equals"
      ],
      "dependency_index_entity": "iothub.item_properties",
      "type": "boolean"
    },
    "Status": {
      "operators": [
        "equals",
        "not_equals",
        "in"
      ],
      "dependency_index_entity": "iothub.item_properties",
      "type": "string"
    },
    "Name": {
      "operators": [
        "equals",
        "not_equals",
        "in"
      ],
      "dependency_index_entity": "iothub.item_sku",
      "type": "string"
    },
    "Tier": {
      "operators": [
        "equals",
        "not_equals",
        "in"
      ],
      "dependency_index_entity": "iothub.item_sku",
      "type": "string"
    }
  }
}