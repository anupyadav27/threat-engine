  "source": {
    "operation_registry": "services/cosmosdb/operation_registry.json",
    "read_ops_rule": "kind is read_list (seed) or read_get (enriched)",
    "excluded_keys": [
      "next_link",
      "nextLink",
      "continuation_token",
      "value",
      "skip_token",
      "max_results",
      "top",
      "skip"
    ]
  },
  "fields": {
    "Type": {
      "operators": [
        "equals",
        "not_equals",
        "in"
      ],
      "dependency_index_entity": "cosmosdb.item_identity",
      "type": "string"
    },
    "PrincipalId": {
      "operators": [
        "equals",
        "not_equals",
        "contains"
      ],
      "dependency_index_entity": "cosmosdb.item_identity",
      "type": "string"
    },
    "Enabled": {
      "operators": [
        "equals",
        "not_equals"
      ],
      "dependency_index_entity": "cosmosdb.item_properties",
      "type": "boolean"
    },
    "Status": {
      "operators": [
        "equals",
        "not_equals",
        "in"
      ],
      "dependency_index_entity": "cosmosdb.item_properties",
      "type": "string"
    },
    "Version": {
      "operators": [
        "equals",
        "not_equals"
      ],
      "dependency_index_entity": "cosmosdb.item_consistency_policy",
      "type": "string"
    },
    "Statement": {
      "operators": [
        "contains"
      ],
      "dependency_index_entity": "cosmosdb.item_consistency_policy",
      "type": "array"
    }
  }
