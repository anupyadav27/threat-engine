{
  "service": "relay",
  "seed_from_list": [
    "Name",
    "Tier",
    "key_name",
    "primary_connection_string",
    "primary_key",
    "secondary_connection_string",
    "secondary_key"
  ],
  "enriched_from_get_describe": [
    "id",
    "name",
    "rights",
    "type"
  ],
  "final_union": [
    "Name",
    "Tier",
    "id",
    "key_name",
    "name",
    "primary_connection_string",
    "primary_key",
    "rights",
    "secondary_connection_string",
    "secondary_key",
    "type"
  ],
  "source": {
    "operation_registry": "services/relay/operation_registry.json",
    "read_ops_rule": "kind is read_list (seed) or read_get (enriched)",
    "excluded_keys": [
      "next_link",
      "nextLink",
      "continuation_token",
      "value",
      "skip_token",
      "max_results",
      "top",
      "skip"
    ]
  },
  "fields": {
    "Name": {
      "operators": [
        "equals",
        "not_equals",
        "in"
      ],
      "dependency_index_entity": "relay.item_sku",
      "type": "string"
    },
    "Tier": {
      "operators": [
        "equals",
        "not_equals",
        "in"
      ],
      "dependency_index_entity": "relay.item_sku",
      "type": "string"
    }
  }
