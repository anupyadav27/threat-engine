  "source": {
    "operation_registry": "services/synapse/operation_registry.json",
    "read_ops_rule": "kind is read_list (seed) or read_get (enriched)",
    "excluded_keys": [
      "next_link",
      "nextLink",
      "continuation_token",
      "value",
      "skip_token",
      "max_results",
      "top",
      "skip"
    ]
  },
  "fields": {
    "Enabled": {
      "operators": [
        "equals",
        "not_equals"
      ],
      "dependency_index_entity": "synapse.item_spark_config_properties",
      "type": "boolean"
    },
    "Status": {
      "operators": [
        "equals",
        "not_equals",
        "in"
      ],
      "dependency_index_entity": "synapse.item_spark_config_properties",
      "type": "string"
    },
    "Name": {
      "operators": [
        "equals",
        "not_equals",
        "in"
      ],
      "dependency_index_entity": "synapse.item_sku",
      "type": "string"
    },
    "Tier": {
      "operators": [
        "equals",
        "not_equals",
        "in"
      ],
      "dependency_index_entity": "synapse.item_sku",
      "type": "string"
    },
    "Type": {
      "operators": [
        "equals",
        "not_equals",
        "in"
      ],
      "dependency_index_entity": "synapse.item_grant_sql_control_to_managed_identity",
      "type": "string"
    },
    "PrincipalId": {
      "operators": [
        "equals",
        "not_equals",
        "contains"
      ],
      "dependency_index_entity": "synapse.item_grant_sql_control_to_managed_identity",
      "type": "string"
    },
    "KeySource": {
      "operators": [
        "equals",
        "not_equals",
        "in"
      ],
      "dependency_index_entity": "synapse.item_encryption",
      "type": "string"
    },
    "KeyVaultProperties": {
      "operators": [
        "equals",
        "not_equals"
      ],
      "dependency_index_entity": "synapse.item_encryption",
      "type": "object"
    },
    "Level": {
      "operators": [
        "equals",
        "not_equals",
        "in"
      ],
      "dependency_index_entity": "synapse.item_managed_virtual_network_settings",
      "type": "string"
    },
    "Format": {
      "operators": [
        "equals",
        "not_equals",
        "contains"
      ],
      "dependency_index_entity": "synapse.item_managed_virtual_network_settings",
      "type": "string"
    },
    "DestinationArn": {
      "operators": [
        "equals",
        "not_equals",
        "contains"
      ],
      "dependency_index_entity": "synapse.item_managed_virtual_network_settings",
      "type": "string"
    }
  }
}