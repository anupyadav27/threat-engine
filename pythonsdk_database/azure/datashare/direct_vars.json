{
  "service": "datashare",
  "seed_from_list": [
    "PrincipalId",
    "Type"
  ],
  "enriched_from_get_describe": [
    "consumer_email",
    "consumer_name",
    "consumer_tenant_name",
    "created_at",
    "expiration_date",
    "id",
    "name",
    "provider_email",
    "provider_name",
    "share_subscription_object_id",
    "share_subscription_status",
    "shared_at",
    "system_data",
    "type"
  ],
  "final_union": [
    "PrincipalId",
    "Type",
    "consumer_email",
    "consumer_name",
    "consumer_tenant_name",
    "created_at",
    "expiration_date",
    "id",
    "name",
    "provider_email",
    "provider_name",
    "share_subscription_object_id",
    "share_subscription_status",
    "shared_at",
    "system_data",
    "type"
  ],
  "source": {
    "operation_registry": "services/datashare/operation_registry.json",
    "read_ops_rule": "kind is read_list (seed) or read_get (enriched)",
    "excluded_keys": [
      "next_link",
      "nextLink",
      "continuation_token",
      "value",
      "skip_token",
      "max_results",
      "top",
      "skip"
    ]
  },
  "fields": {
    "Type": {
      "operators": [
        "equals",
        "not_equals",
        "in"
      ],
      "dependency_index_entity": "datashare.item_identity",
      "type": "string"
    },
    "PrincipalId": {
      "operators": [
        "equals",
        "not_equals",
        "contains"
      ],
      "dependency_index_entity": "datashare.item_identity",
      "type": "string"
    }
  }
}