{
  "service": "purview",
  "seed_from_list": [
    "Name",
    "PrincipalId",
    "Tier",
    "Type",
    "atlas_kafka_primary_endpoint",
    "atlas_kafka_secondary_endpoint",
    "count"
  ],
  "enriched_from_get_describe": [
    "id",
    "name",
    "properties",
    "type"
  ],
  "final_union": [
    "Name",
    "PrincipalId",
    "Tier",
    "Type",
    "atlas_kafka_primary_endpoint",
    "atlas_kafka_secondary_endpoint",
    "count",
    "id",
    "name",
    "properties",
    "type"
  ],
  "source": {
    "operation_registry": "services/purview/operation_registry.json",
    "read_ops_rule": "kind is read_list (seed) or read_get (enriched)",
    "excluded_keys": [
      "next_link",
      "nextLink",
      "continuation_token",
      "value",
      "skip_token",
      "max_results",
      "top",
      "skip"
    ]
  },
  "fields": {
    "Type": {
      "operators": [
        "equals",
        "not_equals",
        "in"
      ],
      "dependency_index_entity": "purview.item_identity",
      "type": "string"
    },
    "PrincipalId": {
      "operators": [
        "equals",
        "not_equals",
        "contains"
      ],
      "dependency_index_entity": "purview.item_identity",
      "type": "string"
    },
    "Name": {
      "operators": [
        "equals",
        "not_equals",
        "in"
      ],
      "dependency_index_entity": "purview.item_sku",
      "type": "string"
    },
    "Tier": {
      "operators": [
        "equals",
        "not_equals",
        "in"
      ],
      "dependency_index_entity": "purview.item_sku",
      "type": "string"
    }
  }
}