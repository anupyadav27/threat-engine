version: '1.0'
provider: aws
service: parameterstore
services:
  client: ssm
  module: boto3.client
discovery:
- discovery_id: aws.ssm.describe_parameters
  calls:
  - action: describe_parameters
    save_as: response
  emit:
    items_for: '{{ response.Parameters }}'
    as: item
    item:
      Name: '{{ item.Name }}'
      ARN: '{{ item.ARN }}'
      Type: '{{ item.Type }}'
      KeyId: '{{ item.KeyId }}'
      LastModifiedDate: '{{ item.LastModifiedDate }}'
      LastModifiedUser: '{{ item.LastModifiedUser }}'
      Description: '{{ item.Description }}'
      AllowedPattern: '{{ item.AllowedPattern }}'
      Version: '{{ item.Version }}'
      Tier: '{{ item.Tier }}'
      Policies: '{{ item.Policies }}'
      DataType: '{{ item.DataType }}'
checks:
- rule_id: aws.parameterstore.parameter.kms_encryption_enabled
  for_each: aws.ssm.describe_parameters
  conditions:
    var: item.KeyId
    op: exists
    value: null
- rule_id: aws.parameterstore.parameter.kms_key_configured
  for_each: aws.ssm.describe_parameters
  conditions:
    var: item.KeyId
    op: exists
    value: null
- rule_id: aws.parameterstore.parameter.rotation_enabled_for_rotatable_secrets
  for_each: aws.ssm.describe_parameters
  conditions:
    var: item.Tier
    op: equals
    value: Advanced
- rule_id: aws.parameterstore.parameter.rbac_least_privilege
  for_each: aws.ssm.describe_parameters
  conditions:
    all:
    - var: item.Policies
      op: exists
      value: null
    - var: item.Policies.PolicyType
      op: equals
      value: IAMPolicy
    - var: item.Policies.PolicyText.Statement.Effect
      op: equals
      value: Allow
    - var: item.Policies.PolicyText.Statement.Action
      op: in
      value:
      - ssm:GetParameter
      - ssm:PutParameter
      - ssm:DeleteParameter
    - var: item.Policies.PolicyText.Statement.Resource
      op: equals
      value: arn:aws:ssm:*:*:parameter/*
- rule_id: aws.parameterstore.parameter.parameterstore_secure_string_type_for_sensitive_configured
  for_each: aws.ssm.describe_parameters
  conditions:
    var: item.Type
    op: equals
    value: SecureString

