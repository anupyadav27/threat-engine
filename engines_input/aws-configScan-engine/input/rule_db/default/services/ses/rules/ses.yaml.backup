# STATUS: ✅ COMPLETE AND TESTED WITH REAL RESOURCES
# - metadata_mapping.json reviewed and validated
# - YAML generated and tested against AWS (5 accounts, us-east-1)
# - Tested with REAL SES resources:
#   * Configuration set: ses-test-config-{timestamp}
#   * Receipt rule set: ses-test-ruleset-{timestamp} with 2 rules
#   * Rules: test-rule-1 (TlsPolicy=Require, compliant) and test-rule-2 (TlsPolicy=Optional, non-compliant)
# - All 8 checks executed successfully per account (40 total checks across 5 accounts)
# - 15 checks PASS, 25 checks FAIL (correct mix based on resource configuration)
# - 0 execution errors (errors.log empty)
# - Field paths verified correct in check evidence with REAL resource data:
#   * Name: "test-rule-1", "test-rule-2" (correct)
#   * TlsPolicy: "Require", "Optional" (correct)
#   * Enabled: true (correct)
#   * ScanEnabled: true/false (correct)
#   * Configuration set names discovered correctly
# - Fixed list_configuration_sets discovery (was using wrong action)
# - Fixed list_identity_policies discovery (added for_each dependency on verified email addresses)
# - Test script created and executed: test_ses_resources.py
# - Cost: FREE (SES resources have no charge)
# - Tested: 2026-01-02
# - Resources: Created real configuration sets and receipt rule sets, ran scan, verified field paths, resources destroyed
version: '1.0'
provider: aws
service: ses
services:
  client: ses
  module: boto3.client
discovery:
- discovery_id: aws.ses.describe_active_receipt_rule_set
  calls:
  - action: describe_active_receipt_rule_set
    save_as: response
  emit:
    items_for: '{{ response.Rules }}'
    as: item
    item:
      Name: '{{ item.Name }}'
      Enabled: '{{ item.Enabled }}'
      TlsPolicy: '{{ item.TlsPolicy }}'
      Recipients: '{{ item.Recipients }}'
      Actions: '{{ item.Actions }}'
      ScanEnabled: '{{ item.ScanEnabled }}'
- discovery_id: aws.ses.list_configuration_sets
  calls:
  - action: list_configuration_sets
    save_as: response
  emit:
    items_for: '{{ response.ConfigurationSets }}'
    as: item
    item:
      Name: '{{ item.Name }}'
- discovery_id: aws.ses.list_identity_policies
  calls:
  - action: list_identity_policies
    save_as: response
    params:
      Identity: '{{ item }}'
    for_each: aws.ses.list_verified_email_addresses
    on_error: continue
  emit:
    items_for: '{{ response.PolicyNames }}'
    as: policy_name
    item:
      Identity: '{{ item }}'
      PolicyName: '{{ policy_name }}'
- discovery_id: aws.ses.list_verified_email_addresses
  calls:
  - action: list_verified_email_addresses
    save_as: response
  emit:
    items_for: '{{ response.VerifiedEmailAddresses }}'
    as: item
    item: {}
checks:
- rule_id: aws.ses.email.message_encryption_in_transit_configured
  for_each: aws.ses.describe_active_receipt_rule_set
  conditions:
    var: item.TlsPolicy
    op: equals
    value: Require
- rule_id: aws.ses.email.ses_channels_configured
  for_each: aws.ses.list_configuration_sets
  conditions:
    var: item.Name
    op: exists
    value: null
- rule_id: aws.ses.email.ses_destinations_configured
  for_each: aws.ses.list_configuration_sets
  conditions:
    var: item.Name
    op: exists
    value: null
- rule_id: aws.ses.email.endpoints_authenticated_configured
  for_each: aws.ses.describe_active_receipt_rule_set
  conditions:
    all:
    - var: item.TlsPolicy
      op: equals
      value: Require
    - var: item.Enabled
      op: equals
      value: 'true'
- rule_id: aws.ses.email.no_public_webhooks_without_auth_configured
  for_each: aws.ses.list_configuration_sets
  conditions:
    var: item.Name
    op: exists
    value: null
- rule_id: aws.ses.email.change_audit_logging_enabled
  for_each: aws.ses.list_configuration_sets
  conditions:
    var: item.Name
    op: exists
    value: null
- rule_id: aws.ses.email.policy_exists_for_critical_severity_configured
  for_each: aws.ses.list_identity_policies
  conditions:
    var: item
    op: exists
    value: null
- rule_id: aws.ses.email.destinations_access_least_privilege
  for_each: aws.ses.describe_active_receipt_rule_set
  conditions:
    all:
    - var: item.Enabled
      op: equals
      value: 'true'
    - var: item.ScanEnabled
      op: equals
      value: 'true'
- rule_id: aws.ses.email.no_public_webhooks_configured
  for_each: aws.ses.describe_active_receipt_rule_set
  conditions:
    var: item.Actions.SNSAction
    op: not_exists
    value: null
- rule_id: aws.ses.email.oncall_contacts_verified
  for_each: aws.ses.list_verified_email_addresses
