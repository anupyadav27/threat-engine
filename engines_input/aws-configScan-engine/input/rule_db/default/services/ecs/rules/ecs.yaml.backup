# - metadata_mapping.json created and reviewed
# - YAML generated and tested against AWS
# - All 8 checks executed successfully (5 accounts, 30 total checks)
# - 0 execution errors
# - Tested: 2026-01-01
version: '1.0'
provider: aws
service: ecs
services:
  client: ecs
  module: boto3.client
discovery:
- discovery_id: aws.ecs.list_task_definitions
  calls:
  - action: list_task_definitions
    save_as: response
  emit:
    items_for: '{{ response.taskDefinitionArns }}'
    as: item
    item:
      taskDefinitionArn: '{{ item }}'
- discovery_id: aws.ecs.describe_task_definition
  for_each: aws.ecs.list_task_definitions
  calls:
  - action: describe_task_definition
    params:
      taskDefinition: '{{ item.taskDefinitionArn }}'
    save_as: response
  emit:
    item:
      taskDefinitionArn: '{{ item.taskDefinitionArn }}'
      taskDefinition: '{{ response.taskDefinition }}'
- discovery_id: aws.ecs.list_services
  calls:
  - action: list_services
    save_as: response
  emit:
    items_for: '{{ response.serviceArns }}'
    as: item
    item:
      serviceArn: '{{ item }}'
- discovery_id: aws.ecs.describe_services
  for_each: aws.ecs.list_services
  calls:
  - action: describe_services
    params:
      services: ['{{ item.serviceArn }}']
    save_as: response
  emit:
    items_for: '{{ response.services }}'
    as: item
    item:
      serviceArn: '{{ item.serviceArn }}'
      serviceName: '{{ item.serviceName }}'
      clusterArn: '{{ item.clusterArn }}'
      networkConfiguration: '{{ item.networkConfiguration }}'
- discovery_id: aws.ecs.list_account_settings
  calls:
  - action: list_account_settings
    save_as: response
  emit:
    items_for: '{{ response.settings }}'
    as: item
    item:
      name: '{{ item.name }}'
      value: '{{ item.value }}'
      principalArn: '{{ item.principalArn }}'
      type: '{{ item.type }}'
checks:
- rule_id: aws.ecs.resource.task_definition_logging_enabled
  for_each: aws.ecs.describe_task_definition
  conditions:
    var: item.taskDefinition.containerDefinitions[].logConfiguration
    op: exists
    value: null
- rule_id: aws.ecs.resource.task_definitions_logging_enabled
  for_each: aws.ecs.describe_task_definition
  conditions:
    var: item.taskDefinition.containerDefinitions[].logConfiguration
    op: exists
    value: null
- rule_id: aws.ecs.task_definitions_logging_block_mode.task_definitions_logging_block_mode_configured
  for_each: aws.ecs.list_account_settings
  conditions:
    var: item.value
    op: equals
    value: block
    when:
      var: item.name
      op: equals
      value: defaultLogDriverMode
- rule_id: aws.ecs.resource.task_sets_assign_public_ip_disabled
  for_each: aws.ecs.describe_services
  conditions:
    var: item.networkConfiguration.awsvpcConfiguration.assignPublicIp
    op: equals
    value: DISABLED
- rule_id: aws.ecs.container_instance.no_privileged_containers_configured
  for_each: aws.ecs.describe_task_definition
  conditions:
    var: item.taskDefinition.containerDefinitions[].privileged
    op: equals
    value: false
- rule_id: aws.ecs.container_instance.container_read_only_root_filesystem_configured
  for_each: aws.ecs.describe_task_definition
  conditions:
    var: item.taskDefinition.containerDefinitions[].readonlyRootFilesystem
    op: equals
    value: true
- rule_id: aws.ecs.container_instance.container_env_no_plaintext_secrets_configured
  for_each: aws.ecs.describe_task_definition
  conditions:
    var: item.taskDefinition.containerDefinitions[].secrets
    op: exists
    value: null
- rule_id: aws.ecs.task_definition_image_source_verification.task_ecs_task_definition_image_source_verification_configured
  for_each: aws.ecs.describe_task_definition
  conditions:
    var: item.taskDefinition.containerDefinitions[].image
    op: exists
    value: null
