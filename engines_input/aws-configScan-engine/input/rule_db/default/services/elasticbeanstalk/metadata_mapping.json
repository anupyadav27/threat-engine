      "response_path": "ConfigurationSettings[].OptionSettings",
      "logical_operator": "all",
      "nested_field": [
        {
          "field_path": "OptionSettings[].Namespace",
          "expected_value": "aws:elasticbeanstalk:application:environment",
          "operator": "equals"
        },
        {
          "field_path": "OptionSettings[].OptionName",
          "expected_value": "SecretsManagerSecret",
          "operator": "equals"
        },
        {
          "field_path": "OptionSettings[].Value",
          "expected_value": null,
          "operator": "exists"
        }
      ],
      "note": "Uses environment-level discovery because describe_configuration_settings requires EnvironmentName"
    },
