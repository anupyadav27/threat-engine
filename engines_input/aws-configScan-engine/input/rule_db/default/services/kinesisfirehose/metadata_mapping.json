{
  "kinesisfirehose_metadata_mapping": [
    {
      "rule_id": "aws.kinesisfirehose.deliverystream.consumer_auth_required",
      "python_method": "describe_delivery_stream",
      "response_path": "DeliveryStreamDescription.Destinations[]",
      "logical_operator": "all",
      "nested_field": [
        {
          "field_path": "ExtendedS3DestinationDescription.DataFormatConversionConfiguration.Enabled",
          "expected_value": true,
          "operator": "equals"
        },
        {
          "field_path": "ExtendedS3DestinationDescription.ProcessingConfiguration.Enabled",
          "expected_value": true,
          "operator": "equals"
        }
      ]
    },
    {
      "rule_id": "aws.kinesisfirehose.deliverystream.encryption_at_rest_enabled",
      "python_method": "describe_delivery_stream",
      "response_path": "DeliveryStreamDescription.DeliveryStreamEncryptionConfiguration",
      "logical_operator": "all",
      "nested_field": [
        {
          "field_path": "DeliveryStreamEncryptionConfiguration.Status",
          "expected_value": "ENABLED",
          "operator": "equals"
        },
        {
          "field_path": "DeliveryStreamEncryptionConfiguration.KeyType",
          "expected_value": [
            "CUSTOMER_MANAGED_CMK",
            "AWS_OWNED_CMK"
          ],
          "operator": "in"
        }
      ]
    },
    {
      "rule_id": "aws.kinesisfirehose.deliverystream.kinesisfirehose_destination_least_privilege",
      "python_method": "describe_delivery_stream",
      "response_path": "DeliveryStreamDescription.Destinations[]",
      "logical_operator": "all",
      "nested_field": [
        {
          "field_path": "DestinationDescription.RoleARN",
          "expected_value": null,
          "operator": "exists"
        },
        {
          "field_path": "DestinationDescription.RoleARN",
          "expected_value": "arn:aws:iam::123456789012:role/KinesisFirehoseServiceRole",
          "operator": "equals"
        }
      ]
    },
    {
      "rule_id": "aws.kinesisfirehose.deliverystream.logging_enabled",
      "python_method": "describe_delivery_stream",
      "response_path": "DeliveryStreamDescription.DeliveryStreamStatus",
      "logical_operator": "all",
      "nested_field": [
        {
          "field_path": "DeliveryStreamDescription.DeliveryStreamStatus",
          "expected_value": "ACTIVE",
          "operator": "equals"
        },
        {
          "field_path": "DeliveryStreamDescription.DeliveryStreamType",
          "expected_value": null,
          "operator": "exists"
        },
        {
          "field_path": "DeliveryStreamDescription.Destinations[].ExtendedS3DestinationDescription.CloudWatchLoggingOptions.Enabled",
          "expected_value": true,
          "operator": "equals"
        }
      ]
    },
    {
      "rule_id": "aws.kinesisfirehose.deliverystream.private_network_only_if_supported",
      "python_method": "describe_delivery_stream",
      "response_path": "DeliveryStreamDescription.Destinations[]",
      "logical_operator": "all",
      "nested_field": [
        {
          "field_path": "DestinationDescription.ExtendedS3DestinationDescription.VpcConfiguration",
          "expected_value": null,
          "operator": "exists"
        },
        {
          "field_path": "DestinationDescription.ExtendedS3DestinationDescription.VpcConfiguration.SubnetIds",
          "expected_value": null,
          "operator": "exists"
        },
        {
          "field_path": "DestinationDescription.ExtendedS3DestinationDescription.VpcConfiguration.RoleARN",
          "expected_value": null,
          "operator": "exists"
        }
      ]
    },
    {
      "rule_id": "aws.kinesisfirehose.deliverystream.kinesisfirehose_destination_encrypted",
      "python_method": "describe_delivery_stream",
      "response_path": "DeliveryStreamDescription.Destinations[]",
      "logical_operator": "all",
      "nested_field": [
        {
          "field_path": "ExtendedS3DestinationDescription.EncryptionConfiguration.NoEncryptionConfig",
          "expected_value": "NoEncryption",
          "operator": "not_equals"
        },
        {
          "field_path": "ExtendedS3DestinationDescription.EncryptionConfiguration.KMSEncryptionConfig.AWSKMSKeyARN",
          "expected_value": null,
          "operator": "exists"
        }
      ]
    }
  ]
}