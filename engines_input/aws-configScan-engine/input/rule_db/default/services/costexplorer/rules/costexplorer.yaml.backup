version: '1.0'
provider: aws
service: costexplorer
services:
  client: costexplorer
  module: boto3.client
discovery:
- discovery_id: aws.ce.get_anomaly_subscriptions
  calls:
  - action: get_anomaly_subscriptions
    save_as: response
  emit:
    items_for: '{{ response.AnomalySubscriptions }}'
    as: item
    item:
      SubscriptionArn: '{{ item.SubscriptionArn }}'
      AccountId: '{{ item.AccountId }}'
      MonitorArnList: '{{ item.MonitorArnList }}'
      Subscribers: '{{ item.Subscribers }}'
      Threshold: '{{ item.Threshold }}'
      Frequency: '{{ item.Frequency }}'
      SubscriptionName: '{{ item.SubscriptionName }}'
      ThresholdExpression: '{{ item.ThresholdExpression }}'
- discovery_id: aws.ce.get_anomaly_monitors
  calls:
  - action: get_anomaly_monitors
    save_as: response
  emit:
    items_for: '{{ response.AnomalyMonitors }}'
    as: item
    item:
      MonitorArn: '{{ item.MonitorArn }}'
      MonitorName: '{{ item.MonitorName }}'
      CreationDate: '{{ item.CreationDate }}'
      LastUpdatedDate: '{{ item.LastUpdatedDate }}'
      LastEvaluatedDate: '{{ item.LastEvaluatedDate }}'
      MonitorType: '{{ item.MonitorType }}'
      MonitorDimension: '{{ item.MonitorDimension }}'
      MonitorSpecification: '{{ item.MonitorSpecification }}'
      DimensionalValueCount: '{{ item.DimensionalValueCount }}'
- discovery_id: aws.ce.list_cost_allocation_tags
  calls:
  - action: list_cost_allocation_tags
    save_as: response
  emit:
    items_for: '{{ response.CostAllocationTags }}'
    as: item
    item:
      TagKey: '{{ item.TagKey }}'
      Type: '{{ item.Type }}'
      Status: '{{ item.Status }}'
      LastUpdatedDate: '{{ item.LastUpdatedDate }}'
      LastUsedDate: '{{ item.LastUsedDate }}'
- discovery_id: aws.ce.list_cost_category_definitions
  calls:
  - action: list_cost_category_definitions
    save_as: response
  emit:
    items_for: '{{ response.CostCategoryReferences }}'
    as: item
    item:
      CostCategoryArn: '{{ item.CostCategoryArn }}'
      Name: '{{ item.Name }}'
      EffectiveStart: '{{ item.EffectiveStart }}'
      EffectiveEnd: '{{ item.EffectiveEnd }}'
      NumberOfRules: '{{ item.NumberOfRules }}'
      ProcessingStatus: '{{ item.ProcessingStatus }}'
      Values: '{{ item.Values }}'
      DefaultValue: '{{ item.DefaultValue }}'
- discovery_id: aws.ce.describe_cost_category_definition
  for_each: aws.ce.list_cost_category_definitions
  calls:
  - action: describe_cost_category_definition
    params:
      CostCategoryArn: '{{ item.CostCategoryArn }}'
    save_as: response
  emit:
    item:
      CostCategoryArn: '{{ response.CostCategory.CostCategoryArn }}'
      Name: '{{ response.CostCategory.Name }}'
      EffectiveStart: '{{ response.CostCategory.EffectiveStart }}'
      EffectiveEnd: '{{ response.CostCategory.EffectiveEnd }}'
      RuleVersion: '{{ response.CostCategory.RuleVersion }}'
      Rules: '{{ response.CostCategory.Rules }}'
      ProcessingStatus: '{{ response.CostCategory.ProcessingStatus }}'
      DefaultValue: '{{ response.CostCategory.DefaultValue }}'
checks:
- rule_id: aws.costexplorer.anomalydetector.alert_destinations_configured
  for_each: aws.ce.get_anomaly_subscriptions
  conditions:
    var: item.Subscribers
    op: exists
    value: null
- rule_id: aws.costexplorer.anomalydetector.costexplorer_detectors_enabled
  for_each: aws.ce.get_anomaly_monitors
  conditions:
    var: item.MonitorArn
    op: exists
    value: null
- rule_id: aws.costexplorer.anomalydetector.costexplorer_severity_thresholds_configured
  for_each: aws.ce.get_anomaly_subscriptions
  conditions:
    all:
    - var: item.Threshold
      op: exists
      value: null
    - var: item.ThresholdExpression
      op: exists
      value: null
- rule_id: aws.costexplorer.cost_allocation_tag.cost_tag_policy_enforced
  for_each: aws.ce.list_cost_allocation_tags
  conditions:
    all:
    - var: item.Status
      op: equals
      value: Active
    - var: item.Type
      op: equals
      value: CostAllocationTag
- rule_id: aws.costexplorer.cost_allocation_tag.costexplorer_required_cost_tags_present
  for_each: aws.ce.list_cost_allocation_tags
  conditions:
    all:
    - var: item.TagKey
      op: exists
      value: null
    - var: item.Status
      op: equals
      value: Active
- rule_id: aws.costexplorer.cost_allocation_tag.untagged_resource_alerts_enabled
  for_each: aws.ce.list_cost_allocation_tags
  conditions:
    var: item.Status
    op: equals
    value: Active
- rule_id: aws.costexplorer.costcategory.billing_admins_mfa_required
  for_each: aws.ce.list_cost_category_definitions
  conditions:
    var: item.CostCategoryArn
    op: exists
    value: null
- rule_id: aws.costexplorer.costcategory.billing_console_rbac_least_privilege
  for_each: aws.ce.list_cost_category_definitions
  conditions:
    all:
    - var: item.CostCategoryArn
      op: exists
      value: null
    - var: item.Name
      op: exists
      value: null
    - var: item.NumberOfRules
      op: greater_than
      value: '0'
- rule_id: aws.costexplorer.costcategory.costexplorer_cost_data_exports_private_and_encrypted
  for_each: aws.ce.describe_cost_category_definition
  conditions:
    all:
    - var: item.ProcessingStatus
      op: equals
      value: ENCRYPTED
    - var: item.DefaultValue
      op: equals
      value: PRIVATE
- rule_id: aws.costexplorer.costcategory.costexplorer_cost_export_destinations_least_privilege
  for_each: aws.ce.list_cost_category_definitions
  conditions:
    all:
    - var: item.CostCategoryArn
      op: exists
      value: null
    - var: item.Name
      op: exists
      value: null
    - var: item.NumberOfRules
      op: greater_than
      value: '0'

# STATUS: ✅ VALIDATED AND TESTED
