# Database Configuration
# Copy this to .env and update with your values

# Local PostgreSQL
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres

# Compliance Engine Database
COMPLIANCE_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/compliance_engine

# Onboarding Engine Database
ONBOARDING_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/threat_engine

# AWS RDS (for production)
# DATABASE_HOST=rds-endpoint.ap-south-1.rds.amazonaws.com
# DATABASE_PORT=5432
# DATABASE_USER=threatengine
# DATABASE_PASSWORD=your-secure-password

