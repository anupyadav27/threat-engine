# AWS Configuration
# Copy this to .env and update with your values

# AWS Region
AWS_REGION=ap-south-1

# S3 Configuration
S3_BUCKET=cspm-lgtech
S3_REGION=ap-south-1

# EKS Configuration
EKS_CLUSTER_NAME=vulnerability-eks-cluster
EKS_REGION=ap-south-1

# RDS Configuration (if using RDS)
# RDS_ENDPOINT=rds-endpoint.ap-south-1.rds.amazonaws.com
# RDS_PORT=5432
# RDS_DATABASE=threat_engine
# RDS_USERNAME=threatengine
# RDS_PASSWORD=your-secure-password

# IAM Roles (for IRSA)
# COMPLIANCE_ENGINE_ROLE_ARN=arn:aws:iam::ACCOUNT:role/compliance-engine-role
# ONBOARDING_ENGINE_ROLE_ARN=arn:aws:iam::ACCOUNT:role/onboarding-engine-role

