# Build from repo root: docker build -f deployment/aws/eks/jobs/Dockerfile.dbinit -t <registry>/threat-engine-db-init:latest .
FROM postgres:14-alpine
RUN apk add --no-cache bash
COPY consolidated_services/database /app/database
WORKDIR /app/database
ENV TE_DB_ROOT=/app/database
ENTRYPOINT ["/bin/sh", "scripts/init_rds_for_eks.sh"]
